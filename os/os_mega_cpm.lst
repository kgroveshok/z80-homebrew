0f52				push de 
0f52				push af 
0f52			 
0f52			 	or a      ;clear carry flag 
0f52				push hl 
0f52				ld de, 255 
0f52				sbc hl, de 
0f52				jr c, .lowallocx 
0f52			 
0f52				push de 
0f52					ld hl, display_fb0 
0f52					ld (display_fb_active), hl 
