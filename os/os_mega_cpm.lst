14d9			include "firmware_595shiftreg.asm"  
14d9			; common code for handling a 595 shift reg out on whatever output port 
14d9			 
14d9			; port in c 
14d9			; byte in a 
14d9			 
14d9			 
14d9			shift_bit_data: equ 0 
14d9			shift_bit_clk: equ 1 
14d9			shift_bit_latch: equ 2 
14d9			 
14d9			 
14d9			; shift out a byte to the sound chip 
14d9			 
14d9			; A contains byte to send 
14d9			 
14d9			shift_byte: 
14d9			 
14d9 06 08			ld b, 8   ; 8 bits to shift 
14db			 
14db 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
14dd			 
14dd				; set data bit state 
14dd			 
14dd cb 7f			bit 7, a 
14df				; high bit is set 
14df 28 02			jr z, .nb2 
14e1 cb c2			set shift_bit_data, d 
14e3			 
14e3				; set latches state  
14e3 cb ca		.nb2:	set shift_bit_clk, d 
14e5 cb 92			res shift_bit_latch, d    ; latch is inverted 
14e7 ed 51			out (c), d 
14e9				 
14e9				; clock the bit out 
14e9 cb 8a			res shift_bit_clk, d 
14eb ed 51			out (c), d 
14ed			 
14ed				; shift a left one bit and repeat 
14ed 17				rla 
14ee			 
14ee 10 eb			djnz .nb1 
14f0			 
14f0				; latch 
14f0 cb d2			set shift_bit_latch, d 
14f2 ed 51			out (c), d 
14f4					 
14f4			 
14f4				; set  
14f4 c9				ret 
# End of file firmware_595shiftreg.asm
