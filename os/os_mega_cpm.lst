0ecd			; Decimal Signed Version 
0ecd			 
0ecd			; DispA 
0ecd			; -------------------------------------------------------------- 
0ecd			; Converts a signed integer value to a zero-terminated ASCII 
0ecd			; string representative of that value (using radix 10). 
0ecd			; -------------------------------------------------------------- 
0ecd			; INPUTS: 
0ecd			;     HL     Value to convert (two's complement integer). 
0ecd			;     DE     Base address of string destination. (pointer). 
0ecd			; -------------------------------------------------------------- 
0ecd			; OUTPUTS: 
0ecd			;     None 
0ecd			; -------------------------------------------------------------- 
0ecd			; REGISTERS/MEMORY DESTROYED 
0ecd			; AF HL 
0ecd			; -------------------------------------------------------------- 
0ecd			 
0ecd			;DispHLToASCII: 
0ecd			;   push    de 
0ecd			;   push    bc 
0ecd			; 
0ecd			;; Detect sign of HL. 
0ecd			;    bit    7, h 
0ecd			;    jr     z, ._DoConvert 
0ecd			; 
0ecd			;; HL is negative. Output '-' to string and negate HL. 
0ecd			;    ld     a, '-' 
0ecd			;    ld     (de), a 
0ecd			;    inc    de 
0ecd			; 
0ecd			;; Negate HL (using two's complement) 
0ecd			;    xor    a 
0ecd			;    sub    l 
0ecd			;    ld     l, a 
0ecd			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
0ecd			;    sbc    a, h 
0ecd			;    ld     h, a 
0ecd			; 
0ecd			;; Convert HL to digit characters 
0ecd			;._DoConvert: 
0ecd			;    ld     b, 0     ; B will count character length of number 
0ecd			;-   ld     a, 10 
0ecd			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
0ecd			;    push   af 
0ecd			;    inc    b 
0ecd			;    ld     a, h 
0ecd			;    or     l 
0ecd			;    jr     nz, - 
0ecd			; 
0ecd			;; Retrieve digits from stack 
0ecd			;-   pop    af 
0ecd			;    or     $30 
0ecd			;    ld     (de), a 
0ecd			;    inc    de 
0ecd			;    djnz   - 
0ecd			; 
0ecd			;; Terminate string with NULL 
0ecd			;    xor    a 
0ecd			;    ld     (de), a 
0ecd			; 
0ecd			;    pop    bc 
0ecd			;    pop    de 
0ecd			;    ret 
0ecd			 
0ecd			;Comments 
0ecd			; 
0ecd			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
0ecd			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
0ecd			;    Note that the output string will not be fixed-width. 
0ecd			; 
0ecd			;Example Usage 
0ecd			; 
0ecd			;    ld    hl, -1004 
0ecd			;    ld    de, OP1 
0ecd			;    call  DispA 
0ecd			;    ld    hl, OP1 
0ecd			;    syscall  PutS 
