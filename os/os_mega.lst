6aa5			; Position cursor to specified location  
6aa5			;   On entry: A = Cursor position  
6aa5			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6aa5 f5			fLCD_Pos:   PUSH AF  
6aa6					; at this point set the E1 or E2 flag depending on position  
6aa6			  
6aa6 c5					push bc  
6aa7			;		push af  
6aa7 06 00				ld b, 0  
6aa9 4f					ld c, a  
6aaa 3e 4f				ld a, kLCD_Line3-1  
6aac b7			 		or a      ;clear carry flag  
6aad 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6aae 38 04				jr c, .pe1  
6ab0			  
6ab0					; E selection  
6ab0 cb 80				res 0, b         ; bit 0 unset e  
6ab2			;		pop af    ; before line 3 so recover orig pos  
6ab2			;		ld c, a    ; save for poking back  
6ab2 18 06				jr .peset	          
6ab4			.pe1:          	; E2 selection  
6ab4 cb c0				set 0, b         ; bit 0 set e1  
6ab6 79					ld a, c  
6ab7 de 4f				sbc a, kLCD_Line3-1  
6ab9 4f					ld c, a	         ; save caculated offset  
6aba			;		pop af     ; bin this original value now we have calculated form  
6aba			  
6aba			.peset:		; set bit  
6aba 78					ld a, b  
6abb 32 fb fa				ld (display_lcde1e2), a 	  
6abe 79					ld a, c  
6abf c1					pop bc  
6ac0			  
6ac0 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6ac2 cd 15 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ac5 f1			            POP  AF  
6ac6 c9			            RET  
6ac7			  
6ac7			  
6ac7			; Output text string to LCD  
6ac7			;   On entry: DE = Pointer to null terminated text string  
6ac7			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6ac7 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6ac8 b7			            OR   A              ;Null terminator?  
6ac9 c8			            RET  Z              ;Yes, so finished  
6aca cd 57 6a		            CALL fLCD_Data      ;Write character to display  
6acd 13			            INC  DE             ;Point to next character  
6ace 18 f7		            JR   fLCD_Str       ;Repeat  
6ad0 c9					ret  
6ad1			  
6ad1			; Define custom character  
6ad1			;   On entry: A = Character number (0 to 7)  
6ad1			;             DE = Pointer to character bitmap data  
6ad1			;   On exit:  A = Next character number  
6ad1			;             DE = Next location following bitmap  
6ad1			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6ad1			; Character is   
6ad1 c5			fLCD_Def:   PUSH BC  
6ad2 f5			            PUSH AF  
6ad3 07			            RLCA                ;Calculate location  
6ad4 07			            RLCA                ;  for bitmap data  
6ad5 07			            RLCA                ;  = 8 x CharacterNumber  
6ad6 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6ad8 cd 15 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6adb 06 00		            LD   B, 0  
6add 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6ade cd 57 6a		            CALL fLCD_Data      ;Write byte to display  
6ae1 13			            INC  DE             ;Point to next byte  
6ae2 04			            INC  B              ;Count bytes  
6ae3 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6ae5 28 f6		            JR   Z, Loop       ;No, so repeat  
6ae7 f1			            POP  AF  
6ae8 3c			            INC  A              ;Increment character number  
6ae9 c1			            POP  BC  
6aea c9			            RET  
