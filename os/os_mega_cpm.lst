100a e1			      pop   HL                      ; Discard previous result 
100b			 
100b dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
100e dd 66 03		      ld    H, (IX+3) 
1011 dd 75 04		      ld    (IX+4), L 
1014 dd 74 05		      ld    (IX+5), H 
1017			 
1017 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
101a dd 66 01		      ld    H, (IX+1) 
101d dd 75 02		      ld    (IX+2), L 
1020 dd 74 03		      ld    (IX+3), H 
1023			 
1023					if DEBUG_FORTH_MALLOC 
1023						DMARK "MA>" 
1023						CALLMONITOR 
1023					endif 
