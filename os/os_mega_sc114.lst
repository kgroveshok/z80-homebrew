8f38 23			      inc   HL 
8f39 56			      ld    D, (HL) 
8f3a eb			      ex    DE, HL 
8f3b			 
8f3b 09			      add   HL, BC                  ; Add addr of freed block and its size 
8f3c			 
8f3c dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
8f3f dd 56 01		      ld    D, (IX+1) 
