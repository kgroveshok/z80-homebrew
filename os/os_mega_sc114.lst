d27d			; stack over and underflow checks 
d27d			 
d27d			; init the words to detect the under/overflow 
d27d			 
d27d			chk_stk_init: 
d27d				; a vague random number to check so we dont get any "lucky" hits 
d27d 3e 2d			ld a, 45 
d27f 6f				ld l, a 
d280 00				nop 
d281 3e 17			ld a, 23 
d283 67				ld h, a 
d284			 
d284 22 81 e2			ld (chk_word), hl     ; the word we need to check against 
d287			 
d287			;	ld (chk_stund), hl	; stack points.... 
d287 22 00 ef			ld (chk_stovr), hl 
d28a 22 d0 e9			ld (chk_ret_und), hl 
d28d 22 8e e9			ld (chk_ret_ovr), hl 
d290 22 0c e9			ld (chk_loop_ovr), hl 
d293 22 0a e8			ld (chk_data_ovr), hl 
d296 c9				ret 
d297				 
d297			check_stacks: 
d297				; check all stack words 
d297			 
d297 e5				push hl 
d298 d5				push de 
d299			 
d299			;	ld de,(chk_word) 
d299			;	ld hl, (chk_stund)	; stack points.... 
d299			;	if DEBUG_STK_FAULT 
d299			;		DMARK "FAa" 
d299			;		CALLMONITOR 
d299			;	endif 
d299			;	call cmp16 
d299			;	jp z, .chk_faulta 
d299			; 
d299			;	ld de, sfaultsu 
d299			;	jp .chk_fault 
d299			 
d299 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
d29c ed 5b 81 e2		ld de,(chk_word) 
d2a0				if DEBUG_STK_FAULT 
d2a0					DMARK "FAb" 
d2a0					CALLMONITOR 
d2a0				endif 
d2a0 cd 58 8a			call cmp16 
d2a3 28 06			jr z, .chk_fault1 
d2a5 11 4a d3			ld de, sfaultso 
d2a8 c3 fa d2			jp .chk_fault 
d2ab			.chk_fault1:  
d2ab 2a d0 e9			ld hl, (chk_ret_und) 
d2ae ed 5b 81 e2		ld de,(chk_word) 
d2b2				if DEBUG_STK_FAULT 
