7572			; **********************************************************************  
7572			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
7572			; **********************************************************************  
7572			;  
7572			; **  Written as a Small Computer Monitor App  
7572			; **  www.scc.me.uk  
7572			;  
7572			; History  
7572			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
7572			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
7572			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
7572			;  
7572			; **********************************************************************  
7572			;  
7572			; This program is an example of one of the methods of interfacing an   
7572			; alphanumeric LCD module.   
7572			;  
7572			; In this example the display is connected to either a Z80 PIO or a   
7572			; simple 8-bit output port.   
7572			;  
7572			; This interfacing method uses 4-bit data mode and uses time delays  
7572			; rather than polling the display's ready status. As a result the   
7572			; interface only requires 6 simple output lines:  
7572			;   Output bit 0 = not used  
7572			;   Output bit 1 = not used  
7572			;   Output bit 2 = RS         High = data, Low = instruction  
7572			;   Output bit 3 = E          Active high  
7572			;   Output bit 4 = DB4  
7572			;   Output bit 5 = DB5  
7572			;   Output bit 6 = DB6  
7572			;   Output bit 7 = DB7  
7572			; Display's R/W is connected to 0v so it is always in write mode  
7572			;  
7572			; This set up should work with any system supporting the RC2014 bus  
7572			  
7572			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
7572			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
7572			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
7572			;  
7572			; **********************************************************************  
7572			  
7572			; Additonal for 4x40. E1 and E2 instead of just E   
7572			; TODO swipe vidout signal on port a to activate E2  
7572			  
7572			; **********************************************************************  
7572			; **  Constants  
7572			; **********************************************************************  
7572			; LCD constants required by LCD support module  
7572			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
7572			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
7572			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
7572			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
7572			; TODO Decide which E is being set  
7572			kLCDWidth:  EQU display_cols             ;Width in characters  
7572			  
7572			; **********************************************************************  
7572			; **  Code library usage  
7572			; **********************************************************************  
7572			  
7572			; send character to current cursor position  
7572			; wraps and/or scrolls screen automatically  
7572			  
7572			  
7572			  
7572			lcd_init:  
7572			  
7572			; SCMonAPI functions used  
7572			  
7572			; Alphanumeric LCD functions used  
7572			; no need to specify specific functions for this module  
7572			  
7572 3e cf		            LD   A, 11001111b  
7574 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
7576 3e 00		            LD   A, 00000000b  
7578 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
757a			  
757a			; Initialise alphanumeric LCD module  
757a 3e 00				ld a, 0  
757c 32 f9 fa				ld (display_lcde1e2), a  
757f cd 00 76		            CALL fLCD_Init      ;Initialise LCD module  
7582 3e 01				ld a, 1  
7584 32 f9 fa				ld (display_lcde1e2), a  
7587 cd 00 76		            CALL fLCD_Init      ;Initialise LCD module  
758a			  
758a c9				ret  
758b			  
758b			;  
758b			;;  
758b			; lcd functions  
758b			;  
758b			;  
758b			  
