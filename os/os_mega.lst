0d00			; 
0d00			; Multiply 8-bit value with a 16-bit value (unrolled) 
0d00			; In: Multiply A with DE 
0d00			; Out: HL = result 
0d00			; 
0d00			Mult12U: 
0d00 2e 00		    ld l,0 
0d02 87			    add a,a 
0d03 30 01		    jr nc,Mult12U_NoAdd0 
0d05 19			    add hl,de 
0d06			Mult12U_NoAdd0: 
0d06 29			    add hl,hl 
0d07 87			    add a,a 
0d08 30 01		    jr nc,Mult12U_NoAdd1 
0d0a 19			    add hl,de 
0d0b			Mult12U_NoAdd1: 
