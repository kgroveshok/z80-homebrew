6afd			  
6afd			; Output text string to LCD  
6afd			;   On entry: DE = Pointer to null terminated text string  
6afd			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6afd 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6afe b7			            OR   A              ;Null terminator?  
6aff c8			            RET  Z              ;Yes, so finished  
6b00 cd 93 6a		            CALL fLCD_Data      ;Write character to display  
6b03 13			            INC  DE             ;Point to next character  
6b04 18 f7		            JR   fLCD_Str       ;Repeat  
6b06 c9					ret  
6b07			  
6b07			; Define custom character  
6b07			;   On entry: A = Character number (0 to 7)  
6b07			;             DE = Pointer to character bitmap data  
6b07			;   On exit:  A = Next character number  
6b07			;             DE = Next location following bitmap  
6b07			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6b07			; Character is   
6b07 c5			fLCD_Def:   PUSH BC  
6b08 f5			            PUSH AF  
6b09 07			            RLCA                ;Calculate location  
6b0a 07			            RLCA                ;  for bitmap data  
6b0b 07			            RLCA                ;  = 8 x CharacterNumber  
6b0c f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6b0e cd 57 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6b11 06 00		            LD   B, 0  
6b13 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6b14 cd 93 6a		            CALL fLCD_Data      ;Write byte to display  
6b17 13			            INC  DE             ;Point to next byte  
6b18 04			            INC  B              ;Count bytes  
6b19 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6b1b 28 f6		            JR   Z, Loop       ;No, so repeat  
6b1d f1			            POP  AF  
6b1e 3c			            INC  A              ;Increment character number  
6b1f c1			            POP  BC  
6b20 c9			            RET  
