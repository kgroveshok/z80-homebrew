5562 ed 5b 92 e2		ld de,(chk_word) 
5566				if DEBUG_STK_FAULT 
5566					DMARK "FA1" 
5566					CALLMONITOR 
5566				endif 
5566 cd fc 0b			call cmp16 
5569 ca 72 55			jp z, .chk_fault3 
556c 11 09 56			ld de, sfaultro 
556f c3 9b 55			jp .chk_fault 
5572			.chk_fault3:  
5572 2a 1d e9			ld hl, (chk_loop_ovr) 
5575 ed 5b 92 e2		ld de,(chk_word) 
5579				if DEBUG_STK_FAULT 
5579					DMARK "FA2" 
5579					CALLMONITOR 
5579				endif 
5579 cd fc 0b			call cmp16 
557c ca 85 55			jp z, .chk_fault4 
557f 11 23 56			ld de, sfaultlo 
5582 c3 9b 55			jp .chk_fault 
