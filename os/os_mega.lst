00a3 22 fc fa				ld (display_fb_active), hl  
00a6			  
00a6 cd 11 0b				call clear_display  
00a9			  
00a9 21 fe fa				ld hl, display_fb2  
00ac 22 fc fa				ld (display_fb_active), hl  
00af			  
