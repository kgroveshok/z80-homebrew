8df1			StrictStrCmp: 
8df1				; Load next chars of each string 
8df1 1a				ld a, (de) 
8df2 47				ld b, a 
8df3 7e				ld a, (hl) 
8df4				; Compare 
8df4 b8				cp b 
8df5				; Return non-zero if chars don't match 
8df5 c0				ret nz 
8df6				; Check for end of both strings 
8df6 fe 00			cp "\0" 
8df8				; Return if strings have ended 
8df8 c8				ret z 
8df9				; Otherwise, advance to next chars 
8df9 23				inc hl 
8dfa 13				inc de 
8dfb 18 f4			jr StrictStrCmp 
8dfd			 
8dfd			;end 
8dfd			; eof 
