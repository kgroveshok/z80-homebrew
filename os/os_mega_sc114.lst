bfed			 
bfed			.SPIO: 
bfed			 
bfed			if STORAGE_SE 
bfed				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
bfed			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
bfed			 
bfed					call spi_ce_low 
bfed			    NEXTW 
bfed			 
bfed			.SPICEH: 
bfed				CWHEAD .SPIBOb 61 "SPICEH" 6 WORD_FLAG_CODE 
bfed			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
bfed			 
bfed					call spi_ce_high 
bfed			    NEXTW 
bfed			 
bfed			.SPIBOb: 
bfed			 
bfed				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
bfed			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
bfed			 
bfed					if DEBUG_FORTH_WORDS_KEY 
bfed						DMARK "SPo" 
bfed						CALLMONITOR 
bfed					endif 
bfed					; get port 
bfed			 
bfed			 
bfed					; get byte to send 
bfed			 
bfed					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfed			 
bfed			;		push hl    ; u1  
bfed			 
bfed					; destroy value TOS 
bfed			 
bfed					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfed			 
bfed					; one value on hl get other one back 
bfed			 
bfed			;		pop hl   ; u2 - addr 
bfed			 
bfed					; TODO Send SPI byte 
bfed			 
bfed			;		push hl 
bfed			;		call spi_ce_low 
bfed			;		pop hl 
bfed					ld a, l 
bfed					call spi_send_byte 
bfed			;		call spi_ce_high 
bfed			 
bfed					NEXTW 
bfed			 
bfed			.SPII: 
bfed				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bfed			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bfed					if DEBUG_FORTH_WORDS_KEY 
bfed						DMARK "SPi" 
bfed						CALLMONITOR 
bfed					endif 
bfed			 
bfed					; TODO Get SPI byte 
bfed			 
bfed					call spi_read_byte 
bfed			 
bfed					if DEBUG_FORTH_WORDS 
bfed						DMARK "Si2" 
bfed						CALLMONITOR 
bfed					endif 
bfed					ld h, 0 
bfed					ld l, a 
bfed					if DEBUG_FORTH_WORDS 
bfed						DMARK "Si3" 
bfed						CALLMONITOR 
bfed					endif 
bfed					;call forth_push_numhl 
bfed					FORTH_PUSH_VALUEHL 
bfed			 
bfed					NEXTW 
bfed			 
bfed			 
bfed			 
bfed			.SESEL: 
bfed				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bfed			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bfed			; | | Zero is disabled storage. 
bfed					if DEBUG_FORTH_WORDS_KEY 
bfed						DMARK "BN?" 
bfed						CALLMONITOR 
bfed					endif 
bfed					ld a, (spi_device_id) 
bfed					sub '0' 
bfed					ld h, 0 
bfed					ld l, a 
bfed					FORTH_PUSH_VALUEHL 
bfed					;call forth_push_numhl 
bfed					NEXTW 
bfed			.SESELS: 
bfed				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bfed			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bfed			; | | Set to zero to disable storage. 
bfed					if DEBUG_FORTH_WORDS_KEY 
bfed						DMARK "BNK" 
bfed						CALLMONITOR 
bfed					endif 
bfed			 
bfed					ld a, 255 
bfed					ld (spi_cartdev), a 
bfed			 
bfed					; get bank 
bfed			 
bfed					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfed			 
bfed			;		push hl 
bfed			 
bfed					; destroy value TOS 
bfed			 
bfed					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfed			 
bfed					; one value on hl get other one back 
bfed			 
bfed			;		pop hl 
bfed			 
bfed			 
bfed					ld c, SPI_CE_HIGH 
bfed					ld b, '0'    ; human readable bank number 
bfed			 
bfed					ld a, l 
bfed			 
bfed					if DEBUG_FORTH_WORDS 
bfed						DMARK "BNK" 
bfed						CALLMONITOR 
bfed					endif 
bfed			 
bfed					; active low 
bfed			 
bfed			;		cp 0 
bfed					or a 
bfed					jr z, .bset 
bfed					cp 1 
bfed					jr nz, .b2 
bfed					res 0, c 
bfed					ld b, '1'    ; human readable bank number 
bfed			.b2:		cp 2 
bfed					jr nz, .b3 
bfed					res 1, c 
bfed					ld b, '2'    ; human readable bank number 
bfed			.b3:		cp 3 
bfed					jr nz, .b4 
bfed					res 2, c 
bfed					ld b, '3'    ; human readable bank number 
bfed			.b4:		cp 4 
bfed					jr nz, .b5 
bfed					res 3, c 
bfed					ld b, '4'    ; human readable bank number 
bfed			.b5:		cp 5 
bfed					jr nz, .bset 
bfed					res 4, c 
bfed					ld b, '5'    ; human readable bank number 
bfed			 
bfed			.bset: 
bfed					ld a, c 
bfed					ld (spi_device),a 
bfed					ld a, b 
bfed					ld (spi_device_id),a 
bfed					if DEBUG_FORTH_WORDS 
bfed						DMARK "BN2" 
bfed						CALLMONITOR 
bfed					endif 
bfed			 
bfed					; set default SPI clk pulse time as disabled for BANK use 
bfed			 
bfed					ld a, 0 
bfed					ld (spi_clktime), a 
bfed			 
bfed					NEXTW 
bfed			 
bfed			.CARTDEV: 
bfed				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bfed			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bfed			; | | Set to zero to disable devices. 
bfed					if DEBUG_FORTH_WORDS_KEY 
bfed						DMARK "CDV" 
bfed						CALLMONITOR 
bfed					endif 
bfed			 
bfed					; disable se storage bank selection 
bfed			 
bfed					ld a, SPI_CE_HIGH		; ce high 
bfed					ld (spi_device), a 
bfed			 
bfed					; get bank 
bfed			 
bfed					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfed			 
bfed			;		push hl 
bfed			 
bfed					; destroy value TOS 
bfed			 
bfed					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfed			 
bfed					; one value on hl get other one back 
bfed			 
bfed			;		pop hl 
bfed			 
bfed					; active low 
bfed			 
bfed					ld c, 255 
bfed			 
bfed					ld a, l 
bfed					if DEBUG_FORTH_WORDS 
bfed						DMARK "CDV" 
bfed						CALLMONITOR 
bfed					endif 
bfed			;		cp 0 
bfed					or a 
bfed					jr z, .cset 
bfed					cp 1 
bfed					jr nz, .c2 
bfed					res 0, c 
bfed			.c2:		cp 2 
bfed					jr nz, .c3 
bfed					res 1, c 
bfed			.c3:		cp 3 
bfed					jr nz, .c4 
bfed					res 2, c 
bfed			.c4:		cp 4 
bfed					jr nz, .c5 
bfed					res 3, c 
bfed			.c5:		cp 5 
bfed					jr nz, .c6 
bfed					res 4, c 
bfed			.c6:		cp 6 
bfed					jr nz, .c7 
bfed					res 5, c 
bfed			.c7:		cp 7 
bfed					jr nz, .c8 
bfed					res 6, c 
bfed			.c8:		cp 8 
bfed					jr nz, .cset 
bfed					res 7, c 
bfed			.cset:		ld a, c 
bfed					ld (spi_cartdev),a 
bfed			 
bfed					if DEBUG_FORTH_WORDS 
bfed						DMARK "CD2" 
bfed						CALLMONITOR 
bfed					endif 
bfed			 
bfed					; set default SPI clk pulse time as 10ms for CARTDEV use 
bfed			 
bfed					ld a, $0a 
bfed					ld (spi_clktime), a 
bfed					NEXTW 
bfed			endif 
bfed			 
bfed			.ENDDEVICE: 
bfed			; eof 
bfed			 
# End of file forth_words_device.asm
