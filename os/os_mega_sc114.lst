8f9f			if MALLOC_4 
8f9f			 
8f9f			; My memory allocation code. Very very simple.... 
8f9f			; allocate space under 250 chars 
8f9f			 
8f9f			heap_init: 
8f9f				; init start of heap as zero 
8f9f				;  
8f9f			 
8f9f				ld hl, heap_start 
8f9f			;	ld a, 0 
8f9f				ld (hl), 0      ; empty block 
8f9f				inc hl 
8f9f			;	ld a, 0 
8f9f				ld (hl), 0      ; length of block 
8f9f				; write end of list 
8f9f				inc hl 
8f9f				ld a,(hl) 
8f9f				inc hl 
8f9f				ld a,(hl) 
8f9f				 
8f9f			 
8f9f				; init some malloc vars 
8f9f			 
8f9f				ld hl, 0 
8f9f				ld (free_list), hl       ; store last malloc location 
8f9f			 
8f9f				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
8f9f			;	ld a, 0 
8f9f				ld (hl), 0 
8f9f			 
8f9f			 
8f9f				ld hl, heap_start 
8f9f				;  
8f9f				  
8f9f				ret 
8f9f			 
8f9f			 
8f9f			;    free block marker 
8f9f			;    requested size  
8f9f			;    pointer to next block 
8f9f			;    .... 
8f9f			;    next block marker 
8f9f			 
8f9f			 
8f9f			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
8f9f			; 
8f9f			 
8f9f			 
8f9f			malloc:  
8f9f				push de 
8f9f				push bc 
8f9f				push af 
8f9f			 
8f9f				; hl space required 
8f9f				 
8f9f				ld c, l    ; hold space   (TODO only a max of 255) 
8f9f			 
8f9f			;	inc c     ; TODO BUG need to fix memory leak on push str 
8f9f			;	inc c 
8f9f			;	inc c 
8f9f			;	inc c 
8f9f			;	inc c 
8f9f			;	inc c 
8f9f			;	inc c 
8f9f			 
8f9f			 
8f9f			 
8f9f				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
8f9f			 
8f9f				ld a, (free_list+3) 
8f9f			;	cp 0 
8f9f				or a 
8f9f				jr z, .contheap 
8f9f			 
8f9f				ld hl, (free_list)     ; get last alloc 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "mrs" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f				jr .startalloc 
8f9f			 
8f9f			.contheap: 
8f9f				ld hl, heap_start 
8f9f			 
8f9f			.startalloc: 
8f9f			 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "mym" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f			.findblock: 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "mmf" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f			 
8f9f				ld a,(hl)  
8f9f				; if byte is zero then clear to use 
8f9f			 
8f9f			;	cp 0 
8f9f				or a 
8f9f				jr z, .foundemptyblock 
8f9f			 
8f9f				; if byte is not clear 
8f9f				;     then byte is offset to next block 
8f9f			 
8f9f				inc hl 
8f9f				ld a, (hl) ; get size 
8f9f			.nextblock:	inc hl 
8f9f					ld e, (hl) 
8f9f					inc hl 
8f9f					ld d, (hl) 
8f9f					ex de, hl 
8f9f			;	inc hl  ; move past the store space 
8f9f			;	inc hl  ; move past zero index  
8f9f			 
8f9f				; TODO detect no more space 
8f9f			 
8f9f				push hl 
8f9f				ld de, heap_end 
8f9f				call cmp16 
8f9f				pop hl 
8f9f				jr nc, .nospace 
8f9f			 
8f9f				jr .findblock 
8f9f			 
8f9f			.nospace: ld hl, 0 
8f9f				jp .exit 
8f9f			 
8f9f			 
8f9f			.foundemptyblock:	 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "mme" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f			 
8f9f			; TODO has block enough space if reusing??? 
8f9f			 
8f9f				;  
8f9f			 
8f9f			; see if this block has been previously used 
8f9f				inc hl 
8f9f				ld a, (hl) 
8f9f				dec hl 
8f9f			;	cp 0 
8f9f				or a 
8f9f				jr z, .newblock 
8f9f			 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "meR" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f			 
8f9f			; no reusing previously allocated block 
8f9f			 
8f9f			; is it smaller than previously used? 
8f9f				 
8f9f				inc hl    ; move to size 
8f9f				ld a, c 
8f9f				sub (hl)        ; we want c < (hl) 
8f9f				dec hl    ; move back to marker 
8f9f			        jr z, .findblock 
8f9f			 
8f9f				; update with the new size which should be lower 
8f9f			 
8f9f			        ;inc  hl   ; negate next move. move back to size  
8f9f			 
8f9f			.newblock: 
8f9f				; need to be at marker here 
8f9f			 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "meN" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f			 
8f9f			 
8f9f				ld a, c 
8f9f			 
8f9f				ld (free_list+3), a	 ; flag resume from last malloc  
8f9f				ld (free_list), hl    ; save out last location 
8f9f			 
8f9f			 
8f9f				;inc a     ; space for length byte 
8f9f				ld (hl), a     ; save block in use marker 
8f9f			 
8f9f				inc hl   ; move to space marker 
8f9f				ld (hl), a    ; save new space 
8f9f			 
8f9f				inc hl   ; move to start of allocated area 
8f9f				 
8f9f			;	push hl     ; save where we are - 1  
8f9f			 
8f9f			;	inc hl  ; move past zero index  
8f9f				; skip space to set down new marker 
8f9f			 
8f9f				; provide some extra space for now 
8f9f			 
8f9f				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
8f9f				inc a 
8f9f				inc a 
8f9f			 
8f9f				push hl   ; save where we are in the node block 
8f9f			 
8f9f				call addatohl 
8f9f			 
8f9f				; write linked list point 
8f9f			 
8f9f				pop de     ; get our node position 
8f9f				ex de, hl 
8f9f			 
8f9f				ld (hl), e 
8f9f				inc hl 
8f9f				ld (hl), d 
8f9f			 
8f9f				inc hl 
8f9f			 
8f9f				; now at start of allocated data so save pointer 
8f9f			 
8f9f				push hl 
8f9f			 
8f9f				; jump to position of next node and setup empty header in DE 
8f9f			 
8f9f				ex de, hl 
8f9f			 
8f9f			;	inc hl ; move past end of block 
8f9f			 
8f9f			;	ld a, 0 
8f9f				ld (hl), 0   ; empty marker 
8f9f				inc hl 
8f9f				ld (hl), 0   ; size 
8f9f				inc hl  
8f9f				ld (hl), 0   ; ptr 
8f9f				inc hl 
8f9f				ld (hl), 0   ; ptr 
8f9f			 
8f9f			 
8f9f				pop hl 
8f9f			 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "mmr" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f			 
8f9f			.exit: 
8f9f				pop af 
8f9f				pop bc 
8f9f				pop de  
8f9f				ret 
8f9f			 
8f9f			 
8f9f			 
8f9f			 
8f9f			free:  
8f9f				push hl 
8f9f				push af 
8f9f				; get address in hl 
8f9f			 
8f9f					if DEBUG_FORTH_MALLOC_INT 
8f9f						DMARK "fre" 
8f9f						CALLMONITOR 
8f9f					endif 
8f9f				; data is at hl - move to block count 
8f9f				dec hl 
8f9f				dec hl    ; get past pointer 
8f9f				dec hl 
8f9f			 
8f9f				ld a, (hl)    ; need this for a validation check 
8f9f			 
8f9f				dec hl    ; move to block marker 
8f9f			 
8f9f				; now check that the block count and block marker are the same  
8f9f			        ; this checks that we are on a malloc node and not random memory 
8f9f			        ; OK a faint chance this could be a problem but rare - famous last words! 
8f9f			 
8f9f				ld c, a 
8f9f				ld a, (hl)    
8f9f			 
8f9f				cp c 
8f9f				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
8f9f			 
8f9f				; yes good chance we are on a malloc node 
8f9f			 
8f9f			;	ld a, 0      
8f9f				ld (hl), 0   ; mark as free 
8f9f			 
8f9f				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
8f9f			 
8f9f			.freeignore:  
8f9f			 
8f9f				pop af 
8f9f				pop hl 
8f9f			 
8f9f				ret 
8f9f			 
8f9f			 
8f9f			 
8f9f			endif 
