0fef			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0fef			;;    subtract $30, if result > 9 then subtract $7 more 
0fef			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0fef			atohex: 
0fef d6 30				SUB $30 
0ff1 fe 0a				CP 10 
0ff3 f8					RET M		; If result negative it was 0-9 so we're done 
0ff4 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0ff6 c9					RET		 
