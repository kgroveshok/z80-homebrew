64b9			; stack over and underflow checks 
64b9			 
64b9			; init the words to detect the under/overflow 
64b9			 
64b9			chk_stk_init: 
64b9				; a vague random number to check so we dont get any "lucky" hits 
64b9 3e 2d			ld a, 45 
64bb 6f				ld l, a 
64bc 00				nop 
64bd 3e 17			ld a, 23 
64bf 67				ld h, a 
64c0			 
64c0 22 bb f0			ld (chk_word), hl     ; the word we need to check against 
64c3			 
64c3			;	ld (chk_stund), hl	; stack points.... 
64c3 22 3b fe			ld (chk_stovr), hl 
64c6 22 0a f9			ld (chk_ret_und), hl 
64c9 22 c8 f8			ld (chk_ret_ovr), hl 
64cc 22 46 f8			ld (chk_loop_ovr), hl 
64cf 22 44 f6			ld (chk_data_ovr), hl 
64d2 c9				ret 
64d3				 
64d3			check_stacks: 
64d3				; check all stack words 
64d3			 
64d3 e5				push hl 
64d4 d5				push de 
64d5			 
64d5			;	ld de,(chk_word) 
64d5			;	ld hl, (chk_stund)	; stack points.... 
64d5			;	if DEBUG_STK_FAULT 
64d5			;		DMARK "FAa" 
64d5			;		CALLMONITOR 
64d5			;	endif 
64d5			;	call cmp16 
64d5			;	jp z, .chk_faulta 
64d5			; 
64d5			;	ld de, sfaultsu 
64d5			;	jp .chk_fault 
64d5			 
64d5 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
64d8 ed 5b bb f0		ld de,(chk_word) 
64dc				if DEBUG_STK_FAULT 
64dc					DMARK "FAb" 
64dc					CALLMONITOR 
64dc				endif 
64dc cd 7d 0d			call cmp16 
64df 28 06			jr z, .chk_fault1 
64e1 11 86 65			ld de, sfaultso 
64e4 c3 36 65			jp .chk_fault 
64e7			.chk_fault1:  
64e7 2a 0a f9			ld hl, (chk_ret_und) 
64ea ed 5b bb f0		ld de,(chk_word) 
64ee				if DEBUG_STK_FAULT 
64ee					DMARK "FAU" 
64ee					CALLMONITOR 
64ee				endif 
64ee cd 7d 0d			call cmp16 
64f1 ca fa 64			jp z, .chk_fault2 
64f4 11 96 65			ld de, sfaultru 
64f7 c3 36 65			jp .chk_fault 
64fa			.chk_fault2:  
64fa 2a c8 f8			ld hl, (chk_ret_ovr) 
64fd ed 5b bb f0		ld de,(chk_word) 
6501				if DEBUG_STK_FAULT 
6501					DMARK "FA1" 
6501					CALLMONITOR 
6501				endif 
6501 cd 7d 0d			call cmp16 
6504 ca 0d 65			jp z, .chk_fault3 
6507 11 a4 65			ld de, sfaultro 
650a c3 36 65			jp .chk_fault 
650d			.chk_fault3:  
650d 2a 46 f8			ld hl, (chk_loop_ovr) 
6510 ed 5b bb f0		ld de,(chk_word) 
6514				if DEBUG_STK_FAULT 
6514					DMARK "FA2" 
6514					CALLMONITOR 
6514				endif 
6514 cd 7d 0d			call cmp16 
6517 ca 20 65			jp z, .chk_fault4 
651a 11 be 65			ld de, sfaultlo 
651d c3 36 65			jp .chk_fault 
6520			.chk_fault4:  
6520 2a 44 f6			ld hl, (chk_data_ovr) 
6523 ed 5b bb f0		ld de,(chk_word) 
6527				if DEBUG_STK_FAULT 
6527					DMARK "FA3" 
6527					CALLMONITOR 
6527				endif 
6527 cd 7d 0d			call cmp16 
652a ca 33 65			jp z, .chk_fault5 
652d 11 d8 65			ld de, sfaultdo 
6530 c3 36 65			jp .chk_fault 
6533			 
6533			 
6533			.chk_fault5:  
6533 d1				pop de 
6534 e1				pop hl 
6535			 
6535 c9				ret 
