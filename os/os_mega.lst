0ff7			BYTERD: 
0ff7 16 00			LD	D,00h		;Set up 
0ff9 cd 01 10			CALL	HEXCON		;Get byte and convert to hex 
0ffc 87				ADD	A,A		;First nibble so 
0ffd 87				ADD	A,A		;multiply by 16 
0ffe 87				ADD	A,A		; 
0fff 87				ADD	A,A		; 
1000 57				LD	D,A		;Save hi nibble in D 
1001			HEXCON: 
1001 7e				ld a, (hl)		;Get next chr 
1002 23				inc hl 
1003 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
1005 fe 0a			CP	00Ah		;Is it 0-9 ? 
1007 38 02			JR	C,NALPHA	;If so miss next bit 
1009 d6 07			SUB	007h		;Else convert alpha 
100b			NALPHA: 
100b b2				OR	D		;Add hi nibble back 
100c c9				RET			; 
