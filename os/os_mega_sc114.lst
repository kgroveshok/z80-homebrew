a6bb 32 5e ee			ld (debug_mark),a  
a6be 3a cd a6			ld a, (.dmark+1)  
a6c1 32 5f ee			ld (debug_mark+1),a  
a6c4 3a ce a6			ld a, (.dmark+2)  
a6c7 32 60 ee			ld (debug_mark+2),a  
a6ca 18 03			jr .pastdmark  
a6cc ..			.dmark: db "BP."  
a6cf f1			.pastdmark: pop af  
a6d0			endm  
