8cdb			; from https://wikiti.brandonw.net/index.php?title=Z80_Routines:Other:DispA 
8cdb			 
8cdb			; Decimal Unsigned Version 
8cdb			 
8cdb			;Number in a to decimal ASCII 
8cdb			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
8cdb			;Example: display a=56 as "056" 
8cdb			;input: a = number 
8cdb			;Output: a=0,value of a in the screen 
8cdb			;destroys af,bc (don't know about hl and de) 
8cdb			DispAToASCII: 
8cdb 0e 9c			ld	c,-100 
8cdd cd e7 8c			call	.Na1 
8ce0 0e f6			ld	c,-10 
8ce2 cd e7 8c			call	.Na1 
8ce5 0e ff			ld	c,-1 
8ce7 06 2f		.Na1:	ld	b,'0'-1 
8ce9 04			.Na2:	inc	b 
8cea 81				add	a,c 
8ceb 38 fc			jr	c,.Na2 
8ced 91				sub	c		;works as add 100/10/1 
8cee f5				push af		;safer than ld c,a 
8cef 78				ld	a,b		;char is in b 
8cf0			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
8cf0 f1				pop af		;safer than ld a,c 
8cf1 c9				ret 
