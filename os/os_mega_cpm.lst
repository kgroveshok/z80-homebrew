4296					; one value on hl get other one back 
4296			 
4296			;		pop hl   ; u2 - addr 
4296			 
4296					; TODO Send SPI byte 
4296			 
4296			;		push hl 
4296			;		call spi_ce_low 
4296			;		pop hl 
4296					ld a, l 
4296					call spi_send_byte 
4296			;		call spi_ce_high 
4296			 
4296					NEXTW 
4296			 
4296			.SPII: 
4296				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
4296			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
4296					if DEBUG_FORTH_WORDS_KEY 
4296						DMARK "SPi" 
4296						CALLMONITOR 
4296					endif 
4296			 
4296					; TODO Get SPI byte 
4296			 
4296					call spi_read_byte 
4296			 
4296					if DEBUG_FORTH_WORDS 
4296						DMARK "Si2" 
4296						CALLMONITOR 
4296					endif 
4296					ld h, 0 
4296					ld l, a 
4296					if DEBUG_FORTH_WORDS 
4296						DMARK "Si3" 
4296						CALLMONITOR 
4296					endif 
4296					;call forth_push_numhl 
