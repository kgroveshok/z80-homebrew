661d			; stack over and underflow checks 
661d			 
661d			; init the words to detect the under/overflow 
661d			 
661d			chk_stk_init: 
661d				; a vague random number to check so we dont get any "lucky" hits 
661d 3e 2d			ld a, 45 
661f 6f				ld l, a 
6620 00				nop 
6621 3e 17			ld a, 23 
6623 67				ld h, a 
6624			 
6624 22 b9 f0			ld (chk_word), hl     ; the word we need to check against 
6627			 
6627			;	ld (chk_stund), hl	; stack points.... 
6627 22 3b fe			ld (chk_stovr), hl 
662a 22 08 f9			ld (chk_ret_und), hl 
662d 22 c6 f8			ld (chk_ret_ovr), hl 
6630 22 44 f8			ld (chk_loop_ovr), hl 
6633 22 42 f6			ld (chk_data_ovr), hl 
6636 c9				ret 
6637				 
6637			check_stacks: 
6637				; check all stack words 
6637			 
6637 e5				push hl 
6638 d5				push de 
6639			 
6639			;	ld de,(chk_word) 
6639			;	ld hl, (chk_stund)	; stack points.... 
6639			;	if DEBUG_STK_FAULT 
6639			;		DMARK "FAa" 
6639			;		CALLMONITOR 
6639			;	endif 
6639			;	call cmp16 
6639			;	jp z, .chk_faulta 
6639			; 
6639			;	ld de, sfaultsu 
6639			;	jp .chk_fault 
6639			 
6639 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
663c ed 5b b9 f0		ld de,(chk_word) 
6640				if DEBUG_STK_FAULT 
6640					DMARK "FAb" 
6640					CALLMONITOR 
6640				endif 
6640 cd 99 0d			call cmp16 
6643 28 06			jr z, .chk_fault1 
6645 11 ea 66			ld de, sfaultso 
6648 c3 9a 66			jp .chk_fault 
664b			.chk_fault1:  
664b 2a 08 f9			ld hl, (chk_ret_und) 
664e ed 5b b9 f0		ld de,(chk_word) 
6652				if DEBUG_STK_FAULT 
6652					DMARK "FAU" 
6652					CALLMONITOR 
6652				endif 
6652 cd 99 0d			call cmp16 
6655 ca 5e 66			jp z, .chk_fault2 
6658 11 fa 66			ld de, sfaultru 
665b c3 9a 66			jp .chk_fault 
665e			.chk_fault2:  
665e 2a c6 f8			ld hl, (chk_ret_ovr) 
6661 ed 5b b9 f0		ld de,(chk_word) 
6665				if DEBUG_STK_FAULT 
6665					DMARK "FA1" 
6665					CALLMONITOR 
6665				endif 
6665 cd 99 0d			call cmp16 
6668 ca 71 66			jp z, .chk_fault3 
666b 11 08 67			ld de, sfaultro 
666e c3 9a 66			jp .chk_fault 
6671			.chk_fault3:  
6671 2a 44 f8			ld hl, (chk_loop_ovr) 
6674 ed 5b b9 f0		ld de,(chk_word) 
6678				if DEBUG_STK_FAULT 
6678					DMARK "FA2" 
6678					CALLMONITOR 
6678				endif 
6678 cd 99 0d			call cmp16 
667b ca 84 66			jp z, .chk_fault4 
667e 11 22 67			ld de, sfaultlo 
6681 c3 9a 66			jp .chk_fault 
6684			.chk_fault4:  
6684 2a 42 f6			ld hl, (chk_data_ovr) 
6687 ed 5b b9 f0		ld de,(chk_word) 
668b				if DEBUG_STK_FAULT 
668b					DMARK "FA3" 
668b					CALLMONITOR 
668b				endif 
668b cd 99 0d			call cmp16 
668e ca 97 66			jp z, .chk_fault5 
6691 11 3c 67			ld de, sfaultdo 
6694 c3 9a 66			jp .chk_fault 
6697			 
