8fc6				 
8fc6 ed 51			out (c), d 
8fc8			 
8fc8 2b				dec hl 
8fc9 cd 63 8a			call ishlzero 
8fcc 20 f8			jr nz, tape_osc 
8fce				 
8fce c9				ret 
