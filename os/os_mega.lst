012c			;  
012c			; TODO use the low spare two pins on port a of display pio to bit bang a serial out video display to an esp  
012c			; TODO abstract the bit bang video out interface for dual display  
012c			; TODO wire video out to tx pin on rc2014 bus  
012c			  
012c			; must supply cin, and cin_wait for low level hardware abstraction   
012c			; moved text_input entry points to here and leave the firmware hardware modules as abstraction layer  
012c			; test scancode  
012c			  
012c			;;;;;  
012c			;;;  
012c			; Moved out to mini and maxi versions  
012c			;  
012c			; include "firmware_key_4x4.asm"  
012c			; using existing 4 wire x 4 resistor array for input  
012c			;include "firmware_key_4x10.asm"  
012c			; need to mod the board for 5 rows due to resistor array  
012c			;include "firmware_key_5x10.asm"  
012c			  
012c			; storage hardware interface  
012c			  
012c			; use microchip serial eeprom for storage  
012c			  
012c			  
012c			if STORAGE_SE  
012c				include "firmware_spi.asm"  
012c			; my spi protocol (used by storage) 
012c			 
012c			; SPI pins 
012c			 
012c			SPI_DI: equ 7       ; chip pin 5 - port a7   pin pin 7 
012c			SPI_DO: equ 6      ; chip pin 2 - port a6   pin 8 
012c			SPI_SCLK: equ 5      ; chip pin 6 - port a5  - pin 9 
012c			 
012c			; chip pin 3 (WP), 7 (HOLD) and 8 (VCC) +5v 
012c			; chip pin 4 gnd 
012c			 
012c			 
012c			SPI_CE0: equ 0      ; chip pin 1 - port a3 - pin 15 
012c			SPI_CE1: equ 1      ;    port a1 pin 14  
012c			SPI_CE2: equ 2      ;    port a2 pin pin 13 
012c			SPI_CE3: equ 3      ; port    a3 pin pin 12 
012c			SPI_CE4: equ 4      ; port a4     pin 10 
012c			 
012c			; active low AND masks 
012c			 
012c			;SPI_CE0_MASK: equ    255-1 
012c			;SPI_CE1_MASK: equ   255-2 
012c			;SPI_CE2_MASK: equ   255-4 
