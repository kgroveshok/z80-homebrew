8960			 
8960			 
8960			;;;; int maths 
8960			 
8960			; https://map.grauw.nl/articles/mult_div_shifts.php 
8960			; Divide 16-bit values (with 16-bit result) 
8960			; In: Divide BC by divider DE 
8960			; Out: BC = result, HL = rest 
8960			; 
8960			Div16: 
8960 21 00 00		    ld hl,0 
8963 78			    ld a,b 
8964 06 08		    ld b,8 
8966			Div16_Loop1: 
8966 17			    rla 
8967 ed 6a		    adc hl,hl 
8969 ed 52		    sbc hl,de 
896b 30 01		    jr nc,Div16_NoAdd1 
896d 19			    add hl,de 
896e			Div16_NoAdd1: 
896e 10 f6		    djnz Div16_Loop1 
8970 17			    rla 
8971 2f			    cpl 
8972 47			    ld b,a 
8973 79			    ld a,c 
8974 48			    ld c,b 
8975 06 08		    ld b,8 
8977			Div16_Loop2: 
8977 17			    rla 
8978 ed 6a		    adc hl,hl 
897a ed 52		    sbc hl,de 
897c 30 01		    jr nc,Div16_NoAdd2 
897e 19			    add hl,de 
897f			Div16_NoAdd2: 
897f 10 f6		    djnz Div16_Loop2 
8981 17			    rla 
8982 2f			    cpl 
8983 41			    ld b,c 
8984 4f			    ld c,a 
8985 c9			ret 
8986			 
8986			 
8986			;http://z80-heaven.wikidot.com/math 
8986			; 
8986			;Inputs: 
8986			;     DE and A are factors 
8986			;Outputs: 
8986			;     A is not changed 
8986			;     B is 0 
8986			;     C is not changed 
8986			;     DE is not changed 
8986			;     HL is the product 
8986			;Time: 
8986			;     342+6x 
8986			; 
8986			Mult16: 
8986			 
8986 06 08		     ld b,8          ;7           7 
8988 21 00 00		     ld hl,0         ;10         10 
898b 29			       add hl,hl     ;11*8       88 
898c 07			       rlca          ;4*8        32 
898d 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
898f 19			         add hl,de   ;--         -- 
8990 10 f9		       djnz $-5      ;13*7+8     99 
8992 c9			ret 
8993			 
8993			; 
8993			; Square root of 16-bit value 
8993			; In:  HL = value 
8993			; Out:  D = result (rounded down) 
8993			; 
8993			;Sqr16: 
8993			;    ld de,#0040 
8993			;    ld a,l 
8993			;    ld l,h 
8993			;    ld h,d 
8993			;    or a 
8993			;    ld b,8 
8993			;Sqr16_Loop: 
8993			;    sbc hl,de 
8993			;    jr nc,Sqr16_Skip 
8993			;    add hl,de 
8993			;Sqr16_Skip: 
8993			;    ccf 
8993			;    rl d 
8993			;    add a,a 
