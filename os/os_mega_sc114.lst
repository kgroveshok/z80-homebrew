89f9 6a			    ld l,d 
89fa 06 08		    ld b,8 
89fc			Mult8_Loop: 
89fc 29			    add hl,hl 
89fd 30 01		    jr nc,Mult8_NoAdd 
89ff 19			    add hl,de 
