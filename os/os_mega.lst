12c7			if MALLOC_3 
12c7			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12c7			;heap_start        .equ  0x9000      ; Starting address of heap 
12c7			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12c7			; 
12c7			 ;     .org 0 
12c7			  ;    jp    main 
12c7			; 
12c7			; 
12c7			 ;     .org  0x100 
12c7			;main: 
12c7			 ;     ld    HL, 0x8100 
12c7			  ;    ld    SP, HL 
12c7			; 
12c7			;      call  heap_init 
12c7			 
12c7			      ; Make some allocations 
12c7			;      ld    HL, 12 
12c7			;      call  malloc            ; Allocates 0x9004 
12c7			; 
12c7			 ;     ld    HL, 12 
12c7			;      call  malloc            ; Allocates 0x9014 
12c7			 
12c7			;      ld    HL, 12 
12c7			;      call  malloc            ; Allocates 0x9024 
12c7			 
12c7			      ; Free some allocations 
12c7			;      ld    HL, 0x9014 
12c7			;      call  free 
12c7			 
12c7			;      ld    HL, 0x9004 
12c7			;      call  free 
12c7			; 
12c7			;      ld    HL, 0x9024 
12c7			;      call  free 
12c7			 
12c7			 
12c7			 ;     halt 
12c7			 
12c7			 
12c7			;------------------------------------------------------------------------------ 
12c7			;     heap_init                                                               : 
12c7			;                                                                             : 
12c7			; Description                                                                 : 
12c7			;     Initialise the heap and make it ready for malloc and free operations.   : 
12c7			;                                                                             : 
12c7			;     The heap is maintained as a linked list, starting with an initial       : 
12c7			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12c7			;     the first free block in the heap. Each block then points to the next    : 
12c7			;     free block within the heap, and the free list ends at the first block   : 
12c7			;     with a null pointer to the next free block.                             : 
12c7			;                                                                             : 
12c7			; Parameters                                                                  : 
12c7			;     Inputs are compile-time only. Two defines which specify the starting    : 
12c7			;     address of the heap and its size are required, along with a memory      : 
12c7			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12c7			;     principally stores a pointer to the first free block in the heap.       : 
12c7			;                                                                             : 
12c7			; Returns                                                                     : 
12c7			;     Nothing                                                                 : 
12c7			;------------------------------------------------------------------------------ 
12c7			heap_init: 
12c7			      push  HL 
12c7			 
12c7			      ; Initialise free list struct 
12c7			      ld    HL, heap_start 
12c7			      ld    (free_list), HL 
12c7			      ld    HL, 0 
12c7			      ld    (free_list+2), HL 
12c7			 
12c7			      ; Insert first free block at bottom of heap, consumes entire heap 
12c7			      ld    HL, heap_start+heap_size-4 
12c7			      ld    (heap_start), HL        ; Next block (end of free list) 
12c7			      ld    HL, heap_size-4 
12c7			      ld    (heap_start+2), HL      ; Block size 
12c7			 
12c7			      ; Insert end of free list block at top of heap - two null words will 
12c7			      ; terminate the free list 
12c7			      ld    HL, 0 
12c7			      ld    (heap_start+heap_size-2), HL 
12c7			      ld    (heap_start+heap_size-4), HL 
12c7			 
12c7			      pop   HL 
12c7			 
12c7			      ret 
12c7			 
12c7			 
12c7			;------------------------------------------------------------------------------ 
12c7			;     malloc                                                                  : 
12c7			;                                                                             : 
12c7			; Description                                                                 : 
12c7			;     Allocates the wanted space from the heap and returns the address of the : 
12c7			;     first useable byte of the allocation.                                   : 
12c7			;                                                                             : 
12c7			;     Allocations can happen in one of two ways:                              : 
12c7			;                                                                             : 
12c7			;     1. A free block may be found which is the exact size wanted. In this    : 
12c7			;        case the block is removed from the free list and retuedn to the      : 
12c7			;        caller.                                                              : 
12c7			;     2. A free block may be found which is larger than the size wanted. In   : 
12c7			;        this case, the larger block is split into two. The first portion of  : 
12c7			;        this block will become the requested space by the malloc call and    : 
12c7			;        is returned to the caller. The second portion becomes a new free     : 
12c7			;        block, and the free list is adjusted to maintain continuity via this : 
12c7			;        newly created block.                                                 : 
12c7			;                                                                             : 
12c7			;     malloc does not set any initial value in the allocated space, the       : 
12c7			;     caller is required to do this as required.                              : 
12c7			;                                                                             : 
12c7			;     This implementation of malloc uses the stack exclusively, and is        : 
12c7			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12c7			;     advisable to disable interrupts before calling malloc, and recommended  : 
12c7			;     to avoid the use of malloc inside ISRs in general.                      : 
12c7			;                                                                             : 
12c7			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12c7			;                                                                             : 
12c7			; Parameters                                                                  : 
12c7			;     HL  Number of bytes wanted                                              : 
12c7			;                                                                             : 
12c7			; Returns                                                                     : 
12c7			;     HL  Address of the first useable byte of the allocation                 : 
12c7			;                                                                             : 
12c7			; Flags                                                                       : 
12c7			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12c7			;                                                                             : 
12c7			; Stack frame                                                                 : 
12c7			;       |             |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |     BC      |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |     DE      |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |     IX      |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |  prev_free  |                                                       : 
12c7			;   +4  +-------------+                                                       : 
12c7			;       |  this_free  |                                                       : 
12c7			;   +2  +-------------+                                                       : 
12c7			;       |  next_free  |                                                       : 
12c7			;   +0  +-------------+                                                       : 
12c7			;       |             |                                                       : 
12c7			;                                                                             : 
12c7			;------------------------------------------------------------------------------ 
12c7			malloc: 
12c7			      push  BC 
12c7			      push  DE 
12c7			      push  IX 
12c7			 
12c7			      ld    A, H                    ; Exit if no space requested 
12c7			      or    L 
12c7			      jp    Z, malloc_early_exit 
12c7			 
12c7			      ; Set up stack frame 
12c7			      ex    DE, HL 
12c7			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12c7			      add   HL, SP 
12c7			      ld    SP, HL 
12c7			      ld    IX, 0                   ; Use IX as a frame pointer 
12c7			      add   IX, SP 
12c7			 
12c7			      ; Setup initial state 
12c7			      ld    HL, 4                   ; want must also include space used by block struct 
12c7			      add   HL, DE 
12c7			 
12c7			      ld    B, H                    ; Move want to BC 
12c7			      ld    C, L 
12c7			 
12c7			      ld    HL, free_list           ; Store prev_free ptr to stack 
12c7			      ld    (IX+4), L 
12c7			      ld    (IX+5), H 
12c7			 
12c7			      ld    E, (HL)                 ; Store this_free ptr to stack 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      ld    (IX+2), E 
12c7			      ld    (IX+3), D 
12c7			      ex    DE, HL                  ; this_free ptr into HL 
12c7			 
12c7			      ; Loop through free block list to find some space 
12c7			malloc_find_space: 
12c7			      ld    E, (HL)                 ; Load next_free ptr into DE 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			 
12c7			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12c7			      or    E 
12c7			      jp    Z, malloc_no_space 
12c7			 
12c7			      ld    (IX+0), E               ; Store next_free ptr to stack 
12c7			      ld    (IX+1), D 
12c7			 
12c7			      ; Does this block have enough space to make the allocation? 
12c7			      inc   HL                      ; Load free block size into DE 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			 
12c7			      ex    DE, HL                  ; Check size of block against want 
12c7			      or    A                       ; Ensure carry flag clear 
12c7			      sbc   HL, BC 
12c7			      push  HL                      ; Store the result for later (new block size) 
12c7			 
12c7			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12c7			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12c7			 
12c7			      ; this_free block is not big enough, setup ptrs to test next free block 
12c7			      pop   HL                      ; Discard previous result 
12c7			 
12c7			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12c7			      ld    H, (IX+3) 
12c7			      ld    (IX+4), L 
12c7			      ld    (IX+5), H 
12c7			 
12c7			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12c7			      ld    H, (IX+1) 
12c7			      ld    (IX+2), L 
12c7			      ld    (IX+3), H 
12c7			 
12c7			      jr    malloc_find_space 
12c7			 
12c7			      ; split a bigger block into two - requested size and remaining size 
12c7			malloc_alloc_split: 
12c7			      ex    DE, HL                  ; Calculate address of new free block 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			      add   HL, BC 
12c7			 
12c7			      ; Create a new block and point it at next_free 
12c7			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12c7			      ld    D, (IX+1) 
12c7			 
12c7			      ld    (HL), E                 ; Store next_free ptr into new block 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			      pop   DE                      ; Store size of new block into new block 
12c7			      inc   HL 
12c7			      ld    (HL), E 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			      ; Update this_free ptr to point to new block 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			 
12c7			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12c7			      ld    D, (IX+3) 
12c7			 
12c7			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12c7			      ld    (IX+3), H 
12c7			 
12c7			      ; Modify this_free block to be allocation 
12c7			      ex    DE, HL 
12c7			      xor   A                       ; Null the next block ptr of allocated block 
12c7			      ld    (HL), A 
12c7			      inc   HL 
12c7			      ld    (HL), A 
12c7			 
12c7			      inc   HL                      ; Store want size into allocated block 
12c7			      ld    (HL), C 
12c7			      inc   HL 
12c7			      ld    (HL), B 
12c7			      inc   HL 
12c7			      push  HL                      ; Address of allocation to return 
12c7			 
12c7			      jr    malloc_update_links 
12c7			 
12c7			malloc_alloc_fit: 
12c7			      pop   HL                      ; Dont need new block size, want is exact fit 
12c7			 
12c7			      ; Modify this_free block to be allocation 
12c7			      ex    DE, HL 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			 
12c7			      xor   A                       ; Null the next block ptr of allocated block 
12c7			      ld    (HL), A 
12c7			      inc   HL 
12c7			      ld    (HL), A 
12c7			 
12c7			      inc   HL                      ; Store address of allocation to return 
12c7			      inc   HL 
12c7			      inc   HL 
12c7			      push  HL 
12c7			 
12c7			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12c7			      ld    L, (IX+0)               ; next_free to HL 
12c7			      ld    H, (IX+1) 
12c7			 
12c7			      ld    (IX+2), L               ; HL to this_free 
12c7			      ld    (IX+3), H 
12c7			 
12c7			 
12c7			malloc_update_links: 
12c7			      ; Update prev_free ptr to point to this_free 
12c7			      ld    L, (IX+4)               ; prev_free ptr to HL 
12c7			      ld    H, (IX+5) 
12c7			 
12c7			      ld    E, (IX+2)               ; this_free ptr to DE 
12c7			      ld    D, (IX+3) 
12c7			 
12c7			      ld    (HL), E                 ; this_free ptr into prev_free 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			      ; Clear the Z flag to indicate successful allocation 
12c7			      ld    A, D 
12c7			      or    E 
12c7			 
12c7			      pop   DE                      ; Address of allocation 
12c7			 
12c7			malloc_no_space: 
12c7			      ld    HL, 6                   ; Clean up stack frame 
12c7			      add   HL, SP 
12c7			      ld    SP, HL 
12c7			 
12c7			      ex    DE, HL                  ; Alloc addr into HL for return 
12c7			 
12c7			malloc_early_exit: 
12c7			      pop   IX 
12c7			      pop   DE 
12c7			      pop   BC 
12c7			 
12c7			      ret 
12c7			 
12c7			 
12c7			;------------------------------------------------------------------------------ 
12c7			;     free                                                                    : 
12c7			;                                                                             : 
12c7			; Description                                                                 : 
12c7			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12c7			;     returned by malloc, otherwise the behaviour is undefined.               : 
12c7			;                                                                             : 
12c7			;     Where possible, directly adjacent free blocks will be merged together   : 
12c7			;     into larger blocks to help ensure that the heap does not become         : 
12c7			;     excessively fragmented.                                                 : 
12c7			;                                                                             : 
12c7			;     free does not clear or set any other value into the freed space, and    : 
12c7			;     therefore its contents may be visible through subsequent malloc's. The  : 
12c7			;     caller should clear the freed space as required.                        : 
12c7			;                                                                             : 
12c7			;     This implementation of free uses the stack exclusively, and is          : 
12c7			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12c7			;     advisable to disable interrupts before calling free, and recommended    : 
12c7			;     to avoid the use of free inside ISRs in general.                        : 
12c7			;                                                                             : 
12c7			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12c7			;                                                                             : 
12c7			; Parameters                                                                  : 
12c7			;     HL  Pointer to address of first byte of allocation to be freed          : 
12c7			;                                                                             : 
12c7			; Returns                                                                     : 
12c7			;     Nothing                                                                 : 
12c7			;                                                                             : 
12c7			; Stack frame                                                                 : 
12c7			;       |             |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |     BC      |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |     DE      |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |     IX      |                                                       : 
12c7			;       +-------------+                                                       : 
12c7			;       |  prev_free  |                                                       : 
12c7			;   +2  +-------------+                                                       : 
12c7			;       |  next_free  |                                                       : 
12c7			;   +0  +-------------+                                                       : 
12c7			;       |             |                                                       : 
12c7			;                                                                             : 
12c7			;------------------------------------------------------------------------------ 
12c7			free: 
12c7			      push  BC 
12c7			      push  DE 
12c7			      push  IX 
12c7			 
12c7			      ld    A, H                    ; Exit if ptr is null 
12c7			      or    L 
12c7			      jp    Z, free_early_exit 
12c7			 
12c7			      ; Set up stack frame 
12c7			      ex    DE, HL 
12c7			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12c7			      add   HL, SP 
12c7			      ld    SP, HL 
12c7			      ld    IX, 0                   ; Use IX as a frame pointer 
12c7			      add   IX, SP 
12c7			 
12c7			      ; The address in HL points to the start of the useable allocated space, 
12c7			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12c7			      ; address of the block itself. 
12c7			      ex    DE, HL 
12c7			      ld    DE, -4 
12c7			      add   HL, DE 
12c7			 
12c7			      ; An allocated block must have a null next block pointer in it 
12c7			      ld    A, (HL) 
12c7			      inc   HL 
12c7			      or    (HL) 
12c7			      jp    NZ, free_done 
12c7			 
12c7			      dec   HL 
12c7			 
12c7			      ld    B, H                    ; Copy HL to BC 
12c7			      ld    C, L 
12c7			 
12c7			      ; Loop through the free list to find the first block with an address 
12c7			      ; higher than the block being freed 
12c7			      ld    HL, free_list 
12c7			 
12c7			free_find_higher_block: 
12c7			      ld    E, (HL)                 ; Load next ptr from free block 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      dec   HL 
12c7			 
12c7			      ld    (IX+0), E               ; Save ptr to next free block 
12c7			      ld    (IX+1), D 
12c7			      ld    (IX+2), L               ; Save ptr to prev free block 
12c7			      ld    (IX+3), H 
12c7			 
12c7			      ld    A, B                    ; Check if DE is greater than BC 
12c7			      cp    D                       ; Compare MSB first 
12c7			      jr    Z, $+4                  ; MSB the same, compare LSB 
12c7			      jr    NC, free_find_higher_block_skip 
12c7			      ld    A, C 
12c7			      cp    E                       ; Then compare LSB 
12c7			      jr    C, free_found_higher_block 
12c7			 
12c7			free_find_higher_block_skip: 
12c7			      ld    A, D                    ; Reached the end of the free list? 
12c7			      or    E 
12c7			      jp    Z, free_done 
12c7			 
12c7			      ex    DE, HL 
12c7			 
12c7			      jr    free_find_higher_block 
12c7			 
12c7			free_found_higher_block: 
12c7			      ; Insert freed block between prev and next free blocks 
12c7			      ld    (HL), C                 ; Point prev free block to freed block 
12c7			      inc   HL 
12c7			      ld    (HL), B 
12c7			 
12c7			      ld    H, B                    ; Point freed block at next free block 
12c7			      ld    L, C 
12c7			      ld    (HL), E 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			      ; Check if the freed block is adjacent to the next free block 
12c7			      inc   HL                      ; Load size of freed block into HL 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      ex    DE, HL 
12c7			 
12c7			      add   HL, BC                  ; Add addr of freed block and its size 
12c7			 
12c7			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12c7			      ld    D, (IX+1) 
12c7			 
12c7			      or    A                       ; Clear the carry flag 
12c7			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12c7			      jr    NZ, free_check_adjacent_to_prev 
12c7			 
12c7			      ; Freed block is adjacent to next, merge into one bigger block 
12c7			      ex    DE, HL                  ; Load next ptr from next block into DE 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      push  HL                      ; Save ptr to next block for later 
12c7			 
12c7			      ld    H, B                    ; Store ptr from next block into freed block 
12c7			      ld    L, C 
12c7			      ld    (HL), E 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			      pop   HL                      ; Restore ptr to next block 
12c7			      inc   HL                      ; Load size of next block into DE 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      push  DE                      ; Save next block size for later 
12c7			 
12c7			      ld    H, B                    ; Load size of freed block into HL 
12c7			      ld    L, C 
12c7			      inc   HL 
12c7			      inc   HL 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      ex    DE, HL 
12c7			 
12c7			      pop   DE                      ; Restore size of next block 
12c7			      add   HL, DE                  ; Add sizes of both blocks 
12c7			      ex    DE, HL 
12c7			 
12c7			      ld    H, B                    ; Store new bigger size into freed block 
12c7			      ld    L, C 
12c7			      inc   HL 
12c7			      inc   HL 
12c7			      ld    (HL), E 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			free_check_adjacent_to_prev: 
12c7			      ; Check if the freed block is adjacent to the prev free block 
12c7			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12c7			      ld    H, (IX+3) 
12c7			 
12c7			      inc   HL                      ; Size of prev free block into DE 
12c7			      inc   HL 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			      dec   HL 
12c7			 
12c7			      add   HL, DE                  ; Add prev block addr and size 
12c7			 
12c7			      or    A                       ; Clear the carry flag 
12c7			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12c7			      jr    NZ, free_done 
12c7			 
12c7			      ; Freed block is adjacent to prev, merge into one bigger block 
12c7			      ld    H, B                    ; Load next ptr from freed block into DE 
12c7			      ld    L, C 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      push  HL                      ; Save freed block ptr for later 
12c7			 
12c7			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12c7			      ld    H, (IX+3) 
12c7			      ld    (HL), E 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			      pop   HL                      ; Restore freed block ptr 
12c7			      inc   HL                      ; Load size of freed block into DE 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			      push  DE                      ; Save freed block size for later 
12c7			 
12c7			      ld    L, (IX+2)               ; Load size of prev block into DE 
12c7			      ld    H, (IX+3) 
12c7			      inc   HL 
12c7			      inc   HL 
12c7			      ld    E, (HL) 
12c7			      inc   HL 
12c7			      ld    D, (HL) 
12c7			 
12c7			      pop   HL                      ; Add sizes of both blocks 
12c7			      add   HL, DE 
12c7			      ex    DE, HL 
12c7			 
12c7			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12c7			      ld    H, (IX+3) 
12c7			      inc   HL 
12c7			      inc   HL 
12c7			      ld    (HL), E 
12c7			      inc   HL 
12c7			      ld    (HL), D 
12c7			 
12c7			free_done: 
12c7			      ld    HL, 4                   ; Clean up stack frame 
12c7			      add   HL, SP 
12c7			      ld    SP, HL 
12c7			 
12c7			free_early_exit: 
12c7			      pop   IX 
12c7			      pop   DE 
12c7			      pop   BC 
12c7			 
12c7			      ret 
12c7			 
12c7			 
12c7			;      .org 0x8000 
12c7			; 
12c7			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12c7			 ;                 .dw   0 
12c7			 
12c7			endif 
12c7			 
12c7			 
12c7			if MALLOC_4 
12c7			 
12c7			; My memory allocation code. Very very simple.... 
12c7			; allocate space under 250 chars 
12c7			 
12c7			heap_init: 
12c7				; init start of heap as zero 
12c7				;  
12c7			 
12c7				ld hl, heap_start 
12c7			;	ld a, 0 
12c7				ld (hl), 0      ; empty block 
12c7				inc hl 
12c7			;	ld a, 0 
12c7				ld (hl), 0      ; length of block 
12c7				; write end of list 
12c7				inc hl 
12c7				ld a,(hl) 
12c7				inc hl 
12c7				ld a,(hl) 
12c7				 
12c7			 
12c7				; init some malloc vars 
12c7			 
12c7				ld hl, 0 
12c7				ld (free_list), hl       ; store last malloc location 
12c7			 
12c7				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12c7			;	ld a, 0 
12c7				ld (hl), 0 
12c7			 
12c7			 
12c7				ld hl, heap_start 
12c7				;  
12c7				  
12c7				ret 
12c7			 
12c7			 
12c7			;    free block marker 
12c7			;    requested size  
12c7			;    pointer to next block 
12c7			;    .... 
12c7			;    next block marker 
12c7			 
12c7			 
12c7			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12c7			; 
12c7			 
12c7			 
12c7			malloc:  
12c7				push de 
12c7				push bc 
12c7				push af 
12c7			 
12c7				; hl space required 
12c7				 
12c7				ld c, l    ; hold space   (TODO only a max of 255) 
12c7			 
12c7			;	inc c     ; TODO BUG need to fix memory leak on push str 
12c7			;	inc c 
12c7			;	inc c 
12c7			;	inc c 
12c7			;	inc c 
12c7			;	inc c 
12c7			;	inc c 
12c7			 
12c7			 
12c7			 
12c7				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12c7			 
12c7				ld a, (free_list+3) 
12c7			;	cp 0 
12c7				or a 
12c7				jr z, .contheap 
12c7			 
12c7				ld hl, (free_list)     ; get last alloc 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "mrs" 
12c7						CALLMONITOR 
12c7					endif 
12c7				jr .startalloc 
12c7			 
12c7			.contheap: 
12c7				ld hl, heap_start 
12c7			 
12c7			.startalloc: 
12c7			 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "mym" 
12c7						CALLMONITOR 
12c7					endif 
12c7			.findblock: 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "mmf" 
12c7						CALLMONITOR 
12c7					endif 
12c7			 
12c7				ld a,(hl)  
12c7				; if byte is zero then clear to use 
12c7			 
12c7			;	cp 0 
12c7				or a 
12c7				jr z, .foundemptyblock 
12c7			 
12c7				; if byte is not clear 
12c7				;     then byte is offset to next block 
12c7			 
12c7				inc hl 
12c7				ld a, (hl) ; get size 
12c7			.nextblock:	inc hl 
12c7					ld e, (hl) 
12c7					inc hl 
12c7					ld d, (hl) 
12c7					ex de, hl 
12c7			;	inc hl  ; move past the store space 
12c7			;	inc hl  ; move past zero index  
12c7			 
12c7				; TODO detect no more space 
12c7			 
12c7				push hl 
12c7				ld de, heap_end 
12c7				call cmp16 
12c7				pop hl 
12c7				jr nc, .nospace 
12c7			 
12c7				jr .findblock 
12c7			 
12c7			.nospace: ld hl, 0 
12c7				jp .exit 
12c7			 
12c7			 
12c7			.foundemptyblock:	 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "mme" 
12c7						CALLMONITOR 
12c7					endif 
12c7			 
12c7			; TODO has block enough space if reusing??? 
12c7			 
12c7				;  
12c7			 
12c7			; see if this block has been previously used 
12c7				inc hl 
12c7				ld a, (hl) 
12c7				dec hl 
12c7			;	cp 0 
12c7				or a 
12c7				jr z, .newblock 
12c7			 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "meR" 
12c7						CALLMONITOR 
12c7					endif 
12c7			 
12c7			; no reusing previously allocated block 
12c7			 
12c7			; is it smaller than previously used? 
12c7				 
12c7				inc hl    ; move to size 
12c7				ld a, c 
12c7				sub (hl)        ; we want c < (hl) 
12c7				dec hl    ; move back to marker 
12c7			        jr z, .findblock 
12c7			 
12c7				; update with the new size which should be lower 
12c7			 
12c7			        ;inc  hl   ; negate next move. move back to size  
12c7			 
12c7			.newblock: 
12c7				; need to be at marker here 
12c7			 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "meN" 
12c7						CALLMONITOR 
12c7					endif 
12c7			 
12c7			 
12c7				ld a, c 
12c7			 
12c7				ld (free_list+3), a	 ; flag resume from last malloc  
12c7				ld (free_list), hl    ; save out last location 
12c7			 
12c7			 
12c7				;inc a     ; space for length byte 
12c7				ld (hl), a     ; save block in use marker 
12c7			 
12c7				inc hl   ; move to space marker 
12c7				ld (hl), a    ; save new space 
12c7			 
12c7				inc hl   ; move to start of allocated area 
12c7				 
12c7			;	push hl     ; save where we are - 1  
12c7			 
12c7			;	inc hl  ; move past zero index  
12c7				; skip space to set down new marker 
12c7			 
12c7				; provide some extra space for now 
12c7			 
12c7				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12c7				inc a 
12c7				inc a 
12c7			 
12c7				push hl   ; save where we are in the node block 
12c7			 
12c7				call addatohl 
12c7			 
12c7				; write linked list point 
12c7			 
12c7				pop de     ; get our node position 
12c7				ex de, hl 
12c7			 
12c7				ld (hl), e 
12c7				inc hl 
12c7				ld (hl), d 
12c7			 
12c7				inc hl 
12c7			 
12c7				; now at start of allocated data so save pointer 
12c7			 
12c7				push hl 
12c7			 
12c7				; jump to position of next node and setup empty header in DE 
12c7			 
12c7				ex de, hl 
12c7			 
12c7			;	inc hl ; move past end of block 
12c7			 
12c7			;	ld a, 0 
12c7				ld (hl), 0   ; empty marker 
12c7				inc hl 
12c7				ld (hl), 0   ; size 
12c7				inc hl  
12c7				ld (hl), 0   ; ptr 
12c7				inc hl 
12c7				ld (hl), 0   ; ptr 
12c7			 
12c7			 
12c7				pop hl 
12c7			 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "mmr" 
12c7						CALLMONITOR 
12c7					endif 
12c7			 
12c7			.exit: 
12c7				pop af 
12c7				pop bc 
12c7				pop de  
12c7				ret 
12c7			 
12c7			 
12c7			 
12c7			 
12c7			free:  
12c7				push hl 
12c7				push af 
12c7				; get address in hl 
12c7			 
12c7					if DEBUG_FORTH_MALLOC_INT 
12c7						DMARK "fre" 
12c7						CALLMONITOR 
12c7					endif 
12c7				; data is at hl - move to block count 
12c7				dec hl 
12c7				dec hl    ; get past pointer 
12c7				dec hl 
12c7			 
12c7				ld a, (hl)    ; need this for a validation check 
12c7			 
12c7				dec hl    ; move to block marker 
12c7			 
12c7				; now check that the block count and block marker are the same  
12c7			        ; this checks that we are on a malloc node and not random memory 
12c7			        ; OK a faint chance this could be a problem but rare - famous last words! 
12c7			 
12c7				ld c, a 
12c7				ld a, (hl)    
12c7			 
12c7				cp c 
12c7				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12c7			 
12c7				; yes good chance we are on a malloc node 
12c7			 
12c7			;	ld a, 0      
12c7				ld (hl), 0   ; mark as free 
12c7			 
12c7				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12c7			 
12c7			.freeignore:  
12c7			 
12c7				pop af 
12c7				pop hl 
12c7			 
12c7				ret 
12c7			 
12c7			 
12c7			 
12c7			endif 
