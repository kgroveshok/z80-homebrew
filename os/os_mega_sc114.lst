8d3f			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
8d3f			 
8d3f			 
8d3f			;Converts an ASCII string to an unsigned 16-bit integer 
8d3f			;Quits when it reaches a non-decimal digit 
8d3f			 
8d3f			string_to_uint16: 
8d3f			atoui_16: 
8d3f			;Input: 
8d3f			;     DE points to the string 
8d3f			;Outputs: 
8d3f			;     HL is the result 
8d3f			;     A is the 8-bit value of the number 
8d3f			;     DE points to the byte after the number 
8d3f			;Destroys: 
8d3f			;     BC 
8d3f			;       if the string is non-empty, BC is HL/10 
8d3f			;Size:  24 bytes 
8d3f			;Speed: 42+d(104+{0,9}) 
8d3f			;       d is the number of digits in the number 
8d3f			;       max is 640 cycles for a 5 digit number 
8d3f			;Assuming no leading zeros: 
8d3f			;1 digit:  146cc 
8d3f			;2 digit:  250cc 
8d3f			;3 digit:  354cc or 363cc (avg: 354.126cc) 
8d3f			;4 digit:  458cc or 467cc (avg: 458.27cc) 
8d3f			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
8d3f			;avg: 544.81158447265625cc (544+13297/16384) 
8d3f			;=============================================================== 
8d3f 21 00 00		  ld hl,0 
8d42			.u16a: 
8d42 1a			  ld a,(de) 
8d43 d6 30		  sub 30h 
8d45 fe 0a		  cp 10 
8d47 d0			  ret nc 
8d48 13			  inc de 
8d49 44			  ld b,h 
8d4a 4d			  ld c,l 
8d4b 29			  add hl,hl 
8d4c 29			  add hl,hl 
8d4d 09			  add hl,bc 
8d4e 29			  add hl,hl 
8d4f 85			  add a,l 
8d50 6f			  ld l,a 
8d51 30 ef		  jr nc,.u16a 
8d53 24			  inc h 
8d54 c3 42 8d		  jp .u16a 
