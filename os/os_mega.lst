69d4			; **********************************************************************  
69d4			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
69d4			; **********************************************************************  
69d4			;  
69d4			; **  Written as a Small Computer Monitor App   
69d4			; **  Version 0.1 SCC 2018-05-16  
69d4			; **  www.scc.me.uk  
69d4			;  
69d4			; **********************************************************************  
69d4			;  
69d4			; This module provides support for alphanumeric LCD modules using with  
69d4			; *  HD44780 (or compatible) controller  
69d4			; *  5 x 7 pixel fonts  
69d4			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
69d4			; *  Interface via six digital outputs to the display (see below)  
69d4			;  
69d4			; LCD module pinout:  
69d4			;   1  Vss   0v supply  
69d4			;   2  Vdd   5v supply  
69d4			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
69d4			;   4  RS    High = data, Low = instruction  
69d4			;   5  R/W   High = Read, Low = Write  
69d4			;   6  E     Enable signal (active high)  
69d4			;   7  DB0   Data bit 0  
69d4			;   8  DB1   Data bit 1  
69d4			;   9  DB2   Data bit 2  
69d4			;  10  DB3   Data bit 3  
69d4			;  11  DB4   Data bit 4  
69d4			;  12  DB5   Data bit 5  
69d4			;  13  DB6   Data bit 6  
69d4			;  14  DB7   Data bit 7  
69d4			;  15  A     Backlight anode (+)  
69d4			;  16  K     Backlight cathode (-)  
69d4			;  
69d4			; This interfacing method uses 4-bit data mode and uses time delays  
69d4			; rather than polling the display's ready status. As a result the   
69d4			; interface only requires 6 simple output lines:  
69d4			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
69d4			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
69d4			;   LCD DB4 = Microcomputer output port bit 4  
69d4			;   LCD DB5 = Microcomputer output port bit 5  
69d4			;   LCD DB6 = Microcomputer output port bit 6  
69d4			;   LCD DB7 = Microcomputer output port bit 7  
69d4			; Display's R/W is connected to 0v so it is always in write mode  
69d4			; All 6 connections must be on the same port address <kLCDPrt>  
69d4			; This method also allows a decent length of cable from micro to LCD  
69d4			;  
69d4			; **********************************************************************  
69d4			;  
69d4			; To include the code for any given function provided by this module,   
69d4			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
69d4			; the parent source file.  
69d4			; For example:  #REQUIRES   uHexPrefix  
69d4			;  
69d4			; Also #INCLUDE this file at some point after the #REQUIRES statements  
69d4			; in the parent source file.  
69d4			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
69d4			;  
69d4			; These are the function names provided by this module:  
69d4			; fLCD_Init                     ;Initialise LCD  
69d4			; fLCD_Inst                     ;Send instruction to LCD  
69d4			; fLCD_Data                     ;Send data byte to LCD  
69d4			; fLCD_Pos                      ;Position cursor  
69d4			; fLCD_Str                      ;Display string  
69d4			; fLCD_Def                      ;Define custom character  
69d4			;  
69d4			; **********************************************************************  
69d4			;  
69d4			; Requires SCMonAPI.asm to also be included in the project  
69d4			;  
69d4			  
69d4			  
69d4			; **********************************************************************  
69d4			; **  Constants  
69d4			; **********************************************************************  
69d4			  
69d4			; Constants that must be defined externally  
69d4			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
69d4			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
69d4			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
69d4			;kLCDWidth: EQU 20             ;Width in characters  
69d4			  
69d4			; general line offsets in any frame buffer  
69d4			  
69d4			  
69d4			display_row_1: equ 0  
69d4			display_row_2: equ display_row_1+display_cols  
69d4			display_row_3: equ display_row_2 + display_cols  
69d4			display_row_4: equ display_row_3 + display_cols  
69d4			;display_row_4_eol:   
69d4			  
69d4			  
69d4			; Cursor position values for the start of each line  
69d4			  
69d4			; E  
69d4			kLCD_Line1: EQU 0x00   
69d4			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
69d4			; E1  
69d4			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
69d4			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
69d4			  
69d4			; Instructions to send as A register to fLCD_Inst  
69d4			kLCD_Clear: EQU 00000001b     ;LCD clear  
69d4			kLCD_Off:   EQU 00001000b     ;LCD off  
69d4			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
69d4			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
69d4			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
69d4			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
69d4			  
69d4			; Constants used by this code module  
69d4			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
69d4			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
69d4			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
69d4			  
69d4			  
69d4			  
69d4			; **********************************************************************  
69d4			; **  LCD support functions  
69d4			; **********************************************************************  
69d4			  
69d4			; Initialise alphanumeric LCD module  
69d4			; LCD control register codes:  
69d4			;   DL   0 = 4-bit mode        1 = 8-bit mode  
69d4			;   N    0 = 1-line mode       1 = 2-line mode  
69d4			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
69d4			;   D    0 = Display off       1 = Display on  
69d4			;   C    0 = Cursor off        1 = Cursor on  
69d4			;   B    0 = Blinking off      1 = Blinking on  
69d4			;   ID   0 = Decrement mode    1 = Increment mode  
69d4			;   SH   0 = Entire shift off  1 = Entire shift on  
69d4 3e 28		fLCD_Init:  LD   A, 40  
69d6 cd 17 6b		            CALL LCDDelay       ;Delay 40ms after power up  
69d9			; For reliable reset set 8-bit mode - 3 times  
69d9 cd e7 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69dc cd e7 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69df cd e7 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69e2			; Set 4-bit mode  
69e2 cd e3 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
69e5 cd 15 6b		            CALL LCDDelay1      ;Delay 37 us or more  
69e8			; Function set  
69e8 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
69ea cd 0d 6a		            CALL fLCD_Inst      ;2 line, display on  
69ed			; Display On/Off control  
69ed 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
69ef cd 0d 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
69f2			; Display Clear  
69f2 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
69f4 cd 0d 6a		            CALL fLCD_Inst      ;Clear display  
69f7			; Entry mode  
69f7 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
69f9 cd 0d 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
69fc			; Display module now initialised  
69fc c9			            RET  
69fd			; ok to here  
69fd			  
69fd			; decide on setting bit for LED on or off  
69fd			; Set correct bit in A  
69fd e5			IsLED: push hl  
69fe 21 ad fd			ld hl, hardware_word+1  
6a01 cb 56			bit 2, (hl)    ; led bit  
6a03 20 04			jr nz, .isled1  
6a05 cb 8f			res kLCDBitLED, a  
6a07 18 02			jr .isleddone  
6a09 cb cf		.isled1: set kLCDBitLED, a  
6a0b			.isleddone:  	  
6a0b e1				pop hl  
6a0c			  
6a0c c9				ret  
6a0d			  
6a0d			  
6a0d			; Write instruction to LCD  
6a0d			;   On entry: A = Instruction byte to be written  
6a0d			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a0d f5			fLCD_Inst:  PUSH AF  
6a0e f5			            PUSH AF  
6a0f cd 21 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a12 f1			            POP  AF  
6a13 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a14 17			            RLA  
6a15 17			            RLA  
6a16 17			            RLA  
6a17 cd 21 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6a1a 3e 02		            LD   A, 2  
6a1c cd 17 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6a1f f1			            POP  AF  
6a20 c9			            RET  
6a21			Wr4bits:   
6a21 f5					push af  
6a22 3a fb fa				ld a, (display_lcde1e2)  
6a25 fe 00				cp 0     ; e  
6a27 20 13				jr nz, .wea2	  
6a29 f1					pop af  
6a2a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a2c cd fd 69				call IsLED  
6a2f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a31 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6a33 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6a35 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a37 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6a39 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a3b c9			            RET  
6a3c f1			.wea2:		pop af  
6a3d e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a3f cd fd 69				call IsLED  
6a42 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a44 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6a46 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6a48 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a4a cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6a4c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a4e c9			            RET  
6a4f			  
6a4f			  
6a4f			; Write data to LCD  
6a4f			;   On entry: A = Data byte to be written  
6a4f			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a4f f5			fLCD_Data:  PUSH AF  
6a50 f5			            PUSH AF  
6a51 cd 63 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6a54 f1			            POP  AF  
6a55 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a56 17			            RLA  
6a57 17			            RLA  
6a58 17			            RLA  
6a59 cd 63 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6a5c 3e 96		            LD   A, 150  
6a5e 3d			Wait:      DEC  A              ;Wait a while to allow data   
6a5f 20 fd		            JR   NZ, Wait      ;  write to complete  
6a61 f1			            POP  AF  
6a62 c9			            RET  
6a63			Wr4bitsa:     
6a63 f5					push af  
6a64 3a fb fa				ld a, (display_lcde1e2)  
6a67 fe 00				cp 0     ; e1  
6a69 20 19				jr nz, .we2	  
6a6b f1					pop af  
6a6c e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a6e cd fd 69				call IsLED  
6a71 cb d7		            SET  kLCDBitRS, A  
6a73 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a75 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6a77 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6a79 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a7b cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6a7d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a7f cb 97		            RES  kLCDBitRS, A  
6a81 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a83 c9			            RET  
6a84 f1			.we2:		pop af  
6a85 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a87 cd fd 69				call IsLED  
6a8a cb d7		            SET  kLCDBitRS, A  
6a8c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a8e cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6a90 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6a92 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a94 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6a96 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a98 cb 97		            RES  kLCDBitRS, A  
6a9a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a9c c9			            RET  
6a9d			  
6a9d			  
6a9d			; Position cursor to specified location  
6a9d			;   On entry: A = Cursor position  
6a9d			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a9d f5			fLCD_Pos:   PUSH AF  
6a9e					; at this point set the E1 or E2 flag depending on position  
6a9e			  
6a9e c5					push bc  
6a9f			;		push af  
6a9f 06 00				ld b, 0  
6aa1 4f					ld c, a  
6aa2 3e 4f				ld a, kLCD_Line3-1  
6aa4 b7			 		or a      ;clear carry flag  
6aa5 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6aa6 38 04				jr c, .pe1  
6aa8			  
6aa8					; E selection  
6aa8 cb 80				res 0, b         ; bit 0 unset e  
6aaa			;		pop af    ; before line 3 so recover orig pos  
6aaa			;		ld c, a    ; save for poking back  
6aaa 18 06				jr .peset	          
6aac			.pe1:          	; E2 selection  
6aac cb c0				set 0, b         ; bit 0 set e1  
6aae 79					ld a, c  
6aaf de 4f				sbc a, kLCD_Line3-1  
6ab1 4f					ld c, a	         ; save caculated offset  
6ab2			;		pop af     ; bin this original value now we have calculated form  
6ab2			  
6ab2			.peset:		; set bit  
6ab2 78					ld a, b  
6ab3 32 fb fa				ld (display_lcde1e2), a 	  
6ab6 79					ld a, c  
6ab7 c1					pop bc  
6ab8			  
6ab8 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6aba cd 0d 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6abd f1			            POP  AF  
6abe c9			            RET  
6abf			  
6abf			  
6abf			; Output text string to LCD  
6abf			;   On entry: DE = Pointer to null terminated text string  
6abf			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6abf 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6ac0 b7			            OR   A              ;Null terminator?  
6ac1 c8			            RET  Z              ;Yes, so finished  
6ac2 cd 4f 6a		            CALL fLCD_Data      ;Write character to display  
6ac5 13			            INC  DE             ;Point to next character  
6ac6 18 f7		            JR   fLCD_Str       ;Repeat  
6ac8 c9					ret  
6ac9			  
6ac9			; Define custom character  
6ac9			;   On entry: A = Character number (0 to 7)  
6ac9			;             DE = Pointer to character bitmap data  
6ac9			;   On exit:  A = Next character number  
6ac9			;             DE = Next location following bitmap  
6ac9			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6ac9			; Character is   
6ac9 c5			fLCD_Def:   PUSH BC  
6aca f5			            PUSH AF  
6acb 07			            RLCA                ;Calculate location  
6acc 07			            RLCA                ;  for bitmap data  
6acd 07			            RLCA                ;  = 8 x CharacterNumber  
6ace f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6ad0 cd 0d 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ad3 06 00		            LD   B, 0  
6ad5 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6ad6 cd 4f 6a		            CALL fLCD_Data      ;Write byte to display  
6ad9 13			            INC  DE             ;Point to next byte  
6ada 04			            INC  B              ;Count bytes  
6adb cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6add 28 f6		            JR   Z, Loop       ;No, so repeat  
6adf f1			            POP  AF  
6ae0 3c			            INC  A              ;Increment character number  
6ae1 c1			            POP  BC  
6ae2 c9			            RET  
6ae3			  
6ae3			  
6ae3			; **********************************************************************  
6ae3			; **  Private functions  
6ae3			; **********************************************************************  
6ae3			  
6ae3			; Write function to LCD  
6ae3			;   On entry: A = Function byte to be written  
6ae3			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ae3 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6ae5 18 02		            JR   WrFunc  
6ae7 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6ae9 f5			WrFunc:     PUSH AF  
6aea f5					push af  
6aeb 3a fb fa				ld a, (display_lcde1e2)  
6aee fe 00				cp 0     ; e1  
6af0 20 0f				jr nz, .wfea2	  
6af2 f1					pop af  
6af3 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6af5 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6af7 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6af9 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6afb cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6afd d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6aff 18 0d			jr .wfskip  
6b01 f1			.wfea2:		pop af  
6b02 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b04 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6b06 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b08 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b0a cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b0c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b0e 3e 05		.wfskip:            LD  A, 5  
6b10 cd 17 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b13 f1			            POP  AF  
6b14 c9			            RET  
6b15			  
6b15			  
6b15			; Delay in milliseconds  
6b15			;   On entry: A = Number of milliseconds delay  
6b15			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6b15 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
6b17 d5			LCDDelay:   PUSH DE  
6b18 5f			            LD   E, A           ;Delay by 'A' ms  
6b19 16 00		            LD   D, 0  
6b1b cd 5b 0a		            CALL aDelayInMS  
6b1e d1			            POP  DE  
6b1f c9			            RET  
6b20			  
6b20			  
6b20			testlcd:  
6b20 3e 00			ld a, kLCD_Line1  
6b22 cd 9d 6a			call fLCD_Pos  
6b25 06 28			ld b, 40  
6b27 11 55 6b			ld de, .ttext1  
6b2a cd cc 69			call write_len_string  
6b2d			  
6b2d 3e 28			ld a, kLCD_Line2  
6b2f cd 9d 6a			call fLCD_Pos  
6b32 06 28			ld b, 40  
6b34 11 7e 6b			ld de, .ttext2  
6b37 cd cc 69			call write_len_string  
6b3a 3e 50			ld a, kLCD_Line3  
