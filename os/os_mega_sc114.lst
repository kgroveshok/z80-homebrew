98bf 2a d6 e9			ld hl,(cli_ret_sp) 
98c2 11 90 e9			ld de, cli_ret_stack 
98c5 cd 58 8a			call cmp16 
98c8 da 1d d3			jp c, fault_rsp_under 
98cb d1				pop de 
98cc e1				pop hl 
98cd				endm 
