9b71			.HEAP: 
9b71			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9b71 15				db WORD_SYS_CORE+OPCODE_HEAP             
9b72 9f 9b			dw .EXEC            
9b74 05				db 4 + 1 
9b75 .. 00			db "HEAP",0              
9b7a				endm 
# End of macro CWHEAD
9b7a			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9b7a			; | | u1 - Current number of bytes in the heap 
9b7a			; | | u2 - Remaining bytes left on the heap 
9b7a			; | |  
9b7a			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9b7a			 
9b7a			 
9b7a				if DEBUG_FORTH_WORDS_KEY 
9b7a					DMARK "HEP" 
9b7a				if DEMARK_VERSION = 1  
9b7a e5					push hl  
9b7b 21 83 9b				ld hl, .dmark  
9b7e 22 60 ee				ld (debug_mark), hl  
9b81				endif  
9b81				if DEMARK_VERSION = 0  
9b81					push af  
9b81					ld a, (.dmark)  
9b81					ld (debug_mark),a  
9b81					ld a, (.dmark+1)  
9b81					ld (debug_mark+1),a  
9b81					ld a, (.dmark+2)  
9b81					ld (debug_mark+2),a  
9b81				endif  
9b81 18 04			jr .pastdmark  
9b83 ..			.dmark: db "HEP"  
9b86				if DEMARK_VERSION = 1  
9b86 00					db 0  
9b87				endif  
9b87				if DEMARK_VERSION = 1  
9b87 e1			.pastdmark: pop hl  
9b88				endif  
9b88				if DEMARK_VERSION = 0  
9b88			.pastdmark: pop af  
9b88				endif  
9b88			endm  
# End of macro DMARK
9b88					CALLMONITOR 
9b88				if BASE_CPM=1  
9b88					call debug_vector  
9b88				endif  
9b88				if BASE_KEV=1  
9b88					rst 8  
9b88				endif  
9b88				endm  
# End of macro CALLMONITOR
9b88				endif 
9b88 2a a9 d0			ld hl, (free_list )      
9b8b 11 ae d0			ld de, heap_start 
9b8e			 
9b8e ed 52			sbc hl, de  
9b90			 
