125a			      ; Check if the freed block is adjacent to the prev free block 
125a dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
125d dd 66 03		      ld    H, (IX+3) 
1260			 
1260 23			      inc   HL                      ; Size of prev free block into DE 
1261 23			      inc   HL 
1262 5e			      ld    E, (HL) 
1263 23			      inc   HL 
1264 56			      ld    D, (HL) 
1265 2b			      dec   HL 
1266 2b			      dec   HL 
1267 2b			      dec   HL 
1268			 
1268 19			      add   HL, DE                  ; Add prev block addr and size 
1269			 
1269 b7			      or    A                       ; Clear the carry flag 
126a ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
126c 20 2e		      jr    NZ, free_done 
126e			 
126e			      ; Freed block is adjacent to prev, merge into one bigger block 
126e 60			      ld    H, B                    ; Load next ptr from freed block into DE 
126f 69			      ld    L, C 
1270 5e			      ld    E, (HL) 
1271 23			      inc   HL 
1272 56			      ld    D, (HL) 
1273 e5			      push  HL                      ; Save freed block ptr for later 
1274			 
1274 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1277 dd 66 03		      ld    H, (IX+3) 
127a 73			      ld    (HL), E 
127b 23			      inc   HL 
127c 72			      ld    (HL), D 
127d			 
127d e1			      pop   HL                      ; Restore freed block ptr 
127e 23			      inc   HL                      ; Load size of freed block into DE 
127f 5e			      ld    E, (HL) 
1280 23			      inc   HL 
1281 56			      ld    D, (HL) 
1282 d5			      push  DE                      ; Save freed block size for later 
1283			 
1283 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
1286 dd 66 03		      ld    H, (IX+3) 
1289 23			      inc   HL 
128a 23			      inc   HL 
128b 5e			      ld    E, (HL) 
128c 23			      inc   HL 
128d 56			      ld    D, (HL) 
128e			 
128e e1			      pop   HL                      ; Add sizes of both blocks 
