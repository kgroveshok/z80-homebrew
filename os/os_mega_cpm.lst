108a			;------------------------------------------------------------------------------ 
108a			;     free                                                                    : 
108a			;                                                                             : 
108a			; Description                                                                 : 
108a			;     Return the space pointed to by HL to the heap. HL must be an address as : 
108a			;     returned by malloc, otherwise the behaviour is undefined.               : 
108a			;                                                                             : 
108a			;     Where possible, directly adjacent free blocks will be merged together   : 
108a			;     into larger blocks to help ensure that the heap does not become         : 
108a			;     excessively fragmented.                                                 : 
108a			;                                                                             : 
108a			;     free does not clear or set any other value into the freed space, and    : 
108a			;     therefore its contents may be visible through subsequent malloc's. The  : 
108a			;     caller should clear the freed space as required.                        : 
108a			;                                                                             : 
108a			;     This implementation of free uses the stack exclusively, and is          : 
108a			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
108a			;     advisable to disable interrupts before calling free, and recommended    : 
108a			;     to avoid the use of free inside ISRs in general.                        : 
108a			;                                                                             : 
108a			;     NOTE: heap_init must be called before malloc and free can be used.      : 
108a			;                                                                             : 
108a			; Parameters                                                                  : 
108a			;     HL  Pointer to address of first byte of allocation to be freed          : 
108a			;                                                                             : 
108a			; Returns                                                                     : 
108a			;     Nothing                                                                 : 
108a			;                                                                             : 
108a			; Stack frame                                                                 : 
108a			;       |             |                                                       : 
108a			;       +-------------+                                                       : 
108a			;       |     BC      |                                                       : 
108a			;       +-------------+                                                       : 
108a			;       |     DE      |                                                       : 
108a			;       +-------------+                                                       : 
108a			;       |     IX      |                                                       : 
108a			;       +-------------+                                                       : 
108a			;       |  prev_free  |                                                       : 
108a			;   +2  +-------------+                                                       : 
108a			;       |  next_free  |                                                       : 
108a			;   +0  +-------------+                                                       : 
108a			;       |             |                                                       : 
108a			;                                                                             : 
108a			;------------------------------------------------------------------------------ 
108a			free: 
108a c5			      push  BC 
108b d5			      push  DE 
108c dd e5		      push  IX 
108e			 
108e 7c			      ld    A, H                    ; Exit if ptr is null 
108f b5			      or    L 
1090 ca 54 11		      jp    Z, free_early_exit 
1093			 
1093			      ; Set up stack frame 
1093 eb			      ex    DE, HL 
1094 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1097 39			      add   HL, SP 
1098 f9			      ld    SP, HL 
1099 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
109d dd 39		      add   IX, SP 
109f			 
109f			      ; The address in HL points to the start of the useable allocated space, 
109f			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
109f			      ; address of the block itself. 
109f eb			      ex    DE, HL 
10a0 11 fc ff		      ld    DE, -4 
10a3 19			      add   HL, DE 
10a4			 
