9e07					ld a, (.dmark)  
9e07					ld (debug_mark),a  
9e07					ld a, (.dmark+1)  
9e07					ld (debug_mark+1),a  
9e07					ld a, (.dmark+2)  
9e07					ld (debug_mark+2),a  
9e07				endif  
9e07 18 04			jr .pastdmark  
9e09 ..			.dmark: db "HEP"  
