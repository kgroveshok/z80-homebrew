bf35			 
bf35			.SPIBOb: 
bf35			 
bf35				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
bf35			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
bf35			 
bf35					if DEBUG_FORTH_WORDS_KEY 
bf35						DMARK "SPo" 
bf35						CALLMONITOR 
bf35					endif 
bf35					; get port 
bf35			 
bf35			 
bf35					; get byte to send 
bf35			 
bf35					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf35			 
bf35			;		push hl    ; u1  
bf35			 
bf35					; destroy value TOS 
bf35			 
bf35					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf35			 
bf35					; one value on hl get other one back 
bf35			 
bf35			;		pop hl   ; u2 - addr 
bf35			 
bf35					; TODO Send SPI byte 
bf35			 
bf35			;		push hl 
bf35			;		call spi_ce_low 
bf35			;		pop hl 
bf35					ld a, l 
bf35					call spi_send_byte 
bf35			;		call spi_ce_high 
bf35			 
bf35					NEXTW 
bf35			 
bf35			.SPII: 
bf35				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bf35			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bf35					if DEBUG_FORTH_WORDS_KEY 
bf35						DMARK "SPi" 
bf35						CALLMONITOR 
bf35					endif 
bf35			 
bf35					; TODO Get SPI byte 
bf35			 
bf35					call spi_read_byte 
bf35			 
bf35					if DEBUG_FORTH_WORDS 
bf35						DMARK "Si2" 
bf35						CALLMONITOR 
bf35					endif 
bf35					ld h, 0 
bf35					ld l, a 
bf35					if DEBUG_FORTH_WORDS 
bf35						DMARK "Si3" 
bf35						CALLMONITOR 
bf35					endif 
bf35					;call forth_push_numhl 
bf35					FORTH_PUSH_VALUEHL 
bf35			 
bf35					NEXTW 
bf35			 
bf35			 
bf35			 
bf35			.SESEL: 
bf35				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bf35			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bf35			; | | Zero is disabled storage. 
bf35					if DEBUG_FORTH_WORDS_KEY 
bf35						DMARK "BN?" 
bf35						CALLMONITOR 
bf35					endif 
bf35					ld a, (spi_device_id) 
bf35					sub '0' 
bf35					ld h, 0 
bf35					ld l, a 
bf35					FORTH_PUSH_VALUEHL 
bf35					;call forth_push_numhl 
bf35					NEXTW 
bf35			.SESELS: 
bf35				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bf35			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bf35			; | | Set to zero to disable storage. 
bf35					if DEBUG_FORTH_WORDS_KEY 
bf35						DMARK "BNK" 
bf35						CALLMONITOR 
bf35					endif 
bf35			 
bf35					ld a, 255 
bf35					ld (spi_cartdev), a 
bf35			 
bf35					; get bank 
bf35			 
bf35					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf35			 
bf35			;		push hl 
bf35			 
bf35					; destroy value TOS 
bf35			 
bf35					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf35			 
bf35					; one value on hl get other one back 
bf35			 
bf35			;		pop hl 
bf35			 
bf35			 
bf35					ld c, SPI_CE_HIGH 
bf35					ld b, '0'    ; human readable bank number 
bf35			 
bf35					ld a, l 
bf35			 
bf35					if DEBUG_FORTH_WORDS 
bf35						DMARK "BNK" 
bf35						CALLMONITOR 
bf35					endif 
bf35			 
bf35					; active low 
bf35			 
bf35			;		cp 0 
bf35					or a 
bf35					jr z, .bset 
bf35					cp 1 
bf35					jr nz, .b2 
bf35					res 0, c 
bf35					ld b, '1'    ; human readable bank number 
bf35			.b2:		cp 2 
bf35					jr nz, .b3 
bf35					res 1, c 
bf35					ld b, '2'    ; human readable bank number 
bf35			.b3:		cp 3 
bf35					jr nz, .b4 
bf35					res 2, c 
bf35					ld b, '3'    ; human readable bank number 
bf35			.b4:		cp 4 
bf35					jr nz, .b5 
bf35					res 3, c 
bf35					ld b, '4'    ; human readable bank number 
bf35			.b5:		cp 5 
bf35					jr nz, .bset 
bf35					res 4, c 
bf35					ld b, '5'    ; human readable bank number 
bf35			 
bf35			.bset: 
bf35					ld a, c 
bf35					ld (spi_device),a 
bf35					ld a, b 
bf35					ld (spi_device_id),a 
bf35					if DEBUG_FORTH_WORDS 
bf35						DMARK "BN2" 
bf35						CALLMONITOR 
bf35					endif 
bf35			 
bf35					; set default SPI clk pulse time as disabled for BANK use 
bf35			 
bf35					ld a, 0 
bf35					ld (spi_clktime), a 
bf35			 
bf35					NEXTW 
bf35			 
bf35			.CARTDEV: 
bf35				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bf35			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bf35			; | | Set to zero to disable devices. 
bf35					if DEBUG_FORTH_WORDS_KEY 
bf35						DMARK "CDV" 
bf35						CALLMONITOR 
bf35					endif 
bf35			 
bf35					; disable se storage bank selection 
bf35			 
bf35					ld a, SPI_CE_HIGH		; ce high 
bf35					ld (spi_device), a 
bf35			 
bf35					; get bank 
bf35			 
bf35					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf35			 
bf35			;		push hl 
bf35			 
bf35					; destroy value TOS 
bf35			 
bf35					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf35			 
bf35					; one value on hl get other one back 
bf35			 
bf35			;		pop hl 
bf35			 
bf35					; active low 
bf35			 
bf35					ld c, 255 
bf35			 
bf35					ld a, l 
bf35					if DEBUG_FORTH_WORDS 
bf35						DMARK "CDV" 
bf35						CALLMONITOR 
bf35					endif 
bf35			;		cp 0 
bf35					or a 
bf35					jr z, .cset 
bf35					cp 1 
bf35					jr nz, .c2 
bf35					res 0, c 
bf35			.c2:		cp 2 
bf35					jr nz, .c3 
bf35					res 1, c 
bf35			.c3:		cp 3 
bf35					jr nz, .c4 
bf35					res 2, c 
bf35			.c4:		cp 4 
bf35					jr nz, .c5 
bf35					res 3, c 
bf35			.c5:		cp 5 
bf35					jr nz, .c6 
bf35					res 4, c 
bf35			.c6:		cp 6 
bf35					jr nz, .c7 
bf35					res 5, c 
bf35			.c7:		cp 7 
bf35					jr nz, .c8 
bf35					res 6, c 
bf35			.c8:		cp 8 
bf35					jr nz, .cset 
bf35					res 7, c 
bf35			.cset:		ld a, c 
bf35					ld (spi_cartdev),a 
bf35			 
bf35					if DEBUG_FORTH_WORDS 
bf35						DMARK "CD2" 
bf35						CALLMONITOR 
bf35					endif 
bf35			 
bf35					; set default SPI clk pulse time as 10ms for CARTDEV use 
bf35			 
bf35					ld a, $0a 
bf35					ld (spi_clktime), a 
bf35					NEXTW 
bf35			endif 
bf35			 
bf35			.ENDDEVICE: 
bf35			; eof 
bf35			 
# End of file forth_words_device.asm
