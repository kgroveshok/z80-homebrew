5245 3a 59 52			ld a, (.dmark)  
5248 32 5e ee			ld (debug_mark),a  
524b 3a 5a 52			ld a, (.dmark+1)  
524e 32 5f ee			ld (debug_mark+1),a  
5251 3a 5b 52			ld a, (.dmark+2)  
5254 32 60 ee			ld (debug_mark+2),a  
5257 18 03			jr .pastdmark  
5259 ..			.dmark: db "VAR"  
525c f1			.pastdmark: pop af  
525d			endm  
# End of macro DMARK
