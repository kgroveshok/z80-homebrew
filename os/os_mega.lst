6796			; **********************************************************************  
6796			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
6796			; **********************************************************************  
6796			;  
6796			; **  Written as a Small Computer Monitor App  
6796			; **  www.scc.me.uk  
6796			;  
6796			; History  
6796			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
6796			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
6796			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
6796			;  
6796			; **********************************************************************  
6796			;  
6796			; This program is an example of one of the methods of interfacing an   
6796			; alphanumeric LCD module.   
6796			;  
6796			; In this example the display is connected to either a Z80 PIO or a   
6796			; simple 8-bit output port.   
6796			;  
6796			; This interfacing method uses 4-bit data mode and uses time delays  
6796			; rather than polling the display's ready status. As a result the   
6796			; interface only requires 6 simple output lines:  
6796			;   Output bit 0 = not used  
6796			;   Output bit 1 = not used  
6796			;   Output bit 2 = RS         High = data, Low = instruction  
6796			;   Output bit 3 = E          Active high  
6796			;   Output bit 4 = DB4  
6796			;   Output bit 5 = DB5  
6796			;   Output bit 6 = DB6  
6796			;   Output bit 7 = DB7  
6796			; Display's R/W is connected to 0v so it is always in write mode  
6796			;  
6796			; This set up should work with any system supporting the RC2014 bus  
6796			  
6796			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
6796			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
6796			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
6796			;  
6796			; **********************************************************************  
6796			  
6796			; Additonal for 4x40. E1 and E2 instead of just E   
6796			; TODO swipe vidout signal on port a to activate E2  
6796			  
6796			; **********************************************************************  
6796			; **  Constants  
6796			; **********************************************************************  
6796			; LCD constants required by LCD support module  
6796			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
6796			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
6796			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
6796			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
6796			; TODO Decide which E is being set  
6796			kLCDWidth:  EQU display_cols             ;Width in characters  
6796			  
6796			; **********************************************************************  
6796			; **  Code library usage  
6796			; **********************************************************************  
6796			  
6796			; send character to current cursor position  
6796			; wraps and/or scrolls screen automatically  
6796			  
6796			  
6796			  
6796			lcd_init:  
6796			  
6796			; SCMonAPI functions used  
6796			  
6796			; Alphanumeric LCD functions used  
6796			; no need to specify specific functions for this module  
6796			  
6796 3e cf		            LD   A, 11001111b  
6798 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
679a 3e 00		            LD   A, 00000000b  
679c d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
679e			  
679e			; Initialise alphanumeric LCD module  
679e 3e 00				ld a, 0  
67a0 32 fb fa				ld (display_lcde1e2), a  
67a3 cd 24 68		            CALL fLCD_Init      ;Initialise LCD module  
67a6 3e 01				ld a, 1  
67a8 32 fb fa				ld (display_lcde1e2), a  
67ab cd 24 68		            CALL fLCD_Init      ;Initialise LCD module  
67ae			  
67ae c9				ret  
