43f6			.GP2: 
43f6			 
43f6				CWHEAD .GPI 31 "SETTAPE" 7 WORD_FLAG_CODE 
43f6			; | SETTAPE ( port gap freq high low -- )   Set parameters for tape support | DONE 
43f6			; | | port - Device address port; default is Device A on 00h 
43f6			; | | gap - Gap period counter; default is 250 
43f6			; | | freq - Osc freq; default 0ms 
43f6			; | | high - High bit period counter; default is 150 
43f6			; | | low - Low bit period counter; default is 50 
43f6			 
43f6					if DEBUG_FORTH_WORDS_KEY 
43f6						DMARK "TSE" 
43f6						CALLMONITOR 
43f6					endif 
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					ld (tape_tm_low), hl 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					ld (tape_tm_high), hl 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					ld a, l 
43f6					ld (tape_tm_freq), a 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					ld a, l 
43f6					ld (tape_tm_gap), a 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					ld a, l 
43f6					ld (tape_port), a 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6					NEXTW 
43f6			 
43f6			 
43f6			.GPI: 
43f6				CWHEAD .GPS 31 "SAVES" 5 WORD_FLAG_CODE 
43f6			; | SAVES ( s1 ... sn c n -- )    Save a count of c strings using file name of n to tape | DONE 
43f6					if DEBUG_FORTH_WORDS_KEY 
43f6						DMARK "SAS" 
43f6						CALLMONITOR 
43f6					endif 
