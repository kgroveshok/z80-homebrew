248c			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
248c			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
248c			WORD_SYS_END: equ 0   ; Opcode for all user words 
248c			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
248c			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
