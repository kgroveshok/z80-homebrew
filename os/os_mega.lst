0d1e			; Out: HL = result 
0d1e			; 
0d1e			Mult12U: 
0d1e 2e 00		    ld l,0 
0d20 87			    add a,a 
0d21 30 01		    jr nc,Mult12U_NoAdd0 
0d23 19			    add hl,de 
