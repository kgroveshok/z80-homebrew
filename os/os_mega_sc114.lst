cc2a 32 60 ee			ld (debug_mark+2),a  
cc2d 18 03			jr .pastdmark  
cc2f ..			.dmark: db "VAR"  
cc32 f1			.pastdmark: pop af  
cc33			endm  
# End of macro DMARK
