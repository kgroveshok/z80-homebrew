11c2			malloc_guard_zerolen: 
11c2				push hl 
11c2				push de 
11c2				push af 
11c2			 
11c2				ld de, 0 
11c2			        call cmp16 
11c2				jr nz, .lowalloz 
11c2			 
11c2				push hl 
11c2				push de 
11c2					ld hl, display_fb0 
11c2					ld (display_fb_active), hl 
11c2				call clear_display 
11c2				ld a, 0 
11c2				ld de, .malloczero 
11c2				call str_at_display 
11c2				call update_display 
11c2				call delay1s 
11c2				call delay1s 
11c2				call bp_on 
11c2			;	ld a, 0 
11c2			;	ld (os_view_disable), a 
11c2			 
11c2				pop de 
11c2				pop hl 
11c2			 
11c2				 
11c2			 
11c2				CALLMONITOR 
11c2			.lowalloz: 
11c2			 
11c2			 
11c2				pop af 
11c2				pop de 
11c2				pop hl 
11c2			ret 
11c2			 
11c2			malloc_guard_entry: 
11c2				push hl 
11c2				push de 
11c2				push af 
11c2			 
11c2			 	or a      ;clear carry flag 
11c2				push hl 
11c2				ld de, 255 
11c2				sbc hl, de 
11c2				jr c, .lowalloc 
11c2			 
11c2				push de 
11c2					ld hl, display_fb0 
11c2					ld (display_fb_active), hl 
11c2				call clear_display 
11c2				ld a, 0 
11c2				ld de, .mallocsize 
11c2				call str_at_display 
11c2				call update_display 
11c2				call delay1s 
11c2				call delay1s 
11c2			;	ld a, 0 
11c2			;	ld (os_view_disable), a 
11c2				call bp_on 
11c2			 
11c2				pop de 
11c2				pop hl 
11c2			 
11c2				 
11c2			 
11c2				CALLMONITOR 
11c2				jr .lowdone 
11c2			.lowalloc: 
11c2			 
11c2			 
11c2				pop hl 
11c2			.lowdone:	pop af 
11c2				pop de 
11c2				pop hl 
11c2			ret 
11c2			 
11c2			malloc_guard_exit: 
11c2				push hl 
11c2				push de 
11c2				push af 
11c2			 
11c2			 	or a      ;clear carry flag 
11c2				push hl 
11c2				ld de, 255 
11c2				sbc hl, de 
11c2				jr c, .lowallocx 
11c2			 
11c2				push de 
11c2					ld hl, display_fb0 
11c2					ld (display_fb_active), hl 
11c2				call clear_display 
11c2				ld a, 0 
11c2				ld de, .mallocasize 
11c2				call str_at_display 
11c2				call update_display 
11c2				call delay1s 
11c2				call delay1s 
11c2			;	ld a, 0 
11c2			;	ld (os_view_disable), a 
11c2				call bp_on 
11c2				pop de 
11c2				pop hl 
11c2			 
11c2				CALLMONITOR 
