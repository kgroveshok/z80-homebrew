9c6c			; A better parser without using malloc and string copies all over the place.  
9c6c			; Exec in situ should be faster 
9c6c			 
9c6c			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
9c6c			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
9c6c			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
9c6c			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
9c6c			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
9c6c			WORD_SYS_END: equ 0   ; Opcode for all user words 
9c6c			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
9c6c			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
9c6c			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
9c6c			 
9c6c			; Core word preamble macro 
9c6c			 
9c6c			CWHEAD:   macro nxtword opcode lit len opflags 
9c6c				db WORD_SYS_CORE+opcode             
9c6c				; internal op code number 
9c6c				dw nxtword            
9c6c				; link to next dict word block 
9c6c				db len + 1 
9c6c				; literal length of dict word inc zero term 
9c6c				db lit,0              
9c6c				; literal dict word 
9c6c			        ; TODO db opflags        
9c6c				endm 
9c6c			 
