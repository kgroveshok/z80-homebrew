8f61 eb			      ex    DE, HL 
8f62			 
8f62 60			      ld    H, B                    ; Store new bigger size into freed block 
8f63 69			      ld    L, C 
8f64 23			      inc   HL 
8f65 23			      inc   HL 
8f66 73			      ld    (HL), E 
8f67 23			      inc   HL 
8f68 72			      ld    (HL), D 
