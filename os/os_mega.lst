0f96			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0f96			;;    subtract $30, if result > 9 then subtract $7 more 
0f96			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0f96			atohex: 
0f96 d6 30				SUB $30 
0f98 fe 0a				CP 10 
0f9a f8					RET M		; If result negative it was 0-9 so we're done 
0f9b d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0f9d c9					RET		 
