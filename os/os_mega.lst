0e55			 
0e55			;-----> Generate a random number 
0e55			; output a=answer 0<=a<=255 
0e55			; all registers are preserved except: af 
0e55			random: 
0e55 e5			        push    hl 
0e56 d5			        push    de 
0e57 2a d9 fa		        ld      hl,(randData) 
0e5a ed 5f		        ld      a,r 
0e5c 57			        ld      d,a 
0e5d 5e			        ld      e,(hl) 
0e5e 19			        add     hl,de 
0e5f 85			        add     a,l 
0e60 ac			        xor     h 
0e61 22 d9 fa		        ld      (randData),hl 
0e64 d1			        pop     de 
0e65 e1			        pop     hl 
0e66 c9			        ret 
0e67			 
0e67			 
0e67			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0e67			 
0e67			 
0e67			 
0e67			;------LFSR------ 
0e67			;James Montelongo 
0e67			;optimized by Spencer Putt 
0e67			;out: 
0e67			; a = 8 bit random number 
0e67			RandLFSR: 
0e67 21 df fa		        ld hl,LFSRSeed+4 
0e6a 5e			        ld e,(hl) 
0e6b 23			        inc hl 
0e6c 56			        ld d,(hl) 
0e6d 23			        inc hl 
0e6e 4e			        ld c,(hl) 
0e6f 23			        inc hl 
0e70 7e			        ld a,(hl) 
0e71 47			        ld b,a 
0e72 cb 13		        rl e  
0e74 cb 12			rl d 
0e76 cb 11		        rl c  
0e78 17				rla 
0e79 cb 13		        rl e  
0e7b cb 12			rl d 
0e7d cb 11		        rl c  
0e7f 17				rla 
0e80 cb 13		        rl e  
0e82 cb 12			rl d 
0e84 cb 11		        rl c  
0e86 17				rla 
0e87 67			        ld h,a 
0e88 cb 13		        rl e  
0e8a cb 12			rl d 
0e8c cb 11		        rl c  
0e8e 17				rla 
0e8f a8			        xor b 
0e90 cb 13		        rl e  
0e92 cb 12			rl d 
0e94 ac			        xor h 
0e95 a9			        xor c 
0e96 aa			        xor d 
0e97 21 e1 fa		        ld hl,LFSRSeed+6 
0e9a 11 e2 fa		        ld de,LFSRSeed+7 
0e9d 01 07 00		        ld bc,7 
0ea0 ed b8		        lddr 
0ea2 12			        ld (de),a 
0ea3 c9			        ret 
0ea4			 
0ea4			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0ea4			 
0ea4			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0ea4			 
0ea4			 
0ea4			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0ea4			 
0ea4			prng16: 
0ea4			;Inputs: 
0ea4			;   (seed1) contains a 16-bit seed value 
0ea4			;   (seed2) contains a NON-ZERO 16-bit seed value 
0ea4			;Outputs: 
0ea4			;   HL is the result 
0ea4			;   BC is the result of the LCG, so not that great of quality 
0ea4			;   DE is preserved 
0ea4			;Destroys: 
0ea4			;   AF 
0ea4			;cycle: 4,294,901,760 (almost 4.3 billion) 
0ea4			;160cc 
0ea4			;26 bytes 
0ea4 2a d3 fa		    ld hl,(seed1) 
0ea7 44			    ld b,h 
0ea8 4d			    ld c,l 
0ea9 29			    add hl,hl 
0eaa 29			    add hl,hl 
0eab 2c			    inc l 
0eac 09			    add hl,bc 
0ead 22 d3 fa		    ld (seed1),hl 
0eb0 2a d1 fa		    ld hl,(seed2) 
0eb3 29			    add hl,hl 
0eb4 9f			    sbc a,a 
0eb5 e6 2d		    and %00101101 
0eb7 ad			    xor l 
0eb8 6f			    ld l,a 
0eb9 22 d1 fa		    ld (seed2),hl 
0ebc 09			    add hl,bc 
0ebd c9			    ret 
0ebe			 
0ebe			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0ebe			 
0ebe			rand32: 
0ebe			;Inputs: 
0ebe			;   (seed1_0) holds the lower 16 bits of the first seed 
0ebe			;   (seed1_1) holds the upper 16 bits of the first seed 
0ebe			;   (seed2_0) holds the lower 16 bits of the second seed 
0ebe			;   (seed2_1) holds the upper 16 bits of the second seed 
0ebe			;   **NOTE: seed2 must be non-zero 
0ebe			;Outputs: 
0ebe			;   HL is the result 
0ebe			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0ebe			;Destroys: 
0ebe			;   AF 
0ebe			;Tested and passes all CAcert tests 
0ebe			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0ebe			;it has a period of 18,446,744,069,414,584,320 
0ebe			;roughly 18.4 quintillion. 
0ebe			;LFSR taps: 0,2,6,7  = 11000101 
0ebe			;291cc 
0ebe			;seed1_0=$+1 
0ebe			;    ld hl,12345 
0ebe			;seed1_1=$+1 
0ebe			;    ld de,6789 
0ebe			;    ld b,h 
0ebe			;    ld c,l 
0ebe			;    add hl,hl \ rl e \ rl d 
0ebe			;    add hl,hl \ rl e \ rl d 
0ebe			;    inc l 
0ebe			;    add hl,bc 
0ebe			;    ld (seed1_0),hl 
0ebe			;    ld hl,(seed1_1) 
0ebe			;    adc hl,de 
0ebe			;    ld (seed1_1),hl 
0ebe			;    ex de,hl 
0ebe			;seed2_0=$+1 
0ebe			;    ld hl,9876 
0ebe			;seed2_1=$+1 
0ebe			;    ld bc,54321 
0ebe			;    add hl,hl \ rl c \ rl b 
0ebe			;    ld (seed2_1),bc 
0ebe			;    sbc a,a 
0ebe			;    and %11000101 
0ebe			;    xor l 
0ebe			;    ld l,a 
0ebe			;    ld (seed2_0),hl 
0ebe			;    ex de,hl 
0ebe			;    add hl,bc 
0ebe			;    ret 
0ebe			; 
0ebe			 
0ebe			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0ebe			; 20 bytes, 86 cycles (excluding ret) 
0ebe			 
0ebe			; returns   hl = pseudorandom number 
0ebe			; corrupts   a 
0ebe			 
0ebe			; generates 16-bit pseudorandom numbers with a period of 65535 
0ebe			; using the xorshift method: 
0ebe			 
0ebe			; hl ^= hl << 7 
0ebe			; hl ^= hl >> 9 
0ebe			; hl ^= hl << 8 
0ebe			 
0ebe			; some alternative shift triplets which also perform well are: 
0ebe			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0ebe			 
0ebe			;  org 32768 
0ebe			 
0ebe			xrnd: 
0ebe 2a d7 fa		  ld hl,(xrandc)       ; seed must not be 0 
0ec1 3e 00		  ld a,0 
0ec3 bd			  cp l 
0ec4 20 02		  jr nz, .xrnd1 
0ec6 2e 01		  ld l, 1 
0ec8			.xrnd1: 
0ec8			 
0ec8 7c			  ld a,h 
0ec9 1f			  rra 
0eca 7d			  ld a,l 
0ecb 1f			  rra 
0ecc ac			  xor h 
0ecd 67			  ld h,a 
0ece 7d			  ld a,l 
0ecf 1f			  rra 
0ed0 7c			  ld a,h 
0ed1 1f			  rra 
0ed2 ad			  xor l 
0ed3 6f			  ld l,a 
0ed4 ac			  xor h 
0ed5 67			  ld h,a 
0ed6			 
0ed6 22 d7 fa		  ld (xrandc),hl 
0ed9			 
0ed9 c9			  ret 
