6b46			; Output text string to LCD  
6b46			;   On entry: DE = Pointer to null terminated text string  
6b46			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6b46 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6b47 b7			            OR   A              ;Null terminator?  
6b48 c8			            RET  Z              ;Yes, so finished  
6b49 cd d6 6a		            CALL fLCD_Data      ;Write character to display  
6b4c 13			            INC  DE             ;Point to next character  
6b4d 18 f7		            JR   fLCD_Str       ;Repeat  
6b4f c9					ret  
6b50			  
6b50			; Define custom character  
6b50			;   On entry: A = Character number (0 to 7)  
6b50			;             DE = Pointer to character bitmap data  
6b50			;   On exit:  A = Next character number  
6b50			;             DE = Next location following bitmap  
6b50			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6b50			; Character is   
6b50 c5			fLCD_Def:   PUSH BC  
6b51 f5			            PUSH AF  
6b52 07			            RLCA                ;Calculate location  
6b53 07			            RLCA                ;  for bitmap data  
6b54 07			            RLCA                ;  = 8 x CharacterNumber  
6b55 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6b57 cd 94 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6b5a 06 00		            LD   B, 0  
6b5c 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6b5d cd d6 6a		            CALL fLCD_Data      ;Write byte to display  
6b60 13			            INC  DE             ;Point to next byte  
6b61 04			            INC  B              ;Count bytes  
6b62 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6b64 28 f6		            JR   Z, Loop       ;No, so repeat  
6b66 f1			            POP  AF  
6b67 3c			            INC  A              ;Increment character number  
6b68 c1			            POP  BC  
6b69 c9			            RET  
