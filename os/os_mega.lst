61ae			; stack over and underflow checks 
61ae			 
61ae			; init the words to detect the under/overflow 
61ae			 
61ae			chk_stk_init: 
61ae				; a vague random number to check so we dont get any "lucky" hits 
61ae 3e 2d			ld a, 45 
61b0 6f				ld l, a 
61b1 00				nop 
61b2 3e 17			ld a, 23 
61b4 67				ld h, a 
61b5			 
61b5 22 cd f0			ld (chk_word), hl     ; the word we need to check against 
61b8			 
61b8			;	ld (chk_stund), hl	; stack points.... 
61b8 22 3b fe			ld (chk_stovr), hl 
61bb 22 1c f9			ld (chk_ret_und), hl 
61be 22 da f8			ld (chk_ret_ovr), hl 
61c1 22 58 f8			ld (chk_loop_ovr), hl 
61c4 22 56 f6			ld (chk_data_ovr), hl 
61c7 c9				ret 
61c8				 
61c8			check_stacks: 
61c8				; check all stack words 
61c8			 
61c8 e5				push hl 
61c9 d5				push de 
61ca			 
61ca			;	ld de,(chk_word) 
61ca			;	ld hl, (chk_stund)	; stack points.... 
61ca			;	if DEBUG_STK_FAULT 
61ca			;		DMARK "FAa" 
61ca			;		CALLMONITOR 
61ca			;	endif 
61ca			;	call cmp16 
61ca			;	jp z, .chk_faulta 
61ca			; 
61ca			;	ld de, sfaultsu 
61ca			;	jp .chk_fault 
61ca			 
61ca 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
61cd ed 5b cd f0		ld de,(chk_word) 
61d1				if DEBUG_STK_FAULT 
61d1					DMARK "FAb" 
61d1					CALLMONITOR 
61d1				endif 
61d1 cd 7a 0d			call cmp16 
61d4 28 06			jr z, .chk_fault1 
61d6 11 7b 62			ld de, sfaultso 
61d9 c3 2b 62			jp .chk_fault 
61dc			.chk_fault1:  
61dc 2a 1c f9			ld hl, (chk_ret_und) 
61df ed 5b cd f0		ld de,(chk_word) 
61e3				if DEBUG_STK_FAULT 
61e3					DMARK "FAU" 
61e3					CALLMONITOR 
61e3				endif 
61e3 cd 7a 0d			call cmp16 
61e6 ca ef 61			jp z, .chk_fault2 
61e9 11 8b 62			ld de, sfaultru 
61ec c3 2b 62			jp .chk_fault 
61ef			.chk_fault2:  
61ef 2a da f8			ld hl, (chk_ret_ovr) 
61f2 ed 5b cd f0		ld de,(chk_word) 
61f6				if DEBUG_STK_FAULT 
61f6					DMARK "FA1" 
61f6					CALLMONITOR 
61f6				endif 
61f6 cd 7a 0d			call cmp16 
61f9 ca 02 62			jp z, .chk_fault3 
61fc 11 99 62			ld de, sfaultro 
61ff c3 2b 62			jp .chk_fault 
6202			.chk_fault3:  
6202 2a 58 f8			ld hl, (chk_loop_ovr) 
6205 ed 5b cd f0		ld de,(chk_word) 
6209				if DEBUG_STK_FAULT 
6209					DMARK "FA2" 
6209					CALLMONITOR 
6209				endif 
6209 cd 7a 0d			call cmp16 
620c ca 15 62			jp z, .chk_fault4 
620f 11 b3 62			ld de, sfaultlo 
6212 c3 2b 62			jp .chk_fault 
6215			.chk_fault4:  
6215 2a 56 f6			ld hl, (chk_data_ovr) 
6218 ed 5b cd f0		ld de,(chk_word) 
621c				if DEBUG_STK_FAULT 
621c					DMARK "FA3" 
621c					CALLMONITOR 
621c				endif 
621c cd 7a 0d			call cmp16 
621f ca 28 62			jp z, .chk_fault5 
6222 11 cd 62			ld de, sfaultdo 
6225 c3 2b 62			jp .chk_fault 
6228			 
6228			 
6228			.chk_fault5:  
6228 d1				pop de 
6229 e1				pop hl 
622a			 
622a c9				ret 
622b			 
622b cd 2c 0b		.chk_fault: 	call clear_display 
622e 3e 28				ld a, display_row_2 
6230 cd 3e 0b				call str_at_display 
6233 11 5d 62				   ld de, .stackfault 
6236 3e 00				ld a, display_row_1 
6238 cd 3e 0b				call str_at_display 
623b			if DEMARK_VERSION = 1 
623b ed 5b 9b fd		ld de, (debug_mark) 
623f			endif 
623f			 
623f			if DEMARK_VERSION = 0 
623f				ld de, debug_mark 
623f			endif 
