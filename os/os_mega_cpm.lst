182c			; 
182c			; kernel to the forth OS 
182c			 
182c			DS_TYPE_STR: equ 1     ; string type 
182c			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
182c			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
182c			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
182c			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
182c			 
182c			FORTH_PARSEV1: equ 0 
182c			FORTH_PARSEV2: equ 0 
182c			FORTH_PARSEV3: equ 0 
182c			FORTH_PARSEV4: equ 0 
182c			FORTH_PARSEV5: equ 0 
182c			FORTH_PARSEV6: equ 1 
182c			 
182c			;if FORTH_PARSEV5 
182c			;	FORTH_END_BUFFER: equ 0 
182c			;else 
182c			FORTH_END_BUFFER: equ 127 
182c			;endif 
182c			 
182c			FORTH_TRUE: equ 1 
182c			FORTH_FALSE: equ 0 
182c			 
