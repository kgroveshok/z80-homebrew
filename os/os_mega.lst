12c4			 
12c4			 
12c4			; HL - Duration 
12c4			; B - Freq 
12c4			 
12c4			sound_buzzer:  
12c4 3e ff			ld a, BUZZ_PIN_MASK 
12c6			 
12c6 d3 00			out (DEVICE_BUZZ), a 
12c8			 
12c8 c5				push bc 
12c9 78				ld a, b 
12ca cd 53 0a			call aDelayInMS 
12cd c1				pop bc 
12ce			 
12ce 2b				dec hl 
12cf cd 88 0d			call ishlzero 
12d2 c8				ret z 
12d3 18 ef			jr sound_buzzer 
12d5				 
12d5			 
