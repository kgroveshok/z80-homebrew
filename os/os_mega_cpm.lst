5ac0			 
5ac0				call clear_display 
5ac0			 
5ac0				; set bank 
5ac0			 
5ac0					ld a, (store_page+STORE_0_BANKRUN) 
5ac0					ld (spi_device), a 
5ac0			 
5ac0				; get file id to load from and get the file name to display 
5ac0			 
5ac0					ld a, (store_page+STORE_0_FILERUN) 
5ac0			 
5ac0					ld l, 0 
5ac0					ld h, a 
5ac0					ld de, store_page 
5ac0			 
5ac0					if DEBUG_FORTH_WORDS 
5ac0						DMARK "ASp" 
5ac0						CALLMONITOR 
5ac0					endif 
5ac0					call storage_read 
5ac0			 
5ac0					if DEBUG_FORTH_WORDS 
5ac0						DMARK "ASr" 
5ac0						CALLMONITOR 
5ac0					endif 
5ac0			 
5ac0					call ishlzero 
5ac0					ret z             ; file not found 
5ac0			 
5ac0					ld a, display_row_2 + 10 
5ac0					ld de, store_page+3 
5ac0					call str_at_display 
5ac0				 
5ac0			; 
5ac0			 
5ac0				ld a, display_row_1+5 
