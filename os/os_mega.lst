25b8			; | NEW ( -- ) Clears all user words and stack | DONE 
25b8				 
25b8				if MALLOC_4 
25b8					call  heap_init 
25b8				endif 
25b8				; reset uword pointers 
25b8 21 00 80			ld hl, baseram 
