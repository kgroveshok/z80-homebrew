d48d			; Which startup method to use? 
d48d			; 
d48d			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
d48d			; followed by loading of a list of scripts in eeprom 
d48d			 
d48d			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
d48d			; from eeprom 
d48d			 
d48d			; Select with define in main stubs 
d48d			 
d48d			if STARTUP_V1 
d48d				include "forth_startupv1.asm" 
d48d			; Startup script loading version 1 
d48d			 
d48d			; If SE storage is available first stage is to use the selected file 
d48d			; then go through the eeprom list 
d48d			 
d48d .. 00		sprompt1: db "Startup load...",0 
d49d .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
