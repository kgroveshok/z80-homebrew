606a			; **********************************************************************  
606a			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
606a			; **********************************************************************  
606a			;  
606a			; **  Written as a Small Computer Monitor App  
606a			; **  www.scc.me.uk  
606a			;  
606a			; History  
606a			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
606a			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
606a			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
606a			;  
606a			; **********************************************************************  
606a			;  
606a			; This program is an example of one of the methods of interfacing an   
606a			; alphanumeric LCD module.   
606a			;  
606a			; In this example the display is connected to either a Z80 PIO or a   
606a			; simple 8-bit output port.   
606a			;  
606a			; This interfacing method uses 4-bit data mode and uses time delays  
606a			; rather than polling the display's ready status. As a result the   
606a			; interface only requires 6 simple output lines:  
606a			;   Output bit 0 = not used  
606a			;   Output bit 1 = not used  
606a			;   Output bit 2 = RS         High = data, Low = instruction  
606a			;   Output bit 3 = E          Active high  
606a			;   Output bit 4 = DB4  
606a			;   Output bit 5 = DB5  
606a			;   Output bit 6 = DB6  
606a			;   Output bit 7 = DB7  
606a			; Display's R/W is connected to 0v so it is always in write mode  
606a			;  
606a			; This set up should work with any system supporting the RC2014 bus  
606a			  
606a			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
606a			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
606a			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
606a			;  
606a			; **********************************************************************  
606a			  
606a			; Additonal for 4x40. E1 and E2 instead of just E   
606a			; TODO swipe vidout signal on port a to activate E2  
606a			  
606a			; **********************************************************************  
606a			; **  Constants  
606a			; **********************************************************************  
606a			; LCD constants required by LCD support module  
606a			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
606a			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
606a			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
606a			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
606a			; TODO Decide which E is being set  
606a			kLCDWidth:  EQU display_cols             ;Width in characters  
606a			  
606a			; **********************************************************************  
606a			; **  Code library usage  
606a			; **********************************************************************  
606a			  
606a			; send character to current cursor position  
606a			; wraps and/or scrolls screen automatically  
606a			  
606a			  
606a			  
