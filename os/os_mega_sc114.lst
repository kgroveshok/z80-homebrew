8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf			.mallocsize: db "Wants malloc >256",0 
8ddf			.mallocasize: db "MALLOC gives >256",0 
8ddf			.malloczero: db "MALLOC gives zero",0 
8ddf			 
8ddf			malloc_guard_zerolen: 
8ddf				push hl 
8ddf				push de 
8ddf				push af 
8ddf			 
8ddf				ld de, 0 
8ddf			        call cmp16 
8ddf				jr nz, .lowalloz 
8ddf			 
8ddf				push hl 
8ddf				push de 
8ddf					ld hl, display_fb0 
8ddf					ld (display_fb_active), hl 
8ddf				call clear_display 
8ddf				ld a, 0 
8ddf				ld de, .malloczero 
8ddf				call str_at_display 
8ddf				call update_display 
8ddf				call delay1s 
8ddf				call delay1s 
8ddf				call bp_on 
8ddf			;	ld a, 0 
8ddf			;	ld (os_view_disable), a 
8ddf			 
8ddf				pop de 
8ddf				pop hl 
8ddf			 
8ddf				 
8ddf			 
8ddf				CALLMONITOR 
8ddf			.lowalloz: 
8ddf			 
8ddf			 
8ddf				pop af 
8ddf				pop de 
8ddf				pop hl 
8ddf			ret 
8ddf			 
8ddf			malloc_guard_entry: 
8ddf				push hl 
8ddf				push de 
8ddf				push af 
8ddf			 
8ddf			 	or a      ;clear carry flag 
8ddf				push hl 
8ddf				ld de, 255 
8ddf				sbc hl, de 
8ddf				jr c, .lowalloc 
8ddf			 
8ddf				push de 
8ddf					ld hl, display_fb0 
8ddf					ld (display_fb_active), hl 
8ddf				call clear_display 
8ddf				ld a, 0 
8ddf				ld de, .mallocsize 
8ddf				call str_at_display 
8ddf				call update_display 
8ddf				call delay1s 
8ddf				call delay1s 
8ddf			;	ld a, 0 
8ddf			;	ld (os_view_disable), a 
8ddf				call bp_on 
8ddf			 
8ddf				pop de 
8ddf				pop hl 
8ddf			 
8ddf				 
8ddf			 
8ddf				CALLMONITOR 
8ddf				jr .lowdone 
8ddf			.lowalloc: 
8ddf			 
8ddf			 
8ddf				pop hl 
8ddf			.lowdone:	pop af 
8ddf				pop de 
8ddf				pop hl 
8ddf			ret 
8ddf			 
8ddf			malloc_guard_exit: 
8ddf				push hl 
8ddf				push de 
8ddf				push af 
8ddf			 
8ddf			 	or a      ;clear carry flag 
8ddf				push hl 
8ddf				ld de, 255 
8ddf				sbc hl, de 
8ddf				jr c, .lowallocx 
8ddf			 
8ddf				push de 
8ddf					ld hl, display_fb0 
8ddf					ld (display_fb_active), hl 
8ddf				call clear_display 
8ddf				ld a, 0 
8ddf				ld de, .mallocasize 
8ddf				call str_at_display 
8ddf				call update_display 
8ddf				call delay1s 
8ddf				call delay1s 
8ddf			;	ld a, 0 
8ddf			;	ld (os_view_disable), a 
8ddf				call bp_on 
8ddf				pop de 
8ddf				pop hl 
8ddf			 
8ddf				CALLMONITOR 
8ddf				jr .lowdonex 
8ddf			.lowallocx: 
8ddf			 
8ddf				pop hl 
8ddf			.lowdonex:	pop af 
8ddf				pop de 
8ddf				pop hl 
8ddf			ret 
8ddf			endif 
