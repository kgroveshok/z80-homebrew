91d8			;------------------------------------------------------------------------------ 
91d8			;     heap_init                                                               : 
91d8			;                                                                             : 
91d8			; Description                                                                 : 
91d8			;     Initialise the heap and make it ready for malloc and free operations.   : 
91d8			;                                                                             : 
91d8			;     The heap is maintained as a linked list, starting with an initial       : 
91d8			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
91d8			;     the first free block in the heap. Each block then points to the next    : 
91d8			;     free block within the heap, and the free list ends at the first block   : 
91d8			;     with a null pointer to the next free block.                             : 
91d8			;                                                                             : 
91d8			; Parameters                                                                  : 
91d8			;     Inputs are compile-time only. Two defines which specify the starting    : 
91d8			;     address of the heap and its size are required, along with a memory      : 
91d8			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
91d8			;     principally stores a pointer to the first free block in the heap.       : 
91d8			;                                                                             : 
91d8			; Returns                                                                     : 
91d8			;     Nothing                                                                 : 
91d8			;------------------------------------------------------------------------------ 
91d8			heap_init: 
91d8			      push  HL 
91d8			 
91d8			      ; Initialise free list struct 
91d8			      ld    HL, heap_start 
91d8			      ld    (free_list), HL 
91d8			      ld    HL, 0 
91d8			      ld    (free_list+2), HL 
91d8			 
91d8			      ; Insert first free block at bottom of heap, consumes entire heap 
91d8			      ld    HL, heap_start+heap_size-4 
91d8			      ld    (heap_start), HL        ; Next block (end of free list) 
91d8			      ld    HL, heap_size-4 
91d8			      ld    (heap_start+2), HL      ; Block size 
91d8			 
91d8			      ; Insert end of free list block at top of heap - two null words will 
91d8			      ; terminate the free list 
91d8			      ld    HL, 0 
91d8			      ld    (heap_start+heap_size-2), HL 
91d8			      ld    (heap_start+heap_size-4), HL 
91d8			 
91d8			      pop   HL 
91d8			 
91d8			      ret 
91d8			 
91d8			 
91d8			;------------------------------------------------------------------------------ 
91d8			;     malloc                                                                  : 
91d8			;                                                                             : 
91d8			; Description                                                                 : 
91d8			;     Allocates the wanted space from the heap and returns the address of the : 
91d8			;     first useable byte of the allocation.                                   : 
91d8			;                                                                             : 
91d8			;     Allocations can happen in one of two ways:                              : 
91d8			;                                                                             : 
91d8			;     1. A free block may be found which is the exact size wanted. In this    : 
91d8			;        case the block is removed from the free list and retuedn to the      : 
91d8			;        caller.                                                              : 
91d8			;     2. A free block may be found which is larger than the size wanted. In   : 
91d8			;        this case, the larger block is split into two. The first portion of  : 
91d8			;        this block will become the requested space by the malloc call and    : 
91d8			;        is returned to the caller. The second portion becomes a new free     : 
91d8			;        block, and the free list is adjusted to maintain continuity via this : 
91d8			;        newly created block.                                                 : 
91d8			;                                                                             : 
91d8			;     malloc does not set any initial value in the allocated space, the       : 
91d8			;     caller is required to do this as required.                              : 
91d8			;                                                                             : 
91d8			;     This implementation of malloc uses the stack exclusively, and is        : 
91d8			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
91d8			;     advisable to disable interrupts before calling malloc, and recommended  : 
91d8			;     to avoid the use of malloc inside ISRs in general.                      : 
91d8			;                                                                             : 
91d8			;     NOTE: heap_init must be called before malloc and free can be used.      : 
91d8			;                                                                             : 
91d8			; Parameters                                                                  : 
91d8			;     HL  Number of bytes wanted                                              : 
91d8			;                                                                             : 
91d8			; Returns                                                                     : 
91d8			;     HL  Address of the first useable byte of the allocation                 : 
91d8			;                                                                             : 
91d8			; Flags                                                                       : 
91d8			;     Z   Set if the allocation did not succeed, clear otherwise              : 
91d8			;                                                                             : 
91d8			; Stack frame                                                                 : 
91d8			;       |             |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |     BC      |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |     DE      |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |     IX      |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |  prev_free  |                                                       : 
91d8			;   +4  +-------------+                                                       : 
91d8			;       |  this_free  |                                                       : 
91d8			;   +2  +-------------+                                                       : 
91d8			;       |  next_free  |                                                       : 
91d8			;   +0  +-------------+                                                       : 
91d8			;       |             |                                                       : 
91d8			;                                                                             : 
91d8			;------------------------------------------------------------------------------ 
91d8			malloc: 
91d8			      push  BC 
91d8			      push  DE 
91d8			      push  IX 
91d8			 
91d8			      ld    A, H                    ; Exit if no space requested 
91d8			      or    L 
91d8			      jp    Z, malloc_early_exit 
91d8			 
91d8			      ; Set up stack frame 
91d8			      ex    DE, HL 
91d8			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
91d8			      add   HL, SP 
91d8			      ld    SP, HL 
91d8			      ld    IX, 0                   ; Use IX as a frame pointer 
91d8			      add   IX, SP 
91d8			 
91d8			      ; Setup initial state 
91d8			      ld    HL, 4                   ; want must also include space used by block struct 
91d8			      add   HL, DE 
91d8			 
91d8			      ld    B, H                    ; Move want to BC 
91d8			      ld    C, L 
91d8			 
91d8			      ld    HL, free_list           ; Store prev_free ptr to stack 
91d8			      ld    (IX+4), L 
91d8			      ld    (IX+5), H 
91d8			 
91d8			      ld    E, (HL)                 ; Store this_free ptr to stack 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      ld    (IX+2), E 
91d8			      ld    (IX+3), D 
91d8			      ex    DE, HL                  ; this_free ptr into HL 
91d8			 
91d8			      ; Loop through free block list to find some space 
91d8			malloc_find_space: 
91d8			      ld    E, (HL)                 ; Load next_free ptr into DE 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			 
91d8			      ld    A, D                    ; Check for null next_free ptr - end of free list 
91d8			      or    E 
91d8			      jp    Z, malloc_no_space 
91d8			 
91d8			      ld    (IX+0), E               ; Store next_free ptr to stack 
91d8			      ld    (IX+1), D 
91d8			 
91d8			      ; Does this block have enough space to make the allocation? 
91d8			      inc   HL                      ; Load free block size into DE 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			 
91d8			      ex    DE, HL                  ; Check size of block against want 
91d8			      or    A                       ; Ensure carry flag clear 
91d8			      sbc   HL, BC 
91d8			      push  HL                      ; Store the result for later (new block size) 
91d8			 
91d8			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
91d8			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
91d8			 
91d8			      ; this_free block is not big enough, setup ptrs to test next free block 
91d8			      pop   HL                      ; Discard previous result 
91d8			 
91d8			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
91d8			      ld    H, (IX+3) 
91d8			      ld    (IX+4), L 
91d8			      ld    (IX+5), H 
91d8			 
91d8			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
91d8			      ld    H, (IX+1) 
91d8			      ld    (IX+2), L 
91d8			      ld    (IX+3), H 
91d8			 
91d8			      jr    malloc_find_space 
91d8			 
91d8			      ; split a bigger block into two - requested size and remaining size 
91d8			malloc_alloc_split: 
91d8			      ex    DE, HL                  ; Calculate address of new free block 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			      add   HL, BC 
91d8			 
91d8			      ; Create a new block and point it at next_free 
91d8			      ld    E, (IX+0)               ; Load next_free ptr into DE 
91d8			      ld    D, (IX+1) 
91d8			 
91d8			      ld    (HL), E                 ; Store next_free ptr into new block 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			      pop   DE                      ; Store size of new block into new block 
91d8			      inc   HL 
91d8			      ld    (HL), E 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			      ; Update this_free ptr to point to new block 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			 
91d8			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
91d8			      ld    D, (IX+3) 
91d8			 
91d8			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
91d8			      ld    (IX+3), H 
91d8			 
91d8			      ; Modify this_free block to be allocation 
91d8			      ex    DE, HL 
91d8			      xor   A                       ; Null the next block ptr of allocated block 
91d8			      ld    (HL), A 
91d8			      inc   HL 
91d8			      ld    (HL), A 
91d8			 
91d8			      inc   HL                      ; Store want size into allocated block 
91d8			      ld    (HL), C 
91d8			      inc   HL 
91d8			      ld    (HL), B 
91d8			      inc   HL 
91d8			      push  HL                      ; Address of allocation to return 
91d8			 
91d8			      jr    malloc_update_links 
91d8			 
91d8			malloc_alloc_fit: 
91d8			      pop   HL                      ; Dont need new block size, want is exact fit 
91d8			 
91d8			      ; Modify this_free block to be allocation 
91d8			      ex    DE, HL 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			 
91d8			      xor   A                       ; Null the next block ptr of allocated block 
91d8			      ld    (HL), A 
91d8			      inc   HL 
91d8			      ld    (HL), A 
91d8			 
91d8			      inc   HL                      ; Store address of allocation to return 
91d8			      inc   HL 
91d8			      inc   HL 
91d8			      push  HL 
91d8			 
91d8			      ; Copy next_free ptr to this_free, remove allocated block from free list 
91d8			      ld    L, (IX+0)               ; next_free to HL 
91d8			      ld    H, (IX+1) 
91d8			 
91d8			      ld    (IX+2), L               ; HL to this_free 
91d8			      ld    (IX+3), H 
91d8			 
91d8			 
91d8			malloc_update_links: 
91d8			      ; Update prev_free ptr to point to this_free 
91d8			      ld    L, (IX+4)               ; prev_free ptr to HL 
91d8			      ld    H, (IX+5) 
91d8			 
91d8			      ld    E, (IX+2)               ; this_free ptr to DE 
91d8			      ld    D, (IX+3) 
91d8			 
91d8			      ld    (HL), E                 ; this_free ptr into prev_free 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			      ; Clear the Z flag to indicate successful allocation 
91d8			      ld    A, D 
91d8			      or    E 
91d8			 
91d8			      pop   DE                      ; Address of allocation 
91d8			 
91d8			malloc_no_space: 
91d8			      ld    HL, 6                   ; Clean up stack frame 
91d8			      add   HL, SP 
91d8			      ld    SP, HL 
91d8			 
91d8			      ex    DE, HL                  ; Alloc addr into HL for return 
91d8			 
91d8			malloc_early_exit: 
91d8			      pop   IX 
91d8			      pop   DE 
91d8			      pop   BC 
91d8			 
91d8			      ret 
91d8			 
91d8			 
91d8			;------------------------------------------------------------------------------ 
91d8			;     free                                                                    : 
91d8			;                                                                             : 
91d8			; Description                                                                 : 
91d8			;     Return the space pointed to by HL to the heap. HL must be an address as : 
91d8			;     returned by malloc, otherwise the behaviour is undefined.               : 
91d8			;                                                                             : 
91d8			;     Where possible, directly adjacent free blocks will be merged together   : 
91d8			;     into larger blocks to help ensure that the heap does not become         : 
91d8			;     excessively fragmented.                                                 : 
91d8			;                                                                             : 
91d8			;     free does not clear or set any other value into the freed space, and    : 
91d8			;     therefore its contents may be visible through subsequent malloc's. The  : 
91d8			;     caller should clear the freed space as required.                        : 
91d8			;                                                                             : 
91d8			;     This implementation of free uses the stack exclusively, and is          : 
91d8			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
91d8			;     advisable to disable interrupts before calling free, and recommended    : 
91d8			;     to avoid the use of free inside ISRs in general.                        : 
91d8			;                                                                             : 
91d8			;     NOTE: heap_init must be called before malloc and free can be used.      : 
91d8			;                                                                             : 
91d8			; Parameters                                                                  : 
91d8			;     HL  Pointer to address of first byte of allocation to be freed          : 
91d8			;                                                                             : 
91d8			; Returns                                                                     : 
91d8			;     Nothing                                                                 : 
91d8			;                                                                             : 
91d8			; Stack frame                                                                 : 
91d8			;       |             |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |     BC      |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |     DE      |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |     IX      |                                                       : 
91d8			;       +-------------+                                                       : 
91d8			;       |  prev_free  |                                                       : 
91d8			;   +2  +-------------+                                                       : 
91d8			;       |  next_free  |                                                       : 
91d8			;   +0  +-------------+                                                       : 
91d8			;       |             |                                                       : 
91d8			;                                                                             : 
91d8			;------------------------------------------------------------------------------ 
91d8			free: 
91d8			      push  BC 
91d8			      push  DE 
91d8			      push  IX 
91d8			 
91d8			      ld    A, H                    ; Exit if ptr is null 
91d8			      or    L 
91d8			      jp    Z, free_early_exit 
91d8			 
91d8			      ; Set up stack frame 
91d8			      ex    DE, HL 
91d8			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
91d8			      add   HL, SP 
91d8			      ld    SP, HL 
91d8			      ld    IX, 0                   ; Use IX as a frame pointer 
91d8			      add   IX, SP 
91d8			 
91d8			      ; The address in HL points to the start of the useable allocated space, 
91d8			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
91d8			      ; address of the block itself. 
91d8			      ex    DE, HL 
91d8			      ld    DE, -4 
91d8			      add   HL, DE 
91d8			 
91d8			      ; An allocated block must have a null next block pointer in it 
91d8			      ld    A, (HL) 
91d8			      inc   HL 
91d8			      or    (HL) 
91d8			      jp    NZ, free_done 
91d8			 
91d8			      dec   HL 
91d8			 
91d8			      ld    B, H                    ; Copy HL to BC 
91d8			      ld    C, L 
91d8			 
91d8			      ; Loop through the free list to find the first block with an address 
91d8			      ; higher than the block being freed 
91d8			      ld    HL, free_list 
91d8			 
91d8			free_find_higher_block: 
91d8			      ld    E, (HL)                 ; Load next ptr from free block 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      dec   HL 
91d8			 
91d8			      ld    (IX+0), E               ; Save ptr to next free block 
91d8			      ld    (IX+1), D 
91d8			      ld    (IX+2), L               ; Save ptr to prev free block 
91d8			      ld    (IX+3), H 
91d8			 
91d8			      ld    A, B                    ; Check if DE is greater than BC 
91d8			      cp    D                       ; Compare MSB first 
91d8			      jr    Z, $+4                  ; MSB the same, compare LSB 
91d8			      jr    NC, free_find_higher_block_skip 
91d8			      ld    A, C 
91d8			      cp    E                       ; Then compare LSB 
91d8			      jr    C, free_found_higher_block 
91d8			 
91d8			free_find_higher_block_skip: 
91d8			      ld    A, D                    ; Reached the end of the free list? 
91d8			      or    E 
91d8			      jp    Z, free_done 
91d8			 
91d8			      ex    DE, HL 
91d8			 
91d8			      jr    free_find_higher_block 
91d8			 
91d8			free_found_higher_block: 
91d8			      ; Insert freed block between prev and next free blocks 
91d8			      ld    (HL), C                 ; Point prev free block to freed block 
91d8			      inc   HL 
91d8			      ld    (HL), B 
91d8			 
91d8			      ld    H, B                    ; Point freed block at next free block 
91d8			      ld    L, C 
91d8			      ld    (HL), E 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			      ; Check if the freed block is adjacent to the next free block 
91d8			      inc   HL                      ; Load size of freed block into HL 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      ex    DE, HL 
91d8			 
91d8			      add   HL, BC                  ; Add addr of freed block and its size 
91d8			 
91d8			      ld    E, (IX+0)               ; Load addr of next free block into DE 
91d8			      ld    D, (IX+1) 
91d8			 
91d8			      or    A                       ; Clear the carry flag 
91d8			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
91d8			      jr    NZ, free_check_adjacent_to_prev 
91d8			 
91d8			      ; Freed block is adjacent to next, merge into one bigger block 
91d8			      ex    DE, HL                  ; Load next ptr from next block into DE 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      push  HL                      ; Save ptr to next block for later 
91d8			 
91d8			      ld    H, B                    ; Store ptr from next block into freed block 
91d8			      ld    L, C 
91d8			      ld    (HL), E 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			      pop   HL                      ; Restore ptr to next block 
91d8			      inc   HL                      ; Load size of next block into DE 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      push  DE                      ; Save next block size for later 
91d8			 
91d8			      ld    H, B                    ; Load size of freed block into HL 
91d8			      ld    L, C 
91d8			      inc   HL 
91d8			      inc   HL 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      ex    DE, HL 
91d8			 
91d8			      pop   DE                      ; Restore size of next block 
91d8			      add   HL, DE                  ; Add sizes of both blocks 
91d8			      ex    DE, HL 
91d8			 
91d8			      ld    H, B                    ; Store new bigger size into freed block 
91d8			      ld    L, C 
91d8			      inc   HL 
91d8			      inc   HL 
91d8			      ld    (HL), E 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			free_check_adjacent_to_prev: 
91d8			      ; Check if the freed block is adjacent to the prev free block 
91d8			      ld    L, (IX+2)               ; Prev free block ptr into HL 
91d8			      ld    H, (IX+3) 
91d8			 
91d8			      inc   HL                      ; Size of prev free block into DE 
91d8			      inc   HL 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			      dec   HL 
91d8			 
91d8			      add   HL, DE                  ; Add prev block addr and size 
91d8			 
91d8			      or    A                       ; Clear the carry flag 
91d8			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
91d8			      jr    NZ, free_done 
91d8			 
91d8			      ; Freed block is adjacent to prev, merge into one bigger block 
91d8			      ld    H, B                    ; Load next ptr from freed block into DE 
91d8			      ld    L, C 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      push  HL                      ; Save freed block ptr for later 
91d8			 
91d8			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
91d8			      ld    H, (IX+3) 
91d8			      ld    (HL), E 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			      pop   HL                      ; Restore freed block ptr 
91d8			      inc   HL                      ; Load size of freed block into DE 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			      push  DE                      ; Save freed block size for later 
91d8			 
91d8			      ld    L, (IX+2)               ; Load size of prev block into DE 
91d8			      ld    H, (IX+3) 
91d8			      inc   HL 
91d8			      inc   HL 
91d8			      ld    E, (HL) 
91d8			      inc   HL 
91d8			      ld    D, (HL) 
91d8			 
91d8			      pop   HL                      ; Add sizes of both blocks 
91d8			      add   HL, DE 
91d8			      ex    DE, HL 
91d8			 
91d8			      ld    L, (IX+2)               ; Store new bigger size into prev block 
91d8			      ld    H, (IX+3) 
91d8			      inc   HL 
91d8			      inc   HL 
91d8			      ld    (HL), E 
91d8			      inc   HL 
91d8			      ld    (HL), D 
91d8			 
91d8			free_done: 
91d8			      ld    HL, 4                   ; Clean up stack frame 
91d8			      add   HL, SP 
91d8			      ld    SP, HL 
91d8			 
91d8			free_early_exit: 
91d8			      pop   IX 
91d8			      pop   DE 
91d8			      pop   BC 
91d8			 
91d8			      ret 
91d8			 
91d8			 
91d8			;      .org 0x8000 
91d8			; 
91d8			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
91d8			 ;                 .dw   0 
91d8			 
91d8			endif 
91d8			 
91d8			 
91d8			if MALLOC_4 
91d8			 
91d8			; My memory allocation code. Very very simple.... 
91d8			; allocate space under 250 chars 
91d8			 
91d8			heap_init: 
91d8				; init start of heap as zero 
91d8				;  
91d8			 
91d8				ld hl, heap_start 
91d8			;	ld a, 0 
91d8				ld (hl), 0      ; empty block 
91d8				inc hl 
91d8			;	ld a, 0 
91d8				ld (hl), 0      ; length of block 
91d8				; write end of list 
91d8				inc hl 
91d8				ld a,(hl) 
91d8				inc hl 
91d8				ld a,(hl) 
91d8				 
91d8			 
91d8				; init some malloc vars 
91d8			 
91d8				ld hl, 0 
91d8				ld (free_list), hl       ; store last malloc location 
91d8			 
91d8				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
91d8			;	ld a, 0 
91d8				ld (hl), 0 
91d8			 
91d8			 
91d8				ld hl, heap_start 
91d8				;  
91d8				  
91d8				ret 
91d8			 
91d8			 
91d8			;    free block marker 
91d8			;    requested size  
91d8			;    pointer to next block 
91d8			;    .... 
91d8			;    next block marker 
91d8			 
91d8			 
91d8			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
91d8			; 
91d8			 
91d8			 
91d8			malloc:  
91d8				push de 
91d8				push bc 
91d8				push af 
91d8			 
91d8				; hl space required 
91d8				 
91d8				ld c, l    ; hold space   (TODO only a max of 255) 
91d8			 
91d8			;	inc c     ; TODO BUG need to fix memory leak on push str 
91d8			;	inc c 
91d8			;	inc c 
91d8			;	inc c 
91d8			;	inc c 
91d8			;	inc c 
91d8			;	inc c 
91d8			 
91d8			 
91d8			 
91d8				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
91d8			 
91d8				ld a, (free_list+3) 
91d8			;	cp 0 
91d8				or a 
91d8				jr z, .contheap 
91d8			 
91d8				ld hl, (free_list)     ; get last alloc 
91d8					if DEBUG_FORTH_MALLOC_INT 
91d8						DMARK "mrs" 
