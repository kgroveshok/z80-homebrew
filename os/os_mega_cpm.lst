10c2 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
10c4 30 04		      jr    NC, free_find_higher_block_skip 
10c6 79			      ld    A, C 
10c7 bb			      cp    E                       ; Then compare LSB 
10c8 38 08		      jr    C, free_found_higher_block 
10ca			 
10ca			free_find_higher_block_skip: 
10ca 7a			      ld    A, D                    ; Reached the end of the free list? 
10cb b3			      or    E 
10cc ca 4f 11		      jp    Z, free_done 
