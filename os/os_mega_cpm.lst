0df0			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0df0			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
0df0			; pass hl for where to put the text 
0df0			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0df0 c5			hexout:	PUSH BC 
0df1 f5					PUSH AF 
0df2 47					LD B, A 
0df3					; Upper nybble 
0df3 cb 3f				SRL A 
0df5 cb 3f				SRL A 
0df7 cb 3f				SRL A 
0df9 cb 3f				SRL A 
0dfb cd 0b 0e				CALL tohex 
0dfe 77					ld (hl),a 
0dff 23					inc hl	 
0e00					 
0e00					; Lower nybble 
0e00 78					LD A, B 
0e01 e6 0f				AND 0FH 
0e03 cd 0b 0e				CALL tohex 
0e06 77					ld (hl),a 
0e07 23					inc hl	 
0e08					 
0e08 f1					POP AF 
0e09 c1					POP BC 
0e0a c9					RET 
0e0b					 
0e0b			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0e0b			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
0e0b			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0e0b			tohex: 
0e0b e5					PUSH HL 
0e0c d5					PUSH DE 
0e0d 16 00				LD D, 0 
0e0f 5f					LD E, A 
0e10 21 18 0e				LD HL, .DATA 
0e13 19					ADD HL, DE 
0e14 7e					LD A, (HL) 
0e15 d1					POP DE 
0e16 e1					POP HL 
0e17 c9					RET 
0e18			 
0e18			.DATA: 
0e18 30					DEFB	30h	; 0 
0e19 31					DEFB	31h	; 1 
0e1a 32					DEFB	32h	; 2 
0e1b 33					DEFB	33h	; 3 
0e1c 34					DEFB	34h	; 4 
0e1d 35					DEFB	35h	; 5 
0e1e 36					DEFB	36h	; 6 
0e1f 37					DEFB	37h	; 7 
0e20 38					DEFB	38h	; 8 
0e21 39					DEFB	39h	; 9 
0e22 41					DEFB	41h	; A 
0e23 42					DEFB	42h	; B 
0e24 43					DEFB	43h	; C 
0e25 44					DEFB	44h	; D 
0e26 45					DEFB	45h	; E 
0e27 46					DEFB	46h	; F 
0e28			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0e28			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0e28			;;    subtract $30, if result > 9 then subtract $7 more 
0e28			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0e28			atohex: 
0e28 d6 30				SUB $30 
0e2a fe 0a				CP 10 
0e2c f8					RET M		; If result negative it was 0-9 so we're done 
0e2d d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0e2f c9					RET		 
