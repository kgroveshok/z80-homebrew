0baa			;;http://z80-heaven.wikidot.com/math 
0baa			;;This divides DE by BC, storing the result in DE, remainder in HL 
0baa			; 
0baa			;DE_Div_BC:          ;1281-2x, x is at most 16 
0baa			;     ld a,16        ;7 
0baa			;     ld hl,0        ;10 
0baa			;     jp $+5         ;10 
0baa			;.DivLoop: 
0baa			;       add hl,bc    ;-- 
0baa			;       dec a        ;64 
0baa			;       jr z,.DivLoopEnd        ;86 
0baa			; 
0baa			;       sla e        ;128 
0baa			;       rl d         ;128 
0baa			;       adc hl,hl    ;240 
0baa			;       sbc hl,bc    ;240 
0baa			;       jr nc,.DivLoop ;23|21 
0baa			;       inc e        ;-- 
0baa			;       jp .DivLoop+1 
0baa			; 
0baa			;.DivLoopEnd: 
0baa			 
0baa			;HL_Div_C: 
0baa			;Inputs: 
0baa			;     HL is the numerator 
0baa			;     C is the denominator 
0baa			;Outputs: 
0baa			;     A is the remainder 
0baa			;     B is 0 
0baa			;     C is not changed 
0baa			;     DE is not changed 
0baa			;     HL is the quotient 
0baa			; 
0baa			;       ld b,16 
0baa			;       xor a 
0baa			;         add hl,hl 
0baa			;         rla 
0baa			;         cp c 
0baa			;         jr c,$+4 
0baa			;           inc l 
0baa			;           sub c 
0baa			;         djnz $-7 
0baa			 
0baa			; https://plutiedev.com/z80-add-8bit-to-16bit 
0baa			 
0baa			addatohl: 
0baa 85			    add   a, l    ; A = A+L 
0bab 6f			    ld    l, a    ; L = A+L 
0bac 8c			    adc   a, h    ; A = A+L+H+carry 
0bad 95			    sub   l       ; A = H+carry 
0bae 67			    ld    h, a    ; H = H+carry 
0baf c9			ret 
0bb0			 
0bb0			addatode: 
0bb0 83			    add   a, e    ; A = A+L 
0bb1 5f			    ld    e, a    ; L = A+L 
0bb2 8a			    adc   a, d    ; A = A+L+H+carry 
0bb3 93			    sub   e       ; A = H+carry 
0bb4 57			    ld    d, a    ; H = H+carry 
0bb5 c9			ret 
0bb6			 
0bb6			 
0bb6			addatobc: 
0bb6 81			    add   a, c    ; A = A+L 
0bb7 4f			    ld    c, a    ; L = A+L 
0bb8 88			    adc   a, b    ; A = A+L+H+carry 
0bb9 91			    sub   c       ; A = H+carry 
0bba 47			    ld    b, a    ; H = H+carry 
0bbb c9			ret 
0bbc			 
0bbc			subafromhl: 
0bbc			   ; If A=0 do nothing 
0bbc			    ; Otherwise flip A's sign. Since 
0bbc			    ; the upper byte becomes -1, also 
0bbc			    ; substract 1 from H. 
0bbc ed 44		    neg 
0bbe ca c7 0b		    jp    z, Skip 
0bc1 25			    dec   h 
0bc2			     
0bc2			    ; Now add the low byte as usual 
0bc2			    ; Two's complement takes care of 
0bc2			    ; ensuring the result is correct 
0bc2 85			    add   a, l 
0bc3 6f			    ld    l, a 
0bc4 8c			    adc   a, h 
0bc5 95			    sub   l 
0bc6 67			    ld    h, a 
0bc7			Skip: 
0bc7 c9				ret 
0bc8			 
0bc8			 
0bc8			; compare hl and de 
0bc8			; returns:  
0bc8			; if hl = de, z=1, s=0, c0=0 
0bc8			; if hl > de, z=0, s=0, c=0 
0bc8			; if hl < de, z=0, s=1, c=1 
0bc8			cmp16:	 
0bc8 b7				or a 
0bc9 ed 52			sbc hl,de 
0bcb e0				ret po 
0bcc 7c				ld a,h 
0bcd 1f				rra 
0bce ee 40			xor 01000000B 
0bd0 37				scf 
0bd1 8f				adc a,a 
0bd2 c9				ret 
