91b6				ld hl, scratch 
91b6			.cfdir:	ld e,(hl) 
91b6				inc hl 
91b6				ld d,(hl) 
91b6				inc hl 
91b6			 
91b6				ex de, hl 
91b6				call ishlzero 
91b6				ret z     ; return on null pointer 
91b6				call free 
