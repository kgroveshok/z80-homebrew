a40d			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a40d			; | | At start the current various registers will be displayed with contents. 
a40d			; | | Top right corner will show the most recent debug marker seen. 
a40d			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a40d			; | | and the return stack pointer (RSP). 
a40d			; | | Pressing: 
a40d			; | |  
a40d			; | |    1 - Initial screen 
a40d			; | |  
a40d			; | |    2 - Display a data dump of HL 
a40d			; | |  
a40d			; | |    3 - Display a data dump of DE 
a40d			; | |  
a40d			; | |    4 - Display a data dump of BC 
a40d			; | |  
a40d			; | |    5 - Display a data dump of HL 
a40d			; | |  
a40d			; | |    6 - Display a data dump of DSP 
a40d			; | |  
a40d			; | |    7 - Display a data dump of RSP 
a40d			; | |  
a40d			; | |    8 - Display a data dump of what is at DSP 
a40d			; | |  
a40d			; | |    9 - Display a data dump of what is at RSP 
a40d			; | |  
a40d			; | |    0 - Exit monitor and continue running. This will also enable break points 
a40d			; | |  
a40d			; | |    * - Disable break points 
a40d			; | |  
a40d			; | |    # - Enter traditional monitor mode 
a40d			; | |  
a40d			; | | 
a40d			; | | Monitor Mode 
a40d			; | | ------------ 
a40d			; | | A prompt of '>' will be shown for various commands: 
a40d			; | |  
a40d			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a40d			; | |  
a40d			; | |    C - Continue display a data dump from the last set address 
a40d			; | |  
a40d			; | |    M xxxx - Set start of memory edit at address xx 
a40d			; | |  
a40d			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a40d			; | |  
a40d			; | |    G xxxx - Exec code at specific address 
a40d			; | |  
a40d			; | |    Q - Return to previous 
a40d				if DEBUG_FORTH_WORDS_KEY 
a40d					DMARK "MON" 
a40d				if DEMARK_VERSION = 1  
a40d e5					push hl  
a40e 21 16 a4				ld hl, .dmark  
a411 22 60 ee				ld (debug_mark), hl  
a414				endif  
a414				if DEMARK_VERSION = 0  
a414					push af  
