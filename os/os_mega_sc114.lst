80e2			; Filesystem layout (Logical layout) 
80e2			; 
80e2			; Block 0 - Bank config  
80e2			; 
80e2			;      Byte - 0 file id counter 
80e2			;      Byte - 1-2 formated: Byte pattern: 0x80 x27 
80e2			;      Byte - 3-20 zero terminated bank label 
80e2			; 
80e2			; Block 1 > File storage 
80e2			; 
80e2			;      Byte 0 file id    - block 0 file details 
80e2			;      Byte 1 block id - block 0 is file  
80e2			;            Byte 2-15 - File name 
80e2			; 
80e2			;       - to end of block data 
80e2			; 
80e2			 
80e2			; Get ID for the file named in pointer held HL 
