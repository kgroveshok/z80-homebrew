# End of macro CWHEAD
52a7			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
52a7			; | 
52a7			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
52a7			; | |  
52a7			; | | e.g. 
52a7			; | |         #30 a var ! 
52a7			; | |         a var @ . 
52a7			; | |   
52a7			; | |     Displays the number 30 
52a7			; | | 
52a7			; | | Each variable pointer is a word so can use for any words that use that:  
52a7			; | |  
52a7			; | | e.g. 
52a7			; | |  
52a7			; | |         #30 a var 2! 
52a7			; | |         a var 2@ . 
52a7			; | |   
52a7			; | |     Displays the number 30 
52a7			; | |  
52a7			; | | > [!NOTE]  
52a7			; ! | > If a full string is passed then only the first char is looked at 
52a7			; | | > Any other char could exceed bounds checks!  
52a7			; | | > 
52a7			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
52a7			 
52a7					if DEBUG_FORTH_WORDS_KEY 
52a7						DMARK "VAR" 
52a7				if DEMARK_VERSION = 1  
52a7 e5					push hl  
52a8 21 b0 52				ld hl, .dmark  
52ab 22 9b fd				ld (debug_mark), hl  
52ae				endif  
52ae				if DEMARK_VERSION = 0  
52ae					push af  
52ae					ld a, (.dmark)  
52ae					ld (debug_mark),a  
52ae					ld a, (.dmark+1)  
52ae					ld (debug_mark+1),a  
52ae					ld a, (.dmark+2)  
52ae					ld (debug_mark+2),a  
52ae				endif  
52ae 18 04			jr .pastdmark  
52b0 ..			.dmark: db "VAR"  
52b3				if DEMARK_VERSION = 1  
52b3 00					db 0  
52b4				endif  
52b4				if DEMARK_VERSION = 1  
52b4 e1			.pastdmark: pop hl  
52b5				endif  
52b5				if DEMARK_VERSION = 0  
52b5			.pastdmark: pop af  
52b5				endif  
