4495			.VARS: 
4495				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
4495 77				db WORD_SYS_CORE+99             
4496 12 45			dw .V0            
4498 04				db 3 + 1 
4499 .. 00			db "VAR",0              
449d				endm 
# End of macro CWHEAD
449d			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
449d			; | 
449d			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
449d			; | |  
449d			; | | e.g. 
449d			; | |         #30 a var ! 
449d			; | |         a var @ . 
449d			; | |   
449d			; | |     Displays the number 30 
449d			; | | 
449d			; | | Each variable pointer is a word so can use for any words that use that:  
449d			; | |  
449d			; | | e.g. 
449d			; | |  
449d			; | |         #30 a var 2! 
449d			; | |         a var 2@ . 
449d			; | |   
449d			; | |     Displays the number 30 
449d			; | |  
449d			; | | > [!NOTE]  
449d			; ! | > If a full string is passed then only the first char is looked at 
449d			; | | > Any other char could exceed bounds checks!  
449d			; | | > 
449d			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
449d			 
449d					if DEBUG_FORTH_WORDS_KEY 
449d						DMARK "VAR" 
449d				if DEMARK_VERSION = 1  
449d e5					push hl  
449e 21 a6 44				ld hl, .dmark  
44a1 22 60 ee				ld (debug_mark), hl  
44a4				endif  
44a4				if DEMARK_VERSION = 0  
44a4					push af  
44a4					ld a, (.dmark)  
44a4					ld (debug_mark),a  
44a4					ld a, (.dmark+1)  
44a4					ld (debug_mark+1),a  
44a4					ld a, (.dmark+2)  
44a4					ld (debug_mark+2),a  
44a4				endif  
44a4 18 04			jr .pastdmark  
44a6 ..			.dmark: db "VAR"  
44a9				if DEMARK_VERSION = 1  
44a9 00					db 0  
44aa				endif  
44aa				if DEMARK_VERSION = 1  
44aa e1			.pastdmark: pop hl  
44ab				endif  
44ab				if DEMARK_VERSION = 0  
44ab			.pastdmark: pop af  
44ab				endif  
44ab			endm  
# End of macro DMARK
44ab						CALLMONITOR 
44ab				if BASE_CPM=1  
44ab cd 6b ee				call debug_vector  
44ae				endif  
