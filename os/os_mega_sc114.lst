8f92			 
8f92 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
8f95 dd 66 03		      ld    H, (IX+3) 
8f98 23			      inc   HL 
8f99 23			      inc   HL 
8f9a 5e			      ld    E, (HL) 
8f9b 23			      inc   HL 
8f9c 56			      ld    D, (HL) 
8f9d			 
8f9d e1			      pop   HL                      ; Add sizes of both blocks 
8f9e 19			      add   HL, DE 
8f9f eb			      ex    DE, HL 
8fa0			 
8fa0 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
8fa3 dd 66 03		      ld    H, (IX+3) 
8fa6 23			      inc   HL 
8fa7 23			      inc   HL 
8fa8 73			      ld    (HL), E 
8fa9 23			      inc   HL 
8faa 72			      ld    (HL), D 
8fab			 
8fab			free_done: 
8fab 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
8fae 39			      add   HL, SP 
8faf f9			      ld    SP, HL 
8fb0			 
8fb0			free_early_exit: 
8fb0 dd e1		      pop   IX 
8fb2 d1			      pop   DE 
8fb3 c1			      pop   BC 
8fb4			 
8fb4 c9			      ret 
8fb5			 
8fb5			; moved to firmware.asm 
8fb5			; 
8fb5			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8fb5			;                  .dw   0 
8fb5			 
8fb5			 
8fb5			endif 
8fb5			 
8fb5			 
8fb5			if MALLOC_3 
8fb5			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
8fb5			;heap_start        .equ  0x9000      ; Starting address of heap 
8fb5			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8fb5			; 
8fb5			 ;     .org 0 
8fb5			  ;    jp    main 
8fb5			; 
8fb5			; 
8fb5			 ;     .org  0x100 
8fb5			;main: 
8fb5			 ;     ld    HL, 0x8100 
8fb5			  ;    ld    SP, HL 
8fb5			; 
8fb5			;      call  heap_init 
8fb5			 
8fb5			      ; Make some allocations 
8fb5			;      ld    HL, 12 
8fb5			;      call  malloc            ; Allocates 0x9004 
8fb5			; 
8fb5			 ;     ld    HL, 12 
8fb5			;      call  malloc            ; Allocates 0x9014 
8fb5			 
8fb5			;      ld    HL, 12 
8fb5			;      call  malloc            ; Allocates 0x9024 
8fb5			 
8fb5			      ; Free some allocations 
8fb5			;      ld    HL, 0x9014 
8fb5			;      call  free 
8fb5			 
8fb5			;      ld    HL, 0x9004 
8fb5			;      call  free 
8fb5			; 
8fb5			;      ld    HL, 0x9024 
8fb5			;      call  free 
8fb5			 
8fb5			 
8fb5			 ;     halt 
8fb5			 
8fb5			 
8fb5			;------------------------------------------------------------------------------ 
8fb5			;     heap_init                                                               : 
8fb5			;                                                                             : 
8fb5			; Description                                                                 : 
8fb5			;     Initialise the heap and make it ready for malloc and free operations.   : 
8fb5			;                                                                             : 
8fb5			;     The heap is maintained as a linked list, starting with an initial       : 
8fb5			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8fb5			;     the first free block in the heap. Each block then points to the next    : 
8fb5			;     free block within the heap, and the free list ends at the first block   : 
8fb5			;     with a null pointer to the next free block.                             : 
8fb5			;                                                                             : 
8fb5			; Parameters                                                                  : 
8fb5			;     Inputs are compile-time only. Two defines which specify the starting    : 
8fb5			;     address of the heap and its size are required, along with a memory      : 
8fb5			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8fb5			;     principally stores a pointer to the first free block in the heap.       : 
8fb5			;                                                                             : 
8fb5			; Returns                                                                     : 
8fb5			;     Nothing                                                                 : 
8fb5			;------------------------------------------------------------------------------ 
8fb5			heap_init: 
8fb5			      push  HL 
8fb5			 
8fb5			      ; Initialise free list struct 
8fb5			      ld    HL, heap_start 
8fb5			      ld    (free_list), HL 
8fb5			      ld    HL, 0 
8fb5			      ld    (free_list+2), HL 
8fb5			 
8fb5			      ; Insert first free block at bottom of heap, consumes entire heap 
8fb5			      ld    HL, heap_start+heap_size-4 
8fb5			      ld    (heap_start), HL        ; Next block (end of free list) 
8fb5			      ld    HL, heap_size-4 
8fb5			      ld    (heap_start+2), HL      ; Block size 
8fb5			 
8fb5			      ; Insert end of free list block at top of heap - two null words will 
8fb5			      ; terminate the free list 
8fb5			      ld    HL, 0 
8fb5			      ld    (heap_start+heap_size-2), HL 
8fb5			      ld    (heap_start+heap_size-4), HL 
8fb5			 
8fb5			      pop   HL 
8fb5			 
8fb5			      ret 
8fb5			 
8fb5			 
8fb5			;------------------------------------------------------------------------------ 
8fb5			;     malloc                                                                  : 
8fb5			;                                                                             : 
8fb5			; Description                                                                 : 
8fb5			;     Allocates the wanted space from the heap and returns the address of the : 
8fb5			;     first useable byte of the allocation.                                   : 
8fb5			;                                                                             : 
8fb5			;     Allocations can happen in one of two ways:                              : 
8fb5			;                                                                             : 
8fb5			;     1. A free block may be found which is the exact size wanted. In this    : 
8fb5			;        case the block is removed from the free list and retuedn to the      : 
8fb5			;        caller.                                                              : 
8fb5			;     2. A free block may be found which is larger than the size wanted. In   : 
8fb5			;        this case, the larger block is split into two. The first portion of  : 
8fb5			;        this block will become the requested space by the malloc call and    : 
8fb5			;        is returned to the caller. The second portion becomes a new free     : 
8fb5			;        block, and the free list is adjusted to maintain continuity via this : 
8fb5			;        newly created block.                                                 : 
8fb5			;                                                                             : 
8fb5			;     malloc does not set any initial value in the allocated space, the       : 
8fb5			;     caller is required to do this as required.                              : 
8fb5			;                                                                             : 
8fb5			;     This implementation of malloc uses the stack exclusively, and is        : 
8fb5			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8fb5			;     advisable to disable interrupts before calling malloc, and recommended  : 
8fb5			;     to avoid the use of malloc inside ISRs in general.                      : 
8fb5			;                                                                             : 
8fb5			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8fb5			;                                                                             : 
8fb5			; Parameters                                                                  : 
8fb5			;     HL  Number of bytes wanted                                              : 
8fb5			;                                                                             : 
8fb5			; Returns                                                                     : 
8fb5			;     HL  Address of the first useable byte of the allocation                 : 
8fb5			;                                                                             : 
8fb5			; Flags                                                                       : 
8fb5			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8fb5			;                                                                             : 
8fb5			; Stack frame                                                                 : 
8fb5			;       |             |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |     BC      |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |     DE      |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |     IX      |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |  prev_free  |                                                       : 
8fb5			;   +4  +-------------+                                                       : 
8fb5			;       |  this_free  |                                                       : 
8fb5			;   +2  +-------------+                                                       : 
8fb5			;       |  next_free  |                                                       : 
8fb5			;   +0  +-------------+                                                       : 
8fb5			;       |             |                                                       : 
8fb5			;                                                                             : 
8fb5			;------------------------------------------------------------------------------ 
8fb5			malloc: 
8fb5			      push  BC 
8fb5			      push  DE 
8fb5			      push  IX 
8fb5			 
8fb5			      ld    A, H                    ; Exit if no space requested 
8fb5			      or    L 
8fb5			      jp    Z, malloc_early_exit 
8fb5			 
8fb5			      ; Set up stack frame 
8fb5			      ex    DE, HL 
8fb5			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8fb5			      add   HL, SP 
8fb5			      ld    SP, HL 
8fb5			      ld    IX, 0                   ; Use IX as a frame pointer 
8fb5			      add   IX, SP 
8fb5			 
8fb5			      ; Setup initial state 
8fb5			      ld    HL, 4                   ; want must also include space used by block struct 
8fb5			      add   HL, DE 
8fb5			 
8fb5			      ld    B, H                    ; Move want to BC 
8fb5			      ld    C, L 
8fb5			 
8fb5			      ld    HL, free_list           ; Store prev_free ptr to stack 
8fb5			      ld    (IX+4), L 
8fb5			      ld    (IX+5), H 
8fb5			 
8fb5			      ld    E, (HL)                 ; Store this_free ptr to stack 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      ld    (IX+2), E 
8fb5			      ld    (IX+3), D 
8fb5			      ex    DE, HL                  ; this_free ptr into HL 
8fb5			 
8fb5			      ; Loop through free block list to find some space 
8fb5			malloc_find_space: 
8fb5			      ld    E, (HL)                 ; Load next_free ptr into DE 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			 
8fb5			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8fb5			      or    E 
8fb5			      jp    Z, malloc_no_space 
8fb5			 
8fb5			      ld    (IX+0), E               ; Store next_free ptr to stack 
8fb5			      ld    (IX+1), D 
8fb5			 
8fb5			      ; Does this block have enough space to make the allocation? 
8fb5			      inc   HL                      ; Load free block size into DE 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			 
8fb5			      ex    DE, HL                  ; Check size of block against want 
8fb5			      or    A                       ; Ensure carry flag clear 
8fb5			      sbc   HL, BC 
8fb5			      push  HL                      ; Store the result for later (new block size) 
8fb5			 
8fb5			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8fb5			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8fb5			 
8fb5			      ; this_free block is not big enough, setup ptrs to test next free block 
8fb5			      pop   HL                      ; Discard previous result 
8fb5			 
8fb5			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8fb5			      ld    H, (IX+3) 
8fb5			      ld    (IX+4), L 
8fb5			      ld    (IX+5), H 
8fb5			 
8fb5			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8fb5			      ld    H, (IX+1) 
8fb5			      ld    (IX+2), L 
8fb5			      ld    (IX+3), H 
8fb5			 
8fb5			      jr    malloc_find_space 
8fb5			 
8fb5			      ; split a bigger block into two - requested size and remaining size 
8fb5			malloc_alloc_split: 
8fb5			      ex    DE, HL                  ; Calculate address of new free block 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			      add   HL, BC 
8fb5			 
8fb5			      ; Create a new block and point it at next_free 
8fb5			      ld    E, (IX+0)               ; Load next_free ptr into DE 
8fb5			      ld    D, (IX+1) 
8fb5			 
8fb5			      ld    (HL), E                 ; Store next_free ptr into new block 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			      pop   DE                      ; Store size of new block into new block 
8fb5			      inc   HL 
8fb5			      ld    (HL), E 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			      ; Update this_free ptr to point to new block 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			 
8fb5			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8fb5			      ld    D, (IX+3) 
8fb5			 
8fb5			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8fb5			      ld    (IX+3), H 
8fb5			 
8fb5			      ; Modify this_free block to be allocation 
8fb5			      ex    DE, HL 
8fb5			      xor   A                       ; Null the next block ptr of allocated block 
8fb5			      ld    (HL), A 
8fb5			      inc   HL 
8fb5			      ld    (HL), A 
8fb5			 
8fb5			      inc   HL                      ; Store want size into allocated block 
8fb5			      ld    (HL), C 
8fb5			      inc   HL 
8fb5			      ld    (HL), B 
8fb5			      inc   HL 
8fb5			      push  HL                      ; Address of allocation to return 
8fb5			 
8fb5			      jr    malloc_update_links 
8fb5			 
8fb5			malloc_alloc_fit: 
8fb5			      pop   HL                      ; Dont need new block size, want is exact fit 
8fb5			 
8fb5			      ; Modify this_free block to be allocation 
8fb5			      ex    DE, HL 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			 
8fb5			      xor   A                       ; Null the next block ptr of allocated block 
8fb5			      ld    (HL), A 
8fb5			      inc   HL 
8fb5			      ld    (HL), A 
8fb5			 
8fb5			      inc   HL                      ; Store address of allocation to return 
8fb5			      inc   HL 
8fb5			      inc   HL 
8fb5			      push  HL 
8fb5			 
8fb5			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8fb5			      ld    L, (IX+0)               ; next_free to HL 
8fb5			      ld    H, (IX+1) 
8fb5			 
8fb5			      ld    (IX+2), L               ; HL to this_free 
8fb5			      ld    (IX+3), H 
8fb5			 
8fb5			 
8fb5			malloc_update_links: 
8fb5			      ; Update prev_free ptr to point to this_free 
8fb5			      ld    L, (IX+4)               ; prev_free ptr to HL 
8fb5			      ld    H, (IX+5) 
8fb5			 
8fb5			      ld    E, (IX+2)               ; this_free ptr to DE 
8fb5			      ld    D, (IX+3) 
8fb5			 
8fb5			      ld    (HL), E                 ; this_free ptr into prev_free 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			      ; Clear the Z flag to indicate successful allocation 
8fb5			      ld    A, D 
8fb5			      or    E 
8fb5			 
8fb5			      pop   DE                      ; Address of allocation 
8fb5			 
8fb5			malloc_no_space: 
8fb5			      ld    HL, 6                   ; Clean up stack frame 
8fb5			      add   HL, SP 
8fb5			      ld    SP, HL 
8fb5			 
8fb5			      ex    DE, HL                  ; Alloc addr into HL for return 
8fb5			 
8fb5			malloc_early_exit: 
8fb5			      pop   IX 
8fb5			      pop   DE 
8fb5			      pop   BC 
8fb5			 
8fb5			      ret 
8fb5			 
8fb5			 
8fb5			;------------------------------------------------------------------------------ 
8fb5			;     free                                                                    : 
8fb5			;                                                                             : 
8fb5			; Description                                                                 : 
8fb5			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8fb5			;     returned by malloc, otherwise the behaviour is undefined.               : 
8fb5			;                                                                             : 
8fb5			;     Where possible, directly adjacent free blocks will be merged together   : 
8fb5			;     into larger blocks to help ensure that the heap does not become         : 
8fb5			;     excessively fragmented.                                                 : 
8fb5			;                                                                             : 
8fb5			;     free does not clear or set any other value into the freed space, and    : 
8fb5			;     therefore its contents may be visible through subsequent malloc's. The  : 
8fb5			;     caller should clear the freed space as required.                        : 
8fb5			;                                                                             : 
8fb5			;     This implementation of free uses the stack exclusively, and is          : 
8fb5			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8fb5			;     advisable to disable interrupts before calling free, and recommended    : 
8fb5			;     to avoid the use of free inside ISRs in general.                        : 
8fb5			;                                                                             : 
8fb5			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8fb5			;                                                                             : 
8fb5			; Parameters                                                                  : 
8fb5			;     HL  Pointer to address of first byte of allocation to be freed          : 
8fb5			;                                                                             : 
8fb5			; Returns                                                                     : 
8fb5			;     Nothing                                                                 : 
8fb5			;                                                                             : 
8fb5			; Stack frame                                                                 : 
8fb5			;       |             |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |     BC      |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |     DE      |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |     IX      |                                                       : 
8fb5			;       +-------------+                                                       : 
8fb5			;       |  prev_free  |                                                       : 
8fb5			;   +2  +-------------+                                                       : 
8fb5			;       |  next_free  |                                                       : 
8fb5			;   +0  +-------------+                                                       : 
8fb5			;       |             |                                                       : 
8fb5			;                                                                             : 
8fb5			;------------------------------------------------------------------------------ 
8fb5			free: 
8fb5			      push  BC 
8fb5			      push  DE 
8fb5			      push  IX 
8fb5			 
8fb5			      ld    A, H                    ; Exit if ptr is null 
8fb5			      or    L 
8fb5			      jp    Z, free_early_exit 
8fb5			 
8fb5			      ; Set up stack frame 
8fb5			      ex    DE, HL 
8fb5			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8fb5			      add   HL, SP 
8fb5			      ld    SP, HL 
8fb5			      ld    IX, 0                   ; Use IX as a frame pointer 
8fb5			      add   IX, SP 
8fb5			 
8fb5			      ; The address in HL points to the start of the useable allocated space, 
8fb5			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8fb5			      ; address of the block itself. 
8fb5			      ex    DE, HL 
8fb5			      ld    DE, -4 
8fb5			      add   HL, DE 
8fb5			 
8fb5			      ; An allocated block must have a null next block pointer in it 
8fb5			      ld    A, (HL) 
8fb5			      inc   HL 
8fb5			      or    (HL) 
8fb5			      jp    NZ, free_done 
8fb5			 
8fb5			      dec   HL 
8fb5			 
8fb5			      ld    B, H                    ; Copy HL to BC 
8fb5			      ld    C, L 
8fb5			 
8fb5			      ; Loop through the free list to find the first block with an address 
8fb5			      ; higher than the block being freed 
8fb5			      ld    HL, free_list 
8fb5			 
8fb5			free_find_higher_block: 
8fb5			      ld    E, (HL)                 ; Load next ptr from free block 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      dec   HL 
8fb5			 
8fb5			      ld    (IX+0), E               ; Save ptr to next free block 
8fb5			      ld    (IX+1), D 
8fb5			      ld    (IX+2), L               ; Save ptr to prev free block 
8fb5			      ld    (IX+3), H 
8fb5			 
8fb5			      ld    A, B                    ; Check if DE is greater than BC 
8fb5			      cp    D                       ; Compare MSB first 
8fb5			      jr    Z, $+4                  ; MSB the same, compare LSB 
8fb5			      jr    NC, free_find_higher_block_skip 
8fb5			      ld    A, C 
8fb5			      cp    E                       ; Then compare LSB 
8fb5			      jr    C, free_found_higher_block 
8fb5			 
8fb5			free_find_higher_block_skip: 
8fb5			      ld    A, D                    ; Reached the end of the free list? 
8fb5			      or    E 
8fb5			      jp    Z, free_done 
8fb5			 
8fb5			      ex    DE, HL 
8fb5			 
8fb5			      jr    free_find_higher_block 
8fb5			 
8fb5			free_found_higher_block: 
8fb5			      ; Insert freed block between prev and next free blocks 
8fb5			      ld    (HL), C                 ; Point prev free block to freed block 
8fb5			      inc   HL 
8fb5			      ld    (HL), B 
8fb5			 
8fb5			      ld    H, B                    ; Point freed block at next free block 
8fb5			      ld    L, C 
8fb5			      ld    (HL), E 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			      ; Check if the freed block is adjacent to the next free block 
8fb5			      inc   HL                      ; Load size of freed block into HL 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      ex    DE, HL 
8fb5			 
8fb5			      add   HL, BC                  ; Add addr of freed block and its size 
8fb5			 
8fb5			      ld    E, (IX+0)               ; Load addr of next free block into DE 
8fb5			      ld    D, (IX+1) 
8fb5			 
8fb5			      or    A                       ; Clear the carry flag 
8fb5			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8fb5			      jr    NZ, free_check_adjacent_to_prev 
8fb5			 
8fb5			      ; Freed block is adjacent to next, merge into one bigger block 
8fb5			      ex    DE, HL                  ; Load next ptr from next block into DE 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      push  HL                      ; Save ptr to next block for later 
8fb5			 
8fb5			      ld    H, B                    ; Store ptr from next block into freed block 
8fb5			      ld    L, C 
8fb5			      ld    (HL), E 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			      pop   HL                      ; Restore ptr to next block 
8fb5			      inc   HL                      ; Load size of next block into DE 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      push  DE                      ; Save next block size for later 
8fb5			 
8fb5			      ld    H, B                    ; Load size of freed block into HL 
8fb5			      ld    L, C 
8fb5			      inc   HL 
8fb5			      inc   HL 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      ex    DE, HL 
8fb5			 
8fb5			      pop   DE                      ; Restore size of next block 
8fb5			      add   HL, DE                  ; Add sizes of both blocks 
8fb5			      ex    DE, HL 
8fb5			 
8fb5			      ld    H, B                    ; Store new bigger size into freed block 
8fb5			      ld    L, C 
8fb5			      inc   HL 
8fb5			      inc   HL 
8fb5			      ld    (HL), E 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			free_check_adjacent_to_prev: 
8fb5			      ; Check if the freed block is adjacent to the prev free block 
8fb5			      ld    L, (IX+2)               ; Prev free block ptr into HL 
8fb5			      ld    H, (IX+3) 
8fb5			 
8fb5			      inc   HL                      ; Size of prev free block into DE 
8fb5			      inc   HL 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			      dec   HL 
8fb5			 
8fb5			      add   HL, DE                  ; Add prev block addr and size 
8fb5			 
8fb5			      or    A                       ; Clear the carry flag 
8fb5			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8fb5			      jr    NZ, free_done 
8fb5			 
8fb5			      ; Freed block is adjacent to prev, merge into one bigger block 
8fb5			      ld    H, B                    ; Load next ptr from freed block into DE 
8fb5			      ld    L, C 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      push  HL                      ; Save freed block ptr for later 
8fb5			 
8fb5			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8fb5			      ld    H, (IX+3) 
8fb5			      ld    (HL), E 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			      pop   HL                      ; Restore freed block ptr 
8fb5			      inc   HL                      ; Load size of freed block into DE 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			      push  DE                      ; Save freed block size for later 
8fb5			 
8fb5			      ld    L, (IX+2)               ; Load size of prev block into DE 
8fb5			      ld    H, (IX+3) 
8fb5			      inc   HL 
8fb5			      inc   HL 
8fb5			      ld    E, (HL) 
8fb5			      inc   HL 
8fb5			      ld    D, (HL) 
8fb5			 
8fb5			      pop   HL                      ; Add sizes of both blocks 
8fb5			      add   HL, DE 
8fb5			      ex    DE, HL 
8fb5			 
8fb5			      ld    L, (IX+2)               ; Store new bigger size into prev block 
8fb5			      ld    H, (IX+3) 
8fb5			      inc   HL 
8fb5			      inc   HL 
8fb5			      ld    (HL), E 
8fb5			      inc   HL 
8fb5			      ld    (HL), D 
8fb5			 
8fb5			free_done: 
8fb5			      ld    HL, 4                   ; Clean up stack frame 
8fb5			      add   HL, SP 
8fb5			      ld    SP, HL 
8fb5			 
8fb5			free_early_exit: 
8fb5			      pop   IX 
8fb5			      pop   DE 
8fb5			      pop   BC 
8fb5			 
8fb5			      ret 
