67c5			; handle the auto run of code from files in storage 
67c5			 
67c5			 
67c5			include "forth_startup.asm" 
67c5			; Which startup method to use? 
67c5			; 
67c5			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
67c5			; followed by loading of a list of scripts in eeprom 
67c5			 
67c5			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
67c5			; from eeprom 
67c5			 
67c5			; Select with define in main stubs 
67c5			 
67c5			if STARTUP_V1 
67c5				include "forth_startupv1.asm" 
67c5			endif 
67c5			if STARTUP_V2 
67c5				include "forth_startupv2.asm" 
67c5			; Version 2 of the startup  
67c5			;  
67c5			; Auto load any files in bank 1 that start with a '*' 
67c5			; If no se storage then revert to using eprom 
67c5			 
67c5			 
67c5			if STORAGE_SE = 0 
67c5			 
67c5			sprompt1: db "Startup load...",0 
67c5			sprompt2: db "Run? 1=No *=End #=All",0 
67c5			 
67c5			 
67c5			 
67c5			 
67c5			forth_startup: 
67c5				ld hl, startcmds 
67c5				ld a, 0 
67c5				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
67c5			 
67c5			.start1:	push hl 
67c5				call clear_display 
67c5				ld de, sprompt1 
67c5			        ld a, display_row_1 
67c5				call str_at_display 
67c5				ld de, sprompt2 
67c5			        ld a, display_row_2 
67c5				call str_at_display 
67c5				pop hl 
67c5				push hl 
67c5				ld e,(hl) 
67c5				inc hl 
67c5				ld d,(hl) 
67c5			        ld a, display_row_3 
67c5				call str_at_display 
67c5				call update_display 
67c5			 
67c5			 
67c5				ld a, (os_last_cmd) 
67c5			;	cp 0 
67c5				or a 
67c5				jr z, .startprompt 
67c5				call delay250ms 
67c5				jr .startdo 
67c5				 
67c5				 
67c5			 
67c5			.startprompt: 
67c5			 
67c5				ld a,display_row_4 + display_cols - 1 
67c5			        ld de, endprg 
67c5				call str_at_display 
67c5				call update_display 
67c5				call delay1s 
67c5				call cin_wait 
67c5						 
67c5				cp '*' 
67c5				jr z, .startupend1 
67c5				cp '#' 
67c5				jr nz, .startno 
67c5				ld a, 1 
67c5				ld (os_last_cmd),a 
67c5				jr .startdo 
67c5			.startno:	cp '1' 
67c5				jr z,.startnxt  
67c5			 
67c5				; exec startup line 
67c5			.startdo:	 
67c5				pop hl 
67c5				push hl 
67c5				 
67c5				ld e,(hl) 
67c5				inc hl 
67c5				ld d,(hl) 
67c5				ex de,hl 
67c5			 
67c5				push hl 
67c5			 
67c5				ld a, 0 
67c5				;ld a, FORTH_END_BUFFER 
67c5				call strlent 
67c5				inc hl   ; include zero term to copy 
67c5				ld b,0 
67c5				ld c,l 
67c5				pop hl 
67c5				ld de, scratch 
67c5				ldir 
67c5			 
67c5			 
67c5				ld hl, scratch 
67c5				call forthparse 
67c5				call forthexec 
67c5				call forthexec_cleanup 
67c5			 
67c5				ld a, display_row_4 
67c5				ld de, endprog 
67c5			 
67c5				call update_display		 
67c5			 
67c5				ld a, (os_last_cmd) 
67c5			;	cp 0 
67c5				or a 
67c5				jr nz, .startnxt 
67c5				call next_page_prompt 
67c5			        call clear_display 
67c5				call update_display		 
67c5			 
67c5				; move onto next startup line? 
67c5			.startnxt: 
67c5			 
67c5				call delay250ms 
67c5				pop hl 
67c5			 
67c5				inc hl 
67c5				inc hl 
67c5			 
67c5				push hl 
67c5				ld e, (hl) 
67c5				inc hl 
67c5				ld d, (hl) 
67c5				pop hl 
67c5				; TODO replace 0 test 
67c5			 
67c5				ex de, hl 
67c5				call ishlzero 
67c5			;	ld a,e 
67c5			;	add d 
67c5			;	cp 0    ; any left to do? 
67c5				ex de, hl 
67c5				jp nz, .start1 
67c5				jr .startupend 
67c5			 
67c5			.startupend1: pop hl 
67c5			.startupend: 
67c5			 
67c5				call clear_display 
67c5				call update_display 
67c5				ret 
67c5			endif 
