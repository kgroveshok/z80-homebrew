d1eb			chk_stk_init: 
d1eb				; a vague random number to check so we dont get any "lucky" hits 
d1eb 3e 2d			ld a, 45 
d1ed 6f				ld l, a 
d1ee 00				nop 
d1ef 3e 17			ld a, 23 
d1f1 67				ld h, a 
d1f2			 
d1f2 22 81 e2			ld (chk_word), hl     ; the word we need to check against 
d1f5			 
d1f5			;	ld (chk_stund), hl	; stack points.... 
d1f5 22 00 ef			ld (chk_stovr), hl 
d1f8 22 d0 e9			ld (chk_ret_und), hl 
d1fb 22 8e e9			ld (chk_ret_ovr), hl 
d1fe 22 0c e9			ld (chk_loop_ovr), hl 
d201 22 0a e8			ld (chk_data_ovr), hl 
d204 c9				ret 
