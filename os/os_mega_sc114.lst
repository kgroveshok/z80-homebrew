8994			; https://map.grauw.nl/articles/mult_div_shifts.php 
8994			; Divide 16-bit values (with 16-bit result) 
8994			; In: Divide BC by divider DE 
8994			; Out: BC = result, HL = rest 
8994			; 
8994			Div16: 
8994 21 00 00		    ld hl,0 
8997 78			    ld a,b 
8998 06 08		    ld b,8 
899a			Div16_Loop1: 
899a 17			    rla 
899b ed 6a		    adc hl,hl 
899d ed 52		    sbc hl,de 
899f 30 01		    jr nc,Div16_NoAdd1 
89a1 19			    add hl,de 
89a2			Div16_NoAdd1: 
89a2 10 f6		    djnz Div16_Loop1 
89a4 17			    rla 
89a5 2f			    cpl 
89a6 47			    ld b,a 
89a7 79			    ld a,c 
89a8 48			    ld c,b 
89a9 06 08		    ld b,8 
89ab			Div16_Loop2: 
89ab 17			    rla 
89ac ed 6a		    adc hl,hl 
89ae ed 52		    sbc hl,de 
89b0 30 01		    jr nc,Div16_NoAdd2 
89b2 19			    add hl,de 
89b3			Div16_NoAdd2: 
89b3 10 f6		    djnz Div16_Loop2 
89b5 17			    rla 
89b6 2f			    cpl 
89b7 41			    ld b,c 
89b8 4f			    ld c,a 
89b9 c9			ret 
