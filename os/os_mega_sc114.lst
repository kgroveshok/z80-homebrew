db6d			; stack over and underflow checks 
db6d			 
db6d			; init the words to detect the under/overflow 
db6d			 
db6d			chk_stk_init: 
db6d				; a vague random number to check so we dont get any "lucky" hits 
db6d 3e 2d			ld a, 45 
db6f 6f				ld l, a 
db70 00				nop 
db71 3e 17			ld a, 23 
db73 67				ld h, a 
db74			 
db74 22 90 e2			ld (chk_word), hl     ; the word we need to check against 
db77			 
db77			;	ld (chk_stund), hl	; stack points.... 
db77 22 00 ef			ld (chk_stovr), hl 
db7a 22 df e9			ld (chk_ret_und), hl 
db7d 22 9d e9			ld (chk_ret_ovr), hl 
db80 22 1b e9			ld (chk_loop_ovr), hl 
db83 22 19 e8			ld (chk_data_ovr), hl 
db86 c9				ret 
db87				 
db87			check_stacks: 
db87				; check all stack words 
db87			 
db87 e5				push hl 
db88 d5				push de 
db89			 
db89			;	ld de,(chk_word) 
db89			;	ld hl, (chk_stund)	; stack points.... 
db89			;	if DEBUG_STK_FAULT 
db89			;		DMARK "FAa" 
db89			;		CALLMONITOR 
db89			;	endif 
db89			;	call cmp16 
db89			;	jp z, .chk_faulta 
db89			; 
db89			;	ld de, sfaultsu 
db89			;	jp .chk_fault 
db89			 
db89 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
db8c ed 5b 90 e2		ld de,(chk_word) 
db90				if DEBUG_STK_FAULT 
db90					DMARK "FAb" 
db90					CALLMONITOR 
db90				endif 
db90 cd 91 8c			call cmp16 
db93 28 06			jr z, .chk_fault1 
db95 11 39 dc			ld de, sfaultso 
db98 c3 ea db			jp .chk_fault 
db9b			.chk_fault1:  
db9b 2a df e9			ld hl, (chk_ret_und) 
db9e ed 5b 90 e2		ld de,(chk_word) 
dba2				if DEBUG_STK_FAULT 
dba2					DMARK "FAU" 
dba2					CALLMONITOR 
dba2				endif 
dba2 cd 91 8c			call cmp16 
dba5 ca ae db			jp z, .chk_fault2 
dba8 11 49 dc			ld de, sfaultru 
dbab c3 ea db			jp .chk_fault 
dbae			.chk_fault2:  
dbae 2a 9d e9			ld hl, (chk_ret_ovr) 
dbb1 ed 5b 90 e2		ld de,(chk_word) 
dbb5				if DEBUG_STK_FAULT 
dbb5					DMARK "FA1" 
dbb5					CALLMONITOR 
dbb5				endif 
dbb5 cd 91 8c			call cmp16 
dbb8 ca c1 db			jp z, .chk_fault3 
dbbb 11 57 dc			ld de, sfaultro 
dbbe c3 ea db			jp .chk_fault 
dbc1			.chk_fault3:  
dbc1 2a 1b e9			ld hl, (chk_loop_ovr) 
dbc4 ed 5b 90 e2		ld de,(chk_word) 
dbc8				if DEBUG_STK_FAULT 
dbc8					DMARK "FA2" 
dbc8					CALLMONITOR 
dbc8				endif 
dbc8 cd 91 8c			call cmp16 
dbcb ca d4 db			jp z, .chk_fault4 
dbce 11 71 dc			ld de, sfaultlo 
dbd1 c3 ea db			jp .chk_fault 
dbd4			.chk_fault4:  
dbd4 2a 19 e8			ld hl, (chk_data_ovr) 
dbd7 ed 5b 90 e2		ld de,(chk_word) 
dbdb				if DEBUG_STK_FAULT 
dbdb					DMARK "FA3" 
dbdb					CALLMONITOR 
dbdb				endif 
dbdb cd 91 8c			call cmp16 
dbde ca e7 db			jp z, .chk_fault5 
dbe1 11 8b dc			ld de, sfaultdo 
dbe4 c3 ea db			jp .chk_fault 
dbe7			 
dbe7			 
