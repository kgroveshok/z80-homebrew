10a9			StrictStrCmp: 
10a9				; Load next chars of each string 
10a9 1a				ld a, (de) 
10aa 47				ld b, a 
10ab 7e				ld a, (hl) 
10ac				; Compare 
10ac b8				cp b 
10ad				; Return non-zero if chars don't match 
10ad c0				ret nz 
10ae				; Check for end of both strings 
10ae fe 00			cp "\0" 
10b0				; Return if strings have ended 
10b0 c8				ret z 
10b1				; Otherwise, advance to next chars 
10b1 23				inc hl 
10b2 13				inc de 
10b3 18 f4			jr StrictStrCmp 
10b5			 
10b5			;end 
10b5			; eof 
