52cc			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
52cc			; | 
52cc			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
52cc			; | |  
52cc			; | | e.g. 
52cc			; | |         #30 a var ! 
52cc			; | |         a var @ . 
52cc			; | |   
52cc			; | |     Displays the number 30 
52cc			; | | 
52cc			; | | Each variable pointer is a word so can use for any words that use that:  
52cc			; | |  
52cc			; | | e.g. 
52cc			; | |  
52cc			; | |         #30 a var 2! 
52cc			; | |         a var 2@ . 
52cc			; | |   
52cc			; | |     Displays the number 30 
52cc			; | |  
52cc			; | | > [!NOTE]  
52cc			; ! | > If a full string is passed then only the first char is looked at 
52cc			; | | > Any other char could exceed bounds checks!  
52cc			; | | > 
52cc			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
52cc			 
52cc					if DEBUG_FORTH_WORDS_KEY 
