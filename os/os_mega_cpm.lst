4447			 
4447			.VARS: 
4447				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
4447 77				db WORD_SYS_CORE+99             
4448 c4 44			dw .V0            
444a 04				db 3 + 1 
444b .. 00			db "VAR",0              
444f				endm 
# End of macro CWHEAD
444f			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
444f			; | 
444f			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
444f			; | |  
444f			; | | e.g. 
444f			; | |         #30 a var ! 
444f			; | |         a var @ . 
444f			; | |   
444f			; | |     Displays the number 30 
444f			; | | 
444f			; | | Each variable pointer is a word so can use for any words that use that:  
444f			; | |  
444f			; | | e.g. 
444f			; | |  
444f			; | |         #30 a var 2! 
444f			; | |         a var 2@ . 
444f			; | |   
444f			; | |     Displays the number 30 
444f			; | |  
444f			; | | > [!NOTE]  
444f			; ! | > If a full string is passed then only the first char is looked at 
444f			; | | > Any other char could exceed bounds checks!  
444f			; | | > 
444f			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
444f			 
444f					if DEBUG_FORTH_WORDS_KEY 
444f						DMARK "VAR" 
444f				if DEMARK_VERSION = 1  
444f e5					push hl  
4450 21 58 44				ld hl, .dmark  
4453 22 60 ee				ld (debug_mark), hl  
4456				endif  
4456				if DEMARK_VERSION = 0  
4456					push af  
4456					ld a, (.dmark)  
4456					ld (debug_mark),a  
4456					ld a, (.dmark+1)  
4456					ld (debug_mark+1),a  
4456					ld a, (.dmark+2)  
4456					ld (debug_mark+2),a  
4456				endif  
4456 18 04			jr .pastdmark  
4458 ..			.dmark: db "VAR"  
445b				if DEMARK_VERSION = 1  
445b 00					db 0  
445c				endif  
445c				if DEMARK_VERSION = 1  
445c e1			.pastdmark: pop hl  
445d				endif  
445d				if DEMARK_VERSION = 0  
445d			.pastdmark: pop af  
445d				endif  
445d			endm  
# End of macro DMARK
445d						CALLMONITOR 
445d				if BASE_CPM=1  
445d cd 6b ee				call debug_vector  
4460				endif  
4460				if BASE_KEV=1  
4460					rst 8  
4460				endif  
4460				endm  
# End of macro CALLMONITOR
4460					endif 
4460			 
4460					FORTH_DSP_VALUEHL 
4460				if BASE_CPM=1 
4460 cd 5f 1a			call macro_dsp_valuehl 
4463				endif 
4463				if BASE_KEV=1 
4463					rst $18 
4463				endif 
4463				endm 
# End of macro FORTH_DSP_VALUEHL
