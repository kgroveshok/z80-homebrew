1325			 
1325			;------------------------------------------------------------------------------ 
1325			;     heap_init                                                               : 
1325			;                                                                             : 
1325			; Description                                                                 : 
1325			;     Initialise the heap and make it ready for malloc and free operations.   : 
1325			;                                                                             : 
1325			;     The heap is maintained as a linked list, starting with an initial       : 
1325			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1325			;     the first free block in the heap. Each block then points to the next    : 
1325			;     free block within the heap, and the free list ends at the first block   : 
1325			;     with a null pointer to the next free block.                             : 
1325			;                                                                             : 
1325			; Parameters                                                                  : 
1325			;     Inputs are compile-time only. Two defines which specify the starting    : 
1325			;     address of the heap and its size are required, along with a memory      : 
1325			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1325			;     principally stores a pointer to the first free block in the heap.       : 
1325			;                                                                             : 
1325			; Returns                                                                     : 
1325			;     Nothing                                                                 : 
1325			;------------------------------------------------------------------------------ 
1325			heap_init: 
1325 e5			      push  HL 
1326			 
1326			      ; Initialise free list struct 
1326 21 0e 80		      ld    HL, heap_start 
1329 22 0a 80		      ld    (free_list), HL 
132c 21 00 00		      ld    HL, 0 
132f 22 0c 80		      ld    (free_list+2), HL 
1332			 
1332			      ; Insert first free block at bottom of heap, consumes entire heap 
1332 21 c6 f0		      ld    HL, heap_start+heap_size-4 
1335 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
1338 21 b8 70		      ld    HL, heap_size-4 
133b 22 10 80		      ld    (heap_start+2), HL      ; Block size 
133e			 
133e			      ; Insert end of free list block at top of heap - two null words will 
133e			      ; terminate the free list 
133e 21 00 00		      ld    HL, 0 
1341 22 c8 f0		      ld    (heap_start+heap_size-2), HL 
1344 22 c6 f0		      ld    (heap_start+heap_size-4), HL 
1347			 
1347 e1			      pop   HL 
1348			 
1348 c9			      ret 
