0f4c			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
0f4c			 
0f4c			; String Length 
0f4c			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
0f4c			 
0f4c			; Get the length of the null-terminated string starting at $8000 hl 
0f4c			;    LD     HL, $8000 
0f4c			 
0f4c			strlenz: 
0f4c			 
0f4c af			    XOR    A               ; Zero is the value we are looking for. 
0f4d 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
0f4e 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
0f4f			                           ; 65, 536 bytes (the entire addressable memory space). 
0f4f ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f51			 
0f51			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f51 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
0f52 6f			    LD     L, A             ; number of bytes 
0f53 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f55 2b			    DEC    HL              ; Compensate for null. 
0f56 c9				ret 
0f57			 
0f57			; Get the length of the A terminated string starting at $8000 hl 
0f57			;    LD     HL, $8000 
0f57			 
0f57			strlent: 
0f57			 
0f57			                  ; A is the value we are looking for. 
0f57 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
0f59 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
0f5b			                           ; 65, 536 bytes (the entire addressable memory space). 
0f5b ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f5d			 
0f5d			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f5d 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
0f5f 2e 00		    LD     L, 0             ; number of bytes 
0f61 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f63 2b			    DEC    HL              ; Compensate for null. 
0f64 c9				ret 
0f65			 
0f65			 
0f65			;Comparing Strings 
0f65			 
0f65			;IN    HL     Address of string1. 
0f65			;      DE     Address of string2. 
0f65			 
0f65			; doc given but wrong??? 
0f65			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
0f65			;      carry  Set if string1 > string2, reset if string1 <= string2. 
0f65			; tested 
0f65			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
0f65			 
0f65			strcmp_old: 
0f65 e5			    PUSH   HL 
0f66 d5			    PUSH   DE 
0f67			 
0f67 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
0f68 be			    CP     (HL)            ; (want to minimize work). 
0f69 38 01		    JR     C, Str1IsBigger 
0f6b 7e			    LD     A, (HL) 
0f6c			 
0f6c			Str1IsBigger: 
0f6c 4f			    LD     C, A             ; Put length in BC 
0f6d 06 00		    LD     B, 0 
0f6f 13			    INC    DE              ; Increment pointers to meat of string. 
0f70 23			    INC    HL 
0f71			 
0f71			CmpLoop: 
0f71 1a			    LD     A, (DE)          ; Compare bytes. 
0f72 ed a1		    CPI 
0f74 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
0f76 13			    INC    DE              ; Update pointer. 
0f77 ea 71 0f		    JP     PE, CmpLoop 
0f7a			 
0f7a d1			    POP    DE 
0f7b e1			    POP    HL 
0f7c 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
0f7d be			    CP     (HL) 
0f7e c9			    RET 
0f7f			 
0f7f			NoMatch: 
0f7f 2b			    DEC    HL 
0f80 be			    CP     (HL)            ; Compare again to affect carry. 
0f81 d1			    POP    DE 
0f82 e1			    POP    HL 
0f83 c9			    RET 
