2449			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
2449			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
2449			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
2449			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
2449			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
2449			WORD_SYS_END: equ 0   ; Opcode for all user words 
2449			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
2449			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
2449			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
2449			 
2449			; Core word preamble macro 
2449			 
2449			CWHEAD:   macro nxtword opcode lit len opflags 
2449				db WORD_SYS_CORE+opcode             
2449				; internal op code number 
2449				dw nxtword            
2449				; link to next dict word block 
2449				db len + 1 
2449				; literal length of dict word inc zero term 
2449				db lit,0              
2449				; literal dict word 
2449			        ; TODO db opflags        
2449				endm 
