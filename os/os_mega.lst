59ef			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
59ef			; | | e.g. 
59ef			; | | $01 OPEN $01 DO READ . LOOP 
59ef			; | | 
59ef			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
59ef			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
59ef			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
59ef			; | | two bytes contain the file id and extent. 
59ef			; | |  
59ef			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
59ef			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
59ef			; | | > [!NOTE] 
59ef			; | | > Compatible with PicoSPINet  
59ef			 
59ef					if DEBUG_FORTH_WORDS_KEY 
59ef						DMARK "REA" 
59ef f5				push af  
59f0 3a 04 5a			ld a, (.dmark)  
59f3 32 99 fd			ld (debug_mark),a  
59f6 3a 05 5a			ld a, (.dmark+1)  
59f9 32 9a fd			ld (debug_mark+1),a  
59fc 3a 06 5a			ld a, (.dmark+2)  
59ff 32 9b fd			ld (debug_mark+2),a  
5a02 18 03			jr .pastdmark  
5a04 ..			.dmark: db "REA"  
5a07 f1			.pastdmark: pop af  
5a08			endm  
# End of macro DMARK
