9925			 
9925			 
9925			FORTH_CHK_DSP_UNDER: macro 
9925				push hl 
9925				push de 
9925				ld hl,(cli_data_sp) 
9925				ld de, cli_data_stack 
9925				call cmp16 
9925				jp c, fault_dsp_under 
9925				pop de 
9925				pop hl 
9925				endm 
9925			 
9925			 
9925			FORTH_CHK_RSP_UNDER: macro 
9925				push hl 
9925				push de 
9925				ld hl,(cli_ret_sp) 
9925				ld de, cli_ret_stack 
9925				call cmp16 
9925				jp c, fault_rsp_under 
9925				pop de 
9925				pop hl 
9925				endm 
9925			 
9925			FORTH_CHK_LOOP_UNDER: macro 
9925				push hl 
9925				push de 
9925				ld hl,(cli_loop_sp) 
9925				ld de, cli_loop_stack 
9925				call cmp16 
9925				jp c, fault_loop_under 
9925				pop de 
9925				pop hl 
9925				endm 
9925			 
9925			FORTH_ERR_TOS_NOTSTR: macro 
9925				; TOSO might need more for checks when used 
9925				push af 
9925				ld a,(hl) 
9925				cp DS_TYPE_STR 
9925				jp nz, type_faultn   
9925				pop af 
9925				endm 
9925			 
9925			FORTH_ERR_TOS_NOTNUM: macro 
9925				push af 
9925				ld a,(hl) 
9925				cp DS_TYPE_INUM 
9925				jp nz, type_faultn   
9925				pop af 
9925				endm 
