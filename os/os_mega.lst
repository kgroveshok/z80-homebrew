1320			; 
1320			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
1320			;                  .dw   0 
1320			 
1320			 
1320			endif 
1320			 
1320			 
1320			if MALLOC_3 
1320			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
1320			;heap_start        .equ  0x9000      ; Starting address of heap 
1320			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
1320			; 
1320			 ;     .org 0 
1320			  ;    jp    main 
1320			; 
1320			; 
1320			 ;     .org  0x100 
1320			;main: 
1320			 ;     ld    HL, 0x8100 
1320			  ;    ld    SP, HL 
1320			; 
1320			;      call  heap_init 
1320			 
1320			      ; Make some allocations 
1320			;      ld    HL, 12 
1320			;      call  malloc            ; Allocates 0x9004 
1320			; 
1320			 ;     ld    HL, 12 
1320			;      call  malloc            ; Allocates 0x9014 
1320			 
1320			;      ld    HL, 12 
1320			;      call  malloc            ; Allocates 0x9024 
1320			 
1320			      ; Free some allocations 
1320			;      ld    HL, 0x9014 
1320			;      call  free 
1320			 
1320			;      ld    HL, 0x9004 
1320			;      call  free 
1320			; 
1320			;      ld    HL, 0x9024 
1320			;      call  free 
1320			 
1320			 
1320			 ;     halt 
1320			 
1320			 
1320			;------------------------------------------------------------------------------ 
1320			;     heap_init                                                               : 
1320			;                                                                             : 
1320			; Description                                                                 : 
1320			;     Initialise the heap and make it ready for malloc and free operations.   : 
1320			;                                                                             : 
1320			;     The heap is maintained as a linked list, starting with an initial       : 
1320			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1320			;     the first free block in the heap. Each block then points to the next    : 
1320			;     free block within the heap, and the free list ends at the first block   : 
1320			;     with a null pointer to the next free block.                             : 
1320			;                                                                             : 
1320			; Parameters                                                                  : 
1320			;     Inputs are compile-time only. Two defines which specify the starting    : 
1320			;     address of the heap and its size are required, along with a memory      : 
1320			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1320			;     principally stores a pointer to the first free block in the heap.       : 
1320			;                                                                             : 
1320			; Returns                                                                     : 
1320			;     Nothing                                                                 : 
1320			;------------------------------------------------------------------------------ 
1320			heap_init: 
1320			      push  HL 
1320			 
1320			      ; Initialise free list struct 
1320			      ld    HL, heap_start 
1320			      ld    (free_list), HL 
1320			      ld    HL, 0 
1320			      ld    (free_list+2), HL 
1320			 
1320			      ; Insert first free block at bottom of heap, consumes entire heap 
1320			      ld    HL, heap_start+heap_size-4 
1320			      ld    (heap_start), HL        ; Next block (end of free list) 
1320			      ld    HL, heap_size-4 
1320			      ld    (heap_start+2), HL      ; Block size 
1320			 
1320			      ; Insert end of free list block at top of heap - two null words will 
1320			      ; terminate the free list 
1320			      ld    HL, 0 
1320			      ld    (heap_start+heap_size-2), HL 
1320			      ld    (heap_start+heap_size-4), HL 
1320			 
1320			      pop   HL 
1320			 
1320			      ret 
1320			 
1320			 
1320			;------------------------------------------------------------------------------ 
1320			;     malloc                                                                  : 
1320			;                                                                             : 
1320			; Description                                                                 : 
1320			;     Allocates the wanted space from the heap and returns the address of the : 
1320			;     first useable byte of the allocation.                                   : 
1320			;                                                                             : 
1320			;     Allocations can happen in one of two ways:                              : 
1320			;                                                                             : 
1320			;     1. A free block may be found which is the exact size wanted. In this    : 
1320			;        case the block is removed from the free list and retuedn to the      : 
1320			;        caller.                                                              : 
1320			;     2. A free block may be found which is larger than the size wanted. In   : 
1320			;        this case, the larger block is split into two. The first portion of  : 
1320			;        this block will become the requested space by the malloc call and    : 
1320			;        is returned to the caller. The second portion becomes a new free     : 
1320			;        block, and the free list is adjusted to maintain continuity via this : 
1320			;        newly created block.                                                 : 
1320			;                                                                             : 
1320			;     malloc does not set any initial value in the allocated space, the       : 
1320			;     caller is required to do this as required.                              : 
1320			;                                                                             : 
1320			;     This implementation of malloc uses the stack exclusively, and is        : 
1320			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1320			;     advisable to disable interrupts before calling malloc, and recommended  : 
1320			;     to avoid the use of malloc inside ISRs in general.                      : 
1320			;                                                                             : 
1320			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1320			;                                                                             : 
1320			; Parameters                                                                  : 
1320			;     HL  Number of bytes wanted                                              : 
1320			;                                                                             : 
1320			; Returns                                                                     : 
1320			;     HL  Address of the first useable byte of the allocation                 : 
1320			;                                                                             : 
1320			; Flags                                                                       : 
1320			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1320			;                                                                             : 
1320			; Stack frame                                                                 : 
1320			;       |             |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |     BC      |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |     DE      |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |     IX      |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |  prev_free  |                                                       : 
1320			;   +4  +-------------+                                                       : 
1320			;       |  this_free  |                                                       : 
1320			;   +2  +-------------+                                                       : 
1320			;       |  next_free  |                                                       : 
1320			;   +0  +-------------+                                                       : 
1320			;       |             |                                                       : 
1320			;                                                                             : 
1320			;------------------------------------------------------------------------------ 
1320			malloc: 
1320			      push  BC 
1320			      push  DE 
1320			      push  IX 
1320			 
1320			      ld    A, H                    ; Exit if no space requested 
1320			      or    L 
1320			      jp    Z, malloc_early_exit 
1320			 
1320			      ; Set up stack frame 
1320			      ex    DE, HL 
1320			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1320			      add   HL, SP 
1320			      ld    SP, HL 
1320			      ld    IX, 0                   ; Use IX as a frame pointer 
1320			      add   IX, SP 
1320			 
1320			      ; Setup initial state 
1320			      ld    HL, 4                   ; want must also include space used by block struct 
1320			      add   HL, DE 
1320			 
1320			      ld    B, H                    ; Move want to BC 
1320			      ld    C, L 
1320			 
1320			      ld    HL, free_list           ; Store prev_free ptr to stack 
1320			      ld    (IX+4), L 
1320			      ld    (IX+5), H 
1320			 
1320			      ld    E, (HL)                 ; Store this_free ptr to stack 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      ld    (IX+2), E 
1320			      ld    (IX+3), D 
1320			      ex    DE, HL                  ; this_free ptr into HL 
1320			 
1320			      ; Loop through free block list to find some space 
1320			malloc_find_space: 
1320			      ld    E, (HL)                 ; Load next_free ptr into DE 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			 
1320			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1320			      or    E 
1320			      jp    Z, malloc_no_space 
1320			 
1320			      ld    (IX+0), E               ; Store next_free ptr to stack 
1320			      ld    (IX+1), D 
1320			 
1320			      ; Does this block have enough space to make the allocation? 
1320			      inc   HL                      ; Load free block size into DE 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			 
1320			      ex    DE, HL                  ; Check size of block against want 
1320			      or    A                       ; Ensure carry flag clear 
1320			      sbc   HL, BC 
1320			      push  HL                      ; Store the result for later (new block size) 
1320			 
1320			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1320			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1320			 
1320			      ; this_free block is not big enough, setup ptrs to test next free block 
1320			      pop   HL                      ; Discard previous result 
1320			 
1320			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1320			      ld    H, (IX+3) 
1320			      ld    (IX+4), L 
1320			      ld    (IX+5), H 
1320			 
1320			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1320			      ld    H, (IX+1) 
1320			      ld    (IX+2), L 
1320			      ld    (IX+3), H 
1320			 
1320			      jr    malloc_find_space 
1320			 
1320			      ; split a bigger block into two - requested size and remaining size 
1320			malloc_alloc_split: 
1320			      ex    DE, HL                  ; Calculate address of new free block 
1320			      dec   HL 
1320			      dec   HL 
1320			      dec   HL 
1320			      add   HL, BC 
1320			 
1320			      ; Create a new block and point it at next_free 
1320			      ld    E, (IX+0)               ; Load next_free ptr into DE 
1320			      ld    D, (IX+1) 
1320			 
1320			      ld    (HL), E                 ; Store next_free ptr into new block 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			      pop   DE                      ; Store size of new block into new block 
1320			      inc   HL 
1320			      ld    (HL), E 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			      ; Update this_free ptr to point to new block 
1320			      dec   HL 
1320			      dec   HL 
1320			      dec   HL 
1320			 
1320			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1320			      ld    D, (IX+3) 
1320			 
1320			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
1320			      ld    (IX+3), H 
1320			 
1320			      ; Modify this_free block to be allocation 
1320			      ex    DE, HL 
1320			      xor   A                       ; Null the next block ptr of allocated block 
1320			      ld    (HL), A 
1320			      inc   HL 
1320			      ld    (HL), A 
1320			 
1320			      inc   HL                      ; Store want size into allocated block 
1320			      ld    (HL), C 
1320			      inc   HL 
1320			      ld    (HL), B 
1320			      inc   HL 
1320			      push  HL                      ; Address of allocation to return 
1320			 
1320			      jr    malloc_update_links 
1320			 
1320			malloc_alloc_fit: 
1320			      pop   HL                      ; Dont need new block size, want is exact fit 
1320			 
1320			      ; Modify this_free block to be allocation 
1320			      ex    DE, HL 
1320			      dec   HL 
1320			      dec   HL 
1320			      dec   HL 
1320			 
1320			      xor   A                       ; Null the next block ptr of allocated block 
1320			      ld    (HL), A 
1320			      inc   HL 
1320			      ld    (HL), A 
1320			 
1320			      inc   HL                      ; Store address of allocation to return 
1320			      inc   HL 
1320			      inc   HL 
1320			      push  HL 
1320			 
1320			      ; Copy next_free ptr to this_free, remove allocated block from free list 
1320			      ld    L, (IX+0)               ; next_free to HL 
1320			      ld    H, (IX+1) 
1320			 
1320			      ld    (IX+2), L               ; HL to this_free 
1320			      ld    (IX+3), H 
1320			 
1320			 
1320			malloc_update_links: 
1320			      ; Update prev_free ptr to point to this_free 
1320			      ld    L, (IX+4)               ; prev_free ptr to HL 
1320			      ld    H, (IX+5) 
1320			 
1320			      ld    E, (IX+2)               ; this_free ptr to DE 
1320			      ld    D, (IX+3) 
1320			 
1320			      ld    (HL), E                 ; this_free ptr into prev_free 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			      ; Clear the Z flag to indicate successful allocation 
1320			      ld    A, D 
1320			      or    E 
1320			 
1320			      pop   DE                      ; Address of allocation 
1320			 
1320			malloc_no_space: 
1320			      ld    HL, 6                   ; Clean up stack frame 
1320			      add   HL, SP 
1320			      ld    SP, HL 
1320			 
1320			      ex    DE, HL                  ; Alloc addr into HL for return 
1320			 
1320			malloc_early_exit: 
1320			      pop   IX 
1320			      pop   DE 
1320			      pop   BC 
1320			 
1320			      ret 
1320			 
1320			 
1320			;------------------------------------------------------------------------------ 
1320			;     free                                                                    : 
1320			;                                                                             : 
1320			; Description                                                                 : 
1320			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1320			;     returned by malloc, otherwise the behaviour is undefined.               : 
1320			;                                                                             : 
1320			;     Where possible, directly adjacent free blocks will be merged together   : 
1320			;     into larger blocks to help ensure that the heap does not become         : 
1320			;     excessively fragmented.                                                 : 
1320			;                                                                             : 
1320			;     free does not clear or set any other value into the freed space, and    : 
1320			;     therefore its contents may be visible through subsequent malloc's. The  : 
1320			;     caller should clear the freed space as required.                        : 
1320			;                                                                             : 
1320			;     This implementation of free uses the stack exclusively, and is          : 
1320			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1320			;     advisable to disable interrupts before calling free, and recommended    : 
1320			;     to avoid the use of free inside ISRs in general.                        : 
1320			;                                                                             : 
1320			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1320			;                                                                             : 
1320			; Parameters                                                                  : 
1320			;     HL  Pointer to address of first byte of allocation to be freed          : 
1320			;                                                                             : 
1320			; Returns                                                                     : 
1320			;     Nothing                                                                 : 
1320			;                                                                             : 
1320			; Stack frame                                                                 : 
1320			;       |             |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |     BC      |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |     DE      |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |     IX      |                                                       : 
1320			;       +-------------+                                                       : 
1320			;       |  prev_free  |                                                       : 
1320			;   +2  +-------------+                                                       : 
1320			;       |  next_free  |                                                       : 
1320			;   +0  +-------------+                                                       : 
1320			;       |             |                                                       : 
1320			;                                                                             : 
1320			;------------------------------------------------------------------------------ 
1320			free: 
1320			      push  BC 
1320			      push  DE 
1320			      push  IX 
1320			 
1320			      ld    A, H                    ; Exit if ptr is null 
1320			      or    L 
1320			      jp    Z, free_early_exit 
1320			 
1320			      ; Set up stack frame 
1320			      ex    DE, HL 
1320			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1320			      add   HL, SP 
1320			      ld    SP, HL 
1320			      ld    IX, 0                   ; Use IX as a frame pointer 
1320			      add   IX, SP 
1320			 
1320			      ; The address in HL points to the start of the useable allocated space, 
1320			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1320			      ; address of the block itself. 
1320			      ex    DE, HL 
1320			      ld    DE, -4 
1320			      add   HL, DE 
1320			 
1320			      ; An allocated block must have a null next block pointer in it 
1320			      ld    A, (HL) 
1320			      inc   HL 
1320			      or    (HL) 
1320			      jp    NZ, free_done 
1320			 
1320			      dec   HL 
1320			 
1320			      ld    B, H                    ; Copy HL to BC 
1320			      ld    C, L 
1320			 
1320			      ; Loop through the free list to find the first block with an address 
1320			      ; higher than the block being freed 
1320			      ld    HL, free_list 
1320			 
1320			free_find_higher_block: 
1320			      ld    E, (HL)                 ; Load next ptr from free block 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      dec   HL 
1320			 
1320			      ld    (IX+0), E               ; Save ptr to next free block 
1320			      ld    (IX+1), D 
1320			      ld    (IX+2), L               ; Save ptr to prev free block 
1320			      ld    (IX+3), H 
1320			 
1320			      ld    A, B                    ; Check if DE is greater than BC 
1320			      cp    D                       ; Compare MSB first 
1320			      jr    Z, $+4                  ; MSB the same, compare LSB 
1320			      jr    NC, free_find_higher_block_skip 
1320			      ld    A, C 
1320			      cp    E                       ; Then compare LSB 
1320			      jr    C, free_found_higher_block 
1320			 
1320			free_find_higher_block_skip: 
1320			      ld    A, D                    ; Reached the end of the free list? 
1320			      or    E 
1320			      jp    Z, free_done 
1320			 
1320			      ex    DE, HL 
1320			 
1320			      jr    free_find_higher_block 
1320			 
1320			free_found_higher_block: 
1320			      ; Insert freed block between prev and next free blocks 
1320			      ld    (HL), C                 ; Point prev free block to freed block 
1320			      inc   HL 
1320			      ld    (HL), B 
1320			 
1320			      ld    H, B                    ; Point freed block at next free block 
1320			      ld    L, C 
1320			      ld    (HL), E 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			      ; Check if the freed block is adjacent to the next free block 
1320			      inc   HL                      ; Load size of freed block into HL 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      ex    DE, HL 
1320			 
1320			      add   HL, BC                  ; Add addr of freed block and its size 
1320			 
1320			      ld    E, (IX+0)               ; Load addr of next free block into DE 
1320			      ld    D, (IX+1) 
1320			 
1320			      or    A                       ; Clear the carry flag 
1320			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1320			      jr    NZ, free_check_adjacent_to_prev 
1320			 
1320			      ; Freed block is adjacent to next, merge into one bigger block 
1320			      ex    DE, HL                  ; Load next ptr from next block into DE 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      push  HL                      ; Save ptr to next block for later 
1320			 
1320			      ld    H, B                    ; Store ptr from next block into freed block 
1320			      ld    L, C 
1320			      ld    (HL), E 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			      pop   HL                      ; Restore ptr to next block 
1320			      inc   HL                      ; Load size of next block into DE 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      push  DE                      ; Save next block size for later 
1320			 
1320			      ld    H, B                    ; Load size of freed block into HL 
1320			      ld    L, C 
1320			      inc   HL 
1320			      inc   HL 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      ex    DE, HL 
1320			 
1320			      pop   DE                      ; Restore size of next block 
1320			      add   HL, DE                  ; Add sizes of both blocks 
1320			      ex    DE, HL 
1320			 
1320			      ld    H, B                    ; Store new bigger size into freed block 
1320			      ld    L, C 
1320			      inc   HL 
1320			      inc   HL 
1320			      ld    (HL), E 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			free_check_adjacent_to_prev: 
1320			      ; Check if the freed block is adjacent to the prev free block 
1320			      ld    L, (IX+2)               ; Prev free block ptr into HL 
1320			      ld    H, (IX+3) 
1320			 
1320			      inc   HL                      ; Size of prev free block into DE 
1320			      inc   HL 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      dec   HL 
1320			      dec   HL 
1320			      dec   HL 
1320			 
1320			      add   HL, DE                  ; Add prev block addr and size 
1320			 
1320			      or    A                       ; Clear the carry flag 
1320			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1320			      jr    NZ, free_done 
1320			 
1320			      ; Freed block is adjacent to prev, merge into one bigger block 
1320			      ld    H, B                    ; Load next ptr from freed block into DE 
1320			      ld    L, C 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      push  HL                      ; Save freed block ptr for later 
1320			 
1320			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1320			      ld    H, (IX+3) 
1320			      ld    (HL), E 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			      pop   HL                      ; Restore freed block ptr 
1320			      inc   HL                      ; Load size of freed block into DE 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			      push  DE                      ; Save freed block size for later 
1320			 
1320			      ld    L, (IX+2)               ; Load size of prev block into DE 
1320			      ld    H, (IX+3) 
1320			      inc   HL 
1320			      inc   HL 
1320			      ld    E, (HL) 
1320			      inc   HL 
1320			      ld    D, (HL) 
1320			 
1320			      pop   HL                      ; Add sizes of both blocks 
1320			      add   HL, DE 
1320			      ex    DE, HL 
1320			 
1320			      ld    L, (IX+2)               ; Store new bigger size into prev block 
1320			      ld    H, (IX+3) 
1320			      inc   HL 
1320			      inc   HL 
1320			      ld    (HL), E 
1320			      inc   HL 
1320			      ld    (HL), D 
1320			 
1320			free_done: 
1320			      ld    HL, 4                   ; Clean up stack frame 
1320			      add   HL, SP 
1320			      ld    SP, HL 
1320			 
1320			free_early_exit: 
1320			      pop   IX 
1320			      pop   DE 
1320			      pop   BC 
1320			 
1320			      ret 
1320			 
1320			 
1320			;      .org 0x8000 
1320			; 
1320			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
1320			 ;                 .dw   0 
1320			 
1320			endif 
1320			 
1320			 
1320			if MALLOC_4 
1320			 
1320			; My memory allocation code. Very very simple.... 
1320			; allocate space under 250 chars 
1320			 
1320			heap_init: 
1320				; init start of heap as zero 
1320				;  
1320			 
1320				ld hl, heap_start 
1320			;	ld a, 0 
1320				ld (hl), 0      ; empty block 
1320				inc hl 
1320			;	ld a, 0 
1320				ld (hl), 0      ; length of block 
1320				; write end of list 
1320				inc hl 
1320				ld a,(hl) 
1320				inc hl 
1320				ld a,(hl) 
1320				 
1320			 
1320				; init some malloc vars 
1320			 
1320				ld hl, 0 
1320				ld (free_list), hl       ; store last malloc location 
1320			 
1320				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
1320			;	ld a, 0 
1320				ld (hl), 0 
1320			 
1320			 
1320				ld hl, heap_start 
1320				;  
1320				  
1320				ret 
1320			 
1320			 
1320			;    free block marker 
1320			;    requested size  
1320			;    pointer to next block 
1320			;    .... 
1320			;    next block marker 
1320			 
1320			 
1320			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
1320			; 
1320			 
1320			 
1320			malloc:  
1320				push de 
1320				push bc 
1320				push af 
1320			 
1320				; hl space required 
1320				 
1320				ld c, l    ; hold space   (TODO only a max of 255) 
1320			 
1320			;	inc c     ; TODO BUG need to fix memory leak on push str 
1320			;	inc c 
1320			;	inc c 
1320			;	inc c 
1320			;	inc c 
1320			;	inc c 
1320			;	inc c 
1320			 
1320			 
1320			 
1320				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
1320			 
1320				ld a, (free_list+3) 
1320			;	cp 0 
1320				or a 
1320				jr z, .contheap 
1320			 
1320				ld hl, (free_list)     ; get last alloc 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "mrs" 
1320						CALLMONITOR 
1320					endif 
1320				jr .startalloc 
1320			 
1320			.contheap: 
1320				ld hl, heap_start 
1320			 
1320			.startalloc: 
1320			 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "mym" 
1320						CALLMONITOR 
1320					endif 
1320			.findblock: 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "mmf" 
1320						CALLMONITOR 
1320					endif 
1320			 
1320				ld a,(hl)  
1320				; if byte is zero then clear to use 
1320			 
1320			;	cp 0 
1320				or a 
1320				jr z, .foundemptyblock 
1320			 
1320				; if byte is not clear 
1320				;     then byte is offset to next block 
1320			 
1320				inc hl 
1320				ld a, (hl) ; get size 
1320			.nextblock:	inc hl 
1320					ld e, (hl) 
1320					inc hl 
1320					ld d, (hl) 
1320					ex de, hl 
1320			;	inc hl  ; move past the store space 
1320			;	inc hl  ; move past zero index  
1320			 
1320				; TODO detect no more space 
1320			 
1320				push hl 
1320				ld de, heap_end 
1320				call cmp16 
1320				pop hl 
1320				jr nc, .nospace 
1320			 
1320				jr .findblock 
1320			 
1320			.nospace: ld hl, 0 
1320				jp .exit 
1320			 
1320			 
1320			.foundemptyblock:	 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "mme" 
1320						CALLMONITOR 
1320					endif 
1320			 
1320			; TODO has block enough space if reusing??? 
1320			 
1320				;  
1320			 
1320			; see if this block has been previously used 
1320				inc hl 
1320				ld a, (hl) 
1320				dec hl 
1320			;	cp 0 
1320				or a 
1320				jr z, .newblock 
1320			 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "meR" 
1320						CALLMONITOR 
1320					endif 
1320			 
1320			; no reusing previously allocated block 
1320			 
1320			; is it smaller than previously used? 
1320				 
1320				inc hl    ; move to size 
1320				ld a, c 
1320				sub (hl)        ; we want c < (hl) 
1320				dec hl    ; move back to marker 
1320			        jr z, .findblock 
1320			 
1320				; update with the new size which should be lower 
1320			 
1320			        ;inc  hl   ; negate next move. move back to size  
1320			 
1320			.newblock: 
1320				; need to be at marker here 
1320			 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "meN" 
1320						CALLMONITOR 
1320					endif 
1320			 
1320			 
1320				ld a, c 
1320			 
1320				ld (free_list+3), a	 ; flag resume from last malloc  
1320				ld (free_list), hl    ; save out last location 
1320			 
1320			 
1320				;inc a     ; space for length byte 
1320				ld (hl), a     ; save block in use marker 
1320			 
1320				inc hl   ; move to space marker 
1320				ld (hl), a    ; save new space 
1320			 
1320				inc hl   ; move to start of allocated area 
1320				 
1320			;	push hl     ; save where we are - 1  
1320			 
1320			;	inc hl  ; move past zero index  
1320				; skip space to set down new marker 
1320			 
1320				; provide some extra space for now 
1320			 
1320				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
1320				inc a 
1320				inc a 
1320			 
1320				push hl   ; save where we are in the node block 
1320			 
1320				call addatohl 
1320			 
1320				; write linked list point 
1320			 
1320				pop de     ; get our node position 
1320				ex de, hl 
1320			 
1320				ld (hl), e 
1320				inc hl 
1320				ld (hl), d 
1320			 
1320				inc hl 
1320			 
1320				; now at start of allocated data so save pointer 
1320			 
1320				push hl 
1320			 
1320				; jump to position of next node and setup empty header in DE 
1320			 
1320				ex de, hl 
1320			 
1320			;	inc hl ; move past end of block 
1320			 
1320			;	ld a, 0 
1320				ld (hl), 0   ; empty marker 
1320				inc hl 
1320				ld (hl), 0   ; size 
1320				inc hl  
1320				ld (hl), 0   ; ptr 
1320				inc hl 
1320				ld (hl), 0   ; ptr 
1320			 
1320			 
1320				pop hl 
1320			 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "mmr" 
1320						CALLMONITOR 
1320					endif 
1320			 
1320			.exit: 
1320				pop af 
1320				pop bc 
1320				pop de  
1320				ret 
1320			 
1320			 
1320			 
1320			 
1320			free:  
1320				push hl 
1320				push af 
1320				; get address in hl 
1320			 
1320					if DEBUG_FORTH_MALLOC_INT 
1320						DMARK "fre" 
1320						CALLMONITOR 
1320					endif 
1320				; data is at hl - move to block count 
1320				dec hl 
1320				dec hl    ; get past pointer 
1320				dec hl 
1320			 
1320				ld a, (hl)    ; need this for a validation check 
1320			 
1320				dec hl    ; move to block marker 
1320			 
1320				; now check that the block count and block marker are the same  
1320			        ; this checks that we are on a malloc node and not random memory 
1320			        ; OK a faint chance this could be a problem but rare - famous last words! 
1320			 
1320				ld c, a 
1320				ld a, (hl)    
1320			 
1320				cp c 
1320				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
1320			 
1320				; yes good chance we are on a malloc node 
1320			 
1320			;	ld a, 0      
1320				ld (hl), 0   ; mark as free 
1320			 
1320				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
1320			 
1320			.freeignore:  
1320			 
1320				pop af 
1320				pop hl 
1320			 
1320				ret 
1320			 
1320			 
1320			 
1320			endif 
1320			 
1320			; eof 
# End of file firmware_memory.asm
