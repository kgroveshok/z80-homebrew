1325			if MALLOC_2 
1325			; Z80 Malloc and Free Functions 
1325			 
1325			; Malloc Function: 
1325			; Input: 
1325			;   HL: Size of block to allocate 
1325			; Output: 
1325			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1325			 
1325			malloc: 
1325				 
1325			if DEBUG_FORTH_MALLOC_HIGH 
1325			call malloc_guard_entry 
1325			endif 
1325			 
1325			 
1325			 
1325			 
1325					if DEBUG_FORTH_MALLOC 
1325						DMARK "mal" 
1325						CALLMONITOR 
1325					endif 
1325			    push af            ; Save AF register 
1325			    ld a, l            ; Load low byte of size into A 
1325			    or h               ; Check if size is zero 
1325			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1325			 
1325			    ; Allocate memory 
1325			    ld hl, (heap_start) ; Load start of heap into HL 
1325					if DEBUG_FORTH_MALLOC 
1325						DMARK "ma1" 
1325						CALLMONITOR 
1325					endif 
1325			    call malloc_internal ; Call internal malloc function 
1325			    pop af             ; Restore AF register 
1325			if DEBUG_FORTH_MALLOC_HIGH 
1325			call malloc_guard_exit 
1325			call malloc_guard_zerolen 
1325			endif 
1325			    ret                ; Return 
1325			 
1325			; Free Function: 
1325			; Input: 
1325			;   HL: Pointer to memory block to free 
1325			; Output: 
1325			;   None 
1325			 
1325			free: 
1325			    push af            ; Save AF register 
1325			    ld a, l            ; Load low byte of pointer into A 
1325			    or h               ; Check if pointer is NULL 
1325			    jp z, free_exit    ; If pointer is NULL, exit 
1325			 
1325			    ; Free memory 
1325			    ld hl, (heap_start) ; Load start of heap into HL 
1325			    call free_internal  ; Call internal free function 
1325			    pop af             ; Restore AF register 
1325			    ret                ; Return 
1325			 
1325			; Internal Malloc Function: 
1325			; Input: 
1325			;   HL: Size of block to allocate 
1325			; Output: 
1325			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1325			 
1325			malloc_internal: 
1325			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1325			    add hl, bc         ; Add management overhead to requested size 
1325			    ex de, hl          ; Save total size in DE, and keep it in HL 
1325					if DEBUG_FORTH_MALLOC 
1325						DMARK "ma2" 
1325						CALLMONITOR 
1325					endif 
1325			 
1325			    ; Search for free memory block 
1325			    ld de, (heap_end)  ; Load end of heap into DE 
1325			    ld bc, 0           ; Initialize counter 
1325			 
1325					if DEBUG_FORTH_MALLOC 
1325						DMARK "ma2" 
1325						CALLMONITOR 
1325					endif 
1325			malloc_search_loop: 
1325			    ; Check if current block is free 
1325			    ld a, (hl)         ; Load current block's status (free or used) 
1325			;    cp 0               ; Compare with zero (free) 
1325				or a 
1325			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1325			 
1325			    ; Check if current block is large enough 
1325			    ld a, (hl+1)       ; Load high byte of block size 
1325			    cp l               ; Compare with low byte of requested size 
1325			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1325			 
1325			    ld a, (hl+2)       ; Load low byte of block size 
1325			    cp h               ; Compare with high byte of requested size 
1325			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1325			 
1325			    ; Mark block as used 
1325			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1325			 
1325			    ; Calculate remaining space in block 
1325			    ld bc, 0           ; Clear BC 
1325			    add hl, bc         ; Increment HL to point to start of data block 
1325			    add hl, de         ; HL = HL + DE (total size) 
1325			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1325			    add hl, bc         ; Add management overhead to start of data block 
1325			 
1325			    ; Save pointer to allocated block in HL 
1325			if DEBUG_FORTH_MALLOC_HIGH 
1325						DMARK "ma5" 
1325			call malloc_guard_exit 
1325			call malloc_guard_zerolen 
1325			endif 
1325			    ret 
1325			 
1325			malloc_skip_block_check: 
1325			    ; Move to the next block 
1325			    ld bc, 3           ; Size of management overhead 
1325			    add hl, bc         ; Move to the next block 
1325			    inc de             ; Increment counter 
1325			 
1325			    ; Check if we have reached the end of heap 
1325			    ld a, e            ; Load low byte of heap end address 
1325			    cp (hl)            ; Compare with low byte of current address 
1325			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1325			    ld a, d            ; Load high byte of heap end address 
1325			;    cp 0               ; Check if it's zero (end of memory) 
1325				or a 
1325			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1325			 
1325			    ; If we reached here, allocation failed 
1325			    xor a              ; Set result to NULL 
1325			if DEBUG_FORTH_MALLOC_HIGH 
1325						DMARK "ma6" 
1325			call malloc_guard_exit 
1325			call malloc_guard_zerolen 
1325			endif 
1325			    ret 
1325			malloc_exit: 
1325			if DEBUG_FORTH_MALLOC_HIGH 
1325						DMARK "ma7" 
1325			call malloc_guard_exit 
1325			call malloc_guard_zerolen 
1325			endif 
1325			    ret 
1325			 
1325			; Internal Free Function: 
1325			; Input: 
1325			;   HL: Pointer to memory block to free 
1325			; Output: 
1325			;   None 
1325			 
1325			free_internal: 
1325			    ld de, (heap_start) ; Load start of heap into DE 
1325			    ld bc, 0            ; Initialize counter 
1325			 
1325			free_search_loop: 
1325			    ; Check if current block contains the pointer 
1325			    ld a, l             ; Load low byte of pointer 
1325			    cp (hl+1)           ; Compare with high byte of current block's address 
1325			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1325			    ld a, h             ; Load high byte of pointer 
1325			    cp (hl+2)           ; Compare with low byte of current block's address 
1325			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1325			 
1325			    ; Mark block as free 
1325			    ld (hl), 0          ; Set status byte to indicate free block 
1325			    ret                 ; Return 
1325			 
1325			free_skip_block_check: 
1325			    ; Move to the next block 
1325			    ld bc, 3            ; Size of management overhead 
1325			    add hl, bc          ; Move to the next block 
1325			    inc de              ; Increment counter 
1325			 
1325			    ; Check if we have reached the end of heap 
1325			    ld a, e             ; Load low byte of heap end address 
1325			    cp (hl)             ; Compare with low byte of current address 
1325			    jr nz, free_search_loop  ; If not equal, continue searching 
1325			    ld a, d             ; Load high byte of heap end address 
1325			;    cp 0                ; Check if it's zero (end of memory) 
1325				or a 
1325			    jr nz, free_search_loop  ; If not zero, continue searching 
1325			 
1325			    ; If we reached here, pointer is not found in heap 
1325			    ret 
1325			 
1325			free_exit: 
1325			    ret                 ; Return 
1325			 
1325			; Define heap start and end addresses 
1325			;heap_start:    .dw 0xC000   ; Start of heap 
1325			;heap_end:      .dw 0xE000   ; End of heap 
1325			 
1325			endif 
