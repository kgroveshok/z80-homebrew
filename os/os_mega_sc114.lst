d27d			; write the frame buffer given in hl to hardware  
d27d			write_display: 
d27d			 
d27d			API: equ 0 
d27d			 
d27d			if API 
d27d				push bc 
d27d				ld b, 4 
d27d			 
d27d			        ld (display_write_tmp), hl 	  
d27d			 
d27d				; clear and home cursor 
d27d			 
d27d				ld c, 6 
d27d				ld de, .cls 
d27d				rst $30 
d27d			 
d27d			 
d27d			.writeln: 
d27d			 
