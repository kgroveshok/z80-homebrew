a40e			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a40e			; | | At start the current various registers will be displayed with contents. 
a40e			; | | Top right corner will show the most recent debug marker seen. 
a40e			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a40e			; | | and the return stack pointer (RSP). 
a40e			; | | Pressing: 
a40e			; | |  
a40e			; | |    1 - Initial screen 
a40e			; | |  
a40e			; | |    2 - Display a data dump of HL 
a40e			; | |  
a40e			; | |    3 - Display a data dump of DE 
a40e			; | |  
a40e			; | |    4 - Display a data dump of BC 
a40e			; | |  
a40e			; | |    5 - Display a data dump of HL 
a40e			; | |  
a40e			; | |    6 - Display a data dump of DSP 
a40e			; | |  
a40e			; | |    7 - Display a data dump of RSP 
a40e			; | |  
a40e			; | |    8 - Display a data dump of what is at DSP 
a40e			; | |  
a40e			; | |    9 - Display a data dump of what is at RSP 
a40e			; | |  
a40e			; | |    0 - Exit monitor and continue running. This will also enable break points 
a40e			; | |  
a40e			; | |    * - Disable break points 
a40e			; | |  
a40e			; | |    # - Enter traditional monitor mode 
a40e			; | |  
a40e			; | | 
a40e			; | | Monitor Mode 
a40e			; | | ------------ 
a40e			; | | A prompt of '>' will be shown for various commands: 
a40e			; | |  
a40e			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a40e			; | |  
a40e			; | |    C - Continue display a data dump from the last set address 
a40e			; | |  
a40e			; | |    M xxxx - Set start of memory edit at address xx 
a40e			; | |  
a40e			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a40e			; | |  
a40e			; | |    G xxxx - Exec code at specific address 
a40e			; | |  
a40e			; | |    Q - Return to previous 
a40e				if DEBUG_FORTH_WORDS_KEY 
a40e					DMARK "MON" 
a40e				if DEMARK_VERSION = 1  
a40e e5					push hl  
a40f 21 17 a4				ld hl, .dmark  
a412 22 60 ee				ld (debug_mark), hl  
a415				endif  
