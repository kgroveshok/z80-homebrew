0c37			 
0c37			;-----> Generate a random number 
0c37			; output a=answer 0<=a<=255 
0c37			; all registers are preserved except: af 
0c37			random: 
0c37 e5			        push    hl 
0c38 d5			        push    de 
0c39 2a db fa		        ld      hl,(randData) 
0c3c ed 5f		        ld      a,r 
0c3e 57			        ld      d,a 
0c3f 5e			        ld      e,(hl) 
0c40 19			        add     hl,de 
0c41 85			        add     a,l 
0c42 ac			        xor     h 
0c43 22 db fa		        ld      (randData),hl 
0c46 d1			        pop     de 
0c47 e1			        pop     hl 
0c48 c9			        ret 
0c49			 
0c49			 
0c49			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0c49			 
0c49			 
0c49			 
0c49			;------LFSR------ 
0c49			;James Montelongo 
0c49			;optimized by Spencer Putt 
0c49			;out: 
0c49			; a = 8 bit random number 
0c49			RandLFSR: 
0c49 21 e1 fa		        ld hl,LFSRSeed+4 
0c4c 5e			        ld e,(hl) 
0c4d 23			        inc hl 
0c4e 56			        ld d,(hl) 
0c4f 23			        inc hl 
0c50 4e			        ld c,(hl) 
0c51 23			        inc hl 
0c52 7e			        ld a,(hl) 
0c53 47			        ld b,a 
0c54 cb 13		        rl e  
0c56 cb 12			rl d 
0c58 cb 11		        rl c  
0c5a 17				rla 
0c5b cb 13		        rl e  
0c5d cb 12			rl d 
0c5f cb 11		        rl c  
0c61 17				rla 
0c62 cb 13		        rl e  
0c64 cb 12			rl d 
0c66 cb 11		        rl c  
0c68 17				rla 
0c69 67			        ld h,a 
0c6a cb 13		        rl e  
0c6c cb 12			rl d 
0c6e cb 11		        rl c  
0c70 17				rla 
0c71 a8			        xor b 
0c72 cb 13		        rl e  
0c74 cb 12			rl d 
0c76 ac			        xor h 
0c77 a9			        xor c 
0c78 aa			        xor d 
0c79 21 e3 fa		        ld hl,LFSRSeed+6 
0c7c 11 e4 fa		        ld de,LFSRSeed+7 
0c7f 01 07 00		        ld bc,7 
0c82 ed b8		        lddr 
0c84 12			        ld (de),a 
0c85 c9			        ret 
0c86			 
0c86			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0c86			 
0c86			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0c86			 
0c86			 
0c86			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0c86			 
0c86			prng16: 
0c86			;Inputs: 
0c86			;   (seed1) contains a 16-bit seed value 
0c86			;   (seed2) contains a NON-ZERO 16-bit seed value 
0c86			;Outputs: 
0c86			;   HL is the result 
0c86			;   BC is the result of the LCG, so not that great of quality 
0c86			;   DE is preserved 
0c86			;Destroys: 
0c86			;   AF 
0c86			;cycle: 4,294,901,760 (almost 4.3 billion) 
0c86			;160cc 
0c86			;26 bytes 
0c86 2a d5 fa		    ld hl,(seed1) 
0c89 44			    ld b,h 
0c8a 4d			    ld c,l 
0c8b 29			    add hl,hl 
0c8c 29			    add hl,hl 
0c8d 2c			    inc l 
0c8e 09			    add hl,bc 
0c8f 22 d5 fa		    ld (seed1),hl 
0c92 2a d3 fa		    ld hl,(seed2) 
0c95 29			    add hl,hl 
0c96 9f			    sbc a,a 
0c97 e6 2d		    and %00101101 
0c99 ad			    xor l 
0c9a 6f			    ld l,a 
0c9b 22 d3 fa		    ld (seed2),hl 
0c9e 09			    add hl,bc 
0c9f c9			    ret 
0ca0			 
0ca0			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0ca0			 
0ca0			rand32: 
0ca0			;Inputs: 
0ca0			;   (seed1_0) holds the lower 16 bits of the first seed 
0ca0			;   (seed1_1) holds the upper 16 bits of the first seed 
0ca0			;   (seed2_0) holds the lower 16 bits of the second seed 
0ca0			;   (seed2_1) holds the upper 16 bits of the second seed 
0ca0			;   **NOTE: seed2 must be non-zero 
0ca0			;Outputs: 
0ca0			;   HL is the result 
0ca0			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0ca0			;Destroys: 
0ca0			;   AF 
0ca0			;Tested and passes all CAcert tests 
0ca0			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0ca0			;it has a period of 18,446,744,069,414,584,320 
0ca0			;roughly 18.4 quintillion. 
0ca0			;LFSR taps: 0,2,6,7  = 11000101 
0ca0			;291cc 
0ca0			;seed1_0=$+1 
0ca0			;    ld hl,12345 
0ca0			;seed1_1=$+1 
0ca0			;    ld de,6789 
0ca0			;    ld b,h 
0ca0			;    ld c,l 
0ca0			;    add hl,hl \ rl e \ rl d 
0ca0			;    add hl,hl \ rl e \ rl d 
0ca0			;    inc l 
0ca0			;    add hl,bc 
0ca0			;    ld (seed1_0),hl 
0ca0			;    ld hl,(seed1_1) 
0ca0			;    adc hl,de 
0ca0			;    ld (seed1_1),hl 
0ca0			;    ex de,hl 
0ca0			;seed2_0=$+1 
0ca0			;    ld hl,9876 
0ca0			;seed2_1=$+1 
0ca0			;    ld bc,54321 
0ca0			;    add hl,hl \ rl c \ rl b 
0ca0			;    ld (seed2_1),bc 
0ca0			;    sbc a,a 
0ca0			;    and %11000101 
0ca0			;    xor l 
0ca0			;    ld l,a 
0ca0			;    ld (seed2_0),hl 
0ca0			;    ex de,hl 
0ca0			;    add hl,bc 
0ca0			;    ret 
0ca0			; 
0ca0			 
0ca0			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0ca0			; 20 bytes, 86 cycles (excluding ret) 
0ca0			 
0ca0			; returns   hl = pseudorandom number 
0ca0			; corrupts   a 
0ca0			 
0ca0			; generates 16-bit pseudorandom numbers with a period of 65535 
0ca0			; using the xorshift method: 
0ca0			 
0ca0			; hl ^= hl << 7 
0ca0			; hl ^= hl >> 9 
0ca0			; hl ^= hl << 8 
0ca0			 
0ca0			; some alternative shift triplets which also perform well are: 
0ca0			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0ca0			 
0ca0			;  org 32768 
0ca0			 
0ca0			xrnd: 
0ca0 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0ca3 3e 00		  ld a,0 
0ca5 bd			  cp l 
0ca6 20 02		  jr nz, .xrnd1 
0ca8 2e 01		  ld l, 1 
0caa			.xrnd1: 
0caa			 
0caa 7c			  ld a,h 
0cab 1f			  rra 
0cac 7d			  ld a,l 
0cad 1f			  rra 
0cae ac			  xor h 
0caf 67			  ld h,a 
0cb0 7d			  ld a,l 
0cb1 1f			  rra 
0cb2 7c			  ld a,h 
0cb3 1f			  rra 
0cb4 ad			  xor l 
0cb5 6f			  ld l,a 
0cb6 ac			  xor h 
0cb7 67			  ld h,a 
0cb8			 
0cb8 22 d9 fa		  ld (xrandc),hl 
0cbb			 
0cbb c9			  ret 
0cbc			;  
0cbc			 
0cbc			 
0cbc			;;;; int maths 
0cbc			 
0cbc			; https://map.grauw.nl/articles/mult_div_shifts.php 
0cbc			; Divide 16-bit values (with 16-bit result) 
0cbc			; In: Divide BC by divider DE 
0cbc			; Out: BC = result, HL = rest 
0cbc			; 
0cbc			Div16: 
0cbc 21 00 00		    ld hl,0 
0cbf 78			    ld a,b 
0cc0 06 08		    ld b,8 
0cc2			Div16_Loop1: 
0cc2 17			    rla 
0cc3 ed 6a		    adc hl,hl 
0cc5 ed 52		    sbc hl,de 
0cc7 30 01		    jr nc,Div16_NoAdd1 
0cc9 19			    add hl,de 
0cca			Div16_NoAdd1: 
0cca 10 f6		    djnz Div16_Loop1 
0ccc 17			    rla 
0ccd 2f			    cpl 
0cce 47			    ld b,a 
0ccf 79			    ld a,c 
0cd0 48			    ld c,b 
0cd1 06 08		    ld b,8 
0cd3			Div16_Loop2: 
0cd3 17			    rla 
0cd4 ed 6a		    adc hl,hl 
0cd6 ed 52		    sbc hl,de 
0cd8 30 01		    jr nc,Div16_NoAdd2 
0cda 19			    add hl,de 
0cdb			Div16_NoAdd2: 
0cdb 10 f6		    djnz Div16_Loop2 
0cdd 17			    rla 
0cde 2f			    cpl 
0cdf 41			    ld b,c 
0ce0 4f			    ld c,a 
0ce1 c9			ret 
0ce2			 
0ce2			 
0ce2			;http://z80-heaven.wikidot.com/math 
0ce2			; 
0ce2			;Inputs: 
0ce2			;     DE and A are factors 
0ce2			;Outputs: 
0ce2			;     A is not changed 
0ce2			;     B is 0 
0ce2			;     C is not changed 
0ce2			;     DE is not changed 
0ce2			;     HL is the product 
0ce2			;Time: 
0ce2			;     342+6x 
0ce2			; 
0ce2			Mult16: 
0ce2			 
0ce2 06 08		     ld b,8          ;7           7 
0ce4 21 00 00		     ld hl,0         ;10         10 
0ce7 29			       add hl,hl     ;11*8       88 
0ce8 07			       rlca          ;4*8        32 
0ce9 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0ceb 19			         add hl,de   ;--         -- 
0cec 10 f9		       djnz $-5      ;13*7+8     99 
0cee c9			ret 
0cef			 
0cef			; 
0cef			; Square root of 16-bit value 
0cef			; In:  HL = value 
0cef			; Out:  D = result (rounded down) 
0cef			; 
0cef			;Sqr16: 
0cef			;    ld de,#0040 
0cef			;    ld a,l 
0cef			;    ld l,h 
0cef			;    ld h,d 
0cef			;    or a 
0cef			;    ld b,8 
0cef			;Sqr16_Loop: 
0cef			;    sbc hl,de 
0cef			;    jr nc,Sqr16_Skip 
0cef			;    add hl,de 
0cef			;Sqr16_Skip: 
0cef			;    ccf 
0cef			;    rl d 
0cef			;    add a,a 
0cef			;    adc hl,hl 
0cef			;    add a,a 
0cef			;    adc hl,hl 
0cef			;    djnz Sqr16_Loop 
0cef			;    ret 
0cef			; 
0cef			; 
0cef			; Divide 8-bit values 
0cef			; In: Divide E by divider C 
0cef			; Out: A = result, B = rest 
0cef			; 
0cef			Div8: 
0cef af			    xor a 
0cf0 06 08		    ld b,8 
0cf2			Div8_Loop: 
0cf2 cb 13		    rl e 
0cf4 17			    rla 
0cf5 91			    sub c 
0cf6 30 01		    jr nc,Div8_NoAdd 
0cf8 81			    add a,c 
0cf9			Div8_NoAdd: 
0cf9 10 f7		    djnz Div8_Loop 
0cfb 47			    ld b,a 
0cfc 7b			    ld a,e 
0cfd 17			    rla 
0cfe 2f			    cpl 
0cff c9			    ret 
