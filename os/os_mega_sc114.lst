98f3			; My forth kernel 
98f3			include "forth_kernel.asm" 
98f3			; 
98f3			; kernel to the forth OS 
98f3			 
98f3			DS_TYPE_STR: equ 1     ; string type 
98f3			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
98f3			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
98f3			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
98f3			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
98f3			 
98f3			FORTH_PARSEV1: equ 0 
98f3			FORTH_PARSEV2: equ 0 
98f3			FORTH_PARSEV3: equ 0 
98f3			FORTH_PARSEV4: equ 0 
98f3			FORTH_PARSEV5: equ 0 
98f3			FORTH_PARSEV6: equ 1 
98f3			 
98f3			;if FORTH_PARSEV5 
98f3			;	FORTH_END_BUFFER: equ 0 
98f3			;else 
98f3			FORTH_END_BUFFER: equ 127 
98f3			;endif 
98f3			 
98f3			FORTH_TRUE: equ 1 
98f3			FORTH_FALSE: equ 0 
98f3			 
98f3			if FORTH_PARSEV4 
98f3			include "forth_stackops.asm" 
98f3			endif 
98f3			 
98f3			if FORTH_PARSEV5 
98f3			include "forth_stackopsv5.asm" 
98f3			endif 
98f3			 
98f3			if FORTH_PARSEV6 
98f3			include "forth_stackopsv5.asm" 
98f3			 
98f3			; Stack operations for v5 parser on wards 
98f3			; * DATA stack 
98f3			; * LOOP stack 
98f3			; * RETURN stack 
98f3			 
98f3			 
98f3			 
98f3			FORTH_CHK_DSP_UNDER: macro 
98f3				push hl 
98f3				push de 
98f3				ld hl,(cli_data_sp) 
98f3				ld de, cli_data_stack 
98f3				call cmp16 
98f3				jp c, fault_dsp_under 
98f3				pop de 
98f3				pop hl 
98f3				endm 
98f3			 
98f3			 
98f3			FORTH_CHK_RSP_UNDER: macro 
98f3				push hl 
98f3				push de 
98f3				ld hl,(cli_ret_sp) 
98f3				ld de, cli_ret_stack 
98f3				call cmp16 
98f3				jp c, fault_rsp_under 
98f3				pop de 
98f3				pop hl 
98f3				endm 
98f3			 
98f3			FORTH_CHK_LOOP_UNDER: macro 
98f3				push hl 
98f3				push de 
98f3				ld hl,(cli_loop_sp) 
98f3				ld de, cli_loop_stack 
98f3				call cmp16 
98f3				jp c, fault_loop_under 
98f3				pop de 
98f3				pop hl 
98f3				endm 
98f3			 
98f3			FORTH_ERR_TOS_NOTSTR: macro 
98f3				; TOSO might need more for checks when used 
98f3				push af 
98f3				ld a,(hl) 
98f3				cp DS_TYPE_STR 
98f3				jp nz, type_faultn   
98f3				pop af 
98f3				endm 
98f3			 
98f3			FORTH_ERR_TOS_NOTNUM: macro 
98f3				push af 
98f3				ld a,(hl) 
98f3				cp DS_TYPE_INUM 
98f3				jp nz, type_faultn   
98f3				pop af 
98f3				endm 
98f3			 
98f3			 
98f3			; increase data stack pointer and save hl to it 
98f3				 
98f3			FORTH_DSP_NEXT: macro 
98f3				call macro_forth_dsp_next 
98f3				endm 
98f3			 
98f3			 
98f3			macro_forth_dsp_next: 
98f3				if DEBUG_FORTH_STACK_GUARD 
98f3 cd c3 de				call check_stacks 
98f6				endif 
98f6 e5				push hl 
98f7 d5				push de 
98f8 eb				ex de,hl 
98f9 2a e1 e9			ld hl,(cli_data_sp) 
98fc 23				inc hl 
98fd 23				inc hl 
98fe			 
98fe			; PARSEV5 
98fe 23				inc hl 
98ff 22 e1 e9			ld (cli_data_sp),hl 
9902 73				ld (hl), e 
9903 23				inc hl 
9904 72				ld (hl), d 
9905 d1				pop de 
9906 e1				pop hl 
9907				if DEBUG_FORTH_STACK_GUARD 
9907 cd c3 de				call check_stacks 
990a				endif 
990a c9				ret 
990b			 
990b			 
990b			; increase ret stack pointer and save hl to it 
990b				 
990b			FORTH_RSP_NEXT: macro 
990b				call macro_forth_rsp_next 
990b				endm 
990b			 
990b			macro_forth_rsp_next: 
990b				if DEBUG_FORTH_STACK_GUARD 
990b cd c3 de				call check_stacks 
990e				endif 
990e e5				push hl 
990f d5				push de 
9910 eb				ex de,hl 
9911 2a e5 e9			ld hl,(cli_ret_sp) 
9914 23				inc hl 
9915 23				inc hl 
9916 22 e5 e9			ld (cli_ret_sp),hl 
9919 73				ld (hl), e 
991a 23				inc hl 
991b 72				ld (hl), d 
991c d1				pop de 
991d e1				pop hl 
991e				if DEBUG_FORTH_STACK_GUARD 
991e cd c3 de				call check_stacks 
9921				endif 
9921 c9				ret 
9922			 
9922			; get current ret stack pointer and save to hl  
9922				 
9922			FORTH_RSP_TOS: macro 
9922				call macro_forth_rsp_tos 
9922				endm 
9922			 
9922			macro_forth_rsp_tos: 
9922				;push de 
9922 2a e5 e9			ld hl,(cli_ret_sp) 
9925 cd 5a 99			call loadhlptrtohl 
9928				;ld e, (hl) 
9928				;inc hl 
9928				;ld d, (hl) 
9928				;ex de, hl 
9928					if DEBUG_FORTH_WORDS 
9928			;			DMARK "RST" 
9928						CALLMONITOR 
9928				if BASE_CPM=1  
9928					call debug_vector  
9928				endif  
9928				if BASE_KEV=1  
9928					rst 8  
9928				endif  
9928				endm  
# End of macro CALLMONITOR
9928					endif 
9928				;pop de 
9928 c9				ret 
9929			 
9929			; pop ret stack pointer 
9929				 
9929			FORTH_RSP_POP: macro 
9929				call macro_forth_rsp_pop 
9929				endm 
9929			 
9929			 
9929			macro_forth_rsp_pop: 
9929				if DEBUG_FORTH_STACK_GUARD 
9929			;		DMARK "RPP" 
9929 cd c3 de				call check_stacks 
992c					FORTH_CHK_RSP_UNDER 
992c e5				push hl 
992d d5				push de 
992e 2a e5 e9			ld hl,(cli_ret_sp) 
9931 11 9f e9			ld de, cli_ret_stack 
9934 cd 91 8c			call cmp16 
9937 da da df			jp c, fault_rsp_under 
993a d1				pop de 
