8ee6			;------------------------------------------------------------------------------ 
8ee6			;     free                                                                    : 
8ee6			;                                                                             : 
8ee6			; Description                                                                 : 
8ee6			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8ee6			;     returned by malloc, otherwise the behaviour is undefined.               : 
8ee6			;                                                                             : 
8ee6			;     Where possible, directly adjacent free blocks will be merged together   : 
8ee6			;     into larger blocks to help ensure that the heap does not become         : 
8ee6			;     excessively fragmented.                                                 : 
8ee6			;                                                                             : 
8ee6			;     free does not clear or set any other value into the freed space, and    : 
8ee6			;     therefore its contents may be visible through subsequent malloc's. The  : 
8ee6			;     caller should clear the freed space as required.                        : 
8ee6			;                                                                             : 
8ee6			;     This implementation of free uses the stack exclusively, and is          : 
8ee6			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8ee6			;     advisable to disable interrupts before calling free, and recommended    : 
8ee6			;     to avoid the use of free inside ISRs in general.                        : 
8ee6			;                                                                             : 
8ee6			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8ee6			;                                                                             : 
8ee6			; Parameters                                                                  : 
8ee6			;     HL  Pointer to address of first byte of allocation to be freed          : 
8ee6			;                                                                             : 
8ee6			; Returns                                                                     : 
8ee6			;     Nothing                                                                 : 
8ee6			;                                                                             : 
8ee6			; Stack frame                                                                 : 
8ee6			;       |             |                                                       : 
8ee6			;       +-------------+                                                       : 
8ee6			;       |     BC      |                                                       : 
8ee6			;       +-------------+                                                       : 
8ee6			;       |     DE      |                                                       : 
8ee6			;       +-------------+                                                       : 
8ee6			;       |     IX      |                                                       : 
8ee6			;       +-------------+                                                       : 
8ee6			;       |  prev_free  |                                                       : 
8ee6			;   +2  +-------------+                                                       : 
8ee6			;       |  next_free  |                                                       : 
8ee6			;   +0  +-------------+                                                       : 
8ee6			;       |             |                                                       : 
8ee6			;                                                                             : 
8ee6			;------------------------------------------------------------------------------ 
8ee6			free: 
8ee6 c5			      push  BC 
8ee7 d5			      push  DE 
8ee8 dd e5		      push  IX 
