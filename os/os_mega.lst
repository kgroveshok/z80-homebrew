02da				include "firmware_seeprom.asm"  
02da			; 
02da			; persisent storage interface via microchip serial eeprom 
02da			 
02da			; port a pio 2 
02da			; pa 7 - si 
02da			; pa 6 - sclk  
02da			; pa 5 - so 
02da			; pa 4 - cs 
02da			; pa 3 - cs 
02da			; pa 2 - cs 
02da			; pa 1 - cs 
02da			; pa 0 - cs 
02da			; 
02da			; TODO get block 
02da			; TODO save block 
02da			; TODO load file 
02da			; TODO save file 
02da			; TODO get dir  
02da			 
02da			;  
02da			storage_adata: equ Device_C    ; device c port a - onboard storage 
02da			storage_actl: equ Device_C+2     ; device c port a 
02da			storage_bdata: equ Device_C+1    ; device c port b - ext storage cart 
02da			storage_bctl: equ Device_C+3     ; device c port b 
02da			 
02da			 
02da			; TODO move these to hardware driver file 
02da			 
02da			;STORE_BLOCK_PHY:   equ 64    ; physical block size on storage   64byte on 256k eeprom 
02da			;STORE_DEVICE_MAXBLOCKS:  equ  512 ; how many blocks are there on this storage device 
02da			; storage bank file system format 
02da			; 
02da			; first page of bank: 
02da			; 	addr 0 - status check 
02da			;       addr 1 - write protect flag 
02da			;       addr 2 - zero if all data is held on this device. >0 - next device number (not used right now) 
02da			;       addr 3 - last file id (to save on scanning for spare file id). or could have bit mask of file ids in use????  
02da			;         TODO see if scanning whole of for available next file id is fast enough 
02da			;	addr 4 > zero term string of bank label 
02da			; 
02da			;        
02da			;  
02da			; first page of any file: 
02da			;      byte 0 - file id  
02da			;      byte 1-17 - fixed file name  
02da			;      byte 18-end of page - extra meta data tba (date? description? keywords?) 
02da			; 
02da			; other pages of any file: 
02da			;      byte 0 - file id 
02da			;      byte 1> - file data 
02da			; 
02da			; TODO depending on how long it takes to load a file in if scanning the whole bank for the file id, could speed it up by having last file page flag??? high bit? that would max 127 files 
02da			;  
02da			; TODO need a bank format which places a 0 in each of the first byte of every page and updates the meta in page 0 
02da			 
02da			 
02da			;storage_so_bit: 5 
02da			;storage_si_bit: 7 
02da			;storage_sclk_bit: 6 
02da			  
02da			 
02da			; init storage pio 
02da			 
02da			storage_init: 
02da			 
02da			 
02da					; set default SPI clk pulse time as disabled 
02da			 
02da 3e 00				ld a, 0 
02dc 32 8f f9				ld (spi_clktime), a 
02df			 
02df					; init hardware 
02df			 
02df 3e cf		            LD   A, 11001111b 
02e1 d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
02e3 3e 00		            LD   A, 00000000b 
02e5 cb f7			set SPI_DO,a 
02e7			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
02e7 d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
02e9			 
02e9 3e cf		            LD   A, 11001111b 
02eb d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
02ed 3e 00		            LD   A, 00000000b 
02ef d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
02f1			 
02f1				; set all external spi devices off  
02f1 3e ff			ld a, 255 
02f3 32 8b f9			ld (spi_device), a 
02f6 32 8e f9			ld (spi_cartdev), a 
02f9			 
02f9					; ensure the spi bus is in a default stable state 
02f9 cd 43 01				call se_stable_spi 
02fc			 
02fc			; TODO scan spi bus and gather which storage banks are present 
02fc			 
02fc			; populate store_bank_active  
02fc			; for each ce line activate and attempt to write first byte of bank and read back 
02fc			; if zero is returned then bank is empty 
02fc			;   
02fc			; 
02fc			 
02fc					; init file extent cache to save on slow reads 
02fc			 
02fc			;	ld hl, store_filecache 
02fc			;	ld de, 0 
02fc			;	ld hl,(de)	 
02fc			 
02fc			 
02fc c9			    ret 
02fd			 
02fd			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
02fd			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
02fd			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
02fd			 
02fd			; INSTRUCTION SET 
02fd			; READ 0000 0011 Read data from memory array beginning at selected address 
02fd			; WRITE 0000 0010 Write data to memory array beginning at selected address 
02fd			; WREN 0000 0110 Set the write enable latch (enable write operations) 
02fd			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
02fd			; RDSR 0000 0101 Read STATUS register 
02fd			; WRSR 0000 0001 Write STATUS register 
