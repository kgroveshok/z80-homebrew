8c27 30					DEFB	30h	; 0 
8c28 31					DEFB	31h	; 1 
8c29 32					DEFB	32h	; 2 
8c2a 33					DEFB	33h	; 3 
8c2b 34					DEFB	34h	; 4 
8c2c 35					DEFB	35h	; 5 
8c2d 36					DEFB	36h	; 6 
8c2e 37					DEFB	37h	; 7 
8c2f 38					DEFB	38h	; 8 
8c30 39					DEFB	39h	; 9 
8c31 41					DEFB	41h	; A 
8c32 42					DEFB	42h	; B 
8c33 43					DEFB	43h	; C 
8c34 44					DEFB	44h	; D 
8c35 45					DEFB	45h	; E 
8c36 46					DEFB	46h	; F 
8c37			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c37			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
8c37			;;    subtract $30, if result > 9 then subtract $7 more 
8c37			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c37			atohex: 
8c37 d6 30				SUB $30 
8c39 fe 0a				CP 10 
8c3b f8					RET M		; If result negative it was 0-9 so we're done 
8c3c d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
8c3e c9					RET		 
