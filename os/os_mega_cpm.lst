0fa1			if MALLOC_2 
0fa1			; Z80 Malloc and Free Functions 
0fa1			 
0fa1			; Malloc Function: 
0fa1			; Input: 
0fa1			;   HL: Size of block to allocate 
0fa1			; Output: 
0fa1			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
0fa1			 
0fa1			malloc: 
0fa1				 
0fa1			if DEBUG_FORTH_MALLOC_HIGH 
0fa1			call malloc_guard_entry 
0fa1			endif 
0fa1			 
0fa1			 
0fa1			 
0fa1			 
0fa1					if DEBUG_FORTH_MALLOC 
0fa1						DMARK "mal" 
0fa1						CALLMONITOR 
0fa1					endif 
0fa1			    push af            ; Save AF register 
0fa1			    ld a, l            ; Load low byte of size into A 
0fa1			    or h               ; Check if size is zero 
0fa1			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
0fa1			 
0fa1			    ; Allocate memory 
0fa1			    ld hl, (heap_start) ; Load start of heap into HL 
0fa1					if DEBUG_FORTH_MALLOC 
0fa1						DMARK "ma1" 
0fa1						CALLMONITOR 
0fa1					endif 
0fa1			    call malloc_internal ; Call internal malloc function 
0fa1			    pop af             ; Restore AF register 
0fa1			if DEBUG_FORTH_MALLOC_HIGH 
0fa1			call malloc_guard_exit 
0fa1			call malloc_guard_zerolen 
0fa1			endif 
0fa1			    ret                ; Return 
0fa1			 
0fa1			; Free Function: 
0fa1			; Input: 
0fa1			;   HL: Pointer to memory block to free 
0fa1			; Output: 
0fa1			;   None 
0fa1			 
0fa1			free: 
0fa1			    push af            ; Save AF register 
0fa1			    ld a, l            ; Load low byte of pointer into A 
0fa1			    or h               ; Check if pointer is NULL 
0fa1			    jp z, free_exit    ; If pointer is NULL, exit 
0fa1			 
0fa1			    ; Free memory 
0fa1			    ld hl, (heap_start) ; Load start of heap into HL 
0fa1			    call free_internal  ; Call internal free function 
0fa1			    pop af             ; Restore AF register 
0fa1			    ret                ; Return 
0fa1			 
0fa1			; Internal Malloc Function: 
0fa1			; Input: 
0fa1			;   HL: Size of block to allocate 
0fa1			; Output: 
0fa1			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
0fa1			 
0fa1			malloc_internal: 
0fa1			    ld bc, 2           ; Number of bytes to allocate for management overhead 
0fa1			    add hl, bc         ; Add management overhead to requested size 
0fa1			    ex de, hl          ; Save total size in DE, and keep it in HL 
0fa1					if DEBUG_FORTH_MALLOC 
0fa1						DMARK "ma2" 
0fa1						CALLMONITOR 
0fa1					endif 
0fa1			 
0fa1			    ; Search for free memory block 
0fa1			    ld de, (heap_end)  ; Load end of heap into DE 
0fa1			    ld bc, 0           ; Initialize counter 
0fa1			 
0fa1					if DEBUG_FORTH_MALLOC 
0fa1						DMARK "ma2" 
0fa1						CALLMONITOR 
0fa1					endif 
0fa1			malloc_search_loop: 
0fa1			    ; Check if current block is free 
0fa1			    ld a, (hl)         ; Load current block's status (free or used) 
0fa1			;    cp 0               ; Compare with zero (free) 
0fa1				or a 
0fa1			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
0fa1			 
0fa1			    ; Check if current block is large enough 
0fa1			    ld a, (hl+1)       ; Load high byte of block size 
0fa1			    cp l               ; Compare with low byte of requested size 
0fa1			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
0fa1			 
0fa1			    ld a, (hl+2)       ; Load low byte of block size 
0fa1			    cp h               ; Compare with high byte of requested size 
0fa1			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
0fa1			 
0fa1			    ; Mark block as used 
0fa1			    ld (hl), 0xFF      ; Set status byte to indicate used block 
0fa1			 
0fa1			    ; Calculate remaining space in block 
0fa1			    ld bc, 0           ; Clear BC 
0fa1			    add hl, bc         ; Increment HL to point to start of data block 
0fa1			    add hl, de         ; HL = HL + DE (total size) 
0fa1			    ld bc, 1           ; Number of bytes to allocate for management overhead 
0fa1			    add hl, bc         ; Add management overhead to start of data block 
0fa1			 
0fa1			    ; Save pointer to allocated block in HL 
0fa1			if DEBUG_FORTH_MALLOC_HIGH 
0fa1						DMARK "ma5" 
0fa1			call malloc_guard_exit 
0fa1			call malloc_guard_zerolen 
0fa1			endif 
0fa1			    ret 
0fa1			 
0fa1			malloc_skip_block_check: 
0fa1			    ; Move to the next block 
0fa1			    ld bc, 3           ; Size of management overhead 
0fa1			    add hl, bc         ; Move to the next block 
0fa1			    inc de             ; Increment counter 
0fa1			 
0fa1			    ; Check if we have reached the end of heap 
0fa1			    ld a, e            ; Load low byte of heap end address 
0fa1			    cp (hl)            ; Compare with low byte of current address 
0fa1			    jr nz, malloc_search_loop  ; If not equal, continue searching 
0fa1			    ld a, d            ; Load high byte of heap end address 
0fa1			;    cp 0               ; Check if it's zero (end of memory) 
0fa1				or a 
0fa1			    jr nz, malloc_search_loop  ; If not zero, continue searching 
0fa1			 
0fa1			    ; If we reached here, allocation failed 
0fa1			    xor a              ; Set result to NULL 
0fa1			if DEBUG_FORTH_MALLOC_HIGH 
0fa1						DMARK "ma6" 
0fa1			call malloc_guard_exit 
0fa1			call malloc_guard_zerolen 
0fa1			endif 
0fa1			    ret 
0fa1			malloc_exit: 
0fa1			if DEBUG_FORTH_MALLOC_HIGH 
0fa1						DMARK "ma7" 
0fa1			call malloc_guard_exit 
0fa1			call malloc_guard_zerolen 
0fa1			endif 
0fa1			    ret 
0fa1			 
0fa1			; Internal Free Function: 
0fa1			; Input: 
0fa1			;   HL: Pointer to memory block to free 
0fa1			; Output: 
0fa1			;   None 
0fa1			 
0fa1			free_internal: 
0fa1			    ld de, (heap_start) ; Load start of heap into DE 
0fa1			    ld bc, 0            ; Initialize counter 
0fa1			 
0fa1			free_search_loop: 
0fa1			    ; Check if current block contains the pointer 
0fa1			    ld a, l             ; Load low byte of pointer 
0fa1			    cp (hl+1)           ; Compare with high byte of current block's address 
0fa1			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
0fa1			    ld a, h             ; Load high byte of pointer 
0fa1			    cp (hl+2)           ; Compare with low byte of current block's address 
0fa1			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
0fa1			 
0fa1			    ; Mark block as free 
0fa1			    ld (hl), 0          ; Set status byte to indicate free block 
0fa1			    ret                 ; Return 
0fa1			 
0fa1			free_skip_block_check: 
0fa1			    ; Move to the next block 
0fa1			    ld bc, 3            ; Size of management overhead 
0fa1			    add hl, bc          ; Move to the next block 
0fa1			    inc de              ; Increment counter 
0fa1			 
0fa1			    ; Check if we have reached the end of heap 
0fa1			    ld a, e             ; Load low byte of heap end address 
0fa1			    cp (hl)             ; Compare with low byte of current address 
0fa1			    jr nz, free_search_loop  ; If not equal, continue searching 
0fa1			    ld a, d             ; Load high byte of heap end address 
0fa1			;    cp 0                ; Check if it's zero (end of memory) 
0fa1				or a 
0fa1			    jr nz, free_search_loop  ; If not zero, continue searching 
0fa1			 
0fa1			    ; If we reached here, pointer is not found in heap 
0fa1			    ret 
0fa1			 
0fa1			free_exit: 
0fa1			    ret                 ; Return 
0fa1			 
