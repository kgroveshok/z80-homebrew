8dfd			if MALLOC_1 
8dfd			 
8dfd			 
8dfd			 
8dfd			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
8dfd			 
8dfd			;moved to firmware.asm 
8dfd			;heap_start        .equ  0x9000      ; Starting address of heap 
8dfd			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8dfd			 
8dfd			;      .org 0 
8dfd			;      jp    main 
8dfd			 
8dfd			 
8dfd			;      .org  0x100 
8dfd			;main: 
8dfd			;      ld    HL, 0x8100 
8dfd			;      ld    SP, HL 
8dfd			; 
8dfd			;      call  heap_init 
8dfd			; 
8dfd			;      ; Make some allocations 
8dfd			;      ld    HL, 12 
8dfd			;      call  malloc            ; Allocates 0x9004 
8dfd			; 
8dfd			;      ld    HL, 12 
8dfd			;      call  malloc            ; Allocates 0x9014 
8dfd			; 
8dfd			;      ld    HL, 12 
8dfd			;      call  malloc            ; Allocates 0x9024 
8dfd			; 
8dfd			;      ; Free some allocations 
8dfd			;      ld    HL, 0x9014 
8dfd			;      call  free 
8dfd			; 
8dfd			;      ld    HL, 0x9004 
8dfd			;      call  free 
8dfd			; 
8dfd			;      ld    HL, 0x9024 
8dfd			;      call  free 
8dfd			; 
8dfd			; 
8dfd			;      halt 
8dfd			 
8dfd			 
8dfd			;------------------------------------------------------------------------------ 
8dfd			;     heap_init                                                               : 
8dfd			;                                                                             : 
8dfd			; Description                                                                 : 
8dfd			;     Initialise the heap and make it ready for malloc and free operations.   : 
8dfd			;                                                                             : 
8dfd			;     The heap is maintained as a linked list, starting with an initial       : 
8dfd			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8dfd			;     the first free block in the heap. Each block then points to the next    : 
8dfd			;     free block within the heap, and the free list ends at the first block   : 
8dfd			;     with a null pointer to the next free block.                             : 
8dfd			;                                                                             : 
8dfd			; Parameters                                                                  : 
8dfd			;     Inputs are compile-time only. Two defines which specify the starting    : 
8dfd			;     address of the heap and its size are required, along with a memory      : 
8dfd			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8dfd			;     principally stores a pointer to the first free block in the heap.       : 
8dfd			;                                                                             : 
8dfd			; Returns                                                                     : 
8dfd			;     Nothing                                                                 : 
8dfd			;------------------------------------------------------------------------------ 
8dfd			heap_init: 
8dfd e5			      push  HL 
8dfe			 
8dfe			      ; Initialise free list struct 
8dfe 21 f5 d5		      ld    HL, heap_start 
8e01 22 f0 d5		      ld    (free_list), HL 
8e04 21 00 00		      ld    HL, 0 
8e07 22 f2 d5		      ld    (free_list+2), HL 
8e0a			 
8e0a			      ; Insert first free block at bottom of heap, consumes entire heap 
8e0a 21 74 e2		      ld    HL, heap_start+heap_size-4 
8e0d 22 f5 d5		      ld    (heap_start), HL        ; Next block (end of free list) 
8e10 21 7f 0c		      ld    HL, heap_size-4 
8e13 22 f7 d5		      ld    (heap_start+2), HL      ; Block size 
8e16			 
8e16			      ; Insert end of free list block at top of heap - two null words will 
8e16			      ; terminate the free list 
8e16 21 00 00		      ld    HL, 0 
8e19 22 76 e2		      ld    (heap_start+heap_size-2), HL 
8e1c 22 74 e2		      ld    (heap_start+heap_size-4), HL 
8e1f			 
8e1f e1			      pop   HL 
8e20			 
8e20 c9			      ret 
8e21			 
8e21			 
8e21			;------------------------------------------------------------------------------ 
8e21			;     malloc                                                                  : 
8e21			;                                                                             : 
8e21			; Description                                                                 : 
8e21			;     Allocates the wanted space from the heap and returns the address of the : 
8e21			;     first useable byte of the allocation.                                   : 
8e21			;                                                                             : 
8e21			;     Allocations can happen in one of two ways:                              : 
8e21			;                                                                             : 
8e21			;     1. A free block may be found which is the exact size wanted. In this    : 
8e21			;        case the block is removed from the free list and retuedn to the      : 
8e21			;        caller.                                                              : 
8e21			;     2. A free block may be found which is larger than the size wanted. In   : 
8e21			;        this case, the larger block is split into two. The first portion of  : 
8e21			;        this block will become the requested space by the malloc call and    : 
8e21			;        is returned to the caller. The second portion becomes a new free     : 
8e21			;        block, and the free list is adjusted to maintain continuity via this : 
8e21			;        newly created block.                                                 : 
8e21			;                                                                             : 
8e21			;     malloc does not set any initial value in the allocated space, the       : 
8e21			;     caller is required to do this as required.                              : 
8e21			;                                                                             : 
8e21			;     This implementation of malloc uses the stack exclusively, and is        : 
8e21			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8e21			;     advisable to disable interrupts before calling malloc, and recommended  : 
8e21			;     to avoid the use of malloc inside ISRs in general.                      : 
