8df8			if MALLOC_2 
8df8			; Z80 Malloc and Free Functions 
8df8			 
8df8			; Malloc Function: 
8df8			; Input: 
8df8			;   HL: Size of block to allocate 
8df8			; Output: 
8df8			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8df8			 
8df8			malloc: 
8df8				 
8df8			if DEBUG_FORTH_MALLOC_HIGH 
8df8			call malloc_guard_entry 
8df8			endif 
8df8			 
8df8			 
8df8			 
8df8			 
8df8					if DEBUG_FORTH_MALLOC 
8df8						DMARK "mal" 
8df8						CALLMONITOR 
8df8					endif 
8df8			    push af            ; Save AF register 
8df8			    ld a, l            ; Load low byte of size into A 
8df8			    or h               ; Check if size is zero 
8df8			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
8df8			 
8df8			    ; Allocate memory 
8df8			    ld hl, (heap_start) ; Load start of heap into HL 
8df8					if DEBUG_FORTH_MALLOC 
8df8						DMARK "ma1" 
8df8						CALLMONITOR 
8df8					endif 
8df8			    call malloc_internal ; Call internal malloc function 
8df8			    pop af             ; Restore AF register 
8df8			if DEBUG_FORTH_MALLOC_HIGH 
8df8			call malloc_guard_exit 
8df8			call malloc_guard_zerolen 
8df8			endif 
8df8			    ret                ; Return 
8df8			 
8df8			; Free Function: 
8df8			; Input: 
8df8			;   HL: Pointer to memory block to free 
8df8			; Output: 
8df8			;   None 
8df8			 
8df8			free: 
8df8			    push af            ; Save AF register 
8df8			    ld a, l            ; Load low byte of pointer into A 
8df8			    or h               ; Check if pointer is NULL 
8df8			    jp z, free_exit    ; If pointer is NULL, exit 
8df8			 
8df8			    ; Free memory 
8df8			    ld hl, (heap_start) ; Load start of heap into HL 
8df8			    call free_internal  ; Call internal free function 
8df8			    pop af             ; Restore AF register 
8df8			    ret                ; Return 
8df8			 
8df8			; Internal Malloc Function: 
8df8			; Input: 
8df8			;   HL: Size of block to allocate 
8df8			; Output: 
8df8			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8df8			 
8df8			malloc_internal: 
8df8			    ld bc, 2           ; Number of bytes to allocate for management overhead 
8df8			    add hl, bc         ; Add management overhead to requested size 
8df8			    ex de, hl          ; Save total size in DE, and keep it in HL 
8df8					if DEBUG_FORTH_MALLOC 
8df8						DMARK "ma2" 
8df8						CALLMONITOR 
8df8					endif 
8df8			 
8df8			    ; Search for free memory block 
8df8			    ld de, (heap_end)  ; Load end of heap into DE 
8df8			    ld bc, 0           ; Initialize counter 
8df8			 
8df8					if DEBUG_FORTH_MALLOC 
8df8						DMARK "ma2" 
8df8						CALLMONITOR 
8df8					endif 
8df8			malloc_search_loop: 
8df8			    ; Check if current block is free 
8df8			    ld a, (hl)         ; Load current block's status (free or used) 
8df8			;    cp 0               ; Compare with zero (free) 
8df8				or a 
8df8			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
8df8			 
8df8			    ; Check if current block is large enough 
8df8			    ld a, (hl+1)       ; Load high byte of block size 
8df8			    cp l               ; Compare with low byte of requested size 
8df8			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
8df8			 
8df8			    ld a, (hl+2)       ; Load low byte of block size 
8df8			    cp h               ; Compare with high byte of requested size 
8df8			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
8df8			 
8df8			    ; Mark block as used 
8df8			    ld (hl), 0xFF      ; Set status byte to indicate used block 
8df8			 
8df8			    ; Calculate remaining space in block 
8df8			    ld bc, 0           ; Clear BC 
8df8			    add hl, bc         ; Increment HL to point to start of data block 
8df8			    add hl, de         ; HL = HL + DE (total size) 
8df8			    ld bc, 1           ; Number of bytes to allocate for management overhead 
8df8			    add hl, bc         ; Add management overhead to start of data block 
8df8			 
8df8			    ; Save pointer to allocated block in HL 
8df8			if DEBUG_FORTH_MALLOC_HIGH 
8df8						DMARK "ma5" 
8df8			call malloc_guard_exit 
8df8			call malloc_guard_zerolen 
8df8			endif 
8df8			    ret 
8df8			 
8df8			malloc_skip_block_check: 
8df8			    ; Move to the next block 
8df8			    ld bc, 3           ; Size of management overhead 
8df8			    add hl, bc         ; Move to the next block 
8df8			    inc de             ; Increment counter 
8df8			 
8df8			    ; Check if we have reached the end of heap 
8df8			    ld a, e            ; Load low byte of heap end address 
8df8			    cp (hl)            ; Compare with low byte of current address 
8df8			    jr nz, malloc_search_loop  ; If not equal, continue searching 
8df8			    ld a, d            ; Load high byte of heap end address 
8df8			;    cp 0               ; Check if it's zero (end of memory) 
8df8				or a 
8df8			    jr nz, malloc_search_loop  ; If not zero, continue searching 
8df8			 
8df8			    ; If we reached here, allocation failed 
8df8			    xor a              ; Set result to NULL 
8df8			if DEBUG_FORTH_MALLOC_HIGH 
8df8						DMARK "ma6" 
8df8			call malloc_guard_exit 
8df8			call malloc_guard_zerolen 
8df8			endif 
8df8			    ret 
8df8			malloc_exit: 
8df8			if DEBUG_FORTH_MALLOC_HIGH 
8df8						DMARK "ma7" 
8df8			call malloc_guard_exit 
8df8			call malloc_guard_zerolen 
8df8			endif 
8df8			    ret 
8df8			 
8df8			; Internal Free Function: 
8df8			; Input: 
8df8			;   HL: Pointer to memory block to free 
8df8			; Output: 
8df8			;   None 
8df8			 
8df8			free_internal: 
8df8			    ld de, (heap_start) ; Load start of heap into DE 
8df8			    ld bc, 0            ; Initialize counter 
8df8			 
8df8			free_search_loop: 
8df8			    ; Check if current block contains the pointer 
8df8			    ld a, l             ; Load low byte of pointer 
8df8			    cp (hl+1)           ; Compare with high byte of current block's address 
8df8			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8df8			    ld a, h             ; Load high byte of pointer 
8df8			    cp (hl+2)           ; Compare with low byte of current block's address 
8df8			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8df8			 
8df8			    ; Mark block as free 
8df8			    ld (hl), 0          ; Set status byte to indicate free block 
8df8			    ret                 ; Return 
8df8			 
8df8			free_skip_block_check: 
8df8			    ; Move to the next block 
8df8			    ld bc, 3            ; Size of management overhead 
8df8			    add hl, bc          ; Move to the next block 
8df8			    inc de              ; Increment counter 
8df8			 
8df8			    ; Check if we have reached the end of heap 
8df8			    ld a, e             ; Load low byte of heap end address 
8df8			    cp (hl)             ; Compare with low byte of current address 
8df8			    jr nz, free_search_loop  ; If not equal, continue searching 
8df8			    ld a, d             ; Load high byte of heap end address 
8df8			;    cp 0                ; Check if it's zero (end of memory) 
8df8				or a 
8df8			    jr nz, free_search_loop  ; If not zero, continue searching 
8df8			 
8df8			    ; If we reached here, pointer is not found in heap 
8df8			    ret 
8df8			 
8df8			free_exit: 
8df8			    ret                 ; Return 
8df8			 
8df8			; Define heap start and end addresses 
8df8			;heap_start:    .dw 0xC000   ; Start of heap 
8df8			;heap_end:      .dw 0xE000   ; End of heap 
8df8			 
8df8			endif 
