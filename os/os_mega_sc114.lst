95e5			include "firmware_595shiftreg.asm"  
95e5			; common code for handling a 595 shift reg out on whatever output port 
95e5			 
95e5			; port in c 
95e5			; byte in a 
95e5			 
95e5			 
95e5			shift_bit_data: equ 0 
95e5			shift_bit_clk: equ 1 
95e5			shift_bit_latch: equ 2 
95e5			 
95e5			 
95e5			; shift out a byte to the sound chip 
95e5			 
95e5			; A contains byte to send 
95e5			 
95e5			shift_byte: 
95e5			 
95e5 06 08			ld b, 8   ; 8 bits to shift 
95e7			 
95e7 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
95e9			 
95e9				; set data bit state 
95e9			 
95e9 cb 7f			bit 7, a 
95eb				; high bit is set 
95eb 28 02			jr z, .nb2 
95ed cb c2			set shift_bit_data, d 
95ef			 
95ef				; set latches state  
95ef cb ca		.nb2:	set shift_bit_clk, d 
95f1 cb 92			res shift_bit_latch, d    ; latch is inverted 
95f3 ed 51			out (c), d 
95f5				 
95f5				; clock the bit out 
95f5 cb 8a			res shift_bit_clk, d 
95f7 ed 51			out (c), d 
95f9			 
95f9				; shift a left one bit and repeat 
95f9 17				rla 
95fa			 
95fa 10 eb			djnz .nb1 
95fc			 
95fc				; latch 
95fc cb d2			set shift_bit_latch, d 
95fe ed 51			out (c), d 
9600					 
9600			 
9600				; set  
9600 c9				ret 
# End of file firmware_595shiftreg.asm
