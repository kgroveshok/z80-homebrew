2109 22 05 f9			ld (cli_data_sp),hl 
210c 73				ld (hl), e 
210d 23				inc hl 
210e 72				ld (hl), d 
210f d1				pop de 
2110 e1				pop hl 
2111				if DEBUG_FORTH_STACK_GUARD 
2111 cd 7f 65				call check_stacks 
2114				endif 
2114 c9				ret 
