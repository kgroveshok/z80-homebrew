8feb			config_fdir: 
8feb				; using the scratch dir go through and release the memory allocated for each string 
8feb				 
8feb				ld hl, scratch 
8feb			.cfdir:	ld e,(hl) 
8feb				inc hl 
8feb				ld d,(hl) 
8feb				inc hl 
8feb			 
8feb				ex de, hl 
8feb				call ishlzero 
8feb				ret z     ; return on null pointer 
8feb				call free 
8feb				ex de, hl 
8feb				jr .cfdir 
8feb			 
8feb			 
8feb				ret 
8feb			 
8feb			 
8feb			config_dir: 
8feb			 
8feb				; for the config menus that need to build a directory of storage call this routine 
8feb				; it will construct a menu in scratch to pass to menu 
8feb			 
8feb				; open storage device 
8feb			 
8feb				; execute DIR to build a list of files and their ids into scratch in menu format 
8feb				; once the menu has finished then will need to call config_fdir to release the strings 
8feb				 
8feb				; c = number items 
8feb			 
8feb				 
8feb				call storage_get_block_0 
8feb			 
8feb				ld hl, store_page     ; get current id count 
8feb				ld b, (hl) 
8feb				ld c, 0    ; count of files   
8feb			 
8feb			 
8feb				ld hl, scratch 
8feb				ld (store_tmp2), hl    ; location to poke strings 
8feb			 
8feb				; check for empty drive 
8feb			 
8feb				ld a, 0 
8feb				cp b 
8feb				jp z, .dirdone 
8feb			 
8feb				 
8feb					if DEBUG_FORTH_WORDS 
8feb						DMARK "Cdc" 
8feb						CALLMONITOR 
8feb					endif 
8feb			 
8feb			 
8feb			.diritem:	 
8feb				push bc 
8feb				; for each of the current ids do a search for them and if found push to stack 
8feb			 
8feb					ld hl, STORE_BLOCK_PHY 
8feb					ld d, 0		 ; look for extent 0 of block id as this contains file name 
8feb					ld e,b 
8feb			 
8feb					call storage_findnextid 
8feb			 
8feb			 
8feb					; if found hl will be non zero 
8feb			 
8feb					call ishlzero 
8feb					jr z, .dirnotfound 
8feb			 
8feb					; increase count 
8feb			 
8feb					pop bc	 
8feb					inc c 
8feb					push bc 
8feb					 
8feb			 
8feb					; get file header and push the file name 
8feb			 
8feb					ld de, store_page 
8feb					call storage_read_block 
8feb			 
8feb					; push file id to stack 
8feb				 
8feb					ld a, (store_page) 
8feb					ld h, 0 
8feb					ld l, a 
8feb			 
8feb					;call forth_push_numhl 
8feb					; TODO store id 
8feb			 
8feb					push hl 
8feb			 
8feb					; push extent count to stack  
8feb				 
8feb					ld hl, store_page+3 
8feb			 
8feb					; get file name length 
8feb			 
8feb					call strlenz   
8feb			 
8feb					inc hl   ; cover zero term 
8feb					inc hl  ; stick the id at the end of the area 
8feb			 
8feb					push hl 
8feb					pop bc    ; move length to bc 
8feb			 
8feb					call malloc 
8feb			 
8feb					; TODO save malloc area to scratch 
8feb			 
8feb					ex de, hl 
8feb					ld hl, (store_tmp2) 
8feb					ld (hl), e 
8feb					inc hl 
8feb					ld (hl), d 
8feb					inc hl 
8feb					ld (store_tmp2), hl 
8feb			 
8feb					 
8feb			 
8feb					;pop hl   ; get source 
8feb			;		ex de, hl    ; swap aronund	 
8feb			 
8feb					ld hl, store_page+3 
8feb					if DEBUG_FORTH_WORDS 
8feb						DMARK "CFd" 
8feb						CALLMONITOR 
8feb					endif 
8feb					ldir 
8feb			 
8feb					; de is past string, move back one and store id 
8feb					 
8feb					dec de 
8feb			 
8feb					; store file id 
8feb			 
8feb					pop hl 
8feb					ex de,hl 
8feb					ld (hl), e 
8feb			 
8feb					if DEBUG_FORTH_WORDS 
8feb						DMARK "Cdi" 
8feb						CALLMONITOR 
8feb					endif 
8feb					 
8feb			.dirnotfound: 
8feb					pop bc     
8feb					djnz .diritem 
8feb				 
8feb			.dirdone:	 
8feb			 
8feb			;		ld a, 0 
8feb					ld hl, (store_tmp2) 
8feb					ld (hl), 0 
8feb					inc hl 
8feb					ld (hl), 0 
8feb					inc hl 
8feb					; push a count of the dir items found 
8feb			 
8feb			;		ld h, 0 
8feb			;		ld l, c 
8feb			 
8feb				ret 
8feb			 
8feb			endif 
