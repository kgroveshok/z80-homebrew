20bf			; forth parser 
20bf			 
20bf			; My forth kernel 
20bf			include "forth_kernel.asm" 
20bf			; 
20bf			; kernel to the forth OS 
20bf			 
20bf			DS_TYPE_STR: equ 1     ; string type 
20bf			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
20bf			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
20bf			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
20bf			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
20bf			 
20bf			FORTH_PARSEV1: equ 0 
20bf			FORTH_PARSEV2: equ 0 
20bf			FORTH_PARSEV3: equ 0 
20bf			FORTH_PARSEV4: equ 0 
20bf			FORTH_PARSEV5: equ 0 
20bf			FORTH_PARSEV6: equ 1 
20bf			 
20bf			;if FORTH_PARSEV5 
20bf			;	FORTH_END_BUFFER: equ 0 
20bf			;else 
20bf			FORTH_END_BUFFER: equ 127 
20bf			;endif 
20bf			 
20bf			FORTH_TRUE: equ 1 
20bf			FORTH_FALSE: equ 0 
20bf			 
20bf			if FORTH_PARSEV4 
20bf			include "forth_stackops.asm" 
20bf			endif 
20bf			 
20bf			if FORTH_PARSEV5 
20bf			include "forth_stackopsv5.asm" 
20bf			endif 
20bf			 
20bf			if FORTH_PARSEV6 
20bf			include "forth_stackopsv5.asm" 
20bf			 
20bf			; Stack operations for v5 parser on wards 
20bf			; * DATA stack 
20bf			; * LOOP stack 
20bf			; * RETURN stack 
20bf			 
20bf			 
20bf			 
20bf			FORTH_CHK_DSP_UNDER: macro 
20bf				push hl 
20bf				push de 
20bf				ld hl,(cli_data_sp) 
20bf				ld de, cli_data_stack 
20bf				call cmp16 
20bf				jp c, fault_dsp_under 
20bf				pop de 
20bf				pop hl 
20bf				endm 
20bf			 
20bf			 
20bf			FORTH_CHK_RSP_UNDER: macro 
20bf				push hl 
20bf				push de 
20bf				ld hl,(cli_ret_sp) 
20bf				ld de, cli_ret_stack 
20bf				call cmp16 
20bf				jp c, fault_rsp_under 
20bf				pop de 
20bf				pop hl 
20bf				endm 
20bf			 
20bf			FORTH_CHK_LOOP_UNDER: macro 
20bf				push hl 
20bf				push de 
20bf				ld hl,(cli_loop_sp) 
20bf				ld de, cli_loop_stack 
20bf				call cmp16 
20bf				jp c, fault_loop_under 
20bf				pop de 
20bf				pop hl 
20bf				endm 
20bf			 
20bf			FORTH_ERR_TOS_NOTSTR: macro 
20bf				; TOSO might need more for checks when used 
20bf				push af 
20bf				ld a,(hl) 
20bf				cp DS_TYPE_STR 
20bf				jp nz, type_faultn   
20bf				pop af 
20bf				endm 
20bf			 
20bf			FORTH_ERR_TOS_NOTNUM: macro 
20bf				push af 
20bf				ld a,(hl) 
20bf				cp DS_TYPE_INUM 
20bf				jp nz, type_faultn   
20bf				pop af 
20bf				endm 
20bf			 
20bf			 
20bf			; increase data stack pointer and save hl to it 
20bf				 
20bf			FORTH_DSP_NEXT: macro 
20bf				call macro_forth_dsp_next 
20bf				endm 
20bf			 
20bf			 
