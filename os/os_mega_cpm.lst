4296				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
4296			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
4296			 
4296					call spi_ce_low 
4296			    NEXTW 
4296			 
4296			.SPICEH: 
