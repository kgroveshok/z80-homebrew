0d45			; 
0d45			; Multiply 8-bit value with a 16-bit value (right rotating) 
0d45			; In: Multiply A with DE 
0d45			;      Put lowest value in A for most efficient calculation 
0d45			; Out: HL = result 
0d45			; 
0d45			Mult12R: 
0d45 21 00 00		    ld hl,0 
0d48			Mult12R_Loop: 
0d48 cb 3f		    srl a 
0d4a 30 01		    jr nc,Mult12R_NoAdd 
0d4c 19			    add hl,de 
