1368			;	call tape_gap 
1368			 
1368 cd 87 0a			call active 
136b eb				ex de, hl 
136c 3e 00			ld a, 0 
136e cd 41 0b			call  str_at_display 
1371 cd 51 0b			call update_display 
1374			 
1374 e1				pop hl 
1375 7e				ld a, (hl) 
1376 fe 00			cp 0 
1378 c8				ret z 
1379 23				inc hl 
