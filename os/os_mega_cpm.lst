0fa1			 
0fa1			;moved to firmware.asm 
0fa1			;heap_start        .equ  0x9000      ; Starting address of heap 
0fa1			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
0fa1			 
0fa1			;      .org 0 
