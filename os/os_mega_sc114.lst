bea3			 
bea3			 
bea3			.SESEL: 
bea3				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bea3			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bea3			; | | Zero is disabled storage. 
bea3					if DEBUG_FORTH_WORDS_KEY 
bea3						DMARK "BN?" 
bea3						CALLMONITOR 
bea3					endif 
bea3					ld a, (spi_device_id) 
bea3					sub '0' 
bea3					ld h, 0 
bea3					ld l, a 
bea3					FORTH_PUSH_VALUEHL 
bea3					;call forth_push_numhl 
bea3					NEXTW 
bea3			.SESELS: 
bea3				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bea3			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bea3			; | | Set to zero to disable storage. 
bea3					if DEBUG_FORTH_WORDS_KEY 
bea3						DMARK "BNK" 
bea3						CALLMONITOR 
bea3					endif 
bea3			 
bea3					ld a, 255 
bea3					ld (spi_cartdev), a 
bea3			 
bea3					; get bank 
bea3			 
bea3					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bea3			 
bea3			;		push hl 
bea3			 
bea3					; destroy value TOS 
bea3			 
bea3					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bea3			 
bea3					; one value on hl get other one back 
bea3			 
bea3			;		pop hl 
bea3			 
bea3			 
bea3					ld c, SPI_CE_HIGH 
bea3					ld b, '0'    ; human readable bank number 
bea3			 
bea3					ld a, l 
bea3			 
bea3					if DEBUG_FORTH_WORDS 
bea3						DMARK "BNK" 
bea3						CALLMONITOR 
bea3					endif 
bea3			 
bea3					; active low 
bea3			 
bea3			;		cp 0 
bea3					or a 
bea3					jr z, .bset 
bea3					cp 1 
bea3					jr nz, .b2 
bea3					res 0, c 
bea3					ld b, '1'    ; human readable bank number 
bea3			.b2:		cp 2 
bea3					jr nz, .b3 
bea3					res 1, c 
bea3					ld b, '2'    ; human readable bank number 
bea3			.b3:		cp 3 
bea3					jr nz, .b4 
bea3					res 2, c 
bea3					ld b, '3'    ; human readable bank number 
bea3			.b4:		cp 4 
bea3					jr nz, .b5 
bea3					res 3, c 
bea3					ld b, '4'    ; human readable bank number 
bea3			.b5:		cp 5 
bea3					jr nz, .bset 
bea3					res 4, c 
bea3					ld b, '5'    ; human readable bank number 
bea3			 
bea3			.bset: 
bea3					ld a, c 
bea3					ld (spi_device),a 
bea3					ld a, b 
bea3					ld (spi_device_id),a 
bea3					if DEBUG_FORTH_WORDS 
bea3						DMARK "BN2" 
bea3						CALLMONITOR 
bea3					endif 
bea3			 
bea3					; set default SPI clk pulse time as disabled for BANK use 
bea3			 
bea3					ld a, 0 
bea3					ld (spi_clktime), a 
bea3			 
bea3					NEXTW 
bea3			 
bea3			.CARTDEV: 
bea3				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bea3			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bea3			; | | Set to zero to disable devices. 
bea3					if DEBUG_FORTH_WORDS_KEY 
bea3						DMARK "CDV" 
bea3						CALLMONITOR 
bea3					endif 
bea3			 
bea3					; disable se storage bank selection 
bea3			 
bea3					ld a, SPI_CE_HIGH		; ce high 
bea3					ld (spi_device), a 
bea3			 
bea3					; get bank 
bea3			 
bea3					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bea3			 
bea3			;		push hl 
bea3			 
bea3					; destroy value TOS 
