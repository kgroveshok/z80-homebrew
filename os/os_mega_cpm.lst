137f			 
137f			;------------------------------------------------------------------------------ 
137f			;     heap_init                                                               : 
137f			;                                                                             : 
137f			; Description                                                                 : 
137f			;     Initialise the heap and make it ready for malloc and free operations.   : 
137f			;                                                                             : 
137f			;     The heap is maintained as a linked list, starting with an initial       : 
137f			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
137f			;     the first free block in the heap. Each block then points to the next    : 
137f			;     free block within the heap, and the free list ends at the first block   : 
137f			;     with a null pointer to the next free block.                             : 
137f			;                                                                             : 
137f			; Parameters                                                                  : 
137f			;     Inputs are compile-time only. Two defines which specify the starting    : 
137f			;     address of the heap and its size are required, along with a memory      : 
137f			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
137f			;     principally stores a pointer to the first free block in the heap.       : 
137f			;                                                                             : 
137f			; Returns                                                                     : 
137f			;     Nothing                                                                 : 
137f			;------------------------------------------------------------------------------ 
137f			heap_init: 
137f			      push  HL 
137f			 
137f			      ; Initialise free list struct 
137f			      ld    HL, heap_start 
137f			      ld    (free_list), HL 
137f			      ld    HL, 0 
137f			      ld    (free_list+2), HL 
137f			 
137f			      ; Insert first free block at bottom of heap, consumes entire heap 
137f			      ld    HL, heap_start+heap_size-4 
137f			      ld    (heap_start), HL        ; Next block (end of free list) 
137f			      ld    HL, heap_size-4 
137f			      ld    (heap_start+2), HL      ; Block size 
137f			 
137f			      ; Insert end of free list block at top of heap - two null words will 
137f			      ; terminate the free list 
137f			      ld    HL, 0 
137f			      ld    (heap_start+heap_size-2), HL 
137f			      ld    (heap_start+heap_size-4), HL 
137f			 
137f			      pop   HL 
137f			 
137f			      ret 
137f			 
137f			 
137f			;------------------------------------------------------------------------------ 
137f			;     malloc                                                                  : 
137f			;                                                                             : 
137f			; Description                                                                 : 
137f			;     Allocates the wanted space from the heap and returns the address of the : 
137f			;     first useable byte of the allocation.                                   : 
137f			;                                                                             : 
137f			;     Allocations can happen in one of two ways:                              : 
137f			;                                                                             : 
137f			;     1. A free block may be found which is the exact size wanted. In this    : 
137f			;        case the block is removed from the free list and retuedn to the      : 
137f			;        caller.                                                              : 
137f			;     2. A free block may be found which is larger than the size wanted. In   : 
137f			;        this case, the larger block is split into two. The first portion of  : 
137f			;        this block will become the requested space by the malloc call and    : 
137f			;        is returned to the caller. The second portion becomes a new free     : 
137f			;        block, and the free list is adjusted to maintain continuity via this : 
137f			;        newly created block.                                                 : 
137f			;                                                                             : 
137f			;     malloc does not set any initial value in the allocated space, the       : 
137f			;     caller is required to do this as required.                              : 
137f			;                                                                             : 
137f			;     This implementation of malloc uses the stack exclusively, and is        : 
137f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
137f			;     advisable to disable interrupts before calling malloc, and recommended  : 
137f			;     to avoid the use of malloc inside ISRs in general.                      : 
137f			;                                                                             : 
137f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
137f			;                                                                             : 
137f			; Parameters                                                                  : 
137f			;     HL  Number of bytes wanted                                              : 
137f			;                                                                             : 
137f			; Returns                                                                     : 
137f			;     HL  Address of the first useable byte of the allocation                 : 
137f			;                                                                             : 
137f			; Flags                                                                       : 
137f			;     Z   Set if the allocation did not succeed, clear otherwise              : 
137f			;                                                                             : 
137f			; Stack frame                                                                 : 
137f			;       |             |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |     BC      |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |     DE      |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |     IX      |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |  prev_free  |                                                       : 
137f			;   +4  +-------------+                                                       : 
137f			;       |  this_free  |                                                       : 
137f			;   +2  +-------------+                                                       : 
137f			;       |  next_free  |                                                       : 
137f			;   +0  +-------------+                                                       : 
137f			;       |             |                                                       : 
137f			;                                                                             : 
137f			;------------------------------------------------------------------------------ 
137f			malloc: 
137f			      push  BC 
137f			      push  DE 
137f			      push  IX 
137f			 
137f			      ld    A, H                    ; Exit if no space requested 
137f			      or    L 
137f			      jp    Z, malloc_early_exit 
137f			 
137f			      ; Set up stack frame 
137f			      ex    DE, HL 
137f			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
137f			      add   HL, SP 
137f			      ld    SP, HL 
137f			      ld    IX, 0                   ; Use IX as a frame pointer 
137f			      add   IX, SP 
137f			 
137f			      ; Setup initial state 
137f			      ld    HL, 4                   ; want must also include space used by block struct 
137f			      add   HL, DE 
137f			 
137f			      ld    B, H                    ; Move want to BC 
137f			      ld    C, L 
137f			 
137f			      ld    HL, free_list           ; Store prev_free ptr to stack 
137f			      ld    (IX+4), L 
137f			      ld    (IX+5), H 
137f			 
137f			      ld    E, (HL)                 ; Store this_free ptr to stack 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      ld    (IX+2), E 
137f			      ld    (IX+3), D 
137f			      ex    DE, HL                  ; this_free ptr into HL 
137f			 
137f			      ; Loop through free block list to find some space 
137f			malloc_find_space: 
137f			      ld    E, (HL)                 ; Load next_free ptr into DE 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			 
137f			      ld    A, D                    ; Check for null next_free ptr - end of free list 
137f			      or    E 
137f			      jp    Z, malloc_no_space 
137f			 
137f			      ld    (IX+0), E               ; Store next_free ptr to stack 
137f			      ld    (IX+1), D 
137f			 
137f			      ; Does this block have enough space to make the allocation? 
137f			      inc   HL                      ; Load free block size into DE 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			 
137f			      ex    DE, HL                  ; Check size of block against want 
137f			      or    A                       ; Ensure carry flag clear 
137f			      sbc   HL, BC 
137f			      push  HL                      ; Store the result for later (new block size) 
137f			 
137f			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
137f			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
137f			 
137f			      ; this_free block is not big enough, setup ptrs to test next free block 
137f			      pop   HL                      ; Discard previous result 
137f			 
137f			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
137f			      ld    H, (IX+3) 
137f			      ld    (IX+4), L 
137f			      ld    (IX+5), H 
137f			 
137f			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
137f			      ld    H, (IX+1) 
137f			      ld    (IX+2), L 
137f			      ld    (IX+3), H 
137f			 
137f			      jr    malloc_find_space 
137f			 
137f			      ; split a bigger block into two - requested size and remaining size 
137f			malloc_alloc_split: 
137f			      ex    DE, HL                  ; Calculate address of new free block 
137f			      dec   HL 
137f			      dec   HL 
137f			      dec   HL 
137f			      add   HL, BC 
137f			 
137f			      ; Create a new block and point it at next_free 
137f			      ld    E, (IX+0)               ; Load next_free ptr into DE 
137f			      ld    D, (IX+1) 
137f			 
137f			      ld    (HL), E                 ; Store next_free ptr into new block 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			      pop   DE                      ; Store size of new block into new block 
137f			      inc   HL 
137f			      ld    (HL), E 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			      ; Update this_free ptr to point to new block 
137f			      dec   HL 
137f			      dec   HL 
137f			      dec   HL 
137f			 
137f			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
137f			      ld    D, (IX+3) 
137f			 
137f			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
137f			      ld    (IX+3), H 
137f			 
137f			      ; Modify this_free block to be allocation 
137f			      ex    DE, HL 
137f			      xor   A                       ; Null the next block ptr of allocated block 
137f			      ld    (HL), A 
137f			      inc   HL 
137f			      ld    (HL), A 
137f			 
137f			      inc   HL                      ; Store want size into allocated block 
137f			      ld    (HL), C 
137f			      inc   HL 
137f			      ld    (HL), B 
137f			      inc   HL 
137f			      push  HL                      ; Address of allocation to return 
137f			 
137f			      jr    malloc_update_links 
137f			 
137f			malloc_alloc_fit: 
137f			      pop   HL                      ; Dont need new block size, want is exact fit 
137f			 
137f			      ; Modify this_free block to be allocation 
137f			      ex    DE, HL 
137f			      dec   HL 
137f			      dec   HL 
137f			      dec   HL 
137f			 
137f			      xor   A                       ; Null the next block ptr of allocated block 
137f			      ld    (HL), A 
137f			      inc   HL 
137f			      ld    (HL), A 
137f			 
137f			      inc   HL                      ; Store address of allocation to return 
137f			      inc   HL 
137f			      inc   HL 
137f			      push  HL 
137f			 
137f			      ; Copy next_free ptr to this_free, remove allocated block from free list 
137f			      ld    L, (IX+0)               ; next_free to HL 
137f			      ld    H, (IX+1) 
137f			 
137f			      ld    (IX+2), L               ; HL to this_free 
137f			      ld    (IX+3), H 
137f			 
137f			 
137f			malloc_update_links: 
137f			      ; Update prev_free ptr to point to this_free 
137f			      ld    L, (IX+4)               ; prev_free ptr to HL 
137f			      ld    H, (IX+5) 
137f			 
137f			      ld    E, (IX+2)               ; this_free ptr to DE 
137f			      ld    D, (IX+3) 
137f			 
137f			      ld    (HL), E                 ; this_free ptr into prev_free 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			      ; Clear the Z flag to indicate successful allocation 
137f			      ld    A, D 
137f			      or    E 
137f			 
137f			      pop   DE                      ; Address of allocation 
137f			 
137f			malloc_no_space: 
137f			      ld    HL, 6                   ; Clean up stack frame 
137f			      add   HL, SP 
137f			      ld    SP, HL 
137f			 
137f			      ex    DE, HL                  ; Alloc addr into HL for return 
137f			 
137f			malloc_early_exit: 
137f			      pop   IX 
137f			      pop   DE 
137f			      pop   BC 
137f			 
137f			      ret 
137f			 
137f			 
137f			;------------------------------------------------------------------------------ 
137f			;     free                                                                    : 
137f			;                                                                             : 
137f			; Description                                                                 : 
137f			;     Return the space pointed to by HL to the heap. HL must be an address as : 
137f			;     returned by malloc, otherwise the behaviour is undefined.               : 
137f			;                                                                             : 
137f			;     Where possible, directly adjacent free blocks will be merged together   : 
137f			;     into larger blocks to help ensure that the heap does not become         : 
137f			;     excessively fragmented.                                                 : 
137f			;                                                                             : 
137f			;     free does not clear or set any other value into the freed space, and    : 
137f			;     therefore its contents may be visible through subsequent malloc's. The  : 
137f			;     caller should clear the freed space as required.                        : 
137f			;                                                                             : 
137f			;     This implementation of free uses the stack exclusively, and is          : 
137f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
137f			;     advisable to disable interrupts before calling free, and recommended    : 
137f			;     to avoid the use of free inside ISRs in general.                        : 
137f			;                                                                             : 
137f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
137f			;                                                                             : 
137f			; Parameters                                                                  : 
137f			;     HL  Pointer to address of first byte of allocation to be freed          : 
137f			;                                                                             : 
137f			; Returns                                                                     : 
137f			;     Nothing                                                                 : 
137f			;                                                                             : 
137f			; Stack frame                                                                 : 
137f			;       |             |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |     BC      |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |     DE      |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |     IX      |                                                       : 
137f			;       +-------------+                                                       : 
137f			;       |  prev_free  |                                                       : 
137f			;   +2  +-------------+                                                       : 
137f			;       |  next_free  |                                                       : 
137f			;   +0  +-------------+                                                       : 
137f			;       |             |                                                       : 
137f			;                                                                             : 
137f			;------------------------------------------------------------------------------ 
137f			free: 
137f			      push  BC 
137f			      push  DE 
137f			      push  IX 
137f			 
137f			      ld    A, H                    ; Exit if ptr is null 
137f			      or    L 
137f			      jp    Z, free_early_exit 
137f			 
137f			      ; Set up stack frame 
137f			      ex    DE, HL 
137f			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
137f			      add   HL, SP 
137f			      ld    SP, HL 
137f			      ld    IX, 0                   ; Use IX as a frame pointer 
137f			      add   IX, SP 
137f			 
137f			      ; The address in HL points to the start of the useable allocated space, 
137f			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
137f			      ; address of the block itself. 
137f			      ex    DE, HL 
137f			      ld    DE, -4 
137f			      add   HL, DE 
137f			 
137f			      ; An allocated block must have a null next block pointer in it 
137f			      ld    A, (HL) 
137f			      inc   HL 
137f			      or    (HL) 
137f			      jp    NZ, free_done 
137f			 
137f			      dec   HL 
137f			 
137f			      ld    B, H                    ; Copy HL to BC 
137f			      ld    C, L 
137f			 
137f			      ; Loop through the free list to find the first block with an address 
137f			      ; higher than the block being freed 
137f			      ld    HL, free_list 
137f			 
137f			free_find_higher_block: 
137f			      ld    E, (HL)                 ; Load next ptr from free block 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      dec   HL 
137f			 
137f			      ld    (IX+0), E               ; Save ptr to next free block 
137f			      ld    (IX+1), D 
137f			      ld    (IX+2), L               ; Save ptr to prev free block 
137f			      ld    (IX+3), H 
137f			 
137f			      ld    A, B                    ; Check if DE is greater than BC 
137f			      cp    D                       ; Compare MSB first 
137f			      jr    Z, $+4                  ; MSB the same, compare LSB 
137f			      jr    NC, free_find_higher_block_skip 
137f			      ld    A, C 
137f			      cp    E                       ; Then compare LSB 
137f			      jr    C, free_found_higher_block 
137f			 
137f			free_find_higher_block_skip: 
137f			      ld    A, D                    ; Reached the end of the free list? 
137f			      or    E 
137f			      jp    Z, free_done 
137f			 
137f			      ex    DE, HL 
137f			 
137f			      jr    free_find_higher_block 
137f			 
137f			free_found_higher_block: 
137f			      ; Insert freed block between prev and next free blocks 
137f			      ld    (HL), C                 ; Point prev free block to freed block 
137f			      inc   HL 
137f			      ld    (HL), B 
137f			 
137f			      ld    H, B                    ; Point freed block at next free block 
137f			      ld    L, C 
137f			      ld    (HL), E 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			      ; Check if the freed block is adjacent to the next free block 
137f			      inc   HL                      ; Load size of freed block into HL 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      ex    DE, HL 
137f			 
137f			      add   HL, BC                  ; Add addr of freed block and its size 
137f			 
137f			      ld    E, (IX+0)               ; Load addr of next free block into DE 
137f			      ld    D, (IX+1) 
137f			 
137f			      or    A                       ; Clear the carry flag 
137f			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
137f			      jr    NZ, free_check_adjacent_to_prev 
137f			 
137f			      ; Freed block is adjacent to next, merge into one bigger block 
137f			      ex    DE, HL                  ; Load next ptr from next block into DE 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      push  HL                      ; Save ptr to next block for later 
137f			 
137f			      ld    H, B                    ; Store ptr from next block into freed block 
137f			      ld    L, C 
137f			      ld    (HL), E 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			      pop   HL                      ; Restore ptr to next block 
137f			      inc   HL                      ; Load size of next block into DE 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      push  DE                      ; Save next block size for later 
137f			 
137f			      ld    H, B                    ; Load size of freed block into HL 
137f			      ld    L, C 
137f			      inc   HL 
137f			      inc   HL 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      ex    DE, HL 
137f			 
137f			      pop   DE                      ; Restore size of next block 
137f			      add   HL, DE                  ; Add sizes of both blocks 
137f			      ex    DE, HL 
137f			 
137f			      ld    H, B                    ; Store new bigger size into freed block 
137f			      ld    L, C 
137f			      inc   HL 
137f			      inc   HL 
137f			      ld    (HL), E 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			free_check_adjacent_to_prev: 
137f			      ; Check if the freed block is adjacent to the prev free block 
137f			      ld    L, (IX+2)               ; Prev free block ptr into HL 
137f			      ld    H, (IX+3) 
137f			 
137f			      inc   HL                      ; Size of prev free block into DE 
137f			      inc   HL 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      dec   HL 
137f			      dec   HL 
137f			      dec   HL 
137f			 
137f			      add   HL, DE                  ; Add prev block addr and size 
137f			 
137f			      or    A                       ; Clear the carry flag 
137f			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
137f			      jr    NZ, free_done 
137f			 
137f			      ; Freed block is adjacent to prev, merge into one bigger block 
137f			      ld    H, B                    ; Load next ptr from freed block into DE 
137f			      ld    L, C 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      push  HL                      ; Save freed block ptr for later 
137f			 
137f			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
137f			      ld    H, (IX+3) 
137f			      ld    (HL), E 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			      pop   HL                      ; Restore freed block ptr 
137f			      inc   HL                      ; Load size of freed block into DE 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			      push  DE                      ; Save freed block size for later 
137f			 
137f			      ld    L, (IX+2)               ; Load size of prev block into DE 
137f			      ld    H, (IX+3) 
137f			      inc   HL 
137f			      inc   HL 
137f			      ld    E, (HL) 
137f			      inc   HL 
137f			      ld    D, (HL) 
137f			 
137f			      pop   HL                      ; Add sizes of both blocks 
137f			      add   HL, DE 
137f			      ex    DE, HL 
137f			 
137f			      ld    L, (IX+2)               ; Store new bigger size into prev block 
137f			      ld    H, (IX+3) 
137f			      inc   HL 
137f			      inc   HL 
137f			      ld    (HL), E 
137f			      inc   HL 
137f			      ld    (HL), D 
137f			 
137f			free_done: 
137f			      ld    HL, 4                   ; Clean up stack frame 
137f			      add   HL, SP 
137f			      ld    SP, HL 
137f			 
137f			free_early_exit: 
137f			      pop   IX 
137f			      pop   DE 
137f			      pop   BC 
137f			 
137f			      ret 
137f			 
137f			 
137f			;      .org 0x8000 
137f			; 
137f			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
137f			 ;                 .dw   0 
137f			 
137f			endif 
137f			 
137f			 
137f			if MALLOC_4 
137f			 
137f			; My memory allocation code. Very very simple.... 
137f			; allocate space under 250 chars 
137f			 
137f			heap_init: 
137f				; init start of heap as zero 
137f				;  
137f			 
137f				ld hl, heap_start 
137f			;	ld a, 0 
137f				ld (hl), 0      ; empty block 
137f				inc hl 
137f			;	ld a, 0 
137f				ld (hl), 0      ; length of block 
137f				; write end of list 
137f				inc hl 
137f				ld a,(hl) 
137f				inc hl 
137f				ld a,(hl) 
137f				 
137f			 
137f				; init some malloc vars 
137f			 
137f				ld hl, 0 
137f				ld (free_list), hl       ; store last malloc location 
137f			 
137f				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
137f			;	ld a, 0 
137f				ld (hl), 0 
137f			 
137f			 
137f				ld hl, heap_start 
137f				;  
137f				  
137f				ret 
137f			 
137f			 
137f			;    free block marker 
137f			;    requested size  
137f			;    pointer to next block 
137f			;    .... 
137f			;    next block marker 
137f			 
137f			 
137f			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
137f			; 
137f			 
137f			 
137f			malloc:  
137f				push de 
137f				push bc 
137f				push af 
137f			 
137f				; hl space required 
137f				 
137f				ld c, l    ; hold space   (TODO only a max of 255) 
137f			 
137f			;	inc c     ; TODO BUG need to fix memory leak on push str 
137f			;	inc c 
137f			;	inc c 
137f			;	inc c 
137f			;	inc c 
137f			;	inc c 
137f			;	inc c 
137f			 
137f			 
137f			 
137f				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
137f			 
137f				ld a, (free_list+3) 
137f			;	cp 0 
137f				or a 
137f				jr z, .contheap 
137f			 
137f				ld hl, (free_list)     ; get last alloc 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "mrs" 
137f						CALLMONITOR 
137f					endif 
137f				jr .startalloc 
137f			 
137f			.contheap: 
137f				ld hl, heap_start 
137f			 
137f			.startalloc: 
137f			 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "mym" 
137f						CALLMONITOR 
137f					endif 
137f			.findblock: 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "mmf" 
137f						CALLMONITOR 
137f					endif 
137f			 
137f				ld a,(hl)  
137f				; if byte is zero then clear to use 
137f			 
137f			;	cp 0 
137f				or a 
137f				jr z, .foundemptyblock 
137f			 
137f				; if byte is not clear 
137f				;     then byte is offset to next block 
137f			 
137f				inc hl 
137f				ld a, (hl) ; get size 
137f			.nextblock:	inc hl 
137f					ld e, (hl) 
137f					inc hl 
137f					ld d, (hl) 
137f					ex de, hl 
137f			;	inc hl  ; move past the store space 
137f			;	inc hl  ; move past zero index  
137f			 
137f				; TODO detect no more space 
137f			 
137f				push hl 
137f				ld de, heap_end 
137f				call cmp16 
137f				pop hl 
137f				jr nc, .nospace 
137f			 
137f				jr .findblock 
137f			 
137f			.nospace: ld hl, 0 
137f				jp .exit 
137f			 
137f			 
137f			.foundemptyblock:	 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "mme" 
137f						CALLMONITOR 
137f					endif 
137f			 
137f			; TODO has block enough space if reusing??? 
137f			 
137f				;  
137f			 
137f			; see if this block has been previously used 
137f				inc hl 
137f				ld a, (hl) 
137f				dec hl 
137f			;	cp 0 
137f				or a 
137f				jr z, .newblock 
137f			 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "meR" 
137f						CALLMONITOR 
137f					endif 
137f			 
137f			; no reusing previously allocated block 
137f			 
137f			; is it smaller than previously used? 
137f				 
137f				inc hl    ; move to size 
137f				ld a, c 
137f				sub (hl)        ; we want c < (hl) 
137f				dec hl    ; move back to marker 
137f			        jr z, .findblock 
137f			 
137f				; update with the new size which should be lower 
137f			 
137f			        ;inc  hl   ; negate next move. move back to size  
137f			 
137f			.newblock: 
137f				; need to be at marker here 
137f			 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "meN" 
137f						CALLMONITOR 
137f					endif 
137f			 
137f			 
137f				ld a, c 
137f			 
137f				ld (free_list+3), a	 ; flag resume from last malloc  
137f				ld (free_list), hl    ; save out last location 
137f			 
137f			 
137f				;inc a     ; space for length byte 
137f				ld (hl), a     ; save block in use marker 
137f			 
137f				inc hl   ; move to space marker 
137f				ld (hl), a    ; save new space 
137f			 
137f				inc hl   ; move to start of allocated area 
137f				 
137f			;	push hl     ; save where we are - 1  
137f			 
137f			;	inc hl  ; move past zero index  
137f				; skip space to set down new marker 
137f			 
137f				; provide some extra space for now 
137f			 
137f				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
137f				inc a 
137f				inc a 
137f			 
137f				push hl   ; save where we are in the node block 
137f			 
137f				call addatohl 
137f			 
137f				; write linked list point 
137f			 
137f				pop de     ; get our node position 
137f				ex de, hl 
137f			 
137f				ld (hl), e 
137f				inc hl 
137f				ld (hl), d 
137f			 
137f				inc hl 
137f			 
137f				; now at start of allocated data so save pointer 
137f			 
137f				push hl 
137f			 
137f				; jump to position of next node and setup empty header in DE 
137f			 
137f				ex de, hl 
137f			 
137f			;	inc hl ; move past end of block 
137f			 
137f			;	ld a, 0 
137f				ld (hl), 0   ; empty marker 
137f				inc hl 
137f				ld (hl), 0   ; size 
137f				inc hl  
137f				ld (hl), 0   ; ptr 
137f				inc hl 
137f				ld (hl), 0   ; ptr 
137f			 
137f			 
137f				pop hl 
137f			 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "mmr" 
137f						CALLMONITOR 
137f					endif 
137f			 
137f			.exit: 
137f				pop af 
137f				pop bc 
137f				pop de  
137f				ret 
137f			 
137f			 
137f			 
137f			 
137f			free:  
137f				push hl 
137f				push af 
137f				; get address in hl 
137f			 
137f					if DEBUG_FORTH_MALLOC_INT 
137f						DMARK "fre" 
137f						CALLMONITOR 
137f					endif 
137f				; data is at hl - move to block count 
137f				dec hl 
137f				dec hl    ; get past pointer 
137f				dec hl 
137f			 
137f				ld a, (hl)    ; need this for a validation check 
137f			 
137f				dec hl    ; move to block marker 
137f			 
137f				; now check that the block count and block marker are the same  
137f			        ; this checks that we are on a malloc node and not random memory 
137f			        ; OK a faint chance this could be a problem but rare - famous last words! 
137f			 
137f				ld c, a 
137f				ld a, (hl)    
137f			 
137f				cp c 
137f				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
137f			 
137f				; yes good chance we are on a malloc node 
137f			 
137f			;	ld a, 0      
137f				ld (hl), 0   ; mark as free 
137f			 
137f				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
137f			 
137f			.freeignore:  
137f			 
137f				pop af 
137f				pop hl 
137f			 
137f				ret 
137f			 
137f			 
137f			 
137f			endif 
