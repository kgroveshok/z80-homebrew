b649				; allocate memory for (count + 1 ) * 2 for word array plus zero pointer 
b649			 
b649					; l contains count 
b649			 
b649 7d					ld a,l 
b64a 32 a4 e2				ld (scratch), a     ; save it for the loading loop 
b64d			 
b64d 2c					inc l  ; for zero pointer 
b64e eb					ex de, hl 
b64f 3e 02				ld a, 2 
b651 cd bd 89				call Mult16 
b654			 
b654					; hl is the size of block to allocate 
b654			 
b654 cd 06 8e				call malloc 
b657				if DEBUG_FORTH_MALLOC_GUARD 
b657 cc 4b c1				call z,malloc_error 
b65a				endif 
b65a					; hl is the pointer to the array block 
b65a						 
b65a 22 a5 e2				ld (scratch+1), hl    ; save the base for later push to stack 
b65d 22 a7 e2				ld (scratch+3), hl    ; save the base for current string to push 
b660			 
b660 3a a4 e2				ld a, (scratch) 
b663 47					ld b, a 
