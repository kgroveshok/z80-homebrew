68a8			; **********************************************************************  
68a8			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
68a8			; **********************************************************************  
68a8			;  
68a8			; **  Written as a Small Computer Monitor App   
68a8			; **  Version 0.1 SCC 2018-05-16  
68a8			; **  www.scc.me.uk  
68a8			;  
68a8			; **********************************************************************  
68a8			;  
68a8			; This module provides support for alphanumeric LCD modules using with  
68a8			; *  HD44780 (or compatible) controller  
68a8			; *  5 x 7 pixel fonts  
68a8			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
68a8			; *  Interface via six digital outputs to the display (see below)  
68a8			;  
68a8			; LCD module pinout:  
68a8			;   1  Vss   0v supply  
68a8			;   2  Vdd   5v supply  
68a8			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
68a8			;   4  RS    High = data, Low = instruction  
68a8			;   5  R/W   High = Read, Low = Write  
68a8			;   6  E     Enable signal (active high)  
68a8			;   7  DB0   Data bit 0  
68a8			;   8  DB1   Data bit 1  
68a8			;   9  DB2   Data bit 2  
68a8			;  10  DB3   Data bit 3  
68a8			;  11  DB4   Data bit 4  
68a8			;  12  DB5   Data bit 5  
68a8			;  13  DB6   Data bit 6  
68a8			;  14  DB7   Data bit 7  
68a8			;  15  A     Backlight anode (+)  
68a8			;  16  K     Backlight cathode (-)  
68a8			;  
68a8			; This interfacing method uses 4-bit data mode and uses time delays  
68a8			; rather than polling the display's ready status. As a result the   
68a8			; interface only requires 6 simple output lines:  
68a8			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
68a8			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
68a8			;   LCD DB4 = Microcomputer output port bit 4  
68a8			;   LCD DB5 = Microcomputer output port bit 5  
68a8			;   LCD DB6 = Microcomputer output port bit 6  
68a8			;   LCD DB7 = Microcomputer output port bit 7  
68a8			; Display's R/W is connected to 0v so it is always in write mode  
68a8			; All 6 connections must be on the same port address <kLCDPrt>  
68a8			; This method also allows a decent length of cable from micro to LCD  
68a8			;  
68a8			; **********************************************************************  
68a8			;  
68a8			; To include the code for any given function provided by this module,   
68a8			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
68a8			; the parent source file.  
68a8			; For example:  #REQUIRES   uHexPrefix  
68a8			;  
68a8			; Also #INCLUDE this file at some point after the #REQUIRES statements  
68a8			; in the parent source file.  
68a8			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
68a8			;  
68a8			; These are the function names provided by this module:  
68a8			; fLCD_Init                     ;Initialise LCD  
68a8			; fLCD_Inst                     ;Send instruction to LCD  
68a8			; fLCD_Data                     ;Send data byte to LCD  
68a8			; fLCD_Pos                      ;Position cursor  
68a8			; fLCD_Str                      ;Display string  
68a8			; fLCD_Def                      ;Define custom character  
68a8			;  
68a8			; **********************************************************************  
68a8			;  
68a8			; Requires SCMonAPI.asm to also be included in the project  
68a8			;  
68a8			  
68a8			  
68a8			; **********************************************************************  
68a8			; **  Constants  
68a8			; **********************************************************************  
68a8			  
68a8			; Constants that must be defined externally  
68a8			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
68a8			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
68a8			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
68a8			;kLCDWidth: EQU 20             ;Width in characters  
68a8			  
68a8			; general line offsets in any frame buffer  
68a8			  
68a8			  
68a8			display_row_1: equ 0  
68a8			display_row_2: equ display_row_1+display_cols  
68a8			display_row_3: equ display_row_2 + display_cols  
68a8			display_row_4: equ display_row_3 + display_cols  
68a8			;display_row_4_eol:   
68a8			  
68a8			  
68a8			; Cursor position values for the start of each line  
68a8			  
68a8			; E  
68a8			kLCD_Line1: EQU 0x00   
68a8			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
68a8			; E1  
68a8			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
68a8			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
68a8			  
68a8			; Instructions to send as A register to fLCD_Inst  
68a8			kLCD_Clear: EQU 00000001b     ;LCD clear  
68a8			kLCD_Off:   EQU 00001000b     ;LCD off  
68a8			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
68a8			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
68a8			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
68a8			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
68a8			  
68a8			; Constants used by this code module  
68a8			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
68a8			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
68a8			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
68a8			  
68a8			  
68a8			  
68a8			; **********************************************************************  
68a8			; **  LCD support functions  
68a8			; **********************************************************************  
68a8			  
68a8			; Initialise alphanumeric LCD module  
68a8			; LCD control register codes:  
68a8			;   DL   0 = 4-bit mode        1 = 8-bit mode  
68a8			;   N    0 = 1-line mode       1 = 2-line mode  
68a8			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
68a8			;   D    0 = Display off       1 = Display on  
68a8			;   C    0 = Cursor off        1 = Cursor on  
68a8			;   B    0 = Blinking off      1 = Blinking on  
68a8			;   ID   0 = Decrement mode    1 = Increment mode  
68a8			;   SH   0 = Entire shift off  1 = Entire shift on  
68a8 3e 28		fLCD_Init:  LD   A, 40  
68aa cd cf 69		            CALL LCDDelay       ;Delay 40ms after power up  
68ad			; For reliable reset set 8-bit mode - 3 times  
68ad cd 9f 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68b0 cd 9f 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68b3 cd 9f 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68b6			; Set 4-bit mode  
68b6 cd 9b 69		            CALL WrFn4bit       ;Function = 4-bit mode  
68b9 cd cd 69		            CALL LCDDelay1      ;Delay 37 us or more  
68bc			; Function set  
68bc 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
68be cd d1 68		            CALL fLCD_Inst      ;2 line, display on  
68c1			; Display On/Off control  
68c1 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
68c3 cd d1 68		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
68c6			; Display Clear  
68c6 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
68c8 cd d1 68		            CALL fLCD_Inst      ;Clear display  
68cb			; Entry mode  
68cb 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
68cd cd d1 68		            CALL fLCD_Inst      ;Increment mode, shift off  
68d0			; Display module now initialised  
68d0 c9			            RET  
68d1			; ok to here  
68d1			  
68d1			; Write instruction to LCD  
68d1			;   On entry: A = Instruction byte to be written  
68d1			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
68d1 f5			fLCD_Inst:  PUSH AF  
68d2 f5			            PUSH AF  
68d3 cd e5 68		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
68d6 f1			            POP  AF  
68d7 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
68d8 17			            RLA  
68d9 17			            RLA  
68da 17			            RLA  
68db cd e5 68		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
68de 3e 02		            LD   A, 2  
68e0 cd cf 69		            CALL LCDDelay       ;Delay 2 ms to complete   
68e3 f1			            POP  AF  
68e4 c9			            RET  
68e5			Wr4bits:   
68e5 f5					push af  
68e6 3a fb fa				ld a, (display_lcde1e2)  
68e9 fe 00				cp 0     ; e  
68eb 20 10				jr nz, .wea2	  
68ed f1					pop af  
68ee e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
68f0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
68f2 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
68f4 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
68f6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
68f8 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
68fa d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
68fc c9			            RET  
68fd f1			.wea2:		pop af  
68fe e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6900 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6902 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6904 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6906 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6908 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
690a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
690c c9			            RET  
690d			  
690d			  
690d			; Write data to LCD  
690d			;   On entry: A = Data byte to be written  
690d			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
690d f5			fLCD_Data:  PUSH AF  
690e f5			            PUSH AF  
690f cd 21 69		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6912 f1			            POP  AF  
6913 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6914 17			            RLA  
6915 17			            RLA  
6916 17			            RLA  
6917 cd 21 69		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
691a 3e 96		            LD   A, 150  
691c 3d			Wait:      DEC  A              ;Wait a while to allow data   
691d 20 fd		            JR   NZ, Wait      ;  write to complete  
691f f1			            POP  AF  
6920 c9			            RET  
6921			Wr4bitsa:     
6921 f5					push af  
6922 3a fb fa				ld a, (display_lcde1e2)  
6925 fe 00				cp 0     ; e1  
6927 20 16				jr nz, .we2	  
6929 f1					pop af  
692a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
692c cb d7		            SET  kLCDBitRS, A  
692e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6930 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6932 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6934 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6936 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6938 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
693a cb 97		            RES  kLCDBitRS, A  
693c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
693e c9			            RET  
693f f1			.we2:		pop af  
6940 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
