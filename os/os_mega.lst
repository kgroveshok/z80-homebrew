688a 3e 50			ld a, kLCD_Line3  
688c cd 66 69		            CALL fLCD_Pos       ;Position cursor to location in A  
688f 06 28			ld b, display_cols  
6891 ed 5b f9 fa		ld de, (display_write_tmp)  
