9be9			user_word_eol:  
9be9				; hl contains the pointer to where to create a linked list item from the end 
9be9				; of the user dict to continue on at the system word dict 
9be9				 
9be9				; poke the stub of the word list linked list to repoint to rom words 
9be9			 
9be9				; stub format 
9be9				; db   word id 
9be9				; dw    link to next word 
9be9			        ; db char length of token 
9be9				; db string + 0 term 
9be9				; db exec code....  
9be9			 
9be9			;	ld a, WORD_SYS_ROOT     ; root word 
9be9 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9beb 23				inc hl 
9bec			 
9bec 11 95 9d			ld de, sysdict 
9bef 73				ld (hl), e		; next word link ie system dict 
9bf0 23				inc hl 
9bf1 72				ld (hl), d		; next word link ie system dict 
9bf2 23				inc hl	 
9bf3			 
9bf3			;	ld (hl), sysdict		; next word link ie system dict 
9bf3			;	inc hl 
9bf3			;	inc hl 
9bf3			 
9bf3			;	inc hl 
9bf3			;	inc hl 
9bf3			 
9bf3			;	ld a, 2			; word length is 0 
9bf3 36 02			ld (hl), 2 
