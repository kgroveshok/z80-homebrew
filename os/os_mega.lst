6a23			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a23 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6a25 18 02		            JR   WrFunc  
6a27 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6a29 f5			WrFunc:     PUSH AF  
6a2a f5					push af  
6a2b 3a fb fa				ld a, (display_lcde1e2)  
6a2e fe 00				cp 0     ; e1  
6a30 20 0f				jr nz, .wfea2	  
6a32 f1					pop af  
6a33 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a35 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6a37 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6a39 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a3b cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6a3d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a3f 18 0d			jr .wfskip  
6a41 f1			.wfea2:		pop af  
6a42 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a44 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6a46 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6a48 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a4a cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6a4c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a4e 3e 05		.wfskip:            LD  A, 5  
6a50 cd 57 6a		            CALL LCDDelay       ;Delay 5 ms to complete  
6a53 f1			            POP  AF  
6a54 c9			            RET  
6a55			  
6a55			  
6a55			; Delay in milliseconds  
6a55			;   On entry: A = Number of milliseconds delay  
6a55			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a55 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
