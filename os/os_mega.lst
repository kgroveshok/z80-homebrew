65a5			; stack over and underflow checks 
65a5			 
65a5			; init the words to detect the under/overflow 
65a5			 
65a5			chk_stk_init: 
65a5				; a vague random number to check so we dont get any "lucky" hits 
65a5 3e 2d			ld a, 45 
65a7 6f				ld l, a 
65a8 00				nop 
65a9 3e 17			ld a, 23 
65ab 67				ld h, a 
65ac			 
65ac 22 b9 f0			ld (chk_word), hl     ; the word we need to check against 
65af			 
65af			;	ld (chk_stund), hl	; stack points.... 
65af 22 3b fe			ld (chk_stovr), hl 
65b2 22 08 f9			ld (chk_ret_und), hl 
65b5 22 c6 f8			ld (chk_ret_ovr), hl 
65b8 22 44 f8			ld (chk_loop_ovr), hl 
65bb 22 42 f6			ld (chk_data_ovr), hl 
65be c9				ret 
65bf				 
65bf			check_stacks: 
65bf				; check all stack words 
65bf			 
65bf e5				push hl 
65c0 d5				push de 
65c1			 
65c1			;	ld de,(chk_word) 
65c1			;	ld hl, (chk_stund)	; stack points.... 
65c1			;	if DEBUG_STK_FAULT 
65c1			;		DMARK "FAa" 
65c1			;		CALLMONITOR 
65c1			;	endif 
65c1			;	call cmp16 
65c1			;	jp z, .chk_faulta 
65c1			; 
65c1			;	ld de, sfaultsu 
65c1			;	jp .chk_fault 
65c1			 
65c1 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
65c4 ed 5b b9 f0		ld de,(chk_word) 
65c8				if DEBUG_STK_FAULT 
65c8					DMARK "FAb" 
65c8					CALLMONITOR 
65c8				endif 
65c8 cd 80 0d			call cmp16 
65cb 28 06			jr z, .chk_fault1 
65cd 11 72 66			ld de, sfaultso 
65d0 c3 22 66			jp .chk_fault 
65d3			.chk_fault1:  
65d3 2a 08 f9			ld hl, (chk_ret_und) 
65d6 ed 5b b9 f0		ld de,(chk_word) 
65da				if DEBUG_STK_FAULT 
65da					DMARK "FAU" 
65da					CALLMONITOR 
65da				endif 
65da cd 80 0d			call cmp16 
65dd ca e6 65			jp z, .chk_fault2 
65e0 11 82 66			ld de, sfaultru 
65e3 c3 22 66			jp .chk_fault 
65e6			.chk_fault2:  
65e6 2a c6 f8			ld hl, (chk_ret_ovr) 
65e9 ed 5b b9 f0		ld de,(chk_word) 
65ed				if DEBUG_STK_FAULT 
65ed					DMARK "FA1" 
65ed					CALLMONITOR 
65ed				endif 
65ed cd 80 0d			call cmp16 
65f0 ca f9 65			jp z, .chk_fault3 
65f3 11 90 66			ld de, sfaultro 
65f6 c3 22 66			jp .chk_fault 
65f9			.chk_fault3:  
65f9 2a 44 f8			ld hl, (chk_loop_ovr) 
65fc ed 5b b9 f0		ld de,(chk_word) 
6600				if DEBUG_STK_FAULT 
6600					DMARK "FA2" 
6600					CALLMONITOR 
6600				endif 
6600 cd 80 0d			call cmp16 
6603 ca 0c 66			jp z, .chk_fault4 
6606 11 aa 66			ld de, sfaultlo 
6609 c3 22 66			jp .chk_fault 
660c			.chk_fault4:  
660c 2a 42 f6			ld hl, (chk_data_ovr) 
660f ed 5b b9 f0		ld de,(chk_word) 
6613				if DEBUG_STK_FAULT 
6613					DMARK "FA3" 
6613					CALLMONITOR 
6613				endif 
6613 cd 80 0d			call cmp16 
6616 ca 1f 66			jp z, .chk_fault5 
6619 11 c4 66			ld de, sfaultdo 
661c c3 22 66			jp .chk_fault 
661f			 
661f			 
661f			.chk_fault5:  
661f d1				pop de 
6620 e1				pop hl 
6621			 
6621 c9				ret 
