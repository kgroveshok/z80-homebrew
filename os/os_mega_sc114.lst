8c85			subafromhl: 
8c85			   ; If A=0 do nothing 
8c85			    ; Otherwise flip A's sign. Since 
8c85			    ; the upper byte becomes -1, also 
8c85			    ; substract 1 from H. 
8c85 ed 44		    neg 
8c87 ca 90 8c		    jp    z, Skip 
8c8a 25			    dec   h 
8c8b			     
8c8b			    ; Now add the low byte as usual 
8c8b			    ; Two's complement takes care of 
8c8b			    ; ensuring the result is correct 
8c8b 85			    add   a, l 
8c8c 6f			    ld    l, a 
8c8d 8c			    adc   a, h 
8c8e 95			    sub   l 
8c8f 67			    ld    h, a 
8c90			Skip: 
