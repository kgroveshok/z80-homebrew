2361			; A better parser without using malloc and string copies all over the place.  
2361			; Exec in situ should be faster 
2361			 
2361			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
2361			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
2361			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
2361			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
2361			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
2361			WORD_SYS_END: equ 0   ; Opcode for all user words 
2361			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
2361			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
2361			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
2361			 
2361			; Core word preamble macro 
2361			 
2361			CWHEAD:   macro nxtword opcode lit len opflags 
2361				db WORD_SYS_CORE+opcode             
2361				; internal op code number 
2361				dw nxtword            
2361				; link to next dict word block 
2361				db len + 1 
2361				; literal length of dict word inc zero term 
2361				db lit,0              
2361				; literal dict word 
2361			        ; TODO db opflags        
2361				endm 
