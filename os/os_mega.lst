2419			user_word_eol:  
2419				; hl contains the pointer to where to create a linked list item from the end 
2419				; of the user dict to continue on at the system word dict 
2419				 
2419				; poke the stub of the word list linked list to repoint to rom words 
2419			 
2419				; stub format 
2419				; db   word id 
2419				; dw    link to next word 
2419			        ; db char length of token 
2419				; db string + 0 term 
2419				; db exec code....  
2419			 
2419			;	ld a, WORD_SYS_ROOT     ; root word 
2419 36 00			ld (hl), WORD_SYS_ROOT		; word id 
241b 23				inc hl 
241c			 
241c 11 c5 25			ld de, sysdict 
241f 73				ld (hl), e		; next word link ie system dict 
2420 23				inc hl 
2421 72				ld (hl), d		; next word link ie system dict 
2422 23				inc hl	 
2423			 
2423			;	ld (hl), sysdict		; next word link ie system dict 
2423			;	inc hl 
2423			;	inc hl 
2423			 
2423			;	inc hl 
2423			;	inc hl 
2423			 
2423			;	ld a, 2			; word length is 0 
2423 36 02			ld (hl), 2 
2425 23				inc hl 
2426			 
2426			;	ld a, '~'			; word length is 0 
2426 36 7e			ld (hl), '~' 
2428 23				inc hl 
2429			;	ld a, 0			; save empty word 
2429 36 00			ld (hl), 0 
242b			 
242b c9				ret 
