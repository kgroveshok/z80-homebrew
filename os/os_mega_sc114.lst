9caa			user_word_eol:  
9caa				; hl contains the pointer to where to create a linked list item from the end 
9caa				; of the user dict to continue on at the system word dict 
9caa				 
9caa				; poke the stub of the word list linked list to repoint to rom words 
9caa			 
9caa				; stub format 
9caa				; db   word id 
9caa				; dw    link to next word 
9caa			        ; db char length of token 
9caa				; db string + 0 term 
9caa				; db exec code....  
9caa			 
9caa			;	ld a, WORD_SYS_ROOT     ; root word 
9caa 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9cac 23				inc hl 
9cad			 
9cad 11 56 9e			ld de, sysdict 
9cb0 73				ld (hl), e		; next word link ie system dict 
9cb1 23				inc hl 
9cb2 72				ld (hl), d		; next word link ie system dict 
9cb3 23				inc hl	 
9cb4			 
9cb4			;	ld (hl), sysdict		; next word link ie system dict 
9cb4			;	inc hl 
9cb4			;	inc hl 
9cb4			 
9cb4			;	inc hl 
9cb4			;	inc hl 
9cb4			 
9cb4			;	ld a, 2			; word length is 0 
9cb4 36 02			ld (hl), 2 
9cb6 23				inc hl 
9cb7			 
9cb7			;	ld a, '~'			; word length is 0 
9cb7 36 7e			ld (hl), '~' 
9cb9 23				inc hl 
9cba			;	ld a, 0			; save empty word 
9cba 36 00			ld (hl), 0 
9cbc			 
