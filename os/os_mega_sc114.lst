bc0d			.SESEL: 
bc0d				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bc0d			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bc0d			; | | Zero is disabled storage. 
bc0d					if DEBUG_FORTH_WORDS_KEY 
bc0d						DMARK "BN?" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d					ld a, (spi_device_id) 
bc0d					sub '0' 
