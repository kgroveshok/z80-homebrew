8a37			; 
8a37			;       sla e        ;128 
8a37			;       rl d         ;128 
8a37			;       adc hl,hl    ;240 
8a37			;       sbc hl,bc    ;240 
8a37			;       jr nc,.DivLoop ;23|21 
8a37			;       inc e        ;-- 
8a37			;       jp .DivLoop+1 
