1b59			user_word_eol:  
1b59				; hl contains the pointer to where to create a linked list item from the end 
1b59				; of the user dict to continue on at the system word dict 
1b59				 
1b59				; poke the stub of the word list linked list to repoint to rom words 
1b59			 
1b59				; stub format 
1b59				; db   word id 
1b59				; dw    link to next word 
1b59			        ; db char length of token 
1b59				; db string + 0 term 
1b59				; db exec code....  
1b59			 
1b59			;	ld a, WORD_SYS_ROOT     ; root word 
1b59 36 00			ld (hl), WORD_SYS_ROOT		; word id 
1b5b 23				inc hl 
1b5c			 
1b5c 11 05 1d			ld de, sysdict 
1b5f 73				ld (hl), e		; next word link ie system dict 
1b60 23				inc hl 
1b61 72				ld (hl), d		; next word link ie system dict 
1b62 23				inc hl	 
1b63			 
1b63			;	ld (hl), sysdict		; next word link ie system dict 
1b63			;	inc hl 
1b63			;	inc hl 
1b63			 
1b63			;	inc hl 
1b63			;	inc hl 
1b63			 
1b63			;	ld a, 2			; word length is 0 
1b63 36 02			ld (hl), 2 
1b65 23				inc hl 
1b66			 
1b66			;	ld a, '~'			; word length is 0 
1b66 36 7e			ld (hl), '~' 
1b68 23				inc hl 
1b69			;	ld a, 0			; save empty word 
1b69 36 00			ld (hl), 0 
