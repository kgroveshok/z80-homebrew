0be5			; random number generators 
0be5			 
0be5			 
0be5			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0be5			 
0be5			 
0be5			;-----> Generate a random number 
0be5			; output a=answer 0<=a<=255 
0be5			; all registers are preserved except: af 
0be5			random: 
0be5 e5			        push    hl 
0be6 d5			        push    de 
0be7 2a d9 fa		        ld      hl,(randData) 
0bea ed 5f		        ld      a,r 
0bec 57			        ld      d,a 
0bed 5e			        ld      e,(hl) 
0bee 19			        add     hl,de 
0bef 85			        add     a,l 
0bf0 ac			        xor     h 
0bf1 22 d9 fa		        ld      (randData),hl 
0bf4 d1			        pop     de 
0bf5 e1			        pop     hl 
0bf6 c9			        ret 
0bf7			 
0bf7			 
0bf7			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0bf7			 
0bf7			 
0bf7			 
0bf7			;------LFSR------ 
0bf7			;James Montelongo 
0bf7			;optimized by Spencer Putt 
0bf7			;out: 
0bf7			; a = 8 bit random number 
0bf7			RandLFSR: 
0bf7 21 df fa		        ld hl,LFSRSeed+4 
0bfa 5e			        ld e,(hl) 
0bfb 23			        inc hl 
0bfc 56			        ld d,(hl) 
0bfd 23			        inc hl 
0bfe 4e			        ld c,(hl) 
0bff 23			        inc hl 
0c00 7e			        ld a,(hl) 
0c01 47			        ld b,a 
0c02 cb 13		        rl e  
