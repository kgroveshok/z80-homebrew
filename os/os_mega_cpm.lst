0f84			; hl and de strings 
0f84			; zero set if the same 
0f84			 
0f84			strcmp: 
0f84 1a				ld a, (de) 
0f85 be				cp (hl) 
0f86 28 02			jr z, .ssame 
0f88 b7				or a 
0f89 c9				ret 
