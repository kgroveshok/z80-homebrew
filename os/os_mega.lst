6a81			; Write function to LCD  
6a81			;   On entry: A = Function byte to be written  
6a81			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a81 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6a83 18 02		            JR   WrFunc  
6a85 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6a87 f5			WrFunc:     PUSH AF  
6a88 f5					push af  
6a89 3a fb fa				ld a, (display_lcde1e2)  
6a8c fe 00				cp 0     ; e1  
6a8e 20 0f				jr nz, .wfea2	  
6a90 f1					pop af  
6a91 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a93 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6a95 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6a97 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a99 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6a9b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a9d 18 0d			jr .wfskip  
6a9f f1			.wfea2:		pop af  
6aa0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6aa2 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6aa4 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6aa6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6aa8 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6aaa d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6aac 3e 05		.wfskip:            LD  A, 5  
6aae cd b5 6a		            CALL LCDDelay       ;Delay 5 ms to complete  
6ab1 f1			            POP  AF  
6ab2 c9			            RET  
6ab3			  
6ab3			  
6ab3			; Delay in milliseconds  
6ab3			;   On entry: A = Number of milliseconds delay  
6ab3			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ab3 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
6ab5 d5			LCDDelay:   PUSH DE  
6ab6 5f			            LD   E, A           ;Delay by 'A' ms  
6ab7 16 00		            LD   D, 0  
6ab9 cd 59 0a		            CALL aDelayInMS  
6abc d1			            POP  DE  
6abd c9			            RET  
