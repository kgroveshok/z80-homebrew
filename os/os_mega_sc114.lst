d5af					call str_at_display 
d5af				 
d5af			; 
d5af			 
d5af				ld a, display_row_1+5 
d5af				ld de, sprompt3 
d5af				call str_at_display 
d5af				ld a, display_row_3+15 
d5af				ld de, sprompt4 
d5af				call str_at_display 
d5af			 
d5af				call update_display 
d5af			 
d5af				call cin_wait 
d5af				cp 'n' 
d5af				ret z 
d5af				cp 'N' 
d5af				ret z 
d5af			 
d5af				call delay1s 
d5af			 
d5af				ld a, (store_page+2) 
d5af				ld (store_openmaxext), a    ; save count of ext 
d5af				ld a, 1  
d5af				ld (store_openext), a    ; save count of ext 
d5af			 
d5af			.autof:  
d5af				ld l , a 
d5af				 
d5af				ld a, (store_page) 
d5af				ld h, a	 
d5af				ld de, store_page 
d5af					if DEBUG_FORTH_WORDS 
d5af						DMARK "ASl" 
d5af						CALLMONITOR 
d5af					endif 
d5af					call storage_read 
d5af				call ishlzero 
d5af				ret z 
d5af			;	jr z, .autoend 
d5af			 
d5af					if DEBUG_FORTH_WORDS 
d5af						DMARK "ASc" 
d5af						CALLMONITOR 
d5af					endif 
d5af				ld de, store_page+2 
d5af				ld a, display_row_4 
d5af				call str_at_display 
d5af			 
d5af				call update_display 
d5af				call delay250ms 
d5af			 
d5af			 
d5af			 
d5af				ld hl, store_page+2 
d5af				call forthparse 
d5af				call forthexec 
d5af				call forthexec_cleanup 
d5af			 
d5af				 
d5af				ld a, (store_openext) 
d5af				inc a 
d5af				ld (store_openext), a    ; save count of ext 
d5af			 
d5af				jr .autof 
