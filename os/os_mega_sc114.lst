8dfd			malloc_guard_zerolen: 
8dfd				push hl 
8dfd				push de 
8dfd				push af 
8dfd			 
8dfd				ld de, 0 
8dfd			        call cmp16 
8dfd				jr nz, .lowalloz 
8dfd			 
8dfd				push hl 
8dfd				push de 
8dfd					ld hl, display_fb0 
8dfd					ld (display_fb_active), hl 
8dfd				call clear_display 
8dfd				ld a, 0 
8dfd				ld de, .malloczero 
8dfd				call str_at_display 
8dfd				call update_display 
8dfd				call delay1s 
8dfd				call delay1s 
8dfd				call bp_on 
8dfd			;	ld a, 0 
8dfd			;	ld (os_view_disable), a 
8dfd			 
8dfd				pop de 
8dfd				pop hl 
8dfd			 
8dfd				 
8dfd			 
8dfd				CALLMONITOR 
8dfd			.lowalloz: 
8dfd			 
8dfd			 
8dfd				pop af 
8dfd				pop de 
8dfd				pop hl 
8dfd			ret 
8dfd			 
8dfd			malloc_guard_entry: 
8dfd				push hl 
8dfd				push de 
8dfd				push af 
8dfd			 
8dfd			 	or a      ;clear carry flag 
8dfd				push hl 
8dfd				ld de, 255 
8dfd				sbc hl, de 
8dfd				jr c, .lowalloc 
8dfd			 
8dfd				push de 
8dfd					ld hl, display_fb0 
8dfd					ld (display_fb_active), hl 
8dfd				call clear_display 
8dfd				ld a, 0 
8dfd				ld de, .mallocsize 
8dfd				call str_at_display 
8dfd				call update_display 
8dfd				call delay1s 
8dfd				call delay1s 
8dfd			;	ld a, 0 
8dfd			;	ld (os_view_disable), a 
8dfd				call bp_on 
8dfd			 
8dfd				pop de 
8dfd				pop hl 
8dfd			 
8dfd				 
8dfd			 
8dfd				CALLMONITOR 
8dfd				jr .lowdone 
8dfd			.lowalloc: 
8dfd			 
8dfd			 
8dfd				pop hl 
8dfd			.lowdone:	pop af 
8dfd				pop de 
8dfd				pop hl 
8dfd			ret 
8dfd			 
8dfd			malloc_guard_exit: 
8dfd				push hl 
8dfd				push de 
8dfd				push af 
8dfd			 
8dfd			 	or a      ;clear carry flag 
8dfd				push hl 
8dfd				ld de, 255 
8dfd				sbc hl, de 
8dfd				jr c, .lowallocx 
8dfd			 
8dfd				push de 
8dfd					ld hl, display_fb0 
8dfd					ld (display_fb_active), hl 
8dfd				call clear_display 
8dfd				ld a, 0 
8dfd				ld de, .mallocasize 
8dfd				call str_at_display 
8dfd				call update_display 
8dfd				call delay1s 
8dfd				call delay1s 
8dfd			;	ld a, 0 
8dfd			;	ld (os_view_disable), a 
8dfd				call bp_on 
8dfd				pop de 
8dfd				pop hl 
8dfd			 
8dfd				CALLMONITOR 
8dfd				jr .lowdonex 
8dfd			.lowallocx: 
8dfd			 
8dfd				pop hl 
8dfd			.lowdonex:	pop af 
8dfd				pop de 
8dfd				pop hl 
8dfd			ret 
8dfd			endif 
