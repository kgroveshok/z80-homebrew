1339			if TAPE_SUPPORT   
1339				include "firmware_tape.asm"    ; Tape support on Device A by default  
1339			; Tape support 
1339			 
1339			 
1339			; encoding 
1339			;  
1339			; pulse marks  of stream 
1339			; proportial 
1339			 
1339			 
1339			; setup default tape params 
1339			tape_init:     
1339 3e 00			ld a, Device_A 
133b 32 89 f9			ld (tape_port), a 
133e			 
133e 3e fa			ld a, 250 
1340 32 84 f9			ld (tape_tm_gap), a 
1343			 
1343 21 40 1f			ld hl, 8000 
1346 22 85 f9			ld (tape_samples), hl 
1349			 
1349 3e 06			ld a, 6 
134b 32 88 f9			ld (tape_pulse_high), a 
134e			 
134e 3e 02			ld a, 2 
1350 32 87 f9			ld (tape_pulse_low), a 
1353			 
1353 21 32 00			ld hl, 50 
1356 22 82 f9			ld (tape_tm_high), hl 
1359			 
1359 21 32 00			ld hl, 50 
135c 22 80 f9			ld (tape_tm_low), hl 
135f c9				ret 
1360			 
1360			; support routinues for tape 
1360			 
1360			 
1360			; Tape Output 
1360			 
1360			; osciallate the pin for the required duration 
1360			 
1360			tape_osc:  
1360				; hl has the number of iterations 
1360				; c = port number 
1360				; d = bus data 
1360				 
1360 ed 51			out (c), d 
1362			 
1362 2b				dec hl 
1363 cd e4 0d			call ishlzero 
1366 20 f8			jr nz, tape_osc 
1368				 
1368 c9				ret 
1369			 
1369			; output a gap period 
1369			tape_gap:  
1369 3a 84 f9			ld a, (tape_tm_gap) 
136c cd 99 0a			call aDelayInMS 
136f c9				ret 
1370			 
1370			tape_byte_gap: 
1370 cd 69 13			call tape_gap 
1373 cd 69 13			call tape_gap 
1376 cd 69 13			call tape_gap 
1379 cd 69 13			call tape_gap 
137c c9				ret 
137d			 
137d			; output a high period 
137d			 
137d			tape_high: 
137d 3a 89 f9			ld a, (tape_port) 
1380 4f				ld c, a 
1381 16 ff			ld d, 255 
1383 3a 88 f9			ld a, (tape_pulse_high) 
1386 47				ld b, a 
1387 2a 82 f9		.th:	ld hl, (tape_tm_high) 
138a cd 60 13			call tape_osc 
138d 10 f8			djnz .th 
138f c9				 ret 
1390			 
1390			; output a low period 
1390			 
1390			tape_low:  
1390			 
1390 3a 89 f9			ld a, (tape_port) 
1393 4f				ld c, a 
1394 16 ff			ld d, 255 
1396 3a 87 f9			ld a, (tape_pulse_low) 
1399 47				ld b, a 
139a 2a 82 f9		.tl:	ld hl, (tape_tm_high) 
139d			; keep the same pulse size and instead use count of pulse rather than length of pulse 
139d			;	ld hl, (tape_tm_low) 
139d cd 60 13			call tape_osc 
13a0 10 f8			djnz .tl 
13a2 c9				 ret 
13a3			 
13a3			; end of save marker 
13a3			 
13a3			tape_end: 
13a3 3e ff			ld a, 255 
13a5 cd bc 13			call tape_byte_out 
13a8 cd 70 13			call tape_byte_gap 
13ab			 
13ab 3e ff			ld a, 255 
13ad cd bc 13			call tape_byte_out 
13b0 cd 70 13			call tape_byte_gap 
13b3 3e ff			ld a, 255 
13b5 cd bc 13			call tape_byte_out 
13b8 cd 70 13			call tape_byte_gap 
13bb c9				 ret 
13bc			 
13bc			; output an encoded byte 
13bc			 
13bc			tape_byte_out: 
13bc				; a = byte to output 
13bc 06 08			ld b, 8 
13be 4f				ld c, a 
13bf			.tbo:    
13bf c5				push bc 
13c0 cb 79			bit 7, c 
13c2 28 05			jr z, .tbol 
13c4 cd 7d 13			call tape_high 
13c7 18 03			jr .tbn 
13c9			.tbol: 
13c9 cd 90 13			call tape_low 
