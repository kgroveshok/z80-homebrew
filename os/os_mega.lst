12e0			;	push hl     ; save where we are - 1  
12e0			 
12e0			;	inc hl  ; move past zero index  
12e0				; skip space to set down new marker 
12e0			 
12e0				; provide some extra space for now 
12e0			 
12e0				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12e0				inc a 
12e0				inc a 
