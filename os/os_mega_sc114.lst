8ed0			;------------------------------------------------------------------------------ 
8ed0			;     free                                                                    : 
8ed0			;                                                                             : 
8ed0			; Description                                                                 : 
8ed0			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8ed0			;     returned by malloc, otherwise the behaviour is undefined.               : 
8ed0			;                                                                             : 
8ed0			;     Where possible, directly adjacent free blocks will be merged together   : 
8ed0			;     into larger blocks to help ensure that the heap does not become         : 
8ed0			;     excessively fragmented.                                                 : 
8ed0			;                                                                             : 
8ed0			;     free does not clear or set any other value into the freed space, and    : 
8ed0			;     therefore its contents may be visible through subsequent malloc's. The  : 
8ed0			;     caller should clear the freed space as required.                        : 
8ed0			;                                                                             : 
8ed0			;     This implementation of free uses the stack exclusively, and is          : 
8ed0			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8ed0			;     advisable to disable interrupts before calling free, and recommended    : 
8ed0			;     to avoid the use of free inside ISRs in general.                        : 
8ed0			;                                                                             : 
8ed0			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8ed0			;                                                                             : 
8ed0			; Parameters                                                                  : 
8ed0			;     HL  Pointer to address of first byte of allocation to be freed          : 
8ed0			;                                                                             : 
8ed0			; Returns                                                                     : 
8ed0			;     Nothing                                                                 : 
8ed0			;                                                                             : 
8ed0			; Stack frame                                                                 : 
8ed0			;       |             |                                                       : 
8ed0			;       +-------------+                                                       : 
8ed0			;       |     BC      |                                                       : 
8ed0			;       +-------------+                                                       : 
8ed0			;       |     DE      |                                                       : 
8ed0			;       +-------------+                                                       : 
8ed0			;       |     IX      |                                                       : 
8ed0			;       +-------------+                                                       : 
8ed0			;       |  prev_free  |                                                       : 
8ed0			;   +2  +-------------+                                                       : 
8ed0			;       |  next_free  |                                                       : 
8ed0			;   +0  +-------------+                                                       : 
8ed0			;       |             |                                                       : 
8ed0			;                                                                             : 
8ed0			;------------------------------------------------------------------------------ 
8ed0			free: 
8ed0 c5			      push  BC 
8ed1 d5			      push  DE 
8ed2 dd e5		      push  IX 
8ed4			 
8ed4 7c			      ld    A, H                    ; Exit if ptr is null 
8ed5 b5			      or    L 
8ed6 ca 9a 8f		      jp    Z, free_early_exit 
