1192			.genfile: 
1192				push hl 
1192				push de 
1192			 
1192				call clear_display 
1192				ld a, display_row_1 
1192				ld de, .genfiletxt 
1192				call str_at_display 
1192				call update_display 
1192			 
1192				pop de 
1192				pop hl 
1192			 
1192			 
1192				push de 
1192				call storage_create 
1192				; id in hl 
1192				pop de   ; table of strings to add 
1192			 
1192			.genloop: 
1192			 
1192				push hl ; save id for next time around 
1192				push de ; save de for next time around 
1192			 
1192				ex de, hl 
1192				call loadwordinhl 
1192				ex de, hl 
1192			 
1192				; need hl to be the id 
1192				; need de to be the string ptr 
1192				 
1192				call storage_append 
1192			 
1192				pop de 
1192				pop hl 
1192			 
1192				inc de 
1192				inc de 
1192			 
1192				ld a,(de) 
1192				cp 0 
1192				jr nz, .genloop 
1192				inc de 
1192				ld a, (de) 
1192				dec de 
1192				cp 0 
1192				jr nz, .genloop	 
1192			 
1192				ret 
