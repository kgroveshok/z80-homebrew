a381 .. 00			db "BP",0              
a384				endm 
# End of macro CWHEAD
a384			; | BP ( u1 -- ) Enable or disable break point monitoring | DONE 
a384			; | | $00 Will enable the break points within specific code paths 
a384			; | | $01 Will disable break points 
a384			; | |  
a384			; | | By default break points are off. Either the above can be used to enable them 
a384			; | | or if a key is held down during start up the spashscreen will appear to freeze 
a384			; | | and on release of the pressed key the CONFIG menu will be displayed where you 
a384			; | | can disable break points. Exiting will then continue boot process. 
a384				; get byte count 
a384				if DEBUG_FORTH_WORDS_KEY 
a384					DMARK "BP." 
a384				if DEMARK_VERSION = 1  
a384 e5					push hl  
a385 21 8d a3				ld hl, .dmark  
a388 22 60 ee				ld (debug_mark), hl  
a38b				endif  
a38b				if DEMARK_VERSION = 0  
a38b					push af  
a38b					ld a, (.dmark)  
a38b					ld (debug_mark),a  
a38b					ld a, (.dmark+1)  
