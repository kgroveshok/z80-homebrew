89b2			; https://map.grauw.nl/articles/mult_div_shifts.php 
89b2			; Divide 16-bit values (with 16-bit result) 
89b2			; In: Divide BC by divider DE 
89b2			; Out: BC = result, HL = rest 
89b2			; 
89b2			Div16: 
89b2 21 00 00		    ld hl,0 
89b5 78			    ld a,b 
89b6 06 08		    ld b,8 
