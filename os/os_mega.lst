2b80			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2b80			; | | At start the current various registers will be displayed with contents. 
2b80			; | | Top right corner will show the most recent debug marker seen. 
2b80			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2b80			; | | and the return stack pointer (RSP). 
2b80			; | | Pressing: 
2b80			; | |  
2b80			; | |    1 - Initial screen 
2b80			; | |  
2b80			; | |    2 - Display a data dump of HL 
2b80			; | |  
2b80			; | |    3 - Display a data dump of DE 
2b80			; | |  
2b80			; | |    4 - Display a data dump of BC 
2b80			; | |  
2b80			; | |    5 - Display a data dump of HL 
2b80			; | |  
2b80			; | |    6 - Display a data dump of DSP 
2b80			; | |  
2b80			; | |    7 - Display a data dump of RSP 
2b80			; | |  
2b80			; | |    8 - Display a data dump of what is at DSP 
2b80			; | |  
2b80			; | |    9 - Display a data dump of what is at RSP 
2b80			; | |  
2b80			; | |    0 - Exit monitor and continue running. This will also enable break points 
2b80			; | |  
2b80			; | |    * - Disable break points 
2b80			; | |  
2b80			; | |    # - Enter traditional monitor mode 
2b80			; | |  
2b80			; | | 
2b80			; | | Monitor Mode 
2b80			; | | ------------ 
2b80			; | | A prompt of '>' will be shown for various commands: 
2b80			; | |  
2b80			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2b80			; | |  
2b80			; | |    C - Continue display a data dump from the last set address 
2b80			; | |  
2b80			; | |    M xxxx - Set start of memory edit at address xx 
2b80			; | |  
2b80			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2b80			; | |  
2b80			; | |    G xxxx - Exec code at specific address 
2b80			; | |  
2b80			; | |    Q - Return to previous 
2b80				if DEBUG_FORTH_WORDS_KEY 
2b80					DMARK "MON" 
2b80				if DEMARK_VERSION = 1  
2b80 e5					push hl  
2b81 21 89 2b				ld hl, .dmark  
2b84 22 9b fd				ld (debug_mark), hl  
2b87				endif  
