8053			;endif  
8053			  
8053			; Block 0 at offset $3b is a flag to decide to offer auto start up - 0 = prompt 1-auto run no prompt 2 - dont run  
8053			  
8053			STORE_0_AUTORUN: equ $20  
8053			  
8053			; Block 0 at offset $20+ holds the file number to run at system startup after the display  
