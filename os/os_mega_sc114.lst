8928			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
8928			; random number generators 
8928			 
8928			 
8928			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
8928			 
8928			 
8928			;-----> Generate a random number 
8928			; output a=answer 0<=a<=255 
8928			; all registers are preserved except: af 
8928			random: 
8928 e5			        push    hl 
8929 d5			        push    de 
892a 2a a0 eb		        ld      hl,(randData) 
892d ed 5f		        ld      a,r 
892f 57			        ld      d,a 
8930 5e			        ld      e,(hl) 
8931 19			        add     hl,de 
8932 85			        add     a,l 
8933 ac			        xor     h 
8934 22 a0 eb		        ld      (randData),hl 
8937 d1			        pop     de 
8938 e1			        pop     hl 
8939 c9			        ret 
893a			 
893a			 
893a			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
893a			 
893a			 
893a			 
893a			;------LFSR------ 
893a			;James Montelongo 
893a			;optimized by Spencer Putt 
893a			;out: 
893a			; a = 8 bit random number 
893a			RandLFSR: 
893a 21 a6 eb		        ld hl,LFSRSeed+4 
893d 5e			        ld e,(hl) 
893e 23			        inc hl 
893f 56			        ld d,(hl) 
8940 23			        inc hl 
8941 4e			        ld c,(hl) 
8942 23			        inc hl 
8943 7e			        ld a,(hl) 
8944 47			        ld b,a 
8945 cb 13		        rl e  
8947 cb 12			rl d 
8949 cb 11		        rl c  
894b 17				rla 
894c cb 13		        rl e  
894e cb 12			rl d 
8950 cb 11		        rl c  
8952 17				rla 
8953 cb 13		        rl e  
8955 cb 12			rl d 
8957 cb 11		        rl c  
8959 17				rla 
895a 67			        ld h,a 
895b cb 13		        rl e  
895d cb 12			rl d 
895f cb 11		        rl c  
8961 17				rla 
8962 a8			        xor b 
8963 cb 13		        rl e  
8965 cb 12			rl d 
8967 ac			        xor h 
8968 a9			        xor c 
8969 aa			        xor d 
896a 21 a8 eb		        ld hl,LFSRSeed+6 
896d 11 a9 eb		        ld de,LFSRSeed+7 
8970 01 07 00		        ld bc,7 
8973 ed b8		        lddr 
8975 12			        ld (de),a 
8976 c9			        ret 
8977			 
8977			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
8977			 
8977			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
8977			 
8977			 
8977			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
8977			 
8977			prng16: 
8977			;Inputs: 
8977			;   (seed1) contains a 16-bit seed value 
8977			;   (seed2) contains a NON-ZERO 16-bit seed value 
8977			;Outputs: 
8977			;   HL is the result 
8977			;   BC is the result of the LCG, so not that great of quality 
8977			;   DE is preserved 
8977			;Destroys: 
8977			;   AF 
8977			;cycle: 4,294,901,760 (almost 4.3 billion) 
8977			;160cc 
8977			;26 bytes 
8977 2a 9a eb		    ld hl,(seed1) 
897a 44			    ld b,h 
897b 4d			    ld c,l 
897c 29			    add hl,hl 
897d 29			    add hl,hl 
897e 2c			    inc l 
897f 09			    add hl,bc 
8980 22 9a eb		    ld (seed1),hl 
8983 2a 98 eb		    ld hl,(seed2) 
8986 29			    add hl,hl 
8987 9f			    sbc a,a 
8988 e6 2d		    and %00101101 
898a ad			    xor l 
898b 6f			    ld l,a 
898c 22 98 eb		    ld (seed2),hl 
898f 09			    add hl,bc 
8990 c9			    ret 
8991			 
8991			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
8991			 
8991			rand32: 
8991			;Inputs: 
8991			;   (seed1_0) holds the lower 16 bits of the first seed 
8991			;   (seed1_1) holds the upper 16 bits of the first seed 
8991			;   (seed2_0) holds the lower 16 bits of the second seed 
8991			;   (seed2_1) holds the upper 16 bits of the second seed 
8991			;   **NOTE: seed2 must be non-zero 
8991			;Outputs: 
8991			;   HL is the result 
8991			;   BC,DE can be used as lower quality values, but are not independent of HL. 
8991			;Destroys: 
8991			;   AF 
8991			;Tested and passes all CAcert tests 
8991			;Uses a very simple 32-bit LCG and 32-bit LFSR 
8991			;it has a period of 18,446,744,069,414,584,320 
8991			;roughly 18.4 quintillion. 
8991			;LFSR taps: 0,2,6,7  = 11000101 
8991			;291cc 
8991			;seed1_0=$+1 
8991			;    ld hl,12345 
8991			;seed1_1=$+1 
8991			;    ld de,6789 
8991			;    ld b,h 
8991			;    ld c,l 
8991			;    add hl,hl \ rl e \ rl d 
8991			;    add hl,hl \ rl e \ rl d 
8991			;    inc l 
8991			;    add hl,bc 
8991			;    ld (seed1_0),hl 
8991			;    ld hl,(seed1_1) 
8991			;    adc hl,de 
8991			;    ld (seed1_1),hl 
8991			;    ex de,hl 
8991			;seed2_0=$+1 
8991			;    ld hl,9876 
8991			;seed2_1=$+1 
8991			;    ld bc,54321 
8991			;    add hl,hl \ rl c \ rl b 
8991			;    ld (seed2_1),bc 
8991			;    sbc a,a 
8991			;    and %11000101 
8991			;    xor l 
8991			;    ld l,a 
8991			;    ld (seed2_0),hl 
8991			;    ex de,hl 
8991			;    add hl,bc 
8991			;    ret 
8991			; 
8991			 
8991			; 16-bit xorshift pseudorandom number generator by John Metcalf 
8991			; 20 bytes, 86 cycles (excluding ret) 
8991			 
8991			; returns   hl = pseudorandom number 
8991			; corrupts   a 
8991			 
8991			; generates 16-bit pseudorandom numbers with a period of 65535 
8991			; using the xorshift method: 
8991			 
8991			; hl ^= hl << 7 
8991			; hl ^= hl >> 9 
8991			; hl ^= hl << 8 
8991			 
8991			; some alternative shift triplets which also perform well are: 
8991			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
8991			 
8991			;  org 32768 
8991			 
8991			xrnd: 
8991 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
8994 3e 00		  ld a,0 
8996 bd			  cp l 
8997 20 02		  jr nz, .xrnd1 
8999 2e 01		  ld l, 1 
899b			.xrnd1: 
899b			 
899b 7c			  ld a,h 
899c 1f			  rra 
899d 7d			  ld a,l 
899e 1f			  rra 
899f ac			  xor h 
89a0 67			  ld h,a 
89a1 7d			  ld a,l 
89a2 1f			  rra 
89a3 7c			  ld a,h 
89a4 1f			  rra 
89a5 ad			  xor l 
89a6 6f			  ld l,a 
89a7 ac			  xor h 
89a8 67			  ld h,a 
89a9			 
89a9 22 9e eb		  ld (xrandc),hl 
89ac			 
89ac c9			  ret 
