9dae			.HEAP: 
9dae			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9dae 15				db WORD_SYS_CORE+OPCODE_HEAP             
9daf dc 9d			dw .EXEC            
9db1 05				db 4 + 1 
9db2 .. 00			db "HEAP",0              
9db7				endm 
# End of macro CWHEAD
9db7			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9db7			; | | u1 - Current number of bytes in the heap 
9db7			; | | u2 - Remaining bytes left on the heap 
9db7			; | |  
9db7			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9db7			 
9db7			 
9db7				if DEBUG_FORTH_WORDS_KEY 
9db7					DMARK "HEP" 
9db7				if DEMARK_VERSION = 1  
9db7 e5					push hl  
9db8 21 c0 9d				ld hl, .dmark  
9dbb 22 60 ee				ld (debug_mark), hl  
9dbe				endif  
9dbe				if DEMARK_VERSION = 0  
9dbe					push af  
9dbe					ld a, (.dmark)  
9dbe					ld (debug_mark),a  
9dbe					ld a, (.dmark+1)  
9dbe					ld (debug_mark+1),a  
9dbe					ld a, (.dmark+2)  
9dbe					ld (debug_mark+2),a  
9dbe				endif  
9dbe 18 04			jr .pastdmark  
9dc0 ..			.dmark: db "HEP"  
9dc3				if DEMARK_VERSION = 1  
9dc3 00					db 0  
9dc4				endif  
9dc4				if DEMARK_VERSION = 1  
9dc4 e1			.pastdmark: pop hl  
9dc5				endif  
9dc5				if DEMARK_VERSION = 0  
9dc5			.pastdmark: pop af  
9dc5				endif  
9dc5			endm  
# End of macro DMARK
9dc5					CALLMONITOR 
9dc5				if BASE_CPM=1  
9dc5					call debug_vector  
9dc5				endif  
9dc5				if BASE_KEV=1  
9dc5					rst 8  
9dc5				endif  
9dc5				endm  
# End of macro CALLMONITOR
9dc5				endif 
