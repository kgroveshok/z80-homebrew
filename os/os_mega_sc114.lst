d427			include "forth_startup.asm" 
d427			; Which startup method to use? 
d427			; 
d427			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
d427			; followed by loading of a list of scripts in eeprom 
d427			 
d427			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
d427			; from eeprom 
d427			 
d427			; Select with define in main stubs 
d427			 
d427			if STARTUP_V1 
d427				include "forth_startupv1.asm" 
d427			; Startup script loading version 1 
d427			 
d427			; If SE storage is available first stage is to use the selected file 
d427			; then go through the eeprom list 
d427			 
d427 .. 00		sprompt1: db "Startup load...",0 
d437 .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
