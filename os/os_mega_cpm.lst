1d7f			.NEW: 
1d7f			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
1d7f 15				db WORD_SYS_CORE+OPCODE_HEAP             
1d80 99 1d			dw .HEAP            
1d82 04				db 3 + 1 
1d83 .. 00			db "NEW",0              
1d87				endm 
# End of macro CWHEAD
1d87			; | NEW ( -- ) Clears all user words and stack | DONE 
1d87				 
1d87				if MALLOC_4 
1d87					call  heap_init 
1d87				endif 
1d87				; reset uword pointers 
1d87 21 19 5b			ld hl, baseram 
1d8a 22 9a e5			ld (os_last_new_uword), hl 
1d8d cd d3 1b			call user_word_eol 
1d90				; clear stack 
1d90 cd ec 1b			call forth_warmstart 
1d93				NEXTW 
1d93 cd 68 ee			call parse_vector 
1d96 c3 46 1c			jp macro_next 
1d99				endm 
# End of macro NEXTW
1d99			 
1d99			.HEAP: 
1d99			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
1d99 15				db WORD_SYS_CORE+OPCODE_HEAP             
1d9a d0 1d			dw .EXEC            
1d9c 05				db 4 + 1 
1d9d .. 00			db "HEAP",0              
1da2				endm 
# End of macro CWHEAD
1da2			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
1da2			; | | u1 - Current number of bytes in the heap 
1da2			; | | u2 - Remaining bytes left on the heap 
1da2			; | |  
1da2			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
1da2			 
1da2			 
1da2				if DEBUG_FORTH_WORDS_KEY 
1da2					DMARK "HEP" 
1da2				if DEMARK_VERSION = 1  
1da2 e5					push hl  
1da3 21 ab 1d				ld hl, .dmark  
1da6 22 60 ee				ld (debug_mark), hl  
1da9				endif  
1da9				if DEMARK_VERSION = 0  
1da9					push af  
1da9					ld a, (.dmark)  
1da9					ld (debug_mark),a  
1da9					ld a, (.dmark+1)  
1da9					ld (debug_mark+1),a  
1da9					ld a, (.dmark+2)  
1da9					ld (debug_mark+2),a  
1da9				endif  
1da9 18 04			jr .pastdmark  
1dab ..			.dmark: db "HEP"  
1dae				if DEMARK_VERSION = 1  
1dae 00					db 0  
1daf				endif  
1daf				if DEMARK_VERSION = 1  
1daf e1			.pastdmark: pop hl  
1db0				endif  
1db0				if DEMARK_VERSION = 0  
1db0			.pastdmark: pop af  
1db0				endif  
1db0			endm  
# End of macro DMARK
1db0					CALLMONITOR 
1db0				if BASE_CPM=1  
1db0 cd 6b ee				call debug_vector  
1db3				endif  
1db3				if BASE_KEV=1  
1db3					rst 8  
1db3				endif  
1db3				endm  
# End of macro CALLMONITOR
1db3				endif 
1db3 2a 23 5b			ld hl, (free_list )      
1db6 11 28 5b			ld de, heap_start 
1db9			 
1db9 ed 52			sbc hl, de  
