0c53			;-----> Generate a random number 
0c53			; output a=answer 0<=a<=255 
0c53			; all registers are preserved except: af 
0c53			random: 
0c53 e5			        push    hl 
0c54 d5			        push    de 
0c55 2a db fa		        ld      hl,(randData) 
0c58 ed 5f		        ld      a,r 
0c5a 57			        ld      d,a 
0c5b 5e			        ld      e,(hl) 
0c5c 19			        add     hl,de 
0c5d 85			        add     a,l 
0c5e ac			        xor     h 
0c5f 22 db fa		        ld      (randData),hl 
0c62 d1			        pop     de 
0c63 e1			        pop     hl 
0c64 c9			        ret 
0c65			 
0c65			 
0c65			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0c65			 
0c65			 
0c65			 
0c65			;------LFSR------ 
0c65			;James Montelongo 
0c65			;optimized by Spencer Putt 
0c65			;out: 
0c65			; a = 8 bit random number 
0c65			RandLFSR: 
0c65 21 e1 fa		        ld hl,LFSRSeed+4 
0c68 5e			        ld e,(hl) 
0c69 23			        inc hl 
0c6a 56			        ld d,(hl) 
0c6b 23			        inc hl 
0c6c 4e			        ld c,(hl) 
0c6d 23			        inc hl 
0c6e 7e			        ld a,(hl) 
0c6f 47			        ld b,a 
0c70 cb 13		        rl e  
0c72 cb 12			rl d 
0c74 cb 11		        rl c  
0c76 17				rla 
0c77 cb 13		        rl e  
0c79 cb 12			rl d 
0c7b cb 11		        rl c  
0c7d 17				rla 
0c7e cb 13		        rl e  
0c80 cb 12			rl d 
0c82 cb 11		        rl c  
0c84 17				rla 
0c85 67			        ld h,a 
0c86 cb 13		        rl e  
0c88 cb 12			rl d 
0c8a cb 11		        rl c  
0c8c 17				rla 
0c8d a8			        xor b 
0c8e cb 13		        rl e  
0c90 cb 12			rl d 
0c92 ac			        xor h 
0c93 a9			        xor c 
0c94 aa			        xor d 
0c95 21 e3 fa		        ld hl,LFSRSeed+6 
0c98 11 e4 fa		        ld de,LFSRSeed+7 
0c9b 01 07 00		        ld bc,7 
0c9e ed b8		        lddr 
0ca0 12			        ld (de),a 
0ca1 c9			        ret 
0ca2			 
0ca2			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0ca2			 
0ca2			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0ca2			 
0ca2			 
0ca2			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0ca2			 
0ca2			prng16: 
0ca2			;Inputs: 
0ca2			;   (seed1) contains a 16-bit seed value 
0ca2			;   (seed2) contains a NON-ZERO 16-bit seed value 
0ca2			;Outputs: 
0ca2			;   HL is the result 
0ca2			;   BC is the result of the LCG, so not that great of quality 
0ca2			;   DE is preserved 
0ca2			;Destroys: 
0ca2			;   AF 
0ca2			;cycle: 4,294,901,760 (almost 4.3 billion) 
0ca2			;160cc 
0ca2			;26 bytes 
0ca2 2a d5 fa		    ld hl,(seed1) 
0ca5 44			    ld b,h 
0ca6 4d			    ld c,l 
0ca7 29			    add hl,hl 
0ca8 29			    add hl,hl 
0ca9 2c			    inc l 
0caa 09			    add hl,bc 
0cab 22 d5 fa		    ld (seed1),hl 
0cae 2a d3 fa		    ld hl,(seed2) 
0cb1 29			    add hl,hl 
0cb2 9f			    sbc a,a 
0cb3 e6 2d		    and %00101101 
0cb5 ad			    xor l 
0cb6 6f			    ld l,a 
0cb7 22 d3 fa		    ld (seed2),hl 
0cba 09			    add hl,bc 
0cbb c9			    ret 
0cbc			 
0cbc			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0cbc			 
0cbc			rand32: 
0cbc			;Inputs: 
0cbc			;   (seed1_0) holds the lower 16 bits of the first seed 
0cbc			;   (seed1_1) holds the upper 16 bits of the first seed 
0cbc			;   (seed2_0) holds the lower 16 bits of the second seed 
0cbc			;   (seed2_1) holds the upper 16 bits of the second seed 
0cbc			;   **NOTE: seed2 must be non-zero 
0cbc			;Outputs: 
0cbc			;   HL is the result 
0cbc			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0cbc			;Destroys: 
0cbc			;   AF 
0cbc			;Tested and passes all CAcert tests 
0cbc			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0cbc			;it has a period of 18,446,744,069,414,584,320 
0cbc			;roughly 18.4 quintillion. 
0cbc			;LFSR taps: 0,2,6,7  = 11000101 
0cbc			;291cc 
0cbc			;seed1_0=$+1 
0cbc			;    ld hl,12345 
0cbc			;seed1_1=$+1 
0cbc			;    ld de,6789 
0cbc			;    ld b,h 
0cbc			;    ld c,l 
0cbc			;    add hl,hl \ rl e \ rl d 
0cbc			;    add hl,hl \ rl e \ rl d 
0cbc			;    inc l 
0cbc			;    add hl,bc 
0cbc			;    ld (seed1_0),hl 
0cbc			;    ld hl,(seed1_1) 
0cbc			;    adc hl,de 
0cbc			;    ld (seed1_1),hl 
0cbc			;    ex de,hl 
0cbc			;seed2_0=$+1 
0cbc			;    ld hl,9876 
0cbc			;seed2_1=$+1 
0cbc			;    ld bc,54321 
0cbc			;    add hl,hl \ rl c \ rl b 
0cbc			;    ld (seed2_1),bc 
0cbc			;    sbc a,a 
0cbc			;    and %11000101 
0cbc			;    xor l 
0cbc			;    ld l,a 
0cbc			;    ld (seed2_0),hl 
0cbc			;    ex de,hl 
0cbc			;    add hl,bc 
0cbc			;    ret 
0cbc			; 
0cbc			 
0cbc			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0cbc			; 20 bytes, 86 cycles (excluding ret) 
0cbc			 
0cbc			; returns   hl = pseudorandom number 
0cbc			; corrupts   a 
0cbc			 
0cbc			; generates 16-bit pseudorandom numbers with a period of 65535 
0cbc			; using the xorshift method: 
0cbc			 
0cbc			; hl ^= hl << 7 
0cbc			; hl ^= hl >> 9 
0cbc			; hl ^= hl << 8 
0cbc			 
0cbc			; some alternative shift triplets which also perform well are: 
0cbc			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0cbc			 
0cbc			;  org 32768 
0cbc			 
0cbc			xrnd: 
0cbc 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0cbf 3e 00		  ld a,0 
0cc1 bd			  cp l 
0cc2 20 02		  jr nz, .xrnd1 
0cc4 2e 01		  ld l, 1 
0cc6			.xrnd1: 
0cc6			 
0cc6 7c			  ld a,h 
0cc7 1f			  rra 
0cc8 7d			  ld a,l 
0cc9 1f			  rra 
0cca ac			  xor h 
0ccb 67			  ld h,a 
0ccc 7d			  ld a,l 
0ccd 1f			  rra 
0cce 7c			  ld a,h 
0ccf 1f			  rra 
0cd0 ad			  xor l 
0cd1 6f			  ld l,a 
0cd2 ac			  xor h 
0cd3 67			  ld h,a 
0cd4			 
0cd4 22 d9 fa		  ld (xrandc),hl 
0cd7			 
0cd7 c9			  ret 
