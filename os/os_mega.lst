6b24			; Position cursor to specified location  
6b24			;   On entry: A = Cursor position  
6b24			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6b24 f5			fLCD_Pos:   PUSH AF  
6b25					; at this point set the E1 or E2 flag depending on position  
6b25			  
6b25 c5					push bc  
6b26			;		push af  
6b26 06 00				ld b, 0  
6b28 4f					ld c, a  
6b29 3e 4f				ld a, kLCD_Line3-1  
6b2b b7			 		or a      ;clear carry flag  
6b2c 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6b2d 38 04				jr c, .pe1  
6b2f			  
6b2f					; E selection  
6b2f cb 80				res 0, b         ; bit 0 unset e  
6b31			;		pop af    ; before line 3 so recover orig pos  
6b31			;		ld c, a    ; save for poking back  
6b31 18 06				jr .peset	          
6b33			.pe1:          	; E2 selection  
6b33 cb c0				set 0, b         ; bit 0 set e1  
6b35 79					ld a, c  
6b36 de 4f				sbc a, kLCD_Line3-1  
6b38 4f					ld c, a	         ; save caculated offset  
6b39			;		pop af     ; bin this original value now we have calculated form  
6b39			  
6b39			.peset:		; set bit  
6b39 78					ld a, b  
6b3a 32 fb fa				ld (display_lcde1e2), a 	  
6b3d 79					ld a, c  
6b3e c1					pop bc  
6b3f			  
6b3f f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6b41 cd 94 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6b44 f1			            POP  AF  
6b45 c9			            RET  
