a6c3			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a6c3			; | | At start the current various registers will be displayed with contents. 
a6c3			; | | Top right corner will show the most recent debug marker seen. 
a6c3			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a6c3			; | | and the return stack pointer (RSP). 
a6c3			; | | Pressing: 
a6c3			; | |  
a6c3			; | |    1 - Initial screen 
a6c3			; | |  
a6c3			; | |    2 - Display a data dump of HL 
a6c3			; | |  
a6c3			; | |    3 - Display a data dump of DE 
a6c3			; | |  
a6c3			; | |    4 - Display a data dump of BC 
a6c3			; | |  
a6c3			; | |    5 - Display a data dump of HL 
a6c3			; | |  
a6c3			; | |    6 - Display a data dump of DSP 
a6c3			; | |  
a6c3			; | |    7 - Display a data dump of RSP 
a6c3			; | |  
a6c3			; | |    8 - Display a data dump of what is at DSP 
a6c3			; | |  
a6c3			; | |    9 - Display a data dump of what is at RSP 
a6c3			; | |  
a6c3			; | |    0 - Exit monitor and continue running. This will also enable break points 
a6c3			; | |  
a6c3			; | |    * - Disable break points 
a6c3			; | |  
a6c3			; | |    # - Enter traditional monitor mode 
a6c3			; | |  
a6c3			; | | 
a6c3			; | | Monitor Mode 
a6c3			; | | ------------ 
a6c3			; | | A prompt of '>' will be shown for various commands: 
a6c3			; | |  
a6c3			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a6c3			; | |  
a6c3			; | |    C - Continue display a data dump from the last set address 
a6c3			; | |  
a6c3			; | |    M xxxx - Set start of memory edit at address xx 
a6c3			; | |  
a6c3			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a6c3			; | |  
a6c3			; | |    G xxxx - Exec code at specific address 
a6c3			; | |  
a6c3			; | |    Q - Return to previous 
a6c3				if DEBUG_FORTH_WORDS_KEY 
a6c3					DMARK "MON" 
a6c3 f5				push af  
a6c4 3a d8 a6			ld a, (.dmark)  
a6c7 32 5e ee			ld (debug_mark),a  
a6ca 3a d9 a6			ld a, (.dmark+1)  
a6cd 32 5f ee			ld (debug_mark+1),a  
a6d0 3a da a6			ld a, (.dmark+2)  
a6d3 32 60 ee			ld (debug_mark+2),a  
a6d6 18 03			jr .pastdmark  
a6d8 ..			.dmark: db "MON"  
a6db f1			.pastdmark: pop af  
a6dc			endm  
# End of macro DMARK
a6dc					CALLMONITOR 
a6dc				if BASE_CPM=1  
a6dc					call debug_vector  
a6dc				endif  
a6dc				if BASE_KEV=1  
a6dc					rst 8  
a6dc				endif  
a6dc				endm  
# End of macro CALLMONITOR
a6dc				endif 
a6dc			;		ld a, 0 
a6dc			;		ld (os_view_disable), a 
a6dc cd e3 92			call bp_on 
a6df			 
a6df				CALLMONITOR 
a6df				if BASE_CPM=1  
a6df					call debug_vector  
a6df				endif  
a6df				if BASE_KEV=1  
a6df					rst 8  
a6df				endif  
