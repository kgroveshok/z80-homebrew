bf80					ld a, (.dmark+1)  
bf80					ld (debug_mark+1),a  
bf80					ld a, (.dmark+2)  
bf80					ld (debug_mark+2),a  
bf80				endif  
bf80 18 04			jr .pastdmark  
bf82 ..			.dmark: db "VAR"  
bf85				if DEMARK_VERSION = 1  
bf85 00					db 0  
bf86				endif  
bf86				if DEMARK_VERSION = 1  
bf86 e1			.pastdmark: pop hl  
bf87				endif  
bf87				if DEMARK_VERSION = 0  
bf87			.pastdmark: pop af  
bf87				endif  
bf87			endm  
# End of macro DMARK
