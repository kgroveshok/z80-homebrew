1284			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1284			 
1284			;written by Zeda 
1284			;Converts a 16-bit unsigned integer to an ASCII string. 
1284			 
1284			uitoa_16: 
1284			;Input: 
1284			;   DE is the number to convert 
1284			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1284			;Output: 
1284			;   HL points to the null-terminated ASCII string 
1284			;      NOTE: This isn't necessarily the same as the input HL. 
1284 d5			  push de 
1285 c5			  push bc 
1286 f5			  push af 
1287 eb			  ex de,hl 
1288			 
1288 01 f0 d8		  ld bc,-10000 
128b 3e 2f		  ld a,'0'-1 
128d 3c			  inc a 
128e 09			  add hl,bc  
128f 38 fc		   jr c,$-2 
1291 12			  ld (de),a 
1292 13			  inc de 
1293			 
1293 01 e8 03		  ld bc,1000 
1296 3e 3a		  ld a,'9'+1 
1298 3d			  dec a  
1299 09			  add hl,bc  
129a 30 fc		   jr nc,$-2 
129c 12			  ld (de),a 
129d 13			  inc de 
129e			 
129e 01 9c ff		  ld bc,-100 
12a1 3e 2f		  ld a,'0'-1 
12a3 3c			  inc a  
12a4 09			  add hl,bc  
12a5 38 fc		   jr c,$-2 
12a7 12			  ld (de),a 
12a8 13			  inc de 
12a9			 
12a9 7d			  ld a,l 
12aa 26 3a		  ld h,'9'+1 
12ac 25			  dec h  
12ad c6 0a		  add a,10  
12af 30 fb		   jr nc,$-3 
12b1 c6 30		  add a,'0' 
12b3 eb			  ex de,hl 
12b4 72			  ld (hl),d 
12b5 23			  inc hl 
12b6 77			  ld (hl),a 
12b7 23			  inc hl 
12b8 36 00		  ld (hl),0 
12ba			 
12ba			;Now strip the leading zeros 
12ba 0e fa		  ld c,-6 
12bc 09			  add hl,bc 
12bd 3e 30		  ld a,'0' 
12bf 23			  inc hl  
12c0 be			  cp (hl)  
12c1 28 fc		  jr z,$-2 
12c3			 
12c3			;Make sure that the string is non-empty! 
12c3 7e			  ld a,(hl) 
12c4 b7			  or a 
12c5 20 01		  jr nz,.atoub 
12c7 2b			  dec hl 
12c8			.atoub: 
12c8			 
12c8 f1			  pop af 
12c9 c1			  pop bc 
12ca d1			  pop de 
12cb c9			  ret 
