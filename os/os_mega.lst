1368			tape_ready_load:  
1368			 
1368 21 84 13			ld hl, trr3 
136b 11 96 13			ld de, trr2 
136e cd c1 0a			call info_panel 
1371 c9				ret 
1372			 
1372 .. 00		trr1: db "Start recorder...",0 
1384 .. 00		trr3: db "Start playback...",0 
1396 .. 00		trr2: db "Press any key when ready.",0 
13b0 .. 00		trr4: db "Tape operation in progesss...", 0 
13ce			 
13ce			 
13ce			; Tape Input 
13ce			 
13ce			; Perform a save to tape 
13ce			 
13ce			; hl - string to output 
13ce			; de - file name 
13ce			 
13ce			tape_save:  
13ce			 
13ce e5				push hl 
13cf d5				push de 
13d0			 
13d0				; prompt to ready tape and press any key 
13d0			 
13d0 cd 5e 13			call tape_ready_rec 
13d3 cd 2f 0b			call clear_display 
13d6			 
13d6 3e 04			ld a, 4  
