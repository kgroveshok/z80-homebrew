8a3a			;DE_Div_BC:          ;1281-2x, x is at most 16 
8a3a			;     ld a,16        ;7 
8a3a			;     ld hl,0        ;10 
8a3a			;     jp $+5         ;10 
8a3a			;.DivLoop: 
