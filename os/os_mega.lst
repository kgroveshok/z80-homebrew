0ffc			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
0ffc			 
0ffc			 
0ffc			;Converts an ASCII string to an unsigned 16-bit integer 
0ffc			;Quits when it reaches a non-decimal digit 
0ffc			 
0ffc			string_to_uint16: 
0ffc			atoui_16: 
0ffc			;Input: 
0ffc			;     DE points to the string 
0ffc			;Outputs: 
0ffc			;     HL is the result 
0ffc			;     A is the 8-bit value of the number 
0ffc			;     DE points to the byte after the number 
0ffc			;Destroys: 
0ffc			;     BC 
0ffc			;       if the string is non-empty, BC is HL/10 
0ffc			;Size:  24 bytes 
0ffc			;Speed: 42+d(104+{0,9}) 
0ffc			;       d is the number of digits in the number 
0ffc			;       max is 640 cycles for a 5 digit number 
0ffc			;Assuming no leading zeros: 
0ffc			;1 digit:  146cc 
0ffc			;2 digit:  250cc 
0ffc			;3 digit:  354cc or 363cc (avg: 354.126cc) 
0ffc			;4 digit:  458cc or 467cc (avg: 458.27cc) 
0ffc			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
0ffc			;avg: 544.81158447265625cc (544+13297/16384) 
0ffc			;=============================================================== 
0ffc 21 00 00		  ld hl,0 
0fff			.u16a: 
0fff 1a			  ld a,(de) 
1000 d6 30		  sub 30h 
1002 fe 0a		  cp 10 
1004 d0			  ret nc 
1005 13			  inc de 
1006 44			  ld b,h 
1007 4d			  ld c,l 
1008 29			  add hl,hl 
1009 29			  add hl,hl 
100a 09			  add hl,bc 
100b 29			  add hl,hl 
100c 85			  add a,l 
100d 6f			  ld l,a 
100e 30 ef		  jr nc,.u16a 
1010 24			  inc h 
1011 c3 ff 0f		  jp .u16a 
