110a			malloc_guard_zerolen: 
110a				push hl 
110a				push de 
110a				push af 
110a			 
110a				ld de, 0 
110a			        call cmp16 
110a				jr nz, .lowalloz 
110a			 
110a				push hl 
110a				push de 
110a					ld hl, display_fb0 
110a					ld (display_fb_active), hl 
110a				call clear_display 
110a				ld a, 0 
110a				ld de, .malloczero 
110a				call str_at_display 
110a				call update_display 
110a				call delay1s 
110a				call delay1s 
110a				call bp_on 
110a			;	ld a, 0 
110a			;	ld (os_view_disable), a 
110a			 
110a				pop de 
110a				pop hl 
110a			 
110a				 
110a			 
110a				CALLMONITOR 
110a			.lowalloz: 
110a			 
110a			 
110a				pop af 
110a				pop de 
110a				pop hl 
110a			ret 
110a			 
110a			malloc_guard_entry: 
110a				push hl 
110a				push de 
110a				push af 
110a			 
110a			 	or a      ;clear carry flag 
110a				push hl 
110a				ld de, 255 
110a				sbc hl, de 
110a				jr c, .lowalloc 
110a			 
110a				push de 
110a					ld hl, display_fb0 
110a					ld (display_fb_active), hl 
110a				call clear_display 
110a				ld a, 0 
110a				ld de, .mallocsize 
110a				call str_at_display 
110a				call update_display 
110a				call delay1s 
110a				call delay1s 
110a			;	ld a, 0 
110a			;	ld (os_view_disable), a 
110a				call bp_on 
110a			 
110a				pop de 
110a				pop hl 
110a			 
110a				 
110a			 
110a				CALLMONITOR 
110a				jr .lowdone 
110a			.lowalloc: 
110a			 
110a			 
110a				pop hl 
110a			.lowdone:	pop af 
110a				pop de 
110a				pop hl 
110a			ret 
110a			 
110a			malloc_guard_exit: 
110a				push hl 
110a				push de 
110a				push af 
110a			 
110a			 	or a      ;clear carry flag 
110a				push hl 
110a				ld de, 255 
110a				sbc hl, de 
110a				jr c, .lowallocx 
110a			 
110a				push de 
110a					ld hl, display_fb0 
110a					ld (display_fb_active), hl 
110a				call clear_display 
110a				ld a, 0 
110a				ld de, .mallocasize 
110a				call str_at_display 
110a				call update_display 
110a				call delay1s 
110a				call delay1s 
110a			;	ld a, 0 
110a			;	ld (os_view_disable), a 
110a				call bp_on 
110a				pop de 
110a				pop hl 
110a			 
110a				CALLMONITOR 
110a				jr .lowdonex 
110a			.lowallocx: 
110a			 
110a				pop hl 
110a			.lowdonex:	pop af 
110a				pop de 
110a				pop hl 
110a			ret 
110a			endif 
