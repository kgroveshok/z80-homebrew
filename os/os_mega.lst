15e9			 
15e9			; Device support for SN76489AN sound chip 
15e9			 
15e9			; https://arduinoplusplus.wordpress.com/2019/10/05/making-noise-with-a-sn76489-digital-sound-generator-part-1/ 
15e9			; http://danceswithferrets.org/geekblog/?p=93 
15e9			; https://www.smspower.org/Development/SN76489 
15e9			 
15e9			; D0 [ 3] 
15e9			; D1 [ 2] 
15e9			; D2 [ 1] 
15e9			; D3 [15] 
15e9			; D4 [13] 
15e9			; D5 [12] 
15e9			; D6 [11] 
15e9			; D7 [10] 
15e9			; /WE [ 5] 
15e9			; CLK [14] 
15e9			; /OE [ 6] 
15e9			; AUDIO [ 7] 
15e9			; GND 8 
15e9			; +5 16 
15e9			; 
15e9			 
15e9			; Write sequence: 
15e9			; CE low 
15e9			; Data bus 
15e9			; WE low then high 
15e9			; 32 clock cycles / 8ns write time at 4mhz 
15e9			; 
15e9			; https://github.com/jblang/SN76489 
15e9			; Shows that the clock needs to be enabled when required. Noticed that with the clock connected it interupted the bus 
15e9			; Tried: 
15e9			; 
15e9			; CE/OE -> Both pins of NAND -> To one pin of second NAND and second pin to full clock -> CLK on chip 
15e9			; 
15e9			; Connected WE to OR too 
15e9			;  
15e9			; That enabled the clock when required 
15e9			; However still random bus corruption. Need further investigation 
15e9			 
15e9			 
15e9			SOUND_LATCH: equ 10000000B 
15e9			SOUND_DATA: equ 0B 
15e9			SOUND_CH0:  equ 0B    ; Tone 
15e9			SOUND_CH1: equ 0100000B        ; Tone 
15e9			SOUND_CH2: equ 1000000B   ; Tone 
15e9			SOUND_CH3: equ 1100000B    ; Noise 
15e9			SOUND_VOL: equ 10000B 
15e9			SOUND_TONE: equ 0B 
15e9			 
15e9			 
15e9 c9			sound_init: ret 
