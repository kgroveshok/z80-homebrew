232a 36 00			ld (hl), WORD_SYS_ROOT		; word id 
232c 23				inc hl 
232d			 
232d 11 d6 24			ld de, sysdict 
2330 73				ld (hl), e		; next word link ie system dict 
2331 23				inc hl 
2332 72				ld (hl), d		; next word link ie system dict 
2333 23				inc hl	 
2334			 
2334			;	ld (hl), sysdict		; next word link ie system dict 
2334			;	inc hl 
2334			;	inc hl 
2334			 
2334			;	inc hl 
2334			;	inc hl 
2334			 
2334			;	ld a, 2			; word length is 0 
2334 36 02			ld (hl), 2 
2336 23				inc hl 
2337			 
2337			;	ld a, '~'			; word length is 0 
2337 36 7e			ld (hl), '~' 
2339 23				inc hl 
233a			;	ld a, 0			; save empty word 
233a 36 00			ld (hl), 0 
233c			 
