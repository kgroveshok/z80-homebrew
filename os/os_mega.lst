6863 cd 55 69		            CALL fLCD_Pos       ;Position cursor to location in A  
6866 06 28			ld b, display_cols  
6868 ed 5b f9 fa		ld de, (display_write_tmp)  
686c cd a0 68			call write_len_string  
686f				  
686f 2a f9 fa			ld hl, (display_write_tmp)  
6872 11 28 00			ld de, display_cols  
6875 19				add hl,de  
6876 22 f9 fa			ld (display_write_tmp),hl  
6879			  
6879				  
6879 3e 50			ld a, kLCD_Line3  
687b cd 55 69		            CALL fLCD_Pos       ;Position cursor to location in A  
687e 06 28			ld b, display_cols  
6880 ed 5b f9 fa		ld de, (display_write_tmp)  
6884 cd a0 68			call write_len_string  
6887				  
6887 2a f9 fa			ld hl, (display_write_tmp)  
688a 11 28 00			ld de, display_cols  
688d 19				add hl,de  
688e 22 f9 fa			ld (display_write_tmp),hl  
6891			  
6891				  
6891 3e 78			ld a, kLCD_Line4  
6893 cd 55 69		            CALL fLCD_Pos       ;Position cursor to location in A  
6896 06 28			ld b, display_cols  
6898 ed 5b f9 fa		ld de, (display_write_tmp)  
689c cd a0 68			call write_len_string  
689f c9					ret  
68a0				  
68a0				; write out a fixed length string given in b from de  
68a0			  
68a0 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
68a1 cd 0d 69		            CALL fLCD_Data      ;Write character to display  
68a4 13				inc de  
68a5 10 f9			djnz write_len_string  
68a7 c9				ret  
