117e			.selbank: 
117e			 
117e			if STARTUP_V2 
117e			;	if STORAGE_SE 
117e			;	else 
117e			 
117e				ld hl, prom_banks 
117e				call menu 
117e				cp 0 
117e				ret z 
117e				 
117e				; set the bank number from the result 
117e			 
117e				 
117e					ld c, SPI_CE_HIGH 
117e					ld b, '0'    ; human readable bank number 
117e			 
117e			 
117e					; active low 
117e			 
117e			;		cp 0 
117e					or a 
117e					jr z, .bset 
117e					cp 1 
117e					jr nz, .b2 
117e					res 0, c 
117e					ld b, '1'    ; human readable bank number 
117e			.b2:		cp 2 
117e					jr nz, .b3 
117e					res 1, c 
117e					ld b, '2'    ; human readable bank number 
117e			.b3:		cp 3 
117e					jr nz, .b4 
117e					res 2, c 
117e					ld b, '3'    ; human readable bank number 
117e			.b4:		cp 4 
117e					jr nz, .b5 
117e					res 3, c 
117e					ld b, '4'    ; human readable bank number 
117e			.b5:		cp 5 
117e					jr nz, .bset 
117e					res 4, c 
117e					ld b, '5'    ; human readable bank number 
117e			 
117e			.bset: 
117e			 
