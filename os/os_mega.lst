0c19			;-----> Generate a random number 
0c19			; output a=answer 0<=a<=255 
0c19			; all registers are preserved except: af 
0c19			random: 
0c19 e5			        push    hl 
0c1a d5			        push    de 
0c1b 2a db fa		        ld      hl,(randData) 
0c1e ed 5f		        ld      a,r 
0c20 57			        ld      d,a 
0c21 5e			        ld      e,(hl) 
0c22 19			        add     hl,de 
0c23 85			        add     a,l 
0c24 ac			        xor     h 
0c25 22 db fa		        ld      (randData),hl 
0c28 d1			        pop     de 
0c29 e1			        pop     hl 
0c2a c9			        ret 
0c2b			 
0c2b			 
0c2b			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0c2b			 
0c2b			 
0c2b			 
0c2b			;------LFSR------ 
0c2b			;James Montelongo 
0c2b			;optimized by Spencer Putt 
0c2b			;out: 
0c2b			; a = 8 bit random number 
0c2b			RandLFSR: 
0c2b 21 e1 fa		        ld hl,LFSRSeed+4 
0c2e 5e			        ld e,(hl) 
0c2f 23			        inc hl 
0c30 56			        ld d,(hl) 
0c31 23			        inc hl 
0c32 4e			        ld c,(hl) 
0c33 23			        inc hl 
0c34 7e			        ld a,(hl) 
0c35 47			        ld b,a 
0c36 cb 13		        rl e  
0c38 cb 12			rl d 
0c3a cb 11		        rl c  
0c3c 17				rla 
0c3d cb 13		        rl e  
0c3f cb 12			rl d 
0c41 cb 11		        rl c  
0c43 17				rla 
0c44 cb 13		        rl e  
0c46 cb 12			rl d 
0c48 cb 11		        rl c  
0c4a 17				rla 
0c4b 67			        ld h,a 
0c4c cb 13		        rl e  
0c4e cb 12			rl d 
0c50 cb 11		        rl c  
0c52 17				rla 
0c53 a8			        xor b 
0c54 cb 13		        rl e  
0c56 cb 12			rl d 
0c58 ac			        xor h 
0c59 a9			        xor c 
0c5a aa			        xor d 
0c5b 21 e3 fa		        ld hl,LFSRSeed+6 
0c5e 11 e4 fa		        ld de,LFSRSeed+7 
0c61 01 07 00		        ld bc,7 
0c64 ed b8		        lddr 
0c66 12			        ld (de),a 
0c67 c9			        ret 
0c68			 
0c68			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0c68			 
0c68			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0c68			 
0c68			 
0c68			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0c68			 
0c68			prng16: 
0c68			;Inputs: 
0c68			;   (seed1) contains a 16-bit seed value 
0c68			;   (seed2) contains a NON-ZERO 16-bit seed value 
0c68			;Outputs: 
0c68			;   HL is the result 
0c68			;   BC is the result of the LCG, so not that great of quality 
0c68			;   DE is preserved 
0c68			;Destroys: 
0c68			;   AF 
0c68			;cycle: 4,294,901,760 (almost 4.3 billion) 
0c68			;160cc 
0c68			;26 bytes 
0c68 2a d5 fa		    ld hl,(seed1) 
0c6b 44			    ld b,h 
0c6c 4d			    ld c,l 
0c6d 29			    add hl,hl 
0c6e 29			    add hl,hl 
0c6f 2c			    inc l 
0c70 09			    add hl,bc 
0c71 22 d5 fa		    ld (seed1),hl 
0c74 2a d3 fa		    ld hl,(seed2) 
0c77 29			    add hl,hl 
0c78 9f			    sbc a,a 
0c79 e6 2d		    and %00101101 
0c7b ad			    xor l 
0c7c 6f			    ld l,a 
0c7d 22 d3 fa		    ld (seed2),hl 
0c80 09			    add hl,bc 
0c81 c9			    ret 
0c82			 
0c82			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0c82			 
0c82			rand32: 
0c82			;Inputs: 
0c82			;   (seed1_0) holds the lower 16 bits of the first seed 
0c82			;   (seed1_1) holds the upper 16 bits of the first seed 
0c82			;   (seed2_0) holds the lower 16 bits of the second seed 
0c82			;   (seed2_1) holds the upper 16 bits of the second seed 
0c82			;   **NOTE: seed2 must be non-zero 
0c82			;Outputs: 
0c82			;   HL is the result 
0c82			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0c82			;Destroys: 
0c82			;   AF 
0c82			;Tested and passes all CAcert tests 
0c82			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0c82			;it has a period of 18,446,744,069,414,584,320 
0c82			;roughly 18.4 quintillion. 
0c82			;LFSR taps: 0,2,6,7  = 11000101 
0c82			;291cc 
0c82			;seed1_0=$+1 
0c82			;    ld hl,12345 
0c82			;seed1_1=$+1 
0c82			;    ld de,6789 
0c82			;    ld b,h 
0c82			;    ld c,l 
0c82			;    add hl,hl \ rl e \ rl d 
0c82			;    add hl,hl \ rl e \ rl d 
0c82			;    inc l 
0c82			;    add hl,bc 
0c82			;    ld (seed1_0),hl 
0c82			;    ld hl,(seed1_1) 
0c82			;    adc hl,de 
0c82			;    ld (seed1_1),hl 
0c82			;    ex de,hl 
0c82			;seed2_0=$+1 
0c82			;    ld hl,9876 
0c82			;seed2_1=$+1 
0c82			;    ld bc,54321 
0c82			;    add hl,hl \ rl c \ rl b 
0c82			;    ld (seed2_1),bc 
0c82			;    sbc a,a 
0c82			;    and %11000101 
0c82			;    xor l 
0c82			;    ld l,a 
0c82			;    ld (seed2_0),hl 
0c82			;    ex de,hl 
0c82			;    add hl,bc 
0c82			;    ret 
0c82			; 
0c82			 
0c82			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0c82			; 20 bytes, 86 cycles (excluding ret) 
0c82			 
0c82			; returns   hl = pseudorandom number 
0c82			; corrupts   a 
0c82			 
0c82			; generates 16-bit pseudorandom numbers with a period of 65535 
0c82			; using the xorshift method: 
0c82			 
0c82			; hl ^= hl << 7 
0c82			; hl ^= hl >> 9 
0c82			; hl ^= hl << 8 
0c82			 
0c82			; some alternative shift triplets which also perform well are: 
0c82			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0c82			 
0c82			;  org 32768 
0c82			 
0c82			xrnd: 
0c82 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0c85 3e 00		  ld a,0 
0c87 bd			  cp l 
0c88 20 02		  jr nz, .xrnd1 
0c8a 2e 01		  ld l, 1 
0c8c			.xrnd1: 
0c8c			 
0c8c 7c			  ld a,h 
0c8d 1f			  rra 
0c8e 7d			  ld a,l 
0c8f 1f			  rra 
0c90 ac			  xor h 
0c91 67			  ld h,a 
0c92 7d			  ld a,l 
0c93 1f			  rra 
0c94 7c			  ld a,h 
0c95 1f			  rra 
0c96 ad			  xor l 
0c97 6f			  ld l,a 
0c98 ac			  xor h 
0c99 67			  ld h,a 
0c9a			 
0c9a 22 d9 fa		  ld (xrandc),hl 
0c9d			 
0c9d c9			  ret 
