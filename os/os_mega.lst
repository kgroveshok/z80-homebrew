02bf			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
02bf			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
02bf			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
02bf			 
02bf			; INSTRUCTION SET 
02bf			; READ 0000 0011 Read data from memory array beginning at selected address 
02bf			; WRITE 0000 0010 Write data to memory array beginning at selected address 
02bf			; WREN 0000 0110 Set the write enable latch (enable write operations) 
02bf			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
02bf			; RDSR 0000 0101 Read STATUS register 
02bf			; WRSR 0000 0001 Write STATUS register 
02bf			; PE 0100 0010 Page Erase – erase one page in memory array 
02bf			; SE 1101 1000 Sector Erase – erase one sector in memory array 
02bf			; CE 1100 0111 Chip Erase – erase all sectors in memory array 
02bf			; RDID 1010 1011 Release from Deep power-down and read electronic signature 
02bf			 
02bf			; TODO send byte steam for page without setting the address for every single byte 
02bf			; TODO read byte  
02bf			 
02bf			; byte in a 
02bf			; address in hl  
02bf			se_writebyte: 
02bf			        
02bf			    ;   ld c, a 
02bf f5			        push af 
02c0 e5			        push hl 
02c1			 
02c1			    ; initi write mode 
02c1			    ; 
02c1			    ;CS low 
02c1			 
02c1 3a 8c f9		       ld a,(spi_portbyte) 
02c4 cd 68 02			call spi_ce_low 
02c7			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02c7 d3 80		       out (storage_adata),a 
02c9 32 8c f9		       ld (spi_portbyte), a 
02cc			 
02cc			    ;clock out wren instruction 
02cc			 
02cc 3e 06		    ld a, store_wren_ins 
02ce cd 69 01		    call spi_send_byte  
02d1			 
02d1			    ;cs high to enable write latch 
02d1			 
02d1 3a 8c f9		       ld a,(spi_portbyte) 
02d4 cd 57 02			call spi_ce_high 
