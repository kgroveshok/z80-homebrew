9e55				if BASE_CPM=1  
9e55					call debug_vector  
9e55				endif  
9e55				if BASE_KEV=1  
9e55					rst 8  
9e55				endif  
9e55				endm  
# End of macro CALLMONITOR
9e55				endif 
