1325			malloc_guard_entry: 
1325				push hl 
1325				push de 
1325				push af 
1325			 
1325			 	or a      ;clear carry flag 
1325				push hl 
1325				ld de, 255 
1325				sbc hl, de 
1325				jr c, .lowalloc 
1325			 
1325				push de 
1325					ld hl, display_fb0 
1325					ld (display_fb_active), hl 
1325				call clear_display 
1325				ld a, 0 
1325				ld de, .mallocsize 
1325				call str_at_display 
1325				call update_display 
1325				call delay1s 
1325				call delay1s 
1325			;	ld a, 0 
1325			;	ld (os_view_disable), a 
1325				call bp_on 
1325			 
1325				pop de 
1325				pop hl 
1325			 
1325				 
1325			 
1325				CALLMONITOR 
1325				jr .lowdone 
1325			.lowalloc: 
1325			 
1325			 
1325				pop hl 
1325			.lowdone:	pop af 
1325				pop de 
1325				pop hl 
1325			ret 
1325			 
1325			malloc_guard_exit: 
1325				push hl 
1325				push de 
1325				push af 
1325			 
1325			 	or a      ;clear carry flag 
1325				push hl 
1325				ld de, 255 
1325				sbc hl, de 
1325				jr c, .lowallocx 
1325			 
1325				push de 
1325					ld hl, display_fb0 
1325					ld (display_fb_active), hl 
1325				call clear_display 
1325				ld a, 0 
1325				ld de, .mallocasize 
1325				call str_at_display 
1325				call update_display 
1325				call delay1s 
1325				call delay1s 
1325			;	ld a, 0 
1325			;	ld (os_view_disable), a 
1325				call bp_on 
1325				pop de 
1325				pop hl 
1325			 
1325				CALLMONITOR 
1325				jr .lowdonex 
1325			.lowallocx: 
1325			 
