0cd5			; https://map.grauw.nl/articles/mult_div_shifts.php 
0cd5			; Divide 16-bit values (with 16-bit result) 
0cd5			; In: Divide BC by divider DE 
0cd5			; Out: BC = result, HL = rest 
0cd5			; 
0cd5			Div16: 
0cd5 21 00 00		    ld hl,0 
0cd8 78			    ld a,b 
0cd9 06 08		    ld b,8 
0cdb			Div16_Loop1: 
0cdb 17			    rla 
0cdc ed 6a		    adc hl,hl 
0cde ed 52		    sbc hl,de 
0ce0 30 01		    jr nc,Div16_NoAdd1 
0ce2 19			    add hl,de 
0ce3			Div16_NoAdd1: 
0ce3 10 f6		    djnz Div16_Loop1 
0ce5 17			    rla 
0ce6 2f			    cpl 
0ce7 47			    ld b,a 
0ce8 79			    ld a,c 
0ce9 48			    ld c,b 
0cea 06 08		    ld b,8 
0cec			Div16_Loop2: 
0cec 17			    rla 
0ced ed 6a		    adc hl,hl 
0cef ed 52		    sbc hl,de 
0cf1 30 01		    jr nc,Div16_NoAdd2 
0cf3 19			    add hl,de 
0cf4			Div16_NoAdd2: 
0cf4 10 f6		    djnz Div16_Loop2 
0cf6 17			    rla 
0cf7 2f			    cpl 
0cf8 41			    ld b,c 
0cf9 4f			    ld c,a 
0cfa c9			ret 
0cfb			 
0cfb			 
0cfb			;http://z80-heaven.wikidot.com/math 
0cfb			; 
0cfb			;Inputs: 
0cfb			;     DE and A are factors 
0cfb			;Outputs: 
0cfb			;     A is not changed 
0cfb			;     B is 0 
0cfb			;     C is not changed 
0cfb			;     DE is not changed 
0cfb			;     HL is the product 
0cfb			;Time: 
0cfb			;     342+6x 
0cfb			; 
0cfb			Mult16: 
0cfb			 
0cfb 06 08		     ld b,8          ;7           7 
0cfd 21 00 00		     ld hl,0         ;10         10 
0d00 29			       add hl,hl     ;11*8       88 
0d01 07			       rlca          ;4*8        32 
0d02 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0d04 19			         add hl,de   ;--         -- 
0d05 10 f9		       djnz $-5      ;13*7+8     99 
0d07 c9			ret 
0d08			 
0d08			; 
