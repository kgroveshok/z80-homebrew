8fd7			 
8fd7				pop bc 
8fd7				ld a,c 
8fd7				ld (store_page+STORE_0_BANKRUN), a 
8fd7				ld a,b 
8fd7				ld (store_page+STORE_0_BANKRUNN), a 
8fd7					ld hl, 0 
8fd7					ld de, store_page 
8fd7				call storage_write_block 
8fd7			 
8fd7			else 
