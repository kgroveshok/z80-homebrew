8df8			malloc_guard_zerolen: 
8df8				push hl 
8df8				push de 
8df8				push af 
8df8			 
8df8				ld de, 0 
8df8			        call cmp16 
8df8				jr nz, .lowalloz 
8df8			 
8df8				push hl 
8df8				push de 
8df8					ld hl, display_fb0 
8df8					ld (display_fb_active), hl 
8df8				call clear_display 
8df8				ld a, 0 
8df8				ld de, .malloczero 
8df8				call str_at_display 
8df8				call update_display 
8df8				call delay1s 
8df8				call delay1s 
8df8				call bp_on 
8df8			;	ld a, 0 
8df8			;	ld (os_view_disable), a 
8df8			 
8df8				pop de 
8df8				pop hl 
8df8			 
8df8				 
8df8			 
8df8				CALLMONITOR 
8df8			.lowalloz: 
8df8			 
8df8			 
8df8				pop af 
8df8				pop de 
8df8				pop hl 
8df8			ret 
8df8			 
8df8			malloc_guard_entry: 
8df8				push hl 
8df8				push de 
8df8				push af 
8df8			 
8df8			 	or a      ;clear carry flag 
8df8				push hl 
8df8				ld de, 255 
8df8				sbc hl, de 
8df8				jr c, .lowalloc 
8df8			 
8df8				push de 
8df8					ld hl, display_fb0 
8df8					ld (display_fb_active), hl 
8df8				call clear_display 
8df8				ld a, 0 
8df8				ld de, .mallocsize 
8df8				call str_at_display 
8df8				call update_display 
8df8				call delay1s 
8df8				call delay1s 
8df8			;	ld a, 0 
8df8			;	ld (os_view_disable), a 
8df8				call bp_on 
8df8			 
8df8				pop de 
8df8				pop hl 
8df8			 
8df8				 
8df8			 
8df8				CALLMONITOR 
8df8				jr .lowdone 
8df8			.lowalloc: 
8df8			 
8df8			 
8df8				pop hl 
8df8			.lowdone:	pop af 
8df8				pop de 
8df8				pop hl 
8df8			ret 
8df8			 
8df8			malloc_guard_exit: 
8df8				push hl 
8df8				push de 
8df8				push af 
8df8			 
8df8			 	or a      ;clear carry flag 
8df8				push hl 
8df8				ld de, 255 
8df8				sbc hl, de 
8df8				jr c, .lowallocx 
8df8			 
8df8				push de 
8df8					ld hl, display_fb0 
8df8					ld (display_fb_active), hl 
8df8				call clear_display 
8df8				ld a, 0 
8df8				ld de, .mallocasize 
8df8				call str_at_display 
8df8				call update_display 
8df8				call delay1s 
8df8				call delay1s 
8df8			;	ld a, 0 
8df8			;	ld (os_view_disable), a 
8df8				call bp_on 
8df8				pop de 
8df8				pop hl 
8df8			 
8df8				CALLMONITOR 
8df8				jr .lowdonex 
8df8			.lowallocx: 
8df8			 
8df8				pop hl 
8df8			.lowdonex:	pop af 
8df8				pop de 
8df8				pop hl 
8df8			ret 
8df8			endif 
