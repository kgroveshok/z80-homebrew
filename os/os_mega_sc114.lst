bbdd					ld (debug_mark+1),a  
bbdd					ld a, (.dmark+2)  
bbdd					ld (debug_mark+2),a  
bbdd				endif  
bbdd 18 04			jr .pastdmark  
bbdf ..			.dmark: db "VAR"  
bbe2				if DEMARK_VERSION = 1  
bbe2 00					db 0  
bbe3				endif  
bbe3				if DEMARK_VERSION = 1  
bbe3 e1			.pastdmark: pop hl  
bbe4				endif  
bbe4				if DEMARK_VERSION = 0  
bbe4			.pastdmark: pop af  
bbe4				endif  
bbe4			endm  
# End of macro DMARK
