1114			StrictStrCmp: 
1114				; Load next chars of each string 
1114 1a				ld a, (de) 
1115 47				ld b, a 
1116 7e				ld a, (hl) 
1117				; Compare 
1117 b8				cp b 
1118				; Return non-zero if chars don't match 
1118 c0				ret nz 
1119				; Check for end of both strings 
1119 fe 00			cp "\0" 
111b				; Return if strings have ended 
111b c8				ret z 
111c				; Otherwise, advance to next chars 
111c 23				inc hl 
111d 13				inc de 
111e 18 f4			jr StrictStrCmp 
