999e			; forth parser 
999e			 
999e			; My forth kernel 
999e			include "forth_kernel.asm" 
999e			; 
999e			; kernel to the forth OS 
999e			 
999e			DS_TYPE_STR: equ 1     ; string type 
999e			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
999e			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
999e			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
999e			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
999e			 
999e			FORTH_PARSEV1: equ 0 
999e			FORTH_PARSEV2: equ 0 
999e			FORTH_PARSEV3: equ 0 
999e			FORTH_PARSEV4: equ 0 
999e			FORTH_PARSEV5: equ 0 
999e			FORTH_PARSEV6: equ 1 
999e			 
999e			;if FORTH_PARSEV5 
999e			;	FORTH_END_BUFFER: equ 0 
999e			;else 
999e			FORTH_END_BUFFER: equ 127 
999e			;endif 
999e			 
999e			FORTH_TRUE: equ 1 
999e			FORTH_FALSE: equ 0 
999e			 
999e			if FORTH_PARSEV4 
999e			include "forth_stackops.asm" 
999e			endif 
999e			 
999e			if FORTH_PARSEV5 
999e			include "forth_stackopsv5.asm" 
999e			endif 
999e			 
999e			if FORTH_PARSEV6 
999e			include "forth_stackopsv5.asm" 
999e			 
999e			; Stack operations for v5 parser on wards 
999e			; * DATA stack 
999e			; * LOOP stack 
999e			; * RETURN stack 
999e			 
999e			 
999e			 
999e			FORTH_CHK_DSP_UNDER: macro 
999e				push hl 
999e				push de 
999e				ld hl,(cli_data_sp) 
999e				ld de, cli_data_stack 
999e				call cmp16 
999e				jp c, fault_dsp_under 
999e				pop de 
999e				pop hl 
999e				endm 
999e			 
999e			 
999e			FORTH_CHK_RSP_UNDER: macro 
999e				push hl 
999e				push de 
999e				ld hl,(cli_ret_sp) 
999e				ld de, cli_ret_stack 
999e				call cmp16 
999e				jp c, fault_rsp_under 
999e				pop de 
999e				pop hl 
999e				endm 
999e			 
999e			FORTH_CHK_LOOP_UNDER: macro 
999e				push hl 
999e				push de 
999e				ld hl,(cli_loop_sp) 
999e				ld de, cli_loop_stack 
999e				call cmp16 
999e				jp c, fault_loop_under 
999e				pop de 
999e				pop hl 
999e				endm 
999e			 
999e			FORTH_ERR_TOS_NOTSTR: macro 
999e				; TOSO might need more for checks when used 
999e				push af 
999e				ld a,(hl) 
999e				cp DS_TYPE_STR 
999e				jp nz, type_faultn   
999e				pop af 
999e				endm 
999e			 
999e			FORTH_ERR_TOS_NOTNUM: macro 
999e				push af 
999e				ld a,(hl) 
999e				cp DS_TYPE_INUM 
999e				jp nz, type_faultn   
999e				pop af 
999e				endm 
999e			 
999e			 
999e			; increase data stack pointer and save hl to it 
999e				 
999e			FORTH_DSP_NEXT: macro 
999e				call macro_forth_dsp_next 
999e				endm 
999e			 
999e			 
999e			macro_forth_dsp_next: 
999e				if DEBUG_FORTH_STACK_GUARD 
999e cd 21 d2				call check_stacks 
99a1				endif 
99a1 e5				push hl 
99a2 d5				push de 
99a3 eb				ex de,hl 
99a4 2a cf e9			ld hl,(cli_data_sp) 
99a7 23				inc hl 
99a8 23				inc hl 
99a9			 
99a9			; PARSEV5 
99a9 23				inc hl 
99aa 22 cf e9			ld (cli_data_sp),hl 
99ad 73				ld (hl), e 
99ae 23				inc hl 
99af 72				ld (hl), d 
99b0 d1				pop de 
99b1 e1				pop hl 
99b2				if DEBUG_FORTH_STACK_GUARD 
99b2 cd 21 d2				call check_stacks 
99b5				endif 
99b5 c9				ret 
99b6			 
99b6			 
99b6			; increase ret stack pointer and save hl to it 
99b6				 
99b6			FORTH_RSP_NEXT: macro 
99b6				call macro_forth_rsp_next 
99b6				endm 
99b6			 
99b6			macro_forth_rsp_next: 
99b6				if DEBUG_FORTH_STACK_GUARD 
99b6 cd 21 d2				call check_stacks 
99b9				endif 
99b9 e5				push hl 
99ba d5				push de 
99bb eb				ex de,hl 
