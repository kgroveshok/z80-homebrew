89ca			; 
89ca			; Square root of 16-bit value 
89ca			; In:  HL = value 
89ca			; Out:  D = result (rounded down) 
89ca			; 
89ca			;Sqr16: 
89ca			;    ld de,#0040 
89ca			;    ld a,l 
89ca			;    ld l,h 
89ca			;    ld h,d 
89ca			;    or a 
89ca			;    ld b,8 
89ca			;Sqr16_Loop: 
89ca			;    sbc hl,de 
89ca			;    jr nc,Sqr16_Skip 
89ca			;    add hl,de 
89ca			;Sqr16_Skip: 
89ca			;    ccf 
89ca			;    rl d 
89ca			;    add a,a 
89ca			;    adc hl,hl 
89ca			;    add a,a 
89ca			;    adc hl,hl 
89ca			;    djnz Sqr16_Loop 
89ca			;    ret 
89ca			; 
89ca			; 
89ca			; Divide 8-bit values 
89ca			; In: Divide E by divider C 
89ca			; Out: A = result, B = rest 
89ca			; 
89ca			Div8: 
89ca af			    xor a 
89cb 06 08		    ld b,8 
89cd			Div8_Loop: 
89cd cb 13		    rl e 
89cf 17			    rla 
89d0 91			    sub c 
89d1 30 01		    jr nc,Div8_NoAdd 
89d3 81			    add a,c 
89d4			Div8_NoAdd: 
89d4 10 f7		    djnz Div8_Loop 
89d6 47			    ld b,a 
89d7 7b			    ld a,e 
89d8 17			    rla 
89d9 2f			    cpl 
89da c9			    ret 
