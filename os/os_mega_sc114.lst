d4ff			 
d4ff			 
d4ff			 
d4ff			forth_startup: 
d4ff 21 4c c2			ld hl, startcmds 
d502 3e 00			ld a, 0 
d504 32 ca e6			ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
d507			 
d507 e5			.start1:	push hl 
d508 cd 10 88			call clear_display 
d50b 11 d9 d4			ld de, sprompt1 
d50e 3e 00		        ld a, display_row_1 
d510 cd 22 88			call str_at_display 
d513 11 e9 d4			ld de, sprompt2 
d516 3e 28		        ld a, display_row_2 
d518 cd 22 88			call str_at_display 
d51b e1				pop hl 
d51c e5				push hl 
d51d 5e				ld e,(hl) 
d51e 23				inc hl 
d51f 56				ld d,(hl) 
d520 3e 50		        ld a, display_row_3 
d522 cd 22 88			call str_at_display 
d525 cd 32 88			call update_display 
d528			 
d528			 
d528 3a ca e6			ld a, (os_last_cmd) 
d52b fe 00			cp 0 
d52d 28 05			jr z, .startprompt 
d52f cd 43 87			call delay250ms 
d532 18 24			jr .startdo 
d534				 
d534				 
d534			 
