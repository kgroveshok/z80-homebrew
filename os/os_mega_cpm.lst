5a14			; Which startup method to use? 
5a14			; 
5a14			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
5a14			; followed by loading of a list of scripts in eeprom 
5a14			 
5a14			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
5a14			; from eeprom 
5a14			 
5a14			; Select with define in main stubs 
5a14			 
5a14			if STARTUP_V1 
5a14				include "forth_startupv1.asm" 
5a14			; Startup script loading version 1 
