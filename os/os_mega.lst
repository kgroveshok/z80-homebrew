25ac					ld (debug_mark+1),a  
25ac					ld a, (.dmark+2)  
25ac					ld (debug_mark+2),a  
25ac				endif  
25ac 18 04			jr .pastdmark  
25ae ..			.dmark: db "HEP"  
25b1				if DEMARK_VERSION = 1  
25b1 00					db 0  
25b2				endif  
25b2				if DEMARK_VERSION = 1  
25b2 e1			.pastdmark: pop hl  
25b3				endif  
