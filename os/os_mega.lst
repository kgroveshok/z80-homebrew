25aa			.NEW: 
25aa			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
25aa 15				db WORD_SYS_CORE+OPCODE_HEAP             
25ab c4 25			dw .HEAP            
25ad 04				db 3 + 1 
25ae .. 00			db "NEW",0              
25b2				endm 
# End of macro CWHEAD
25b2			; | NEW ( -- ) Clears all user words and stack | DONE 
25b2				 
25b2				if MALLOC_4 
25b2					call  heap_init 
25b2				endif 
25b2				; reset uword pointers 
25b2 21 00 80			ld hl, baseram 
25b5 22 da f3			ld (os_last_new_uword), hl 
25b8 cd fe 23			call user_word_eol 
25bb				; clear stack 
25bb cd 17 24			call forth_warmstart 
25be				NEXTW 
25be cd a3 fd			call parse_vector 
25c1 c3 71 24			jp macro_next 
25c4				endm 
# End of macro NEXTW
25c4			 
25c4			.HEAP: 
25c4			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
25c4 15				db WORD_SYS_CORE+OPCODE_HEAP             
25c5 f5 25			dw .EXEC            
25c7 05				db 4 + 1 
25c8 .. 00			db "HEAP",0              
25cd				endm 
# End of macro CWHEAD
25cd			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
25cd			; | | u1 - Current number of bytes in the heap 
25cd			; | | u2 - Remaining bytes left on the heap 
25cd			; | |  
25cd			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
25cd			 
25cd			 
25cd				if DEBUG_FORTH_WORDS_KEY 
25cd					DMARK "HEP" 
25cd				if DEMARK_VERSION = 1  
25cd e5					push hl  
25ce 21 d6 25				ld hl, .dmark  
25d1 22 9b fd				ld (debug_mark), hl  
25d4				endif  
25d4				if DEMARK_VERSION = 0  
25d4					push af  
25d4					ld a, (.dmark)  
25d4					ld (debug_mark),a  
25d4					ld a, (.dmark+1)  
25d4					ld (debug_mark+1),a  
25d4					ld a, (.dmark+2)  
25d4					ld (debug_mark+2),a  
25d4				endif  
25d4 18 04			jr .pastdmark  
25d6 ..			.dmark: db "HEP"  
25d9				if DEMARK_VERSION = 1  
25d9 00					db 0  
25da				endif  
25da				if DEMARK_VERSION = 1  
25da e1			.pastdmark: pop hl  
25db				endif  
25db				if DEMARK_VERSION = 0  
25db			.pastdmark: pop af  
25db				endif  
25db			endm  
# End of macro DMARK
25db					CALLMONITOR 
25db				if BASE_CPM=1  
25db					call debug_vector  
25db				endif  
25db				if BASE_KEV=1  
25db cf					rst 8  
25dc				endif  
25dc				endm  
# End of macro CALLMONITOR
25dc				endif 
25dc 2a 0a 80			ld hl, (free_list )      
25df 11 0e 80			ld de, heap_start 
25e2			 
25e2 ed 52			sbc hl, de  
25e4			 
25e4			;	call forth_push_numhl 
25e4					FORTH_PUSH_VALUEHL 
25e4				if BASE_CPM=1 
25e4					call forth_push_numhl 
25e4				endif 
25e4				if BASE_KEV=1 
25e4 e7					rst $20 
25e5				endif 
25e5				endm 
# End of macro FORTH_PUSH_VALUEHL
25e5			 
25e5			 
25e5 ed 5b 0a 80		ld de, (free_list )      
25e9 21 b8 f0			ld hl, heap_end 
25ec			 
25ec ed 52			sbc hl, de 
