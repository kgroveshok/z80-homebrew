0d5b			 
0d5b			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0d5b			 
0d5b			rand32: 
0d5b			;Inputs: 
0d5b			;   (seed1_0) holds the lower 16 bits of the first seed 
0d5b			;   (seed1_1) holds the upper 16 bits of the first seed 
0d5b			;   (seed2_0) holds the lower 16 bits of the second seed 
0d5b			;   (seed2_1) holds the upper 16 bits of the second seed 
0d5b			;   **NOTE: seed2 must be non-zero 
0d5b			;Outputs: 
0d5b			;   HL is the result 
0d5b			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0d5b			;Destroys: 
0d5b			;   AF 
0d5b			;Tested and passes all CAcert tests 
0d5b			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0d5b			;it has a period of 18,446,744,069,414,584,320 
0d5b			;roughly 18.4 quintillion. 
0d5b			;LFSR taps: 0,2,6,7  = 11000101 
0d5b			;291cc 
0d5b			;seed1_0=$+1 
0d5b			;    ld hl,12345 
0d5b			;seed1_1=$+1 
0d5b			;    ld de,6789 
0d5b			;    ld b,h 
0d5b			;    ld c,l 
0d5b			;    add hl,hl \ rl e \ rl d 
0d5b			;    add hl,hl \ rl e \ rl d 
0d5b			;    inc l 
0d5b			;    add hl,bc 
0d5b			;    ld (seed1_0),hl 
0d5b			;    ld hl,(seed1_1) 
0d5b			;    adc hl,de 
0d5b			;    ld (seed1_1),hl 
0d5b			;    ex de,hl 
0d5b			;seed2_0=$+1 
0d5b			;    ld hl,9876 
0d5b			;seed2_1=$+1 
0d5b			;    ld bc,54321 
0d5b			;    add hl,hl \ rl c \ rl b 
0d5b			;    ld (seed2_1),bc 
0d5b			;    sbc a,a 
0d5b			;    and %11000101 
0d5b			;    xor l 
0d5b			;    ld l,a 
0d5b			;    ld (seed2_0),hl 
0d5b			;    ex de,hl 
0d5b			;    add hl,bc 
0d5b			;    ret 
0d5b			; 
0d5b			 
0d5b			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0d5b			; 20 bytes, 86 cycles (excluding ret) 
0d5b			 
0d5b			; returns   hl = pseudorandom number 
0d5b			; corrupts   a 
0d5b			 
0d5b			; generates 16-bit pseudorandom numbers with a period of 65535 
0d5b			; using the xorshift method: 
0d5b			 
0d5b			; hl ^= hl << 7 
0d5b			; hl ^= hl >> 9 
0d5b			; hl ^= hl << 8 
0d5b			 
0d5b			; some alternative shift triplets which also perform well are: 
0d5b			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0d5b			 
0d5b			;  org 32768 
0d5b			 
0d5b			xrnd: 
0d5b 2a 9c eb		  ld hl,(xrandc)       ; seed must not be 0 
0d5e 3e 00		  ld a,0 
0d60 bd			  cp l 
0d61 20 02		  jr nz, .xrnd1 
0d63 2e 01		  ld l, 1 
0d65			.xrnd1: 
0d65			 
0d65 7c			  ld a,h 
0d66 1f			  rra 
0d67 7d			  ld a,l 
0d68 1f			  rra 
0d69 ac			  xor h 
0d6a 67			  ld h,a 
0d6b 7d			  ld a,l 
0d6c 1f			  rra 
0d6d 7c			  ld a,h 
0d6e 1f			  rra 
0d6f ad			  xor l 
0d70 6f			  ld l,a 
0d71 ac			  xor h 
0d72 67			  ld h,a 
0d73			 
0d73 22 9c eb		  ld (xrandc),hl 
0d76			 
0d76 c9			  ret 
0d77			;  
