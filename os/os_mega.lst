684a 3e 00			ld a, kLCD_Line1  
684c cd 56 69		            CALL fLCD_Pos       ;Position cursor to location in A  
684f 06 28			ld b, display_cols  
6851 ed 5b f9 fa		ld de, (display_write_tmp)  
6855 cd a1 68			call write_len_string  
6858				  
