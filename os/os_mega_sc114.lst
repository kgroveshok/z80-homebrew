92b9			 
92b9			config_fdir: 
92b9				; using the scratch dir go through and release the memory allocated for each string 
92b9				 
92b9				ld hl, scratch 
92b9			.cfdir:	ld e,(hl) 
92b9				inc hl 
92b9				ld d,(hl) 
92b9				inc hl 
92b9			 
92b9				ex de, hl 
92b9				call ishlzero 
92b9				ret z     ; return on null pointer 
92b9				call free 
92b9				ex de, hl 
92b9				jr .cfdir 
92b9			 
92b9			 
92b9				ret 
92b9			 
92b9			 
92b9			config_dir: 
92b9			 
92b9				; for the config menus that need to build a directory of storage call this routine 
92b9				; it will construct a menu in scratch to pass to menu 
92b9			 
92b9				; open storage device 
92b9			 
92b9				; execute DIR to build a list of files and their ids into scratch in menu format 
92b9				; once the menu has finished then will need to call config_fdir to release the strings 
92b9				 
92b9				; c = number items 
92b9			 
92b9				 
92b9				call storage_get_block_0 
92b9			 
92b9				ld hl, store_page     ; get current id count 
92b9				ld b, (hl) 
92b9				ld c, 0    ; count of files   
92b9			 
92b9			 
92b9				ld hl, scratch 
92b9				ld (store_tmp2), hl    ; location to poke strings 
92b9			 
92b9				; check for empty drive 
92b9			 
92b9				ld a, 0 
92b9				cp b 
92b9				jp z, .dirdone 
92b9			 
92b9				 
92b9					if DEBUG_FORTH_WORDS 
92b9						DMARK "Cdc" 
92b9						CALLMONITOR 
92b9					endif 
92b9			 
92b9			 
92b9			.diritem:	 
92b9				push bc 
92b9				; for each of the current ids do a search for them and if found push to stack 
92b9			 
92b9					ld hl, STORE_BLOCK_PHY 
92b9					ld d, 0		 ; look for extent 0 of block id as this contains file name 
92b9					ld e,b 
92b9			 
92b9					call storage_findnextid 
92b9			 
92b9			 
92b9					; if found hl will be non zero 
92b9			 
92b9					call ishlzero 
92b9					jr z, .dirnotfound 
92b9			 
92b9					; increase count 
92b9			 
92b9					pop bc	 
92b9					inc c 
92b9					push bc 
92b9					 
92b9			 
92b9					; get file header and push the file name 
92b9			 
92b9					ld de, store_page 
92b9					call storage_read_block 
92b9			 
92b9					; push file id to stack 
92b9				 
92b9					ld a, (store_page) 
92b9					ld h, 0 
92b9					ld l, a 
92b9			 
92b9					;call forth_push_numhl 
92b9					; TODO store id 
92b9			 
92b9					push hl 
92b9			 
92b9					; push extent count to stack  
92b9				 
92b9					ld hl, store_page+3 
92b9			 
92b9					; get file name length 
92b9			 
92b9					call strlenz   
92b9			 
92b9					inc hl   ; cover zero term 
92b9					inc hl  ; stick the id at the end of the area 
92b9			 
92b9					push hl 
92b9					pop bc    ; move length to bc 
92b9			 
92b9					call malloc 
92b9			 
92b9					; TODO save malloc area to scratch 
92b9			 
92b9					ex de, hl 
92b9					ld hl, (store_tmp2) 
92b9					ld (hl), e 
92b9					inc hl 
92b9					ld (hl), d 
92b9					inc hl 
92b9					ld (store_tmp2), hl 
92b9			 
92b9					 
92b9			 
92b9					;pop hl   ; get source 
92b9			;		ex de, hl    ; swap aronund	 
92b9			 
92b9					ld hl, store_page+3 
92b9					if DEBUG_FORTH_WORDS 
92b9						DMARK "CFd" 
92b9						CALLMONITOR 
92b9					endif 
92b9					ldir 
92b9			 
92b9					; de is past string, move back one and store id 
92b9					 
92b9					dec de 
92b9			 
92b9					; store file id 
92b9			 
92b9					pop hl 
92b9					ex de,hl 
92b9					ld (hl), e 
92b9			 
92b9					if DEBUG_FORTH_WORDS 
92b9						DMARK "Cdi" 
92b9						CALLMONITOR 
92b9					endif 
92b9					 
92b9			.dirnotfound: 
92b9					pop bc     
92b9					djnz .diritem 
92b9				 
92b9			.dirdone:	 
92b9			 
92b9			;		ld a, 0 
92b9					ld hl, (store_tmp2) 
92b9					ld (hl), 0 
92b9					inc hl 
92b9					ld (hl), 0 
92b9					inc hl 
92b9					; push a count of the dir items found 
92b9			 
92b9			;		ld h, 0 
92b9			;		ld l, c 
92b9			 
92b9				ret 
92b9			 
92b9			endif 
