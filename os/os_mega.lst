0cff 87			    add a,a 
0d00 30 01		    jr nc,Mult12U_NoAdd0 
0d02 19			    add hl,de 
0d03			Mult12U_NoAdd0: 
0d03 29			    add hl,hl 
0d04 87			    add a,a 
0d05 30 01		    jr nc,Mult12U_NoAdd1 
0d07 19			    add hl,de 
0d08			Mult12U_NoAdd1: 
0d08 29			    add hl,hl 
0d09 87			    add a,a 
0d0a 30 01		    jr nc,Mult12U_NoAdd2 
0d0c 19			    add hl,de 
0d0d			Mult12U_NoAdd2: 
0d0d 29			    add hl,hl 
0d0e 87			    add a,a 
0d0f 30 01		    jr nc,Mult12U_NoAdd3 
0d11 19			    add hl,de 
0d12			Mult12U_NoAdd3: 
0d12 29			    add hl,hl 
0d13 87			    add a,a 
0d14 30 01		    jr nc,Mult12U_NoAdd4 
0d16 19			    add hl,de 
0d17			Mult12U_NoAdd4: 
