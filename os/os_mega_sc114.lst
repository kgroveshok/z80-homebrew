8f62			; Decimal Signed Version 
8f62			 
8f62			; DispA 
8f62			; -------------------------------------------------------------- 
8f62			; Converts a signed integer value to a zero-terminated ASCII 
8f62			; string representative of that value (using radix 10). 
8f62			; -------------------------------------------------------------- 
8f62			; INPUTS: 
8f62			;     HL     Value to convert (two's complement integer). 
8f62			;     DE     Base address of string destination. (pointer). 
8f62			; -------------------------------------------------------------- 
8f62			; OUTPUTS: 
8f62			;     None 
8f62			; -------------------------------------------------------------- 
8f62			; REGISTERS/MEMORY DESTROYED 
8f62			; AF HL 
8f62			; -------------------------------------------------------------- 
8f62			 
8f62			;DispHLToASCII: 
8f62			;   push    de 
8f62			;   push    bc 
8f62			; 
8f62			;; Detect sign of HL. 
8f62			;    bit    7, h 
8f62			;    jr     z, ._DoConvert 
8f62			; 
8f62			;; HL is negative. Output '-' to string and negate HL. 
8f62			;    ld     a, '-' 
8f62			;    ld     (de), a 
8f62			;    inc    de 
8f62			; 
8f62			;; Negate HL (using two's complement) 
8f62			;    xor    a 
8f62			;    sub    l 
8f62			;    ld     l, a 
8f62			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
8f62			;    sbc    a, h 
8f62			;    ld     h, a 
8f62			; 
8f62			;; Convert HL to digit characters 
8f62			;._DoConvert: 
8f62			;    ld     b, 0     ; B will count character length of number 
8f62			;-   ld     a, 10 
8f62			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
8f62			;    push   af 
8f62			;    inc    b 
8f62			;    ld     a, h 
8f62			;    or     l 
8f62			;    jr     nz, - 
8f62			; 
8f62			;; Retrieve digits from stack 
8f62			;-   pop    af 
8f62			;    or     $30 
8f62			;    ld     (de), a 
8f62			;    inc    de 
8f62			;    djnz   - 
8f62			; 
8f62			;; Terminate string with NULL 
8f62			;    xor    a 
8f62			;    ld     (de), a 
8f62			; 
8f62			;    pop    bc 
8f62			;    pop    de 
8f62			;    ret 
8f62			 
8f62			;Comments 
8f62			; 
8f62			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
8f62			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
8f62			;    Note that the output string will not be fixed-width. 
8f62			; 
8f62			;Example Usage 
8f62			; 
8f62			;    ld    hl, -1004 
8f62			;    ld    de, OP1 
8f62			;    call  DispA 
8f62			;    ld    hl, OP1 
8f62			;    syscall  PutS 
