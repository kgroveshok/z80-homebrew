20aa					FORTH_CHK_RSP_UNDER 
20aa e5				push hl 
20ab d5				push de 
20ac 2a 0e f9			ld hl,(cli_ret_sp) 
20af 11 c8 f8			ld de, cli_ret_stack 
20b2 cd 80 0d			call cmp16 
20b5 da d7 66			jp c, fault_rsp_under 
20b8 d1				pop de 
20b9 e1				pop hl 
20ba				endm 
# End of macro FORTH_CHK_RSP_UNDER
20ba				endif 
20ba e5				push hl 
20bb 2a 0e f9			ld hl,(cli_ret_sp) 
