9b71			;  
9b71			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
9b71			; 2DUP 2DROP 2SWAP  
9b71			; @ C@ - get byte  
9b71			; ! C! - store byte 
9b71			; 0< true if less than zero 
9b71			; 0= true if zero 
9b71			; < >  
9b71			; = true if same 
9b71			; variables 
