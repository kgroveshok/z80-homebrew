4ca6					ld (debug_mark+1),a  
4ca6					ld a, (.dmark+2)  
4ca6					ld (debug_mark+2),a  
4ca6				endif  
4ca6 18 04			jr .pastdmark  
4ca8 ..			.dmark: db "REA"  
4cab				if DEMARK_VERSION = 1  
4cab 00					db 0  
4cac				endif  
