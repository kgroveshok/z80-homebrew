ca26			 
ca26			 
ca26			.SESEL: 
ca26				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
ca26			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
ca26			; | | Zero is disabled storage. 
ca26					if DEBUG_FORTH_WORDS_KEY 
ca26						DMARK "BN?" 
ca26						CALLMONITOR 
ca26					endif 
ca26					ld a, (spi_device_id) 
ca26					sub '0' 
ca26					ld h, 0 
ca26					ld l, a 
ca26					FORTH_PUSH_VALUEHL 
ca26					;call forth_push_numhl 
ca26					NEXTW 
ca26			.SESELS: 
ca26				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
ca26			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
ca26			; | | Set to zero to disable storage. 
ca26					if DEBUG_FORTH_WORDS_KEY 
ca26						DMARK "BNK" 
ca26						CALLMONITOR 
ca26					endif 
ca26			 
ca26					ld a, 255 
ca26					ld (spi_cartdev), a 
ca26			 
ca26					; get bank 
ca26			 
ca26					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
ca26			 
ca26			;		push hl 
ca26			 
ca26					; destroy value TOS 
ca26			 
ca26					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
ca26			 
ca26					; one value on hl get other one back 
ca26			 
ca26			;		pop hl 
ca26			 
ca26			 
ca26					ld c, SPI_CE_HIGH 
ca26					ld b, '0'    ; human readable bank number 
ca26			 
ca26					ld a, l 
ca26			 
ca26					if DEBUG_FORTH_WORDS 
ca26						DMARK "BNK" 
ca26						CALLMONITOR 
ca26					endif 
ca26			 
ca26					; active low 
ca26			 
ca26			;		cp 0 
ca26					or a 
ca26					jr z, .bset 
ca26					cp 1 
ca26					jr nz, .b2 
ca26					res 0, c 
ca26					ld b, '1'    ; human readable bank number 
ca26			.b2:		cp 2 
ca26					jr nz, .b3 
ca26					res 1, c 
ca26					ld b, '2'    ; human readable bank number 
ca26			.b3:		cp 3 
ca26					jr nz, .b4 
ca26					res 2, c 
ca26					ld b, '3'    ; human readable bank number 
ca26			.b4:		cp 4 
ca26					jr nz, .b5 
ca26					res 3, c 
ca26					ld b, '4'    ; human readable bank number 
ca26			.b5:		cp 5 
ca26					jr nz, .bset 
ca26					res 4, c 
ca26					ld b, '5'    ; human readable bank number 
ca26			 
ca26			.bset: 
ca26					ld a, c 
ca26					ld (spi_device),a 
ca26					ld a, b 
ca26					ld (spi_device_id),a 
ca26					if DEBUG_FORTH_WORDS 
ca26						DMARK "BN2" 
ca26						CALLMONITOR 
ca26					endif 
ca26			 
ca26					; set default SPI clk pulse time as disabled for BANK use 
ca26			 
ca26					ld a, 0 
ca26					ld (spi_clktime), a 
ca26			 
ca26					NEXTW 
ca26			 
ca26			.CARTDEV: 
ca26				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
ca26			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
ca26			; | | Set to zero to disable devices. 
ca26					if DEBUG_FORTH_WORDS_KEY 
ca26						DMARK "CDV" 
ca26						CALLMONITOR 
ca26					endif 
ca26			 
ca26					; disable se storage bank selection 
ca26			 
ca26					ld a, SPI_CE_HIGH		; ce high 
ca26					ld (spi_device), a 
ca26			 
ca26					; get bank 
ca26			 
ca26					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
ca26			 
ca26			;		push hl 
ca26			 
ca26					; destroy value TOS 
ca26			 
ca26					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
ca26			 
ca26					; one value on hl get other one back 
ca26			 
ca26			;		pop hl 
ca26			 
ca26					; active low 
ca26			 
ca26					ld c, 255 
ca26			 
ca26					ld a, l 
ca26					if DEBUG_FORTH_WORDS 
ca26						DMARK "CDV" 
ca26						CALLMONITOR 
ca26					endif 
ca26			;		cp 0 
ca26					or a 
ca26					jr z, .cset 
ca26					cp 1 
ca26					jr nz, .c2 
ca26					res 0, c 
ca26			.c2:		cp 2 
ca26					jr nz, .c3 
ca26					res 1, c 
ca26			.c3:		cp 3 
ca26					jr nz, .c4 
ca26					res 2, c 
ca26			.c4:		cp 4 
ca26					jr nz, .c5 
ca26					res 3, c 
ca26			.c5:		cp 5 
ca26					jr nz, .c6 
ca26					res 4, c 
ca26			.c6:		cp 6 
ca26					jr nz, .c7 
ca26					res 5, c 
ca26			.c7:		cp 7 
ca26					jr nz, .c8 
ca26					res 6, c 
ca26			.c8:		cp 8 
ca26					jr nz, .cset 
ca26					res 7, c 
ca26			.cset:		ld a, c 
ca26					ld (spi_cartdev),a 
ca26			 
ca26					if DEBUG_FORTH_WORDS 
ca26						DMARK "CD2" 
ca26						CALLMONITOR 
ca26					endif 
ca26			 
ca26					; set default SPI clk pulse time as 10ms for CARTDEV use 
ca26			 
ca26					ld a, $0a 
ca26					ld (spi_clktime), a 
ca26					NEXTW 
ca26			endif 
ca26			 
