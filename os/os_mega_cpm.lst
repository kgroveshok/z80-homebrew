11ad			.genfile: 
11ad				push hl 
11ad				push de 
11ad			 
11ad				call clear_display 
11ad				ld a, display_row_1 
11ad				ld de, .genfiletxt 
11ad				call str_at_display 
11ad				call update_display 
11ad			 
11ad				pop de 
11ad				pop hl 
11ad			 
11ad			 
11ad				push de 
11ad				call storage_create 
11ad				; id in hl 
11ad				pop de   ; table of strings to add 
11ad			 
11ad			.genloop: 
11ad			 
11ad				push hl ; save id for next time around 
11ad				push de ; save de for next time around 
11ad			 
11ad				ex de, hl 
11ad				call loadwordinhl 
11ad				ex de, hl 
11ad			 
11ad				; need hl to be the id 
11ad				; need de to be the string ptr 
11ad				 
11ad				call storage_append 
11ad			 
11ad				pop de 
11ad				pop hl 
11ad			 
11ad				inc de 
11ad				inc de 
11ad			 
11ad				ld a,(de) 
11ad				cp 0 
11ad				jr nz, .genloop 
11ad				inc de 
11ad				ld a, (de) 
11ad				dec de 
11ad				cp 0 
11ad				jr nz, .genloop	 
11ad			 
11ad				ret 
