2503					endif 
2503 b9				cp c 
2504			 
2504 28 03			jr z, .fnt2cmpmorefirst	 
2506			 
2506				; first char not found move to next char 
2506			 
2506 23				inc hl 
2507 18 f4			jr .fnt1 
2509			 
2509			.fnt2cmpmorefirst:	 
2509				; first char of token found.  
2509			 
2509 e5				push hl     ; save start of token just in case it is the right one 
250a d9				exx 
250b e1				pop hl        ; save it to hl' 
250c d9				exx 
250d			 
250d			 
250d			.fnt2cmpmore:	 
250d				; compare the rest 
250d				 
250d 23				inc hl 
250e 13				inc de 
250f				 
250f 1a				ld a, (de) 
2510 4f				ld c,a 
2511 7e				ld a,(hl) 
2512 cd b1 10			call toUpper 
2515			 
2515					if DEBUG_FORTH 
2515						DMARK "NT2" 
2515						CALLMONITOR 
2515					endif 
2515				; c has the token to find char 
2515				; a has the mem to scan char 
2515			 
2515 b9				cp c 
2516 28 04			jr z,.fntmatch1 
2518			 
2518				; they are not the same 
2518			 
2518					if DEBUG_FORTH 
2518						DMARK "NT3" 
2518						CALLMONITOR 
2518					endif 
2518 d1				pop de	; reset de token to look for 
2519 d5				push de 
251a 18 e1			jr .fnt1 
251c				 
251c			.fntmatch1: 
251c			 
251c				; is the same char a null which means we might have a full hit? 
251c					if DEBUG_FORTH 
