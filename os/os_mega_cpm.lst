0ee8			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
0ee8			 
0ee8			 
0ee8			;Converts an ASCII string to an unsigned 16-bit integer 
0ee8			;Quits when it reaches a non-decimal digit 
0ee8			 
0ee8			string_to_uint16: 
0ee8			atoui_16: 
0ee8			;Input: 
0ee8			;     DE points to the string 
0ee8			;Outputs: 
0ee8			;     HL is the result 
0ee8			;     A is the 8-bit value of the number 
0ee8			;     DE points to the byte after the number 
0ee8			;Destroys: 
0ee8			;     BC 
0ee8			;       if the string is non-empty, BC is HL/10 
0ee8			;Size:  24 bytes 
0ee8			;Speed: 42+d(104+{0,9}) 
0ee8			;       d is the number of digits in the number 
0ee8			;       max is 640 cycles for a 5 digit number 
0ee8			;Assuming no leading zeros: 
0ee8			;1 digit:  146cc 
0ee8			;2 digit:  250cc 
0ee8			;3 digit:  354cc or 363cc (avg: 354.126cc) 
0ee8			;4 digit:  458cc or 467cc (avg: 458.27cc) 
0ee8			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
0ee8			;avg: 544.81158447265625cc (544+13297/16384) 
0ee8			;=============================================================== 
0ee8 21 00 00		  ld hl,0 
0eeb			.u16a: 
0eeb 1a			  ld a,(de) 
0eec d6 30		  sub 30h 
0eee fe 0a		  cp 10 
0ef0 d0			  ret nc 
0ef1 13			  inc de 
0ef2 44			  ld b,h 
0ef3 4d			  ld c,l 
0ef4 29			  add hl,hl 
0ef5 29			  add hl,hl 
0ef6 09			  add hl,bc 
0ef7 29			  add hl,hl 
0ef8 85			  add a,l 
0ef9 6f			  ld l,a 
0efa 30 ef		  jr nc,.u16a 
0efc 24			  inc h 
0efd c3 eb 0e		  jp .u16a 
