0dbb			;;This divides DE by BC, storing the result in DE, remainder in HL 
0dbb			; 
0dbb			;DE_Div_BC:          ;1281-2x, x is at most 16 
0dbb			;     ld a,16        ;7 
0dbb			;     ld hl,0        ;10 
0dbb			;     jp $+5         ;10 
0dbb			;.DivLoop: 
0dbb			;       add hl,bc    ;-- 
0dbb			;       dec a        ;64 
0dbb			;       jr z,.DivLoopEnd        ;86 
0dbb			; 
0dbb			;       sla e        ;128 
0dbb			;       rl d         ;128 
0dbb			;       adc hl,hl    ;240 
0dbb			;       sbc hl,bc    ;240 
0dbb			;       jr nc,.DivLoop ;23|21 
0dbb			;       inc e        ;-- 
0dbb			;       jp .DivLoop+1 
0dbb			; 
0dbb			;.DivLoopEnd: 
0dbb			 
0dbb			;HL_Div_C: 
0dbb			;Inputs: 
0dbb			;     HL is the numerator 
0dbb			;     C is the denominator 
0dbb			;Outputs: 
0dbb			;     A is the remainder 
0dbb			;     B is 0 
0dbb			;     C is not changed 
0dbb			;     DE is not changed 
0dbb			;     HL is the quotient 
0dbb			; 
0dbb			;       ld b,16 
0dbb			;       xor a 
0dbb			;         add hl,hl 
0dbb			;         rla 
0dbb			;         cp c 
0dbb			;         jr c,$+4 
0dbb			;           inc l 
0dbb			;           sub c 
0dbb			;         djnz $-7 
0dbb			 
0dbb			; https://plutiedev.com/z80-add-8bit-to-16bit 
0dbb			 
0dbb			addatohl: 
0dbb 85			    add   a, l    ; A = A+L 
0dbc 6f			    ld    l, a    ; L = A+L 
0dbd 8c			    adc   a, h    ; A = A+L+H+carry 
0dbe 95			    sub   l       ; A = H+carry 
0dbf 67			    ld    h, a    ; H = H+carry 
0dc0 c9			ret 
