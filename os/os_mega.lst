0cef			; 
0cef			; Divide 8-bit values 
0cef			; In: Divide E by divider C 
0cef			; Out: A = result, B = rest 
0cef			; 
0cef			Div8: 
0cef af			    xor a 
0cf0 06 08		    ld b,8 
0cf2			Div8_Loop: 
0cf2 cb 13		    rl e 
0cf4 17			    rla 
0cf5 91			    sub c 
0cf6 30 01		    jr nc,Div8_NoAdd 
0cf8 81			    add a,c 
0cf9			Div8_NoAdd: 
0cf9 10 f7		    djnz Div8_Loop 
0cfb 47			    ld b,a 
0cfc 7b			    ld a,e 
0cfd 17			    rla 
0cfe 2f			    cpl 
0cff c9			    ret 
