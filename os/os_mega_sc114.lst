d4c2 3e 00		        ld a, display_row_1 
d4c4 cd 22 88			call str_at_display 
d4c7 11 9d d4			ld de, sprompt2 
d4ca 3e 28		        ld a, display_row_2 
d4cc cd 22 88			call str_at_display 
d4cf e1				pop hl 
d4d0 e5				push hl 
d4d1 5e				ld e,(hl) 
d4d2 23				inc hl 
d4d3 56				ld d,(hl) 
d4d4 3e 50		        ld a, display_row_3 
d4d6 cd 22 88			call str_at_display 
d4d9 cd 32 88			call update_display 
d4dc			 
d4dc			 
