996c			; forth parser 
996c			 
996c			; My forth kernel 
996c			include "forth_kernel.asm" 
996c			; 
996c			; kernel to the forth OS 
996c			 
996c			DS_TYPE_STR: equ 1     ; string type 
996c			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
996c			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
996c			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
996c			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
996c			 
996c			FORTH_PARSEV1: equ 0 
996c			FORTH_PARSEV2: equ 0 
996c			FORTH_PARSEV3: equ 0 
996c			FORTH_PARSEV4: equ 0 
996c			FORTH_PARSEV5: equ 0 
996c			FORTH_PARSEV6: equ 1 
996c			 
996c			;if FORTH_PARSEV5 
996c			;	FORTH_END_BUFFER: equ 0 
996c			;else 
996c			FORTH_END_BUFFER: equ 127 
996c			;endif 
996c			 
996c			FORTH_TRUE: equ 1 
996c			FORTH_FALSE: equ 0 
996c			 
996c			if FORTH_PARSEV4 
996c			include "forth_stackops.asm" 
996c			endif 
996c			 
996c			if FORTH_PARSEV5 
996c			include "forth_stackopsv5.asm" 
996c			endif 
996c			 
996c			if FORTH_PARSEV6 
996c			include "forth_stackopsv5.asm" 
996c			 
996c			; Stack operations for v5 parser on wards 
996c			; * DATA stack 
996c			; * LOOP stack 
996c			; * RETURN stack 
996c			 
996c			 
996c			 
996c			FORTH_CHK_DSP_UNDER: macro 
996c				push hl 
996c				push de 
996c				ld hl,(cli_data_sp) 
996c				ld de, cli_data_stack 
996c				call cmp16 
996c				jp c, fault_dsp_under 
996c				pop de 
996c				pop hl 
996c				endm 
996c			 
996c			 
996c			FORTH_CHK_RSP_UNDER: macro 
996c				push hl 
996c				push de 
996c				ld hl,(cli_ret_sp) 
996c				ld de, cli_ret_stack 
996c				call cmp16 
996c				jp c, fault_rsp_under 
996c				pop de 
996c				pop hl 
996c				endm 
996c			 
996c			FORTH_CHK_LOOP_UNDER: macro 
996c				push hl 
996c				push de 
996c				ld hl,(cli_loop_sp) 
996c				ld de, cli_loop_stack 
996c				call cmp16 
996c				jp c, fault_loop_under 
996c				pop de 
996c				pop hl 
996c				endm 
996c			 
996c			FORTH_ERR_TOS_NOTSTR: macro 
996c				; TOSO might need more for checks when used 
996c				push af 
996c				ld a,(hl) 
996c				cp DS_TYPE_STR 
996c				jp nz, type_faultn   
996c				pop af 
996c				endm 
996c			 
996c			FORTH_ERR_TOS_NOTNUM: macro 
996c				push af 
996c				ld a,(hl) 
996c				cp DS_TYPE_INUM 
996c				jp nz, type_faultn   
996c				pop af 
996c				endm 
996c			 
996c			 
996c			; increase data stack pointer and save hl to it 
996c				 
996c			FORTH_DSP_NEXT: macro 
996c				call macro_forth_dsp_next 
996c				endm 
996c			 
996c			 
996c			macro_forth_dsp_next: 
996c				if DEBUG_FORTH_STACK_GUARD 
996c cd 1d d3				call check_stacks 
996f				endif 
996f e5				push hl 
9970 d5				push de 
9971 eb				ex de,hl 
9972 2a cf e9			ld hl,(cli_data_sp) 
9975 23				inc hl 
9976 23				inc hl 
9977			 
9977			; PARSEV5 
9977 23				inc hl 
