9982			user_word_eol:  
9982				; hl contains the pointer to where to create a linked list item from the end 
9982				; of the user dict to continue on at the system word dict 
9982				 
9982				; poke the stub of the word list linked list to repoint to rom words 
9982			 
9982				; stub format 
9982				; db   word id 
9982				; dw    link to next word 
9982			        ; db char length of token 
9982				; db string + 0 term 
9982				; db exec code....  
9982			 
9982			;	ld a, WORD_SYS_ROOT     ; root word 
9982 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9984 23				inc hl 
9985			 
9985 11 2e 9b			ld de, sysdict 
9988 73				ld (hl), e		; next word link ie system dict 
9989 23				inc hl 
998a 72				ld (hl), d		; next word link ie system dict 
998b 23				inc hl	 
998c			 
998c			;	ld (hl), sysdict		; next word link ie system dict 
998c			;	inc hl 
998c			;	inc hl 
998c			 
998c			;	inc hl 
998c			;	inc hl 
998c			 
998c			;	ld a, 2			; word length is 0 
998c 36 02			ld (hl), 2 
998e 23				inc hl 
998f			 
998f			;	ld a, '~'			; word length is 0 
998f 36 7e			ld (hl), '~' 
9991 23				inc hl 
9992			;	ld a, 0			; save empty word 
9992 36 00			ld (hl), 0 
9994			 
9994 c9				ret 
