ba8f					ld (debug_mark+1),a  
ba8f					ld a, (.dmark+2)  
ba8f					ld (debug_mark+2),a  
ba8f				endif  
ba8f 18 03			jr .pastdmark  
ba91 ..			.dmark: db "VAR"  
ba94				if DEMARK_VERSION = 1  
ba94 e1			.pastdmark: pop hl  
ba95				endif  
ba95				if DEMARK_VERSION = 0  
ba95			.pastdmark: pop af  
ba95				endif  
ba95			endm  
# End of macro DMARK
ba95						CALLMONITOR 
ba95				if BASE_CPM=1  
ba95					call debug_vector  
ba95				endif  
