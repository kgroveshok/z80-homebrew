8d5e 3e 2f		  ld a,'0'-1 
8d60 3c			  inc a  
8d61 09			  add hl,bc  
8d62 38 fc		   jr c,$-2 
8d64 12			  ld (de),a 
8d65 13			  inc de 
8d66			 
