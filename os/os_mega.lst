0d96			; if hl < de, z=0, s=1, c=1 
0d96			cmp16:	 
0d96 b7				or a 
0d97 ed 52			sbc hl,de 
0d99 e0				ret po 
0d9a 7c				ld a,h 
0d9b 1f				rra 
