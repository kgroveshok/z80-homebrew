6558			 
6558			; stack over and underflow checks 
6558			 
6558			; init the words to detect the under/overflow 
6558			 
6558			chk_stk_init: 
6558				; a vague random number to check so we dont get any "lucky" hits 
6558 3e 2d			ld a, 45 
655a 6f				ld l, a 
655b 00				nop 
655c 3e 17			ld a, 23 
655e 67				ld h, a 
655f			 
655f 22 b4 f0			ld (chk_word), hl     ; the word we need to check against 
6562			 
6562			;	ld (chk_stund), hl	; stack points.... 
6562 22 3b fe			ld (chk_stovr), hl 
6565 22 03 f9			ld (chk_ret_und), hl 
6568 22 c1 f8			ld (chk_ret_ovr), hl 
656b 22 3f f8			ld (chk_loop_ovr), hl 
656e 22 3d f6			ld (chk_data_ovr), hl 
6571 c9				ret 
6572				 
6572			check_stacks: 
6572				; check all stack words 
6572			 
6572 e5				push hl 
6573 d5				push de 
6574			 
6574			;	ld de,(chk_word) 
6574			;	ld hl, (chk_stund)	; stack points.... 
6574			;	if DEBUG_STK_FAULT 
6574			;		DMARK "FAa" 
6574			;		CALLMONITOR 
6574			;	endif 
6574			;	call cmp16 
6574			;	jp z, .chk_faulta 
6574			; 
6574			;	ld de, sfaultsu 
6574			;	jp .chk_fault 
6574			 
6574 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
6577 ed 5b b4 f0		ld de,(chk_word) 
657b				if DEBUG_STK_FAULT 
657b					DMARK "FAb" 
657b					CALLMONITOR 
657b				endif 
657b cd 96 0d			call cmp16 
657e 28 06			jr z, .chk_fault1 
6580 11 25 66			ld de, sfaultso 
6583 c3 d5 65			jp .chk_fault 
6586			.chk_fault1:  
6586 2a 03 f9			ld hl, (chk_ret_und) 
6589 ed 5b b4 f0		ld de,(chk_word) 
658d				if DEBUG_STK_FAULT 
658d					DMARK "FAU" 
658d					CALLMONITOR 
658d				endif 
658d cd 96 0d			call cmp16 
6590 ca 99 65			jp z, .chk_fault2 
6593 11 35 66			ld de, sfaultru 
6596 c3 d5 65			jp .chk_fault 
6599			.chk_fault2:  
6599 2a c1 f8			ld hl, (chk_ret_ovr) 
659c ed 5b b4 f0		ld de,(chk_word) 
65a0				if DEBUG_STK_FAULT 
65a0					DMARK "FA1" 
65a0					CALLMONITOR 
65a0				endif 
65a0 cd 96 0d			call cmp16 
65a3 ca ac 65			jp z, .chk_fault3 
65a6 11 43 66			ld de, sfaultro 
65a9 c3 d5 65			jp .chk_fault 
65ac			.chk_fault3:  
65ac 2a 3f f8			ld hl, (chk_loop_ovr) 
65af ed 5b b4 f0		ld de,(chk_word) 
65b3				if DEBUG_STK_FAULT 
65b3					DMARK "FA2" 
65b3					CALLMONITOR 
65b3				endif 
65b3 cd 96 0d			call cmp16 
65b6 ca bf 65			jp z, .chk_fault4 
65b9 11 5d 66			ld de, sfaultlo 
65bc c3 d5 65			jp .chk_fault 
65bf			.chk_fault4:  
65bf 2a 3d f6			ld hl, (chk_data_ovr) 
65c2 ed 5b b4 f0		ld de,(chk_word) 
65c6				if DEBUG_STK_FAULT 
65c6					DMARK "FA3" 
65c6					CALLMONITOR 
65c6				endif 
65c6 cd 96 0d			call cmp16 
65c9 ca d2 65			jp z, .chk_fault5 
65cc 11 77 66			ld de, sfaultdo 
65cf c3 d5 65			jp .chk_fault 
