1d48			;  
1d48			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
1d48			; 2DUP 2DROP 2SWAP  
1d48			; @ C@ - get byte  
1d48			; ! C! - store byte 
1d48			; 0< true if less than zero 
1d48			; 0= true if zero 
1d48			; < >  
1d48			; = true if same 
