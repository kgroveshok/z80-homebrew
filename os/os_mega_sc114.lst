8cf2			; Decimal Signed Version 
8cf2			 
8cf2			; DispA 
8cf2			; -------------------------------------------------------------- 
8cf2			; Converts a signed integer value to a zero-terminated ASCII 
8cf2			; string representative of that value (using radix 10). 
8cf2			; -------------------------------------------------------------- 
8cf2			; INPUTS: 
8cf2			;     HL     Value to convert (two's complement integer). 
8cf2			;     DE     Base address of string destination. (pointer). 
8cf2			; -------------------------------------------------------------- 
8cf2			; OUTPUTS: 
8cf2			;     None 
8cf2			; -------------------------------------------------------------- 
8cf2			; REGISTERS/MEMORY DESTROYED 
8cf2			; AF HL 
8cf2			; -------------------------------------------------------------- 
8cf2			 
8cf2			;DispHLToASCII: 
8cf2			;   push    de 
8cf2			;   push    bc 
8cf2			; 
8cf2			;; Detect sign of HL. 
8cf2			;    bit    7, h 
8cf2			;    jr     z, ._DoConvert 
8cf2			; 
8cf2			;; HL is negative. Output '-' to string and negate HL. 
8cf2			;    ld     a, '-' 
8cf2			;    ld     (de), a 
8cf2			;    inc    de 
8cf2			; 
8cf2			;; Negate HL (using two's complement) 
8cf2			;    xor    a 
8cf2			;    sub    l 
8cf2			;    ld     l, a 
8cf2			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
8cf2			;    sbc    a, h 
8cf2			;    ld     h, a 
8cf2			; 
8cf2			;; Convert HL to digit characters 
8cf2			;._DoConvert: 
8cf2			;    ld     b, 0     ; B will count character length of number 
8cf2			;-   ld     a, 10 
8cf2			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
8cf2			;    push   af 
8cf2			;    inc    b 
8cf2			;    ld     a, h 
8cf2			;    or     l 
8cf2			;    jr     nz, - 
8cf2			; 
8cf2			;; Retrieve digits from stack 
8cf2			;-   pop    af 
8cf2			;    or     $30 
8cf2			;    ld     (de), a 
8cf2			;    inc    de 
8cf2			;    djnz   - 
8cf2			; 
8cf2			;; Terminate string with NULL 
8cf2			;    xor    a 
8cf2			;    ld     (de), a 
8cf2			; 
8cf2			;    pop    bc 
8cf2			;    pop    de 
8cf2			;    ret 
8cf2			 
8cf2			;Comments 
8cf2			; 
8cf2			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
8cf2			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
8cf2			;    Note that the output string will not be fixed-width. 
8cf2			; 
8cf2			;Example Usage 
8cf2			; 
8cf2			;    ld    hl, -1004 
8cf2			;    ld    de, OP1 
8cf2			;    call  DispA 
8cf2			;    ld    hl, OP1 
8cf2			;    syscall  PutS 
8cf2			 
8cf2			 
8cf2			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
8cf2			 
8cf2			 
8cf2			;Converts an ASCII string to an unsigned 16-bit integer 
8cf2			;Quits when it reaches a non-decimal digit 
8cf2			 
8cf2			string_to_uint16: 
8cf2			atoui_16: 
8cf2			;Input: 
8cf2			;     DE points to the string 
8cf2			;Outputs: 
8cf2			;     HL is the result 
8cf2			;     A is the 8-bit value of the number 
8cf2			;     DE points to the byte after the number 
8cf2			;Destroys: 
8cf2			;     BC 
8cf2			;       if the string is non-empty, BC is HL/10 
8cf2			;Size:  24 bytes 
8cf2			;Speed: 42+d(104+{0,9}) 
8cf2			;       d is the number of digits in the number 
8cf2			;       max is 640 cycles for a 5 digit number 
8cf2			;Assuming no leading zeros: 
8cf2			;1 digit:  146cc 
8cf2			;2 digit:  250cc 
8cf2			;3 digit:  354cc or 363cc (avg: 354.126cc) 
8cf2			;4 digit:  458cc or 467cc (avg: 458.27cc) 
8cf2			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
8cf2			;avg: 544.81158447265625cc (544+13297/16384) 
8cf2			;=============================================================== 
8cf2 21 00 00		  ld hl,0 
8cf5			.u16a: 
8cf5 1a			  ld a,(de) 
8cf6 d6 30		  sub 30h 
8cf8 fe 0a		  cp 10 
8cfa d0			  ret nc 
8cfb 13			  inc de 
8cfc 44			  ld b,h 
8cfd 4d			  ld c,l 
8cfe 29			  add hl,hl 
8cff 29			  add hl,hl 
8d00 09			  add hl,bc 
8d01 29			  add hl,hl 
8d02 85			  add a,l 
8d03 6f			  ld l,a 
8d04 30 ef		  jr nc,.u16a 
8d06 24			  inc h 
8d07 c3 f5 8c		  jp .u16a 
8d0a			 
8d0a			 
8d0a			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
8d0a			 
8d0a			;written by Zeda 
8d0a			;Converts a 16-bit unsigned integer to an ASCII string. 
8d0a			 
8d0a			uitoa_16: 
8d0a			;Input: 
8d0a			;   DE is the number to convert 
8d0a			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
8d0a			;Output: 
8d0a			;   HL points to the null-terminated ASCII string 
8d0a			;      NOTE: This isn't necessarily the same as the input HL. 
8d0a d5			  push de 
8d0b c5			  push bc 
8d0c f5			  push af 
8d0d eb			  ex de,hl 
8d0e			 
8d0e 01 f0 d8		  ld bc,-10000 
8d11 3e 2f		  ld a,'0'-1 
8d13 3c			  inc a 
8d14 09			  add hl,bc  
8d15 38 fc		   jr c,$-2 
8d17 12			  ld (de),a 
8d18 13			  inc de 
8d19			 
8d19 01 e8 03		  ld bc,1000 
8d1c 3e 3a		  ld a,'9'+1 
8d1e 3d			  dec a  
8d1f 09			  add hl,bc  
8d20 30 fc		   jr nc,$-2 
8d22 12			  ld (de),a 
8d23 13			  inc de 
8d24			 
8d24 01 9c ff		  ld bc,-100 
8d27 3e 2f		  ld a,'0'-1 
8d29 3c			  inc a  
8d2a 09			  add hl,bc  
8d2b 38 fc		   jr c,$-2 
8d2d 12			  ld (de),a 
8d2e 13			  inc de 
8d2f			 
8d2f 7d			  ld a,l 
8d30 26 3a		  ld h,'9'+1 
8d32 25			  dec h  
8d33 c6 0a		  add a,10  
8d35 30 fb		   jr nc,$-3 
8d37 c6 30		  add a,'0' 
8d39 eb			  ex de,hl 
8d3a 72			  ld (hl),d 
8d3b 23			  inc hl 
8d3c 77			  ld (hl),a 
8d3d 23			  inc hl 
8d3e 36 00		  ld (hl),0 
8d40			 
8d40			;Now strip the leading zeros 
8d40 0e fa		  ld c,-6 
8d42 09			  add hl,bc 
8d43 3e 30		  ld a,'0' 
8d45 23			  inc hl  
8d46 be			  cp (hl)  
8d47 28 fc		  jr z,$-2 
8d49			 
8d49			;Make sure that the string is non-empty! 
8d49 7e			  ld a,(hl) 
8d4a b7			  or a 
8d4b 20 01		  jr nz,.atoub 
8d4d 2b			  dec hl 
8d4e			.atoub: 
8d4e			 
8d4e f1			  pop af 
8d4f c1			  pop bc 
8d50 d1			  pop de 
8d51 c9			  ret 
8d52			 
8d52			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
8d52			 
8d52			toUpper: 
8d52			;A is the char. 
8d52			;If A is a lowercase letter, this sets it to the matching uppercase 
8d52			;18cc or 30cc or 41cc 
8d52			;avg: 26.75cc 
8d52 fe 61		  cp 'a' 
8d54 d8			  ret c 
8d55 fe 7b		  cp 'z'+1 
8d57 d0			  ret nc 
8d58 d6 20		  sub 'a'-'A' 
8d5a c9			  ret 
8d5b			 
8d5b			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
8d5b			 
8d5b			; String Length 
8d5b			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
8d5b			 
8d5b			; Get the length of the null-terminated string starting at $8000 hl 
8d5b			;    LD     HL, $8000 
8d5b			 
8d5b			strlenz: 
8d5b			 
8d5b af			    XOR    A               ; Zero is the value we are looking for. 
8d5c 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
8d5d 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
8d5e			                           ; 65, 536 bytes (the entire addressable memory space). 
8d5e ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
8d60			 
8d60			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
8d60 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
8d61 6f			    LD     L, A             ; number of bytes 
8d62 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
8d64 2b			    DEC    HL              ; Compensate for null. 
8d65 c9				ret 
8d66			 
8d66			; Get the length of the A terminated string starting at $8000 hl 
8d66			;    LD     HL, $8000 
8d66			 
8d66			strlent: 
8d66			 
8d66			                  ; A is the value we are looking for. 
8d66 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
8d68 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
8d6a			                           ; 65, 536 bytes (the entire addressable memory space). 
8d6a ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
8d6c			 
8d6c			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
8d6c 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
8d6e 2e 00		    LD     L, 0             ; number of bytes 
8d70 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
8d72 2b			    DEC    HL              ; Compensate for null. 
8d73 c9				ret 
8d74			 
8d74			 
8d74			;Comparing Strings 
8d74			 
8d74			;IN    HL     Address of string1. 
8d74			;      DE     Address of string2. 
8d74			 
8d74			; doc given but wrong??? 
8d74			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
8d74			;      carry  Set if string1 > string2, reset if string1 <= string2. 
8d74			; tested 
8d74			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
8d74			 
8d74			strcmp_old: 
8d74 e5			    PUSH   HL 
8d75 d5			    PUSH   DE 
8d76			 
8d76 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
8d77 be			    CP     (HL)            ; (want to minimize work). 
8d78 38 01		    JR     C, Str1IsBigger 
8d7a 7e			    LD     A, (HL) 
8d7b			 
8d7b			Str1IsBigger: 
8d7b 4f			    LD     C, A             ; Put length in BC 
8d7c 06 00		    LD     B, 0 
8d7e 13			    INC    DE              ; Increment pointers to meat of string. 
8d7f 23			    INC    HL 
8d80			 
8d80			CmpLoop: 
8d80 1a			    LD     A, (DE)          ; Compare bytes. 
8d81 ed a1		    CPI 
8d83 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
8d85 13			    INC    DE              ; Update pointer. 
8d86 ea 80 8d		    JP     PE, CmpLoop 
8d89			 
8d89 d1			    POP    DE 
8d8a e1			    POP    HL 
8d8b 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
8d8c be			    CP     (HL) 
8d8d c9			    RET 
8d8e			 
8d8e			NoMatch: 
8d8e 2b			    DEC    HL 
8d8f be			    CP     (HL)            ; Compare again to affect carry. 
8d90 d1			    POP    DE 
8d91 e1			    POP    HL 
8d92 c9			    RET 
