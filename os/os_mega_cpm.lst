1eee			; A better parser without using malloc and string copies all over the place.  
1eee			; Exec in situ should be faster 
1eee			 
1eee			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
1eee			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
1eee			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
1eee			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
1eee			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
1eee			WORD_SYS_END: equ 0   ; Opcode for all user words 
1eee			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
1eee			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
1eee			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
1eee			 
1eee			; Core word preamble macro 
1eee			 
1eee			CWHEAD:   macro nxtword opcode lit len opflags 
1eee				db WORD_SYS_CORE+opcode             
1eee				; internal op code number 
1eee				dw nxtword            
1eee				; link to next dict word block 
1eee				db len + 1 
1eee				; literal length of dict word inc zero term 
1eee				db lit,0              
1eee				; literal dict word 
1eee			        ; TODO db opflags        
1eee				endm 
