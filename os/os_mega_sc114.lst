9884			FORTH_PARSEV2: equ 0 
9884			FORTH_PARSEV3: equ 0 
9884			FORTH_PARSEV4: equ 0 
9884			FORTH_PARSEV5: equ 0 
9884			FORTH_PARSEV6: equ 1 
