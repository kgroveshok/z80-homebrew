aaf5			; | SCRATCH ( u -- addr ) Pushes address of offset u to stack | DONE 
aaf5			; | | The scratch area provides 32 word array. Can be used as single byte or as a word by passing the offset on stack. Pushes the resulting address to stack.  
aaf5			; | | When used with the direct storage writing/malloc and the !@ or word versions it is possible to construct an expanded and flexible variable system 
aaf5			; | |  
aaf5			; | | e.g.    : score $00 scratch ; 
aaf5			; | |  
aaf5			; | | $00 score ! 
aaf5			; | | $01 score +! 
aaf5			; | |  
aaf5			; | | e.g.   : varword $0a scratch ;  
aaf5			; | | 
aaf5			; | | $8000 varword ! 
aaf5					if DEBUG_FORTH_WORDS_KEY 
aaf5						DMARK "SCR" 
aaf5 f5				push af  
aaf6 3a 0a ab			ld a, (.dmark)  
aaf9 32 5e ee			ld (debug_mark),a  
aafc 3a 0b ab			ld a, (.dmark+1)  
aaff 32 5f ee			ld (debug_mark+1),a  
ab02 3a 0c ab			ld a, (.dmark+2)  
ab05 32 60 ee			ld (debug_mark+2),a  
ab08 18 03			jr .pastdmark  
ab0a ..			.dmark: db "SCR"  
ab0d f1			.pastdmark: pop af  
ab0e			endm  
# End of macro DMARK
