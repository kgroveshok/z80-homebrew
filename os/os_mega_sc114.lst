920f			config_dir: 
920f			 
920f				; for the config menus that need to build a directory of storage call this routine 
920f				; it will construct a menu in scratch to pass to menu 
920f			 
920f				; open storage device 
920f			 
920f				; execute DIR to build a list of files and their ids into scratch in menu format 
920f				; once the menu has finished then will need to call config_fdir to release the strings 
920f				 
920f				; c = number items 
920f			 
920f				 
920f				call storage_get_block_0 
920f			 
920f				ld hl, store_page     ; get current id count 
920f				ld b, (hl) 
920f				ld c, 0    ; count of files   
920f			 
920f			 
920f				ld hl, scratch 
920f				ld (store_tmp2), hl    ; location to poke strings 
920f			 
920f				; check for empty drive 
920f			 
920f				ld a, 0 
920f				cp b 
920f				jp z, .dirdone 
920f			 
