a77a					ld (debug_mark+1),a  
a77a					ld a, (.dmark+2)  
a77a					ld (debug_mark+2),a  
a77a				endif  
a77a 18 04			jr .pastdmark  
a77c ..			.dmark: db "SCR"  
a77f				if DEMARK_VERSION = 1  
a77f 00					db 0  
a780				endif  
