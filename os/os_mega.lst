1120			;------------------------------------------------------------------------------ 
1120			;     heap_init                                                               : 
1120			;                                                                             : 
1120			; Description                                                                 : 
1120			;     Initialise the heap and make it ready for malloc and free operations.   : 
1120			;                                                                             : 
1120			;     The heap is maintained as a linked list, starting with an initial       : 
1120			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1120			;     the first free block in the heap. Each block then points to the next    : 
1120			;     free block within the heap, and the free list ends at the first block   : 
1120			;     with a null pointer to the next free block.                             : 
1120			;                                                                             : 
1120			; Parameters                                                                  : 
1120			;     Inputs are compile-time only. Two defines which specify the starting    : 
1120			;     address of the heap and its size are required, along with a memory      : 
1120			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1120			;     principally stores a pointer to the first free block in the heap.       : 
1120			;                                                                             : 
1120			; Returns                                                                     : 
1120			;     Nothing                                                                 : 
1120			;------------------------------------------------------------------------------ 
1120			heap_init: 
1120 e5			      push  HL 
1121			 
1121			      ; Initialise free list struct 
1121 21 0e 80		      ld    HL, heap_start 
1124 22 0a 80		      ld    (free_list), HL 
1127 21 00 00		      ld    HL, 0 
112a 22 0c 80		      ld    (free_list+2), HL 
112d			 
112d			      ; Insert first free block at bottom of heap, consumes entire heap 
112d 21 af f0		      ld    HL, heap_start+heap_size-4 
1130 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
1133 21 a1 70		      ld    HL, heap_size-4 
1136 22 10 80		      ld    (heap_start+2), HL      ; Block size 
1139			 
1139			      ; Insert end of free list block at top of heap - two null words will 
1139			      ; terminate the free list 
1139 21 00 00		      ld    HL, 0 
113c 22 b1 f0		      ld    (heap_start+heap_size-2), HL 
113f 22 af f0		      ld    (heap_start+heap_size-4), HL 
1142			 
1142 e1			      pop   HL 
1143			 
1143 c9			      ret 
1144			 
1144			 
1144			;------------------------------------------------------------------------------ 
1144			;     malloc                                                                  : 
1144			;                                                                             : 
1144			; Description                                                                 : 
1144			;     Allocates the wanted space from the heap and returns the address of the : 
1144			;     first useable byte of the allocation.                                   : 
1144			;                                                                             : 
1144			;     Allocations can happen in one of two ways:                              : 
1144			;                                                                             : 
1144			;     1. A free block may be found which is the exact size wanted. In this    : 
1144			;        case the block is removed from the free list and retuedn to the      : 
1144			;        caller.                                                              : 
1144			;     2. A free block may be found which is larger than the size wanted. In   : 
1144			;        this case, the larger block is split into two. The first portion of  : 
1144			;        this block will become the requested space by the malloc call and    : 
1144			;        is returned to the caller. The second portion becomes a new free     : 
1144			;        block, and the free list is adjusted to maintain continuity via this : 
1144			;        newly created block.                                                 : 
1144			;                                                                             : 
1144			;     malloc does not set any initial value in the allocated space, the       : 
1144			;     caller is required to do this as required.                              : 
1144			;                                                                             : 
1144			;     This implementation of malloc uses the stack exclusively, and is        : 
1144			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1144			;     advisable to disable interrupts before calling malloc, and recommended  : 
1144			;     to avoid the use of malloc inside ISRs in general.                      : 
1144			;                                                                             : 
1144			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1144			;                                                                             : 
1144			; Parameters                                                                  : 
1144			;     HL  Number of bytes wanted                                              : 
1144			;                                                                             : 
1144			; Returns                                                                     : 
1144			;     HL  Address of the first useable byte of the allocation                 : 
1144			;                                                                             : 
1144			; Flags                                                                       : 
1144			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1144			;                                                                             : 
1144			; Stack frame                                                                 : 
1144			;       |             |                                                       : 
1144			;       +-------------+                                                       : 
1144			;       |     BC      |                                                       : 
1144			;       +-------------+                                                       : 
1144			;       |     DE      |                                                       : 
1144			;       +-------------+                                                       : 
1144			;       |     IX      |                                                       : 
1144			;       +-------------+                                                       : 
1144			;       |  prev_free  |                                                       : 
1144			;   +4  +-------------+                                                       : 
1144			;       |  this_free  |                                                       : 
1144			;   +2  +-------------+                                                       : 
1144			;       |  next_free  |                                                       : 
1144			;   +0  +-------------+                                                       : 
1144			;       |             |                                                       : 
1144			;                                                                             : 
1144			;------------------------------------------------------------------------------ 
1144			 
1144			 
1144			;malloc: 
1144			; 
1144			;	SAVESP ON 1 
1144			; 
1144			;	call malloc_code 
1144			; 
1144			;	CHECKSP ON 1 
1144			;	ret 
1144			 
1144			 
1144			malloc: 
1144 c5			      push  BC 
1145 d5			      push  DE 
1146 dd e5		      push  IX 
1148			if DEBUG_FORTH_MALLOC_HIGH 
1148			call malloc_guard_entry 
1148			endif 
1148			 
1148					if DEBUG_FORTH_MALLOC 
1148						DMARK "mal" 
1148						CALLMONITOR 
1148					endif 
1148 7c			      ld    A, H                    ; Exit if no space requested 
1149 b5			      or    L 
114a ca 09 12		      jp    Z, malloc_early_exit 
114d			 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			; 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			;inc hl 
114d			 
114d			 
114d			 
114d			 
114d					if DEBUG_FORTH_MALLOC 
114d						DMARK "maA" 
114d						CALLMONITOR 
114d					endif 
114d			      ; Set up stack frame 
114d eb			      ex    DE, HL 
114e 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1151 39			      add   HL, SP 
1152 f9			      ld    SP, HL 
1153 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1157 dd 39		      add   IX, SP 
1159			 
1159			      ; Setup initial state 
1159 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
115c 19			      add   HL, DE 
115d			 
115d 44			      ld    B, H                    ; Move want to BC 
115e 4d			      ld    C, L 
115f			 
115f 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
1162 dd 75 04		      ld    (IX+4), L 
1165 dd 74 05		      ld    (IX+5), H 
1168			 
1168 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
1169 23			      inc   HL 
116a 56			      ld    D, (HL) 
116b dd 73 02		      ld    (IX+2), E 
116e dd 72 03		      ld    (IX+3), D 
1171 eb			      ex    DE, HL                  ; this_free ptr into HL 
1172			 
1172					if DEBUG_FORTH_MALLOC 
1172						DMARK "maB" 
1172						CALLMONITOR 
1172					endif 
1172			      ; Loop through free block list to find some space 
1172			malloc_find_space: 
1172 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
1173 23			      inc   HL 
1174 56			      ld    D, (HL) 
1175			 
1175 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1176 b3			      or    E 
1177 ca 03 12		      jp    Z, malloc_no_space 
117a			 
117a dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
117d dd 72 01		      ld    (IX+1), D 
1180			 
1180			      ; Does this block have enough space to make the allocation? 
1180 23			      inc   HL                      ; Load free block size into DE 
1181 5e			      ld    E, (HL) 
1182 23			      inc   HL 
1183 56			      ld    D, (HL) 
1184			 
1184 eb			      ex    DE, HL                  ; Check size of block against want 
1185 b7			      or    A                       ; Ensure carry flag clear 
1186 ed 42		      sbc   HL, BC 
1188 e5			      push  HL                      ; Store the result for later (new block size) 
1189			 
1189 ca d8 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
118c 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
118e			 
118e			      ; this_free block is not big enough, setup ptrs to test next free block 
118e e1			      pop   HL                      ; Discard previous result 
118f			 
118f dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1192 dd 66 03		      ld    H, (IX+3) 
1195 dd 75 04		      ld    (IX+4), L 
1198 dd 74 05		      ld    (IX+5), H 
119b			 
119b dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
119e dd 66 01		      ld    H, (IX+1) 
11a1 dd 75 02		      ld    (IX+2), L 
11a4 dd 74 03		      ld    (IX+3), H 
11a7			 
11a7					if DEBUG_FORTH_MALLOC 
11a7						DMARK "MA>" 
11a7						CALLMONITOR 
11a7					endif 
11a7 18 c9		      jr    malloc_find_space 
11a9			 
11a9			      ; split a bigger block into two - requested size and remaining size 
11a9			malloc_alloc_split: 
11a9					if DEBUG_FORTH_MALLOC 
11a9						DMARK "MAs" 
11a9						CALLMONITOR 
11a9					endif 
11a9 eb			      ex    DE, HL                  ; Calculate address of new free block 
11aa 2b			      dec   HL 
11ab 2b			      dec   HL 
11ac 2b			      dec   HL 
11ad 09			      add   HL, BC 
11ae			 
11ae			      ; Create a new block and point it at next_free 
11ae dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
11b1 dd 56 01		      ld    D, (IX+1) 
11b4			 
11b4 73			      ld    (HL), E                 ; Store next_free ptr into new block 
11b5 23			      inc   HL 
11b6 72			      ld    (HL), D 
11b7			 
11b7 d1			      pop   DE                      ; Store size of new block into new block 
11b8 23			      inc   HL 
11b9 73			      ld    (HL), E 
11ba 23			      inc   HL 
11bb 72			      ld    (HL), D 
11bc			 
11bc			      ; Update this_free ptr to point to new block 
11bc 2b			      dec   HL 
11bd 2b			      dec   HL 
11be 2b			      dec   HL 
11bf			 
11bf dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
11c2 dd 56 03		      ld    D, (IX+3) 
11c5			 
11c5 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
11c8 dd 74 03		      ld    (IX+3), H 
11cb			 
11cb			      ; Modify this_free block to be allocation 
11cb eb			      ex    DE, HL 
11cc af			      xor   A                       ; Null the next block ptr of allocated block 
11cd 77			      ld    (HL), A 
11ce 23			      inc   HL 
11cf 77			      ld    (HL), A 
11d0			 
11d0 23			      inc   HL                      ; Store want size into allocated block 
11d1 71			      ld    (HL), C 
11d2 23			      inc   HL 
11d3 70			      ld    (HL), B 
11d4 23			      inc   HL 
11d5 e5			      push  HL                      ; Address of allocation to return 
11d6			 
11d6 18 19		      jr    malloc_update_links 
11d8			 
11d8			malloc_alloc_fit: 
11d8 e1			      pop   HL                      ; Dont need new block size, want is exact fit 
11d9			 
11d9					if DEBUG_FORTH_MALLOC 
11d9						DMARK "MAf" 
11d9						CALLMONITOR 
11d9					endif 
11d9			      ; Modify this_free block to be allocation 
11d9 eb			      ex    DE, HL 
11da 2b			      dec   HL 
11db 2b			      dec   HL 
11dc 2b			      dec   HL 
11dd			 
11dd af			      xor   A                       ; Null the next block ptr of allocated block 
11de 77			      ld    (HL), A 
11df 23			      inc   HL 
11e0 77			      ld    (HL), A 
11e1			 
11e1 23			      inc   HL                      ; Store address of allocation to return 
11e2 23			      inc   HL 
11e3 23			      inc   HL 
11e4 e5			      push  HL 
11e5			 
11e5			      ; Copy next_free ptr to this_free, remove allocated block from free list 
11e5 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11e8 dd 66 01		      ld    H, (IX+1) 
11eb			 
11eb dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11ee dd 74 03		      ld    (IX+3), H 
11f1			 
11f1			 
11f1			malloc_update_links: 
11f1			      ; Update prev_free ptr to point to this_free 
11f1 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
11f4 dd 66 05		      ld    H, (IX+5) 
11f7			 
11f7 dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
11fa dd 56 03		      ld    D, (IX+3) 
11fd			 
11fd 73			      ld    (HL), E                 ; this_free ptr into prev_free 
11fe 23			      inc   HL 
11ff 72			      ld    (HL), D 
1200			 
1200					if DEBUG_FORTH_MALLOC 
1200						DMARK "Mul" 
1200						CALLMONITOR 
1200					endif 
1200			      ; Clear the Z flag to indicate successful allocation 
1200 7a			      ld    A, D 
1201 b3			      or    E 
1202			 
1202 d1			      pop   DE                      ; Address of allocation 
1203					if DEBUG_FORTH_MALLOC 
1203						DMARK "MAu" 
1203						CALLMONITOR 
1203					endif 
1203			 
1203			malloc_no_space: 
1203 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
1206 39			      add   HL, SP 
1207 f9			      ld    SP, HL 
1208			 
1208 eb			      ex    DE, HL                  ; Alloc addr into HL for return 
1209					if DEBUG_FORTH_MALLOC 
1209						DMARK "MAN" 
1209						CALLMONITOR 
1209					endif 
1209			 
1209			malloc_early_exit: 
1209					if DEBUG_FORTH_MALLOC 
1209						DMARK "MAx" 
1209						CALLMONITOR 
1209					endif 
1209 dd e1		      pop   IX 
120b d1			      pop   DE 
120c c1			      pop   BC 
120d			 
120d			if DEBUG_FORTH_MALLOC_HIGH 
120d			call malloc_guard_exit 
120d			call malloc_guard_zerolen 
120d			endif 
120d c9			      ret 
