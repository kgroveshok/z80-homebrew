98dc			FORTH_PARSEV1: equ 0 
98dc			FORTH_PARSEV2: equ 0 
98dc			FORTH_PARSEV3: equ 0 
98dc			FORTH_PARSEV4: equ 0 
98dc			FORTH_PARSEV5: equ 0 
98dc			FORTH_PARSEV6: equ 1 
98dc			 
