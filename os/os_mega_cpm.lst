11b6			StrictStrCmp: 
11b6				; Load next chars of each string 
11b6 1a				ld a, (de) 
11b7 47				ld b, a 
11b8 7e				ld a, (hl) 
11b9				; Compare 
11b9 b8				cp b 
11ba				; Return non-zero if chars don't match 
11ba c0				ret nz 
11bb				; Check for end of both strings 
11bb fe 00			cp "\0" 
11bd				; Return if strings have ended 
11bd c8				ret z 
11be				; Otherwise, advance to next chars 
11be 23				inc hl 
11bf 13				inc de 
11c0 18 f4			jr StrictStrCmp 
11c2			 
