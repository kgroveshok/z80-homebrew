9ca4			user_word_eol:  
9ca4				; hl contains the pointer to where to create a linked list item from the end 
9ca4				; of the user dict to continue on at the system word dict 
9ca4				 
9ca4				; poke the stub of the word list linked list to repoint to rom words 
9ca4			 
9ca4				; stub format 
9ca4				; db   word id 
9ca4				; dw    link to next word 
9ca4			        ; db char length of token 
9ca4				; db string + 0 term 
9ca4				; db exec code....  
9ca4			 
9ca4			;	ld a, WORD_SYS_ROOT     ; root word 
9ca4 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9ca6 23				inc hl 
9ca7			 
9ca7 11 50 9e			ld de, sysdict 
9caa 73				ld (hl), e		; next word link ie system dict 
9cab 23				inc hl 
9cac 72				ld (hl), d		; next word link ie system dict 
9cad 23				inc hl	 
9cae			 
9cae			;	ld (hl), sysdict		; next word link ie system dict 
9cae			;	inc hl 
9cae			;	inc hl 
9cae			 
9cae			;	inc hl 
9cae			;	inc hl 
9cae			 
9cae			;	ld a, 2			; word length is 0 
9cae 36 02			ld (hl), 2 
9cb0 23				inc hl 
9cb1			 
9cb1			;	ld a, '~'			; word length is 0 
9cb1 36 7e			ld (hl), '~' 
9cb3 23				inc hl 
9cb4			;	ld a, 0			; save empty word 
9cb4 36 00			ld (hl), 0 
