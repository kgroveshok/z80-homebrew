9ca7			user_word_eol:  
9ca7				; hl contains the pointer to where to create a linked list item from the end 
9ca7				; of the user dict to continue on at the system word dict 
9ca7				 
9ca7				; poke the stub of the word list linked list to repoint to rom words 
9ca7			 
9ca7				; stub format 
9ca7				; db   word id 
9ca7				; dw    link to next word 
9ca7			        ; db char length of token 
9ca7				; db string + 0 term 
9ca7				; db exec code....  
9ca7			 
9ca7			;	ld a, WORD_SYS_ROOT     ; root word 
9ca7 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9ca9 23				inc hl 
9caa			 
9caa 11 53 9e			ld de, sysdict 
9cad 73				ld (hl), e		; next word link ie system dict 
9cae 23				inc hl 
9caf 72				ld (hl), d		; next word link ie system dict 
9cb0 23				inc hl	 
9cb1			 
9cb1			;	ld (hl), sysdict		; next word link ie system dict 
9cb1			;	inc hl 
9cb1			;	inc hl 
9cb1			 
9cb1			;	inc hl 
9cb1			;	inc hl 
9cb1			 
9cb1			;	ld a, 2			; word length is 0 
9cb1 36 02			ld (hl), 2 
9cb3 23				inc hl 
9cb4			 
9cb4			;	ld a, '~'			; word length is 0 
9cb4 36 7e			ld (hl), '~' 
9cb6 23				inc hl 
9cb7			;	ld a, 0			; save empty word 
9cb7 36 00			ld (hl), 0 
9cb9			 
9cb9 c9				ret 
