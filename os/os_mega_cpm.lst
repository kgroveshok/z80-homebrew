0153			  
0153			; memory allocation   
0153			  
0153			chk_stund: equ tos+2           ; underflow check word  
0153			chk_stovr: equ chk_stund-stacksize -2; overflow check word  
0153			  
0153			; keyscan table needs rows x cols buffer  
0153			;key_rows: equ 5     ; TODO move out to mini and maxi + 1 null  
0153			;key_cols: equ 10    ; TODO move out to mini and maxi + 1 null  
0153			  
0153			key_macroroot:  equ chk_stovr - 2       ; root ptr for start of keyboard macro strings  
0153			key_macrolast:  equ key_macroroot - 2   ; last macro defined to aid linked list ptr  
0153			;  
0153			; Macro linked list format  
0153			; key code single byte   
0153			; ptr to next or zero if last in the list  
0153			; zero term string   
0153			  
0153			;keyscan_table_row1: equ chk_stovr -key_cols-1  
0153			keyscan_table_row1: equ key_macrolast -key_cols-1  
0153			keyscan_table_row2: equ keyscan_table_row1-key_cols-1  
0153			keyscan_table_row3: equ keyscan_table_row2-key_cols-1  
0153			keyscan_table_row4: equ keyscan_table_row3-key_cols-1  
0153			keyscan_table_row5: equ keyscan_table_row4-key_cols-1  
0153			keyscan_table: equ keyscan_table_row5-(key_cols*key_rows)-1  
0153			keyscan_scancol: equ keyscan_table-key_cols  
0153			;keyscan_table_len: equ key_rows*key_cols  
0153			;keybufptr: equ keyscan_table - 2  
0153			;keysymbol: equ keybufptr - 1  
0153			key_held: equ keyscan_scancol-1	; currently held  
0153			key_held_prev: equ key_held - 1   ; previously held (to detect bounce and cycle of key if required)  
0153			key_repeat_ct: equ key_held_prev - 4 ; timers (two words)  
0153			key_fa: equ key_repeat_ct -1 ;  
0153			key_fb: equ key_fa -1 ;  
0153			key_fc: equ key_fb -1 ;  
0153			key_fd: equ key_fc -1 ;  
0153			key_face_held: equ key_fd - 1   
0153			; flag for enabling/disabling various hardware diag loading via block 0 on bank 1  
0153			  
0153			hardware_config: equ key_face_held - 10  
0153			  
0153			; hardware config switches  
0153			; TODO add bitmasks on includes for hardware  
0153			; high byte for expansion ids  
0153			;     0000 0000  no card inserted  
0153			;     0000 0001  storage card inserted  
0153			;     0000 0010  spi sd card active  
0153			;     0000 0100  LED is on, 0 if off  
0153			;     1000 0000  NMI has been activated  
0153			  
0153			;       
0153			; low byte:  
0153			;     0000 0001   4x4 keypad  
0153			;     0000 0010   full keyboard  
0153			;     0000 0011   spi/ext keyboard  
0153			;     0000 0100   20x4 lcd  
0153			;     0000 1000   40x4 lcd  
0153			;     0000 1100   spi/ext display  
0153			;     0001 0000   ide interface available  
0153			  
0153			hardware_word: equ hardware_config - 2  
0153			  
0153			; debug marker - optional display of debug point on the debug screens  
0153			  
0153			nmi_vector:  equ hardware_word - 3   ; vector to the nmi handler  
0153			debug_vector:  equ nmi_vector - 3   ; vector to the debug handler  
0153			parse_vector:  equ debug_vector - 3 ; vector to the parser vector  
0153			  
0153			debug_umark: equ parse_vector - 6  ; current user mark  
0153			  
0153			if DEMARK_VERSION = 1  
0153			debug_mark: equ debug_umark - 2    ; internal word debug points - pointer to the string to print  
0153			endif  
0153			if DEMARK_VERSION = 0  
0153			debug_mark: equ debug_umark - 4    ; internal word debug points - poke a four char string with zero term  
0153			endif  
0153			  
0153			; input_str vars  
0153			input_ptr:  equ debug_mark - 2    ; ptr to the current cursor position of string currently being edited  on entry starting   
0153			input_start:  equ input_ptr - 2    ; ptr to the start of string   
0153			input_size: equ input_start -1  ; number of chars  
0153			input_display_size: equ input_size -1  ; TODO number of chars that are displayable. if < input_size then scroll   
0153			input_at_pos: equ input_display_size - 1 ; frame buffer offset for start of input  
0153			input_under_cursor: equ input_at_pos - 1 ; char under the cursor so we can blink it  
0153			input_at_cursor: equ input_under_cursor - 1 ; offset of cursor to current start of string  
0153			input_cur_flash: equ input_at_cursor - 2 ;  timeout for cursor flash  
0153			input_cur_onoff: equ input_cur_flash - 1 ;  cursor blink on or off  
0153			input_len: equ input_cur_onoff - 5 ; length of current input  
0153			input_cursor: equ input_len - 5 ; offset of cursor to current start of string  
0153			  
0153			; cursor blink rate  
0153			CUR_BLINK_RATE: equ $09  
0153			;CUR_BLINK_RATE: equ 15  
0153			  
0153			key_actual_pressed: equ input_cursor - 1   
0153			key_symbol: equ key_actual_pressed - 1   
0153			key_shift: equ key_symbol - 1   
0153			  
0153			; Display allocation  
0153			  
0153			;display_rows: equ 4     ; move out to mini and mega files  
0153			;display_cols: equ 20  
0153			  
0153			display_fb_len: equ display_rows*display_cols  
0153			  
0153			; primary frame buffer     
0153			display_fb0: equ  key_shift-display_fb_len -1 ; -display_fb_len-1          ; cli input     TODO why is that doubling up?  
0153			; working frame buffers  
0153			display_fb1: equ  display_fb0-display_fb_len -1 ; -display_fb_len-1          ; default running program  
0153			display_fb3: equ  display_fb1-display_fb_len - 1  
0153			display_fb2: equ  display_fb3-display_fb_len - 1  
0153			;  
0153			; pointer to active frame buffer  
0153			display_fb_active: equ display_fb2 - 2  
0153			display_lcde1e2: equ display_fb_active - 1         ; 0=e1, 1=e2   For E1/E2 selection when using the lcd 4x40 display  
0153			display_write_tmp: equ display_lcde1e2 - 2  
0153			display_active:  equ display_write_tmp-3   ; current state of activity char (plus room to write string)  
0153			  
0153			;  
0153			  
0153			;; can load into de directory  
0153			cursor_col: equ display_active-1  
0153			cursor_row: equ cursor_col-1  
0153			cursor_ptr: equ cursor_row - 1     ;  actual offset into lcd memory for row and col combo  
0153			cursor_shape: equ cursor_ptr - 2   ; char used for the current cursor   
0153			  
0153			; maths vars  
0153			  
0153			LFSRSeed: equ cursor_shape -20   
0153			randData: equ LFSRSeed - 2  
0153			xrandc: equ randData - 2  
0153			stackstore: equ xrandc - 2  
0153			seed1: equ  stackstore -2   
0153			seed2: equ seed1 - 2  
0153			  
0153			; cf storage vars  
0153			  
0153			iErrorNum:  equ seed2-1         ;Error number  
0153			iErrorReg:  equ iErrorNum -1              ;Error register  
0153			iErrorVer:  equ iErrorReg - 1              ;Verify error flag  
0153			  
0153			store_bank_active: equ iErrorVer - (5 + 8 ) 		; TODO not used.  indicator of which storage banks are available to use 5 on board and 8 in cart  
0153			  
0153			STORE_BLOCK_LOG:  equ   280      ; TODO remove.... Logical block size     
0153			  
0153			store_page: equ store_bank_active-STORE_BLOCK_LOG-1            ; bigger than page size for eeprom so we can join multiple blocks if they are continuation records  
0153			;?????store_ffpage: equ store_page-STORE_BLOCK_LOG            ; page size for eeprom?????  
0153			store_readptr: equ store_page-2       ; tracks the file extent during storage_read of continuation blocks  
0153			store_readbuf: equ store_readptr-2       ; tracks the position for the buffer during storage_read of continuation blocks  
0153			store_longread: equ store_readbuf -1 ;   if zero then only read one block. If not zero then do a read for as long as required  
0153			store_tmp1: equ store_longread - 2      ; temp pointer holders during ops  
0153			store_tmp2: equ store_tmp1 - 2        ; temp pointer holders during ops  
0153			store_tmp3: equ store_tmp2 - 2        ; temp pointer holders during ops  
0153			store_tmpid: equ store_tmp3 - 1		; page temp id  
0153			store_tmpext: equ store_tmpid - 1		; file extent temp  
0153			store_readcont: equ store_tmpid - 1		; If current read results in an overflow buffer to next record flag it up  
0153			store_openaddr: equ store_readcont - 2		; file block address of current opened file for read  
0153			store_openext: equ store_openaddr - 1		; file extent of current opened file for read  
0153			store_openmaxext: equ store_openext - 1		; max extent of current opened file for read  
0153			store_filecache: equ store_openmaxext-2   ;  TODO (using just one for now)  file id + extent count cache * 5  
0153			store_tmppageid: equ store_filecache-2    ; phyical page id temp  
0153			;  
0153			; spi vars  
0153			  
0153			  
0153			spi_clktime: equ store_tmppageid - 1      ; holds the number of ms that happens between spi clock pulses  
0153			spi_cartdev: equ spi_clktime - 1      ; holds bit mask to send to portb (ext spi) devices  
0153			spi_cartdev2: equ spi_cartdev - 1      ; holds bit mask to send to portb's shift reg devices  
0153			spi_portbyte: equ spi_cartdev2 - 1      ; holds bit mask to send to spi bus   
0153			spi_device: equ spi_portbyte - 1    ; bit mask to send to porta (eeproms) devices  
0153			spi_device_id: equ spi_device - 1    ; human readable bank number  
0153			  
0153			;;;;; Tape support params  
0153			  
0153			tape_port: equ spi_device_id - 1     ; device number  
0153			tape_pulse_high: equ tape_port - 1       ; how many pulses mean 1  
0153			tape_pulse_low: equ tape_pulse_high - 1    ; how many pulses mean 0  
0153			tape_samples: equ tape_pulse_low - 2   ; how many sample cycles are needed to count the pulses  
0153			tape_tm_gap: equ tape_samples - 1      ; inter bit gap in ms  
0153			tape_tm_high: equ tape_tm_gap - 2      ; cycles for a high pulse  
0153			tape_tm_low: equ tape_tm_high - 2     ; cycles for a low pulse  
0153			tape_sync: equ tape_tm_low-10     ; counters used in detecting tape header  
0153			  
0153			;;;;; forth cli params  
0153			  
0153			; TODO use a different frame buffer for forth???  
0153			  
0153			f_cursor_ptr:  equ tape_sync - 1  ; offset into frame buffer for any . or EMIT output  
0153			cli_buffer: equ f_cursor_ptr - 20     ; temp hold - maybe not needed  
0153			cli_origtoken: equ cli_buffer - 2     ; pointer to the text of token for this word being checked  
0153			cli_token: equ cli_origtoken - 2     ; pointer to the text of token for this word being checked  
0153			cli_execword: equ cli_token - 2      ; pointer to start of code for this word  
0153			cli_nextword: equ cli_execword - 2      ; pointer to start of next word in dict  
0153			cli_ptr: equ cli_nextword - 2           ; pointer to start of word to parse by forth kernel (working)  
0153			cli_origptr: equ cli_ptr - 2           ; pointer to start of word to parse which resets cli_ptr on each word test  
0153			  
0153			cli_mvdot: equ cli_origptr - 1 ;     ; true will move the cursor once something is displayed  
0153			cli_autodisplay: equ cli_mvdot - 1 ;     ; true will auto update the display (slow) otherwise need to use DRAW  
0153			cli_var_array: equ cli_autodisplay - ( 10 * 2 ) ; word or string pointer variables using V@0-V@9  
0153			cli_var_array2: equ cli_var_array - ( 26 * 2 ) ; word or string pointer variables using VAR word  
0153			cli_ret_sp: equ cli_var_array2 - 2    ; ret stack pointer  
0153			cli_loop_sp: equ cli_ret_sp - 2   ; data stack pointer  
0153			cli_data_sp: equ cli_loop_sp - 2   ; data stack pointer  
0153			  
0153			chk_ret_und: equ cli_data_sp-2           ; underflow check word  
0153			cli_ret_stack: equ chk_ret_und - STACK_RET_SIZE      ; TODO could I just use normal stack for this? - use linked list for looping  
0153			chk_ret_ovr: equ cli_ret_stack -2; overflow check word  
0153			cli_loop_stack: equ chk_ret_ovr - STACK_LOOP_SIZE      ; TODO could I just use normal stack for this? - use linked list for looping  
0153			chk_loop_ovr: equ cli_loop_stack -2; overflow check word  
0153			cli_data_stack: equ chk_loop_ovr - STACK_DATA_SIZE		 ;   
0153			chk_data_ovr: equ cli_data_stack -2; overflow check word  
0153			  
0153			os_var_array: equ chk_data_ovr - (32 * 2)      ;   32 word array for use using the SCRATCH word  
0153			  
0153			; os/forth token vars  
0153			  
0153			os_last_cmd: equ os_var_array-255  
0153			os_cli_cmd: equ os_last_cmd-255              ; cli command entry line  
0153			os_current_i: equ os_cli_cmd-2  
0153			os_cur_ptr: equ os_current_i-2  
0153			os_word_scratch: equ os_cur_ptr-30  
0153			os_tok_len: equ os_word_scratch - 2  
0153			os_tok_ptr: equ os_tok_len - 2               ; our current PC ptr  
0153			os_tok_malloc: equ os_tok_ptr - 2  
0153			os_last_new_uword: equ os_tok_malloc - 2    ; hold start of last user word added  
0153			os_input: equ os_last_new_uword-255    ; buffer for EDIT word  
0153			execscratch: equ os_input-255        ; exec cmd eval buffer  
0153			scratch: equ execscratch-255  
0153			  
0153			os_stack_1: equ scratch - 3       ; stack holding area 1  
0153			os_stack_2: equ os_stack_1 - 3       ; stack holding area 2  
0153			os_stack_3: equ os_stack_2 - 3       ; stack holding area 3  
0153			os_stack_4: equ os_stack_3 - 3       ; stack holding area 4  
0153			  
0153			  
0153			; temp locations for new word processing to save on adding more   
0153			  
0153			os_new_malloc: equ os_stack_4-2  
0153			os_new_parse_len: equ os_new_malloc - 2  
0153			os_new_word_len: equ os_new_parse_len - 2  
0153			os_new_work_ptr: equ os_new_word_len - 2  
0153			os_new_src_ptr: equ os_new_work_ptr - 2  
0153			os_new_exec: equ os_new_src_ptr - 2  
0153			os_new_exec_ptr: equ os_new_exec - 2  
0153			  
0153			; resume memory alloocations....  
0153			  
0153			;os_view_disable: equ os_new_exec_ptr - 1  
0153			os_view_af: equ os_new_exec_ptr - 2  
0153			os_view_hl: equ os_view_af -2  
0153			os_view_de: equ os_view_hl - 2  
0153			os_view_bc: equ os_view_de - 2  
0153			  
0153			; stack checksum word  
0153			if DEBUG_STACK_IMB  
0153				curframe: equ  os_view_de - 5  
0153				store_sp: equ curframe - (STACK_IMB_STORE*4)  
0153				chk_word: equ store_sp - 2		 ; this is the word to init and then check against to detect stack corruption. Held far away from all stacks  
0153			else  
0153				chk_word: equ os_view_bc - 2		 ; this is the word to init and then check against to detect stack corruption. Held far away from all stacks  
0153			endif  
