5e57			; stack over and underflow checks 
5e57			 
5e57			; init the words to detect the under/overflow 
5e57			 
5e57			chk_stk_init: 
5e57				; a vague random number to check so we dont get any "lucky" hits 
5e57 3e 2d			ld a, 45 
5e59 6f				ld l, a 
5e5a 00				nop 
5e5b 3e 17			ld a, 23 
5e5d 67				ld h, a 
5e5e			 
5e5e 22 cd f0			ld (chk_word), hl     ; the word we need to check against 
5e61			 
5e61			;	ld (chk_stund), hl	; stack points.... 
5e61 22 3b fe			ld (chk_stovr), hl 
5e64 22 1c f9			ld (chk_ret_und), hl 
5e67 22 da f8			ld (chk_ret_ovr), hl 
5e6a 22 58 f8			ld (chk_loop_ovr), hl 
5e6d 22 56 f6			ld (chk_data_ovr), hl 
5e70 c9				ret 
5e71				 
5e71			check_stacks: 
5e71				; check all stack words 
5e71			 
5e71 e5				push hl 
5e72 d5				push de 
5e73			 
5e73			;	ld de,(chk_word) 
5e73			;	ld hl, (chk_stund)	; stack points.... 
5e73			;	if DEBUG_STK_FAULT 
5e73			;		DMARK "FAa" 
5e73			;		CALLMONITOR 
5e73			;	endif 
5e73			;	call cmp16 
5e73			;	jp z, .chk_faulta 
5e73			; 
5e73			;	ld de, sfaultsu 
5e73			;	jp .chk_fault 
5e73			 
5e73 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
5e76 ed 5b cd f0		ld de,(chk_word) 
5e7a				if DEBUG_STK_FAULT 
5e7a					DMARK "FAb" 
5e7a					CALLMONITOR 
5e7a				endif 
5e7a cd 5f 0d			call cmp16 
5e7d 28 06			jr z, .chk_fault1 
5e7f 11 24 5f			ld de, sfaultso 
5e82 c3 d4 5e			jp .chk_fault 
5e85			.chk_fault1:  
5e85 2a 1c f9			ld hl, (chk_ret_und) 
5e88 ed 5b cd f0		ld de,(chk_word) 
5e8c				if DEBUG_STK_FAULT 
5e8c					DMARK "FAU" 
5e8c					CALLMONITOR 
5e8c				endif 
5e8c cd 5f 0d			call cmp16 
5e8f ca 98 5e			jp z, .chk_fault2 
5e92 11 34 5f			ld de, sfaultru 
5e95 c3 d4 5e			jp .chk_fault 
5e98			.chk_fault2:  
5e98 2a da f8			ld hl, (chk_ret_ovr) 
5e9b ed 5b cd f0		ld de,(chk_word) 
5e9f				if DEBUG_STK_FAULT 
5e9f					DMARK "FA1" 
5e9f					CALLMONITOR 
5e9f				endif 
5e9f cd 5f 0d			call cmp16 
5ea2 ca ab 5e			jp z, .chk_fault3 
5ea5 11 42 5f			ld de, sfaultro 
5ea8 c3 d4 5e			jp .chk_fault 
5eab			.chk_fault3:  
5eab 2a 58 f8			ld hl, (chk_loop_ovr) 
5eae ed 5b cd f0		ld de,(chk_word) 
5eb2				if DEBUG_STK_FAULT 
5eb2					DMARK "FA2" 
5eb2					CALLMONITOR 
5eb2				endif 
5eb2 cd 5f 0d			call cmp16 
5eb5 ca be 5e			jp z, .chk_fault4 
5eb8 11 5c 5f			ld de, sfaultlo 
5ebb c3 d4 5e			jp .chk_fault 
5ebe			.chk_fault4:  
5ebe 2a 56 f6			ld hl, (chk_data_ovr) 
5ec1 ed 5b cd f0		ld de,(chk_word) 
5ec5				if DEBUG_STK_FAULT 
5ec5					DMARK "FA3" 
5ec5					CALLMONITOR 
5ec5				endif 
5ec5 cd 5f 0d			call cmp16 
5ec8 ca d1 5e			jp z, .chk_fault5 
5ecb 11 76 5f			ld de, sfaultdo 
5ece c3 d4 5e			jp .chk_fault 
