0dde			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0dde			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0dde			;;    subtract $30, if result > 9 then subtract $7 more 
0dde			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0dde			atohex: 
0dde d6 30				SUB $30 
0de0 fe 0a				CP 10 
0de2 f8					RET M		; If result negative it was 0-9 so we're done 
0de3 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0de5 c9					RET		 
