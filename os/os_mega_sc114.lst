8c4c			; from z80uartmonitor 
8c4c			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c4c			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
8c4c			; pass hl for where to put the text 
8c4c			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c4c c5			hexout:	PUSH BC 
8c4d f5					PUSH AF 
8c4e 47					LD B, A 
8c4f					; Upper nybble 
8c4f cb 3f				SRL A 
8c51 cb 3f				SRL A 
8c53 cb 3f				SRL A 
8c55 cb 3f				SRL A 
8c57 cd 67 8c				CALL tohex 
8c5a 77					ld (hl),a 
8c5b 23					inc hl	 
8c5c					 
8c5c					; Lower nybble 
8c5c 78					LD A, B 
8c5d e6 0f				AND 0FH 
8c5f cd 67 8c				CALL tohex 
8c62 77					ld (hl),a 
8c63 23					inc hl	 
8c64					 
8c64 f1					POP AF 
8c65 c1					POP BC 
8c66 c9					RET 
8c67					 
8c67			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c67			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
8c67			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c67			tohex: 
8c67 e5					PUSH HL 
8c68 d5					PUSH DE 
8c69 16 00				LD D, 0 
8c6b 5f					LD E, A 
8c6c 21 74 8c				LD HL, .DATA 
8c6f 19					ADD HL, DE 
8c70 7e					LD A, (HL) 
8c71 d1					POP DE 
8c72 e1					POP HL 
8c73 c9					RET 
8c74			 
8c74			.DATA: 
8c74 30					DEFB	30h	; 0 
8c75 31					DEFB	31h	; 1 
8c76 32					DEFB	32h	; 2 
8c77 33					DEFB	33h	; 3 
8c78 34					DEFB	34h	; 4 
8c79 35					DEFB	35h	; 5 
8c7a 36					DEFB	36h	; 6 
8c7b 37					DEFB	37h	; 7 
8c7c 38					DEFB	38h	; 8 
8c7d 39					DEFB	39h	; 9 
8c7e 41					DEFB	41h	; A 
8c7f 42					DEFB	42h	; B 
8c80 43					DEFB	43h	; C 
8c81 44					DEFB	44h	; D 
8c82 45					DEFB	45h	; E 
8c83 46					DEFB	46h	; F 
8c84			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c84			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
8c84			;;    subtract $30, if result > 9 then subtract $7 more 
8c84			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c84			atohex: 
8c84 d6 30				SUB $30 
8c86 fe 0a				CP 10 
8c88 f8					RET M		; If result negative it was 0-9 so we're done 
8c89 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
8c8b c9					RET		 
8c8c			 
8c8c			 
8c8c			 
8c8c			 
8c8c			; Get 2 ASCII characters as hex byte from pointer in hl 
8c8c			 
8c8c			BYTERD: 
8c8c 16 00			LD	D,00h		;Set up 
8c8e cd 96 8c			CALL	HEXCON		;Get byte and convert to hex 
8c91 87				ADD	A,A		;First nibble so 
8c92 87				ADD	A,A		;multiply by 16 
8c93 87				ADD	A,A		; 
8c94 87				ADD	A,A		; 
8c95 57				LD	D,A		;Save hi nibble in D 
8c96			HEXCON: 
8c96 7e				ld a, (hl)		;Get next chr 
8c97 23				inc hl 
8c98 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
8c9a fe 0a			CP	00Ah		;Is it 0-9 ? 
8c9c 38 02			JR	C,NALPHA	;If so miss next bit 
8c9e d6 07			SUB	007h		;Else convert alpha 
8ca0			NALPHA: 
8ca0 b2				OR	D		;Add hi nibble back 
8ca1 c9				RET			; 
