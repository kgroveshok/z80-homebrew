0f52				ld de, 0 
0f52			        call cmp16 
0f52				jr nz, .lowalloz 
0f52			 
0f52				push hl 
0f52				push de 
0f52					ld hl, display_fb0 
0f52					ld (display_fb_active), hl 
0f52				call clear_display 
0f52				ld a, 0 
0f52				ld de, .malloczero 
0f52				call str_at_display 
0f52				call update_display 
0f52				call delay1s 
0f52				call delay1s 
0f52				call bp_on 
