1051			; Decimal Signed Version 
1051			 
1051			; DispA 
1051			; -------------------------------------------------------------- 
1051			; Converts a signed integer value to a zero-terminated ASCII 
1051			; string representative of that value (using radix 10). 
1051			; -------------------------------------------------------------- 
1051			; INPUTS: 
1051			;     HL     Value to convert (two's complement integer). 
1051			;     DE     Base address of string destination. (pointer). 
1051			; -------------------------------------------------------------- 
1051			; OUTPUTS: 
1051			;     None 
1051			; -------------------------------------------------------------- 
1051			; REGISTERS/MEMORY DESTROYED 
1051			; AF HL 
1051			; -------------------------------------------------------------- 
1051			 
1051			;DispHLToASCII: 
1051			;   push    de 
1051			;   push    bc 
1051			; 
1051			;; Detect sign of HL. 
1051			;    bit    7, h 
1051			;    jr     z, ._DoConvert 
1051			; 
1051			;; HL is negative. Output '-' to string and negate HL. 
1051			;    ld     a, '-' 
1051			;    ld     (de), a 
1051			;    inc    de 
1051			; 
1051			;; Negate HL (using two's complement) 
1051			;    xor    a 
1051			;    sub    l 
1051			;    ld     l, a 
1051			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
1051			;    sbc    a, h 
1051			;    ld     h, a 
1051			; 
1051			;; Convert HL to digit characters 
1051			;._DoConvert: 
1051			;    ld     b, 0     ; B will count character length of number 
1051			;-   ld     a, 10 
1051			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
1051			;    push   af 
1051			;    inc    b 
1051			;    ld     a, h 
1051			;    or     l 
1051			;    jr     nz, - 
1051			; 
1051			;; Retrieve digits from stack 
1051			;-   pop    af 
1051			;    or     $30 
1051			;    ld     (de), a 
1051			;    inc    de 
1051			;    djnz   - 
1051			; 
1051			;; Terminate string with NULL 
1051			;    xor    a 
1051			;    ld     (de), a 
1051			; 
1051			;    pop    bc 
1051			;    pop    de 
1051			;    ret 
1051			 
1051			;Comments 
1051			; 
1051			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
1051			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
1051			;    Note that the output string will not be fixed-width. 
1051			; 
1051			;Example Usage 
1051			; 
1051			;    ld    hl, -1004 
1051			;    ld    de, OP1 
1051			;    call  DispA 
1051			;    ld    hl, OP1 
1051			;    syscall  PutS 
1051			 
1051			 
1051			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1051			 
1051			 
1051			;Converts an ASCII string to an unsigned 16-bit integer 
1051			;Quits when it reaches a non-decimal digit 
1051			 
1051			string_to_uint16: 
1051			atoui_16: 
1051			;Input: 
1051			;     DE points to the string 
1051			;Outputs: 
1051			;     HL is the result 
1051			;     A is the 8-bit value of the number 
1051			;     DE points to the byte after the number 
1051			;Destroys: 
1051			;     BC 
1051			;       if the string is non-empty, BC is HL/10 
1051			;Size:  24 bytes 
1051			;Speed: 42+d(104+{0,9}) 
1051			;       d is the number of digits in the number 
1051			;       max is 640 cycles for a 5 digit number 
1051			;Assuming no leading zeros: 
1051			;1 digit:  146cc 
1051			;2 digit:  250cc 
1051			;3 digit:  354cc or 363cc (avg: 354.126cc) 
1051			;4 digit:  458cc or 467cc (avg: 458.27cc) 
1051			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
1051			;avg: 544.81158447265625cc (544+13297/16384) 
1051			;=============================================================== 
1051 21 00 00		  ld hl,0 
1054			.u16a: 
1054 1a			  ld a,(de) 
1055 d6 30		  sub 30h 
1057 fe 0a		  cp 10 
1059 d0			  ret nc 
105a 13			  inc de 
105b 44			  ld b,h 
105c 4d			  ld c,l 
105d 29			  add hl,hl 
105e 29			  add hl,hl 
105f 09			  add hl,bc 
1060 29			  add hl,hl 
1061 85			  add a,l 
1062 6f			  ld l,a 
1063 30 ef		  jr nc,.u16a 
1065 24			  inc h 
1066 c3 54 10		  jp .u16a 
1069			 
1069			 
1069			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1069			 
1069			;written by Zeda 
1069			;Converts a 16-bit unsigned integer to an ASCII string. 
1069			 
1069			uitoa_16: 
1069			;Input: 
1069			;   DE is the number to convert 
1069			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1069			;Output: 
1069			;   HL points to the null-terminated ASCII string 
1069			;      NOTE: This isn't necessarily the same as the input HL. 
1069 d5			  push de 
106a c5			  push bc 
106b f5			  push af 
106c eb			  ex de,hl 
106d			 
106d 01 f0 d8		  ld bc,-10000 
1070 3e 2f		  ld a,'0'-1 
1072 3c			  inc a 
1073 09			  add hl,bc  
1074 38 fc		   jr c,$-2 
1076 12			  ld (de),a 
1077 13			  inc de 
1078			 
1078 01 e8 03		  ld bc,1000 
107b 3e 3a		  ld a,'9'+1 
107d 3d			  dec a  
107e 09			  add hl,bc  
107f 30 fc		   jr nc,$-2 
1081 12			  ld (de),a 
1082 13			  inc de 
1083			 
1083 01 9c ff		  ld bc,-100 
1086 3e 2f		  ld a,'0'-1 
1088 3c			  inc a  
1089 09			  add hl,bc  
108a 38 fc		   jr c,$-2 
108c 12			  ld (de),a 
108d 13			  inc de 
108e			 
108e 7d			  ld a,l 
108f 26 3a		  ld h,'9'+1 
1091 25			  dec h  
1092 c6 0a		  add a,10  
1094 30 fb		   jr nc,$-3 
1096 c6 30		  add a,'0' 
1098 eb			  ex de,hl 
1099 72			  ld (hl),d 
109a 23			  inc hl 
109b 77			  ld (hl),a 
109c 23			  inc hl 
109d 36 00		  ld (hl),0 
109f			 
109f			;Now strip the leading zeros 
109f 0e fa		  ld c,-6 
10a1 09			  add hl,bc 
10a2 3e 30		  ld a,'0' 
10a4 23			  inc hl  
10a5 be			  cp (hl)  
10a6 28 fc		  jr z,$-2 
10a8			 
10a8			;Make sure that the string is non-empty! 
10a8 7e			  ld a,(hl) 
10a9 b7			  or a 
10aa 20 01		  jr nz,.atoub 
10ac 2b			  dec hl 
10ad			.atoub: 
10ad			 
10ad f1			  pop af 
10ae c1			  pop bc 
10af d1			  pop de 
10b0 c9			  ret 
10b1			 
10b1			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
10b1			 
10b1			toUpper: 
10b1			;A is the char. 
10b1			;If A is a lowercase letter, this sets it to the matching uppercase 
10b1			;18cc or 30cc or 41cc 
10b1			;avg: 26.75cc 
10b1 fe 61		  cp 'a' 
10b3 d8			  ret c 
10b4 fe 7b		  cp 'z'+1 
10b6 d0			  ret nc 
10b7 d6 20		  sub 'a'-'A' 
10b9 c9			  ret 
