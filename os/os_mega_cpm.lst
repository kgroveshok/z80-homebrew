1897			; Stack operations for v5 parser on wards 
1897			; * DATA stack 
1897			; * LOOP stack 
1897			; * RETURN stack 
1897			 
1897			 
1897			 
1897			FORTH_CHK_DSP_UNDER: macro 
1897				push hl 
1897				push de 
1897				ld hl,(cli_data_sp) 
1897				ld de, cli_data_stack 
1897				call cmp16 
1897				jp c, fault_dsp_under 
1897				pop de 
1897				pop hl 
1897				endm 
1897			 
1897			 
1897			FORTH_CHK_RSP_UNDER: macro 
1897				push hl 
1897				push de 
1897				ld hl,(cli_ret_sp) 
1897				ld de, cli_ret_stack 
1897				call cmp16 
1897				jp c, fault_rsp_under 
1897				pop de 
1897				pop hl 
1897				endm 
1897			 
1897			FORTH_CHK_LOOP_UNDER: macro 
1897				push hl 
1897				push de 
1897				ld hl,(cli_loop_sp) 
1897				ld de, cli_loop_stack 
1897				call cmp16 
1897				jp c, fault_loop_under 
1897				pop de 
1897				pop hl 
1897				endm 
1897			 
1897			FORTH_ERR_TOS_NOTSTR: macro 
1897				; TOSO might need more for checks when used 
1897				push af 
1897				ld a,(hl) 
1897				cp DS_TYPE_STR 
1897				jp nz, type_faultn   
1897				pop af 
1897				endm 
1897			 
1897			FORTH_ERR_TOS_NOTNUM: macro 
1897				push af 
1897				ld a,(hl) 
1897				cp DS_TYPE_INUM 
1897				jp nz, type_faultn   
1897				pop af 
1897				endm 
1897			 
1897			 
1897			; increase data stack pointer and save hl to it 
1897				 
1897			FORTH_DSP_NEXT: macro 
1897				call macro_forth_dsp_next 
1897				endm 
1897			 
1897			 
1897			macro_forth_dsp_next: 
1897				if DEBUG_FORTH_STACK_GUARD 
1897 cd f5 56				call check_stacks 
189a				endif 
189a e5				push hl 
189b d5				push de 
189c eb				ex de,hl 
189d 2a ca e9			ld hl,(cli_data_sp) 
18a0 23				inc hl 
18a1 23				inc hl 
18a2			 
18a2			; PARSEV5 
18a2 23				inc hl 
18a3 22 ca e9			ld (cli_data_sp),hl 
18a6 73				ld (hl), e 
18a7 23				inc hl 
18a8 72				ld (hl), d 
18a9 d1				pop de 
18aa e1				pop hl 
18ab				if DEBUG_FORTH_STACK_GUARD 
18ab cd f5 56				call check_stacks 
18ae				endif 
18ae c9				ret 
