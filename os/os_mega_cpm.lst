0fee			malloc_find_space: 
0fee 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
0fef 23			      inc   HL 
0ff0 56			      ld    D, (HL) 
0ff1			 
0ff1 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
0ff2 b3			      or    E 
