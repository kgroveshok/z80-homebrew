8cbd			;                jr      nc, is_hex_1    ; No, continue 
8cbd			;                ccf                     ; Complement carry (i.e. clear it) 
8cbd			;                ret 
8cbd			;is_hex_1        cp      '9' + 1         ; Less or equal '9*? 
8cbd			;                ret     c               ; Yes 
8cbd			;                cp      'A'             ; Less than 'A'? 
8cbd			;                jr      nc, is_hex_2    ; No, continue 
8cbd			;                ccf                     ; Yes - clear carry and return 
8cbd			;                ret 
8cbd			;is_hex_2        scf                     ; Set carry 
8cbd			;                ret 
8cbd			; 
8cbd			; Convert a single character contained in A to upper case: 
8cbd			; 
8cbd fe 61		to_upper:        cp      'a'             ; Nothing to do if not lower case 
8cbf d8			                ret     c 
8cc0 fe 7b		                cp      'z' + 1         ; > 'z'? 
8cc2 d0			                ret     nc              ; Nothing to do, either 
8cc3 e6 5f		                and     $5f             ; Convert to upper case 
8cc5 c9			                ret 
