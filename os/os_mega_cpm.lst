551e			; stack over and underflow checks 
551e			 
551e			; init the words to detect the under/overflow 
551e			 
551e			chk_stk_init: 
551e				; a vague random number to check so we dont get any "lucky" hits 
551e 3e 2d			ld a, 45 
5520 6f				ld l, a 
5521 00				nop 
5522 3e 17			ld a, 23 
5524 67				ld h, a 
5525			 
5525 22 92 e2			ld (chk_word), hl     ; the word we need to check against 
5528			 
5528			;	ld (chk_stund), hl	; stack points.... 
5528 22 00 ef			ld (chk_stovr), hl 
552b 22 e1 e9			ld (chk_ret_und), hl 
552e 22 9f e9			ld (chk_ret_ovr), hl 
5531 22 1d e9			ld (chk_loop_ovr), hl 
5534 22 1b e8			ld (chk_data_ovr), hl 
5537 c9				ret 
