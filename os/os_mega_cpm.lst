1bb2			user_word_eol:  
1bb2				; hl contains the pointer to where to create a linked list item from the end 
1bb2				; of the user dict to continue on at the system word dict 
1bb2				 
1bb2				; poke the stub of the word list linked list to repoint to rom words 
1bb2			 
1bb2				; stub format 
1bb2				; db   word id 
1bb2				; dw    link to next word 
1bb2			        ; db char length of token 
1bb2				; db string + 0 term 
1bb2				; db exec code....  
1bb2			 
1bb2			;	ld a, WORD_SYS_ROOT     ; root word 
1bb2 36 00			ld (hl), WORD_SYS_ROOT		; word id 
1bb4 23				inc hl 
1bb5			 
1bb5 11 5e 1d			ld de, sysdict 
1bb8 73				ld (hl), e		; next word link ie system dict 
1bb9 23				inc hl 
1bba 72				ld (hl), d		; next word link ie system dict 
1bbb 23				inc hl	 
1bbc			 
1bbc			;	ld (hl), sysdict		; next word link ie system dict 
1bbc			;	inc hl 
1bbc			;	inc hl 
1bbc			 
1bbc			;	inc hl 
1bbc			;	inc hl 
1bbc			 
1bbc			;	ld a, 2			; word length is 0 
1bbc 36 02			ld (hl), 2 
1bbe 23				inc hl 
1bbf			 
1bbf			;	ld a, '~'			; word length is 0 
1bbf 36 7e			ld (hl), '~' 
1bc1 23				inc hl 
1bc2			;	ld a, 0			; save empty word 
1bc2 36 00			ld (hl), 0 
