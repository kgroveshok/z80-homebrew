0f86				call bp_on 
0f86			 
0f86				pop de 
0f86				pop hl 
0f86			 
0f86				 
0f86			 
0f86				CALLMONITOR 
0f86				jr .lowdone 
0f86			.lowalloc: 
0f86			 
0f86			 
0f86				pop hl 
0f86			.lowdone:	pop af 
0f86				pop de 
0f86				pop hl 
0f86			ret 
