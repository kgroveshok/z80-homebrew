0ad1			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0ad1			 
0ad1			 
0ad1			;-----> Generate a random number 
0ad1			; output a=answer 0<=a<=255 
0ad1			; all registers are preserved except: af 
0ad1			random: 
0ad1 e5			        push    hl 
0ad2 d5			        push    de 
0ad3 2a a0 eb		        ld      hl,(randData) 
0ad6 ed 5f		        ld      a,r 
0ad8 57			        ld      d,a 
0ad9 5e			        ld      e,(hl) 
0ada 19			        add     hl,de 
0adb 85			        add     a,l 
0adc ac			        xor     h 
0add 22 a0 eb		        ld      (randData),hl 
0ae0 d1			        pop     de 
0ae1 e1			        pop     hl 
0ae2 c9			        ret 
0ae3			 
0ae3			 
0ae3			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0ae3			 
0ae3			 
0ae3			 
0ae3			;------LFSR------ 
0ae3			;James Montelongo 
0ae3			;optimized by Spencer Putt 
0ae3			;out: 
0ae3			; a = 8 bit random number 
0ae3			RandLFSR: 
0ae3 21 a6 eb		        ld hl,LFSRSeed+4 
0ae6 5e			        ld e,(hl) 
0ae7 23			        inc hl 
0ae8 56			        ld d,(hl) 
0ae9 23			        inc hl 
0aea 4e			        ld c,(hl) 
0aeb 23			        inc hl 
0aec 7e			        ld a,(hl) 
0aed 47			        ld b,a 
0aee cb 13		        rl e  
0af0 cb 12			rl d 
0af2 cb 11		        rl c  
0af4 17				rla 
0af5 cb 13		        rl e  
0af7 cb 12			rl d 
0af9 cb 11		        rl c  
0afb 17				rla 
0afc cb 13		        rl e  
0afe cb 12			rl d 
0b00 cb 11		        rl c  
0b02 17				rla 
0b03 67			        ld h,a 
0b04 cb 13		        rl e  
0b06 cb 12			rl d 
0b08 cb 11		        rl c  
0b0a 17				rla 
0b0b a8			        xor b 
0b0c cb 13		        rl e  
0b0e cb 12			rl d 
0b10 ac			        xor h 
0b11 a9			        xor c 
0b12 aa			        xor d 
0b13 21 a8 eb		        ld hl,LFSRSeed+6 
0b16 11 a9 eb		        ld de,LFSRSeed+7 
0b19 01 07 00		        ld bc,7 
0b1c ed b8		        lddr 
0b1e 12			        ld (de),a 
0b1f c9			        ret 
