4479			 
4479			;		pop hl   ; u2 - addr 
4479			 
4479					; TODO Send SPI byte 
4479			 
4479			;		push hl 
4479			;		call spi_ce_low 
4479			;		pop hl 
4479					ld a, l 
4479					call spi_send_byte 
4479			;		call spi_ce_high 
