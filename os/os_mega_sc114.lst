8dd6			StrictStrCmp: 
8dd6				; Load next chars of each string 
8dd6 1a				ld a, (de) 
8dd7 47				ld b, a 
8dd8 7e				ld a, (hl) 
8dd9				; Compare 
8dd9 b8				cp b 
8dda				; Return non-zero if chars don't match 
8dda c0				ret nz 
8ddb				; Check for end of both strings 
8ddb fe 00			cp "\0" 
8ddd				; Return if strings have ended 
8ddd c8				ret z 
8dde				; Otherwise, advance to next chars 
8dde 23				inc hl 
8ddf 13				inc de 
8de0 18 f4			jr StrictStrCmp 
