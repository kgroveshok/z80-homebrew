901b			malloc_guard_zerolen: 
901b				push hl 
901b				push de 
901b				push af 
901b			 
901b				ld de, 0 
901b			        call cmp16 
901b				jr nz, .lowalloz 
901b			 
901b				push hl 
901b				push de 
901b					ld hl, display_fb0 
901b					ld (display_fb_active), hl 
901b				call clear_display 
901b				ld a, 0 
901b				ld de, .malloczero 
901b				call str_at_display 
901b				call update_display 
901b				call delay1s 
901b				call delay1s 
901b				call bp_on 
901b			;	ld a, 0 
901b			;	ld (os_view_disable), a 
901b			 
901b				pop de 
901b				pop hl 
901b			 
901b				 
901b			 
901b				CALLMONITOR 
901b			.lowalloz: 
901b			 
901b			 
901b				pop af 
901b				pop de 
901b				pop hl 
901b			ret 
901b			 
901b			malloc_guard_entry: 
901b				push hl 
901b				push de 
901b				push af 
901b			 
901b			 	or a      ;clear carry flag 
901b				push hl 
901b				ld de, 255 
901b				sbc hl, de 
901b				jr c, .lowalloc 
901b			 
901b				push de 
901b					ld hl, display_fb0 
901b					ld (display_fb_active), hl 
901b				call clear_display 
901b				ld a, 0 
901b				ld de, .mallocsize 
901b				call str_at_display 
901b				call update_display 
901b				call delay1s 
901b				call delay1s 
901b			;	ld a, 0 
901b			;	ld (os_view_disable), a 
901b				call bp_on 
901b			 
901b				pop de 
901b				pop hl 
901b			 
901b				 
901b			 
901b				CALLMONITOR 
901b				jr .lowdone 
901b			.lowalloc: 
901b			 
901b			 
901b				pop hl 
901b			.lowdone:	pop af 
901b				pop de 
901b				pop hl 
901b			ret 
901b			 
901b			malloc_guard_exit: 
901b				push hl 
901b				push de 
901b				push af 
901b			 
901b			 	or a      ;clear carry flag 
901b				push hl 
901b				ld de, 255 
901b				sbc hl, de 
901b				jr c, .lowallocx 
901b			 
901b				push de 
901b					ld hl, display_fb0 
901b					ld (display_fb_active), hl 
901b				call clear_display 
901b				ld a, 0 
901b				ld de, .mallocasize 
901b				call str_at_display 
901b				call update_display 
901b				call delay1s 
901b				call delay1s 
901b			;	ld a, 0 
901b			;	ld (os_view_disable), a 
901b				call bp_on 
901b				pop de 
901b				pop hl 
901b			 
901b				CALLMONITOR 
901b				jr .lowdonex 
901b			.lowallocx: 
901b			 
901b				pop hl 
901b			.lowdonex:	pop af 
901b				pop de 
901b				pop hl 
901b			ret 
