0322 cd 31 02			call spi_ce_high 
0325			;       set SPI_CE0,a           ; TODO pass the ce bank bit mask - perhaps have a call that sets it 
0325 d3 80		       out (storage_adata),a 
0327 32 91 f9		       ld (spi_portbyte), a 
