dfd9 28 05			jr z, .cin_skip 
dfdb			 
dfdb				; yep, get it 
dfdb			 
dfdb 0e 01			ld c, $01 
dfdd f7				rst $30 
dfde c1				pop bc 
dfdf c9				ret 
