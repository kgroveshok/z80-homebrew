24d4 15				db WORD_SYS_CORE+OPCODE_HEAP             
24d5 10 25			dw .EXEC            
24d7 05				db 4 + 1 
24d8 .. 00			db "HEAP",0              
24dd				endm 
# End of macro CWHEAD
24dd			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
24dd			; | | u1 - Current number of bytes in the heap 
24dd			; | | u2 - Remaining bytes left on the heap 
24dd			; | |  
24dd			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
24dd			 
24dd			 
24dd				if DEBUG_FORTH_WORDS_KEY 
24dd					DMARK "HEP" 
24dd f5				push af  
24de 3a f2 24			ld a, (.dmark)  
24e1 32 99 fd			ld (debug_mark),a  
24e4 3a f3 24			ld a, (.dmark+1)  
24e7 32 9a fd			ld (debug_mark+1),a  
24ea 3a f4 24			ld a, (.dmark+2)  
24ed 32 9b fd			ld (debug_mark+2),a  
24f0 18 03			jr .pastdmark  
24f2 ..			.dmark: db "HEP"  
24f5 f1			.pastdmark: pop af  
24f6			endm  
# End of macro DMARK
24f6					CALLMONITOR 
24f6				if BASE_CPM=1  
24f6					call debug_vector  
24f6				endif  
24f6				if BASE_KEV=1  
24f6 cf					rst 8  
24f7				endif  
24f7				endm  
# End of macro CALLMONITOR
24f7				endif 
24f7 2a 0a 80			ld hl, (free_list )      
24fa 11 0e 80			ld de, heap_start 
24fd			 
24fd ed 52			sbc hl, de  
24ff			 
24ff			;	call forth_push_numhl 
24ff					FORTH_PUSH_VALUEHL 
24ff				if BASE_CPM=1 
24ff					call forth_push_numhl 
24ff				endif 
24ff				if BASE_KEV=1 
24ff e7					rst $20 
2500				endif 
2500				endm 
# End of macro FORTH_PUSH_VALUEHL
