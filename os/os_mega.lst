646b			; stack over and underflow checks 
646b			 
646b			; init the words to detect the under/overflow 
646b			 
646b			chk_stk_init: 
646b				; a vague random number to check so we dont get any "lucky" hits 
646b 3e 2d			ld a, 45 
646d 6f				ld l, a 
646e 00				nop 
646f 3e 17			ld a, 23 
6471 67				ld h, a 
6472			 
6472 22 bc f0			ld (chk_word), hl     ; the word we need to check against 
6475			 
6475			;	ld (chk_stund), hl	; stack points.... 
6475 22 3b fe			ld (chk_stovr), hl 
6478 22 0b f9			ld (chk_ret_und), hl 
647b 22 c9 f8			ld (chk_ret_ovr), hl 
647e 22 47 f8			ld (chk_loop_ovr), hl 
6481 22 45 f6			ld (chk_data_ovr), hl 
6484 c9				ret 
6485				 
6485			check_stacks: 
6485				; check all stack words 
6485			 
6485 e5				push hl 
6486 d5				push de 
6487			 
6487			;	ld de,(chk_word) 
6487			;	ld hl, (chk_stund)	; stack points.... 
6487			;	if DEBUG_STK_FAULT 
6487			;		DMARK "FAa" 
6487			;		CALLMONITOR 
6487			;	endif 
6487			;	call cmp16 
6487			;	jp z, .chk_faulta 
6487			; 
6487			;	ld de, sfaultsu 
6487			;	jp .chk_fault 
6487			 
6487 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
648a ed 5b bc f0		ld de,(chk_word) 
648e				if DEBUG_STK_FAULT 
648e					DMARK "FAb" 
648e					CALLMONITOR 
648e				endif 
648e cd 7d 0d			call cmp16 
6491 28 06			jr z, .chk_fault1 
6493 11 38 65			ld de, sfaultso 
6496 c3 e8 64			jp .chk_fault 
6499			.chk_fault1:  
6499 2a 0b f9			ld hl, (chk_ret_und) 
649c ed 5b bc f0		ld de,(chk_word) 
64a0				if DEBUG_STK_FAULT 
64a0					DMARK "FAU" 
64a0					CALLMONITOR 
64a0				endif 
64a0 cd 7d 0d			call cmp16 
64a3 ca ac 64			jp z, .chk_fault2 
64a6 11 48 65			ld de, sfaultru 
64a9 c3 e8 64			jp .chk_fault 
64ac			.chk_fault2:  
64ac 2a c9 f8			ld hl, (chk_ret_ovr) 
64af ed 5b bc f0		ld de,(chk_word) 
64b3				if DEBUG_STK_FAULT 
64b3					DMARK "FA1" 
64b3					CALLMONITOR 
64b3				endif 
64b3 cd 7d 0d			call cmp16 
64b6 ca bf 64			jp z, .chk_fault3 
64b9 11 56 65			ld de, sfaultro 
64bc c3 e8 64			jp .chk_fault 
64bf			.chk_fault3:  
64bf 2a 47 f8			ld hl, (chk_loop_ovr) 
64c2 ed 5b bc f0		ld de,(chk_word) 
64c6				if DEBUG_STK_FAULT 
64c6					DMARK "FA2" 
64c6					CALLMONITOR 
64c6				endif 
64c6 cd 7d 0d			call cmp16 
64c9 ca d2 64			jp z, .chk_fault4 
64cc 11 70 65			ld de, sfaultlo 
64cf c3 e8 64			jp .chk_fault 
64d2			.chk_fault4:  
64d2 2a 45 f6			ld hl, (chk_data_ovr) 
64d5 ed 5b bc f0		ld de,(chk_word) 
64d9				if DEBUG_STK_FAULT 
64d9					DMARK "FA3" 
64d9					CALLMONITOR 
64d9				endif 
64d9 cd 7d 0d			call cmp16 
64dc ca e5 64			jp z, .chk_fault5 
64df 11 8a 65			ld de, sfaultdo 
64e2 c3 e8 64			jp .chk_fault 
64e5			 
64e5			 
64e5			.chk_fault5:  
64e5 d1				pop de 
64e6 e1				pop hl 
64e7			 
64e7 c9				ret 
