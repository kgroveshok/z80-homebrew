011b 3e 5f		ld a, '_'  
011d 32 9b fd		ld (debug_mark),a  
0120 32 9c fd		ld (debug_mark+1),a  
0123 32 9d fd		ld (debug_mark+2),a  
0126 3e 00		ld a,0  
