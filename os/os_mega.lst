0d5c			;HL_Div_C: 
0d5c			;Inputs: 
0d5c			;     HL is the numerator 
0d5c			;     C is the denominator 
0d5c			;Outputs: 
0d5c			;     A is the remainder 
0d5c			;     B is 0 
0d5c			;     C is not changed 
0d5c			;     DE is not changed 
0d5c			;     HL is the quotient 
