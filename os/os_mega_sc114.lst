bc0d			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bc0d			; | | Set to zero to disable storage. 
bc0d					if DEBUG_FORTH_WORDS_KEY 
bc0d						DMARK "BNK" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d			 
bc0d					ld a, 255 
bc0d					ld (spi_cartdev), a 
