d563			 
d563				call update_display 
d563			 
d563				call cin_wait 
d563				cp 'n' 
d563				ret z 
d563				cp 'N' 
d563				ret z 
d563			 
d563				call delay1s 
d563			 
d563				ld a, (store_page+2) 
d563				ld (store_openmaxext), a    ; save count of ext 
d563				ld a, 1  
d563				ld (store_openext), a    ; save count of ext 
d563			 
d563			.autof:  
d563				ld l , a 
d563				 
d563				ld a, (store_page) 
d563				ld h, a	 
d563				ld de, store_page 
d563					if DEBUG_FORTH_WORDS 
d563						DMARK "ASl" 
d563						CALLMONITOR 
d563					endif 
d563					call storage_read 
d563				call ishlzero 
d563				ret z 
d563			;	jr z, .autoend 
d563			 
d563					if DEBUG_FORTH_WORDS 
d563						DMARK "ASc" 
d563						CALLMONITOR 
d563					endif 
d563				ld de, store_page+2 
d563				ld a, display_row_4 
