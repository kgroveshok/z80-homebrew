6077			; handle the auto run of code from files in storage 
6077			 
6077			 
6077			include "forth_startup.asm" 
6077			; Which startup method to use? 
6077			; 
6077			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6077			; followed by loading of a list of scripts in eeprom 
6077			 
6077			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6077			; from eeprom 
6077			 
6077			; Select with define in main stubs 
6077			 
6077			if STARTUP_V1 
6077				include "forth_startupv1.asm" 
6077			endif 
6077			if STARTUP_V2 
6077				include "forth_startupv2.asm" 
6077			; Version 2 of the startup  
6077			;  
6077			; Auto load any files in bank 1 that start with a '*' 
6077			; If no se storage then revert to using eprom 
6077			 
6077			 
6077			if STORAGE_SE = 0 
6077			 
6077			sprompt1: db "Startup load...",0 
6077			sprompt2: db "Run? 1=No *=End #=All",0 
6077			 
6077			 
6077			 
6077			 
6077			forth_startup: 
6077				ld hl, startcmds 
6077				ld a, 0 
6077				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
6077			 
6077			.start1:	push hl 
6077				call clear_display 
6077				ld de, sprompt1 
6077			        ld a, display_row_1 
6077				call str_at_display 
6077				ld de, sprompt2 
6077			        ld a, display_row_2 
6077				call str_at_display 
6077				pop hl 
6077				push hl 
6077				ld e,(hl) 
6077				inc hl 
6077				ld d,(hl) 
6077			        ld a, display_row_3 
6077				call str_at_display 
6077				call update_display 
6077			 
6077			 
6077				ld a, (os_last_cmd) 
6077			;	cp 0 
6077				or a 
6077				jr z, .startprompt 
6077				call delay250ms 
6077				jr .startdo 
6077				 
6077				 
6077			 
6077			.startprompt: 
6077			 
6077				ld a,display_row_4 + display_cols - 1 
6077			        ld de, endprg 
6077				call str_at_display 
6077				call update_display 
6077				call delay1s 
6077				call cin_wait 
6077						 
6077				cp '*' 
6077				jr z, .startupend1 
6077				cp '#' 
6077				jr nz, .startno 
6077				ld a, 1 
6077				ld (os_last_cmd),a 
6077				jr .startdo 
6077			.startno:	cp '1' 
6077				jr z,.startnxt  
6077			 
6077				; exec startup line 
6077			.startdo:	 
6077				pop hl 
6077				push hl 
6077				 
6077				ld e,(hl) 
6077				inc hl 
6077				ld d,(hl) 
6077				ex de,hl 
6077			 
6077				push hl 
6077			 
6077				ld a, 0 
6077				;ld a, FORTH_END_BUFFER 
6077				call strlent 
6077				inc hl   ; include zero term to copy 
6077				ld b,0 
6077				ld c,l 
6077				pop hl 
6077				ld de, scratch 
6077				ldir 
6077			 
6077			 
6077				ld hl, scratch 
6077				call forthparse 
6077				call forthexec 
6077				call forthexec_cleanup 
6077			 
6077				ld a, display_row_4 
6077				ld de, endprog 
6077			 
6077				call update_display		 
6077			 
6077				ld a, (os_last_cmd) 
6077			;	cp 0 
6077				or a 
6077				jr nz, .startnxt 
6077				call next_page_prompt 
6077			        call clear_display 
6077				call update_display		 
6077			 
6077				; move onto next startup line? 
6077			.startnxt: 
6077			 
6077				call delay250ms 
6077				pop hl 
6077			 
6077				inc hl 
6077				inc hl 
6077			 
6077				push hl 
6077				ld e, (hl) 
6077				inc hl 
6077				ld d, (hl) 
6077				pop hl 
6077				; TODO replace 0 test 
6077			 
6077				ex de, hl 
6077				call ishlzero 
6077			;	ld a,e 
6077			;	add d 
6077			;	cp 0    ; any left to do? 
6077				ex de, hl 
6077				jp nz, .start1 
6077				jr .startupend 
6077			 
6077			.startupend1: pop hl 
6077			.startupend: 
6077			 
6077				call clear_display 
6077				call update_display 
6077				ret 
6077			endif 
