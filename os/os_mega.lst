1104			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
1104			 
1104			;      .org 0 
1104			;      jp    main 
1104			 
1104			 
1104			;      .org  0x100 
1104			;main: 
1104			;      ld    HL, 0x8100 
1104			;      ld    SP, HL 
1104			; 
1104			;      call  heap_init 
1104			; 
1104			;      ; Make some allocations 
1104			;      ld    HL, 12 
1104			;      call  malloc            ; Allocates 0x9004 
1104			; 
1104			;      ld    HL, 12 
1104			;      call  malloc            ; Allocates 0x9014 
1104			; 
1104			;      ld    HL, 12 
1104			;      call  malloc            ; Allocates 0x9024 
1104			; 
1104			;      ; Free some allocations 
1104			;      ld    HL, 0x9014 
1104			;      call  free 
1104			; 
1104			;      ld    HL, 0x9004 
1104			;      call  free 
1104			; 
1104			;      ld    HL, 0x9024 
1104			;      call  free 
1104			; 
1104			; 
1104			;      halt 
