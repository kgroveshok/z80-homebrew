0a82			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0a82			 
0a82			 
0a82			;-----> Generate a random number 
0a82			; output a=answer 0<=a<=255 
0a82			; all registers are preserved except: af 
0a82			random: 
0a82 e5			        push    hl 
0a83 d5			        push    de 
0a84 2a 9e eb		        ld      hl,(randData) 
0a87 ed 5f		        ld      a,r 
0a89 57			        ld      d,a 
0a8a 5e			        ld      e,(hl) 
0a8b 19			        add     hl,de 
0a8c 85			        add     a,l 
0a8d ac			        xor     h 
0a8e 22 9e eb		        ld      (randData),hl 
0a91 d1			        pop     de 
0a92 e1			        pop     hl 
0a93 c9			        ret 
0a94			 
0a94			 
0a94			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0a94			 
0a94			 
0a94			 
0a94			;------LFSR------ 
0a94			;James Montelongo 
0a94			;optimized by Spencer Putt 
0a94			;out: 
0a94			; a = 8 bit random number 
0a94			RandLFSR: 
0a94 21 a4 eb		        ld hl,LFSRSeed+4 
0a97 5e			        ld e,(hl) 
0a98 23			        inc hl 
0a99 56			        ld d,(hl) 
0a9a 23			        inc hl 
0a9b 4e			        ld c,(hl) 
0a9c 23			        inc hl 
0a9d 7e			        ld a,(hl) 
0a9e 47			        ld b,a 
0a9f cb 13		        rl e  
0aa1 cb 12			rl d 
0aa3 cb 11		        rl c  
0aa5 17				rla 
0aa6 cb 13		        rl e  
0aa8 cb 12			rl d 
0aaa cb 11		        rl c  
0aac 17				rla 
0aad cb 13		        rl e  
0aaf cb 12			rl d 
0ab1 cb 11		        rl c  
0ab3 17				rla 
0ab4 67			        ld h,a 
0ab5 cb 13		        rl e  
0ab7 cb 12			rl d 
0ab9 cb 11		        rl c  
0abb 17				rla 
0abc a8			        xor b 
0abd cb 13		        rl e  
0abf cb 12			rl d 
0ac1 ac			        xor h 
0ac2 a9			        xor c 
0ac3 aa			        xor d 
0ac4 21 a6 eb		        ld hl,LFSRSeed+6 
0ac7 11 a7 eb		        ld de,LFSRSeed+7 
0aca 01 07 00		        ld bc,7 
0acd ed b8		        lddr 
0acf 12			        ld (de),a 
0ad0 c9			        ret 
0ad1			 
0ad1			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0ad1			 
0ad1			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0ad1			 
0ad1			 
0ad1			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0ad1			 
0ad1			prng16: 
0ad1			;Inputs: 
0ad1			;   (seed1) contains a 16-bit seed value 
0ad1			;   (seed2) contains a NON-ZERO 16-bit seed value 
0ad1			;Outputs: 
0ad1			;   HL is the result 
0ad1			;   BC is the result of the LCG, so not that great of quality 
0ad1			;   DE is preserved 
0ad1			;Destroys: 
0ad1			;   AF 
0ad1			;cycle: 4,294,901,760 (almost 4.3 billion) 
0ad1			;160cc 
0ad1			;26 bytes 
0ad1 2a 98 eb		    ld hl,(seed1) 
0ad4 44			    ld b,h 
0ad5 4d			    ld c,l 
0ad6 29			    add hl,hl 
0ad7 29			    add hl,hl 
0ad8 2c			    inc l 
0ad9 09			    add hl,bc 
0ada 22 98 eb		    ld (seed1),hl 
0add 2a 96 eb		    ld hl,(seed2) 
0ae0 29			    add hl,hl 
0ae1 9f			    sbc a,a 
0ae2 e6 2d		    and %00101101 
0ae4 ad			    xor l 
0ae5 6f			    ld l,a 
0ae6 22 96 eb		    ld (seed2),hl 
0ae9 09			    add hl,bc 
0aea c9			    ret 
0aeb			 
0aeb			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0aeb			 
0aeb			rand32: 
0aeb			;Inputs: 
0aeb			;   (seed1_0) holds the lower 16 bits of the first seed 
0aeb			;   (seed1_1) holds the upper 16 bits of the first seed 
0aeb			;   (seed2_0) holds the lower 16 bits of the second seed 
0aeb			;   (seed2_1) holds the upper 16 bits of the second seed 
0aeb			;   **NOTE: seed2 must be non-zero 
0aeb			;Outputs: 
0aeb			;   HL is the result 
0aeb			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0aeb			;Destroys: 
0aeb			;   AF 
0aeb			;Tested and passes all CAcert tests 
0aeb			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0aeb			;it has a period of 18,446,744,069,414,584,320 
0aeb			;roughly 18.4 quintillion. 
0aeb			;LFSR taps: 0,2,6,7  = 11000101 
0aeb			;291cc 
0aeb			;seed1_0=$+1 
0aeb			;    ld hl,12345 
0aeb			;seed1_1=$+1 
0aeb			;    ld de,6789 
0aeb			;    ld b,h 
0aeb			;    ld c,l 
0aeb			;    add hl,hl \ rl e \ rl d 
0aeb			;    add hl,hl \ rl e \ rl d 
0aeb			;    inc l 
0aeb			;    add hl,bc 
0aeb			;    ld (seed1_0),hl 
0aeb			;    ld hl,(seed1_1) 
0aeb			;    adc hl,de 
0aeb			;    ld (seed1_1),hl 
0aeb			;    ex de,hl 
0aeb			;seed2_0=$+1 
0aeb			;    ld hl,9876 
0aeb			;seed2_1=$+1 
0aeb			;    ld bc,54321 
0aeb			;    add hl,hl \ rl c \ rl b 
0aeb			;    ld (seed2_1),bc 
0aeb			;    sbc a,a 
0aeb			;    and %11000101 
0aeb			;    xor l 
0aeb			;    ld l,a 
0aeb			;    ld (seed2_0),hl 
0aeb			;    ex de,hl 
0aeb			;    add hl,bc 
0aeb			;    ret 
0aeb			; 
0aeb			 
0aeb			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0aeb			; 20 bytes, 86 cycles (excluding ret) 
0aeb			 
0aeb			; returns   hl = pseudorandom number 
0aeb			; corrupts   a 
0aeb			 
0aeb			; generates 16-bit pseudorandom numbers with a period of 65535 
0aeb			; using the xorshift method: 
0aeb			 
0aeb			; hl ^= hl << 7 
0aeb			; hl ^= hl >> 9 
0aeb			; hl ^= hl << 8 
0aeb			 
0aeb			; some alternative shift triplets which also perform well are: 
0aeb			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0aeb			 
0aeb			;  org 32768 
0aeb			 
0aeb			xrnd: 
0aeb 2a 9c eb		  ld hl,(xrandc)       ; seed must not be 0 
0aee 3e 00		  ld a,0 
0af0 bd			  cp l 
0af1 20 02		  jr nz, .xrnd1 
0af3 2e 01		  ld l, 1 
0af5			.xrnd1: 
0af5			 
0af5 7c			  ld a,h 
0af6 1f			  rra 
0af7 7d			  ld a,l 
0af8 1f			  rra 
0af9 ac			  xor h 
0afa 67			  ld h,a 
0afb 7d			  ld a,l 
0afc 1f			  rra 
0afd 7c			  ld a,h 
0afe 1f			  rra 
0aff ad			  xor l 
0b00 6f			  ld l,a 
0b01 ac			  xor h 
0b02 67			  ld h,a 
0b03			 
0b03 22 9c eb		  ld (xrandc),hl 
0b06			 
0b06 c9			  ret 
0b07			;  
0b07			 
0b07			 
0b07			;;;; int maths 
0b07			 
0b07			; https://map.grauw.nl/articles/mult_div_shifts.php 
0b07			; Divide 16-bit values (with 16-bit result) 
0b07			; In: Divide BC by divider DE 
0b07			; Out: BC = result, HL = rest 
0b07			; 
0b07			Div16: 
0b07 21 00 00		    ld hl,0 
0b0a 78			    ld a,b 
0b0b 06 08		    ld b,8 
0b0d			Div16_Loop1: 
0b0d 17			    rla 
0b0e ed 6a		    adc hl,hl 
0b10 ed 52		    sbc hl,de 
0b12 30 01		    jr nc,Div16_NoAdd1 
0b14 19			    add hl,de 
0b15			Div16_NoAdd1: 
0b15 10 f6		    djnz Div16_Loop1 
0b17 17			    rla 
0b18 2f			    cpl 
0b19 47			    ld b,a 
0b1a 79			    ld a,c 
0b1b 48			    ld c,b 
0b1c 06 08		    ld b,8 
0b1e			Div16_Loop2: 
0b1e 17			    rla 
0b1f ed 6a		    adc hl,hl 
0b21 ed 52		    sbc hl,de 
0b23 30 01		    jr nc,Div16_NoAdd2 
0b25 19			    add hl,de 
0b26			Div16_NoAdd2: 
0b26 10 f6		    djnz Div16_Loop2 
0b28 17			    rla 
0b29 2f			    cpl 
0b2a 41			    ld b,c 
0b2b 4f			    ld c,a 
0b2c c9			ret 
0b2d			 
0b2d			 
0b2d			;http://z80-heaven.wikidot.com/math 
0b2d			; 
0b2d			;Inputs: 
