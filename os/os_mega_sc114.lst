8c33			; from z80uartmonitor 
8c33			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c33			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
8c33			; pass hl for where to put the text 
8c33			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c33 c5			hexout:	PUSH BC 
8c34 f5					PUSH AF 
8c35 47					LD B, A 
8c36					; Upper nybble 
8c36 cb 3f				SRL A 
8c38 cb 3f				SRL A 
8c3a cb 3f				SRL A 
8c3c cb 3f				SRL A 
8c3e cd 4e 8c				CALL tohex 
8c41 77					ld (hl),a 
8c42 23					inc hl	 
8c43					 
8c43					; Lower nybble 
8c43 78					LD A, B 
8c44 e6 0f				AND 0FH 
8c46 cd 4e 8c				CALL tohex 
8c49 77					ld (hl),a 
8c4a 23					inc hl	 
8c4b					 
8c4b f1					POP AF 
8c4c c1					POP BC 
8c4d c9					RET 
8c4e					 
8c4e			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c4e			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
8c4e			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c4e			tohex: 
8c4e e5					PUSH HL 
8c4f d5					PUSH DE 
8c50 16 00				LD D, 0 
8c52 5f					LD E, A 
8c53 21 5b 8c				LD HL, .DATA 
8c56 19					ADD HL, DE 
8c57 7e					LD A, (HL) 
8c58 d1					POP DE 
8c59 e1					POP HL 
8c5a c9					RET 
8c5b			 
8c5b			.DATA: 
8c5b 30					DEFB	30h	; 0 
8c5c 31					DEFB	31h	; 1 
8c5d 32					DEFB	32h	; 2 
8c5e 33					DEFB	33h	; 3 
8c5f 34					DEFB	34h	; 4 
8c60 35					DEFB	35h	; 5 
8c61 36					DEFB	36h	; 6 
8c62 37					DEFB	37h	; 7 
8c63 38					DEFB	38h	; 8 
8c64 39					DEFB	39h	; 9 
8c65 41					DEFB	41h	; A 
8c66 42					DEFB	42h	; B 
8c67 43					DEFB	43h	; C 
8c68 44					DEFB	44h	; D 
8c69 45					DEFB	45h	; E 
8c6a 46					DEFB	46h	; F 
8c6b			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c6b			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
8c6b			;;    subtract $30, if result > 9 then subtract $7 more 
8c6b			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c6b			atohex: 
8c6b d6 30				SUB $30 
8c6d fe 0a				CP 10 
8c6f f8					RET M		; If result negative it was 0-9 so we're done 
8c70 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
8c72 c9					RET		 
