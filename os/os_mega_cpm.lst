1038			 
1038			      ; Update this_free ptr to point to new block 
1038 2b			      dec   HL 
1039 2b			      dec   HL 
103a 2b			      dec   HL 
103b			 
103b dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
103e dd 56 03		      ld    D, (IX+3) 
1041			 
1041 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
