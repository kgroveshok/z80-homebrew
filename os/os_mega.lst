1107			if MALLOC_2 
1107			; Z80 Malloc and Free Functions 
1107			 
1107			; Malloc Function: 
1107			; Input: 
1107			;   HL: Size of block to allocate 
1107			; Output: 
1107			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1107			 
1107			malloc: 
1107				 
1107			if DEBUG_FORTH_MALLOC_HIGH 
1107			call malloc_guard_entry 
1107			endif 
1107			 
1107			 
1107			 
1107			 
1107					if DEBUG_FORTH_MALLOC 
1107						DMARK "mal" 
1107						CALLMONITOR 
1107					endif 
1107			    push af            ; Save AF register 
1107			    ld a, l            ; Load low byte of size into A 
1107			    or h               ; Check if size is zero 
1107			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1107			 
1107			    ; Allocate memory 
1107			    ld hl, (heap_start) ; Load start of heap into HL 
1107					if DEBUG_FORTH_MALLOC 
1107						DMARK "ma1" 
1107						CALLMONITOR 
1107					endif 
1107			    call malloc_internal ; Call internal malloc function 
1107			    pop af             ; Restore AF register 
1107			if DEBUG_FORTH_MALLOC_HIGH 
1107			call malloc_guard_exit 
1107			call malloc_guard_zerolen 
1107			endif 
1107			    ret                ; Return 
1107			 
1107			; Free Function: 
1107			; Input: 
1107			;   HL: Pointer to memory block to free 
1107			; Output: 
1107			;   None 
1107			 
1107			free: 
1107			    push af            ; Save AF register 
1107			    ld a, l            ; Load low byte of pointer into A 
1107			    or h               ; Check if pointer is NULL 
1107			    jp z, free_exit    ; If pointer is NULL, exit 
1107			 
1107			    ; Free memory 
1107			    ld hl, (heap_start) ; Load start of heap into HL 
1107			    call free_internal  ; Call internal free function 
1107			    pop af             ; Restore AF register 
1107			    ret                ; Return 
1107			 
1107			; Internal Malloc Function: 
1107			; Input: 
1107			;   HL: Size of block to allocate 
1107			; Output: 
1107			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1107			 
1107			malloc_internal: 
1107			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1107			    add hl, bc         ; Add management overhead to requested size 
1107			    ex de, hl          ; Save total size in DE, and keep it in HL 
1107					if DEBUG_FORTH_MALLOC 
1107						DMARK "ma2" 
1107						CALLMONITOR 
1107					endif 
1107			 
1107			    ; Search for free memory block 
1107			    ld de, (heap_end)  ; Load end of heap into DE 
1107			    ld bc, 0           ; Initialize counter 
1107			 
1107					if DEBUG_FORTH_MALLOC 
1107						DMARK "ma2" 
1107						CALLMONITOR 
1107					endif 
1107			malloc_search_loop: 
1107			    ; Check if current block is free 
1107			    ld a, (hl)         ; Load current block's status (free or used) 
1107			;    cp 0               ; Compare with zero (free) 
1107				or a 
1107			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1107			 
1107			    ; Check if current block is large enough 
1107			    ld a, (hl+1)       ; Load high byte of block size 
1107			    cp l               ; Compare with low byte of requested size 
1107			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1107			 
1107			    ld a, (hl+2)       ; Load low byte of block size 
1107			    cp h               ; Compare with high byte of requested size 
1107			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1107			 
1107			    ; Mark block as used 
1107			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1107			 
1107			    ; Calculate remaining space in block 
1107			    ld bc, 0           ; Clear BC 
1107			    add hl, bc         ; Increment HL to point to start of data block 
1107			    add hl, de         ; HL = HL + DE (total size) 
1107			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1107			    add hl, bc         ; Add management overhead to start of data block 
1107			 
1107			    ; Save pointer to allocated block in HL 
1107			if DEBUG_FORTH_MALLOC_HIGH 
1107						DMARK "ma5" 
1107			call malloc_guard_exit 
1107			call malloc_guard_zerolen 
1107			endif 
1107			    ret 
1107			 
1107			malloc_skip_block_check: 
1107			    ; Move to the next block 
1107			    ld bc, 3           ; Size of management overhead 
1107			    add hl, bc         ; Move to the next block 
1107			    inc de             ; Increment counter 
1107			 
1107			    ; Check if we have reached the end of heap 
1107			    ld a, e            ; Load low byte of heap end address 
1107			    cp (hl)            ; Compare with low byte of current address 
1107			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1107			    ld a, d            ; Load high byte of heap end address 
1107			;    cp 0               ; Check if it's zero (end of memory) 
1107				or a 
1107			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1107			 
1107			    ; If we reached here, allocation failed 
1107			    xor a              ; Set result to NULL 
1107			if DEBUG_FORTH_MALLOC_HIGH 
1107						DMARK "ma6" 
1107			call malloc_guard_exit 
1107			call malloc_guard_zerolen 
1107			endif 
1107			    ret 
1107			malloc_exit: 
1107			if DEBUG_FORTH_MALLOC_HIGH 
1107						DMARK "ma7" 
1107			call malloc_guard_exit 
1107			call malloc_guard_zerolen 
1107			endif 
1107			    ret 
1107			 
1107			; Internal Free Function: 
1107			; Input: 
1107			;   HL: Pointer to memory block to free 
1107			; Output: 
1107			;   None 
1107			 
1107			free_internal: 
1107			    ld de, (heap_start) ; Load start of heap into DE 
1107			    ld bc, 0            ; Initialize counter 
1107			 
1107			free_search_loop: 
1107			    ; Check if current block contains the pointer 
1107			    ld a, l             ; Load low byte of pointer 
1107			    cp (hl+1)           ; Compare with high byte of current block's address 
1107			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1107			    ld a, h             ; Load high byte of pointer 
1107			    cp (hl+2)           ; Compare with low byte of current block's address 
1107			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1107			 
1107			    ; Mark block as free 
1107			    ld (hl), 0          ; Set status byte to indicate free block 
1107			    ret                 ; Return 
1107			 
1107			free_skip_block_check: 
1107			    ; Move to the next block 
1107			    ld bc, 3            ; Size of management overhead 
1107			    add hl, bc          ; Move to the next block 
1107			    inc de              ; Increment counter 
1107			 
1107			    ; Check if we have reached the end of heap 
1107			    ld a, e             ; Load low byte of heap end address 
1107			    cp (hl)             ; Compare with low byte of current address 
1107			    jr nz, free_search_loop  ; If not equal, continue searching 
1107			    ld a, d             ; Load high byte of heap end address 
1107			;    cp 0                ; Check if it's zero (end of memory) 
1107				or a 
1107			    jr nz, free_search_loop  ; If not zero, continue searching 
1107			 
1107			    ; If we reached here, pointer is not found in heap 
1107			    ret 
1107			 
1107			free_exit: 
1107			    ret                 ; Return 
1107			 
1107			; Define heap start and end addresses 
1107			;heap_start:    .dw 0xC000   ; Start of heap 
1107			;heap_end:      .dw 0xE000   ; End of heap 
1107			 
1107			endif 
