a7f1			; | SCRATCH ( u -- addr ) Pushes address of offset u to stack | DONE 
a7f1			; | | The scratch area provides 32 word array. Can be used as single byte or as a word by passing the offset on stack. Pushes the resulting address to stack.  
a7f1			; | | When used with the direct storage writing/malloc and the !@ or word versions it is possible to construct an expanded and flexible variable system 
a7f1			; | |  
a7f1			; | | e.g.    : score $00 scratch ; 
a7f1			; | |  
a7f1			; | | $00 score ! 
a7f1			; | | $01 score +! 
a7f1			; | |  
a7f1			; | | e.g.   : varword $0a scratch ;  
a7f1			; | | 
a7f1			; | | $8000 varword ! 
a7f1					if DEBUG_FORTH_WORDS_KEY 
a7f1						DMARK "SCR" 
a7f1				if DEMARK_VERSION = 1  
a7f1 e5					push hl  
a7f2 21 fa a7				ld hl, .dmark  
a7f5 22 60 ee				ld (debug_mark), hl  
a7f8				endif  
