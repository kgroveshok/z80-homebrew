0d28 19			    add hl,de 
0d29			Mult12U_NoAdd1: 
0d29 29			    add hl,hl 
0d2a 87			    add a,a 
0d2b 30 01		    jr nc,Mult12U_NoAdd2 
0d2d 19			    add hl,de 
