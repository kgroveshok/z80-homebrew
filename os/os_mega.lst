# End of macro CWHEAD
51a1			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
51a1			; | 
51a1			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
51a1			; | |  
51a1			; | | e.g. 
51a1			; | |         #30 a var ! 
51a1			; | |         a var @ . 
51a1			; | |   
51a1			; | |     Displays the number 30 
51a1			; | | 
51a1			; | | Each variable pointer is a word so can use for any words that use that:  
51a1			; | |  
51a1			; | | e.g. 
51a1			; | |  
51a1			; | |         #30 a var 2! 
51a1			; | |         a var 2@ . 
51a1			; | |   
51a1			; | |     Displays the number 30 
51a1			; | |  
51a1			; | | > [!NOTE]  
51a1			; ! | > If a full string is passed then only the first char is looked at 
51a1			; | | > Any other char could exceed bounds checks!  
51a1			; | | > 
51a1			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
51a1			 
51a1					if DEBUG_FORTH_WORDS_KEY 
51a1						DMARK "VAR" 
51a1				if DEMARK_VERSION = 1  
51a1 e5					push hl  
51a2 21 aa 51				ld hl, .dmark  
51a5 22 9b fd				ld (debug_mark), hl  
51a8				endif  
51a8				if DEMARK_VERSION = 0  
51a8					push af  
51a8					ld a, (.dmark)  
51a8					ld (debug_mark),a  
51a8					ld a, (.dmark+1)  
51a8					ld (debug_mark+1),a  
51a8					ld a, (.dmark+2)  
51a8					ld (debug_mark+2),a  
51a8				endif  
51a8 18 04			jr .pastdmark  
51aa ..			.dmark: db "VAR"  
51ad				if DEMARK_VERSION = 1  
51ad 00					db 0  
51ae				endif  
51ae				if DEMARK_VERSION = 1  
51ae e1			.pastdmark: pop hl  
51af				endif  
51af				if DEMARK_VERSION = 0  
51af			.pastdmark: pop af  
51af				endif  
51af			endm  
# End of macro DMARK
51af						CALLMONITOR 
51af				if BASE_CPM=1  
51af					call debug_vector  
51af				endif  
51af				if BASE_KEV=1  
51af cf					rst 8  
51b0				endif  
51b0				endm  
# End of macro CALLMONITOR
51b0					endif 
