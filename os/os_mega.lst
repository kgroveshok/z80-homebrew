6ebc 3e 28		            LD   A, kLCD_Line2  
6ebe cd e3 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
6ec1 11 21 fe		            LD   DE, keyscan_table_row2  
6ec4 cd 05 6b		            CALL fLCD_Str       ;Display string pointed to by DE  
6ec7 3e 50		            LD   A, kLCD_Line3  
6ec9 cd e3 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
6ecc 11 16 fe		            LD   DE, keyscan_table_row3  
6ecf cd 05 6b		            CALL fLCD_Str       ;Display string pointed to by DE  
6ed2 3e 78		            LD   A, kLCD_Line4  
