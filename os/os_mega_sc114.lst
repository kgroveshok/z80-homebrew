88db			 
88db			;-----> Generate a random number 
88db			; output a=answer 0<=a<=255 
88db			; all registers are preserved except: af 
88db			random: 
88db e5			        push    hl 
88dc d5			        push    de 
88dd 2a 9e eb		        ld      hl,(randData) 
88e0 ed 5f		        ld      a,r 
88e2 57			        ld      d,a 
88e3 5e			        ld      e,(hl) 
88e4 19			        add     hl,de 
88e5 85			        add     a,l 
88e6 ac			        xor     h 
88e7 22 9e eb		        ld      (randData),hl 
88ea d1			        pop     de 
88eb e1			        pop     hl 
88ec c9			        ret 
88ed			 
88ed			 
88ed			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
88ed			 
88ed			 
88ed			 
88ed			;------LFSR------ 
88ed			;James Montelongo 
88ed			;optimized by Spencer Putt 
88ed			;out: 
88ed			; a = 8 bit random number 
88ed			RandLFSR: 
88ed 21 a4 eb		        ld hl,LFSRSeed+4 
88f0 5e			        ld e,(hl) 
88f1 23			        inc hl 
88f2 56			        ld d,(hl) 
88f3 23			        inc hl 
88f4 4e			        ld c,(hl) 
88f5 23			        inc hl 
88f6 7e			        ld a,(hl) 
88f7 47			        ld b,a 
88f8 cb 13		        rl e  
88fa cb 12			rl d 
88fc cb 11		        rl c  
88fe 17				rla 
88ff cb 13		        rl e  
8901 cb 12			rl d 
8903 cb 11		        rl c  
8905 17				rla 
8906 cb 13		        rl e  
8908 cb 12			rl d 
890a cb 11		        rl c  
890c 17				rla 
890d 67			        ld h,a 
890e cb 13		        rl e  
8910 cb 12			rl d 
8912 cb 11		        rl c  
8914 17				rla 
8915 a8			        xor b 
8916 cb 13		        rl e  
8918 cb 12			rl d 
891a ac			        xor h 
891b a9			        xor c 
891c aa			        xor d 
891d 21 a6 eb		        ld hl,LFSRSeed+6 
8920 11 a7 eb		        ld de,LFSRSeed+7 
8923 01 07 00		        ld bc,7 
8926 ed b8		        lddr 
8928 12			        ld (de),a 
8929 c9			        ret 
892a			 
892a			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
892a			 
892a			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
892a			 
892a			 
892a			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
892a			 
892a			prng16: 
892a			;Inputs: 
892a			;   (seed1) contains a 16-bit seed value 
892a			;   (seed2) contains a NON-ZERO 16-bit seed value 
892a			;Outputs: 
892a			;   HL is the result 
892a			;   BC is the result of the LCG, so not that great of quality 
892a			;   DE is preserved 
892a			;Destroys: 
892a			;   AF 
892a			;cycle: 4,294,901,760 (almost 4.3 billion) 
892a			;160cc 
892a			;26 bytes 
892a 2a 98 eb		    ld hl,(seed1) 
892d 44			    ld b,h 
892e 4d			    ld c,l 
892f 29			    add hl,hl 
8930 29			    add hl,hl 
8931 2c			    inc l 
8932 09			    add hl,bc 
8933 22 98 eb		    ld (seed1),hl 
8936 2a 96 eb		    ld hl,(seed2) 
8939 29			    add hl,hl 
893a 9f			    sbc a,a 
893b e6 2d		    and %00101101 
893d ad			    xor l 
893e 6f			    ld l,a 
893f 22 96 eb		    ld (seed2),hl 
8942 09			    add hl,bc 
8943 c9			    ret 
8944			 
8944			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
8944			 
8944			rand32: 
8944			;Inputs: 
8944			;   (seed1_0) holds the lower 16 bits of the first seed 
8944			;   (seed1_1) holds the upper 16 bits of the first seed 
8944			;   (seed2_0) holds the lower 16 bits of the second seed 
8944			;   (seed2_1) holds the upper 16 bits of the second seed 
8944			;   **NOTE: seed2 must be non-zero 
8944			;Outputs: 
8944			;   HL is the result 
8944			;   BC,DE can be used as lower quality values, but are not independent of HL. 
8944			;Destroys: 
8944			;   AF 
8944			;Tested and passes all CAcert tests 
8944			;Uses a very simple 32-bit LCG and 32-bit LFSR 
8944			;it has a period of 18,446,744,069,414,584,320 
8944			;roughly 18.4 quintillion. 
8944			;LFSR taps: 0,2,6,7  = 11000101 
8944			;291cc 
8944			;seed1_0=$+1 
8944			;    ld hl,12345 
8944			;seed1_1=$+1 
8944			;    ld de,6789 
8944			;    ld b,h 
8944			;    ld c,l 
8944			;    add hl,hl \ rl e \ rl d 
8944			;    add hl,hl \ rl e \ rl d 
8944			;    inc l 
8944			;    add hl,bc 
8944			;    ld (seed1_0),hl 
8944			;    ld hl,(seed1_1) 
8944			;    adc hl,de 
8944			;    ld (seed1_1),hl 
8944			;    ex de,hl 
8944			;seed2_0=$+1 
8944			;    ld hl,9876 
8944			;seed2_1=$+1 
8944			;    ld bc,54321 
8944			;    add hl,hl \ rl c \ rl b 
8944			;    ld (seed2_1),bc 
8944			;    sbc a,a 
8944			;    and %11000101 
8944			;    xor l 
8944			;    ld l,a 
8944			;    ld (seed2_0),hl 
8944			;    ex de,hl 
8944			;    add hl,bc 
8944			;    ret 
8944			; 
8944			 
8944			; 16-bit xorshift pseudorandom number generator by John Metcalf 
8944			; 20 bytes, 86 cycles (excluding ret) 
8944			 
8944			; returns   hl = pseudorandom number 
8944			; corrupts   a 
8944			 
8944			; generates 16-bit pseudorandom numbers with a period of 65535 
8944			; using the xorshift method: 
8944			 
8944			; hl ^= hl << 7 
8944			; hl ^= hl >> 9 
8944			; hl ^= hl << 8 
8944			 
8944			; some alternative shift triplets which also perform well are: 
8944			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
8944			 
8944			;  org 32768 
8944			 
8944			xrnd: 
8944 2a 9c eb		  ld hl,(xrandc)       ; seed must not be 0 
8947 3e 00		  ld a,0 
8949 bd			  cp l 
894a 20 02		  jr nz, .xrnd1 
894c 2e 01		  ld l, 1 
894e			.xrnd1: 
894e			 
894e 7c			  ld a,h 
894f 1f			  rra 
8950 7d			  ld a,l 
8951 1f			  rra 
8952 ac			  xor h 
8953 67			  ld h,a 
8954 7d			  ld a,l 
8955 1f			  rra 
8956 7c			  ld a,h 
8957 1f			  rra 
8958 ad			  xor l 
8959 6f			  ld l,a 
895a ac			  xor h 
895b 67			  ld h,a 
895c			 
895c 22 9c eb		  ld (xrandc),hl 
895f			 
895f c9			  ret 
