6786			;	ld a,e 
6786			;	add d 
6786			;	cp 0    ; any left to do? 
6786				ex de, hl 
6786				jp nz, .start1 
6786				jr .startupend 
6786			 
6786			.startupend1: pop hl 
6786			.startupend: 
6786			 
6786				call clear_display 
6786				call update_display 
6786				ret 
6786			endif 
