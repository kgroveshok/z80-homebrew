0d7b			addatohl: 
0d7b 85			    add   a, l    ; A = A+L 
0d7c 6f			    ld    l, a    ; L = A+L 
0d7d 8c			    adc   a, h    ; A = A+L+H+carry 
0d7e 95			    sub   l       ; A = H+carry 
0d7f 67			    ld    h, a    ; H = H+carry 
0d80 c9			ret 
