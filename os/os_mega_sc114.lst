8c51			; from z80uartmonitor 
8c51			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c51			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
8c51			; pass hl for where to put the text 
8c51			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c51 c5			hexout:	PUSH BC 
8c52 f5					PUSH AF 
8c53 47					LD B, A 
8c54					; Upper nybble 
8c54 cb 3f				SRL A 
8c56 cb 3f				SRL A 
8c58 cb 3f				SRL A 
8c5a cb 3f				SRL A 
8c5c cd 6c 8c				CALL tohex 
8c5f 77					ld (hl),a 
8c60 23					inc hl	 
8c61					 
8c61					; Lower nybble 
8c61 78					LD A, B 
8c62 e6 0f				AND 0FH 
8c64 cd 6c 8c				CALL tohex 
8c67 77					ld (hl),a 
8c68 23					inc hl	 
8c69					 
8c69 f1					POP AF 
8c6a c1					POP BC 
8c6b c9					RET 
8c6c					 
8c6c			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c6c			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
8c6c			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c6c			tohex: 
8c6c e5					PUSH HL 
8c6d d5					PUSH DE 
8c6e 16 00				LD D, 0 
8c70 5f					LD E, A 
8c71 21 79 8c				LD HL, .DATA 
8c74 19					ADD HL, DE 
8c75 7e					LD A, (HL) 
8c76 d1					POP DE 
8c77 e1					POP HL 
8c78 c9					RET 
8c79			 
8c79			.DATA: 
8c79 30					DEFB	30h	; 0 
8c7a 31					DEFB	31h	; 1 
8c7b 32					DEFB	32h	; 2 
8c7c 33					DEFB	33h	; 3 
8c7d 34					DEFB	34h	; 4 
8c7e 35					DEFB	35h	; 5 
8c7f 36					DEFB	36h	; 6 
8c80 37					DEFB	37h	; 7 
8c81 38					DEFB	38h	; 8 
8c82 39					DEFB	39h	; 9 
8c83 41					DEFB	41h	; A 
8c84 42					DEFB	42h	; B 
8c85 43					DEFB	43h	; C 
8c86 44					DEFB	44h	; D 
8c87 45					DEFB	45h	; E 
8c88 46					DEFB	46h	; F 
8c89			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c89			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
8c89			;;    subtract $30, if result > 9 then subtract $7 more 
8c89			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c89			atohex: 
8c89 d6 30				SUB $30 
8c8b fe 0a				CP 10 
8c8d f8					RET M		; If result negative it was 0-9 so we're done 
8c8e d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
8c90 c9					RET		 
8c91			 
8c91			 
8c91			 
8c91			 
8c91			; Get 2 ASCII characters as hex byte from pointer in hl 
8c91			 
8c91			BYTERD: 
8c91 16 00			LD	D,00h		;Set up 
8c93 cd 9b 8c			CALL	HEXCON		;Get byte and convert to hex 
8c96 87				ADD	A,A		;First nibble so 
8c97 87				ADD	A,A		;multiply by 16 
8c98 87				ADD	A,A		; 
8c99 87				ADD	A,A		; 
8c9a 57				LD	D,A		;Save hi nibble in D 
8c9b			HEXCON: 
8c9b 7e				ld a, (hl)		;Get next chr 
8c9c 23				inc hl 
8c9d d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
8c9f fe 0a			CP	00Ah		;Is it 0-9 ? 
8ca1 38 02			JR	C,NALPHA	;If so miss next bit 
8ca3 d6 07			SUB	007h		;Else convert alpha 
8ca5			NALPHA: 
8ca5 b2				OR	D		;Add hi nibble back 
8ca6 c9				RET			; 
