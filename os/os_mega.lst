606a			  
606a			; SCMonAPI functions used  
606a			  
606a			; Alphanumeric LCD functions used  
606a			; no need to specify specific functions for this module  
606a			  
606a 3e cf		            LD   A, 11001111b  
606c d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
606e 3e 00		            LD   A, 00000000b  
6070 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6072			  
