5a2e 5e				ld e,(hl) 
5a2f 23				inc hl 
5a30 56				ld d,(hl) 
5a31 3e 50		        ld a, display_row_3 
5a33 cd c6 09			call str_at_display 
5a36 cd d6 09			call update_display 
5a39			 
5a39			 
