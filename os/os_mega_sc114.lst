8ca2			; 
8ca2			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8ca2			; Since the routines get_byte and therefore get_nibble are called, only valid 
8ca2			; characters (0-9a-f) are accepted. 
8ca2			; 
8ca2			;get_word        push    af 
8ca2			;                call    get_byte        ; Get the upper byte 
8ca2			;                ld      h, a 
8ca2			;                call    get_byte        ; Get the lower byte 
8ca2			;                ld      l, a 
8ca2			;                pop     af 
8ca2			;                ret 
8ca2			; 
8ca2			; Get a byte in hexadecimal notation. The result is returned in A. Since 
8ca2			; the routine get_nibble is used only valid characters are accepted - the  
8ca2			; input routine only accepts characters 0-9a-f. 
8ca2			; 
8ca2 c5			get_byte:        push    bc              ; Save contents of B (and C) 
8ca3 7e					ld a,(hl) 
8ca4 23					inc hl 
8ca5 cd ca 8c		                call    nibble2val      ; Get upper nibble 
8ca8 cb 07		                rlc     a 
8caa cb 07		                rlc     a 
8cac cb 07		                rlc     a 
8cae cb 07		                rlc     a 
8cb0 47			                ld      b, a            ; Save upper four bits 
8cb1 7e					ld a,(hl) 
8cb2 cd ca 8c		                call    nibble2val      ; Get lower nibble 
8cb5 b0			                or      b               ; Combine both nibbles 
8cb6 c1			                pop     bc              ; Restore B (and C) 
8cb7 c9			                ret 
8cb8			; 
8cb8			; Get a hexadecimal digit from the serial line. This routine blocks until 
8cb8			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
8cb8			; to the serial line interface. The lower 4 bits of A contain the value of  
8cb8			; that particular digit. 
8cb8			; 
8cb8			;get_nibble      ld a,(hl)           ; Read a character 
8cb8			;                call    to_upper        ; Convert to upper case 
8cb8			;                call    is_hex          ; Was it a hex digit? 
8cb8			;                jr      nc, get_nibble  ; No, get another character 
8cb8			 ;               call    nibble2val      ; Convert nibble to value 
8cb8			 ;               call    print_nibble 
8cb8			 ;               ret 
8cb8			; 
8cb8			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
8cb8			; A valid hexadecimal digit is denoted by a set C flag. 
8cb8			; 
8cb8			;is_hex          cp      'F' + 1         ; Greater than 'F'? 
8cb8			;                ret     nc              ; Yes 
8cb8			;                cp      '0'             ; Less than '0'? 
8cb8			;                jr      nc, is_hex_1    ; No, continue 
8cb8			;                ccf                     ; Complement carry (i.e. clear it) 
8cb8			;                ret 
8cb8			;is_hex_1        cp      '9' + 1         ; Less or equal '9*? 
8cb8			;                ret     c               ; Yes 
8cb8			;                cp      'A'             ; Less than 'A'? 
8cb8			;                jr      nc, is_hex_2    ; No, continue 
8cb8			;                ccf                     ; Yes - clear carry and return 
8cb8			;                ret 
8cb8			;is_hex_2        scf                     ; Set carry 
8cb8			;                ret 
8cb8			; 
8cb8			; Convert a single character contained in A to upper case: 
8cb8			; 
8cb8 fe 61		to_upper:        cp      'a'             ; Nothing to do if not lower case 
8cba d8			                ret     c 
8cbb fe 7b		                cp      'z' + 1         ; > 'z'? 
8cbd d0			                ret     nc              ; Nothing to do, either 
8cbe e6 5f		                and     $5f             ; Convert to upper case 
8cc0 c9			                ret 
