63b6			; init the words to detect the under/overflow 
63b6			 
63b6			chk_stk_init: 
63b6				; a vague random number to check so we dont get any "lucky" hits 
63b6 3e 2d			ld a, 45 
63b8 6f				ld l, a 
63b9 00				nop 
63ba 3e 17			ld a, 23 
63bc 67				ld h, a 
63bd			 
63bd 22 90 e2			ld (chk_word), hl     ; the word we need to check against 
63c0			 
63c0			;	ld (chk_stund), hl	; stack points.... 
63c0 22 00 ef			ld (chk_stovr), hl 
63c3 22 df e9			ld (chk_ret_und), hl 
63c6 22 9d e9			ld (chk_ret_ovr), hl 
63c9 22 1b e9			ld (chk_loop_ovr), hl 
63cc 22 19 e8			ld (chk_data_ovr), hl 
63cf c9				ret 
63d0				 
63d0			check_stacks: 
63d0				; check all stack words 
63d0			 
63d0 e5				push hl 
63d1 d5				push de 
63d2			 
63d2			;	ld de,(chk_word) 
63d2			;	ld hl, (chk_stund)	; stack points.... 
63d2			;	if DEBUG_STK_FAULT 
63d2			;		DMARK "FAa" 
63d2			;		CALLMONITOR 
63d2			;	endif 
63d2			;	call cmp16 
63d2			;	jp z, .chk_faulta 
63d2			; 
63d2			;	ld de, sfaultsu 
63d2			;	jp .chk_fault 
63d2			 
63d2 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
63d5 ed 5b 90 e2		ld de,(chk_word) 
63d9				if DEBUG_STK_FAULT 
63d9					DMARK "FAb" 
63d9					CALLMONITOR 
63d9				endif 
63d9 cd 38 0e			call cmp16 
63dc 28 06			jr z, .chk_fault1 
63de 11 82 64			ld de, sfaultso 
63e1 c3 33 64			jp .chk_fault 
63e4			.chk_fault1:  
63e4 2a df e9			ld hl, (chk_ret_und) 
63e7 ed 5b 90 e2		ld de,(chk_word) 
63eb				if DEBUG_STK_FAULT 
63eb					DMARK "FAU" 
63eb					CALLMONITOR 
63eb				endif 
63eb cd 38 0e			call cmp16 
63ee ca f7 63			jp z, .chk_fault2 
63f1 11 92 64			ld de, sfaultru 
63f4 c3 33 64			jp .chk_fault 
63f7			.chk_fault2:  
63f7 2a 9d e9			ld hl, (chk_ret_ovr) 
63fa ed 5b 90 e2		ld de,(chk_word) 
63fe				if DEBUG_STK_FAULT 
63fe					DMARK "FA1" 
63fe					CALLMONITOR 
63fe				endif 
63fe cd 38 0e			call cmp16 
6401 ca 0a 64			jp z, .chk_fault3 
6404 11 a0 64			ld de, sfaultro 
6407 c3 33 64			jp .chk_fault 
640a			.chk_fault3:  
640a 2a 1b e9			ld hl, (chk_loop_ovr) 
640d ed 5b 90 e2		ld de,(chk_word) 
6411				if DEBUG_STK_FAULT 
6411					DMARK "FA2" 
6411					CALLMONITOR 
6411				endif 
6411 cd 38 0e			call cmp16 
6414 ca 1d 64			jp z, .chk_fault4 
6417 11 ba 64			ld de, sfaultlo 
641a c3 33 64			jp .chk_fault 
641d			.chk_fault4:  
641d 2a 19 e8			ld hl, (chk_data_ovr) 
6420 ed 5b 90 e2		ld de,(chk_word) 
6424				if DEBUG_STK_FAULT 
6424					DMARK "FA3" 
6424					CALLMONITOR 
6424				endif 
6424 cd 38 0e			call cmp16 
6427 ca 30 64			jp z, .chk_fault5 
642a 11 d4 64			ld de, sfaultdo 
642d c3 33 64			jp .chk_fault 
