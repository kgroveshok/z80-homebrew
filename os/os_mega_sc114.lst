cd44			 
cd44			.SESEL: 
cd44				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
cd44			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
cd44			; | | Zero is disabled storage. 
cd44					if DEBUG_FORTH_WORDS_KEY 
cd44						DMARK "BN?" 
cd44						CALLMONITOR 
cd44					endif 
cd44					ld a, (spi_device_id) 
cd44					sub '0' 
cd44					ld h, 0 
cd44					ld l, a 
cd44					call forth_push_numhl 
cd44					NEXTW 
cd44			.SESELS: 
cd44				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
cd44			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
cd44			; | | Set to zero to disable storage. 
cd44					if DEBUG_FORTH_WORDS_KEY 
cd44						DMARK "BNK" 
cd44						CALLMONITOR 
cd44					endif 
cd44			 
cd44					ld a, 255 
cd44					ld (spi_cartdev), a 
cd44			 
cd44					; get bank 
cd44			 
cd44					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cd44			 
cd44			;		push hl 
cd44			 
cd44					; destroy value TOS 
cd44			 
cd44					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cd44			 
cd44					; one value on hl get other one back 
cd44			 
cd44			;		pop hl 
cd44			 
cd44			 
cd44					ld c, SPI_CE_HIGH 
cd44					ld b, '0'    ; human readable bank number 
cd44			 
cd44					ld a, l 
cd44			 
cd44					if DEBUG_FORTH_WORDS 
cd44						DMARK "BNK" 
cd44						CALLMONITOR 
cd44					endif 
cd44			 
cd44					; active low 
cd44			 
cd44			;		cp 0 
cd44					or a 
cd44					jr z, .bset 
cd44					cp 1 
cd44					jr nz, .b2 
cd44					res 0, c 
cd44					ld b, '1'    ; human readable bank number 
cd44			.b2:		cp 2 
cd44					jr nz, .b3 
cd44					res 1, c 
cd44					ld b, '2'    ; human readable bank number 
cd44			.b3:		cp 3 
cd44					jr nz, .b4 
cd44					res 2, c 
cd44					ld b, '3'    ; human readable bank number 
cd44			.b4:		cp 4 
cd44					jr nz, .b5 
cd44					res 3, c 
cd44					ld b, '4'    ; human readable bank number 
cd44			.b5:		cp 5 
cd44					jr nz, .bset 
cd44					res 4, c 
cd44					ld b, '5'    ; human readable bank number 
cd44			 
cd44			.bset: 
cd44					ld a, c 
cd44					ld (spi_device),a 
cd44					ld a, b 
cd44					ld (spi_device_id),a 
cd44					if DEBUG_FORTH_WORDS 
cd44						DMARK "BN2" 
cd44						CALLMONITOR 
cd44					endif 
cd44			 
cd44					; set default SPI clk pulse time as disabled for BANK use 
cd44			 
cd44					ld a, 0 
cd44					ld (spi_clktime), a 
cd44			 
cd44					NEXTW 
cd44			 
cd44			.CARTDEV: 
cd44				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
cd44			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
cd44			; | | Set to zero to disable devices. 
cd44					if DEBUG_FORTH_WORDS_KEY 
cd44						DMARK "CDV" 
cd44						CALLMONITOR 
cd44					endif 
cd44			 
cd44					; disable se storage bank selection 
cd44			 
cd44					ld a, SPI_CE_HIGH		; ce high 
cd44					ld (spi_device), a 
cd44			 
cd44					; get bank 
cd44			 
cd44					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cd44			 
cd44			;		push hl 
cd44			 
cd44					; destroy value TOS 
cd44			 
cd44					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cd44			 
cd44					; one value on hl get other one back 
cd44			 
cd44			;		pop hl 
cd44			 
cd44					; active low 
cd44			 
cd44					ld c, 255 
cd44			 
cd44					ld a, l 
cd44					if DEBUG_FORTH_WORDS 
cd44						DMARK "CDV" 
cd44						CALLMONITOR 
cd44					endif 
cd44			;		cp 0 
cd44					or a 
cd44					jr z, .cset 
cd44					cp 1 
cd44					jr nz, .c2 
cd44					res 0, c 
cd44			.c2:		cp 2 
cd44					jr nz, .c3 
cd44					res 1, c 
cd44			.c3:		cp 3 
cd44					jr nz, .c4 
cd44					res 2, c 
cd44			.c4:		cp 4 
cd44					jr nz, .c5 
cd44					res 3, c 
cd44			.c5:		cp 5 
cd44					jr nz, .c6 
cd44					res 4, c 
cd44			.c6:		cp 6 
cd44					jr nz, .c7 
cd44					res 5, c 
cd44			.c7:		cp 7 
cd44					jr nz, .c8 
cd44					res 6, c 
cd44			.c8:		cp 8 
cd44					jr nz, .cset 
cd44					res 7, c 
cd44			.cset:		ld a, c 
cd44					ld (spi_cartdev),a 
cd44			 
cd44					if DEBUG_FORTH_WORDS 
cd44						DMARK "CD2" 
cd44						CALLMONITOR 
cd44					endif 
cd44			 
cd44					; set default SPI clk pulse time as 10ms for CARTDEV use 
cd44			 
cd44					ld a, $0a 
cd44					ld (spi_clktime), a 
cd44					NEXTW 
cd44			endif 
cd44			 
