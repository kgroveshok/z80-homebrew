1117			StrictStrCmp: 
1117				; Load next chars of each string 
1117 1a				ld a, (de) 
1118 47				ld b, a 
1119 7e				ld a, (hl) 
111a				; Compare 
111a b8				cp b 
111b				; Return non-zero if chars don't match 
111b c0				ret nz 
111c				; Check for end of both strings 
111c fe 00			cp "\0" 
111e				; Return if strings have ended 
111e c8				ret z 
111f				; Otherwise, advance to next chars 
111f 23				inc hl 
1120 13				inc de 
1121 18 f4			jr StrictStrCmp 
