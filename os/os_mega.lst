10ba			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
10ba			 
10ba			; String Length 
10ba			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
10ba			 
10ba			; Get the length of the null-terminated string starting at $8000 hl 
10ba			;    LD     HL, $8000 
10ba			 
10ba			strlenz: 
10ba			 
10ba af			    XOR    A               ; Zero is the value we are looking for. 
10bb 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
10bc 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
10bd			                           ; 65, 536 bytes (the entire addressable memory space). 
10bd ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10bf			 
10bf			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10bf 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
10c0 6f			    LD     L, A             ; number of bytes 
10c1 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10c3 2b			    DEC    HL              ; Compensate for null. 
10c4 c9				ret 
10c5			 
10c5			; Get the length of the A terminated string starting at $8000 hl 
10c5			;    LD     HL, $8000 
10c5			 
10c5			strlent: 
10c5			 
10c5			                  ; A is the value we are looking for. 
10c5 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10c7 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10c9			                           ; 65, 536 bytes (the entire addressable memory space). 
10c9 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10cb			 
10cb			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10cb 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10cd 2e 00		    LD     L, 0             ; number of bytes 
10cf ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10d1 2b			    DEC    HL              ; Compensate for null. 
10d2 c9				ret 
10d3			 
10d3			 
10d3			;Comparing Strings 
10d3			 
10d3			;IN    HL     Address of string1. 
10d3			;      DE     Address of string2. 
10d3			 
10d3			; doc given but wrong??? 
10d3			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10d3			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10d3			; tested 
10d3			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10d3			 
10d3			strcmp_old: 
10d3 e5			    PUSH   HL 
10d4 d5			    PUSH   DE 
10d5			 
10d5 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10d6 be			    CP     (HL)            ; (want to minimize work). 
10d7 38 01		    JR     C, Str1IsBigger 
10d9 7e			    LD     A, (HL) 
10da			 
10da			Str1IsBigger: 
10da 4f			    LD     C, A             ; Put length in BC 
10db 06 00		    LD     B, 0 
10dd 13			    INC    DE              ; Increment pointers to meat of string. 
10de 23			    INC    HL 
10df			 
10df			CmpLoop: 
10df 1a			    LD     A, (DE)          ; Compare bytes. 
10e0 ed a1		    CPI 
10e2 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10e4 13			    INC    DE              ; Update pointer. 
10e5 ea df 10		    JP     PE, CmpLoop 
10e8			 
10e8 d1			    POP    DE 
10e9 e1			    POP    HL 
10ea 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
10eb be			    CP     (HL) 
10ec c9			    RET 
10ed			 
10ed			NoMatch: 
10ed 2b			    DEC    HL 
10ee be			    CP     (HL)            ; Compare again to affect carry. 
10ef d1			    POP    DE 
10f0 e1			    POP    HL 
10f1 c9			    RET 
