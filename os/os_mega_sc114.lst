9b21				; get back the saved start of the token 
9b21			 
9b21 d9				exx 
9b22 e5				push hl     ; save start of token just in case it is the right one 
9b23 d9				exx 
9b24 e1				pop hl        ; save it to hl 
9b25			 
9b25 c9				ret 
