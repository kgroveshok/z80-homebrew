4479			; var handler 
4479			 
4479			 
4479			.VARS: 
4479				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
4479 77				db WORD_SYS_CORE+99             
447a f6 44			dw .V0            
447c 04				db 3 + 1 
447d .. 00			db "VAR",0              
4481				endm 
# End of macro CWHEAD
4481			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
4481			; | 
4481			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
4481			; | |  
4481			; | | e.g. 
4481			; | |         #30 a var ! 
4481			; | |         a var @ . 
4481			; | |   
4481			; | |     Displays the number 30 
4481			; | | 
4481			; | | Each variable pointer is a word so can use for any words that use that:  
4481			; | |  
4481			; | | e.g. 
4481			; | |  
4481			; | |         #30 a var 2! 
4481			; | |         a var 2@ . 
4481			; | |   
4481			; | |     Displays the number 30 
4481			; | |  
4481			; | | > [!NOTE]  
4481			; ! | > If a full string is passed then only the first char is looked at 
4481			; | | > Any other char could exceed bounds checks!  
4481			; | | > 
4481			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
4481			 
4481					if DEBUG_FORTH_WORDS_KEY 
4481						DMARK "VAR" 
4481				if DEMARK_VERSION = 1  
4481 e5					push hl  
4482 21 8a 44				ld hl, .dmark  
4485 22 60 ee				ld (debug_mark), hl  
4488				endif  
4488				if DEMARK_VERSION = 0  
4488					push af  
4488					ld a, (.dmark)  
4488					ld (debug_mark),a  
4488					ld a, (.dmark+1)  
4488					ld (debug_mark+1),a  
4488					ld a, (.dmark+2)  
4488					ld (debug_mark+2),a  
4488				endif  
4488 18 04			jr .pastdmark  
448a ..			.dmark: db "VAR"  
448d				if DEMARK_VERSION = 1  
448d 00					db 0  
448e				endif  
448e				if DEMARK_VERSION = 1  
448e e1			.pastdmark: pop hl  
448f				endif  
448f				if DEMARK_VERSION = 0  
448f			.pastdmark: pop af  
448f				endif  
448f			endm  
# End of macro DMARK
448f						CALLMONITOR 
448f				if BASE_CPM=1  
448f cd 6b ee				call debug_vector  
4492				endif  
4492				if BASE_KEV=1  
4492					rst 8  
4492				endif  
4492				endm  
# End of macro CALLMONITOR
4492					endif 
4492			 
4492					FORTH_DSP_VALUEHL 
4492				if BASE_CPM=1 
4492 cd 75 1a			call macro_dsp_valuehl 
4495				endif 
4495				if BASE_KEV=1 
4495					rst $18 
4495				endif 
4495				endm 
# End of macro FORTH_DSP_VALUEHL
