8fb7			config_fdir: 
8fb7				; using the scratch dir go through and release the memory allocated for each string 
8fb7				 
8fb7				ld hl, scratch 
8fb7			.cfdir:	ld e,(hl) 
8fb7				inc hl 
8fb7				ld d,(hl) 
8fb7				inc hl 
8fb7			 
8fb7				ex de, hl 
8fb7				call ishlzero 
8fb7				ret z     ; return on null pointer 
8fb7				call free 
8fb7				ex de, hl 
8fb7				jr .cfdir 
8fb7			 
8fb7			 
8fb7				ret 
