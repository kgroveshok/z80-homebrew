11b9			; Get 2 ASCII characters as hex byte from pointer in hl 
11b9			 
11b9			BYTERD: 
11b9 16 00			LD	D,00h		;Set up 
11bb cd c3 11			CALL	HEXCON		;Get byte and convert to hex 
11be 87				ADD	A,A		;First nibble so 
11bf 87				ADD	A,A		;multiply by 16 
11c0 87				ADD	A,A		; 
11c1 87				ADD	A,A		; 
11c2 57				LD	D,A		;Save hi nibble in D 
11c3			HEXCON: 
11c3 7e				ld a, (hl)		;Get next chr 
11c4 23				inc hl 
11c5 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
11c7 fe 0a			CP	00Ah		;Is it 0-9 ? 
11c9 38 02			JR	C,NALPHA	;If so miss next bit 
11cb d6 07			SUB	007h		;Else convert alpha 
11cd			NALPHA: 
11cd b2				OR	D		;Add hi nibble back 
11ce c9				RET			; 
