cc16 .. 00			db "VAR",0              
cc1a				endm 
# End of macro CWHEAD
cc1a			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
cc1a			; | 
cc1a			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
cc1a			; | |  
cc1a			; | | e.g. 
cc1a			; | |         #30 a var ! 
cc1a			; | |         a var @ . 
cc1a			; | |   
cc1a			; | |     Displays the number 30 
cc1a			; | | 
cc1a			; | | Each variable pointer is a word so can use for any words that use that:  
cc1a			; | |  
cc1a			; | | e.g. 
cc1a			; | |  
cc1a			; | |         #30 a var 2! 
cc1a			; | |         a var 2@ . 
cc1a			; | |   
cc1a			; | |     Displays the number 30 
cc1a			; | |  
cc1a			; | | > [!NOTE]  
cc1a			; ! | > If a full string is passed then only the first char is looked at 
cc1a			; | | > Any other char could exceed bounds checks!  
cc1a			; | | > 
cc1a			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
cc1a			 
cc1a					if DEBUG_FORTH_WORDS_KEY 
cc1a						DMARK "VAR" 
