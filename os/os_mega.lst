1043 06 2f		.Na1:	ld	b,'0'-1 
1045 04			.Na2:	inc	b 
1046 81				add	a,c 
1047 38 fc			jr	c,.Na2 
1049 91				sub	c		;works as add 100/10/1 
104a f5				push af		;safer than ld c,a 
104b 78				ld	a,b		;char is in b 
