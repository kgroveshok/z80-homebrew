014e 0e 00			ld c, 0 
0150 db 80			in a, (storage_adata) 
0152 cb 77			bit SPI_DO, a 
0154 28 02			jr z, .r1 
0156 0e 01			ld c, 1	 
0158			.r1: 
0158 79				ld a, c 
0159 c9				ret 
015a			; Set/clr spi output pin 
015a			 
