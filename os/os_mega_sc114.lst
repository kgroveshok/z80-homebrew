8f68				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
8f68				inc a 
8f68				inc a 
8f68			 
8f68				push hl   ; save where we are in the node block 
8f68			 
8f68				call addatohl 
8f68			 
8f68				; write linked list point 
8f68			 
8f68				pop de     ; get our node position 
8f68				ex de, hl 
8f68			 
8f68				ld (hl), e 
8f68				inc hl 
8f68				ld (hl), d 
8f68			 
8f68				inc hl 
8f68			 
8f68				; now at start of allocated data so save pointer 
8f68			 
8f68				push hl 
8f68			 
8f68				; jump to position of next node and setup empty header in DE 
8f68			 
8f68				ex de, hl 
8f68			 
8f68			;	inc hl ; move past end of block 
8f68			 
8f68			;	ld a, 0 
8f68				ld (hl), 0   ; empty marker 
8f68				inc hl 
8f68				ld (hl), 0   ; size 
8f68				inc hl  
8f68				ld (hl), 0   ; ptr 
8f68				inc hl 
8f68				ld (hl), 0   ; ptr 
8f68			 
8f68			 
8f68				pop hl 
8f68			 
8f68					if DEBUG_FORTH_MALLOC_INT 
8f68						DMARK "mmr" 
8f68						CALLMONITOR 
8f68					endif 
8f68			 
8f68			.exit: 
8f68				pop af 
8f68				pop bc 
8f68				pop de  
8f68				ret 
8f68			 
8f68			 
8f68			 
8f68			 
8f68			free:  
8f68				push hl 
8f68				push af 
8f68				; get address in hl 
8f68			 
8f68					if DEBUG_FORTH_MALLOC_INT 
8f68						DMARK "fre" 
8f68						CALLMONITOR 
8f68					endif 
8f68				; data is at hl - move to block count 
8f68				dec hl 
8f68				dec hl    ; get past pointer 
8f68				dec hl 
8f68			 
8f68				ld a, (hl)    ; need this for a validation check 
8f68			 
8f68				dec hl    ; move to block marker 
8f68			 
8f68				; now check that the block count and block marker are the same  
8f68			        ; this checks that we are on a malloc node and not random memory 
8f68			        ; OK a faint chance this could be a problem but rare - famous last words! 
8f68			 
8f68				ld c, a 
8f68				ld a, (hl)    
8f68			 
8f68				cp c 
8f68				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
8f68			 
8f68				; yes good chance we are on a malloc node 
8f68			 
8f68			;	ld a, 0      
8f68				ld (hl), 0   ; mark as free 
8f68			 
8f68				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
8f68			 
8f68			.freeignore:  
8f68			 
8f68				pop af 
8f68				pop hl 
8f68			 
8f68				ret 
8f68			 
8f68			 
8f68			 
8f68			endif 
8f68			 
