10c3 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
10c6 dd 66 03		      ld    H, (IX+3) 
10c9			 
10c9 23			      inc   HL                      ; Size of prev free block into DE 
10ca 23			      inc   HL 
10cb 5e			      ld    E, (HL) 
10cc 23			      inc   HL 
10cd 56			      ld    D, (HL) 
10ce 2b			      dec   HL 
10cf 2b			      dec   HL 
10d0 2b			      dec   HL 
10d1			 
10d1 19			      add   HL, DE                  ; Add prev block addr and size 
10d2			 
10d2 b7			      or    A                       ; Clear the carry flag 
10d3 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
10d5 20 2e		      jr    NZ, free_done 
10d7			 
10d7			      ; Freed block is adjacent to prev, merge into one bigger block 
10d7 60			      ld    H, B                    ; Load next ptr from freed block into DE 
10d8 69			      ld    L, C 
10d9 5e			      ld    E, (HL) 
10da 23			      inc   HL 
10db 56			      ld    D, (HL) 
10dc e5			      push  HL                      ; Save freed block ptr for later 
10dd			 
