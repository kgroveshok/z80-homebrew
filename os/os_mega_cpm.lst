0f86			 
0f86				ld de, 0 
0f86			        call cmp16 
0f86				jr nz, .lowalloz 
0f86			 
0f86				push hl 
0f86				push de 
0f86					ld hl, display_fb0 
0f86					ld (display_fb_active), hl 
0f86				call clear_display 
0f86				ld a, 0 
0f86				ld de, .malloczero 
0f86				call str_at_display 
0f86				call update_display 
0f86				call delay1s 
0f86				call delay1s 
0f86				call bp_on 
0f86			;	ld a, 0 
