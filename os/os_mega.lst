11b1			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
11b1			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
11b1			;;    subtract $30, if result > 9 then subtract $7 more 
11b1			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
11b1			atohex: 
11b1 d6 30				SUB $30 
11b3 fe 0a				CP 10 
11b5 f8					RET M		; If result negative it was 0-9 so we're done 
11b6 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
11b8 c9					RET		 
