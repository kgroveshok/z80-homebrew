10d1			 
10d1			; only care about direct match or not 
10d1			; hl and de strings 
10d1			; zero set if the same 
10d1			 
10d1			strcmp: 
10d1 1a				ld a, (de) 
10d2 be				cp (hl) 
10d3 28 02			jr z, .ssame 
10d5 b7				or a 
10d6 c9				ret 
10d7			 
10d7			.ssame:  
10d7			;	cp 0 
10d7 b7				or a 
10d8 c8				ret z 
10d9			 
10d9 23				inc hl 
10da 13				inc de 
10db 18 f4			jr strcmp 
