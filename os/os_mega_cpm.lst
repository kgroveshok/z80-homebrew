0f4f			 
0f4f			;Comparing Strings 
0f4f			 
0f4f			;IN    HL     Address of string1. 
0f4f			;      DE     Address of string2. 
0f4f			 
0f4f			; doc given but wrong??? 
0f4f			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
0f4f			;      carry  Set if string1 > string2, reset if string1 <= string2. 
0f4f			; tested 
0f4f			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
0f4f			 
0f4f			strcmp_old: 
0f4f e5			    PUSH   HL 
0f50 d5			    PUSH   DE 
0f51			 
0f51 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
0f52 be			    CP     (HL)            ; (want to minimize work). 
0f53 38 01		    JR     C, Str1IsBigger 
0f55 7e			    LD     A, (HL) 
0f56			 
0f56			Str1IsBigger: 
0f56 4f			    LD     C, A             ; Put length in BC 
0f57 06 00		    LD     B, 0 
0f59 13			    INC    DE              ; Increment pointers to meat of string. 
0f5a 23			    INC    HL 
0f5b			 
0f5b			CmpLoop: 
0f5b 1a			    LD     A, (DE)          ; Compare bytes. 
0f5c ed a1		    CPI 
0f5e 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
0f60 13			    INC    DE              ; Update pointer. 
0f61 ea 5b 0f		    JP     PE, CmpLoop 
0f64			 
0f64 d1			    POP    DE 
0f65 e1			    POP    HL 
0f66 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
0f67 be			    CP     (HL) 
0f68 c9			    RET 
0f69			 
0f69			NoMatch: 
0f69 2b			    DEC    HL 
0f6a be			    CP     (HL)            ; Compare again to affect carry. 
0f6b d1			    POP    DE 
0f6c e1			    POP    HL 
0f6d c9			    RET 
0f6e			 
