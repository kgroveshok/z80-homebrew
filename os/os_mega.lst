1107				ld a, 0 
1107				ld de, .mallocasize 
1107				call str_at_display 
1107				call update_display 
1107				call delay1s 
1107				call delay1s 
1107			;	ld a, 0 
1107			;	ld (os_view_disable), a 
1107				call bp_on 
1107				pop de 
1107				pop hl 
1107			 
1107				CALLMONITOR 
1107				jr .lowdonex 
1107			.lowallocx: 
1107			 
