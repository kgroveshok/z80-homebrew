63e6			; init the words to detect the under/overflow 
63e6			 
63e6			chk_stk_init: 
63e6				; a vague random number to check so we dont get any "lucky" hits 
63e6 3e 2d			ld a, 45 
63e8 6f				ld l, a 
63e9 00				nop 
63ea 3e 17			ld a, 23 
63ec 67				ld h, a 
63ed			 
63ed 22 bc f0			ld (chk_word), hl     ; the word we need to check against 
63f0			 
63f0			;	ld (chk_stund), hl	; stack points.... 
63f0 22 3b fe			ld (chk_stovr), hl 
63f3 22 0b f9			ld (chk_ret_und), hl 
63f6 22 c9 f8			ld (chk_ret_ovr), hl 
63f9 22 47 f8			ld (chk_loop_ovr), hl 
63fc 22 45 f6			ld (chk_data_ovr), hl 
63ff c9				ret 
