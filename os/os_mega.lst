6207			; **********************************************************************  
6207			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
6207			; **********************************************************************  
6207			;  
6207			; **  Written as a Small Computer Monitor App  
6207			; **  www.scc.me.uk  
6207			;  
6207			; History  
6207			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
6207			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
6207			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
6207			;  
6207			; **********************************************************************  
6207			;  
6207			; This program is an example of one of the methods of interfacing an   
6207			; alphanumeric LCD module.   
6207			;  
6207			; In this example the display is connected to either a Z80 PIO or a   
6207			; simple 8-bit output port.   
6207			;  
6207			; This interfacing method uses 4-bit data mode and uses time delays  
6207			; rather than polling the display's ready status. As a result the   
6207			; interface only requires 6 simple output lines:  
6207			;   Output bit 0 = not used  
6207			;   Output bit 1 = not used  
6207			;   Output bit 2 = RS         High = data, Low = instruction  
6207			;   Output bit 3 = E          Active high  
6207			;   Output bit 4 = DB4  
6207			;   Output bit 5 = DB5  
6207			;   Output bit 6 = DB6  
6207			;   Output bit 7 = DB7  
6207			; Display's R/W is connected to 0v so it is always in write mode  
6207			;  
6207			; This set up should work with any system supporting the RC2014 bus  
6207			  
6207			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
6207			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
6207			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
6207			;  
6207			; **********************************************************************  
6207			  
6207			; Additonal for 4x40. E1 and E2 instead of just E   
6207			; TODO swipe vidout signal on port a to activate E2  
6207			  
6207			; **********************************************************************  
6207			; **  Constants  
6207			; **********************************************************************  
6207			; LCD constants required by LCD support module  
6207			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
6207			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
6207			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
6207			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
6207			; TODO Decide which E is being set  
6207			kLCDWidth:  EQU display_cols             ;Width in characters  
6207			  
6207			; **********************************************************************  
6207			; **  Code library usage  
6207			; **********************************************************************  
6207			  
6207			; send character to current cursor position  
6207			; wraps and/or scrolls screen automatically  
6207			  
6207			  
6207			  
6207			lcd_init:  
6207			  
6207			; SCMonAPI functions used  
6207			  
6207			; Alphanumeric LCD functions used  
6207			; no need to specify specific functions for this module  
6207			  
6207 3e cf		            LD   A, 11001111b  
6209 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
620b 3e 00		            LD   A, 00000000b  
620d d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
620f			  
620f			; Initialise alphanumeric LCD module  
620f 3e 00				ld a, 0  
6211 32 fb fa				ld (display_lcde1e2), a  
6214 cd 95 62		            CALL fLCD_Init      ;Initialise LCD module  
6217 3e 01				ld a, 1  
6219 32 fb fa				ld (display_lcde1e2), a  
621c cd 95 62		            CALL fLCD_Init      ;Initialise LCD module  
621f			  
621f c9				ret  
6220			  
