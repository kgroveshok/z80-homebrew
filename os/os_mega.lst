1030			 
1030			 
1030			;Converts an ASCII string to an unsigned 16-bit integer 
1030			;Quits when it reaches a non-decimal digit 
1030			 
1030			string_to_uint16: 
1030			atoui_16: 
1030			;Input: 
1030			;     DE points to the string 
1030			;Outputs: 
1030			;     HL is the result 
1030			;     A is the 8-bit value of the number 
1030			;     DE points to the byte after the number 
1030			;Destroys: 
1030			;     BC 
1030			;       if the string is non-empty, BC is HL/10 
1030			;Size:  24 bytes 
1030			;Speed: 42+d(104+{0,9}) 
1030			;       d is the number of digits in the number 
1030			;       max is 640 cycles for a 5 digit number 
1030			;Assuming no leading zeros: 
1030			;1 digit:  146cc 
1030			;2 digit:  250cc 
1030			;3 digit:  354cc or 363cc (avg: 354.126cc) 
1030			;4 digit:  458cc or 467cc (avg: 458.27cc) 
1030			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
1030			;avg: 544.81158447265625cc (544+13297/16384) 
1030			;=============================================================== 
1030 21 00 00		  ld hl,0 
1033			.u16a: 
1033 1a			  ld a,(de) 
1034 d6 30		  sub 30h 
1036 fe 0a		  cp 10 
1038 d0			  ret nc 
1039 13			  inc de 
103a 44			  ld b,h 
103b 4d			  ld c,l 
103c 29			  add hl,hl 
103d 29			  add hl,hl 
103e 09			  add hl,bc 
103f 29			  add hl,hl 
1040 85			  add a,l 
1041 6f			  ld l,a 
1042 30 ef		  jr nc,.u16a 
1044 24			  inc h 
1045 c3 33 10		  jp .u16a 
1048			 
1048			 
1048			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1048			 
1048			;written by Zeda 
1048			;Converts a 16-bit unsigned integer to an ASCII string. 
1048			 
1048			uitoa_16: 
1048			;Input: 
1048			;   DE is the number to convert 
1048			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1048			;Output: 
1048			;   HL points to the null-terminated ASCII string 
1048			;      NOTE: This isn't necessarily the same as the input HL. 
1048 d5			  push de 
1049 c5			  push bc 
104a f5			  push af 
104b eb			  ex de,hl 
104c			 
104c 01 f0 d8		  ld bc,-10000 
104f 3e 2f		  ld a,'0'-1 
1051 3c			  inc a 
1052 09			  add hl,bc  
1053 38 fc		   jr c,$-2 
1055 12			  ld (de),a 
1056 13			  inc de 
1057			 
1057 01 e8 03		  ld bc,1000 
105a 3e 3a		  ld a,'9'+1 
105c 3d			  dec a  
105d 09			  add hl,bc  
105e 30 fc		   jr nc,$-2 
1060 12			  ld (de),a 
1061 13			  inc de 
1062			 
1062 01 9c ff		  ld bc,-100 
1065 3e 2f		  ld a,'0'-1 
1067 3c			  inc a  
1068 09			  add hl,bc  
1069 38 fc		   jr c,$-2 
106b 12			  ld (de),a 
106c 13			  inc de 
106d			 
106d 7d			  ld a,l 
106e 26 3a		  ld h,'9'+1 
1070 25			  dec h  
1071 c6 0a		  add a,10  
1073 30 fb		   jr nc,$-3 
1075 c6 30		  add a,'0' 
1077 eb			  ex de,hl 
1078 72			  ld (hl),d 
1079 23			  inc hl 
107a 77			  ld (hl),a 
107b 23			  inc hl 
107c 36 00		  ld (hl),0 
107e			 
107e			;Now strip the leading zeros 
107e 0e fa		  ld c,-6 
1080 09			  add hl,bc 
1081 3e 30		  ld a,'0' 
1083 23			  inc hl  
1084 be			  cp (hl)  
1085 28 fc		  jr z,$-2 
1087			 
1087			;Make sure that the string is non-empty! 
1087 7e			  ld a,(hl) 
1088 b7			  or a 
1089 20 01		  jr nz,.atoub 
108b 2b			  dec hl 
108c			.atoub: 
108c			 
108c f1			  pop af 
108d c1			  pop bc 
108e d1			  pop de 
108f c9			  ret 
1090			 
1090			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
1090			 
1090			toUpper: 
1090			;A is the char. 
1090			;If A is a lowercase letter, this sets it to the matching uppercase 
1090			;18cc or 30cc or 41cc 
1090			;avg: 26.75cc 
1090 fe 61		  cp 'a' 
1092 d8			  ret c 
1093 fe 7b		  cp 'z'+1 
1095 d0			  ret nc 
1096 d6 20		  sub 'a'-'A' 
1098 c9			  ret 
1099			 
1099			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
1099			 
1099			; String Length 
1099			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
1099			 
1099			; Get the length of the null-terminated string starting at $8000 hl 
1099			;    LD     HL, $8000 
1099			 
1099			strlenz: 
1099			 
1099 af			    XOR    A               ; Zero is the value we are looking for. 
109a 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
109b 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
109c			                           ; 65, 536 bytes (the entire addressable memory space). 
109c ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
109e			 
109e			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
109e 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
109f 6f			    LD     L, A             ; number of bytes 
10a0 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10a2 2b			    DEC    HL              ; Compensate for null. 
10a3 c9				ret 
10a4			 
10a4			; Get the length of the A terminated string starting at $8000 hl 
10a4			;    LD     HL, $8000 
10a4			 
10a4			strlent: 
10a4			 
10a4			                  ; A is the value we are looking for. 
10a4 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10a6 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10a8			                           ; 65, 536 bytes (the entire addressable memory space). 
10a8 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10aa			 
10aa			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10aa 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10ac 2e 00		    LD     L, 0             ; number of bytes 
10ae ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10b0 2b			    DEC    HL              ; Compensate for null. 
10b1 c9				ret 
10b2			 
10b2			 
10b2			;Comparing Strings 
10b2			 
10b2			;IN    HL     Address of string1. 
10b2			;      DE     Address of string2. 
10b2			 
10b2			; doc given but wrong??? 
10b2			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10b2			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10b2			; tested 
10b2			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10b2			 
10b2			strcmp_old: 
10b2 e5			    PUSH   HL 
10b3 d5			    PUSH   DE 
10b4			 
10b4 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10b5 be			    CP     (HL)            ; (want to minimize work). 
10b6 38 01		    JR     C, Str1IsBigger 
10b8 7e			    LD     A, (HL) 
10b9			 
10b9			Str1IsBigger: 
10b9 4f			    LD     C, A             ; Put length in BC 
10ba 06 00		    LD     B, 0 
10bc 13			    INC    DE              ; Increment pointers to meat of string. 
10bd 23			    INC    HL 
10be			 
10be			CmpLoop: 
10be 1a			    LD     A, (DE)          ; Compare bytes. 
10bf ed a1		    CPI 
10c1 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10c3 13			    INC    DE              ; Update pointer. 
10c4 ea be 10		    JP     PE, CmpLoop 
10c7			 
10c7 d1			    POP    DE 
10c8 e1			    POP    HL 
10c9 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
10ca be			    CP     (HL) 
10cb c9			    RET 
10cc			 
10cc			NoMatch: 
10cc 2b			    DEC    HL 
10cd be			    CP     (HL)            ; Compare again to affect carry. 
10ce d1			    POP    DE 
10cf e1			    POP    HL 
10d0 c9			    RET 
