89ad 21 00 00		    ld hl,0 
89b0 78			    ld a,b 
89b1 06 08		    ld b,8 
89b3			Div16_Loop1: 
89b3 17			    rla 
89b4 ed 6a		    adc hl,hl 
89b6 ed 52		    sbc hl,de 
89b8 30 01		    jr nc,Div16_NoAdd1 
89ba 19			    add hl,de 
89bb			Div16_NoAdd1: 
89bb 10 f6		    djnz Div16_Loop1 
89bd 17			    rla 
89be 2f			    cpl 
89bf 47			    ld b,a 
89c0 79			    ld a,c 
89c1 48			    ld c,b 
89c2 06 08		    ld b,8 
89c4			Div16_Loop2: 
89c4 17			    rla 
89c5 ed 6a		    adc hl,hl 
89c7 ed 52		    sbc hl,de 
89c9 30 01		    jr nc,Div16_NoAdd2 
89cb 19			    add hl,de 
89cc			Div16_NoAdd2: 
89cc 10 f6		    djnz Div16_Loop2 
89ce 17			    rla 
89cf 2f			    cpl 
89d0 41			    ld b,c 
89d1 4f			    ld c,a 
89d2 c9			ret 
