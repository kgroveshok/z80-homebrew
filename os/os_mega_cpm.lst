117e				ld (spi_device), a 
117e			 
117e				call storage_get_block_0 
117e			 
117e				pop bc 
117e				ld a,c 
117e				ld (store_page+STORE_0_BANKRUN), a 
117e				ld a,b 
117e				ld (store_page+STORE_0_BANKRUNN), a 
117e					ld hl, 0 
117e					ld de, store_page 
117e				call storage_write_block 
117e			 
