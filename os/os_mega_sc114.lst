c001					push af  
c001					ld a, (.dmark)  
c001					ld (debug_mark),a  
c001					ld a, (.dmark+1)  
c001					ld (debug_mark+1),a  
c001					ld a, (.dmark+2)  
c001					ld (debug_mark+2),a  
c001				endif  
c001 18 04			jr .pastdmark  
c003 ..			.dmark: db "VAR"  
c006				if DEMARK_VERSION = 1  
c006 00					db 0  
c007				endif  
c007				if DEMARK_VERSION = 1  
c007 e1			.pastdmark: pop hl  
c008				endif  
c008				if DEMARK_VERSION = 0  
c008			.pastdmark: pop af  
c008				endif  
c008			endm  
# End of macro DMARK
c008						CALLMONITOR 
c008				if BASE_CPM=1  
