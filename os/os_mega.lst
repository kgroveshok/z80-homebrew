6946			; **********************************************************************  
6946			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
6946			; **********************************************************************  
6946			;  
6946			; **  Written as a Small Computer Monitor App  
6946			; **  www.scc.me.uk  
6946			;  
6946			; History  
6946			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
6946			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
6946			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
6946			;  
6946			; **********************************************************************  
6946			;  
6946			; This program is an example of one of the methods of interfacing an   
6946			; alphanumeric LCD module.   
6946			;  
6946			; In this example the display is connected to either a Z80 PIO or a   
6946			; simple 8-bit output port.   
6946			;  
6946			; This interfacing method uses 4-bit data mode and uses time delays  
6946			; rather than polling the display's ready status. As a result the   
6946			; interface only requires 6 simple output lines:  
6946			;   Output bit 0 = not used  
6946			;   Output bit 1 = not used  
6946			;   Output bit 2 = RS         High = data, Low = instruction  
6946			;   Output bit 3 = E          Active high  
6946			;   Output bit 4 = DB4  
6946			;   Output bit 5 = DB5  
6946			;   Output bit 6 = DB6  
6946			;   Output bit 7 = DB7  
6946			; Display's R/W is connected to 0v so it is always in write mode  
6946			;  
6946			; This set up should work with any system supporting the RC2014 bus  
6946			  
6946			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
6946			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
6946			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
6946			;  
6946			; **********************************************************************  
6946			  
6946			; Additonal for 4x40. E1 and E2 instead of just E   
6946			; TODO swipe vidout signal on port a to activate E2  
6946			  
6946			; **********************************************************************  
6946			; **  Constants  
6946			; **********************************************************************  
6946			; LCD constants required by LCD support module  
6946			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
6946			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
6946			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
6946			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VICLK  
6946			kLCDBitLED:   EQU 1              ;Port bit for LCD E2 signal            VIDDO  
6946			; TODO Decide which E is being set  
6946			kLCDWidth:  EQU display_cols             ;Width in characters  
6946			  
6946			; **********************************************************************  
6946			; **  Code library usage  
6946			; **********************************************************************  
6946			  
6946			; send character to current cursor position  
6946			; wraps and/or scrolls screen automatically  
6946			  
6946			  
6946			  
6946			lcd_init:  
6946			  
6946			; SCMonAPI functions used  
6946			  
6946			; Alphanumeric LCD functions used  
6946			; no need to specify specific functions for this module  
6946			  
6946 3e cf		            LD   A, 11001111b  
6948 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
694a 3e 00		            LD   A, 00000000b  
694c d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
694e			  
694e			; Initialise alphanumeric LCD module  
694e 3e 00				ld a, 0  
6950 32 fb fa				ld (display_lcde1e2), a  
6953 cd d4 69		            CALL fLCD_Init      ;Initialise LCD module  
6956 3e 01				ld a, 1  
6958 32 fb fa				ld (display_lcde1e2), a  
695b cd d4 69		            CALL fLCD_Init      ;Initialise LCD module  
695e			  
695e c9				ret  
695f			  
