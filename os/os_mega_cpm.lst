115e			 
115e			; hl - points to file name 
115e			; de - points to strings to add to file 
115e			 
115e			.genfile: 
115e				push hl 
115e				push de 
115e			 
115e				call clear_display 
115e				ld a, display_row_1 
115e				ld de, .genfiletxt 
115e				call str_at_display 
115e				call update_display 
115e			 
115e				pop de 
115e				pop hl 
115e			 
115e			 
115e				push de 
115e				call storage_create 
115e				; id in hl 
115e				pop de   ; table of strings to add 
115e			 
115e			.genloop: 
115e			 
115e				push hl ; save id for next time around 
115e				push de ; save de for next time around 
115e			 
115e				ex de, hl 
115e				call loadwordinhl 
115e				ex de, hl 
115e			 
115e				; need hl to be the id 
115e				; need de to be the string ptr 
115e				 
115e				call storage_append 
115e			 
115e				pop de 
115e				pop hl 
115e			 
115e				inc de 
115e				inc de 
115e			 
115e				ld a,(de) 
115e				cp 0 
115e				jr nz, .genloop 
115e				inc de 
115e				ld a, (de) 
115e				dec de 
115e				cp 0 
115e				jr nz, .genloop	 
115e			 
115e				ret 
