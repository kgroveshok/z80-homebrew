1b9c			user_word_eol:  
1b9c				; hl contains the pointer to where to create a linked list item from the end 
1b9c				; of the user dict to continue on at the system word dict 
1b9c				 
1b9c				; poke the stub of the word list linked list to repoint to rom words 
1b9c			 
1b9c				; stub format 
1b9c				; db   word id 
1b9c				; dw    link to next word 
1b9c			        ; db char length of token 
1b9c				; db string + 0 term 
1b9c				; db exec code....  
1b9c			 
1b9c			;	ld a, WORD_SYS_ROOT     ; root word 
1b9c 36 00			ld (hl), WORD_SYS_ROOT		; word id 
1b9e 23				inc hl 
1b9f			 
1b9f 11 48 1d			ld de, sysdict 
1ba2 73				ld (hl), e		; next word link ie system dict 
1ba3 23				inc hl 
1ba4 72				ld (hl), d		; next word link ie system dict 
1ba5 23				inc hl	 
1ba6			 
1ba6			;	ld (hl), sysdict		; next word link ie system dict 
1ba6			;	inc hl 
1ba6			;	inc hl 
1ba6			 
1ba6			;	inc hl 
1ba6			;	inc hl 
1ba6			 
1ba6			;	ld a, 2			; word length is 0 
1ba6 36 02			ld (hl), 2 
1ba8 23				inc hl 
1ba9			 
1ba9			;	ld a, '~'			; word length is 0 
1ba9 36 7e			ld (hl), '~' 
1bab 23				inc hl 
1bac			;	ld a, 0			; save empty word 
1bac 36 00			ld (hl), 0 
