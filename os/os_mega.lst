6a2c			  
6a2c				  
6a2c 3e 50			ld a, kLCD_Line3  
6a2e cd 24 6b		            CALL fLCD_Pos       ;Position cursor to location in A  
6a31 06 28			ld b, display_cols  
6a33 ed 5b f9 fa		ld de, (display_write_tmp)  
6a37 cd 53 6a			call write_len_string  
6a3a				  
6a3a 2a f9 fa			ld hl, (display_write_tmp)  
6a3d 11 28 00			ld de, display_cols  
6a40 19				add hl,de  
6a41 22 f9 fa			ld (display_write_tmp),hl  
6a44			  
6a44				  
6a44 3e 78			ld a, kLCD_Line4  
6a46 cd 24 6b		            CALL fLCD_Pos       ;Position cursor to location in A  
6a49 06 28			ld b, display_cols  
6a4b ed 5b f9 fa		ld de, (display_write_tmp)  
6a4f cd 53 6a			call write_len_string  
6a52 c9					ret  
6a53				  
6a53				; write out a fixed length string given in b from de  
6a53			  
6a53 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
6a54 cd d6 6a		            CALL fLCD_Data      ;Write character to display  
6a57 13				inc de  
