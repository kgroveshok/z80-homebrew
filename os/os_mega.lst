6930			; **********************************************************************  
6930			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6930			; **********************************************************************  
6930			;  
6930			; **  Written as a Small Computer Monitor App   
6930			; **  Version 0.1 SCC 2018-05-16  
6930			; **  www.scc.me.uk  
6930			;  
6930			; **********************************************************************  
6930			;  
6930			; This module provides support for alphanumeric LCD modules using with  
6930			; *  HD44780 (or compatible) controller  
6930			; *  5 x 7 pixel fonts  
6930			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6930			; *  Interface via six digital outputs to the display (see below)  
6930			;  
6930			; LCD module pinout:  
6930			;   1  Vss   0v supply  
6930			;   2  Vdd   5v supply  
6930			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6930			;   4  RS    High = data, Low = instruction  
6930			;   5  R/W   High = Read, Low = Write  
6930			;   6  E     Enable signal (active high)  
6930			;   7  DB0   Data bit 0  
6930			;   8  DB1   Data bit 1  
6930			;   9  DB2   Data bit 2  
6930			;  10  DB3   Data bit 3  
6930			;  11  DB4   Data bit 4  
6930			;  12  DB5   Data bit 5  
6930			;  13  DB6   Data bit 6  
6930			;  14  DB7   Data bit 7  
6930			;  15  A     Backlight anode (+)  
6930			;  16  K     Backlight cathode (-)  
6930			;  
6930			; This interfacing method uses 4-bit data mode and uses time delays  
6930			; rather than polling the display's ready status. As a result the   
6930			; interface only requires 6 simple output lines:  
6930			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6930			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6930			;   LCD DB4 = Microcomputer output port bit 4  
6930			;   LCD DB5 = Microcomputer output port bit 5  
6930			;   LCD DB6 = Microcomputer output port bit 6  
6930			;   LCD DB7 = Microcomputer output port bit 7  
6930			; Display's R/W is connected to 0v so it is always in write mode  
6930			; All 6 connections must be on the same port address <kLCDPrt>  
6930			; This method also allows a decent length of cable from micro to LCD  
6930			;  
6930			; **********************************************************************  
6930			;  
6930			; To include the code for any given function provided by this module,   
6930			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6930			; the parent source file.  
6930			; For example:  #REQUIRES   uHexPrefix  
6930			;  
6930			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6930			; in the parent source file.  
6930			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6930			;  
6930			; These are the function names provided by this module:  
6930			; fLCD_Init                     ;Initialise LCD  
6930			; fLCD_Inst                     ;Send instruction to LCD  
6930			; fLCD_Data                     ;Send data byte to LCD  
6930			; fLCD_Pos                      ;Position cursor  
6930			; fLCD_Str                      ;Display string  
6930			; fLCD_Def                      ;Define custom character  
6930			;  
6930			; **********************************************************************  
6930			;  
6930			; Requires SCMonAPI.asm to also be included in the project  
6930			;  
6930			  
6930			  
6930			; **********************************************************************  
6930			; **  Constants  
6930			; **********************************************************************  
6930			  
6930			; Constants that must be defined externally  
6930			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6930			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6930			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6930			;kLCDWidth: EQU 20             ;Width in characters  
6930			  
6930			; general line offsets in any frame buffer  
6930			  
6930			  
6930			display_row_1: equ 0  
6930			display_row_2: equ display_row_1+display_cols  
6930			display_row_3: equ display_row_2 + display_cols  
6930			display_row_4: equ display_row_3 + display_cols  
6930			;display_row_4_eol:   
6930			  
6930			  
6930			; Cursor position values for the start of each line  
6930			  
6930			; E  
6930			kLCD_Line1: EQU 0x00   
6930			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6930			; E1  
6930			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6930			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6930			  
6930			; Instructions to send as A register to fLCD_Inst  
6930			kLCD_Clear: EQU 00000001b     ;LCD clear  
6930			kLCD_Off:   EQU 00001000b     ;LCD off  
6930			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6930			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6930			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6930			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6930			  
6930			; Constants used by this code module  
6930			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6930			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6930			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6930			  
6930			  
