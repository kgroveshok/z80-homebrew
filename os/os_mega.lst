0160 cb 11			rl c 
0162				; if bit 7 is set then carry is set 
0162 30 02			jr nc, .ssbc2 
0164 cb ff			set SPI_DI,a 
0166			.ssbc2:  ; output bit to ensure it is stable 
0166 d3 80			out (storage_adata),a 
0168 c9				ret 
