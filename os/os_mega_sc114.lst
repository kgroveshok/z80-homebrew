8c36			; from z80uartmonitor 
8c36			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c36			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
8c36			; pass hl for where to put the text 
8c36			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c36 c5			hexout:	PUSH BC 
8c37 f5					PUSH AF 
8c38 47					LD B, A 
8c39					; Upper nybble 
8c39 cb 3f				SRL A 
8c3b cb 3f				SRL A 
8c3d cb 3f				SRL A 
8c3f cb 3f				SRL A 
8c41 cd 51 8c				CALL tohex 
8c44 77					ld (hl),a 
8c45 23					inc hl	 
8c46					 
8c46					; Lower nybble 
8c46 78					LD A, B 
8c47 e6 0f				AND 0FH 
8c49 cd 51 8c				CALL tohex 
8c4c 77					ld (hl),a 
8c4d 23					inc hl	 
8c4e					 
8c4e f1					POP AF 
8c4f c1					POP BC 
8c50 c9					RET 
8c51					 
8c51			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c51			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
8c51			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c51			tohex: 
8c51 e5					PUSH HL 
8c52 d5					PUSH DE 
8c53 16 00				LD D, 0 
8c55 5f					LD E, A 
8c56 21 5e 8c				LD HL, .DATA 
8c59 19					ADD HL, DE 
8c5a 7e					LD A, (HL) 
8c5b d1					POP DE 
8c5c e1					POP HL 
8c5d c9					RET 
8c5e			 
8c5e			.DATA: 
8c5e 30					DEFB	30h	; 0 
8c5f 31					DEFB	31h	; 1 
8c60 32					DEFB	32h	; 2 
8c61 33					DEFB	33h	; 3 
8c62 34					DEFB	34h	; 4 
8c63 35					DEFB	35h	; 5 
8c64 36					DEFB	36h	; 6 
8c65 37					DEFB	37h	; 7 
8c66 38					DEFB	38h	; 8 
8c67 39					DEFB	39h	; 9 
8c68 41					DEFB	41h	; A 
8c69 42					DEFB	42h	; B 
8c6a 43					DEFB	43h	; C 
8c6b 44					DEFB	44h	; D 
8c6c 45					DEFB	45h	; E 
8c6d 46					DEFB	46h	; F 
8c6e			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c6e			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
8c6e			;;    subtract $30, if result > 9 then subtract $7 more 
8c6e			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8c6e			atohex: 
8c6e d6 30				SUB $30 
8c70 fe 0a				CP 10 
8c72 f8					RET M		; If result negative it was 0-9 so we're done 
8c73 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
8c75 c9					RET		 
8c76			 
8c76			 
8c76			 
8c76			 
8c76			; Get 2 ASCII characters as hex byte from pointer in hl 
8c76			 
8c76			BYTERD: 
8c76 16 00			LD	D,00h		;Set up 
8c78 cd 80 8c			CALL	HEXCON		;Get byte and convert to hex 
8c7b 87				ADD	A,A		;First nibble so 
8c7c 87				ADD	A,A		;multiply by 16 
8c7d 87				ADD	A,A		; 
8c7e 87				ADD	A,A		; 
8c7f 57				LD	D,A		;Save hi nibble in D 
8c80			HEXCON: 
8c80 7e				ld a, (hl)		;Get next chr 
8c81 23				inc hl 
8c82 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
8c84 fe 0a			CP	00Ah		;Is it 0-9 ? 
8c86 38 02			JR	C,NALPHA	;If so miss next bit 
8c88 d6 07			SUB	007h		;Else convert alpha 
8c8a			NALPHA: 
8c8a b2				OR	D		;Add hi nibble back 
8c8b c9				RET			; 
8c8c			 
8c8c			 
8c8c			; 
8c8c			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8c8c			; Since the routines get_byte and therefore get_nibble are called, only valid 
8c8c			; characters (0-9a-f) are accepted. 
8c8c			; 
