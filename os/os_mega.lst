69a0			; **********************************************************************  
69a0			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
69a0			; **********************************************************************  
69a0			;  
69a0			; **  Written as a Small Computer Monitor App  
69a0			; **  www.scc.me.uk  
69a0			;  
69a0			; History  
69a0			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
69a0			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
69a0			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
69a0			;  
69a0			; **********************************************************************  
69a0			;  
69a0			; This program is an example of one of the methods of interfacing an   
69a0			; alphanumeric LCD module.   
69a0			;  
69a0			; In this example the display is connected to either a Z80 PIO or a   
69a0			; simple 8-bit output port.   
69a0			;  
69a0			; This interfacing method uses 4-bit data mode and uses time delays  
69a0			; rather than polling the display's ready status. As a result the   
69a0			; interface only requires 6 simple output lines:  
69a0			;   Output bit 0 = not used  
69a0			;   Output bit 1 = not used  
69a0			;   Output bit 2 = RS         High = data, Low = instruction  
69a0			;   Output bit 3 = E          Active high  
69a0			;   Output bit 4 = DB4  
69a0			;   Output bit 5 = DB5  
69a0			;   Output bit 6 = DB6  
69a0			;   Output bit 7 = DB7  
69a0			; Display's R/W is connected to 0v so it is always in write mode  
69a0			;  
69a0			; This set up should work with any system supporting the RC2014 bus  
69a0			  
69a0			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
69a0			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
69a0			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
69a0			;  
69a0			; **********************************************************************  
69a0			  
69a0			; Additonal for 4x40. E1 and E2 instead of just E   
69a0			; TODO swipe vidout signal on port a to activate E2  
69a0			  
69a0			; **********************************************************************  
69a0			; **  Constants  
69a0			; **********************************************************************  
69a0			; LCD constants required by LCD support module  
69a0			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
69a0			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
69a0			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
69a0			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
69a0			; TODO Decide which E is being set  
69a0			kLCDWidth:  EQU display_cols             ;Width in characters  
69a0			  
69a0			; **********************************************************************  
69a0			; **  Code library usage  
69a0			; **********************************************************************  
69a0			  
69a0			; send character to current cursor position  
69a0			; wraps and/or scrolls screen automatically  
69a0			  
69a0			  
69a0			  
69a0			lcd_init:  
69a0			  
69a0			; SCMonAPI functions used  
69a0			  
69a0			; Alphanumeric LCD functions used  
69a0			; no need to specify specific functions for this module  
69a0			  
69a0 3e cf		            LD   A, 11001111b  
69a2 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
69a4 3e 00		            LD   A, 00000000b  
69a6 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
69a8			  
69a8			; Initialise alphanumeric LCD module  
69a8 3e 00				ld a, 0  
69aa 32 fb fa				ld (display_lcde1e2), a  
69ad cd 2e 6a		            CALL fLCD_Init      ;Initialise LCD module  
69b0 3e 01				ld a, 1  
69b2 32 fb fa				ld (display_lcde1e2), a  
69b5 cd 2e 6a		            CALL fLCD_Init      ;Initialise LCD module  
69b8			  
69b8 c9				ret  
69b9			  
69b9			;  
69b9			;;  
69b9			; lcd functions  
69b9			;  
69b9			;  
69b9			  
69b9			; what is at cursor position   
69b9			  
69b9			;get_cursor:	ld de, (cursor_row)   ;  row + col  
69b9			;		call curptr  
69b9			;		ret  
69b9			  
69b9			  
69b9			; take current custor pos in de (d=row,e=col) and return a pointer to the frame buffer  
69b9			  
69b9			curptr:  
69b9 c5				push bc  
69ba 21 e1 fc			ld hl, display_fb0  
69bd			cpr:	  
69bd				; loop for cursor whole row  
69bd 0e 28			ld c, display_cols  
69bf 23			cpr1:	inc hl  
69c0 0d				dec c  
69c1 20 fc			jr nz, cpr1  
69c3 05				dec b  
69c4 20 f7			jr nz, cpr  
69c6			  
69c6				; add col	  
69c6			  
69c6 23			cpr2:	inc hl  
69c7 1d				dec e  
69c8 20 fc			jr nz, cpr2  
69ca			  
69ca c1				pop bc  
69cb c9				ret  
69cc				  
69cc			  
69cc			  
69cc			  
69cc			  
69cc			; write the frame buffer given in hl to hardware   
69cc 22 f9 fa		write_display: ld (display_write_tmp), hl 	   
69cf 3e 00			ld a, kLCD_Line1  
69d1 cd db 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69d4 06 28			ld b, display_cols  
69d6 ed 5b f9 fa		ld de, (display_write_tmp)  
69da cd 26 6a			call write_len_string  
69dd				  
69dd				  
69dd 2a f9 fa			ld hl, (display_write_tmp)  
69e0 11 28 00			ld de, display_cols  
69e3 19				add hl,de  
69e4 22 f9 fa			ld (display_write_tmp),hl  
69e7			  
69e7				  
69e7 3e 28			ld a, kLCD_Line2  
69e9 cd db 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69ec 06 28			ld b, display_cols  
69ee ed 5b f9 fa		ld de, (display_write_tmp)  
69f2 cd 26 6a			call write_len_string  
69f5				  
69f5 2a f9 fa			ld hl, (display_write_tmp)  
69f8 11 28 00			ld de, display_cols  
69fb 19				add hl,de  
69fc 22 f9 fa			ld (display_write_tmp),hl  
69ff			  
69ff				  
69ff 3e 50			ld a, kLCD_Line3  
6a01 cd db 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
6a04 06 28			ld b, display_cols  
6a06 ed 5b f9 fa		ld de, (display_write_tmp)  
6a0a cd 26 6a			call write_len_string  
6a0d				  
6a0d 2a f9 fa			ld hl, (display_write_tmp)  
6a10 11 28 00			ld de, display_cols  
6a13 19				add hl,de  
6a14 22 f9 fa			ld (display_write_tmp),hl  
6a17			  
6a17				  
6a17 3e 78			ld a, kLCD_Line4  
6a19 cd db 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
6a1c 06 28			ld b, display_cols  
6a1e ed 5b f9 fa		ld de, (display_write_tmp)  
6a22 cd 26 6a			call write_len_string  
6a25 c9					ret  
6a26				  
6a26				; write out a fixed length string given in b from de  
6a26			  
6a26 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
6a27 cd 93 6a		            CALL fLCD_Data      ;Write character to display  
6a2a 13				inc de  
6a2b 10 f9			djnz write_len_string  
6a2d c9				ret  
