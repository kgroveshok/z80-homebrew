110a			;      call  malloc            ; Allocates 0x9004 
110a			; 
110a			;      ld    HL, 12 
110a			;      call  malloc            ; Allocates 0x9014 
110a			; 
110a			;      ld    HL, 12 
110a			;      call  malloc            ; Allocates 0x9024 
