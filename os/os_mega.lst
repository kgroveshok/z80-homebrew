0cda			;;;; int maths 
0cda			 
0cda			; https://map.grauw.nl/articles/mult_div_shifts.php 
0cda			; Divide 16-bit values (with 16-bit result) 
0cda			; In: Divide BC by divider DE 
0cda			; Out: BC = result, HL = rest 
0cda			; 
0cda			Div16: 
0cda 21 00 00		    ld hl,0 
0cdd 78			    ld a,b 
0cde 06 08		    ld b,8 
0ce0			Div16_Loop1: 
0ce0 17			    rla 
0ce1 ed 6a		    adc hl,hl 
0ce3 ed 52		    sbc hl,de 
0ce5 30 01		    jr nc,Div16_NoAdd1 
0ce7 19			    add hl,de 
0ce8			Div16_NoAdd1: 
0ce8 10 f6		    djnz Div16_Loop1 
0cea 17			    rla 
0ceb 2f			    cpl 
0cec 47			    ld b,a 
0ced 79			    ld a,c 
0cee 48			    ld c,b 
0cef 06 08		    ld b,8 
0cf1			Div16_Loop2: 
0cf1 17			    rla 
0cf2 ed 6a		    adc hl,hl 
0cf4 ed 52		    sbc hl,de 
0cf6 30 01		    jr nc,Div16_NoAdd2 
0cf8 19			    add hl,de 
0cf9			Div16_NoAdd2: 
0cf9 10 f6		    djnz Div16_Loop2 
0cfb 17			    rla 
0cfc 2f			    cpl 
0cfd 41			    ld b,c 
0cfe 4f			    ld c,a 
0cff c9			ret 
0d00			 
0d00			 
0d00			;http://z80-heaven.wikidot.com/math 
0d00			; 
0d00			;Inputs: 
0d00			;     DE and A are factors 
0d00			;Outputs: 
0d00			;     A is not changed 
0d00			;     B is 0 
0d00			;     C is not changed 
0d00			;     DE is not changed 
0d00			;     HL is the product 
0d00			;Time: 
0d00			;     342+6x 
0d00			; 
0d00			Mult16: 
0d00			 
0d00 06 08		     ld b,8          ;7           7 
0d02 21 00 00		     ld hl,0         ;10         10 
0d05 29			       add hl,hl     ;11*8       88 
0d06 07			       rlca          ;4*8        32 
0d07 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0d09 19			         add hl,de   ;--         -- 
0d0a 10 f9		       djnz $-5      ;13*7+8     99 
0d0c c9			ret 
0d0d			 
0d0d			; 
0d0d			; Square root of 16-bit value 
0d0d			; In:  HL = value 
0d0d			; Out:  D = result (rounded down) 
0d0d			; 
0d0d			;Sqr16: 
0d0d			;    ld de,#0040 
0d0d			;    ld a,l 
0d0d			;    ld l,h 
0d0d			;    ld h,d 
0d0d			;    or a 
0d0d			;    ld b,8 
0d0d			;Sqr16_Loop: 
0d0d			;    sbc hl,de 
0d0d			;    jr nc,Sqr16_Skip 
0d0d			;    add hl,de 
0d0d			;Sqr16_Skip: 
0d0d			;    ccf 
0d0d			;    rl d 
0d0d			;    add a,a 
0d0d			;    adc hl,hl 
0d0d			;    add a,a 
0d0d			;    adc hl,hl 
0d0d			;    djnz Sqr16_Loop 
0d0d			;    ret 
0d0d			; 
0d0d			; 
0d0d			; Divide 8-bit values 
0d0d			; In: Divide E by divider C 
0d0d			; Out: A = result, B = rest 
0d0d			; 
0d0d			Div8: 
0d0d af			    xor a 
0d0e 06 08		    ld b,8 
0d10			Div8_Loop: 
0d10 cb 13		    rl e 
0d12 17			    rla 
0d13 91			    sub c 
0d14 30 01		    jr nc,Div8_NoAdd 
0d16 81			    add a,c 
0d17			Div8_NoAdd: 
0d17 10 f7		    djnz Div8_Loop 
0d19 47			    ld b,a 
0d1a 7b			    ld a,e 
0d1b 17			    rla 
0d1c 2f			    cpl 
0d1d c9			    ret 
0d1e			 
0d1e			; 
0d1e			; Multiply 8-bit value with a 16-bit value (unrolled) 
