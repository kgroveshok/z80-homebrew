1876			; kernel to the forth OS 
1876			 
1876			DS_TYPE_STR: equ 1     ; string type 
1876			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
1876			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
1876			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
1876			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
1876			 
1876			FORTH_PARSEV1: equ 0 
1876			FORTH_PARSEV2: equ 0 
1876			FORTH_PARSEV3: equ 0 
1876			FORTH_PARSEV4: equ 0 
1876			FORTH_PARSEV5: equ 0 
1876			FORTH_PARSEV6: equ 1 
