12e0			 
12e0			.contheap: 
12e0				ld hl, heap_start 
12e0			 
12e0			.startalloc: 
12e0			 
12e0					if DEBUG_FORTH_MALLOC_INT 
12e0						DMARK "mym" 
12e0						CALLMONITOR 
12e0					endif 
12e0			.findblock: 
12e0					if DEBUG_FORTH_MALLOC_INT 
12e0						DMARK "mmf" 
12e0						CALLMONITOR 
12e0					endif 
12e0			 
12e0				ld a,(hl)  
12e0				; if byte is zero then clear to use 
12e0			 
12e0			;	cp 0 
12e0				or a 
12e0				jr z, .foundemptyblock 
12e0			 
12e0				; if byte is not clear 
12e0				;     then byte is offset to next block 
12e0			 
12e0				inc hl 
12e0				ld a, (hl) ; get size 
12e0			.nextblock:	inc hl 
12e0					ld e, (hl) 
12e0					inc hl 
12e0					ld d, (hl) 
12e0					ex de, hl 
12e0			;	inc hl  ; move past the store space 
12e0			;	inc hl  ; move past zero index  
12e0			 
12e0				; TODO detect no more space 
12e0			 
