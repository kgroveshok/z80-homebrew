73be			; **********************************************************************  
73be			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
73be			; **********************************************************************  
73be			;  
73be			; **  Written as a Small Computer Monitor App  
73be			; **  www.scc.me.uk  
73be			;  
73be			; History  
73be			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
73be			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
73be			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
73be			;  
73be			; **********************************************************************  
73be			;  
73be			; This program is an example of one of the methods of interfacing an   
73be			; alphanumeric LCD module.   
73be			;  
73be			; In this example the display is connected to either a Z80 PIO or a   
73be			; simple 8-bit output port.   
73be			;  
73be			; This interfacing method uses 4-bit data mode and uses time delays  
73be			; rather than polling the display's ready status. As a result the   
73be			; interface only requires 6 simple output lines:  
73be			;   Output bit 0 = not used  
73be			;   Output bit 1 = not used  
73be			;   Output bit 2 = RS         High = data, Low = instruction  
73be			;   Output bit 3 = E          Active high  
73be			;   Output bit 4 = DB4  
73be			;   Output bit 5 = DB5  
73be			;   Output bit 6 = DB6  
73be			;   Output bit 7 = DB7  
73be			; Display's R/W is connected to 0v so it is always in write mode  
73be			;  
73be			; This set up should work with any system supporting the RC2014 bus  
73be			  
73be			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
73be			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
73be			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
73be			;  
73be			; **********************************************************************  
73be			  
73be			; Additonal for 4x40. E1 and E2 instead of just E   
73be			; TODO swipe vidout signal on port a to activate E2  
73be			  
73be			; **********************************************************************  
73be			; **  Constants  
73be			; **********************************************************************  
73be			; LCD constants required by LCD support module  
73be			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
73be			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
73be			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
73be			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
73be			; TODO Decide which E is being set  
73be			kLCDWidth:  EQU display_cols             ;Width in characters  
73be			  
73be			; **********************************************************************  
73be			; **  Code library usage  
73be			; **********************************************************************  
73be			  
73be			; send character to current cursor position  
73be			; wraps and/or scrolls screen automatically  
73be			  
73be			  
73be			  
73be			lcd_init:  
73be			  
73be			; SCMonAPI functions used  
73be			  
73be			; Alphanumeric LCD functions used  
73be			; no need to specify specific functions for this module  
73be			  
73be 3e cf		            LD   A, 11001111b  
73c0 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
73c2 3e 00		            LD   A, 00000000b  
73c4 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
73c6			  
73c6			; Initialise alphanumeric LCD module  
73c6 3e 00				ld a, 0  
73c8 32 f9 fa				ld (display_lcde1e2), a  
73cb cd 4c 74		            CALL fLCD_Init      ;Initialise LCD module  
73ce 3e 01				ld a, 1  
73d0 32 f9 fa				ld (display_lcde1e2), a  
73d3 cd 4c 74		            CALL fLCD_Init      ;Initialise LCD module  
73d6			  
73d6 c9				ret  
73d7			  
73d7			;  
73d7			;;  
73d7			; lcd functions  
73d7			;  
73d7			;  
73d7			  
73d7			; what is at cursor position   
73d7			  
73d7			;get_cursor:	ld de, (cursor_row)   ;  row + col  
73d7			;		call curptr  
73d7			;		ret  
73d7			  
73d7			  
73d7			; take current custor pos in de (d=row,e=col) and return a pointer to the frame buffer  
73d7			  
73d7			curptr:  
73d7 c5				push bc  
73d8 21 df fc			ld hl, display_fb0  
73db			cpr:	  
73db				; loop for cursor whole row  
73db 0e 28			ld c, display_cols  
73dd 23			cpr1:	inc hl  
73de 0d				dec c  
73df 20 fc			jr nz, cpr1  
73e1 05				dec b  
73e2 20 f7			jr nz, cpr  
73e4			  
73e4				; add col	  
73e4			  
73e4 23			cpr2:	inc hl  
73e5 1d				dec e  
73e6 20 fc			jr nz, cpr2  
73e8			  
73e8 c1				pop bc  
73e9 c9				ret  
73ea				  
73ea			  
73ea			  
73ea			  
73ea			  
73ea			; write the frame buffer given in hl to hardware   
73ea 22 f7 fa		write_display: ld (display_write_tmp), hl 	   
73ed 3e 00			ld a, kLCD_Line1  
73ef cd f9 74		            CALL fLCD_Pos       ;Position cursor to location in A  
73f2 06 28			ld b, display_cols  
73f4 ed 5b f7 fa		ld de, (display_write_tmp)  
73f8 cd 44 74			call write_len_string  
73fb				  
73fb				  
73fb 2a f7 fa			ld hl, (display_write_tmp)  
73fe 11 28 00			ld de, display_cols  
7401 19				add hl,de  
7402 22 f7 fa			ld (display_write_tmp),hl  
7405			  
7405				  
7405 3e 28			ld a, kLCD_Line2  
7407 cd f9 74		            CALL fLCD_Pos       ;Position cursor to location in A  
740a 06 28			ld b, display_cols  
740c ed 5b f7 fa		ld de, (display_write_tmp)  
7410 cd 44 74			call write_len_string  
7413				  
7413 2a f7 fa			ld hl, (display_write_tmp)  
7416 11 28 00			ld de, display_cols  
7419 19				add hl,de  
741a 22 f7 fa			ld (display_write_tmp),hl  
741d			  
741d				  
741d 3e 50			ld a, kLCD_Line3  
741f cd f9 74		            CALL fLCD_Pos       ;Position cursor to location in A  
7422 06 28			ld b, display_cols  
7424 ed 5b f7 fa		ld de, (display_write_tmp)  
7428 cd 44 74			call write_len_string  
742b				  
742b 2a f7 fa			ld hl, (display_write_tmp)  
742e 11 28 00			ld de, display_cols  
7431 19				add hl,de  
