0e99			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
0e99			 
0e99			 
0e99			;Converts an ASCII string to an unsigned 16-bit integer 
0e99			;Quits when it reaches a non-decimal digit 
0e99			 
0e99			string_to_uint16: 
0e99			atoui_16: 
0e99			;Input: 
0e99			;     DE points to the string 
0e99			;Outputs: 
0e99			;     HL is the result 
0e99			;     A is the 8-bit value of the number 
0e99			;     DE points to the byte after the number 
0e99			;Destroys: 
0e99			;     BC 
0e99			;       if the string is non-empty, BC is HL/10 
0e99			;Size:  24 bytes 
0e99			;Speed: 42+d(104+{0,9}) 
0e99			;       d is the number of digits in the number 
0e99			;       max is 640 cycles for a 5 digit number 
0e99			;Assuming no leading zeros: 
0e99			;1 digit:  146cc 
0e99			;2 digit:  250cc 
0e99			;3 digit:  354cc or 363cc (avg: 354.126cc) 
0e99			;4 digit:  458cc or 467cc (avg: 458.27cc) 
0e99			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
0e99			;avg: 544.81158447265625cc (544+13297/16384) 
0e99			;=============================================================== 
0e99 21 00 00		  ld hl,0 
0e9c			.u16a: 
0e9c 1a			  ld a,(de) 
0e9d d6 30		  sub 30h 
0e9f fe 0a		  cp 10 
0ea1 d0			  ret nc 
0ea2 13			  inc de 
0ea3 44			  ld b,h 
0ea4 4d			  ld c,l 
0ea5 29			  add hl,hl 
0ea6 29			  add hl,hl 
0ea7 09			  add hl,bc 
0ea8 29			  add hl,hl 
0ea9 85			  add a,l 
0eaa 6f			  ld l,a 
0eab 30 ef		  jr nc,.u16a 
0ead 24			  inc h 
0eae c3 9c 0e		  jp .u16a 
