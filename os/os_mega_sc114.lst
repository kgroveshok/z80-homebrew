9e53			.HEAP: 
9e53			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9e53 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e54 92 9e			dw .EXEC            
9e56 05				db 4 + 1 
9e57 .. 00			db "HEAP",0              
9e5c				endm 
# End of macro CWHEAD
9e5c			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9e5c			; | | u1 - Current number of bytes in the heap 
9e5c			; | | u2 - Remaining bytes left on the heap 
9e5c			; | |  
9e5c			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9e5c			 
9e5c			 
9e5c				if DEBUG_FORTH_WORDS_KEY 
9e5c					DMARK "HEP" 
9e5c f5				push af  
9e5d 3a 71 9e			ld a, (.dmark)  
9e60 32 5e ee			ld (debug_mark),a  
9e63 3a 72 9e			ld a, (.dmark+1)  
9e66 32 5f ee			ld (debug_mark+1),a  
9e69 3a 73 9e			ld a, (.dmark+2)  
9e6c 32 60 ee			ld (debug_mark+2),a  
9e6f 18 03			jr .pastdmark  
9e71 ..			.dmark: db "HEP"  
9e74 f1			.pastdmark: pop af  
9e75			endm  
# End of macro DMARK
9e75					CALLMONITOR 
9e75				if BASE_CPM=1  
9e75					call debug_vector  
9e75				endif  
9e75				if BASE_KEV=1  
9e75					rst 8  
9e75				endif  
9e75				endm  
# End of macro CALLMONITOR
9e75				endif 
