0de6			; Get 2 ASCII characters as hex byte from pointer in hl 
0de6			 
0de6			BYTERD: 
0de6 16 00			LD	D,00h		;Set up 
0de8 cd f0 0d			CALL	HEXCON		;Get byte and convert to hex 
0deb 87				ADD	A,A		;First nibble so 
0dec 87				ADD	A,A		;multiply by 16 
0ded 87				ADD	A,A		; 
0dee 87				ADD	A,A		; 
0def 57				LD	D,A		;Save hi nibble in D 
0df0			HEXCON: 
0df0 7e				ld a, (hl)		;Get next chr 
0df1 23				inc hl 
0df2 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
0df4 fe 0a			CP	00Ah		;Is it 0-9 ? 
0df6 38 02			JR	C,NALPHA	;If so miss next bit 
0df8 d6 07			SUB	007h		;Else convert alpha 
0dfa			NALPHA: 
0dfa b2				OR	D		;Add hi nibble back 
0dfb c9				RET			; 
