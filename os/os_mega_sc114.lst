8a37			; https://plutiedev.com/z80-add-8bit-to-16bit 
8a37			 
8a37			addatohl: 
8a37 85			    add   a, l    ; A = A+L 
8a38 6f			    ld    l, a    ; L = A+L 
8a39 8c			    adc   a, h    ; A = A+L+H+carry 
8a3a 95			    sub   l       ; A = H+carry 
8a3b 67			    ld    h, a    ; H = H+carry 
8a3c c9			ret 
8a3d			 
8a3d			addatode: 
8a3d 83			    add   a, e    ; A = A+L 
8a3e 5f			    ld    e, a    ; L = A+L 
8a3f 8a			    adc   a, d    ; A = A+L+H+carry 
8a40 93			    sub   e       ; A = H+carry 
8a41 57			    ld    d, a    ; H = H+carry 
8a42 c9			ret 
8a43			 
8a43			 
8a43			addatobc: 
8a43 81			    add   a, c    ; A = A+L 
8a44 4f			    ld    c, a    ; L = A+L 
8a45 88			    adc   a, b    ; A = A+L+H+carry 
8a46 91			    sub   c       ; A = H+carry 
8a47 47			    ld    b, a    ; H = H+carry 
8a48 c9			ret 
