99a3			; forth parser 
99a3			 
99a3			; My forth kernel 
99a3			include "forth_kernel.asm" 
99a3			; 
99a3			; kernel to the forth OS 
99a3			 
99a3			DS_TYPE_STR: equ 1     ; string type 
99a3			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
99a3			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
99a3			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
99a3			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
99a3			 
99a3			FORTH_PARSEV1: equ 0 
99a3			FORTH_PARSEV2: equ 0 
99a3			FORTH_PARSEV3: equ 0 
99a3			FORTH_PARSEV4: equ 0 
99a3			FORTH_PARSEV5: equ 0 
99a3			FORTH_PARSEV6: equ 1 
99a3			 
99a3			;if FORTH_PARSEV5 
99a3			;	FORTH_END_BUFFER: equ 0 
99a3			;else 
99a3			FORTH_END_BUFFER: equ 127 
99a3			;endif 
99a3			 
99a3			FORTH_TRUE: equ 1 
99a3			FORTH_FALSE: equ 0 
99a3			 
99a3			if FORTH_PARSEV4 
99a3			include "forth_stackops.asm" 
99a3			endif 
99a3			 
99a3			if FORTH_PARSEV5 
99a3			include "forth_stackopsv5.asm" 
99a3			endif 
99a3			 
99a3			if FORTH_PARSEV6 
99a3			include "forth_stackopsv5.asm" 
99a3			 
99a3			; Stack operations for v5 parser on wards 
99a3			; * DATA stack 
99a3			; * LOOP stack 
99a3			; * RETURN stack 
99a3			 
99a3			 
99a3			 
99a3			FORTH_CHK_DSP_UNDER: macro 
99a3				push hl 
99a3				push de 
99a3				ld hl,(cli_data_sp) 
99a3				ld de, cli_data_stack 
99a3				call cmp16 
99a3				jp c, fault_dsp_under 
99a3				pop de 
99a3				pop hl 
99a3				endm 
99a3			 
99a3			 
99a3			FORTH_CHK_RSP_UNDER: macro 
99a3				push hl 
99a3				push de 
99a3				ld hl,(cli_ret_sp) 
99a3				ld de, cli_ret_stack 
99a3				call cmp16 
99a3				jp c, fault_rsp_under 
99a3				pop de 
99a3				pop hl 
99a3				endm 
99a3			 
99a3			FORTH_CHK_LOOP_UNDER: macro 
99a3				push hl 
99a3				push de 
99a3				ld hl,(cli_loop_sp) 
99a3				ld de, cli_loop_stack 
99a3				call cmp16 
99a3				jp c, fault_loop_under 
99a3				pop de 
99a3				pop hl 
99a3				endm 
99a3			 
99a3			FORTH_ERR_TOS_NOTSTR: macro 
99a3				; TOSO might need more for checks when used 
99a3				push af 
99a3				ld a,(hl) 
99a3				cp DS_TYPE_STR 
99a3				jp nz, type_faultn   
99a3				pop af 
99a3				endm 
99a3			 
99a3			FORTH_ERR_TOS_NOTNUM: macro 
99a3				push af 
99a3				ld a,(hl) 
99a3				cp DS_TYPE_INUM 
99a3				jp nz, type_faultn   
99a3				pop af 
99a3				endm 
99a3			 
99a3			 
99a3			; increase data stack pointer and save hl to it 
99a3				 
99a3			FORTH_DSP_NEXT: macro 
99a3				call macro_forth_dsp_next 
99a3				endm 
99a3			 
99a3			 
99a3			macro_forth_dsp_next: 
99a3				if DEBUG_FORTH_STACK_GUARD 
99a3 cd 1a d2				call check_stacks 
99a6				endif 
99a6 e5				push hl 
99a7 d5				push de 
99a8 eb				ex de,hl 
99a9 2a ca e9			ld hl,(cli_data_sp) 
99ac 23				inc hl 
99ad 23				inc hl 
99ae			 
99ae			; PARSEV5 
99ae 23				inc hl 
99af 22 ca e9			ld (cli_data_sp),hl 
99b2 73				ld (hl), e 
99b3 23				inc hl 
99b4 72				ld (hl), d 
99b5 d1				pop de 
99b6 e1				pop hl 
99b7				if DEBUG_FORTH_STACK_GUARD 
99b7 cd 1a d2				call check_stacks 
99ba				endif 
99ba c9				ret 
99bb			 
99bb			 
99bb			; increase ret stack pointer and save hl to it 
99bb				 
99bb			FORTH_RSP_NEXT: macro 
99bb				call macro_forth_rsp_next 
99bb				endm 
99bb			 
99bb			macro_forth_rsp_next: 
99bb				if DEBUG_FORTH_STACK_GUARD 
99bb cd 1a d2				call check_stacks 
99be				endif 
99be e5				push hl 
99bf d5				push de 
99c0 eb				ex de,hl 
99c1 2a ce e9			ld hl,(cli_ret_sp) 
99c4 23				inc hl 
99c5 23				inc hl 
99c6 22 ce e9			ld (cli_ret_sp),hl 
