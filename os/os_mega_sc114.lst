bff2			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bff2			; | | Set to zero to disable devices. 
bff2					if DEBUG_FORTH_WORDS_KEY 
bff2						DMARK "CDV" 
bff2						CALLMONITOR 
bff2					endif 
bff2			 
bff2					; disable se storage bank selection 
bff2			 
bff2					ld a, SPI_CE_HIGH		; ce high 
bff2					ld (spi_device), a 
bff2			 
bff2					; get bank 
bff2			 
bff2					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bff2			 
bff2			;		push hl 
bff2			 
bff2					; destroy value TOS 
bff2			 
bff2					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bff2			 
bff2					; one value on hl get other one back 
bff2			 
bff2			;		pop hl 
bff2			 
bff2					; active low 
bff2			 
bff2					ld c, 255 
bff2			 
bff2					ld a, l 
bff2					if DEBUG_FORTH_WORDS 
bff2						DMARK "CDV" 
bff2						CALLMONITOR 
bff2					endif 
bff2			;		cp 0 
bff2					or a 
bff2					jr z, .cset 
bff2					cp 1 
bff2					jr nz, .c2 
bff2					res 0, c 
bff2			.c2:		cp 2 
bff2					jr nz, .c3 
bff2					res 1, c 
bff2			.c3:		cp 3 
bff2					jr nz, .c4 
bff2					res 2, c 
bff2			.c4:		cp 4 
bff2					jr nz, .c5 
bff2					res 3, c 
bff2			.c5:		cp 5 
bff2					jr nz, .c6 
bff2					res 4, c 
bff2			.c6:		cp 6 
bff2					jr nz, .c7 
bff2					res 5, c 
bff2			.c7:		cp 7 
bff2					jr nz, .c8 
bff2					res 6, c 
bff2			.c8:		cp 8 
bff2					jr nz, .cset 
bff2					res 7, c 
bff2			.cset:		ld a, c 
bff2					ld (spi_cartdev),a 
bff2			 
bff2					if DEBUG_FORTH_WORDS 
bff2						DMARK "CD2" 
bff2						CALLMONITOR 
bff2					endif 
bff2			 
bff2					; set default SPI clk pulse time as 10ms for CARTDEV use 
bff2			 
bff2					ld a, $0a 
bff2					ld (spi_clktime), a 
bff2					NEXTW 
bff2			endif 
bff2			 
bff2			.ENDDEVICE: 
