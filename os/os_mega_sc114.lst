98dd			; 
98dd			; kernel to the forth OS 
98dd			 
98dd			DS_TYPE_STR: equ 1     ; string type 
98dd			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
98dd			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
98dd			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
98dd			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
98dd			 
98dd			FORTH_PARSEV1: equ 0 
98dd			FORTH_PARSEV2: equ 0 
98dd			FORTH_PARSEV3: equ 0 
98dd			FORTH_PARSEV4: equ 0 
98dd			FORTH_PARSEV5: equ 0 
98dd			FORTH_PARSEV6: equ 1 
98dd			 
98dd			;if FORTH_PARSEV5 
98dd			;	FORTH_END_BUFFER: equ 0 
98dd			;else 
98dd			FORTH_END_BUFFER: equ 127 
98dd			;endif 
98dd			 
98dd			FORTH_TRUE: equ 1 
98dd			FORTH_FALSE: equ 0 
