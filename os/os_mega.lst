63ce			 
63ce				ex de, hl 
63ce				call ishlzero 
63ce			;	ld a,e 
63ce			;	add d 
63ce			;	cp 0    ; any left to do? 
63ce				ex de, hl 
63ce				jp nz, .start1 
63ce				jr .startupend 
63ce			 
63ce			.startupend1: pop hl 
63ce			.startupend: 
63ce			 
63ce				call clear_display 
63ce				call update_display 
63ce				ret 
