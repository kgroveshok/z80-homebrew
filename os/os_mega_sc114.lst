8ef0 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8ef3 39			      add   HL, SP 
8ef4 f9			      ld    SP, HL 
8ef5 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
8ef9 dd 39		      add   IX, SP 
