0fd5 cb 07		                rlc     a 
0fd7 cb 07		                rlc     a 
0fd9 cb 07		                rlc     a 
0fdb cb 07		                rlc     a 
0fdd 47			                ld      b, a            ; Save upper four bits 
0fde 7e					ld a,(hl) 
0fdf cd f7 0f		                call    nibble2val      ; Get lower nibble 
0fe2 b0			                or      b               ; Combine both nibbles 
0fe3 c1			                pop     bc              ; Restore B (and C) 
0fe4 c9			                ret 
