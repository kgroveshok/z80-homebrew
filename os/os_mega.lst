0dcd			subafromhl: 
0dcd			   ; If A=0 do nothing 
0dcd			    ; Otherwise flip A's sign. Since 
0dcd			    ; the upper byte becomes -1, also 
0dcd			    ; substract 1 from H. 
0dcd ed 44		    neg 
0dcf ca d8 0d		    jp    z, Skip 
0dd2 25			    dec   h 
0dd3			     
0dd3			    ; Now add the low byte as usual 
0dd3			    ; Two's complement takes care of 
0dd3			    ; ensuring the result is correct 
0dd3 85			    add   a, l 
0dd4 6f			    ld    l, a 
0dd5 8c			    adc   a, h 
0dd6 95			    sub   l 
0dd7 67			    ld    h, a 
0dd8			Skip: 
0dd8 c9				ret 
