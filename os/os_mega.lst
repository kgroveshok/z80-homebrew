0297				include "firmware_seeprom.asm"  
0297			; 
0297			; persisent storage interface via microchip serial eeprom 
0297			 
0297			; port a pio 2 
0297			; pa 7 - si 
0297			; pa 6 - sclk  
0297			; pa 5 - so 
0297			; pa 4 - cs 
0297			; pa 3 - cs 
0297			; pa 2 - cs 
0297			; pa 1 - cs 
0297			; pa 0 - cs 
0297			; 
0297			; TODO get block 
0297			; TODO save block 
0297			; TODO load file 
0297			; TODO save file 
0297			; TODO get dir  
0297			 
0297			;  
0297			storage_adata: equ Device_C    ; device c port a - onboard storage 
0297			storage_actl: equ Device_C+2     ; device c port a 
0297			storage_bdata: equ Device_C+1    ; device c port b - ext storage cart 
0297			storage_bctl: equ Device_C+3     ; device c port b 
0297			 
0297			 
0297			; TODO move these to hardware driver file 
0297			 
0297			;STORE_BLOCK_PHY:   equ 64    ; physical block size on storage   64byte on 256k eeprom 
0297			;STORE_DEVICE_MAXBLOCKS:  equ  512 ; how many blocks are there on this storage device 
0297			; storage bank file system format 
0297			; 
0297			; first page of bank: 
0297			; 	addr 0 - status check 
0297			;       addr 1 - write protect flag 
0297			;       addr 2 - zero if all data is held on this device. >0 - next device number (not used right now) 
0297			;       addr 3 - last file id (to save on scanning for spare file id). or could have bit mask of file ids in use????  
0297			;         TODO see if scanning whole of for available next file id is fast enough 
0297			;	addr 4 > zero term string of bank label 
0297			; 
0297			;        
0297			;  
0297			; first page of any file: 
0297			;      byte 0 - file id  
0297			;      byte 1-17 - fixed file name  
0297			;      byte 18-end of page - extra meta data tba (date? description? keywords?) 
0297			; 
0297			; other pages of any file: 
0297			;      byte 0 - file id 
0297			;      byte 1> - file data 
0297			; 
0297			; TODO depending on how long it takes to load a file in if scanning the whole bank for the file id, could speed it up by having last file page flag??? high bit? that would max 127 files 
0297			;  
0297			; TODO need a bank format which places a 0 in each of the first byte of every page and updates the meta in page 0 
0297			 
0297			 
0297			;storage_so_bit: 5 
0297			;storage_si_bit: 7 
0297			;storage_sclk_bit: 6 
0297			  
0297			 
0297			; init storage pio 
0297			 
0297			storage_init: 
0297			 
0297			 
0297					; set default SPI clk pulse time as disabled 
0297			 
0297 3e 00				ld a, 0 
0299 32 8f f9				ld (spi_clktime), a 
029c			 
029c					; init hardware 
029c			 
029c 3e cf		            LD   A, 11001111b 
029e d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
02a0 3e 00		            LD   A, 00000000b 
02a2 cb f7			set SPI_DO,a 
02a4			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
02a4 d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
02a6			 
02a6 3e cf		            LD   A, 11001111b 
02a8 d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
02aa 3e 00		            LD   A, 00000000b 
02ac d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
02ae			 
02ae				; set all external spi devices off  
02ae 3e ff			ld a, 255 
02b0 32 8b f9			ld (spi_device), a 
02b3 32 8e f9			ld (spi_cartdev), a 
02b6			 
02b6					; ensure the spi bus is in a default stable state 
02b6 cd 3e 01				call se_stable_spi 
02b9			 
02b9			; TODO scan spi bus and gather which storage banks are present 
02b9			 
02b9			; populate store_bank_active  
02b9			; for each ce line activate and attempt to write first byte of bank and read back 
02b9			; if zero is returned then bank is empty 
02b9			;   
02b9			; 
02b9			 
02b9					; init file extent cache to save on slow reads 
02b9			 
02b9			;	ld hl, store_filecache 
02b9			;	ld de, 0 
02b9			;	ld hl,(de)	 
02b9			 
02b9			 
02b9 c9			    ret 
02ba			 
02ba			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
02ba			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
02ba			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
02ba			 
02ba			; INSTRUCTION SET 
02ba			; READ 0000 0011 Read data from memory array beginning at selected address 
02ba			; WRITE 0000 0010 Write data to memory array beginning at selected address 
02ba			; WREN 0000 0110 Set the write enable latch (enable write operations) 
02ba			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
02ba			; RDSR 0000 0101 Read STATUS register 
02ba			; WRSR 0000 0001 Write STATUS register 
02ba			; PE 0100 0010 Page Erase – erase one page in memory array 
02ba			; SE 1101 1000 Sector Erase – erase one sector in memory array 
02ba			; CE 1100 0111 Chip Erase – erase all sectors in memory array 
02ba			; RDID 1010 1011 Release from Deep power-down and read electronic signature 
02ba			 
02ba			; TODO send byte steam for page without setting the address for every single byte 
02ba			; TODO read byte  
02ba			 
02ba			; byte in a 
02ba			; address in hl  
02ba			se_writebyte: 
02ba			        
02ba			    ;   ld c, a 
02ba f5			        push af 
02bb e5			        push hl 
02bc			 
02bc			    ; initi write mode 
02bc			    ; 
02bc			    ;CS low 
02bc			 
02bc 3a 8c f9		       ld a,(spi_portbyte) 
02bf cd 63 02			call spi_ce_low 
02c2			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02c2 d3 80		       out (storage_adata),a 
02c4 32 8c f9		       ld (spi_portbyte), a 
02c7			 
02c7			    ;clock out wren instruction 
02c7			 
02c7 3e 06		    ld a, store_wren_ins 
02c9 cd 64 01		    call spi_send_byte  
02cc			 
02cc			    ;cs high to enable write latch 
02cc			 
02cc 3a 8c f9		       ld a,(spi_portbyte) 
02cf cd 52 02			call spi_ce_high 
02d2			;       set SPI_CE0,a           ; TODO pass the ce bank bit mask 
02d2 d3 80		       out (storage_adata),a 
02d4 32 8c f9		       ld (spi_portbyte), a 
02d7			 
02d7			;	nop 
02d7			    ; 
02d7			    ; intial write data 
02d7			    ; 
