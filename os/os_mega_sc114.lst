8f68				ld de, heap_end 
8f68				call cmp16 
8f68				pop hl 
8f68				jr nc, .nospace 
8f68			 
8f68				jr .findblock 
8f68			 
8f68			.nospace: ld hl, 0 
8f68				jp .exit 
8f68			 
8f68			 
8f68			.foundemptyblock:	 
8f68					if DEBUG_FORTH_MALLOC_INT 
8f68						DMARK "mme" 
8f68						CALLMONITOR 
8f68					endif 
8f68			 
8f68			; TODO has block enough space if reusing??? 
8f68			 
8f68				;  
8f68			 
8f68			; see if this block has been previously used 
8f68				inc hl 
8f68				ld a, (hl) 
