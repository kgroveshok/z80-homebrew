697b			; **********************************************************************  
697b			;  
697b			; This program is an example of one of the methods of interfacing an   
697b			; alphanumeric LCD module.   
697b			;  
697b			; In this example the display is connected to either a Z80 PIO or a   
697b			; simple 8-bit output port.   
697b			;  
697b			; This interfacing method uses 4-bit data mode and uses time delays  
697b			; rather than polling the display's ready status. As a result the   
697b			; interface only requires 6 simple output lines:  
697b			;   Output bit 0 = not used  
697b			;   Output bit 1 = not used  
697b			;   Output bit 2 = RS         High = data, Low = instruction  
697b			;   Output bit 3 = E          Active high  
697b			;   Output bit 4 = DB4  
697b			;   Output bit 5 = DB5  
697b			;   Output bit 6 = DB6  
697b			;   Output bit 7 = DB7  
697b			; Display's R/W is connected to 0v so it is always in write mode  
697b			;  
697b			; This set up should work with any system supporting the RC2014 bus  
697b			  
697b			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
697b			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
697b			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
697b			;  
697b			; **********************************************************************  
697b			  
697b			; Additonal for 4x40. E1 and E2 instead of just E   
697b			; TODO swipe vidout signal on port a to activate E2  
697b			  
697b			; **********************************************************************  
697b			; **  Constants  
697b			; **********************************************************************  
697b			; LCD constants required by LCD support module  
697b			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
697b			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
697b			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
697b			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
697b			; TODO Decide which E is being set  
697b			kLCDWidth:  EQU display_cols             ;Width in characters  
697b			  
697b			; **********************************************************************  
697b			; **  Code library usage  
697b			; **********************************************************************  
697b			  
697b			; send character to current cursor position  
697b			; wraps and/or scrolls screen automatically  
697b			  
697b			  
697b			  
697b			lcd_init:  
697b			  
697b			; SCMonAPI functions used  
697b			  
697b			; Alphanumeric LCD functions used  
697b			; no need to specify specific functions for this module  
697b			  
697b 3e cf		            LD   A, 11001111b  
697d d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
697f 3e 00		            LD   A, 00000000b  
6981 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6983			  
6983			; Initialise alphanumeric LCD module  
6983 3e 00				ld a, 0  
6985 32 fb fa				ld (display_lcde1e2), a  
6988 cd 09 6a		            CALL fLCD_Init      ;Initialise LCD module  
698b 3e 01				ld a, 1  
698d 32 fb fa				ld (display_lcde1e2), a  
6990 cd 09 6a		            CALL fLCD_Init      ;Initialise LCD module  
6993			  
6993 c9				ret  
6994			  
6994			;  
6994			;;  
6994			; lcd functions  
6994			;  
6994			;  
6994			  
6994			; what is at cursor position   
6994			  
6994			;get_cursor:	ld de, (cursor_row)   ;  row + col  
6994			;		call curptr  
6994			;		ret  
6994			  
6994			  
6994			; take current custor pos in de (d=row,e=col) and return a pointer to the frame buffer  
6994			  
6994			curptr:  
6994 c5				push bc  
6995 21 e1 fc			ld hl, display_fb0  
6998			cpr:	  
6998				; loop for cursor whole row  
6998 0e 28			ld c, display_cols  
699a 23			cpr1:	inc hl  
699b 0d				dec c  
699c 20 fc			jr nz, cpr1  
699e 05				dec b  
699f 20 f7			jr nz, cpr  
69a1			  
69a1				; add col	  
69a1			  
69a1 23			cpr2:	inc hl  
69a2 1d				dec e  
69a3 20 fc			jr nz, cpr2  
69a5			  
69a5 c1				pop bc  
69a6 c9				ret  
69a7				  
69a7			  
69a7			  
69a7			  
69a7			  
69a7			; write the frame buffer given in hl to hardware   
69a7 22 f9 fa		write_display: ld (display_write_tmp), hl 	   
69aa 3e 00			ld a, kLCD_Line1  
69ac cd b6 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69af 06 28			ld b, display_cols  
69b1 ed 5b f9 fa		ld de, (display_write_tmp)  
69b5 cd 01 6a			call write_len_string  
69b8				  
69b8				  
69b8 2a f9 fa			ld hl, (display_write_tmp)  
69bb 11 28 00			ld de, display_cols  
69be 19				add hl,de  
69bf 22 f9 fa			ld (display_write_tmp),hl  
69c2			  
69c2				  
69c2 3e 28			ld a, kLCD_Line2  
69c4 cd b6 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69c7 06 28			ld b, display_cols  
69c9 ed 5b f9 fa		ld de, (display_write_tmp)  
69cd cd 01 6a			call write_len_string  
69d0				  
69d0 2a f9 fa			ld hl, (display_write_tmp)  
69d3 11 28 00			ld de, display_cols  
69d6 19				add hl,de  
69d7 22 f9 fa			ld (display_write_tmp),hl  
69da			  
69da				  
69da 3e 50			ld a, kLCD_Line3  
69dc cd b6 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69df 06 28			ld b, display_cols  
69e1 ed 5b f9 fa		ld de, (display_write_tmp)  
69e5 cd 01 6a			call write_len_string  
69e8				  
69e8 2a f9 fa			ld hl, (display_write_tmp)  
69eb 11 28 00			ld de, display_cols  
69ee 19				add hl,de  
69ef 22 f9 fa			ld (display_write_tmp),hl  
69f2			  
69f2				  
69f2 3e 78			ld a, kLCD_Line4  
69f4 cd b6 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69f7 06 28			ld b, display_cols  
69f9 ed 5b f9 fa		ld de, (display_write_tmp)  
69fd cd 01 6a			call write_len_string  
6a00 c9					ret  
6a01				  
6a01				; write out a fixed length string given in b from de  
6a01			  
6a01 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
6a02 cd 6e 6a		            CALL fLCD_Data      ;Write character to display  
6a05 13				inc de  
6a06 10 f9			djnz write_len_string  
6a08 c9				ret  
6a09			  
6a09			; Some other things to do  
6a09			;            LD   A, kLCD_Clear ;Display clear  
6a09			;            LD   A, kLCD_Blink ;Display on with blinking block cursor  
6a09			;            LD   A, kLCD_Under ;Display on with underscore cursor  
6a09			;            LD   A, kLCD_On     ;Display on with no cursor  
6a09			;            ;LD   A, kLCD_Off   ;Display off  
6a09			;            CALL fLCD_Inst      ;Send instruction to display  
