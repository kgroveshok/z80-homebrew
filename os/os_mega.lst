15dc			 
15dc			; Device support for SN76489AN sound chip 
15dc			 
15dc			; https://arduinoplusplus.wordpress.com/2019/10/05/making-noise-with-a-sn76489-digital-sound-generator-part-1/ 
15dc			; http://danceswithferrets.org/geekblog/?p=93 
15dc			; https://www.smspower.org/Development/SN76489 
15dc			 
15dc			; D0 [ 3] 
15dc			; D1 [ 2] 
15dc			; D2 [ 1] 
15dc			; D3 [15] 
15dc			; D4 [13] 
15dc			; D5 [12] 
15dc			; D6 [11] 
15dc			; D7 [10] 
15dc			; /WE [ 5] 
15dc			; CLK [14] 
15dc			; /OE [ 6] 
15dc			; AUDIO [ 7] 
15dc			; GND 8 
15dc			; +5 16 
15dc			; 
15dc			 
15dc			; Write sequence: 
15dc			; CE low 
15dc			; Data bus 
15dc			; WE low then high 
15dc			; 32 clock cycles / 8ns write time at 4mhz 
15dc			; 
15dc			; https://github.com/jblang/SN76489 
15dc			; Shows that the clock needs to be enabled when required. Noticed that with the clock connected it interupted the bus 
15dc			; Tried: 
15dc			; 
15dc			; CE/OE -> Both pins of NAND -> To one pin of second NAND and second pin to full clock -> CLK on chip 
15dc			; 
15dc			; Connected WE to OR too 
15dc			;  
15dc			; That enabled the clock when required 
15dc			; However still random bus corruption. Need further investigation 
15dc			 
15dc			 
15dc			SOUND_LATCH: equ 10000000B 
15dc			SOUND_DATA: equ 0B 
15dc			SOUND_CH0:  equ 0B    ; Tone 
15dc			SOUND_CH1: equ 0100000B        ; Tone 
15dc			SOUND_CH2: equ 1000000B   ; Tone 
15dc			SOUND_CH3: equ 1100000B    ; Noise 
15dc			SOUND_VOL: equ 10000B 
15dc			SOUND_TONE: equ 0B 
15dc			 
15dc			 
