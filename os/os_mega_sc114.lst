bfd9			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bfd9			; | 
bfd9			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bfd9			; | |  
bfd9			; | | e.g. 
bfd9			; | |         #30 a var ! 
bfd9			; | |         a var @ . 
bfd9			; | |   
bfd9			; | |     Displays the number 30 
bfd9			; | | 
bfd9			; | | Each variable pointer is a word so can use for any words that use that:  
bfd9			; | |  
bfd9			; | | e.g. 
bfd9			; | |  
bfd9			; | |         #30 a var 2! 
bfd9			; | |         a var 2@ . 
bfd9			; | |   
bfd9			; | |     Displays the number 30 
bfd9			; | |  
bfd9			; | | > [!NOTE]  
bfd9			; ! | > If a full string is passed then only the first char is looked at 
bfd9			; | | > Any other char could exceed bounds checks!  
bfd9			; | | > 
bfd9			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bfd9			 
bfd9					if DEBUG_FORTH_WORDS_KEY 
bfd9						DMARK "VAR" 
bfd9				if DEMARK_VERSION = 1  
bfd9 e5					push hl  
bfda 21 e2 bf				ld hl, .dmark  
