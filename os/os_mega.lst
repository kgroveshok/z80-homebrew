1120			; Z80 Malloc and Free Functions 
1120			 
1120			; Malloc Function: 
1120			; Input: 
1120			;   HL: Size of block to allocate 
1120			; Output: 
1120			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1120			 
1120			malloc: 
1120				 
1120			if DEBUG_FORTH_MALLOC_HIGH 
1120			call malloc_guard_entry 
1120			endif 
1120			 
1120			 
1120			 
1120			 
1120					if DEBUG_FORTH_MALLOC 
1120						DMARK "mal" 
1120						CALLMONITOR 
1120					endif 
1120			    push af            ; Save AF register 
1120			    ld a, l            ; Load low byte of size into A 
1120			    or h               ; Check if size is zero 
1120			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1120			 
1120			    ; Allocate memory 
1120			    ld hl, (heap_start) ; Load start of heap into HL 
1120					if DEBUG_FORTH_MALLOC 
1120						DMARK "ma1" 
1120						CALLMONITOR 
1120					endif 
1120			    call malloc_internal ; Call internal malloc function 
1120			    pop af             ; Restore AF register 
1120			if DEBUG_FORTH_MALLOC_HIGH 
1120			call malloc_guard_exit 
1120			call malloc_guard_zerolen 
1120			endif 
1120			    ret                ; Return 
1120			 
1120			; Free Function: 
1120			; Input: 
1120			;   HL: Pointer to memory block to free 
1120			; Output: 
1120			;   None 
1120			 
1120			free: 
1120			    push af            ; Save AF register 
1120			    ld a, l            ; Load low byte of pointer into A 
1120			    or h               ; Check if pointer is NULL 
1120			    jp z, free_exit    ; If pointer is NULL, exit 
1120			 
1120			    ; Free memory 
1120			    ld hl, (heap_start) ; Load start of heap into HL 
1120			    call free_internal  ; Call internal free function 
1120			    pop af             ; Restore AF register 
1120			    ret                ; Return 
1120			 
1120			; Internal Malloc Function: 
1120			; Input: 
1120			;   HL: Size of block to allocate 
1120			; Output: 
1120			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1120			 
1120			malloc_internal: 
1120			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1120			    add hl, bc         ; Add management overhead to requested size 
1120			    ex de, hl          ; Save total size in DE, and keep it in HL 
1120					if DEBUG_FORTH_MALLOC 
1120						DMARK "ma2" 
1120						CALLMONITOR 
1120					endif 
1120			 
1120			    ; Search for free memory block 
1120			    ld de, (heap_end)  ; Load end of heap into DE 
1120			    ld bc, 0           ; Initialize counter 
1120			 
1120					if DEBUG_FORTH_MALLOC 
1120						DMARK "ma2" 
1120						CALLMONITOR 
1120					endif 
1120			malloc_search_loop: 
1120			    ; Check if current block is free 
1120			    ld a, (hl)         ; Load current block's status (free or used) 
1120			;    cp 0               ; Compare with zero (free) 
1120				or a 
1120			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1120			 
1120			    ; Check if current block is large enough 
1120			    ld a, (hl+1)       ; Load high byte of block size 
1120			    cp l               ; Compare with low byte of requested size 
1120			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1120			 
1120			    ld a, (hl+2)       ; Load low byte of block size 
1120			    cp h               ; Compare with high byte of requested size 
1120			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1120			 
1120			    ; Mark block as used 
1120			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1120			 
1120			    ; Calculate remaining space in block 
1120			    ld bc, 0           ; Clear BC 
1120			    add hl, bc         ; Increment HL to point to start of data block 
1120			    add hl, de         ; HL = HL + DE (total size) 
1120			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1120			    add hl, bc         ; Add management overhead to start of data block 
1120			 
1120			    ; Save pointer to allocated block in HL 
1120			if DEBUG_FORTH_MALLOC_HIGH 
1120						DMARK "ma5" 
1120			call malloc_guard_exit 
1120			call malloc_guard_zerolen 
1120			endif 
1120			    ret 
1120			 
1120			malloc_skip_block_check: 
1120			    ; Move to the next block 
1120			    ld bc, 3           ; Size of management overhead 
1120			    add hl, bc         ; Move to the next block 
1120			    inc de             ; Increment counter 
1120			 
1120			    ; Check if we have reached the end of heap 
1120			    ld a, e            ; Load low byte of heap end address 
1120			    cp (hl)            ; Compare with low byte of current address 
1120			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1120			    ld a, d            ; Load high byte of heap end address 
1120			;    cp 0               ; Check if it's zero (end of memory) 
1120				or a 
1120			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1120			 
1120			    ; If we reached here, allocation failed 
1120			    xor a              ; Set result to NULL 
1120			if DEBUG_FORTH_MALLOC_HIGH 
1120						DMARK "ma6" 
1120			call malloc_guard_exit 
1120			call malloc_guard_zerolen 
1120			endif 
1120			    ret 
1120			malloc_exit: 
1120			if DEBUG_FORTH_MALLOC_HIGH 
1120						DMARK "ma7" 
1120			call malloc_guard_exit 
1120			call malloc_guard_zerolen 
1120			endif 
1120			    ret 
1120			 
1120			; Internal Free Function: 
1120			; Input: 
1120			;   HL: Pointer to memory block to free 
1120			; Output: 
1120			;   None 
1120			 
1120			free_internal: 
1120			    ld de, (heap_start) ; Load start of heap into DE 
1120			    ld bc, 0            ; Initialize counter 
1120			 
1120			free_search_loop: 
1120			    ; Check if current block contains the pointer 
1120			    ld a, l             ; Load low byte of pointer 
1120			    cp (hl+1)           ; Compare with high byte of current block's address 
1120			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1120			    ld a, h             ; Load high byte of pointer 
1120			    cp (hl+2)           ; Compare with low byte of current block's address 
1120			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1120			 
1120			    ; Mark block as free 
1120			    ld (hl), 0          ; Set status byte to indicate free block 
1120			    ret                 ; Return 
1120			 
1120			free_skip_block_check: 
1120			    ; Move to the next block 
1120			    ld bc, 3            ; Size of management overhead 
1120			    add hl, bc          ; Move to the next block 
1120			    inc de              ; Increment counter 
1120			 
1120			    ; Check if we have reached the end of heap 
1120			    ld a, e             ; Load low byte of heap end address 
1120			    cp (hl)             ; Compare with low byte of current address 
1120			    jr nz, free_search_loop  ; If not equal, continue searching 
1120			    ld a, d             ; Load high byte of heap end address 
1120			;    cp 0                ; Check if it's zero (end of memory) 
1120				or a 
1120			    jr nz, free_search_loop  ; If not zero, continue searching 
1120			 
1120			    ; If we reached here, pointer is not found in heap 
1120			    ret 
1120			 
1120			free_exit: 
1120			    ret                 ; Return 
1120			 
1120			; Define heap start and end addresses 
1120			;heap_start:    .dw 0xC000   ; Start of heap 
1120			;heap_end:      .dw 0xE000   ; End of heap 
1120			 
1120			endif 
1120			 
1120			 
1120			if MALLOC_1 
