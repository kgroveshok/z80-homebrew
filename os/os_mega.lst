2028			user_word_eol:  
2028				; hl contains the pointer to where to create a linked list item from the end 
2028				; of the user dict to continue on at the system word dict 
2028				 
2028				; poke the stub of the word list linked list to repoint to rom words 
2028			 
2028				; stub format 
2028				; db   word id 
2028				; dw    link to next word 
2028			        ; db char length of token 
2028				; db string + 0 term 
2028				; db exec code....  
2028			 
2028			;	ld a, WORD_SYS_ROOT     ; root word 
2028 36 00			ld (hl), WORD_SYS_ROOT		; word id 
202a 23				inc hl 
202b			 
202b 11 d4 21			ld de, sysdict 
202e 73				ld (hl), e		; next word link ie system dict 
202f 23				inc hl 
2030 72				ld (hl), d		; next word link ie system dict 
2031 23				inc hl	 
2032			 
2032			;	ld (hl), sysdict		; next word link ie system dict 
2032			;	inc hl 
2032			;	inc hl 
2032			 
2032			;	inc hl 
2032			;	inc hl 
2032			 
2032			;	ld a, 2			; word length is 0 
2032 36 02			ld (hl), 2 
2034 23				inc hl 
2035			 
2035			;	ld a, '~'			; word length is 0 
2035 36 7e			ld (hl), '~' 
2037 23				inc hl 
2038			;	ld a, 0			; save empty word 
2038 36 00			ld (hl), 0 
203a			 
