0df5			; from z80uartmonitor 
0df5			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0df5			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
0df5			; pass hl for where to put the text 
0df5			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0df5 c5			hexout:	PUSH BC 
0df6 f5					PUSH AF 
0df7 47					LD B, A 
0df8					; Upper nybble 
0df8 cb 3f				SRL A 
0dfa cb 3f				SRL A 
0dfc cb 3f				SRL A 
0dfe cb 3f				SRL A 
0e00 cd 10 0e				CALL tohex 
0e03 77					ld (hl),a 
0e04 23					inc hl	 
0e05					 
0e05					; Lower nybble 
0e05 78					LD A, B 
0e06 e6 0f				AND 0FH 
0e08 cd 10 0e				CALL tohex 
0e0b 77					ld (hl),a 
0e0c 23					inc hl	 
0e0d					 
0e0d f1					POP AF 
0e0e c1					POP BC 
0e0f c9					RET 
0e10					 
0e10			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0e10			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
0e10			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0e10			tohex: 
0e10 e5					PUSH HL 
0e11 d5					PUSH DE 
0e12 16 00				LD D, 0 
0e14 5f					LD E, A 
0e15 21 1d 0e				LD HL, .DATA 
0e18 19					ADD HL, DE 
0e19 7e					LD A, (HL) 
0e1a d1					POP DE 
0e1b e1					POP HL 
0e1c c9					RET 
0e1d			 
0e1d			.DATA: 
0e1d 30					DEFB	30h	; 0 
0e1e 31					DEFB	31h	; 1 
0e1f 32					DEFB	32h	; 2 
0e20 33					DEFB	33h	; 3 
0e21 34					DEFB	34h	; 4 
0e22 35					DEFB	35h	; 5 
0e23 36					DEFB	36h	; 6 
0e24 37					DEFB	37h	; 7 
0e25 38					DEFB	38h	; 8 
0e26 39					DEFB	39h	; 9 
0e27 41					DEFB	41h	; A 
0e28 42					DEFB	42h	; B 
0e29 43					DEFB	43h	; C 
0e2a 44					DEFB	44h	; D 
0e2b 45					DEFB	45h	; E 
0e2c 46					DEFB	46h	; F 
0e2d			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0e2d			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0e2d			;;    subtract $30, if result > 9 then subtract $7 more 
0e2d			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0e2d			atohex: 
0e2d d6 30				SUB $30 
0e2f fe 0a				CP 10 
0e31 f8					RET M		; If result negative it was 0-9 so we're done 
0e32 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0e34 c9					RET		 
