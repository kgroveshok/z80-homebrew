d26c			; stack over and underflow checks 
d26c			 
d26c			; init the words to detect the under/overflow 
d26c			 
d26c			chk_stk_init: 
d26c				; a vague random number to check so we dont get any "lucky" hits 
d26c 3e 2d			ld a, 45 
d26e 6f				ld l, a 
d26f 00				nop 
d270 3e 17			ld a, 23 
d272 67				ld h, a 
d273			 
d273 22 81 e2			ld (chk_word), hl     ; the word we need to check against 
d276			 
d276			;	ld (chk_stund), hl	; stack points.... 
d276 22 00 ef			ld (chk_stovr), hl 
d279 22 d0 e9			ld (chk_ret_und), hl 
d27c 22 8e e9			ld (chk_ret_ovr), hl 
d27f 22 0c e9			ld (chk_loop_ovr), hl 
d282 22 0a e8			ld (chk_data_ovr), hl 
d285 c9				ret 
d286				 
d286			check_stacks: 
d286				; check all stack words 
d286			 
d286 e5				push hl 
d287 d5				push de 
d288			 
d288			;	ld de,(chk_word) 
d288			;	ld hl, (chk_stund)	; stack points.... 
d288			;	if DEBUG_STK_FAULT 
d288			;		DMARK "FAa" 
d288			;		CALLMONITOR 
d288			;	endif 
d288			;	call cmp16 
d288			;	jp z, .chk_faulta 
d288			; 
d288			;	ld de, sfaultsu 
d288			;	jp .chk_fault 
d288			 
d288 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
d28b ed 5b 81 e2		ld de,(chk_word) 
d28f				if DEBUG_STK_FAULT 
d28f					DMARK "FAb" 
d28f					CALLMONITOR 
d28f				endif 
d28f cd 58 8a			call cmp16 
d292 28 06			jr z, .chk_fault1 
d294 11 39 d3			ld de, sfaultso 
d297 c3 e9 d2			jp .chk_fault 
d29a			.chk_fault1:  
d29a 2a d0 e9			ld hl, (chk_ret_und) 
d29d ed 5b 81 e2		ld de,(chk_word) 
d2a1				if DEBUG_STK_FAULT 
d2a1					DMARK "FAU" 
d2a1					CALLMONITOR 
d2a1				endif 
d2a1 cd 58 8a			call cmp16 
d2a4 ca ad d2			jp z, .chk_fault2 
d2a7 11 49 d3			ld de, sfaultru 
d2aa c3 e9 d2			jp .chk_fault 
d2ad			.chk_fault2:  
d2ad 2a 8e e9			ld hl, (chk_ret_ovr) 
d2b0 ed 5b 81 e2		ld de,(chk_word) 
d2b4				if DEBUG_STK_FAULT 
d2b4					DMARK "FA1" 
d2b4					CALLMONITOR 
d2b4				endif 
d2b4 cd 58 8a			call cmp16 
d2b7 ca c0 d2			jp z, .chk_fault3 
d2ba 11 57 d3			ld de, sfaultro 
d2bd c3 e9 d2			jp .chk_fault 
d2c0			.chk_fault3:  
d2c0 2a 0c e9			ld hl, (chk_loop_ovr) 
d2c3 ed 5b 81 e2		ld de,(chk_word) 
d2c7				if DEBUG_STK_FAULT 
d2c7					DMARK "FA2" 
d2c7					CALLMONITOR 
d2c7				endif 
d2c7 cd 58 8a			call cmp16 
d2ca ca d3 d2			jp z, .chk_fault4 
d2cd 11 71 d3			ld de, sfaultlo 
d2d0 c3 e9 d2			jp .chk_fault 
d2d3			.chk_fault4:  
