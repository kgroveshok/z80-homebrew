15d6			; Sound abstraction layer 
15d6			 
15d6			; support different sound chips through common interface 
15d6			 
15d6			SOUND_DEVICE_AY: equ 0 
15d6			 
15d6			SOUND_DEVICE: equ Device_A 
15d6			 
15d6			if SOUND_DEVICE_AY 
15d6				include "firmware_sound_ay38910.asm" 
15d6			else 
15d6				include "firmware_sound_sn76489an.asm" 
15d6			 
15d6			; Device support for SN76489AN sound chip 
15d6			 
15d6			; https://arduinoplusplus.wordpress.com/2019/10/05/making-noise-with-a-sn76489-digital-sound-generator-part-1/ 
15d6			; http://danceswithferrets.org/geekblog/?p=93 
15d6			; https://www.smspower.org/Development/SN76489 
15d6			 
15d6			; D0 [ 3] 
15d6			; D1 [ 2] 
15d6			; D2 [ 1] 
15d6			; D3 [15] 
15d6			; D4 [13] 
15d6			; D5 [12] 
15d6			; D6 [11] 
15d6			; D7 [10] 
15d6			; /WE [ 5] 
15d6			; CLK [14] 
15d6			; /OE [ 6] 
15d6			; AUDIO [ 7] 
15d6			; GND 8 
15d6			; +5 16 
15d6			; 
15d6			 
15d6			; Write sequence: 
15d6			; CE low 
15d6			; Data bus 
15d6			; WE low then high 
15d6			; 32 clock cycles / 8ns write time at 4mhz 
15d6			; 
15d6			; https://github.com/jblang/SN76489 
15d6			; Shows that the clock needs to be enabled when required. Noticed that with the clock connected it interupted the bus 
15d6			; Tried: 
15d6			; 
15d6			; CE/OE -> Both pins of NAND -> To one pin of second NAND and second pin to full clock -> CLK on chip 
15d6			; 
15d6			; Connected WE to OR too 
15d6			;  
15d6			; That enabled the clock when required 
15d6			; However still random bus corruption. Need further investigation 
15d6			 
15d6			 
15d6			SOUND_LATCH: equ 10000000B 
15d6			SOUND_DATA: equ 0B 
15d6			SOUND_CH0:  equ 0B    ; Tone 
15d6			SOUND_CH1: equ 0100000B        ; Tone 
15d6			SOUND_CH2: equ 1000000B   ; Tone 
15d6			SOUND_CH3: equ 1100000B    ; Noise 
15d6			SOUND_VOL: equ 10000B 
15d6			SOUND_TONE: equ 0B 
15d6			 
15d6			 
15d6 c9			sound_init: ret 
15d7			 
15d7			 
15d7			sound_bit_data: equ 0 
15d7			sound_bit_clk: equ 1 
15d7			sound_bit_latch: equ 2 
15d7			sound_bit_sound: equ 3 
15d7			 
15d7			 
15d7			; shift out a byte to the sound chip 
15d7			 
15d7			; A contains byte to send 
15d7			 
15d7			note_byte: 
15d7			 
15d7 0e 00			ld c, 	SOUND_DEVICE 
15d9 06 08			ld b, 8   ; 8 bits to shift 
15db			 
15db 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
15dd			 
15dd				; set data bit state 
15dd			 
15dd cb 7f			bit 7, a 
15df				; high bit is set 
15df 28 02			jr z, .nb2 
15e1 cb c2			set sound_bit_data, d 
15e3			 
15e3				; set latches state high 
15e3 cb ca		.nb2:	set sound_bit_clk, d 
15e5 cb d2			set sound_bit_latch, d 
15e7 ed 51			out (c), d 
15e9				 
15e9				; clock the bit out 
15e9 cb 8a			res sound_bit_clk, d 
15eb ed 51			out (c), d 
15ed cb ca			set sound_bit_clk, d 
15ef ed 51			out (c), d 
15f1			 
15f1				; shift a left one bit and repeat 
15f1 17				rla 
15f2			 
15f2 10 e7			djnz .nb1 
15f4			 
15f4				; latch 
15f4 cb d2			set sound_bit_latch, d 
15f6 ed 51			out (c), d 
15f8 cb 92			res sound_bit_latch, d 
15fa ed 51			out (c), d 
15fc cb d2			set sound_bit_latch, d 
15fe ed 51			out (c), d 
