1123			if MALLOC_2 
1123			; Z80 Malloc and Free Functions 
1123			 
1123			; Malloc Function: 
1123			; Input: 
1123			;   HL: Size of block to allocate 
1123			; Output: 
1123			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1123			 
1123			malloc: 
1123				 
1123			if DEBUG_FORTH_MALLOC_HIGH 
1123			call malloc_guard_entry 
1123			endif 
1123			 
1123			 
1123			 
1123			 
1123					if DEBUG_FORTH_MALLOC 
1123						DMARK "mal" 
1123						CALLMONITOR 
1123					endif 
1123			    push af            ; Save AF register 
1123			    ld a, l            ; Load low byte of size into A 
1123			    or h               ; Check if size is zero 
1123			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1123			 
1123			    ; Allocate memory 
1123			    ld hl, (heap_start) ; Load start of heap into HL 
1123					if DEBUG_FORTH_MALLOC 
1123						DMARK "ma1" 
1123						CALLMONITOR 
1123					endif 
1123			    call malloc_internal ; Call internal malloc function 
1123			    pop af             ; Restore AF register 
1123			if DEBUG_FORTH_MALLOC_HIGH 
1123			call malloc_guard_exit 
1123			call malloc_guard_zerolen 
1123			endif 
1123			    ret                ; Return 
1123			 
1123			; Free Function: 
1123			; Input: 
1123			;   HL: Pointer to memory block to free 
1123			; Output: 
1123			;   None 
1123			 
1123			free: 
1123			    push af            ; Save AF register 
1123			    ld a, l            ; Load low byte of pointer into A 
1123			    or h               ; Check if pointer is NULL 
1123			    jp z, free_exit    ; If pointer is NULL, exit 
1123			 
1123			    ; Free memory 
1123			    ld hl, (heap_start) ; Load start of heap into HL 
1123			    call free_internal  ; Call internal free function 
1123			    pop af             ; Restore AF register 
1123			    ret                ; Return 
1123			 
1123			; Internal Malloc Function: 
1123			; Input: 
1123			;   HL: Size of block to allocate 
1123			; Output: 
1123			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1123			 
1123			malloc_internal: 
1123			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1123			    add hl, bc         ; Add management overhead to requested size 
1123			    ex de, hl          ; Save total size in DE, and keep it in HL 
1123					if DEBUG_FORTH_MALLOC 
1123						DMARK "ma2" 
1123						CALLMONITOR 
1123					endif 
1123			 
1123			    ; Search for free memory block 
1123			    ld de, (heap_end)  ; Load end of heap into DE 
1123			    ld bc, 0           ; Initialize counter 
1123			 
1123					if DEBUG_FORTH_MALLOC 
1123						DMARK "ma2" 
1123						CALLMONITOR 
1123					endif 
1123			malloc_search_loop: 
1123			    ; Check if current block is free 
1123			    ld a, (hl)         ; Load current block's status (free or used) 
1123			;    cp 0               ; Compare with zero (free) 
1123				or a 
1123			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1123			 
1123			    ; Check if current block is large enough 
1123			    ld a, (hl+1)       ; Load high byte of block size 
1123			    cp l               ; Compare with low byte of requested size 
1123			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1123			 
1123			    ld a, (hl+2)       ; Load low byte of block size 
1123			    cp h               ; Compare with high byte of requested size 
1123			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1123			 
1123			    ; Mark block as used 
1123			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1123			 
1123			    ; Calculate remaining space in block 
1123			    ld bc, 0           ; Clear BC 
1123			    add hl, bc         ; Increment HL to point to start of data block 
1123			    add hl, de         ; HL = HL + DE (total size) 
1123			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1123			    add hl, bc         ; Add management overhead to start of data block 
1123			 
1123			    ; Save pointer to allocated block in HL 
1123			if DEBUG_FORTH_MALLOC_HIGH 
1123						DMARK "ma5" 
1123			call malloc_guard_exit 
1123			call malloc_guard_zerolen 
1123			endif 
1123			    ret 
1123			 
1123			malloc_skip_block_check: 
1123			    ; Move to the next block 
1123			    ld bc, 3           ; Size of management overhead 
1123			    add hl, bc         ; Move to the next block 
1123			    inc de             ; Increment counter 
1123			 
1123			    ; Check if we have reached the end of heap 
1123			    ld a, e            ; Load low byte of heap end address 
1123			    cp (hl)            ; Compare with low byte of current address 
1123			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1123			    ld a, d            ; Load high byte of heap end address 
1123			;    cp 0               ; Check if it's zero (end of memory) 
1123				or a 
1123			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1123			 
1123			    ; If we reached here, allocation failed 
1123			    xor a              ; Set result to NULL 
1123			if DEBUG_FORTH_MALLOC_HIGH 
1123						DMARK "ma6" 
1123			call malloc_guard_exit 
1123			call malloc_guard_zerolen 
1123			endif 
1123			    ret 
1123			malloc_exit: 
1123			if DEBUG_FORTH_MALLOC_HIGH 
1123						DMARK "ma7" 
1123			call malloc_guard_exit 
1123			call malloc_guard_zerolen 
1123			endif 
1123			    ret 
1123			 
1123			; Internal Free Function: 
1123			; Input: 
1123			;   HL: Pointer to memory block to free 
1123			; Output: 
1123			;   None 
1123			 
1123			free_internal: 
1123			    ld de, (heap_start) ; Load start of heap into DE 
1123			    ld bc, 0            ; Initialize counter 
1123			 
1123			free_search_loop: 
1123			    ; Check if current block contains the pointer 
1123			    ld a, l             ; Load low byte of pointer 
1123			    cp (hl+1)           ; Compare with high byte of current block's address 
1123			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1123			    ld a, h             ; Load high byte of pointer 
1123			    cp (hl+2)           ; Compare with low byte of current block's address 
1123			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1123			 
1123			    ; Mark block as free 
1123			    ld (hl), 0          ; Set status byte to indicate free block 
1123			    ret                 ; Return 
1123			 
1123			free_skip_block_check: 
1123			    ; Move to the next block 
1123			    ld bc, 3            ; Size of management overhead 
1123			    add hl, bc          ; Move to the next block 
1123			    inc de              ; Increment counter 
1123			 
1123			    ; Check if we have reached the end of heap 
1123			    ld a, e             ; Load low byte of heap end address 
1123			    cp (hl)             ; Compare with low byte of current address 
1123			    jr nz, free_search_loop  ; If not equal, continue searching 
1123			    ld a, d             ; Load high byte of heap end address 
1123			;    cp 0                ; Check if it's zero (end of memory) 
1123				or a 
1123			    jr nz, free_search_loop  ; If not zero, continue searching 
1123			 
1123			    ; If we reached here, pointer is not found in heap 
1123			    ret 
1123			 
1123			free_exit: 
1123			    ret                 ; Return 
1123			 
1123			; Define heap start and end addresses 
1123			;heap_start:    .dw 0xC000   ; Start of heap 
1123			;heap_end:      .dw 0xE000   ; End of heap 
1123			 
1123			endif 
1123			 
