0d7b			;;This divides DE by BC, storing the result in DE, remainder in HL 
0d7b			; 
0d7b			;DE_Div_BC:          ;1281-2x, x is at most 16 
0d7b			;     ld a,16        ;7 
0d7b			;     ld hl,0        ;10 
0d7b			;     jp $+5         ;10 
0d7b			;.DivLoop: 
0d7b			;       add hl,bc    ;-- 
0d7b			;       dec a        ;64 
0d7b			;       jr z,.DivLoopEnd        ;86 
0d7b			; 
0d7b			;       sla e        ;128 
0d7b			;       rl d         ;128 
0d7b			;       adc hl,hl    ;240 
0d7b			;       sbc hl,bc    ;240 
0d7b			;       jr nc,.DivLoop ;23|21 
0d7b			;       inc e        ;-- 
0d7b			;       jp .DivLoop+1 
0d7b			; 
0d7b			;.DivLoopEnd: 
0d7b			 
0d7b			;HL_Div_C: 
0d7b			;Inputs: 
0d7b			;     HL is the numerator 
0d7b			;     C is the denominator 
0d7b			;Outputs: 
0d7b			;     A is the remainder 
0d7b			;     B is 0 
0d7b			;     C is not changed 
0d7b			;     DE is not changed 
0d7b			;     HL is the quotient 
0d7b			; 
0d7b			;       ld b,16 
0d7b			;       xor a 
0d7b			;         add hl,hl 
0d7b			;         rla 
0d7b			;         cp c 
0d7b			;         jr c,$+4 
0d7b			;           inc l 
0d7b			;           sub c 
0d7b			;         djnz $-7 
