# End of macro CWHEAD
5e6a			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5e6a			; | 
5e6a			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5e6a			; | |  
5e6a			; | | e.g. 
5e6a			; | |         #30 a var ! 
5e6a			; | |         a var @ . 
5e6a			; | |   
5e6a			; | |     Displays the number 30 
5e6a			; | | 
5e6a			; | | Each variable pointer is a word so can use for any words that use that:  
5e6a			; | |  
5e6a			; | | e.g. 
5e6a			; | |  
5e6a			; | |         #30 a var 2! 
5e6a			; | |         a var 2@ . 
5e6a			; | |   
5e6a			; | |     Displays the number 30 
5e6a			; | |  
5e6a			; | | > [!NOTE]  
5e6a			; ! | > If a full string is passed then only the first char is looked at 
5e6a			; | | > Any other char could exceed bounds checks!  
5e6a			; | | > 
5e6a			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5e6a			 
5e6a					if DEBUG_FORTH_WORDS_KEY 
5e6a						DMARK "VAR" 
5e6a f5				push af  
5e6b 3a 7f 5e			ld a, (.dmark)  
5e6e 32 99 fd			ld (debug_mark),a  
5e71 3a 80 5e			ld a, (.dmark+1)  
5e74 32 9a fd			ld (debug_mark+1),a  
5e77 3a 81 5e			ld a, (.dmark+2)  
5e7a 32 9b fd			ld (debug_mark+2),a  
5e7d 18 03			jr .pastdmark  
5e7f ..			.dmark: db "VAR"  
5e82 f1			.pastdmark: pop af  
5e83			endm  
# End of macro DMARK
5e83						CALLMONITOR 
5e83				if BASE_CPM=1  
5e83					call debug_vector  
5e83				endif  
5e83				if BASE_KEV=1  
5e83 cf					rst 8  
5e84				endif  
5e84				endm  
# End of macro CALLMONITOR
5e84					endif 
