8c73			; Get 2 ASCII characters as hex byte from pointer in hl 
8c73			 
8c73			BYTERD: 
8c73 16 00			LD	D,00h		;Set up 
8c75 cd 7d 8c			CALL	HEXCON		;Get byte and convert to hex 
8c78 87				ADD	A,A		;First nibble so 
8c79 87				ADD	A,A		;multiply by 16 
8c7a 87				ADD	A,A		; 
8c7b 87				ADD	A,A		; 
8c7c 57				LD	D,A		;Save hi nibble in D 
8c7d			HEXCON: 
8c7d 7e				ld a, (hl)		;Get next chr 
8c7e 23				inc hl 
8c7f d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
8c81 fe 0a			CP	00Ah		;Is it 0-9 ? 
8c83 38 02			JR	C,NALPHA	;If so miss next bit 
8c85 d6 07			SUB	007h		;Else convert alpha 
8c87			NALPHA: 
8c87 b2				OR	D		;Add hi nibble back 
8c88 c9				RET			; 
