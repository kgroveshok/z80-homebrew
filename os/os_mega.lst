7674			include "firmware_lcd_4x40.asm" 
7674			; **********************************************************************  
7674			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
7674			; **********************************************************************  
7674			;  
7674			; **  Written as a Small Computer Monitor App  
7674			; **  www.scc.me.uk  
7674			;  
7674			; History  
7674			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
7674			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
7674			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
7674			;  
7674			; **********************************************************************  
7674			;  
7674			; This program is an example of one of the methods of interfacing an   
7674			; alphanumeric LCD module.   
7674			;  
7674			; In this example the display is connected to either a Z80 PIO or a   
7674			; simple 8-bit output port.   
7674			;  
7674			; This interfacing method uses 4-bit data mode and uses time delays  
7674			; rather than polling the display's ready status. As a result the   
7674			; interface only requires 6 simple output lines:  
7674			;   Output bit 0 = not used  
7674			;   Output bit 1 = not used  
7674			;   Output bit 2 = RS         High = data, Low = instruction  
7674			;   Output bit 3 = E          Active high  
7674			;   Output bit 4 = DB4  
7674			;   Output bit 5 = DB5  
7674			;   Output bit 6 = DB6  
7674			;   Output bit 7 = DB7  
7674			; Display's R/W is connected to 0v so it is always in write mode  
7674			;  
7674			; This set up should work with any system supporting the RC2014 bus  
7674			  
7674			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
7674			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
7674			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
7674			;  
7674			; **********************************************************************  
7674			  
7674			; Additonal for 4x40. E1 and E2 instead of just E   
7674			; TODO swipe vidout signal on port a to activate E2  
7674			  
7674			; **********************************************************************  
7674			; **  Constants  
7674			; **********************************************************************  
7674			; LCD constants required by LCD support module  
7674			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
7674			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
7674			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
7674			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
7674			; TODO Decide which E is being set  
7674			kLCDWidth:  EQU display_cols             ;Width in characters  
7674			  
7674			; **********************************************************************  
7674			; **  Code library usage  
7674			; **********************************************************************  
7674			  
7674			; send character to current cursor position  
7674			; wraps and/or scrolls screen automatically  
7674			  
7674			  
7674			  
7674			lcd_init:  
7674			  
7674			; SCMonAPI functions used  
7674			  
7674			; Alphanumeric LCD functions used  
7674			; no need to specify specific functions for this module  
7674			  
7674 3e cf		            LD   A, 11001111b  
7676 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
7678 3e 00		            LD   A, 00000000b  
767a d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
767c			  
767c			; Initialise alphanumeric LCD module  
767c 3e 00				ld a, 0  
767e 32 f9 fa				ld (display_lcde1e2), a  
