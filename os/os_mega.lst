248f b7				or a 
2490 28 0b			jr z, .fntmatchyes 
2492			 
2492				; are we at the end of the token to find? 
2492			 
2492					if DEBUG_FORTH 
2492						DMARK "NT5" 
2492						CALLMONITOR 
2492					endif 
