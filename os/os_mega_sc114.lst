bfd1			 
bfd1			 
bfd1			 
bfd1			.SESEL: 
bfd1				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bfd1			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bfd1			; | | Zero is disabled storage. 
bfd1					if DEBUG_FORTH_WORDS_KEY 
bfd1						DMARK "BN?" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1					ld a, (spi_device_id) 
bfd1					sub '0' 
bfd1					ld h, 0 
bfd1					ld l, a 
bfd1					FORTH_PUSH_VALUEHL 
bfd1					;call forth_push_numhl 
bfd1					NEXTW 
bfd1			.SESELS: 
bfd1				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bfd1			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bfd1			; | | Set to zero to disable storage. 
bfd1					if DEBUG_FORTH_WORDS_KEY 
bfd1						DMARK "BNK" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1			 
bfd1					ld a, 255 
bfd1					ld (spi_cartdev), a 
bfd1			 
bfd1					; get bank 
bfd1			 
bfd1					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfd1			 
bfd1			;		push hl 
bfd1			 
bfd1					; destroy value TOS 
bfd1			 
bfd1					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfd1			 
bfd1					; one value on hl get other one back 
bfd1			 
bfd1			;		pop hl 
bfd1			 
bfd1			 
bfd1					ld c, SPI_CE_HIGH 
bfd1					ld b, '0'    ; human readable bank number 
bfd1			 
bfd1					ld a, l 
bfd1			 
bfd1					if DEBUG_FORTH_WORDS 
bfd1						DMARK "BNK" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1			 
bfd1					; active low 
bfd1			 
bfd1			;		cp 0 
bfd1					or a 
bfd1					jr z, .bset 
bfd1					cp 1 
bfd1					jr nz, .b2 
bfd1					res 0, c 
bfd1					ld b, '1'    ; human readable bank number 
bfd1			.b2:		cp 2 
bfd1					jr nz, .b3 
bfd1					res 1, c 
bfd1					ld b, '2'    ; human readable bank number 
bfd1			.b3:		cp 3 
bfd1					jr nz, .b4 
bfd1					res 2, c 
bfd1					ld b, '3'    ; human readable bank number 
bfd1			.b4:		cp 4 
bfd1					jr nz, .b5 
bfd1					res 3, c 
bfd1					ld b, '4'    ; human readable bank number 
bfd1			.b5:		cp 5 
bfd1					jr nz, .bset 
bfd1					res 4, c 
bfd1					ld b, '5'    ; human readable bank number 
bfd1			 
bfd1			.bset: 
bfd1					ld a, c 
bfd1					ld (spi_device),a 
bfd1					ld a, b 
bfd1					ld (spi_device_id),a 
bfd1					if DEBUG_FORTH_WORDS 
bfd1						DMARK "BN2" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1			 
bfd1					; set default SPI clk pulse time as disabled for BANK use 
bfd1			 
bfd1					ld a, 0 
bfd1					ld (spi_clktime), a 
bfd1			 
bfd1					NEXTW 
bfd1			 
bfd1			.CARTDEV: 
bfd1				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bfd1			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bfd1			; | | Set to zero to disable devices. 
bfd1					if DEBUG_FORTH_WORDS_KEY 
bfd1						DMARK "CDV" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1			 
bfd1					; disable se storage bank selection 
bfd1			 
bfd1					ld a, SPI_CE_HIGH		; ce high 
bfd1					ld (spi_device), a 
bfd1			 
bfd1					; get bank 
bfd1			 
bfd1					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfd1			 
bfd1			;		push hl 
bfd1			 
bfd1					; destroy value TOS 
bfd1			 
bfd1					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfd1			 
bfd1					; one value on hl get other one back 
bfd1			 
bfd1			;		pop hl 
bfd1			 
bfd1					; active low 
bfd1			 
bfd1					ld c, 255 
bfd1			 
bfd1					ld a, l 
bfd1					if DEBUG_FORTH_WORDS 
bfd1						DMARK "CDV" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1			;		cp 0 
bfd1					or a 
bfd1					jr z, .cset 
bfd1					cp 1 
bfd1					jr nz, .c2 
bfd1					res 0, c 
bfd1			.c2:		cp 2 
bfd1					jr nz, .c3 
bfd1					res 1, c 
bfd1			.c3:		cp 3 
bfd1					jr nz, .c4 
bfd1					res 2, c 
bfd1			.c4:		cp 4 
bfd1					jr nz, .c5 
bfd1					res 3, c 
bfd1			.c5:		cp 5 
bfd1					jr nz, .c6 
bfd1					res 4, c 
bfd1			.c6:		cp 6 
bfd1					jr nz, .c7 
bfd1					res 5, c 
bfd1			.c7:		cp 7 
bfd1					jr nz, .c8 
bfd1					res 6, c 
bfd1			.c8:		cp 8 
bfd1					jr nz, .cset 
bfd1					res 7, c 
bfd1			.cset:		ld a, c 
bfd1					ld (spi_cartdev),a 
bfd1			 
bfd1					if DEBUG_FORTH_WORDS 
bfd1						DMARK "CD2" 
bfd1						CALLMONITOR 
bfd1					endif 
bfd1			 
bfd1					; set default SPI clk pulse time as 10ms for CARTDEV use 
bfd1			 
bfd1					ld a, $0a 
bfd1					ld (spi_clktime), a 
bfd1					NEXTW 
bfd1			endif 
bfd1			 
