2c8b			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2c8b			; | | At start the current various registers will be displayed with contents. 
2c8b			; | | Top right corner will show the most recent debug marker seen. 
2c8b			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2c8b			; | | and the return stack pointer (RSP). 
2c8b			; | | Pressing: 
2c8b			; | |  
2c8b			; | |    1 - Initial screen 
2c8b			; | |  
2c8b			; | |    2 - Display a data dump of HL 
2c8b			; | |  
2c8b			; | |    3 - Display a data dump of DE 
2c8b			; | |  
2c8b			; | |    4 - Display a data dump of BC 
2c8b			; | |  
2c8b			; | |    5 - Display a data dump of HL 
2c8b			; | |  
2c8b			; | |    6 - Display a data dump of DSP 
2c8b			; | |  
2c8b			; | |    7 - Display a data dump of RSP 
2c8b			; | |  
2c8b			; | |    8 - Display a data dump of what is at DSP 
2c8b			; | |  
2c8b			; | |    9 - Display a data dump of what is at RSP 
2c8b			; | |  
2c8b			; | |    0 - Exit monitor and continue running. This will also enable break points 
2c8b			; | |  
2c8b			; | |    * - Disable break points 
2c8b			; | |  
2c8b			; | |    # - Enter traditional monitor mode 
2c8b			; | |  
2c8b			; | | 
2c8b			; | | Monitor Mode 
2c8b			; | | ------------ 
2c8b			; | | A prompt of '>' will be shown for various commands: 
2c8b			; | |  
2c8b			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2c8b			; | |  
2c8b			; | |    C - Continue display a data dump from the last set address 
2c8b			; | |  
2c8b			; | |    M xxxx - Set start of memory edit at address xx 
2c8b			; | |  
2c8b			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2c8b			; | |  
2c8b			; | |    G xxxx - Exec code at specific address 
2c8b			; | |  
2c8b			; | |    Q - Return to previous 
2c8b				if DEBUG_FORTH_WORDS_KEY 
2c8b					DMARK "MON" 
2c8b				if DEMARK_VERSION = 1  
2c8b e5					push hl  
2c8c 21 94 2c				ld hl, .dmark  
2c8f 22 9b fd				ld (debug_mark), hl  
2c92				endif  
