1f9a				push de 
1f9a				ld hl,(cli_ret_sp) 
1f9a				ld de, cli_ret_stack 
1f9a				call cmp16 
1f9a				jp c, fault_rsp_under 
1f9a				pop de 
1f9a				pop hl 
1f9a				endm 
1f9a			 
1f9a			FORTH_CHK_LOOP_UNDER: macro 
