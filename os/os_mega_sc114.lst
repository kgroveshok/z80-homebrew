d4fd						DMARK "ASc" 
d4fd						CALLMONITOR 
d4fd					endif 
d4fd				ld de, store_page+2 
d4fd				ld a, display_row_4 
d4fd				call str_at_display 
d4fd			 
d4fd				call update_display 
d4fd				call delay250ms 
d4fd			 
d4fd			 
