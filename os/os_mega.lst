683d			; handle the auto run of code from files in storage 
683d			 
683d			 
683d			include "forth_startup.asm" 
683d			; Which startup method to use? 
683d			; 
683d			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
683d			; followed by loading of a list of scripts in eeprom 
683d			 
683d			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
683d			; from eeprom 
683d			 
683d			; Select with define in main stubs 
683d			 
683d			if STARTUP_V1 
683d				include "forth_startupv1.asm" 
683d			endif 
683d			if STARTUP_V2 
683d				include "forth_startupv2.asm" 
683d			; Version 2 of the startup  
683d			;  
683d			; Auto load any files in bank 1 that start with a '*' 
683d			; If no se storage then revert to using eprom 
683d			 
683d			 
683d			if STORAGE_SE = 0 
683d			 
683d			sprompt1: db "Startup load...",0 
683d			sprompt2: db "Run? 1=No *=End #=All",0 
683d			 
683d			 
683d			 
683d			 
683d			forth_startup: 
683d				ld hl, startcmds 
683d				ld a, 0 
683d				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
683d			 
683d			.start1:	push hl 
683d				call clear_display 
683d				ld de, sprompt1 
683d			        ld a, display_row_1 
683d				call str_at_display 
683d				ld de, sprompt2 
683d			        ld a, display_row_2 
683d				call str_at_display 
683d				pop hl 
683d				push hl 
683d				ld e,(hl) 
683d				inc hl 
683d				ld d,(hl) 
683d			        ld a, display_row_3 
683d				call str_at_display 
683d				call update_display 
683d			 
683d			 
683d				ld a, (os_last_cmd) 
683d			;	cp 0 
683d				or a 
683d				jr z, .startprompt 
683d				call delay250ms 
683d				jr .startdo 
683d				 
683d				 
683d			 
683d			.startprompt: 
683d			 
683d				ld a,display_row_4 + display_cols - 1 
683d			        ld de, endprg 
683d				call str_at_display 
683d				call update_display 
683d				call delay1s 
683d				call cin_wait 
683d						 
683d				cp '*' 
683d				jr z, .startupend1 
683d				cp '#' 
683d				jr nz, .startno 
683d				ld a, 1 
683d				ld (os_last_cmd),a 
683d				jr .startdo 
683d			.startno:	cp '1' 
683d				jr z,.startnxt  
683d			 
683d				; exec startup line 
683d			.startdo:	 
683d				pop hl 
683d				push hl 
683d				 
683d				ld e,(hl) 
683d				inc hl 
683d				ld d,(hl) 
683d				ex de,hl 
683d			 
683d				push hl 
683d			 
683d				ld a, 0 
683d				;ld a, FORTH_END_BUFFER 
683d				call strlent 
683d				inc hl   ; include zero term to copy 
683d				ld b,0 
683d				ld c,l 
683d				pop hl 
683d				ld de, scratch 
683d				ldir 
683d			 
683d			 
683d				ld hl, scratch 
683d				call forthparse 
683d				call forthexec 
683d				call forthexec_cleanup 
683d			 
683d				ld a, display_row_4 
683d				ld de, endprog 
683d			 
683d				call update_display		 
683d			 
683d				ld a, (os_last_cmd) 
683d			;	cp 0 
683d				or a 
683d				jr nz, .startnxt 
683d				call next_page_prompt 
683d			        call clear_display 
683d				call update_display		 
683d			 
683d				; move onto next startup line? 
683d			.startnxt: 
683d			 
683d				call delay250ms 
683d				pop hl 
683d			 
683d				inc hl 
683d				inc hl 
683d			 
683d				push hl 
683d				ld e, (hl) 
683d				inc hl 
683d				ld d, (hl) 
683d				pop hl 
683d				; TODO replace 0 test 
683d			 
683d				ex de, hl 
683d				call ishlzero 
683d			;	ld a,e 
683d			;	add d 
683d			;	cp 0    ; any left to do? 
683d				ex de, hl 
683d				jp nz, .start1 
683d				jr .startupend 
683d			 
683d			.startupend1: pop hl 
683d			.startupend: 
683d			 
683d				call clear_display 
683d				call update_display 
683d				ret 
683d			endif 
