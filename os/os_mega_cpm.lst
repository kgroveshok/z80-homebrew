5814			forth_autoload: 
5814			 
5814				; load block 0 of store 1 
5814				 
5814				ld a, $fe      ; bit 0 clear 
5814				ld (spi_device), a 
5814			 
5814				call storage_get_block_0 
5814			 
5814				ld a, (store_page+STORE_0_AUTOFILE) 
5814			 
5814				cp 0 
5814				ret z     ; auto start not enabled 
5814			 
5814				call clear_display 
5814			 
5814				; set bank 
5814			 
5814					ld a, (store_page+STORE_0_BANKRUN) 
5814					ld (spi_device), a 
5814			 
5814				; get file id to load from and get the file name to display 
5814			 
5814					ld a, (store_page+STORE_0_FILERUN) 
5814			 
5814					ld l, 0 
5814					ld h, a 
5814					ld de, store_page 
5814			 
5814					if DEBUG_FORTH_WORDS 
5814						DMARK "ASp" 
5814						CALLMONITOR 
5814					endif 
5814					call storage_read 
5814			 
5814					if DEBUG_FORTH_WORDS 
5814						DMARK "ASr" 
5814						CALLMONITOR 
5814					endif 
5814			 
5814					call ishlzero 
5814					ret z             ; file not found 
5814			 
5814					ld a, display_row_2 + 10 
5814					ld de, store_page+3 
5814					call str_at_display 
5814				 
5814			; 
5814			 
5814				ld a, display_row_1+5 
5814				ld de, sprompt3 
5814				call str_at_display 
5814				ld a, display_row_3+15 
5814				ld de, sprompt4 
5814				call str_at_display 
5814			 
5814				call update_display 
5814			 
5814				call cin_wait 
5814				cp 'n' 
5814				ret z 
5814				cp 'N' 
5814				ret z 
5814			 
5814				call delay1s 
5814			 
5814				ld a, (store_page+2) 
5814				ld (store_openmaxext), a    ; save count of ext 
5814				ld a, 1  
5814				ld (store_openext), a    ; save count of ext 
5814			 
5814			.autof:  
5814				ld l , a 
5814				 
5814				ld a, (store_page) 
5814				ld h, a	 
5814				ld de, store_page 
5814					if DEBUG_FORTH_WORDS 
5814						DMARK "ASl" 
5814						CALLMONITOR 
5814					endif 
5814					call storage_read 
5814				call ishlzero 
5814				ret z 
5814			;	jr z, .autoend 
5814			 
5814					if DEBUG_FORTH_WORDS 
5814						DMARK "ASc" 
5814						CALLMONITOR 
5814					endif 
5814				ld de, store_page+2 
5814				ld a, display_row_4 
5814				call str_at_display 
5814			 
5814				call update_display 
5814				call delay250ms 
5814			 
5814			 
5814			 
5814				ld hl, store_page+2 
5814				call forthparse 
5814				call forthexec 
5814				call forthexec_cleanup 
5814			 
5814				 
5814				ld a, (store_openext) 
5814				inc a 
5814				ld (store_openext), a    ; save count of ext 
5814			 
5814				jr .autof 
