5317			.SPITIME: 
5317				CWHEAD .VA 99 "SPITIME" 7 WORD_FLAG_CODE 
5317 77				db WORD_SYS_CORE+99             
5318 2f 53			dw .VA            
531a 08				db 7 + 1 
