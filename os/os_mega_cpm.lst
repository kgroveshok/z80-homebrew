5b06				call clear_display 
5b06			 
5b06				; set bank 
5b06			 
5b06					ld a, (store_page+STORE_0_BANKRUN) 
5b06					ld (spi_device), a 
5b06			 
5b06				; get file id to load from and get the file name to display 
5b06			 
5b06					ld a, (store_page+STORE_0_FILERUN) 
5b06			 
5b06					ld l, 0 
5b06					ld h, a 
5b06					ld de, store_page 
5b06			 
5b06					if DEBUG_FORTH_WORDS 
5b06						DMARK "ASp" 
5b06						CALLMONITOR 
5b06					endif 
5b06					call storage_read 
5b06			 
5b06					if DEBUG_FORTH_WORDS 
5b06						DMARK "ASr" 
5b06						CALLMONITOR 
5b06					endif 
5b06			 
5b06					call ishlzero 
5b06					ret z             ; file not found 
5b06			 
5b06					ld a, display_row_2 + 10 
5b06					ld de, store_page+3 
5b06					call str_at_display 
5b06				 
5b06			; 
5b06			 
5b06				ld a, display_row_1+5 
5b06				ld de, sprompt3 
