71b6					CALLMONITOR 
71b6				endif 
71b6 cd 9b 0f			call cmp16 
71b9 ca c2 71			jp z, .chk_fault3 
71bc 11 58 72			ld de, sfaultro 
71bf c3 eb 71			jp .chk_fault 
71c2			.chk_fault3:  
71c2 2a 56 f8			ld hl, (chk_loop_ovr) 
71c5 ed 5b cb f0		ld de,(chk_word) 
71c9				if DEBUG_STK_FAULT 
71c9					DMARK "FA2" 
71c9					CALLMONITOR 
71c9				endif 
71c9 cd 9b 0f			call cmp16 
71cc ca d5 71			jp z, .chk_fault4 
71cf 11 72 72			ld de, sfaultlo 
71d2 c3 eb 71			jp .chk_fault 
71d5			.chk_fault4:  
