0133 3a 94 f9			ld a, (spi_clktime) 
0136			;	cp 0 
0136 b7				or a 
0137 28 03			jr z, .scskip 
0139 cd 56 0a			call aDelayInMS 
013c			.scskip: 
013c f1				pop af 
013d c9				ret 
