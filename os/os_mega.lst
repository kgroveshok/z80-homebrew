20be			; forth parser 
20be			 
20be			; My forth kernel 
20be			include "forth_kernel.asm" 
20be			; 
20be			; kernel to the forth OS 
20be			 
20be			DS_TYPE_STR: equ 1     ; string type 
20be			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
20be			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
20be			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
20be			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
20be			 
20be			FORTH_PARSEV1: equ 0 
20be			FORTH_PARSEV2: equ 0 
20be			FORTH_PARSEV3: equ 0 
20be			FORTH_PARSEV4: equ 0 
20be			FORTH_PARSEV5: equ 0 
20be			FORTH_PARSEV6: equ 1 
20be			 
20be			;if FORTH_PARSEV5 
20be			;	FORTH_END_BUFFER: equ 0 
20be			;else 
20be			FORTH_END_BUFFER: equ 127 
20be			;endif 
20be			 
20be			FORTH_TRUE: equ 1 
20be			FORTH_FALSE: equ 0 
20be			 
20be			if FORTH_PARSEV4 
20be			include "forth_stackops.asm" 
20be			endif 
20be			 
20be			if FORTH_PARSEV5 
20be			include "forth_stackopsv5.asm" 
20be			endif 
20be			 
20be			if FORTH_PARSEV6 
20be			include "forth_stackopsv5.asm" 
20be			 
20be			; Stack operations for v5 parser on wards 
20be			; * DATA stack 
20be			; * LOOP stack 
20be			; * RETURN stack 
20be			 
20be			 
20be			 
20be			FORTH_CHK_DSP_UNDER: macro 
20be				push hl 
20be				push de 
20be				ld hl,(cli_data_sp) 
20be				ld de, cli_data_stack 
20be				call cmp16 
20be				jp c, fault_dsp_under 
20be				pop de 
20be				pop hl 
20be				endm 
20be			 
20be			 
20be			FORTH_CHK_RSP_UNDER: macro 
20be				push hl 
20be				push de 
20be				ld hl,(cli_ret_sp) 
20be				ld de, cli_ret_stack 
20be				call cmp16 
20be				jp c, fault_rsp_under 
20be				pop de 
20be				pop hl 
20be				endm 
20be			 
20be			FORTH_CHK_LOOP_UNDER: macro 
20be				push hl 
20be				push de 
20be				ld hl,(cli_loop_sp) 
20be				ld de, cli_loop_stack 
20be				call cmp16 
20be				jp c, fault_loop_under 
20be				pop de 
20be				pop hl 
20be				endm 
20be			 
20be			FORTH_ERR_TOS_NOTSTR: macro 
20be				; TOSO might need more for checks when used 
20be				push af 
20be				ld a,(hl) 
20be				cp DS_TYPE_STR 
20be				jp nz, type_faultn   
20be				pop af 
20be				endm 
20be			 
20be			FORTH_ERR_TOS_NOTNUM: macro 
20be				push af 
20be				ld a,(hl) 
20be				cp DS_TYPE_INUM 
20be				jp nz, type_faultn   
20be				pop af 
20be				endm 
20be			 
20be			 
20be			; increase data stack pointer and save hl to it 
20be				 
20be			FORTH_DSP_NEXT: macro 
20be				call macro_forth_dsp_next 
20be				endm 
20be			 
20be			 
20be			macro_forth_dsp_next: 
20be				if DEBUG_FORTH_STACK_GUARD 
20be cd e5 65				call check_stacks 
20c1				endif 
20c1 e5				push hl 
20c2 d5				push de 
20c3 eb				ex de,hl 
20c4 2a 0a f9			ld hl,(cli_data_sp) 
20c7 23				inc hl 
20c8 23				inc hl 
20c9			 
20c9			; PARSEV5 
20c9 23				inc hl 
20ca 22 0a f9			ld (cli_data_sp),hl 
20cd 73				ld (hl), e 
20ce 23				inc hl 
20cf 72				ld (hl), d 
20d0 d1				pop de 
20d1 e1				pop hl 
20d2				if DEBUG_FORTH_STACK_GUARD 
20d2 cd e5 65				call check_stacks 
20d5				endif 
20d5 c9				ret 
20d6			 
20d6			 
20d6			; increase ret stack pointer and save hl to it 
20d6				 
20d6			FORTH_RSP_NEXT: macro 
20d6				call macro_forth_rsp_next 
20d6				endm 
20d6			 
20d6			macro_forth_rsp_next: 
20d6				if DEBUG_FORTH_STACK_GUARD 
20d6 cd e5 65				call check_stacks 
20d9				endif 
20d9 e5				push hl 
20da d5				push de 
20db eb				ex de,hl 
