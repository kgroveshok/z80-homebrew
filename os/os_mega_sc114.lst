d5cf			cin_wait: 
d5cf			;	ld a, 0 
d5cf			;	ret 
d5cf			 
d5cf				;in a,(SC114_SIO_1_IN) 
d5cf			        ; Use SCM API to get from whatever console device we are using 
d5cf c5				push bc 
d5d0 0e 01			ld c, $01 
d5d2 f7				rst $30 
d5d3 c1				pop bc 
d5d4 c9				ret 
d5d5			 
d5d5			cinndb: 	 
d5d5			cin: 
d5d5			 
d5d5			 
d5d5 c5				push bc 
d5d6			 
d5d6				; any key waiting to process? 
d5d6 0e 03			ld c, $03 
d5d8 f7				rst $30 
d5d9 28 05			jr z, .cin_skip 
d5db			 
d5db				; yep, get it 
d5db			 
d5db 0e 01			ld c, $01 
d5dd f7				rst $30 
d5de c1				pop bc 
d5df c9				ret 
d5e0			.cin_skip: 
