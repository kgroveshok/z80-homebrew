8c79 83			    add   a, e    ; A = A+L 
8c7a 5f			    ld    e, a    ; L = A+L 
8c7b 8a			    adc   a, d    ; A = A+L+H+carry 
8c7c 93			    sub   e       ; A = H+carry 
8c7d 57			    ld    d, a    ; H = H+carry 
8c7e c9			ret 
