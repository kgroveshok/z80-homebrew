# End of macro CWHEAD
2c9a			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2c9a			; | | At start the current various registers will be displayed with contents. 
2c9a			; | | Top right corner will show the most recent debug marker seen. 
2c9a			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2c9a			; | | and the return stack pointer (RSP). 
2c9a			; | | Pressing: 
2c9a			; | |  
2c9a			; | |    1 - Initial screen 
2c9a			; | |  
2c9a			; | |    2 - Display a data dump of HL 
2c9a			; | |  
2c9a			; | |    3 - Display a data dump of DE 
2c9a			; | |  
2c9a			; | |    4 - Display a data dump of BC 
2c9a			; | |  
2c9a			; | |    5 - Display a data dump of HL 
2c9a			; | |  
2c9a			; | |    6 - Display a data dump of DSP 
2c9a			; | |  
2c9a			; | |    7 - Display a data dump of RSP 
2c9a			; | |  
2c9a			; | |    8 - Display a data dump of what is at DSP 
2c9a			; | |  
2c9a			; | |    9 - Display a data dump of what is at RSP 
2c9a			; | |  
2c9a			; | |    0 - Exit monitor and continue running. This will also enable break points 
2c9a			; | |  
2c9a			; | |    * - Disable break points 
2c9a			; | |  
2c9a			; | |    # - Enter traditional monitor mode 
2c9a			; | |  
2c9a			; | | 
2c9a			; | | Monitor Mode 
2c9a			; | | ------------ 
2c9a			; | | A prompt of '>' will be shown for various commands: 
2c9a			; | |  
2c9a			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2c9a			; | |  
2c9a			; | |    C - Continue display a data dump from the last set address 
2c9a			; | |  
2c9a			; | |    M xxxx - Set start of memory edit at address xx 
2c9a			; | |  
2c9a			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2c9a			; | |  
2c9a			; | |    G xxxx - Exec code at specific address 
2c9a			; | |  
2c9a			; | |    Q - Return to previous 
2c9a				if DEBUG_FORTH_WORDS_KEY 
2c9a					DMARK "MON" 
2c9a				if DEMARK_VERSION = 1  
2c9a e5					push hl  
2c9b 21 a3 2c				ld hl, .dmark  
2c9e 22 9b fd				ld (debug_mark), hl  
2ca1				endif  
2ca1				if DEMARK_VERSION = 0  
2ca1					push af  
2ca1					ld a, (.dmark)  
2ca1					ld (debug_mark),a  
2ca1					ld a, (.dmark+1)  
