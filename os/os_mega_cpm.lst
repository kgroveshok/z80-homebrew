1143			; 
1143			 ;     .org  0x100 
1143			;main: 
1143			 ;     ld    HL, 0x8100 
1143			  ;    ld    SP, HL 
1143			; 
1143			;      call  heap_init 
1143			 
1143			      ; Make some allocations 
1143			;      ld    HL, 12 
1143			;      call  malloc            ; Allocates 0x9004 
1143			; 
1143			 ;     ld    HL, 12 
1143			;      call  malloc            ; Allocates 0x9014 
1143			 
1143			;      ld    HL, 12 
1143			;      call  malloc            ; Allocates 0x9024 
1143			 
1143			      ; Free some allocations 
1143			;      ld    HL, 0x9014 
1143			;      call  free 
1143			 
1143			;      ld    HL, 0x9004 
1143			;      call  free 
1143			; 
1143			;      ld    HL, 0x9024 
1143			;      call  free 
1143			 
1143			 
1143			 ;     halt 
1143			 
1143			 
1143			;------------------------------------------------------------------------------ 
1143			;     heap_init                                                               : 
1143			;                                                                             : 
1143			; Description                                                                 : 
1143			;     Initialise the heap and make it ready for malloc and free operations.   : 
1143			;                                                                             : 
1143			;     The heap is maintained as a linked list, starting with an initial       : 
1143			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1143			;     the first free block in the heap. Each block then points to the next    : 
1143			;     free block within the heap, and the free list ends at the first block   : 
1143			;     with a null pointer to the next free block.                             : 
1143			;                                                                             : 
1143			; Parameters                                                                  : 
1143			;     Inputs are compile-time only. Two defines which specify the starting    : 
1143			;     address of the heap and its size are required, along with a memory      : 
1143			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1143			;     principally stores a pointer to the first free block in the heap.       : 
1143			;                                                                             : 
1143			; Returns                                                                     : 
1143			;     Nothing                                                                 : 
1143			;------------------------------------------------------------------------------ 
1143			heap_init: 
1143			      push  HL 
1143			 
1143			      ; Initialise free list struct 
1143			      ld    HL, heap_start 
1143			      ld    (free_list), HL 
1143			      ld    HL, 0 
1143			      ld    (free_list+2), HL 
1143			 
1143			      ; Insert first free block at bottom of heap, consumes entire heap 
1143			      ld    HL, heap_start+heap_size-4 
1143			      ld    (heap_start), HL        ; Next block (end of free list) 
1143			      ld    HL, heap_size-4 
1143			      ld    (heap_start+2), HL      ; Block size 
1143			 
1143			      ; Insert end of free list block at top of heap - two null words will 
1143			      ; terminate the free list 
1143			      ld    HL, 0 
1143			      ld    (heap_start+heap_size-2), HL 
1143			      ld    (heap_start+heap_size-4), HL 
1143			 
1143			      pop   HL 
1143			 
1143			      ret 
1143			 
1143			 
1143			;------------------------------------------------------------------------------ 
1143			;     malloc                                                                  : 
1143			;                                                                             : 
1143			; Description                                                                 : 
1143			;     Allocates the wanted space from the heap and returns the address of the : 
1143			;     first useable byte of the allocation.                                   : 
1143			;                                                                             : 
1143			;     Allocations can happen in one of two ways:                              : 
1143			;                                                                             : 
1143			;     1. A free block may be found which is the exact size wanted. In this    : 
1143			;        case the block is removed from the free list and retuedn to the      : 
1143			;        caller.                                                              : 
1143			;     2. A free block may be found which is larger than the size wanted. In   : 
1143			;        this case, the larger block is split into two. The first portion of  : 
1143			;        this block will become the requested space by the malloc call and    : 
1143			;        is returned to the caller. The second portion becomes a new free     : 
1143			;        block, and the free list is adjusted to maintain continuity via this : 
1143			;        newly created block.                                                 : 
1143			;                                                                             : 
1143			;     malloc does not set any initial value in the allocated space, the       : 
1143			;     caller is required to do this as required.                              : 
1143			;                                                                             : 
1143			;     This implementation of malloc uses the stack exclusively, and is        : 
1143			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1143			;     advisable to disable interrupts before calling malloc, and recommended  : 
1143			;     to avoid the use of malloc inside ISRs in general.                      : 
1143			;                                                                             : 
1143			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1143			;                                                                             : 
1143			; Parameters                                                                  : 
1143			;     HL  Number of bytes wanted                                              : 
1143			;                                                                             : 
1143			; Returns                                                                     : 
1143			;     HL  Address of the first useable byte of the allocation                 : 
1143			;                                                                             : 
1143			; Flags                                                                       : 
1143			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1143			;                                                                             : 
1143			; Stack frame                                                                 : 
1143			;       |             |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |     BC      |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |     DE      |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |     IX      |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |  prev_free  |                                                       : 
1143			;   +4  +-------------+                                                       : 
1143			;       |  this_free  |                                                       : 
1143			;   +2  +-------------+                                                       : 
1143			;       |  next_free  |                                                       : 
1143			;   +0  +-------------+                                                       : 
1143			;       |             |                                                       : 
1143			;                                                                             : 
1143			;------------------------------------------------------------------------------ 
1143			malloc: 
1143			      push  BC 
1143			      push  DE 
1143			      push  IX 
1143			 
1143			      ld    A, H                    ; Exit if no space requested 
1143			      or    L 
1143			      jp    Z, malloc_early_exit 
1143			 
1143			      ; Set up stack frame 
1143			      ex    DE, HL 
1143			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1143			      add   HL, SP 
1143			      ld    SP, HL 
1143			      ld    IX, 0                   ; Use IX as a frame pointer 
1143			      add   IX, SP 
1143			 
1143			      ; Setup initial state 
1143			      ld    HL, 4                   ; want must also include space used by block struct 
1143			      add   HL, DE 
1143			 
1143			      ld    B, H                    ; Move want to BC 
1143			      ld    C, L 
1143			 
1143			      ld    HL, free_list           ; Store prev_free ptr to stack 
1143			      ld    (IX+4), L 
1143			      ld    (IX+5), H 
1143			 
1143			      ld    E, (HL)                 ; Store this_free ptr to stack 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      ld    (IX+2), E 
1143			      ld    (IX+3), D 
1143			      ex    DE, HL                  ; this_free ptr into HL 
1143			 
1143			      ; Loop through free block list to find some space 
1143			malloc_find_space: 
1143			      ld    E, (HL)                 ; Load next_free ptr into DE 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			 
1143			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1143			      or    E 
1143			      jp    Z, malloc_no_space 
1143			 
1143			      ld    (IX+0), E               ; Store next_free ptr to stack 
1143			      ld    (IX+1), D 
1143			 
1143			      ; Does this block have enough space to make the allocation? 
1143			      inc   HL                      ; Load free block size into DE 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			 
1143			      ex    DE, HL                  ; Check size of block against want 
1143			      or    A                       ; Ensure carry flag clear 
1143			      sbc   HL, BC 
1143			      push  HL                      ; Store the result for later (new block size) 
1143			 
1143			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1143			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1143			 
1143			      ; this_free block is not big enough, setup ptrs to test next free block 
1143			      pop   HL                      ; Discard previous result 
1143			 
1143			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1143			      ld    H, (IX+3) 
1143			      ld    (IX+4), L 
1143			      ld    (IX+5), H 
1143			 
1143			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1143			      ld    H, (IX+1) 
1143			      ld    (IX+2), L 
1143			      ld    (IX+3), H 
1143			 
1143			      jr    malloc_find_space 
1143			 
1143			      ; split a bigger block into two - requested size and remaining size 
1143			malloc_alloc_split: 
1143			      ex    DE, HL                  ; Calculate address of new free block 
1143			      dec   HL 
1143			      dec   HL 
1143			      dec   HL 
1143			      add   HL, BC 
1143			 
1143			      ; Create a new block and point it at next_free 
1143			      ld    E, (IX+0)               ; Load next_free ptr into DE 
1143			      ld    D, (IX+1) 
1143			 
1143			      ld    (HL), E                 ; Store next_free ptr into new block 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			      pop   DE                      ; Store size of new block into new block 
1143			      inc   HL 
1143			      ld    (HL), E 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			      ; Update this_free ptr to point to new block 
1143			      dec   HL 
1143			      dec   HL 
1143			      dec   HL 
1143			 
1143			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1143			      ld    D, (IX+3) 
1143			 
1143			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
1143			      ld    (IX+3), H 
1143			 
1143			      ; Modify this_free block to be allocation 
1143			      ex    DE, HL 
1143			      xor   A                       ; Null the next block ptr of allocated block 
1143			      ld    (HL), A 
1143			      inc   HL 
1143			      ld    (HL), A 
1143			 
1143			      inc   HL                      ; Store want size into allocated block 
1143			      ld    (HL), C 
1143			      inc   HL 
1143			      ld    (HL), B 
1143			      inc   HL 
1143			      push  HL                      ; Address of allocation to return 
1143			 
1143			      jr    malloc_update_links 
1143			 
1143			malloc_alloc_fit: 
1143			      pop   HL                      ; Dont need new block size, want is exact fit 
1143			 
1143			      ; Modify this_free block to be allocation 
1143			      ex    DE, HL 
1143			      dec   HL 
1143			      dec   HL 
1143			      dec   HL 
1143			 
1143			      xor   A                       ; Null the next block ptr of allocated block 
1143			      ld    (HL), A 
1143			      inc   HL 
1143			      ld    (HL), A 
1143			 
1143			      inc   HL                      ; Store address of allocation to return 
1143			      inc   HL 
1143			      inc   HL 
1143			      push  HL 
1143			 
1143			      ; Copy next_free ptr to this_free, remove allocated block from free list 
1143			      ld    L, (IX+0)               ; next_free to HL 
1143			      ld    H, (IX+1) 
1143			 
1143			      ld    (IX+2), L               ; HL to this_free 
1143			      ld    (IX+3), H 
1143			 
1143			 
1143			malloc_update_links: 
1143			      ; Update prev_free ptr to point to this_free 
1143			      ld    L, (IX+4)               ; prev_free ptr to HL 
1143			      ld    H, (IX+5) 
1143			 
1143			      ld    E, (IX+2)               ; this_free ptr to DE 
1143			      ld    D, (IX+3) 
1143			 
1143			      ld    (HL), E                 ; this_free ptr into prev_free 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			      ; Clear the Z flag to indicate successful allocation 
1143			      ld    A, D 
1143			      or    E 
1143			 
1143			      pop   DE                      ; Address of allocation 
1143			 
1143			malloc_no_space: 
1143			      ld    HL, 6                   ; Clean up stack frame 
1143			      add   HL, SP 
1143			      ld    SP, HL 
1143			 
1143			      ex    DE, HL                  ; Alloc addr into HL for return 
1143			 
1143			malloc_early_exit: 
1143			      pop   IX 
1143			      pop   DE 
1143			      pop   BC 
1143			 
1143			      ret 
1143			 
1143			 
1143			;------------------------------------------------------------------------------ 
1143			;     free                                                                    : 
1143			;                                                                             : 
1143			; Description                                                                 : 
1143			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1143			;     returned by malloc, otherwise the behaviour is undefined.               : 
1143			;                                                                             : 
1143			;     Where possible, directly adjacent free blocks will be merged together   : 
1143			;     into larger blocks to help ensure that the heap does not become         : 
1143			;     excessively fragmented.                                                 : 
1143			;                                                                             : 
1143			;     free does not clear or set any other value into the freed space, and    : 
1143			;     therefore its contents may be visible through subsequent malloc's. The  : 
1143			;     caller should clear the freed space as required.                        : 
1143			;                                                                             : 
1143			;     This implementation of free uses the stack exclusively, and is          : 
1143			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1143			;     advisable to disable interrupts before calling free, and recommended    : 
1143			;     to avoid the use of free inside ISRs in general.                        : 
1143			;                                                                             : 
1143			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1143			;                                                                             : 
1143			; Parameters                                                                  : 
1143			;     HL  Pointer to address of first byte of allocation to be freed          : 
1143			;                                                                             : 
1143			; Returns                                                                     : 
1143			;     Nothing                                                                 : 
1143			;                                                                             : 
1143			; Stack frame                                                                 : 
1143			;       |             |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |     BC      |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |     DE      |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |     IX      |                                                       : 
1143			;       +-------------+                                                       : 
1143			;       |  prev_free  |                                                       : 
1143			;   +2  +-------------+                                                       : 
1143			;       |  next_free  |                                                       : 
1143			;   +0  +-------------+                                                       : 
1143			;       |             |                                                       : 
1143			;                                                                             : 
1143			;------------------------------------------------------------------------------ 
1143			free: 
1143			      push  BC 
1143			      push  DE 
1143			      push  IX 
1143			 
1143			      ld    A, H                    ; Exit if ptr is null 
1143			      or    L 
1143			      jp    Z, free_early_exit 
1143			 
1143			      ; Set up stack frame 
1143			      ex    DE, HL 
1143			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1143			      add   HL, SP 
1143			      ld    SP, HL 
1143			      ld    IX, 0                   ; Use IX as a frame pointer 
1143			      add   IX, SP 
1143			 
1143			      ; The address in HL points to the start of the useable allocated space, 
1143			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1143			      ; address of the block itself. 
1143			      ex    DE, HL 
1143			      ld    DE, -4 
1143			      add   HL, DE 
1143			 
1143			      ; An allocated block must have a null next block pointer in it 
1143			      ld    A, (HL) 
1143			      inc   HL 
1143			      or    (HL) 
1143			      jp    NZ, free_done 
1143			 
1143			      dec   HL 
1143			 
1143			      ld    B, H                    ; Copy HL to BC 
1143			      ld    C, L 
1143			 
1143			      ; Loop through the free list to find the first block with an address 
1143			      ; higher than the block being freed 
1143			      ld    HL, free_list 
1143			 
1143			free_find_higher_block: 
1143			      ld    E, (HL)                 ; Load next ptr from free block 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      dec   HL 
1143			 
1143			      ld    (IX+0), E               ; Save ptr to next free block 
1143			      ld    (IX+1), D 
1143			      ld    (IX+2), L               ; Save ptr to prev free block 
1143			      ld    (IX+3), H 
1143			 
1143			      ld    A, B                    ; Check if DE is greater than BC 
1143			      cp    D                       ; Compare MSB first 
1143			      jr    Z, $+4                  ; MSB the same, compare LSB 
1143			      jr    NC, free_find_higher_block_skip 
1143			      ld    A, C 
1143			      cp    E                       ; Then compare LSB 
1143			      jr    C, free_found_higher_block 
1143			 
1143			free_find_higher_block_skip: 
1143			      ld    A, D                    ; Reached the end of the free list? 
1143			      or    E 
1143			      jp    Z, free_done 
1143			 
1143			      ex    DE, HL 
1143			 
1143			      jr    free_find_higher_block 
1143			 
1143			free_found_higher_block: 
1143			      ; Insert freed block between prev and next free blocks 
1143			      ld    (HL), C                 ; Point prev free block to freed block 
1143			      inc   HL 
1143			      ld    (HL), B 
1143			 
1143			      ld    H, B                    ; Point freed block at next free block 
1143			      ld    L, C 
1143			      ld    (HL), E 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			      ; Check if the freed block is adjacent to the next free block 
1143			      inc   HL                      ; Load size of freed block into HL 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      ex    DE, HL 
1143			 
1143			      add   HL, BC                  ; Add addr of freed block and its size 
1143			 
1143			      ld    E, (IX+0)               ; Load addr of next free block into DE 
1143			      ld    D, (IX+1) 
1143			 
1143			      or    A                       ; Clear the carry flag 
1143			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1143			      jr    NZ, free_check_adjacent_to_prev 
1143			 
1143			      ; Freed block is adjacent to next, merge into one bigger block 
1143			      ex    DE, HL                  ; Load next ptr from next block into DE 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      push  HL                      ; Save ptr to next block for later 
1143			 
1143			      ld    H, B                    ; Store ptr from next block into freed block 
1143			      ld    L, C 
1143			      ld    (HL), E 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			      pop   HL                      ; Restore ptr to next block 
1143			      inc   HL                      ; Load size of next block into DE 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      push  DE                      ; Save next block size for later 
1143			 
1143			      ld    H, B                    ; Load size of freed block into HL 
1143			      ld    L, C 
1143			      inc   HL 
1143			      inc   HL 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      ex    DE, HL 
1143			 
1143			      pop   DE                      ; Restore size of next block 
1143			      add   HL, DE                  ; Add sizes of both blocks 
1143			      ex    DE, HL 
1143			 
1143			      ld    H, B                    ; Store new bigger size into freed block 
1143			      ld    L, C 
1143			      inc   HL 
1143			      inc   HL 
1143			      ld    (HL), E 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			free_check_adjacent_to_prev: 
1143			      ; Check if the freed block is adjacent to the prev free block 
1143			      ld    L, (IX+2)               ; Prev free block ptr into HL 
1143			      ld    H, (IX+3) 
1143			 
1143			      inc   HL                      ; Size of prev free block into DE 
1143			      inc   HL 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      dec   HL 
1143			      dec   HL 
1143			      dec   HL 
1143			 
1143			      add   HL, DE                  ; Add prev block addr and size 
1143			 
1143			      or    A                       ; Clear the carry flag 
1143			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1143			      jr    NZ, free_done 
1143			 
1143			      ; Freed block is adjacent to prev, merge into one bigger block 
1143			      ld    H, B                    ; Load next ptr from freed block into DE 
1143			      ld    L, C 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      push  HL                      ; Save freed block ptr for later 
1143			 
1143			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1143			      ld    H, (IX+3) 
1143			      ld    (HL), E 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			      pop   HL                      ; Restore freed block ptr 
1143			      inc   HL                      ; Load size of freed block into DE 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			      push  DE                      ; Save freed block size for later 
1143			 
1143			      ld    L, (IX+2)               ; Load size of prev block into DE 
1143			      ld    H, (IX+3) 
1143			      inc   HL 
1143			      inc   HL 
1143			      ld    E, (HL) 
1143			      inc   HL 
1143			      ld    D, (HL) 
1143			 
1143			      pop   HL                      ; Add sizes of both blocks 
1143			      add   HL, DE 
1143			      ex    DE, HL 
1143			 
1143			      ld    L, (IX+2)               ; Store new bigger size into prev block 
1143			      ld    H, (IX+3) 
1143			      inc   HL 
1143			      inc   HL 
1143			      ld    (HL), E 
1143			      inc   HL 
1143			      ld    (HL), D 
1143			 
1143			free_done: 
1143			      ld    HL, 4                   ; Clean up stack frame 
1143			      add   HL, SP 
1143			      ld    SP, HL 
1143			 
1143			free_early_exit: 
1143			      pop   IX 
1143			      pop   DE 
1143			      pop   BC 
1143			 
1143			      ret 
1143			 
1143			 
1143			;      .org 0x8000 
1143			; 
1143			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
1143			 ;                 .dw   0 
1143			 
1143			endif 
1143			 
1143			 
1143			if MALLOC_4 
1143			 
1143			; My memory allocation code. Very very simple.... 
1143			; allocate space under 250 chars 
1143			 
1143			heap_init: 
1143				; init start of heap as zero 
1143				;  
1143			 
1143				ld hl, heap_start 
1143			;	ld a, 0 
1143				ld (hl), 0      ; empty block 
1143				inc hl 
1143			;	ld a, 0 
1143				ld (hl), 0      ; length of block 
1143				; write end of list 
1143				inc hl 
1143				ld a,(hl) 
1143				inc hl 
1143				ld a,(hl) 
1143				 
1143			 
1143				; init some malloc vars 
1143			 
1143				ld hl, 0 
1143				ld (free_list), hl       ; store last malloc location 
1143			 
1143				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
1143			;	ld a, 0 
1143				ld (hl), 0 
1143			 
1143			 
1143				ld hl, heap_start 
1143				;  
1143				  
1143				ret 
1143			 
1143			 
1143			;    free block marker 
1143			;    requested size  
1143			;    pointer to next block 
1143			;    .... 
1143			;    next block marker 
1143			 
1143			 
1143			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
1143			; 
1143			 
1143			 
1143			malloc:  
1143				push de 
1143				push bc 
1143				push af 
1143			 
1143				; hl space required 
1143				 
1143				ld c, l    ; hold space   (TODO only a max of 255) 
1143			 
1143			;	inc c     ; TODO BUG need to fix memory leak on push str 
1143			;	inc c 
1143			;	inc c 
1143			;	inc c 
1143			;	inc c 
1143			;	inc c 
1143			;	inc c 
1143			 
1143			 
1143			 
1143				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
1143			 
1143				ld a, (free_list+3) 
1143			;	cp 0 
1143				or a 
1143				jr z, .contheap 
1143			 
1143				ld hl, (free_list)     ; get last alloc 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "mrs" 
1143						CALLMONITOR 
1143					endif 
1143				jr .startalloc 
1143			 
1143			.contheap: 
1143				ld hl, heap_start 
1143			 
1143			.startalloc: 
1143			 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "mym" 
1143						CALLMONITOR 
1143					endif 
1143			.findblock: 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "mmf" 
1143						CALLMONITOR 
1143					endif 
1143			 
1143				ld a,(hl)  
1143				; if byte is zero then clear to use 
1143			 
1143			;	cp 0 
1143				or a 
1143				jr z, .foundemptyblock 
1143			 
1143				; if byte is not clear 
1143				;     then byte is offset to next block 
1143			 
1143				inc hl 
1143				ld a, (hl) ; get size 
1143			.nextblock:	inc hl 
1143					ld e, (hl) 
1143					inc hl 
1143					ld d, (hl) 
1143					ex de, hl 
1143			;	inc hl  ; move past the store space 
1143			;	inc hl  ; move past zero index  
1143			 
1143				; TODO detect no more space 
1143			 
1143				push hl 
1143				ld de, heap_end 
1143				call cmp16 
1143				pop hl 
1143				jr nc, .nospace 
1143			 
1143				jr .findblock 
1143			 
1143			.nospace: ld hl, 0 
1143				jp .exit 
1143			 
1143			 
1143			.foundemptyblock:	 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "mme" 
1143						CALLMONITOR 
1143					endif 
1143			 
1143			; TODO has block enough space if reusing??? 
1143			 
1143				;  
1143			 
1143			; see if this block has been previously used 
1143				inc hl 
1143				ld a, (hl) 
1143				dec hl 
1143			;	cp 0 
1143				or a 
1143				jr z, .newblock 
1143			 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "meR" 
1143						CALLMONITOR 
1143					endif 
1143			 
1143			; no reusing previously allocated block 
1143			 
1143			; is it smaller than previously used? 
1143				 
1143				inc hl    ; move to size 
1143				ld a, c 
1143				sub (hl)        ; we want c < (hl) 
1143				dec hl    ; move back to marker 
1143			        jr z, .findblock 
1143			 
1143				; update with the new size which should be lower 
1143			 
1143			        ;inc  hl   ; negate next move. move back to size  
1143			 
1143			.newblock: 
1143				; need to be at marker here 
1143			 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "meN" 
1143						CALLMONITOR 
1143					endif 
1143			 
1143			 
1143				ld a, c 
1143			 
1143				ld (free_list+3), a	 ; flag resume from last malloc  
1143				ld (free_list), hl    ; save out last location 
1143			 
1143			 
1143				;inc a     ; space for length byte 
1143				ld (hl), a     ; save block in use marker 
1143			 
1143				inc hl   ; move to space marker 
1143				ld (hl), a    ; save new space 
1143			 
1143				inc hl   ; move to start of allocated area 
1143				 
1143			;	push hl     ; save where we are - 1  
1143			 
1143			;	inc hl  ; move past zero index  
1143				; skip space to set down new marker 
1143			 
1143				; provide some extra space for now 
1143			 
1143				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
1143				inc a 
1143				inc a 
1143			 
1143				push hl   ; save where we are in the node block 
1143			 
1143				call addatohl 
1143			 
1143				; write linked list point 
1143			 
1143				pop de     ; get our node position 
1143				ex de, hl 
1143			 
1143				ld (hl), e 
1143				inc hl 
1143				ld (hl), d 
1143			 
1143				inc hl 
1143			 
1143				; now at start of allocated data so save pointer 
1143			 
1143				push hl 
1143			 
1143				; jump to position of next node and setup empty header in DE 
1143			 
1143				ex de, hl 
1143			 
1143			;	inc hl ; move past end of block 
1143			 
1143			;	ld a, 0 
1143				ld (hl), 0   ; empty marker 
1143				inc hl 
1143				ld (hl), 0   ; size 
1143				inc hl  
1143				ld (hl), 0   ; ptr 
1143				inc hl 
1143				ld (hl), 0   ; ptr 
1143			 
1143			 
1143				pop hl 
1143			 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "mmr" 
1143						CALLMONITOR 
1143					endif 
1143			 
1143			.exit: 
1143				pop af 
1143				pop bc 
1143				pop de  
1143				ret 
1143			 
1143			 
1143			 
1143			 
1143			free:  
1143				push hl 
1143				push af 
1143				; get address in hl 
1143			 
1143					if DEBUG_FORTH_MALLOC_INT 
1143						DMARK "fre" 
1143						CALLMONITOR 
1143					endif 
1143				; data is at hl - move to block count 
1143				dec hl 
1143				dec hl    ; get past pointer 
1143				dec hl 
1143			 
1143				ld a, (hl)    ; need this for a validation check 
1143			 
1143				dec hl    ; move to block marker 
1143			 
1143				; now check that the block count and block marker are the same  
1143			        ; this checks that we are on a malloc node and not random memory 
1143			        ; OK a faint chance this could be a problem but rare - famous last words! 
1143			 
1143				ld c, a 
1143				ld a, (hl)    
1143			 
1143				cp c 
1143				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
1143			 
1143				; yes good chance we are on a malloc node 
1143			 
1143			;	ld a, 0      
1143				ld (hl), 0   ; mark as free 
1143			 
1143				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
1143			 
1143			.freeignore:  
1143			 
1143				pop af 
1143				pop hl 
1143			 
1143				ret 
1143			 
1143			 
1143			 
1143			endif 
1143			 
