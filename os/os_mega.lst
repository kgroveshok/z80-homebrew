2070			endif 
2070			 
2070			if FORTH_PARSEV6 
2070			include "forth_stackopsv5.asm" 
2070			 
2070			; Stack operations for v5 parser on wards 
2070			; * DATA stack 
2070			; * LOOP stack 
2070			; * RETURN stack 
2070			 
2070			 
2070			 
2070			FORTH_CHK_DSP_UNDER: macro 
2070				push hl 
2070				push de 
2070				ld hl,(cli_data_sp) 
2070				ld de, cli_data_stack 
2070				call cmp16 
2070				jp c, fault_dsp_under 
2070				pop de 
2070				pop hl 
2070				endm 
2070			 
2070			 
2070			FORTH_CHK_RSP_UNDER: macro 
2070				push hl 
2070				push de 
2070				ld hl,(cli_ret_sp) 
2070				ld de, cli_ret_stack 
2070				call cmp16 
2070				jp c, fault_rsp_under 
2070				pop de 
2070				pop hl 
2070				endm 
2070			 
2070			FORTH_CHK_LOOP_UNDER: macro 
2070				push hl 
2070				push de 
2070				ld hl,(cli_loop_sp) 
2070				ld de, cli_loop_stack 
2070				call cmp16 
2070				jp c, fault_loop_under 
2070				pop de 
2070				pop hl 
2070				endm 
2070			 
2070			FORTH_ERR_TOS_NOTSTR: macro 
2070				; TOSO might need more for checks when used 
2070				push af 
2070				ld a,(hl) 
2070				cp DS_TYPE_STR 
2070				jp nz, type_faultn   
2070				pop af 
2070				endm 
2070			 
2070			FORTH_ERR_TOS_NOTNUM: macro 
2070				push af 
2070				ld a,(hl) 
2070				cp DS_TYPE_INUM 
2070				jp nz, type_faultn   
2070				pop af 
2070				endm 
2070			 
2070			 
2070			; increase data stack pointer and save hl to it 
2070				 
2070			FORTH_DSP_NEXT: macro 
2070				call macro_forth_dsp_next 
2070				endm 
2070			 
2070			 
2070			macro_forth_dsp_next: 
2070				if DEBUG_FORTH_STACK_GUARD 
2070 cd bf 65				call check_stacks 
2073				endif 
2073 e5				push hl 
2074 d5				push de 
2075 eb				ex de,hl 
2076 2a 0a f9			ld hl,(cli_data_sp) 
2079 23				inc hl 
207a 23				inc hl 
207b			 
207b			; PARSEV5 
207b 23				inc hl 
207c 22 0a f9			ld (cli_data_sp),hl 
207f 73				ld (hl), e 
2080 23				inc hl 
2081 72				ld (hl), d 
2082 d1				pop de 
2083 e1				pop hl 
2084				if DEBUG_FORTH_STACK_GUARD 
2084 cd bf 65				call check_stacks 
2087				endif 
2087 c9				ret 
2088			 
2088			 
2088			; increase ret stack pointer and save hl to it 
