247d			; A better parser without using malloc and string copies all over the place.  
247d			; Exec in situ should be faster 
247d			 
247d			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
247d			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
247d			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
247d			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
247d			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
247d			WORD_SYS_END: equ 0   ; Opcode for all user words 
247d			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
247d			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
247d			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
247d			 
247d			; Core word preamble macro 
247d			 
247d			CWHEAD:   macro nxtword opcode lit len opflags 
247d				db WORD_SYS_CORE+opcode             
247d				; internal op code number 
247d				dw nxtword            
247d				; link to next dict word block 
247d				db len + 1 
247d				; literal length of dict word inc zero term 
247d				db lit,0              
247d				; literal dict word 
247d			        ; TODO db opflags        
247d				endm 
