0cb9			;;;; int maths 
0cb9			 
0cb9			; https://map.grauw.nl/articles/mult_div_shifts.php 
0cb9			; Divide 16-bit values (with 16-bit result) 
0cb9			; In: Divide BC by divider DE 
0cb9			; Out: BC = result, HL = rest 
0cb9			; 
0cb9			Div16: 
0cb9 21 00 00		    ld hl,0 
0cbc 78			    ld a,b 
0cbd 06 08		    ld b,8 
0cbf			Div16_Loop1: 
0cbf 17			    rla 
0cc0 ed 6a		    adc hl,hl 
0cc2 ed 52		    sbc hl,de 
0cc4 30 01		    jr nc,Div16_NoAdd1 
0cc6 19			    add hl,de 
0cc7			Div16_NoAdd1: 
0cc7 10 f6		    djnz Div16_Loop1 
0cc9 17			    rla 
0cca 2f			    cpl 
0ccb 47			    ld b,a 
0ccc 79			    ld a,c 
0ccd 48			    ld c,b 
0cce 06 08		    ld b,8 
0cd0			Div16_Loop2: 
0cd0 17			    rla 
0cd1 ed 6a		    adc hl,hl 
0cd3 ed 52		    sbc hl,de 
0cd5 30 01		    jr nc,Div16_NoAdd2 
0cd7 19			    add hl,de 
0cd8			Div16_NoAdd2: 
0cd8 10 f6		    djnz Div16_Loop2 
0cda 17			    rla 
0cdb 2f			    cpl 
0cdc 41			    ld b,c 
0cdd 4f			    ld c,a 
0cde c9			ret 
0cdf			 
0cdf			 
0cdf			;http://z80-heaven.wikidot.com/math 
0cdf			; 
0cdf			;Inputs: 
0cdf			;     DE and A are factors 
0cdf			;Outputs: 
0cdf			;     A is not changed 
0cdf			;     B is 0 
0cdf			;     C is not changed 
0cdf			;     DE is not changed 
0cdf			;     HL is the product 
0cdf			;Time: 
0cdf			;     342+6x 
0cdf			; 
0cdf			Mult16: 
0cdf			 
0cdf 06 08		     ld b,8          ;7           7 
0ce1 21 00 00		     ld hl,0         ;10         10 
0ce4 29			       add hl,hl     ;11*8       88 
0ce5 07			       rlca          ;4*8        32 
0ce6 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0ce8 19			         add hl,de   ;--         -- 
0ce9 10 f9		       djnz $-5      ;13*7+8     99 
0ceb c9			ret 
0cec			 
0cec			; 
