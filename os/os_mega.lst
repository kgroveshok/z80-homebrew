1065			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
1065			 
1065			; String Length 
1065			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
1065			 
1065			; Get the length of the null-terminated string starting at $8000 hl 
1065			;    LD     HL, $8000 
1065			 
1065			strlenz: 
1065			 
1065 af			    XOR    A               ; Zero is the value we are looking for. 
1066 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
1067 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
1068			                           ; 65, 536 bytes (the entire addressable memory space). 
1068 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
106a			 
106a			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
106a 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
106b 6f			    LD     L, A             ; number of bytes 
106c ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
106e 2b			    DEC    HL              ; Compensate for null. 
106f c9				ret 
1070			 
1070			; Get the length of the A terminated string starting at $8000 hl 
1070			;    LD     HL, $8000 
1070			 
1070			strlent: 
1070			 
1070			                  ; A is the value we are looking for. 
1070 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
1072 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
1074			                           ; 65, 536 bytes (the entire addressable memory space). 
1074 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
1076			 
1076			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
1076 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
1078 2e 00		    LD     L, 0             ; number of bytes 
107a ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
107c 2b			    DEC    HL              ; Compensate for null. 
107d c9				ret 
107e			 
107e			 
107e			;Comparing Strings 
107e			 
107e			;IN    HL     Address of string1. 
107e			;      DE     Address of string2. 
107e			 
107e			; doc given but wrong??? 
107e			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
107e			;      carry  Set if string1 > string2, reset if string1 <= string2. 
107e			; tested 
107e			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
107e			 
107e			strcmp_old: 
107e e5			    PUSH   HL 
107f d5			    PUSH   DE 
1080			 
1080 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
1081 be			    CP     (HL)            ; (want to minimize work). 
1082 38 01		    JR     C, Str1IsBigger 
1084 7e			    LD     A, (HL) 
1085			 
1085			Str1IsBigger: 
1085 4f			    LD     C, A             ; Put length in BC 
1086 06 00		    LD     B, 0 
1088 13			    INC    DE              ; Increment pointers to meat of string. 
1089 23			    INC    HL 
108a			 
108a			CmpLoop: 
108a 1a			    LD     A, (DE)          ; Compare bytes. 
108b ed a1		    CPI 
108d 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
108f 13			    INC    DE              ; Update pointer. 
1090 ea 8a 10		    JP     PE, CmpLoop 
1093			 
1093 d1			    POP    DE 
1094 e1			    POP    HL 
1095 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
1096 be			    CP     (HL) 
1097 c9			    RET 
1098			 
1098			NoMatch: 
1098 2b			    DEC    HL 
1099 be			    CP     (HL)            ; Compare again to affect carry. 
109a d1			    POP    DE 
109b e1			    POP    HL 
109c c9			    RET 
109d			 
