100c 1a			strcpy:   LD   A, (DE)        ;Get character from string 
100d b7			            OR   A              ;Null terminator? 
100e c8			            RET  Z              ;Yes, so finished 
100f 1a					ld a,(de) 
1010 77					ld (hl),a 
1011 13			            INC  DE             ;Point to next character 
1012 23					inc hl 
1013 18 f7		            JR   strcpy       ;Repeat 
1015 c9					ret 
