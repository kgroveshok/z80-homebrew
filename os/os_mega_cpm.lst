1e7b			user_word_eol:  
1e7b				; hl contains the pointer to where to create a linked list item from the end 
1e7b				; of the user dict to continue on at the system word dict 
1e7b				 
1e7b				; poke the stub of the word list linked list to repoint to rom words 
1e7b			 
1e7b				; stub format 
1e7b				; db   word id 
1e7b				; dw    link to next word 
1e7b			        ; db char length of token 
1e7b				; db string + 0 term 
1e7b				; db exec code....  
1e7b			 
1e7b			;	ld a, WORD_SYS_ROOT     ; root word 
1e7b 36 00			ld (hl), WORD_SYS_ROOT		; word id 
1e7d 23				inc hl 
1e7e			 
1e7e 11 27 20			ld de, sysdict 
1e81 73				ld (hl), e		; next word link ie system dict 
1e82 23				inc hl 
1e83 72				ld (hl), d		; next word link ie system dict 
1e84 23				inc hl	 
1e85			 
1e85			;	ld (hl), sysdict		; next word link ie system dict 
1e85			;	inc hl 
1e85			;	inc hl 
1e85			 
1e85			;	inc hl 
1e85			;	inc hl 
1e85			 
1e85			;	ld a, 2			; word length is 0 
1e85 36 02			ld (hl), 2 
1e87 23				inc hl 
1e88			 
1e88			;	ld a, '~'			; word length is 0 
1e88 36 7e			ld (hl), '~' 
1e8a 23				inc hl 
1e8b			;	ld a, 0			; save empty word 
1e8b 36 00			ld (hl), 0 
1e8d			 
