92b4				call storage_append 
92b4			 
92b4				pop de 
92b4				pop hl 
92b4			 
92b4				inc de 
92b4				inc de 
92b4			 
92b4				ld a,(de) 
92b4				cp 0 
92b4				jr nz, .genloop 
92b4				inc de 
92b4				ld a, (de) 
92b4				dec de 
92b4				cp 0 
92b4				jr nz, .genloop	 
92b4			 
92b4				ret 
