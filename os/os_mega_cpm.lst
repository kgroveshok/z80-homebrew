0f86			;------------------------------------------------------------------------------ 
0f86			;     heap_init                                                               : 
0f86			;                                                                             : 
0f86			; Description                                                                 : 
0f86			;     Initialise the heap and make it ready for malloc and free operations.   : 
0f86			;                                                                             : 
0f86			;     The heap is maintained as a linked list, starting with an initial       : 
0f86			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
0f86			;     the first free block in the heap. Each block then points to the next    : 
0f86			;     free block within the heap, and the free list ends at the first block   : 
0f86			;     with a null pointer to the next free block.                             : 
0f86			;                                                                             : 
0f86			; Parameters                                                                  : 
0f86			;     Inputs are compile-time only. Two defines which specify the starting    : 
0f86			;     address of the heap and its size are required, along with a memory      : 
0f86			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
0f86			;     principally stores a pointer to the first free block in the heap.       : 
0f86			;                                                                             : 
0f86			; Returns                                                                     : 
0f86			;     Nothing                                                                 : 
0f86			;------------------------------------------------------------------------------ 
0f86			heap_init: 
0f86 e5			      push  HL 
0f87			 
0f87			      ; Initialise free list struct 
0f87 21 4f 59		      ld    HL, heap_start 
0f8a 22 4a 59		      ld    (free_list), HL 
0f8d 21 00 00		      ld    HL, 0 
0f90 22 4c 59		      ld    (free_list+2), HL 
0f93			 
0f93			      ; Insert first free block at bottom of heap, consumes entire heap 
0f93 21 8d e2		      ld    HL, heap_start+heap_size-4 
0f96 22 4f 59		      ld    (heap_start), HL        ; Next block (end of free list) 
0f99 21 3e 89		      ld    HL, heap_size-4 
0f9c 22 51 59		      ld    (heap_start+2), HL      ; Block size 
0f9f			 
0f9f			      ; Insert end of free list block at top of heap - two null words will 
0f9f			      ; terminate the free list 
0f9f 21 00 00		      ld    HL, 0 
0fa2 22 8f e2		      ld    (heap_start+heap_size-2), HL 
0fa5 22 8d e2		      ld    (heap_start+heap_size-4), HL 
0fa8			 
0fa8 e1			      pop   HL 
0fa9			 
0fa9 c9			      ret 
0faa			 
0faa			 
0faa			;------------------------------------------------------------------------------ 
0faa			;     malloc                                                                  : 
0faa			;                                                                             : 
0faa			; Description                                                                 : 
0faa			;     Allocates the wanted space from the heap and returns the address of the : 
0faa			;     first useable byte of the allocation.                                   : 
0faa			;                                                                             : 
0faa			;     Allocations can happen in one of two ways:                              : 
0faa			;                                                                             : 
0faa			;     1. A free block may be found which is the exact size wanted. In this    : 
0faa			;        case the block is removed from the free list and retuedn to the      : 
0faa			;        caller.                                                              : 
0faa			;     2. A free block may be found which is larger than the size wanted. In   : 
0faa			;        this case, the larger block is split into two. The first portion of  : 
0faa			;        this block will become the requested space by the malloc call and    : 
0faa			;        is returned to the caller. The second portion becomes a new free     : 
0faa			;        block, and the free list is adjusted to maintain continuity via this : 
0faa			;        newly created block.                                                 : 
0faa			;                                                                             : 
0faa			;     malloc does not set any initial value in the allocated space, the       : 
0faa			;     caller is required to do this as required.                              : 
0faa			;                                                                             : 
0faa			;     This implementation of malloc uses the stack exclusively, and is        : 
0faa			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
0faa			;     advisable to disable interrupts before calling malloc, and recommended  : 
0faa			;     to avoid the use of malloc inside ISRs in general.                      : 
0faa			;                                                                             : 
0faa			;     NOTE: heap_init must be called before malloc and free can be used.      : 
0faa			;                                                                             : 
0faa			; Parameters                                                                  : 
0faa			;     HL  Number of bytes wanted                                              : 
0faa			;                                                                             : 
0faa			; Returns                                                                     : 
0faa			;     HL  Address of the first useable byte of the allocation                 : 
0faa			;                                                                             : 
0faa			; Flags                                                                       : 
0faa			;     Z   Set if the allocation did not succeed, clear otherwise              : 
0faa			;                                                                             : 
0faa			; Stack frame                                                                 : 
0faa			;       |             |                                                       : 
0faa			;       +-------------+                                                       : 
0faa			;       |     BC      |                                                       : 
0faa			;       +-------------+                                                       : 
0faa			;       |     DE      |                                                       : 
0faa			;       +-------------+                                                       : 
0faa			;       |     IX      |                                                       : 
0faa			;       +-------------+                                                       : 
0faa			;       |  prev_free  |                                                       : 
0faa			;   +4  +-------------+                                                       : 
0faa			;       |  this_free  |                                                       : 
0faa			;   +2  +-------------+                                                       : 
0faa			;       |  next_free  |                                                       : 
0faa			;   +0  +-------------+                                                       : 
0faa			;       |             |                                                       : 
0faa			;                                                                             : 
0faa			;------------------------------------------------------------------------------ 
0faa			 
0faa			 
0faa			;malloc: 
0faa			; 
0faa			;	SAVESP ON 1 
0faa			; 
0faa			;	call malloc_code 
0faa			; 
0faa			;	CHECKSP ON 1 
0faa			;	ret 
0faa			 
0faa			 
0faa			malloc: 
0faa c5			      push  BC 
0fab d5			      push  DE 
0fac dd e5		      push  IX 
0fae			if DEBUG_FORTH_MALLOC_HIGH 
0fae			call malloc_guard_entry 
0fae			endif 
0fae			 
0fae					if DEBUG_FORTH_MALLOC 
0fae						DMARK "mal" 
0fae						CALLMONITOR 
0fae					endif 
0fae 7c			      ld    A, H                    ; Exit if no space requested 
0faf b5			      or    L 
0fb0 ca 6f 10		      jp    Z, malloc_early_exit 
0fb3			 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			; 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			;inc hl 
0fb3			 
0fb3			 
0fb3			 
0fb3			 
0fb3					if DEBUG_FORTH_MALLOC 
0fb3						DMARK "maA" 
0fb3						CALLMONITOR 
0fb3					endif 
0fb3			      ; Set up stack frame 
0fb3 eb			      ex    DE, HL 
0fb4 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
0fb7 39			      add   HL, SP 
0fb8 f9			      ld    SP, HL 
0fb9 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
0fbd dd 39		      add   IX, SP 
0fbf			 
0fbf			      ; Setup initial state 
0fbf 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
0fc2 19			      add   HL, DE 
0fc3			 
0fc3 44			      ld    B, H                    ; Move want to BC 
0fc4 4d			      ld    C, L 
0fc5			 
0fc5 21 4a 59		      ld    HL, free_list           ; Store prev_free ptr to stack 
0fc8 dd 75 04		      ld    (IX+4), L 
0fcb dd 74 05		      ld    (IX+5), H 
0fce			 
0fce 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
0fcf 23			      inc   HL 
0fd0 56			      ld    D, (HL) 
0fd1 dd 73 02		      ld    (IX+2), E 
0fd4 dd 72 03		      ld    (IX+3), D 
0fd7 eb			      ex    DE, HL                  ; this_free ptr into HL 
0fd8			 
0fd8					if DEBUG_FORTH_MALLOC 
0fd8						DMARK "maB" 
0fd8						CALLMONITOR 
0fd8					endif 
0fd8			      ; Loop through free block list to find some space 
0fd8			malloc_find_space: 
0fd8 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
0fd9 23			      inc   HL 
0fda 56			      ld    D, (HL) 
0fdb			 
0fdb 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
0fdc b3			      or    E 
0fdd ca 69 10		      jp    Z, malloc_no_space 
0fe0			 
0fe0 dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
0fe3 dd 72 01		      ld    (IX+1), D 
0fe6			 
0fe6			      ; Does this block have enough space to make the allocation? 
0fe6 23			      inc   HL                      ; Load free block size into DE 
0fe7 5e			      ld    E, (HL) 
0fe8 23			      inc   HL 
0fe9 56			      ld    D, (HL) 
0fea			 
0fea eb			      ex    DE, HL                  ; Check size of block against want 
0feb b7			      or    A                       ; Ensure carry flag clear 
0fec ed 42		      sbc   HL, BC 
0fee e5			      push  HL                      ; Store the result for later (new block size) 
0fef			 
0fef ca 3e 10		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
0ff2 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
0ff4			 
0ff4			      ; this_free block is not big enough, setup ptrs to test next free block 
0ff4 e1			      pop   HL                      ; Discard previous result 
0ff5			 
0ff5 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
0ff8 dd 66 03		      ld    H, (IX+3) 
0ffb dd 75 04		      ld    (IX+4), L 
0ffe dd 74 05		      ld    (IX+5), H 
1001			 
1001 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1004 dd 66 01		      ld    H, (IX+1) 
1007 dd 75 02		      ld    (IX+2), L 
100a dd 74 03		      ld    (IX+3), H 
100d			 
100d					if DEBUG_FORTH_MALLOC 
100d						DMARK "MA>" 
100d						CALLMONITOR 
100d					endif 
100d 18 c9		      jr    malloc_find_space 
100f			 
100f			      ; split a bigger block into two - requested size and remaining size 
100f			malloc_alloc_split: 
100f					if DEBUG_FORTH_MALLOC 
100f						DMARK "MAs" 
100f						CALLMONITOR 
100f					endif 
100f eb			      ex    DE, HL                  ; Calculate address of new free block 
1010 2b			      dec   HL 
1011 2b			      dec   HL 
1012 2b			      dec   HL 
1013 09			      add   HL, BC 
1014			 
1014			      ; Create a new block and point it at next_free 
1014 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
1017 dd 56 01		      ld    D, (IX+1) 
101a			 
101a 73			      ld    (HL), E                 ; Store next_free ptr into new block 
101b 23			      inc   HL 
101c 72			      ld    (HL), D 
101d			 
101d d1			      pop   DE                      ; Store size of new block into new block 
101e 23			      inc   HL 
101f 73			      ld    (HL), E 
1020 23			      inc   HL 
1021 72			      ld    (HL), D 
1022			 
1022			      ; Update this_free ptr to point to new block 
1022 2b			      dec   HL 
1023 2b			      dec   HL 
1024 2b			      dec   HL 
1025			 
1025 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1028 dd 56 03		      ld    D, (IX+3) 
102b			 
102b dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
102e dd 74 03		      ld    (IX+3), H 
1031			 
1031			      ; Modify this_free block to be allocation 
1031 eb			      ex    DE, HL 
1032 af			      xor   A                       ; Null the next block ptr of allocated block 
1033 77			      ld    (HL), A 
1034 23			      inc   HL 
1035 77			      ld    (HL), A 
1036			 
1036 23			      inc   HL                      ; Store want size into allocated block 
1037 71			      ld    (HL), C 
1038 23			      inc   HL 
1039 70			      ld    (HL), B 
103a 23			      inc   HL 
103b e5			      push  HL                      ; Address of allocation to return 
103c			 
103c 18 19		      jr    malloc_update_links 
103e			 
103e			malloc_alloc_fit: 
103e e1			      pop   HL                      ; Dont need new block size, want is exact fit 
103f			 
103f					if DEBUG_FORTH_MALLOC 
103f						DMARK "MAf" 
103f						CALLMONITOR 
103f					endif 
103f			      ; Modify this_free block to be allocation 
103f eb			      ex    DE, HL 
1040 2b			      dec   HL 
1041 2b			      dec   HL 
1042 2b			      dec   HL 
1043			 
1043 af			      xor   A                       ; Null the next block ptr of allocated block 
1044 77			      ld    (HL), A 
1045 23			      inc   HL 
1046 77			      ld    (HL), A 
1047			 
1047 23			      inc   HL                      ; Store address of allocation to return 
1048 23			      inc   HL 
1049 23			      inc   HL 
104a e5			      push  HL 
104b			 
104b			      ; Copy next_free ptr to this_free, remove allocated block from free list 
104b dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
104e dd 66 01		      ld    H, (IX+1) 
1051			 
1051 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
1054 dd 74 03		      ld    (IX+3), H 
1057			 
1057			 
1057			malloc_update_links: 
1057			      ; Update prev_free ptr to point to this_free 
1057 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
105a dd 66 05		      ld    H, (IX+5) 
105d			 
105d dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
1060 dd 56 03		      ld    D, (IX+3) 
1063			 
1063 73			      ld    (HL), E                 ; this_free ptr into prev_free 
1064 23			      inc   HL 
1065 72			      ld    (HL), D 
1066			 
1066					if DEBUG_FORTH_MALLOC 
1066						DMARK "Mul" 
1066						CALLMONITOR 
1066					endif 
1066			      ; Clear the Z flag to indicate successful allocation 
1066 7a			      ld    A, D 
1067 b3			      or    E 
1068			 
1068 d1			      pop   DE                      ; Address of allocation 
1069					if DEBUG_FORTH_MALLOC 
1069						DMARK "MAu" 
1069						CALLMONITOR 
1069					endif 
1069			 
1069			malloc_no_space: 
1069 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
106c 39			      add   HL, SP 
106d f9			      ld    SP, HL 
106e			 
106e eb			      ex    DE, HL                  ; Alloc addr into HL for return 
106f					if DEBUG_FORTH_MALLOC 
106f						DMARK "MAN" 
106f						CALLMONITOR 
106f					endif 
106f			 
106f			malloc_early_exit: 
106f					if DEBUG_FORTH_MALLOC 
106f						DMARK "MAx" 
106f						CALLMONITOR 
106f					endif 
106f dd e1		      pop   IX 
1071 d1			      pop   DE 
1072 c1			      pop   BC 
1073			 
1073			if DEBUG_FORTH_MALLOC_HIGH 
1073			call malloc_guard_exit 
1073			call malloc_guard_zerolen 
1073			endif 
1073 c9			      ret 
1074			 
1074			 
1074			;------------------------------------------------------------------------------ 
1074			;     free                                                                    : 
1074			;                                                                             : 
1074			; Description                                                                 : 
1074			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1074			;     returned by malloc, otherwise the behaviour is undefined.               : 
1074			;                                                                             : 
1074			;     Where possible, directly adjacent free blocks will be merged together   : 
1074			;     into larger blocks to help ensure that the heap does not become         : 
1074			;     excessively fragmented.                                                 : 
1074			;                                                                             : 
1074			;     free does not clear or set any other value into the freed space, and    : 
1074			;     therefore its contents may be visible through subsequent malloc's. The  : 
1074			;     caller should clear the freed space as required.                        : 
1074			;                                                                             : 
1074			;     This implementation of free uses the stack exclusively, and is          : 
1074			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1074			;     advisable to disable interrupts before calling free, and recommended    : 
1074			;     to avoid the use of free inside ISRs in general.                        : 
1074			;                                                                             : 
1074			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1074			;                                                                             : 
1074			; Parameters                                                                  : 
1074			;     HL  Pointer to address of first byte of allocation to be freed          : 
1074			;                                                                             : 
1074			; Returns                                                                     : 
1074			;     Nothing                                                                 : 
1074			;                                                                             : 
1074			; Stack frame                                                                 : 
1074			;       |             |                                                       : 
1074			;       +-------------+                                                       : 
1074			;       |     BC      |                                                       : 
1074			;       +-------------+                                                       : 
1074			;       |     DE      |                                                       : 
1074			;       +-------------+                                                       : 
1074			;       |     IX      |                                                       : 
1074			;       +-------------+                                                       : 
1074			;       |  prev_free  |                                                       : 
1074			;   +2  +-------------+                                                       : 
1074			;       |  next_free  |                                                       : 
1074			;   +0  +-------------+                                                       : 
1074			;       |             |                                                       : 
1074			;                                                                             : 
1074			;------------------------------------------------------------------------------ 
1074			free: 
1074 c5			      push  BC 
1075 d5			      push  DE 
1076 dd e5		      push  IX 
1078			 
1078 7c			      ld    A, H                    ; Exit if ptr is null 
1079 b5			      or    L 
107a ca 3e 11		      jp    Z, free_early_exit 
107d			 
107d			      ; Set up stack frame 
107d eb			      ex    DE, HL 
107e 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1081 39			      add   HL, SP 
1082 f9			      ld    SP, HL 
1083 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1087 dd 39		      add   IX, SP 
1089			 
1089			      ; The address in HL points to the start of the useable allocated space, 
1089			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1089			      ; address of the block itself. 
1089 eb			      ex    DE, HL 
108a 11 fc ff		      ld    DE, -4 
108d 19			      add   HL, DE 
108e			 
108e			      ; An allocated block must have a null next block pointer in it 
108e 7e			      ld    A, (HL) 
108f 23			      inc   HL 
1090 b6			      or    (HL) 
1091 c2 39 11		      jp    NZ, free_done 
1094			 
1094 2b			      dec   HL 
1095			 
1095 44			      ld    B, H                    ; Copy HL to BC 
1096 4d			      ld    C, L 
1097			 
1097			      ; Loop through the free list to find the first block with an address 
1097			      ; higher than the block being freed 
1097 21 4a 59		      ld    HL, free_list 
109a			 
109a			free_find_higher_block: 
109a 5e			      ld    E, (HL)                 ; Load next ptr from free block 
109b 23			      inc   HL 
109c 56			      ld    D, (HL) 
109d 2b			      dec   HL 
109e			 
109e dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
10a1 dd 72 01		      ld    (IX+1), D 
10a4 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
10a7 dd 74 03		      ld    (IX+3), H 
10aa			 
10aa 78			      ld    A, B                    ; Check if DE is greater than BC 
10ab ba			      cp    D                       ; Compare MSB first 
10ac 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
10ae 30 04		      jr    NC, free_find_higher_block_skip 
10b0 79			      ld    A, C 
10b1 bb			      cp    E                       ; Then compare LSB 
10b2 38 08		      jr    C, free_found_higher_block 
10b4			 
10b4			free_find_higher_block_skip: 
10b4 7a			      ld    A, D                    ; Reached the end of the free list? 
10b5 b3			      or    E 
10b6 ca 39 11		      jp    Z, free_done 
10b9			 
10b9 eb			      ex    DE, HL 
10ba			 
10ba 18 de		      jr    free_find_higher_block 
10bc			 
10bc			free_found_higher_block: 
10bc			      ; Insert freed block between prev and next free blocks 
10bc 71			      ld    (HL), C                 ; Point prev free block to freed block 
10bd 23			      inc   HL 
10be 70			      ld    (HL), B 
10bf			 
10bf 60			      ld    H, B                    ; Point freed block at next free block 
10c0 69			      ld    L, C 
10c1 73			      ld    (HL), E 
10c2 23			      inc   HL 
10c3 72			      ld    (HL), D 
10c4			 
10c4			      ; Check if the freed block is adjacent to the next free block 
10c4 23			      inc   HL                      ; Load size of freed block into HL 
10c5 5e			      ld    E, (HL) 
10c6 23			      inc   HL 
10c7 56			      ld    D, (HL) 
10c8 eb			      ex    DE, HL 
10c9			 
10c9 09			      add   HL, BC                  ; Add addr of freed block and its size 
10ca			 
10ca dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
10cd dd 56 01		      ld    D, (IX+1) 
10d0			 
10d0 b7			      or    A                       ; Clear the carry flag 
10d1 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
10d3 20 22		      jr    NZ, free_check_adjacent_to_prev 
10d5			 
10d5			      ; Freed block is adjacent to next, merge into one bigger block 
10d5 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
10d6 5e			      ld    E, (HL) 
10d7 23			      inc   HL 
10d8 56			      ld    D, (HL) 
10d9 e5			      push  HL                      ; Save ptr to next block for later 
10da			 
10da 60			      ld    H, B                    ; Store ptr from next block into freed block 
10db 69			      ld    L, C 
10dc 73			      ld    (HL), E 
10dd 23			      inc   HL 
10de 72			      ld    (HL), D 
10df			 
10df e1			      pop   HL                      ; Restore ptr to next block 
10e0 23			      inc   HL                      ; Load size of next block into DE 
10e1 5e			      ld    E, (HL) 
10e2 23			      inc   HL 
10e3 56			      ld    D, (HL) 
10e4 d5			      push  DE                      ; Save next block size for later 
10e5			 
10e5 60			      ld    H, B                    ; Load size of freed block into HL 
10e6 69			      ld    L, C 
10e7 23			      inc   HL 
10e8 23			      inc   HL 
10e9 5e			      ld    E, (HL) 
10ea 23			      inc   HL 
10eb 56			      ld    D, (HL) 
10ec eb			      ex    DE, HL 
10ed			 
10ed d1			      pop   DE                      ; Restore size of next block 
10ee 19			      add   HL, DE                  ; Add sizes of both blocks 
10ef eb			      ex    DE, HL 
10f0			 
10f0 60			      ld    H, B                    ; Store new bigger size into freed block 
10f1 69			      ld    L, C 
10f2 23			      inc   HL 
10f3 23			      inc   HL 
10f4 73			      ld    (HL), E 
10f5 23			      inc   HL 
10f6 72			      ld    (HL), D 
10f7			 
10f7			free_check_adjacent_to_prev: 
10f7			      ; Check if the freed block is adjacent to the prev free block 
10f7 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
10fa dd 66 03		      ld    H, (IX+3) 
10fd			 
10fd 23			      inc   HL                      ; Size of prev free block into DE 
10fe 23			      inc   HL 
10ff 5e			      ld    E, (HL) 
1100 23			      inc   HL 
1101 56			      ld    D, (HL) 
1102 2b			      dec   HL 
1103 2b			      dec   HL 
1104 2b			      dec   HL 
1105			 
1105 19			      add   HL, DE                  ; Add prev block addr and size 
1106			 
1106 b7			      or    A                       ; Clear the carry flag 
1107 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1109 20 2e		      jr    NZ, free_done 
110b			 
110b			      ; Freed block is adjacent to prev, merge into one bigger block 
110b 60			      ld    H, B                    ; Load next ptr from freed block into DE 
110c 69			      ld    L, C 
110d 5e			      ld    E, (HL) 
110e 23			      inc   HL 
110f 56			      ld    D, (HL) 
1110 e5			      push  HL                      ; Save freed block ptr for later 
1111			 
1111 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1114 dd 66 03		      ld    H, (IX+3) 
1117 73			      ld    (HL), E 
1118 23			      inc   HL 
1119 72			      ld    (HL), D 
111a			 
111a e1			      pop   HL                      ; Restore freed block ptr 
111b 23			      inc   HL                      ; Load size of freed block into DE 
111c 5e			      ld    E, (HL) 
111d 23			      inc   HL 
111e 56			      ld    D, (HL) 
111f d5			      push  DE                      ; Save freed block size for later 
1120			 
1120 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
1123 dd 66 03		      ld    H, (IX+3) 
1126 23			      inc   HL 
1127 23			      inc   HL 
1128 5e			      ld    E, (HL) 
1129 23			      inc   HL 
112a 56			      ld    D, (HL) 
112b			 
112b e1			      pop   HL                      ; Add sizes of both blocks 
112c 19			      add   HL, DE 
112d eb			      ex    DE, HL 
112e			 
112e dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
1131 dd 66 03		      ld    H, (IX+3) 
1134 23			      inc   HL 
1135 23			      inc   HL 
1136 73			      ld    (HL), E 
1137 23			      inc   HL 
1138 72			      ld    (HL), D 
1139			 
1139			free_done: 
1139 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
113c 39			      add   HL, SP 
113d f9			      ld    SP, HL 
113e			 
113e			free_early_exit: 
113e dd e1		      pop   IX 
1140 d1			      pop   DE 
1141 c1			      pop   BC 
1142			 
1142 c9			      ret 
