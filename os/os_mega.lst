16c2 cb 89				res 1, c 
16c4 06 32				ld b, '2'    ; human readable bank number 
16c6 fe 03		.b3:		cp 3 
16c8 20 04				jr nz, .b4 
16ca cb 91				res 2, c 
16cc 06 33				ld b, '3'    ; human readable bank number 
