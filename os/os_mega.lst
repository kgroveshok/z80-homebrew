511a			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
511a			; | 
511a			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
511a			; | |  
511a			; | | e.g. 
511a			; | |         #30 a var ! 
511a			; | |         a var @ . 
511a			; | |   
511a			; | |     Displays the number 30 
511a			; | | 
511a			; | | Each variable pointer is a word so can use for any words that use that:  
511a			; | |  
511a			; | | e.g. 
511a			; | |  
511a			; | |         #30 a var 2! 
511a			; | |         a var 2@ . 
511a			; | |   
511a			; | |     Displays the number 30 
511a			; | |  
511a			; | | > [!NOTE]  
511a			; ! | > If a full string is passed then only the first char is looked at 
511a			; | | > Any other char could exceed bounds checks!  
511a			; | | > 
511a			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
511a			 
511a					if DEBUG_FORTH_WORDS_KEY 
511a						DMARK "VAR" 
511a				if DEMARK_VERSION = 1  
511a e5					push hl  
511b 21 23 51				ld hl, .dmark  
511e 22 9b fd				ld (debug_mark), hl  
5121				endif  
