0f7a			StrictStrCmp: 
0f7a				; Load next chars of each string 
0f7a 1a				ld a, (de) 
0f7b 47				ld b, a 
0f7c 7e				ld a, (hl) 
0f7d				; Compare 
0f7d b8				cp b 
0f7e				; Return non-zero if chars don't match 
0f7e c0				ret nz 
0f7f				; Check for end of both strings 
0f7f fe 00			cp "\0" 
0f81				; Return if strings have ended 
0f81 c8				ret z 
0f82				; Otherwise, advance to next chars 
0f82 23				inc hl 
0f83 13				inc de 
0f84 18 f4			jr StrictStrCmp 
