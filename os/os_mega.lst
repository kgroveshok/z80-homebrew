00a0			hardware_init:  
00a0			  
00a0					; Set bit for stack checks (if those features are enabled)  
00a0 2a af fd				ld hl, (hardware_config+1)  
00a3 cb fe				set 7, (hl)  
00a5			  
00a5					;ld a, 0  
00a5					;ld (hardware_diag), a  
00a5			  
00a5					; clear all the buffers  
00a5			  
00a5 21 40 fc				ld hl, display_fb1  
00a8 22 fc fa				ld (display_fb_active), hl  
00ab			  
00ab cd 37 0b				call clear_display  
00ae			  
00ae 21 fe fa				ld hl, display_fb2  
00b1 22 fc fa				ld (display_fb_active), hl  
00b4			  
00b4 cd 37 0b				call clear_display  
00b7			  
00b7					; init primary frame buffer area  
00b7 21 e1 fc				ld hl, display_fb0  
00ba 22 fc fa				ld (display_fb_active), hl  
00bd			  
00bd cd 37 0b				call clear_display  
00c0			  
00c0			  
00c0 cd 46 69				call lcd_init		; lcd hardware first as some screen functions called during key_init e.g. cursor shapes  
00c3			  
