244e			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
244e			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
244e			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
244e			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
244e			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
244e			WORD_SYS_END: equ 0   ; Opcode for all user words 
244e			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
244e			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
244e			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
244e			 
244e			; Core word preamble macro 
244e			 
244e			CWHEAD:   macro nxtword opcode lit len opflags 
244e				db WORD_SYS_CORE+opcode             
244e				; internal op code number 
244e				dw nxtword            
244e				; link to next dict word block 
244e				db len + 1 
244e				; literal length of dict word inc zero term 
244e				db lit,0              
244e				; literal dict word 
244e			        ; TODO db opflags        
244e				endm 
