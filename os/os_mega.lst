22ac 73				ld (hl), e		; next word link ie system dict 
22ad 23				inc hl 
22ae 72				ld (hl), d		; next word link ie system dict 
22af 23				inc hl	 
22b0			 
22b0			;	ld (hl), sysdict		; next word link ie system dict 
22b0			;	inc hl 
22b0			;	inc hl 
22b0			 
22b0			;	inc hl 
22b0			;	inc hl 
22b0			 
22b0			;	ld a, 2			; word length is 0 
22b0 36 02			ld (hl), 2 
22b2 23				inc hl 
22b3			 
22b3			;	ld a, '~'			; word length is 0 
22b3 36 7e			ld (hl), '~' 
22b5 23				inc hl 
22b6			;	ld a, 0			; save empty word 
22b6 36 00			ld (hl), 0 
