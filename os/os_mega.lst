12e0			free:  
12e0				push hl 
12e0				push af 
12e0				; get address in hl 
12e0			 
12e0					if DEBUG_FORTH_MALLOC_INT 
12e0						DMARK "fre" 
12e0						CALLMONITOR 
12e0					endif 
