89ba			;http://z80-heaven.wikidot.com/math 
89ba			; 
89ba			;Inputs: 
89ba			;     DE and A are factors 
89ba			;Outputs: 
89ba			;     A is not changed 
89ba			;     B is 0 
89ba			;     C is not changed 
89ba			;     DE is not changed 
89ba			;     HL is the product 
89ba			;Time: 
89ba			;     342+6x 
89ba			; 
89ba			Mult16: 
89ba			 
89ba 06 08		     ld b,8          ;7           7 
89bc 21 00 00		     ld hl,0         ;10         10 
89bf 29			       add hl,hl     ;11*8       88 
89c0 07			       rlca          ;4*8        32 
89c1 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
89c3 19			         add hl,de   ;--         -- 
89c4 10 f9		       djnz $-5      ;13*7+8     99 
89c6 c9			ret 
