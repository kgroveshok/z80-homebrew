0d3f 17			    rla 
0d40 cb 11		    rl c 
0d42 30 07		    jr nc,Mult32_NoAdd 
0d44 19			    add hl,de 
0d45 ce 00		    adc a,0 
0d47 d2 4b 0d		    jp nc,Mult32_NoAdd 
0d4a 0c			    inc c 
0d4b			Mult32_NoAdd: 
