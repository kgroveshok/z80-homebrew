920e			 
920e			;		ld a, 0 
920e					ld hl, (store_tmp2) 
920e					ld (hl), 0 
920e					inc hl 
920e					ld (hl), 0 
920e					inc hl 
920e					; push a count of the dir items found 
920e			 
920e			;		ld h, 0 
920e			;		ld l, c 
920e			 
920e				ret 
920e			 
920e			endif 
