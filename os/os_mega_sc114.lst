8dec			StrictStrCmp: 
8dec				; Load next chars of each string 
8dec 1a				ld a, (de) 
8ded 47				ld b, a 
8dee 7e				ld a, (hl) 
8def				; Compare 
8def b8				cp b 
8df0				; Return non-zero if chars don't match 
8df0 c0				ret nz 
8df1				; Check for end of both strings 
8df1 fe 00			cp "\0" 
8df3				; Return if strings have ended 
8df3 c8				ret z 
8df4				; Otherwise, advance to next chars 
8df4 23				inc hl 
8df5 13				inc de 
8df6 18 f4			jr StrictStrCmp 
8df8			 
8df8			;end 
8df8			; eof 
