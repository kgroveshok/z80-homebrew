ba8a			; | SPITIME ( -- u1 )   Pushes address of the SPI pulse counter/delay to stack | DONE 
ba8a			; 
ba8a			; | | If using BANK devices then leave as is. 
ba8a			; | | Only really useful for the CARTDEV where other devices may be far too slow. In particular 
ba8a			; | | the multiplexing of the PicoSPINet addon which might not be running fast enough for all of the nodes 
ba8a			 
ba8a 21 59 ea				ld hl, spi_clktime  
