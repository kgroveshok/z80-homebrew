67eb			 
67eb			; handle the auto run of code from files in storage 
67eb			 
67eb			 
67eb			include "forth_startup.asm" 
67eb			; Which startup method to use? 
67eb			; 
67eb			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
67eb			; followed by loading of a list of scripts in eeprom 
67eb			 
67eb			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
67eb			; from eeprom 
67eb			 
67eb			; Select with define in main stubs 
67eb			 
67eb			if STARTUP_V1 
67eb				include "forth_startupv1.asm" 
67eb			endif 
67eb			if STARTUP_V2 
67eb				include "forth_startupv2.asm" 
67eb			; Version 2 of the startup  
67eb			;  
67eb			; Auto load any files in bank 1 that start with a '*' 
67eb			; If no se storage then revert to using eprom 
67eb			 
67eb			 
67eb			if STORAGE_SE = 0 
67eb			 
67eb			sprompt1: db "Startup load...",0 
67eb			sprompt2: db "Run? 1=No *=End #=All",0 
67eb			 
67eb			 
67eb			 
67eb			 
67eb			forth_startup: 
67eb				ld hl, startcmds 
67eb				ld a, 0 
67eb				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
67eb			 
67eb			.start1:	push hl 
67eb				call clear_display 
67eb				ld de, sprompt1 
67eb			        ld a, display_row_1 
67eb				call str_at_display 
67eb				ld de, sprompt2 
67eb			        ld a, display_row_2 
67eb				call str_at_display 
67eb				pop hl 
67eb				push hl 
67eb				ld e,(hl) 
67eb				inc hl 
67eb				ld d,(hl) 
67eb			        ld a, display_row_3 
67eb				call str_at_display 
67eb				call update_display 
67eb			 
67eb			 
67eb				ld a, (os_last_cmd) 
67eb			;	cp 0 
67eb				or a 
67eb				jr z, .startprompt 
67eb				call delay250ms 
67eb				jr .startdo 
67eb				 
67eb				 
67eb			 
67eb			.startprompt: 
67eb			 
67eb				ld a,display_row_4 + display_cols - 1 
67eb			        ld de, endprg 
67eb				call str_at_display 
67eb				call update_display 
67eb				call delay1s 
67eb				call cin_wait 
67eb						 
67eb				cp '*' 
67eb				jr z, .startupend1 
67eb				cp '#' 
67eb				jr nz, .startno 
67eb				ld a, 1 
67eb				ld (os_last_cmd),a 
67eb				jr .startdo 
67eb			.startno:	cp '1' 
67eb				jr z,.startnxt  
67eb			 
67eb				; exec startup line 
67eb			.startdo:	 
67eb				pop hl 
67eb				push hl 
67eb				 
67eb				ld e,(hl) 
67eb				inc hl 
67eb				ld d,(hl) 
67eb				ex de,hl 
67eb			 
67eb				push hl 
67eb			 
67eb				ld a, 0 
67eb				;ld a, FORTH_END_BUFFER 
67eb				call strlent 
67eb				inc hl   ; include zero term to copy 
67eb				ld b,0 
67eb				ld c,l 
67eb				pop hl 
67eb				ld de, scratch 
67eb				ldir 
67eb			 
67eb			 
67eb				ld hl, scratch 
67eb				call forthparse 
67eb				call forthexec 
67eb				call forthexec_cleanup 
67eb			 
67eb				ld a, display_row_4 
67eb				ld de, endprog 
67eb			 
67eb				call update_display		 
67eb			 
67eb				ld a, (os_last_cmd) 
67eb			;	cp 0 
67eb				or a 
67eb				jr nz, .startnxt 
67eb				call next_page_prompt 
67eb			        call clear_display 
67eb				call update_display		 
67eb			 
67eb				; move onto next startup line? 
67eb			.startnxt: 
67eb			 
67eb				call delay250ms 
67eb				pop hl 
67eb			 
67eb				inc hl 
67eb				inc hl 
67eb			 
67eb				push hl 
