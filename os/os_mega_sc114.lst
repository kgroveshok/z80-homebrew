# End of macro CWHEAD
bf2c			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bf2c			; | 
bf2c			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bf2c			; | |  
bf2c			; | | e.g. 
bf2c			; | |         #30 a var ! 
bf2c			; | |         a var @ . 
bf2c			; | |   
bf2c			; | |     Displays the number 30 
bf2c			; | | 
bf2c			; | | Each variable pointer is a word so can use for any words that use that:  
bf2c			; | |  
bf2c			; | | e.g. 
bf2c			; | |  
bf2c			; | |         #30 a var 2! 
bf2c			; | |         a var 2@ . 
bf2c			; | |   
bf2c			; | |     Displays the number 30 
bf2c			; | |  
bf2c			; | | > [!NOTE]  
bf2c			; ! | > If a full string is passed then only the first char is looked at 
bf2c			; | | > Any other char could exceed bounds checks!  
bf2c			; | | > 
bf2c			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bf2c			 
bf2c					if DEBUG_FORTH_WORDS_KEY 
