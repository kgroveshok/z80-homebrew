5f14 .. 00			db "VAR",0              
5f18				endm 
# End of macro CWHEAD
5f18			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5f18			; | 
5f18			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5f18			; | |  
5f18			; | | e.g. 
5f18			; | |         #30 a var ! 
5f18			; | |         a var @ . 
5f18			; | |   
5f18			; | |     Displays the number 30 
5f18			; | | 
5f18			; | | Each variable pointer is a word so can use for any words that use that:  
5f18			; | |  
5f18			; | | e.g. 
5f18			; | |  
5f18			; | |         #30 a var 2! 
5f18			; | |         a var 2@ . 
5f18			; | |   
5f18			; | |     Displays the number 30 
5f18			; | |  
5f18			; | | > [!NOTE]  
5f18			; ! | > If a full string is passed then only the first char is looked at 
5f18			; | | > Any other char could exceed bounds checks!  
5f18			; | | > 
5f18			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5f18			 
5f18					if DEBUG_FORTH_WORDS_KEY 
5f18						DMARK "VAR" 
5f18 f5				push af  
5f19 3a 2d 5f			ld a, (.dmark)  
5f1c 32 99 fd			ld (debug_mark),a  
5f1f 3a 2e 5f			ld a, (.dmark+1)  
5f22 32 9a fd			ld (debug_mark+1),a  
5f25 3a 2f 5f			ld a, (.dmark+2)  
5f28 32 9b fd			ld (debug_mark+2),a  
5f2b 18 03			jr .pastdmark  
5f2d ..			.dmark: db "VAR"  
5f30 f1			.pastdmark: pop af  
5f31			endm  
# End of macro DMARK
5f31						CALLMONITOR 
5f31				if BASE_CPM=1  
5f31					call debug_vector  
5f31				endif  
5f31				if BASE_KEV=1  
5f31 cf					rst 8  
5f32				endif  
5f32				endm  
# End of macro CALLMONITOR
5f32					endif 
