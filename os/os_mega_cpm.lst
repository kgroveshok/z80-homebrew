244c			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
244c			; | | At start the current various registers will be displayed with contents. 
244c			; | | Top right corner will show the most recent debug marker seen. 
244c			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
244c			; | | and the return stack pointer (RSP). 
244c			; | | Pressing: 
244c			; | |  
244c			; | |    1 - Initial screen 
244c			; | |  
244c			; | |    2 - Display a data dump of HL 
244c			; | |  
244c			; | |    3 - Display a data dump of DE 
244c			; | |  
244c			; | |    4 - Display a data dump of BC 
244c			; | |  
244c			; | |    5 - Display a data dump of HL 
244c			; | |  
244c			; | |    6 - Display a data dump of DSP 
244c			; | |  
244c			; | |    7 - Display a data dump of RSP 
244c			; | |  
244c			; | |    8 - Display a data dump of what is at DSP 
244c			; | |  
244c			; | |    9 - Display a data dump of what is at RSP 
244c			; | |  
244c			; | |    0 - Exit monitor and continue running. This will also enable break points 
244c			; | |  
244c			; | |    * - Disable break points 
244c			; | |  
244c			; | |    # - Enter traditional monitor mode 
244c			; | |  
244c			; | | 
244c			; | | Monitor Mode 
244c			; | | ------------ 
244c			; | | A prompt of '>' will be shown for various commands: 
244c			; | |  
244c			; | |    D xxxx - Display a data dump starting from hex address xxxx 
244c			; | |  
244c			; | |    C - Continue display a data dump from the last set address 
244c			; | |  
244c			; | |    M xxxx - Set start of memory edit at address xx 
244c			; | |  
244c			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
244c			; | |  
244c			; | |    G xxxx - Exec code at specific address 
244c			; | |  
244c			; | |    Q - Return to previous 
244c				if DEBUG_FORTH_WORDS_KEY 
244c					DMARK "MON" 
244c				if DEMARK_VERSION = 1  
244c e5					push hl  
244d 21 55 24				ld hl, .dmark  
2450 22 5e ee				ld (debug_mark), hl  
2453				endif  
2453				if DEMARK_VERSION = 0  
2453					push af  
2453					ld a, (.dmark)  
2453					ld (debug_mark),a  
2453					ld a, (.dmark+1)  
2453					ld (debug_mark+1),a  
2453					ld a, (.dmark+2)  
2453					ld (debug_mark+2),a  
2453				endif  
2453 18 03			jr .pastdmark  
2455 ..			.dmark: db "MON"  
2458				if DEMARK_VERSION = 1  
2458 e1			.pastdmark: pop hl  
2459				endif  
2459				if DEMARK_VERSION = 0  
2459			.pastdmark: pop af  
2459				endif  
2459			endm  
# End of macro DMARK
2459					CALLMONITOR 
2459				if BASE_CPM=1  
2459 cd 6b ee				call debug_vector  
245c				endif  
245c				if BASE_KEV=1  
245c					rst 8  
245c				endif  
245c				endm  
# End of macro CALLMONITOR
245c				endif 
