0ee8			; Decimal Signed Version 
0ee8			 
0ee8			; DispA 
0ee8			; -------------------------------------------------------------- 
0ee8			; Converts a signed integer value to a zero-terminated ASCII 
0ee8			; string representative of that value (using radix 10). 
0ee8			; -------------------------------------------------------------- 
0ee8			; INPUTS: 
0ee8			;     HL     Value to convert (two's complement integer). 
0ee8			;     DE     Base address of string destination. (pointer). 
0ee8			; -------------------------------------------------------------- 
0ee8			; OUTPUTS: 
0ee8			;     None 
0ee8			; -------------------------------------------------------------- 
0ee8			; REGISTERS/MEMORY DESTROYED 
0ee8			; AF HL 
0ee8			; -------------------------------------------------------------- 
0ee8			 
0ee8			;DispHLToASCII: 
0ee8			;   push    de 
0ee8			;   push    bc 
0ee8			; 
0ee8			;; Detect sign of HL. 
0ee8			;    bit    7, h 
0ee8			;    jr     z, ._DoConvert 
0ee8			; 
0ee8			;; HL is negative. Output '-' to string and negate HL. 
0ee8			;    ld     a, '-' 
0ee8			;    ld     (de), a 
0ee8			;    inc    de 
0ee8			; 
0ee8			;; Negate HL (using two's complement) 
0ee8			;    xor    a 
0ee8			;    sub    l 
0ee8			;    ld     l, a 
0ee8			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
0ee8			;    sbc    a, h 
0ee8			;    ld     h, a 
0ee8			; 
0ee8			;; Convert HL to digit characters 
0ee8			;._DoConvert: 
0ee8			;    ld     b, 0     ; B will count character length of number 
0ee8			;-   ld     a, 10 
0ee8			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
0ee8			;    push   af 
0ee8			;    inc    b 
0ee8			;    ld     a, h 
0ee8			;    or     l 
0ee8			;    jr     nz, - 
0ee8			; 
0ee8			;; Retrieve digits from stack 
0ee8			;-   pop    af 
0ee8			;    or     $30 
0ee8			;    ld     (de), a 
0ee8			;    inc    de 
0ee8			;    djnz   - 
0ee8			; 
0ee8			;; Terminate string with NULL 
0ee8			;    xor    a 
0ee8			;    ld     (de), a 
0ee8			; 
0ee8			;    pop    bc 
0ee8			;    pop    de 
0ee8			;    ret 
0ee8			 
0ee8			;Comments 
0ee8			; 
0ee8			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
0ee8			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
0ee8			;    Note that the output string will not be fixed-width. 
0ee8			; 
0ee8			;Example Usage 
0ee8			; 
0ee8			;    ld    hl, -1004 
0ee8			;    ld    de, OP1 
0ee8			;    call  DispA 
0ee8			;    ld    hl, OP1 
0ee8			;    syscall  PutS 
