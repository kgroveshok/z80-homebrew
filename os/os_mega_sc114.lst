8dc1			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
8dc1			;      carry  Set if string1 > string2, reset if string1 <= string2. 
8dc1			; tested 
8dc1			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
8dc1			 
8dc1			strcmp_old: 
8dc1 e5			    PUSH   HL 
8dc2 d5			    PUSH   DE 
8dc3			 
8dc3 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
8dc4 be			    CP     (HL)            ; (want to minimize work). 
8dc5 38 01		    JR     C, Str1IsBigger 
8dc7 7e			    LD     A, (HL) 
8dc8			 
8dc8			Str1IsBigger: 
8dc8 4f			    LD     C, A             ; Put length in BC 
8dc9 06 00		    LD     B, 0 
8dcb 13			    INC    DE              ; Increment pointers to meat of string. 
8dcc 23			    INC    HL 
8dcd			 
8dcd			CmpLoop: 
8dcd 1a			    LD     A, (DE)          ; Compare bytes. 
8dce ed a1		    CPI 
8dd0 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
8dd2 13			    INC    DE              ; Update pointer. 
8dd3 ea cd 8d		    JP     PE, CmpLoop 
8dd6			 
8dd6 d1			    POP    DE 
8dd7 e1			    POP    HL 
8dd8 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
8dd9 be			    CP     (HL) 
8dda c9			    RET 
8ddb			 
8ddb			NoMatch: 
8ddb 2b			    DEC    HL 
8ddc be			    CP     (HL)            ; Compare again to affect carry. 
8ddd d1			    POP    DE 
8dde e1			    POP    HL 
8ddf c9			    RET 
