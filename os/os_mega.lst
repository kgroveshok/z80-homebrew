2538			.NEW: 
2538			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
2538 15				db WORD_SYS_CORE+OPCODE_HEAP             
2539 52 25			dw .HEAP            
253b 04				db 3 + 1 
253c .. 00			db "NEW",0              
2540				endm 
# End of macro CWHEAD
2540			; | NEW ( -- ) Clears all user words and stack | DONE 
2540				 
2540				if MALLOC_4 
2540					call  heap_init 
2540				endif 
2540				; reset uword pointers 
2540 21 00 80			ld hl, baseram 
2543 22 da f3			ld (os_last_new_uword), hl 
2546 cd 8c 23			call user_word_eol 
