0ddd					; Upper nybble 
0ddd cb 3f				SRL A 
0ddf cb 3f				SRL A 
0de1 cb 3f				SRL A 
0de3 cb 3f				SRL A 
0de5 cd f5 0d				CALL tohex 
0de8 77					ld (hl),a 
0de9 23					inc hl	 
0dea					 
0dea					; Lower nybble 
0dea 78					LD A, B 
0deb e6 0f				AND 0FH 
0ded cd f5 0d				CALL tohex 
0df0 77					ld (hl),a 
0df1 23					inc hl	 
0df2					 
0df2 f1					POP AF 
0df3 c1					POP BC 
0df4 c9					RET 
