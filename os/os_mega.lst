2ad5					ld (debug_mark+1),a  
2ad5					ld a, (.dmark+2)  
2ad5					ld (debug_mark+2),a  
2ad5				endif  
2ad5 18 04			jr .pastdmark  
2ad7 ..			.dmark: db "MON"  
2ada				if DEMARK_VERSION = 1  
2ada 00					db 0  
2adb				endif  
2adb				if DEMARK_VERSION = 1  
2adb e1			.pastdmark: pop hl  
2adc				endif  
