0c9e			; Out: BC = result, HL = rest 
0c9e			; 
0c9e			Div16: 
0c9e 21 00 00		    ld hl,0 
0ca1 78			    ld a,b 
0ca2 06 08		    ld b,8 
0ca4			Div16_Loop1: 
0ca4 17			    rla 
0ca5 ed 6a		    adc hl,hl 
0ca7 ed 52		    sbc hl,de 
0ca9 30 01		    jr nc,Div16_NoAdd1 
0cab 19			    add hl,de 
0cac			Div16_NoAdd1: 
0cac 10 f6		    djnz Div16_Loop1 
0cae 17			    rla 
0caf 2f			    cpl 
0cb0 47			    ld b,a 
0cb1 79			    ld a,c 
0cb2 48			    ld c,b 
0cb3 06 08		    ld b,8 
0cb5			Div16_Loop2: 
0cb5 17			    rla 
0cb6 ed 6a		    adc hl,hl 
0cb8 ed 52		    sbc hl,de 
0cba 30 01		    jr nc,Div16_NoAdd2 
0cbc 19			    add hl,de 
0cbd			Div16_NoAdd2: 
