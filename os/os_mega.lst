120e			;------------------------------------------------------------------------------ 
120e			;     free                                                                    : 
120e			;                                                                             : 
120e			; Description                                                                 : 
120e			;     Return the space pointed to by HL to the heap. HL must be an address as : 
120e			;     returned by malloc, otherwise the behaviour is undefined.               : 
120e			;                                                                             : 
120e			;     Where possible, directly adjacent free blocks will be merged together   : 
120e			;     into larger blocks to help ensure that the heap does not become         : 
120e			;     excessively fragmented.                                                 : 
120e			;                                                                             : 
120e			;     free does not clear or set any other value into the freed space, and    : 
120e			;     therefore its contents may be visible through subsequent malloc's. The  : 
120e			;     caller should clear the freed space as required.                        : 
120e			;                                                                             : 
120e			;     This implementation of free uses the stack exclusively, and is          : 
120e			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
120e			;     advisable to disable interrupts before calling free, and recommended    : 
120e			;     to avoid the use of free inside ISRs in general.                        : 
120e			;                                                                             : 
120e			;     NOTE: heap_init must be called before malloc and free can be used.      : 
120e			;                                                                             : 
120e			; Parameters                                                                  : 
120e			;     HL  Pointer to address of first byte of allocation to be freed          : 
120e			;                                                                             : 
120e			; Returns                                                                     : 
120e			;     Nothing                                                                 : 
120e			;                                                                             : 
120e			; Stack frame                                                                 : 
120e			;       |             |                                                       : 
120e			;       +-------------+                                                       : 
120e			;       |     BC      |                                                       : 
120e			;       +-------------+                                                       : 
120e			;       |     DE      |                                                       : 
120e			;       +-------------+                                                       : 
120e			;       |     IX      |                                                       : 
120e			;       +-------------+                                                       : 
120e			;       |  prev_free  |                                                       : 
120e			;   +2  +-------------+                                                       : 
120e			;       |  next_free  |                                                       : 
120e			;   +0  +-------------+                                                       : 
120e			;       |             |                                                       : 
120e			;                                                                             : 
120e			;------------------------------------------------------------------------------ 
120e			free: 
120e c5			      push  BC 
120f d5			      push  DE 
1210 dd e5		      push  IX 
1212			 
1212 7c			      ld    A, H                    ; Exit if ptr is null 
1213 b5			      or    L 
1214 ca d8 12		      jp    Z, free_early_exit 
1217			 
1217			      ; Set up stack frame 
1217 eb			      ex    DE, HL 
1218 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
121b 39			      add   HL, SP 
121c f9			      ld    SP, HL 
121d dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1221 dd 39		      add   IX, SP 
1223			 
1223			      ; The address in HL points to the start of the useable allocated space, 
1223			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1223			      ; address of the block itself. 
1223 eb			      ex    DE, HL 
1224 11 fc ff		      ld    DE, -4 
1227 19			      add   HL, DE 
1228			 
1228			      ; An allocated block must have a null next block pointer in it 
1228 7e			      ld    A, (HL) 
1229 23			      inc   HL 
122a b6			      or    (HL) 
122b c2 d3 12		      jp    NZ, free_done 
122e			 
122e 2b			      dec   HL 
122f			 
122f 44			      ld    B, H                    ; Copy HL to BC 
1230 4d			      ld    C, L 
1231			 
1231			      ; Loop through the free list to find the first block with an address 
1231			      ; higher than the block being freed 
1231 21 0a 80		      ld    HL, free_list 
1234			 
1234			free_find_higher_block: 
1234 5e			      ld    E, (HL)                 ; Load next ptr from free block 
1235 23			      inc   HL 
1236 56			      ld    D, (HL) 
1237 2b			      dec   HL 
1238			 
1238 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
123b dd 72 01		      ld    (IX+1), D 
123e dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1241 dd 74 03		      ld    (IX+3), H 
1244			 
1244 78			      ld    A, B                    ; Check if DE is greater than BC 
1245 ba			      cp    D                       ; Compare MSB first 
1246 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
1248 30 04		      jr    NC, free_find_higher_block_skip 
124a 79			      ld    A, C 
124b bb			      cp    E                       ; Then compare LSB 
124c 38 08		      jr    C, free_found_higher_block 
124e			 
124e			free_find_higher_block_skip: 
124e 7a			      ld    A, D                    ; Reached the end of the free list? 
124f b3			      or    E 
1250 ca d3 12		      jp    Z, free_done 
1253			 
1253 eb			      ex    DE, HL 
1254			 
1254 18 de		      jr    free_find_higher_block 
1256			 
1256			free_found_higher_block: 
1256			      ; Insert freed block between prev and next free blocks 
1256 71			      ld    (HL), C                 ; Point prev free block to freed block 
1257 23			      inc   HL 
1258 70			      ld    (HL), B 
1259			 
1259 60			      ld    H, B                    ; Point freed block at next free block 
125a 69			      ld    L, C 
125b 73			      ld    (HL), E 
125c 23			      inc   HL 
125d 72			      ld    (HL), D 
125e			 
125e			      ; Check if the freed block is adjacent to the next free block 
125e 23			      inc   HL                      ; Load size of freed block into HL 
125f 5e			      ld    E, (HL) 
1260 23			      inc   HL 
1261 56			      ld    D, (HL) 
1262 eb			      ex    DE, HL 
1263			 
1263 09			      add   HL, BC                  ; Add addr of freed block and its size 
1264			 
1264 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
1267 dd 56 01		      ld    D, (IX+1) 
126a			 
126a b7			      or    A                       ; Clear the carry flag 
126b ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
126d 20 22		      jr    NZ, free_check_adjacent_to_prev 
126f			 
126f			      ; Freed block is adjacent to next, merge into one bigger block 
126f eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1270 5e			      ld    E, (HL) 
1271 23			      inc   HL 
1272 56			      ld    D, (HL) 
1273 e5			      push  HL                      ; Save ptr to next block for later 
1274			 
1274 60			      ld    H, B                    ; Store ptr from next block into freed block 
1275 69			      ld    L, C 
1276 73			      ld    (HL), E 
1277 23			      inc   HL 
1278 72			      ld    (HL), D 
1279			 
1279 e1			      pop   HL                      ; Restore ptr to next block 
127a 23			      inc   HL                      ; Load size of next block into DE 
127b 5e			      ld    E, (HL) 
127c 23			      inc   HL 
127d 56			      ld    D, (HL) 
127e d5			      push  DE                      ; Save next block size for later 
127f			 
127f 60			      ld    H, B                    ; Load size of freed block into HL 
1280 69			      ld    L, C 
1281 23			      inc   HL 
1282 23			      inc   HL 
1283 5e			      ld    E, (HL) 
1284 23			      inc   HL 
1285 56			      ld    D, (HL) 
1286 eb			      ex    DE, HL 
1287			 
1287 d1			      pop   DE                      ; Restore size of next block 
1288 19			      add   HL, DE                  ; Add sizes of both blocks 
1289 eb			      ex    DE, HL 
128a			 
128a 60			      ld    H, B                    ; Store new bigger size into freed block 
128b 69			      ld    L, C 
128c 23			      inc   HL 
128d 23			      inc   HL 
128e 73			      ld    (HL), E 
128f 23			      inc   HL 
1290 72			      ld    (HL), D 
1291			 
1291			free_check_adjacent_to_prev: 
1291			      ; Check if the freed block is adjacent to the prev free block 
1291 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1294 dd 66 03		      ld    H, (IX+3) 
1297			 
1297 23			      inc   HL                      ; Size of prev free block into DE 
1298 23			      inc   HL 
1299 5e			      ld    E, (HL) 
129a 23			      inc   HL 
129b 56			      ld    D, (HL) 
129c 2b			      dec   HL 
129d 2b			      dec   HL 
129e 2b			      dec   HL 
129f			 
129f 19			      add   HL, DE                  ; Add prev block addr and size 
12a0			 
12a0 b7			      or    A                       ; Clear the carry flag 
12a1 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12a3 20 2e		      jr    NZ, free_done 
12a5			 
12a5			      ; Freed block is adjacent to prev, merge into one bigger block 
12a5 60			      ld    H, B                    ; Load next ptr from freed block into DE 
12a6 69			      ld    L, C 
12a7 5e			      ld    E, (HL) 
12a8 23			      inc   HL 
12a9 56			      ld    D, (HL) 
12aa e5			      push  HL                      ; Save freed block ptr for later 
12ab			 
12ab dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12ae dd 66 03		      ld    H, (IX+3) 
12b1 73			      ld    (HL), E 
12b2 23			      inc   HL 
12b3 72			      ld    (HL), D 
12b4			 
12b4 e1			      pop   HL                      ; Restore freed block ptr 
12b5 23			      inc   HL                      ; Load size of freed block into DE 
12b6 5e			      ld    E, (HL) 
12b7 23			      inc   HL 
12b8 56			      ld    D, (HL) 
12b9 d5			      push  DE                      ; Save freed block size for later 
12ba			 
12ba dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
12bd dd 66 03		      ld    H, (IX+3) 
12c0 23			      inc   HL 
12c1 23			      inc   HL 
12c2 5e			      ld    E, (HL) 
12c3 23			      inc   HL 
12c4 56			      ld    D, (HL) 
12c5			 
12c5 e1			      pop   HL                      ; Add sizes of both blocks 
12c6 19			      add   HL, DE 
12c7 eb			      ex    DE, HL 
12c8			 
12c8 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
12cb dd 66 03		      ld    H, (IX+3) 
12ce 23			      inc   HL 
12cf 23			      inc   HL 
12d0 73			      ld    (HL), E 
12d1 23			      inc   HL 
12d2 72			      ld    (HL), D 
12d3			 
12d3			free_done: 
12d3 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
12d6 39			      add   HL, SP 
12d7 f9			      ld    SP, HL 
12d8			 
12d8			free_early_exit: 
12d8 dd e1		      pop   IX 
12da d1			      pop   DE 
12db c1			      pop   BC 
12dc			 
12dc c9			      ret 
12dd			 
12dd			; moved to firmware.asm 
12dd			; 
12dd			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12dd			;                  .dw   0 
12dd			 
12dd			 
12dd			endif 
12dd			 
12dd			 
12dd			if MALLOC_3 
12dd			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12dd			;heap_start        .equ  0x9000      ; Starting address of heap 
12dd			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12dd			; 
12dd			 ;     .org 0 
12dd			  ;    jp    main 
12dd			; 
12dd			; 
12dd			 ;     .org  0x100 
12dd			;main: 
12dd			 ;     ld    HL, 0x8100 
12dd			  ;    ld    SP, HL 
12dd			; 
12dd			;      call  heap_init 
12dd			 
12dd			      ; Make some allocations 
12dd			;      ld    HL, 12 
12dd			;      call  malloc            ; Allocates 0x9004 
12dd			; 
12dd			 ;     ld    HL, 12 
12dd			;      call  malloc            ; Allocates 0x9014 
12dd			 
12dd			;      ld    HL, 12 
12dd			;      call  malloc            ; Allocates 0x9024 
12dd			 
12dd			      ; Free some allocations 
12dd			;      ld    HL, 0x9014 
12dd			;      call  free 
12dd			 
12dd			;      ld    HL, 0x9004 
12dd			;      call  free 
12dd			; 
12dd			;      ld    HL, 0x9024 
12dd			;      call  free 
12dd			 
12dd			 
12dd			 ;     halt 
12dd			 
12dd			 
12dd			;------------------------------------------------------------------------------ 
12dd			;     heap_init                                                               : 
12dd			;                                                                             : 
12dd			; Description                                                                 : 
12dd			;     Initialise the heap and make it ready for malloc and free operations.   : 
12dd			;                                                                             : 
12dd			;     The heap is maintained as a linked list, starting with an initial       : 
12dd			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12dd			;     the first free block in the heap. Each block then points to the next    : 
12dd			;     free block within the heap, and the free list ends at the first block   : 
12dd			;     with a null pointer to the next free block.                             : 
12dd			;                                                                             : 
12dd			; Parameters                                                                  : 
12dd			;     Inputs are compile-time only. Two defines which specify the starting    : 
12dd			;     address of the heap and its size are required, along with a memory      : 
12dd			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12dd			;     principally stores a pointer to the first free block in the heap.       : 
12dd			;                                                                             : 
12dd			; Returns                                                                     : 
12dd			;     Nothing                                                                 : 
12dd			;------------------------------------------------------------------------------ 
12dd			heap_init: 
12dd			      push  HL 
12dd			 
12dd			      ; Initialise free list struct 
12dd			      ld    HL, heap_start 
12dd			      ld    (free_list), HL 
12dd			      ld    HL, 0 
12dd			      ld    (free_list+2), HL 
12dd			 
12dd			      ; Insert first free block at bottom of heap, consumes entire heap 
12dd			      ld    HL, heap_start+heap_size-4 
12dd			      ld    (heap_start), HL        ; Next block (end of free list) 
12dd			      ld    HL, heap_size-4 
12dd			      ld    (heap_start+2), HL      ; Block size 
12dd			 
12dd			      ; Insert end of free list block at top of heap - two null words will 
12dd			      ; terminate the free list 
12dd			      ld    HL, 0 
12dd			      ld    (heap_start+heap_size-2), HL 
12dd			      ld    (heap_start+heap_size-4), HL 
12dd			 
12dd			      pop   HL 
12dd			 
12dd			      ret 
12dd			 
12dd			 
12dd			;------------------------------------------------------------------------------ 
12dd			;     malloc                                                                  : 
12dd			;                                                                             : 
12dd			; Description                                                                 : 
12dd			;     Allocates the wanted space from the heap and returns the address of the : 
12dd			;     first useable byte of the allocation.                                   : 
12dd			;                                                                             : 
12dd			;     Allocations can happen in one of two ways:                              : 
12dd			;                                                                             : 
12dd			;     1. A free block may be found which is the exact size wanted. In this    : 
12dd			;        case the block is removed from the free list and retuedn to the      : 
12dd			;        caller.                                                              : 
12dd			;     2. A free block may be found which is larger than the size wanted. In   : 
12dd			;        this case, the larger block is split into two. The first portion of  : 
12dd			;        this block will become the requested space by the malloc call and    : 
12dd			;        is returned to the caller. The second portion becomes a new free     : 
12dd			;        block, and the free list is adjusted to maintain continuity via this : 
12dd			;        newly created block.                                                 : 
12dd			;                                                                             : 
12dd			;     malloc does not set any initial value in the allocated space, the       : 
12dd			;     caller is required to do this as required.                              : 
12dd			;                                                                             : 
12dd			;     This implementation of malloc uses the stack exclusively, and is        : 
12dd			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12dd			;     advisable to disable interrupts before calling malloc, and recommended  : 
12dd			;     to avoid the use of malloc inside ISRs in general.                      : 
12dd			;                                                                             : 
12dd			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12dd			;                                                                             : 
12dd			; Parameters                                                                  : 
12dd			;     HL  Number of bytes wanted                                              : 
12dd			;                                                                             : 
12dd			; Returns                                                                     : 
12dd			;     HL  Address of the first useable byte of the allocation                 : 
12dd			;                                                                             : 
12dd			; Flags                                                                       : 
12dd			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12dd			;                                                                             : 
12dd			; Stack frame                                                                 : 
12dd			;       |             |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |     BC      |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |     DE      |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |     IX      |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |  prev_free  |                                                       : 
12dd			;   +4  +-------------+                                                       : 
12dd			;       |  this_free  |                                                       : 
12dd			;   +2  +-------------+                                                       : 
12dd			;       |  next_free  |                                                       : 
12dd			;   +0  +-------------+                                                       : 
12dd			;       |             |                                                       : 
12dd			;                                                                             : 
12dd			;------------------------------------------------------------------------------ 
12dd			malloc: 
12dd			      push  BC 
12dd			      push  DE 
12dd			      push  IX 
12dd			 
12dd			      ld    A, H                    ; Exit if no space requested 
12dd			      or    L 
12dd			      jp    Z, malloc_early_exit 
12dd			 
12dd			      ; Set up stack frame 
12dd			      ex    DE, HL 
12dd			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12dd			      add   HL, SP 
12dd			      ld    SP, HL 
12dd			      ld    IX, 0                   ; Use IX as a frame pointer 
12dd			      add   IX, SP 
12dd			 
12dd			      ; Setup initial state 
12dd			      ld    HL, 4                   ; want must also include space used by block struct 
12dd			      add   HL, DE 
12dd			 
12dd			      ld    B, H                    ; Move want to BC 
12dd			      ld    C, L 
12dd			 
12dd			      ld    HL, free_list           ; Store prev_free ptr to stack 
12dd			      ld    (IX+4), L 
12dd			      ld    (IX+5), H 
12dd			 
12dd			      ld    E, (HL)                 ; Store this_free ptr to stack 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      ld    (IX+2), E 
12dd			      ld    (IX+3), D 
12dd			      ex    DE, HL                  ; this_free ptr into HL 
12dd			 
12dd			      ; Loop through free block list to find some space 
12dd			malloc_find_space: 
12dd			      ld    E, (HL)                 ; Load next_free ptr into DE 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			 
12dd			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12dd			      or    E 
12dd			      jp    Z, malloc_no_space 
12dd			 
12dd			      ld    (IX+0), E               ; Store next_free ptr to stack 
12dd			      ld    (IX+1), D 
12dd			 
12dd			      ; Does this block have enough space to make the allocation? 
12dd			      inc   HL                      ; Load free block size into DE 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			 
12dd			      ex    DE, HL                  ; Check size of block against want 
12dd			      or    A                       ; Ensure carry flag clear 
12dd			      sbc   HL, BC 
12dd			      push  HL                      ; Store the result for later (new block size) 
12dd			 
12dd			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12dd			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12dd			 
12dd			      ; this_free block is not big enough, setup ptrs to test next free block 
12dd			      pop   HL                      ; Discard previous result 
12dd			 
12dd			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12dd			      ld    H, (IX+3) 
12dd			      ld    (IX+4), L 
12dd			      ld    (IX+5), H 
12dd			 
12dd			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12dd			      ld    H, (IX+1) 
12dd			      ld    (IX+2), L 
12dd			      ld    (IX+3), H 
12dd			 
12dd			      jr    malloc_find_space 
12dd			 
12dd			      ; split a bigger block into two - requested size and remaining size 
12dd			malloc_alloc_split: 
12dd			      ex    DE, HL                  ; Calculate address of new free block 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			      add   HL, BC 
12dd			 
12dd			      ; Create a new block and point it at next_free 
12dd			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12dd			      ld    D, (IX+1) 
12dd			 
12dd			      ld    (HL), E                 ; Store next_free ptr into new block 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			      pop   DE                      ; Store size of new block into new block 
12dd			      inc   HL 
12dd			      ld    (HL), E 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			      ; Update this_free ptr to point to new block 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			 
12dd			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12dd			      ld    D, (IX+3) 
12dd			 
12dd			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12dd			      ld    (IX+3), H 
12dd			 
12dd			      ; Modify this_free block to be allocation 
12dd			      ex    DE, HL 
12dd			      xor   A                       ; Null the next block ptr of allocated block 
12dd			      ld    (HL), A 
12dd			      inc   HL 
12dd			      ld    (HL), A 
12dd			 
12dd			      inc   HL                      ; Store want size into allocated block 
12dd			      ld    (HL), C 
12dd			      inc   HL 
12dd			      ld    (HL), B 
12dd			      inc   HL 
12dd			      push  HL                      ; Address of allocation to return 
12dd			 
12dd			      jr    malloc_update_links 
12dd			 
12dd			malloc_alloc_fit: 
12dd			      pop   HL                      ; Dont need new block size, want is exact fit 
12dd			 
12dd			      ; Modify this_free block to be allocation 
12dd			      ex    DE, HL 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			 
12dd			      xor   A                       ; Null the next block ptr of allocated block 
12dd			      ld    (HL), A 
12dd			      inc   HL 
12dd			      ld    (HL), A 
12dd			 
12dd			      inc   HL                      ; Store address of allocation to return 
12dd			      inc   HL 
12dd			      inc   HL 
12dd			      push  HL 
12dd			 
12dd			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12dd			      ld    L, (IX+0)               ; next_free to HL 
12dd			      ld    H, (IX+1) 
12dd			 
12dd			      ld    (IX+2), L               ; HL to this_free 
12dd			      ld    (IX+3), H 
12dd			 
12dd			 
12dd			malloc_update_links: 
12dd			      ; Update prev_free ptr to point to this_free 
12dd			      ld    L, (IX+4)               ; prev_free ptr to HL 
12dd			      ld    H, (IX+5) 
12dd			 
12dd			      ld    E, (IX+2)               ; this_free ptr to DE 
12dd			      ld    D, (IX+3) 
12dd			 
12dd			      ld    (HL), E                 ; this_free ptr into prev_free 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			      ; Clear the Z flag to indicate successful allocation 
12dd			      ld    A, D 
12dd			      or    E 
12dd			 
12dd			      pop   DE                      ; Address of allocation 
12dd			 
12dd			malloc_no_space: 
12dd			      ld    HL, 6                   ; Clean up stack frame 
12dd			      add   HL, SP 
12dd			      ld    SP, HL 
12dd			 
12dd			      ex    DE, HL                  ; Alloc addr into HL for return 
12dd			 
12dd			malloc_early_exit: 
12dd			      pop   IX 
12dd			      pop   DE 
12dd			      pop   BC 
12dd			 
12dd			      ret 
12dd			 
12dd			 
12dd			;------------------------------------------------------------------------------ 
12dd			;     free                                                                    : 
12dd			;                                                                             : 
12dd			; Description                                                                 : 
12dd			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12dd			;     returned by malloc, otherwise the behaviour is undefined.               : 
12dd			;                                                                             : 
12dd			;     Where possible, directly adjacent free blocks will be merged together   : 
12dd			;     into larger blocks to help ensure that the heap does not become         : 
12dd			;     excessively fragmented.                                                 : 
12dd			;                                                                             : 
12dd			;     free does not clear or set any other value into the freed space, and    : 
12dd			;     therefore its contents may be visible through subsequent malloc's. The  : 
12dd			;     caller should clear the freed space as required.                        : 
12dd			;                                                                             : 
12dd			;     This implementation of free uses the stack exclusively, and is          : 
12dd			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12dd			;     advisable to disable interrupts before calling free, and recommended    : 
12dd			;     to avoid the use of free inside ISRs in general.                        : 
12dd			;                                                                             : 
12dd			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12dd			;                                                                             : 
12dd			; Parameters                                                                  : 
12dd			;     HL  Pointer to address of first byte of allocation to be freed          : 
12dd			;                                                                             : 
12dd			; Returns                                                                     : 
12dd			;     Nothing                                                                 : 
12dd			;                                                                             : 
12dd			; Stack frame                                                                 : 
12dd			;       |             |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |     BC      |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |     DE      |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |     IX      |                                                       : 
12dd			;       +-------------+                                                       : 
12dd			;       |  prev_free  |                                                       : 
12dd			;   +2  +-------------+                                                       : 
12dd			;       |  next_free  |                                                       : 
12dd			;   +0  +-------------+                                                       : 
12dd			;       |             |                                                       : 
12dd			;                                                                             : 
12dd			;------------------------------------------------------------------------------ 
12dd			free: 
12dd			      push  BC 
12dd			      push  DE 
12dd			      push  IX 
12dd			 
12dd			      ld    A, H                    ; Exit if ptr is null 
12dd			      or    L 
12dd			      jp    Z, free_early_exit 
12dd			 
12dd			      ; Set up stack frame 
12dd			      ex    DE, HL 
12dd			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12dd			      add   HL, SP 
12dd			      ld    SP, HL 
12dd			      ld    IX, 0                   ; Use IX as a frame pointer 
12dd			      add   IX, SP 
12dd			 
12dd			      ; The address in HL points to the start of the useable allocated space, 
12dd			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12dd			      ; address of the block itself. 
12dd			      ex    DE, HL 
12dd			      ld    DE, -4 
12dd			      add   HL, DE 
12dd			 
12dd			      ; An allocated block must have a null next block pointer in it 
12dd			      ld    A, (HL) 
12dd			      inc   HL 
12dd			      or    (HL) 
12dd			      jp    NZ, free_done 
12dd			 
12dd			      dec   HL 
12dd			 
12dd			      ld    B, H                    ; Copy HL to BC 
12dd			      ld    C, L 
12dd			 
12dd			      ; Loop through the free list to find the first block with an address 
12dd			      ; higher than the block being freed 
12dd			      ld    HL, free_list 
12dd			 
12dd			free_find_higher_block: 
12dd			      ld    E, (HL)                 ; Load next ptr from free block 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      dec   HL 
12dd			 
12dd			      ld    (IX+0), E               ; Save ptr to next free block 
12dd			      ld    (IX+1), D 
12dd			      ld    (IX+2), L               ; Save ptr to prev free block 
12dd			      ld    (IX+3), H 
12dd			 
12dd			      ld    A, B                    ; Check if DE is greater than BC 
12dd			      cp    D                       ; Compare MSB first 
12dd			      jr    Z, $+4                  ; MSB the same, compare LSB 
12dd			      jr    NC, free_find_higher_block_skip 
12dd			      ld    A, C 
12dd			      cp    E                       ; Then compare LSB 
12dd			      jr    C, free_found_higher_block 
12dd			 
12dd			free_find_higher_block_skip: 
12dd			      ld    A, D                    ; Reached the end of the free list? 
12dd			      or    E 
12dd			      jp    Z, free_done 
12dd			 
12dd			      ex    DE, HL 
12dd			 
12dd			      jr    free_find_higher_block 
12dd			 
12dd			free_found_higher_block: 
12dd			      ; Insert freed block between prev and next free blocks 
12dd			      ld    (HL), C                 ; Point prev free block to freed block 
12dd			      inc   HL 
12dd			      ld    (HL), B 
12dd			 
12dd			      ld    H, B                    ; Point freed block at next free block 
12dd			      ld    L, C 
12dd			      ld    (HL), E 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			      ; Check if the freed block is adjacent to the next free block 
12dd			      inc   HL                      ; Load size of freed block into HL 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      ex    DE, HL 
12dd			 
12dd			      add   HL, BC                  ; Add addr of freed block and its size 
12dd			 
12dd			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12dd			      ld    D, (IX+1) 
12dd			 
12dd			      or    A                       ; Clear the carry flag 
12dd			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12dd			      jr    NZ, free_check_adjacent_to_prev 
12dd			 
12dd			      ; Freed block is adjacent to next, merge into one bigger block 
12dd			      ex    DE, HL                  ; Load next ptr from next block into DE 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      push  HL                      ; Save ptr to next block for later 
12dd			 
12dd			      ld    H, B                    ; Store ptr from next block into freed block 
12dd			      ld    L, C 
12dd			      ld    (HL), E 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			      pop   HL                      ; Restore ptr to next block 
12dd			      inc   HL                      ; Load size of next block into DE 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      push  DE                      ; Save next block size for later 
12dd			 
12dd			      ld    H, B                    ; Load size of freed block into HL 
12dd			      ld    L, C 
12dd			      inc   HL 
12dd			      inc   HL 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      ex    DE, HL 
12dd			 
12dd			      pop   DE                      ; Restore size of next block 
12dd			      add   HL, DE                  ; Add sizes of both blocks 
12dd			      ex    DE, HL 
12dd			 
12dd			      ld    H, B                    ; Store new bigger size into freed block 
12dd			      ld    L, C 
12dd			      inc   HL 
12dd			      inc   HL 
12dd			      ld    (HL), E 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			free_check_adjacent_to_prev: 
12dd			      ; Check if the freed block is adjacent to the prev free block 
12dd			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12dd			      ld    H, (IX+3) 
12dd			 
12dd			      inc   HL                      ; Size of prev free block into DE 
12dd			      inc   HL 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			      dec   HL 
12dd			 
12dd			      add   HL, DE                  ; Add prev block addr and size 
12dd			 
12dd			      or    A                       ; Clear the carry flag 
12dd			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12dd			      jr    NZ, free_done 
12dd			 
12dd			      ; Freed block is adjacent to prev, merge into one bigger block 
12dd			      ld    H, B                    ; Load next ptr from freed block into DE 
12dd			      ld    L, C 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      push  HL                      ; Save freed block ptr for later 
12dd			 
12dd			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12dd			      ld    H, (IX+3) 
12dd			      ld    (HL), E 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			      pop   HL                      ; Restore freed block ptr 
12dd			      inc   HL                      ; Load size of freed block into DE 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			      push  DE                      ; Save freed block size for later 
12dd			 
12dd			      ld    L, (IX+2)               ; Load size of prev block into DE 
12dd			      ld    H, (IX+3) 
12dd			      inc   HL 
12dd			      inc   HL 
12dd			      ld    E, (HL) 
12dd			      inc   HL 
12dd			      ld    D, (HL) 
12dd			 
12dd			      pop   HL                      ; Add sizes of both blocks 
12dd			      add   HL, DE 
12dd			      ex    DE, HL 
12dd			 
12dd			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12dd			      ld    H, (IX+3) 
12dd			      inc   HL 
12dd			      inc   HL 
12dd			      ld    (HL), E 
12dd			      inc   HL 
12dd			      ld    (HL), D 
12dd			 
12dd			free_done: 
12dd			      ld    HL, 4                   ; Clean up stack frame 
12dd			      add   HL, SP 
12dd			      ld    SP, HL 
12dd			 
12dd			free_early_exit: 
12dd			      pop   IX 
12dd			      pop   DE 
12dd			      pop   BC 
12dd			 
12dd			      ret 
12dd			 
12dd			 
12dd			;      .org 0x8000 
12dd			; 
12dd			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12dd			 ;                 .dw   0 
12dd			 
12dd			endif 
12dd			 
12dd			 
12dd			if MALLOC_4 
12dd			 
12dd			; My memory allocation code. Very very simple.... 
12dd			; allocate space under 250 chars 
12dd			 
12dd			heap_init: 
12dd				; init start of heap as zero 
12dd				;  
12dd			 
12dd				ld hl, heap_start 
12dd			;	ld a, 0 
12dd				ld (hl), 0      ; empty block 
12dd				inc hl 
12dd			;	ld a, 0 
12dd				ld (hl), 0      ; length of block 
12dd				; write end of list 
12dd				inc hl 
12dd				ld a,(hl) 
12dd				inc hl 
12dd				ld a,(hl) 
12dd				 
12dd			 
12dd				; init some malloc vars 
12dd			 
12dd				ld hl, 0 
12dd				ld (free_list), hl       ; store last malloc location 
12dd			 
12dd				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12dd			;	ld a, 0 
12dd				ld (hl), 0 
12dd			 
12dd			 
12dd				ld hl, heap_start 
12dd				;  
12dd				  
12dd				ret 
12dd			 
12dd			 
12dd			;    free block marker 
12dd			;    requested size  
12dd			;    pointer to next block 
12dd			;    .... 
12dd			;    next block marker 
12dd			 
12dd			 
12dd			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12dd			; 
12dd			 
12dd			 
12dd			malloc:  
12dd				push de 
12dd				push bc 
12dd				push af 
12dd			 
12dd				; hl space required 
12dd				 
12dd				ld c, l    ; hold space   (TODO only a max of 255) 
12dd			 
12dd			;	inc c     ; TODO BUG need to fix memory leak on push str 
12dd			;	inc c 
12dd			;	inc c 
12dd			;	inc c 
12dd			;	inc c 
12dd			;	inc c 
12dd			;	inc c 
12dd			 
12dd			 
12dd			 
12dd				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12dd			 
12dd				ld a, (free_list+3) 
12dd			;	cp 0 
12dd				or a 
12dd				jr z, .contheap 
12dd			 
12dd				ld hl, (free_list)     ; get last alloc 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "mrs" 
12dd						CALLMONITOR 
12dd					endif 
12dd				jr .startalloc 
12dd			 
12dd			.contheap: 
12dd				ld hl, heap_start 
12dd			 
12dd			.startalloc: 
12dd			 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "mym" 
12dd						CALLMONITOR 
12dd					endif 
12dd			.findblock: 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "mmf" 
12dd						CALLMONITOR 
12dd					endif 
12dd			 
12dd				ld a,(hl)  
12dd				; if byte is zero then clear to use 
12dd			 
12dd			;	cp 0 
12dd				or a 
12dd				jr z, .foundemptyblock 
12dd			 
12dd				; if byte is not clear 
12dd				;     then byte is offset to next block 
12dd			 
12dd				inc hl 
12dd				ld a, (hl) ; get size 
12dd			.nextblock:	inc hl 
12dd					ld e, (hl) 
12dd					inc hl 
12dd					ld d, (hl) 
12dd					ex de, hl 
12dd			;	inc hl  ; move past the store space 
12dd			;	inc hl  ; move past zero index  
12dd			 
12dd				; TODO detect no more space 
12dd			 
12dd				push hl 
12dd				ld de, heap_end 
12dd				call cmp16 
12dd				pop hl 
12dd				jr nc, .nospace 
12dd			 
12dd				jr .findblock 
12dd			 
12dd			.nospace: ld hl, 0 
12dd				jp .exit 
12dd			 
12dd			 
12dd			.foundemptyblock:	 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "mme" 
12dd						CALLMONITOR 
12dd					endif 
12dd			 
12dd			; TODO has block enough space if reusing??? 
12dd			 
12dd				;  
12dd			 
12dd			; see if this block has been previously used 
12dd				inc hl 
12dd				ld a, (hl) 
12dd				dec hl 
12dd			;	cp 0 
12dd				or a 
12dd				jr z, .newblock 
12dd			 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "meR" 
12dd						CALLMONITOR 
12dd					endif 
12dd			 
12dd			; no reusing previously allocated block 
12dd			 
12dd			; is it smaller than previously used? 
12dd				 
12dd				inc hl    ; move to size 
12dd				ld a, c 
12dd				sub (hl)        ; we want c < (hl) 
12dd				dec hl    ; move back to marker 
12dd			        jr z, .findblock 
12dd			 
12dd				; update with the new size which should be lower 
12dd			 
12dd			        ;inc  hl   ; negate next move. move back to size  
12dd			 
12dd			.newblock: 
12dd				; need to be at marker here 
12dd			 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "meN" 
12dd						CALLMONITOR 
12dd					endif 
12dd			 
12dd			 
12dd				ld a, c 
12dd			 
12dd				ld (free_list+3), a	 ; flag resume from last malloc  
12dd				ld (free_list), hl    ; save out last location 
12dd			 
12dd			 
12dd				;inc a     ; space for length byte 
12dd				ld (hl), a     ; save block in use marker 
12dd			 
12dd				inc hl   ; move to space marker 
12dd				ld (hl), a    ; save new space 
12dd			 
12dd				inc hl   ; move to start of allocated area 
12dd				 
12dd			;	push hl     ; save where we are - 1  
12dd			 
12dd			;	inc hl  ; move past zero index  
12dd				; skip space to set down new marker 
12dd			 
12dd				; provide some extra space for now 
12dd			 
12dd				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12dd				inc a 
12dd				inc a 
12dd			 
12dd				push hl   ; save where we are in the node block 
12dd			 
12dd				call addatohl 
12dd			 
12dd				; write linked list point 
12dd			 
12dd				pop de     ; get our node position 
12dd				ex de, hl 
12dd			 
12dd				ld (hl), e 
12dd				inc hl 
12dd				ld (hl), d 
12dd			 
12dd				inc hl 
12dd			 
12dd				; now at start of allocated data so save pointer 
12dd			 
12dd				push hl 
12dd			 
12dd				; jump to position of next node and setup empty header in DE 
12dd			 
12dd				ex de, hl 
12dd			 
12dd			;	inc hl ; move past end of block 
12dd			 
12dd			;	ld a, 0 
12dd				ld (hl), 0   ; empty marker 
12dd				inc hl 
12dd				ld (hl), 0   ; size 
12dd				inc hl  
12dd				ld (hl), 0   ; ptr 
12dd				inc hl 
12dd				ld (hl), 0   ; ptr 
12dd			 
12dd			 
12dd				pop hl 
12dd			 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "mmr" 
12dd						CALLMONITOR 
12dd					endif 
12dd			 
12dd			.exit: 
12dd				pop af 
12dd				pop bc 
12dd				pop de  
12dd				ret 
12dd			 
12dd			 
12dd			 
12dd			 
12dd			free:  
12dd				push hl 
12dd				push af 
12dd				; get address in hl 
12dd			 
12dd					if DEBUG_FORTH_MALLOC_INT 
12dd						DMARK "fre" 
12dd						CALLMONITOR 
12dd					endif 
12dd				; data is at hl - move to block count 
12dd				dec hl 
12dd				dec hl    ; get past pointer 
12dd				dec hl 
12dd			 
12dd				ld a, (hl)    ; need this for a validation check 
12dd			 
12dd				dec hl    ; move to block marker 
12dd			 
12dd				; now check that the block count and block marker are the same  
12dd			        ; this checks that we are on a malloc node and not random memory 
12dd			        ; OK a faint chance this could be a problem but rare - famous last words! 
12dd			 
12dd				ld c, a 
12dd				ld a, (hl)    
12dd			 
12dd				cp c 
12dd				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12dd			 
12dd				; yes good chance we are on a malloc node 
12dd			 
12dd			;	ld a, 0      
12dd				ld (hl), 0   ; mark as free 
12dd			 
12dd				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12dd			 
12dd			.freeignore:  
12dd			 
12dd				pop af 
12dd				pop hl 
12dd			 
12dd				ret 
12dd			 
12dd			 
12dd			 
12dd			endif 
12dd			 
