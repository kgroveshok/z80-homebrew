1325			malloc_guard_zerolen: 
1325				push hl 
1325				push de 
1325				push af 
1325			 
1325				ld de, 0 
1325			        call cmp16 
1325				jr nz, .lowalloz 
1325			 
1325				push hl 
1325				push de 
1325					ld hl, display_fb0 
1325					ld (display_fb_active), hl 
1325				call clear_display 
1325				ld a, 0 
1325				ld de, .malloczero 
1325				call str_at_display 
1325				call update_display 
1325				call delay1s 
1325				call delay1s 
1325				call bp_on 
1325			;	ld a, 0 
1325			;	ld (os_view_disable), a 
1325			 
1325				pop de 
1325				pop hl 
1325			 
1325				 
1325			 
1325				CALLMONITOR 
1325			.lowalloz: 
1325			 
1325			 
1325				pop af 
1325				pop de 
1325				pop hl 
1325			ret 
