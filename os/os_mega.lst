0754			; Save Config 
0754			; Find free block 
0754			; Set buffer with file name and file id 
0754			; Write buffer to free block  
0754			 
0754			 
0754			; hl point to file name 
0754			; hl returns file id 
0754			 
0754			; file format: 
0754			; byte 0 - file id 
0754			; byte 1 - extent number 
0754			; byte 2-> data 
0754			 
0754			; format for extent number 0: 
0754			; 
0754			; byte 0 - file id 
0754			; byte 1 - extent 0 
0754			; byte 2 - extent count 
0754			; byte 3 -> file name and meta data 
