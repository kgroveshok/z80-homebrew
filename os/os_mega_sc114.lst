bf25			.SESELS: 
bf25				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bf25			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bf25			; | | Set to zero to disable storage. 
bf25					if DEBUG_FORTH_WORDS_KEY 
bf25						DMARK "BNK" 
bf25						CALLMONITOR 
bf25					endif 
bf25			 
bf25					ld a, 255 
bf25					ld (spi_cartdev), a 
bf25			 
bf25					; get bank 
bf25			 
bf25					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf25			 
bf25			;		push hl 
bf25			 
bf25					; destroy value TOS 
bf25			 
bf25					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf25			 
bf25					; one value on hl get other one back 
bf25			 
bf25			;		pop hl 
bf25			 
bf25			 
bf25					ld c, SPI_CE_HIGH 
bf25					ld b, '0'    ; human readable bank number 
bf25			 
bf25					ld a, l 
bf25			 
bf25					if DEBUG_FORTH_WORDS 
bf25						DMARK "BNK" 
bf25						CALLMONITOR 
bf25					endif 
bf25			 
bf25					; active low 
bf25			 
bf25			;		cp 0 
bf25					or a 
bf25					jr z, .bset 
bf25					cp 1 
bf25					jr nz, .b2 
bf25					res 0, c 
bf25					ld b, '1'    ; human readable bank number 
bf25			.b2:		cp 2 
bf25					jr nz, .b3 
bf25					res 1, c 
bf25					ld b, '2'    ; human readable bank number 
bf25			.b3:		cp 3 
bf25					jr nz, .b4 
bf25					res 2, c 
bf25					ld b, '3'    ; human readable bank number 
bf25			.b4:		cp 4 
bf25					jr nz, .b5 
bf25					res 3, c 
bf25					ld b, '4'    ; human readable bank number 
bf25			.b5:		cp 5 
bf25					jr nz, .bset 
bf25					res 4, c 
bf25					ld b, '5'    ; human readable bank number 
bf25			 
bf25			.bset: 
bf25					ld a, c 
bf25					ld (spi_device),a 
bf25					ld a, b 
bf25					ld (spi_device_id),a 
bf25					if DEBUG_FORTH_WORDS 
bf25						DMARK "BN2" 
bf25						CALLMONITOR 
bf25					endif 
bf25			 
bf25					; set default SPI clk pulse time as disabled for BANK use 
bf25			 
bf25					ld a, 0 
bf25					ld (spi_clktime), a 
bf25			 
bf25					NEXTW 
bf25			 
bf25			.CARTDEV: 
bf25				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bf25			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bf25			; | | Set to zero to disable devices. 
bf25					if DEBUG_FORTH_WORDS_KEY 
bf25						DMARK "CDV" 
bf25						CALLMONITOR 
bf25					endif 
bf25			 
bf25					; disable se storage bank selection 
bf25			 
bf25					ld a, SPI_CE_HIGH		; ce high 
bf25					ld (spi_device), a 
bf25			 
bf25					; get bank 
bf25			 
bf25					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf25			 
bf25			;		push hl 
bf25			 
bf25					; destroy value TOS 
bf25			 
bf25					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf25			 
bf25					; one value on hl get other one back 
bf25			 
bf25			;		pop hl 
bf25			 
bf25					; active low 
bf25			 
bf25					ld c, 255 
bf25			 
bf25					ld a, l 
bf25					if DEBUG_FORTH_WORDS 
bf25						DMARK "CDV" 
bf25						CALLMONITOR 
bf25					endif 
bf25			;		cp 0 
bf25					or a 
bf25					jr z, .cset 
bf25					cp 1 
bf25					jr nz, .c2 
bf25					res 0, c 
bf25			.c2:		cp 2 
bf25					jr nz, .c3 
bf25					res 1, c 
bf25			.c3:		cp 3 
bf25					jr nz, .c4 
bf25					res 2, c 
bf25			.c4:		cp 4 
bf25					jr nz, .c5 
bf25					res 3, c 
bf25			.c5:		cp 5 
bf25					jr nz, .c6 
bf25					res 4, c 
bf25			.c6:		cp 6 
bf25					jr nz, .c7 
bf25					res 5, c 
bf25			.c7:		cp 7 
bf25					jr nz, .c8 
bf25					res 6, c 
bf25			.c8:		cp 8 
bf25					jr nz, .cset 
bf25					res 7, c 
bf25			.cset:		ld a, c 
bf25					ld (spi_cartdev),a 
bf25			 
bf25					if DEBUG_FORTH_WORDS 
bf25						DMARK "CD2" 
bf25						CALLMONITOR 
bf25					endif 
bf25			 
bf25					; set default SPI clk pulse time as 10ms for CARTDEV use 
bf25			 
bf25					ld a, $0a 
bf25					ld (spi_clktime), a 
bf25					NEXTW 
bf25			endif 
bf25			 
bf25			.ENDDEVICE: 
bf25			; eof 
bf25			 
# End of file forth_words_device.asm
