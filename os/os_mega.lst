2471			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
2471			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
2471			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
2471			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
2471			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
2471			WORD_SYS_END: equ 0   ; Opcode for all user words 
2471			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
2471			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
2471			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
2471			 
2471			; Core word preamble macro 
2471			 
2471			CWHEAD:   macro nxtword opcode lit len opflags 
2471				db WORD_SYS_CORE+opcode             
2471				; internal op code number 
2471				dw nxtword            
2471				; link to next dict word block 
2471				db len + 1 
2471				; literal length of dict word inc zero term 
2471				db lit,0              
2471				; literal dict word 
2471			        ; TODO db opflags        
2471				endm 
