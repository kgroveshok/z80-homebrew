# End of macro CWHEAD
4b6a			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4b6a			; | | e.g. 
4b6a			; | | $01 OPEN $01 DO READ . LOOP 
4b6a			; | | 
4b6a			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4b6a			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4b6a			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4b6a			; | | two bytes contain the file id and extent. 
4b6a			; | |  
4b6a			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4b6a			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4b6a			; | | > [!NOTE] 
4b6a			; | | > Compatible with PicoSPINet  
4b6a			 
4b6a					if DEBUG_FORTH_WORDS_KEY 
4b6a						DMARK "REA" 
4b6a				if DEMARK_VERSION = 1  
4b6a e5					push hl  
4b6b 21 73 4b				ld hl, .dmark  
4b6e 22 9b fd				ld (debug_mark), hl  
4b71				endif  
