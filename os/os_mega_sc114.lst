d563			 
d563					if DEBUG_FORTH_WORDS 
d563						DMARK "ASr" 
d563						CALLMONITOR 
d563					endif 
d563			 
d563					call ishlzero 
d563					ret z             ; file not found 
d563			 
d563					ld a, display_row_2 + 10 
d563					ld de, store_page+3 
d563					call str_at_display 
d563				 
d563			; 
d563			 
d563				ld a, display_row_1+5 
d563				ld de, sprompt3 
d563				call str_at_display 
d563				ld a, display_row_3+15 
d563				ld de, sprompt4 
