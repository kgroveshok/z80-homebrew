1d72					ld (debug_mark+1),a  
1d72					ld a, (.dmark+2)  
1d72					ld (debug_mark+2),a  
1d72				endif  
1d72 18 04			jr .pastdmark  
1d74 ..			.dmark: db "HEP"  
