8a15			subafromhl: 
8a15			   ; If A=0 do nothing 
8a15			    ; Otherwise flip A's sign. Since 
8a15			    ; the upper byte becomes -1, also 
8a15			    ; substract 1 from H. 
8a15 ed 44		    neg 
8a17 ca 20 8a		    jp    z, Skip 
8a1a 25			    dec   h 
8a1b			     
8a1b			    ; Now add the low byte as usual 
8a1b			    ; Two's complement takes care of 
8a1b			    ; ensuring the result is correct 
8a1b 85			    add   a, l 
8a1c 6f			    ld    l, a 
8a1d 8c			    adc   a, h 
8a1e 95			    sub   l 
8a1f 67			    ld    h, a 
8a20			Skip: 
8a20 c9				ret 
