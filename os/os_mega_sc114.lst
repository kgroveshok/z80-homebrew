95e0			include "firmware_595shiftreg.asm"  
95e0			; common code for handling a 595 shift reg out on whatever output port 
95e0			 
95e0			; port in c 
95e0			; byte in a 
95e0			 
95e0			 
95e0			shift_bit_data: equ 0 
95e0			shift_bit_clk: equ 1 
95e0			shift_bit_latch: equ 2 
95e0			 
95e0			 
95e0			; shift out a byte to the sound chip 
95e0			 
95e0			; A contains byte to send 
95e0			 
95e0			shift_byte: 
95e0			 
95e0 06 08			ld b, 8   ; 8 bits to shift 
95e2			 
95e2 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
95e4			 
95e4				; set data bit state 
95e4			 
95e4 cb 7f			bit 7, a 
95e6				; high bit is set 
95e6 28 02			jr z, .nb2 
95e8 cb c2			set shift_bit_data, d 
95ea			 
95ea				; set latches state  
95ea cb ca		.nb2:	set shift_bit_clk, d 
95ec cb 92			res shift_bit_latch, d    ; latch is inverted 
95ee ed 51			out (c), d 
95f0				 
95f0				; clock the bit out 
95f0 cb 8a			res shift_bit_clk, d 
95f2 ed 51			out (c), d 
95f4			 
95f4				; shift a left one bit and repeat 
95f4 17				rla 
95f5			 
95f5 10 eb			djnz .nb1 
95f7			 
95f7				; latch 
95f7 cb d2			set shift_bit_latch, d 
95f9 ed 51			out (c), d 
95fb					 
95fb			 
95fb				; set  
95fb c9				ret 
# End of file firmware_595shiftreg.asm
