10d0			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
10d0			 
10d0			; String Length 
10d0			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
10d0			 
10d0			; Get the length of the null-terminated string starting at $8000 hl 
10d0			;    LD     HL, $8000 
10d0			 
10d0			strlenz: 
10d0			 
10d0 af			    XOR    A               ; Zero is the value we are looking for. 
10d1 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
10d2 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
10d3			                           ; 65, 536 bytes (the entire addressable memory space). 
10d3 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10d5			 
10d5			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10d5 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
10d6 6f			    LD     L, A             ; number of bytes 
10d7 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10d9 2b			    DEC    HL              ; Compensate for null. 
10da c9				ret 
10db			 
10db			; Get the length of the A terminated string starting at $8000 hl 
10db			;    LD     HL, $8000 
10db			 
10db			strlent: 
10db			 
10db			                  ; A is the value we are looking for. 
10db 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10dd 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10df			                           ; 65, 536 bytes (the entire addressable memory space). 
10df ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10e1			 
10e1			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10e1 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10e3 2e 00		    LD     L, 0             ; number of bytes 
10e5 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10e7 2b			    DEC    HL              ; Compensate for null. 
10e8 c9				ret 
10e9			 
10e9			 
10e9			;Comparing Strings 
10e9			 
10e9			;IN    HL     Address of string1. 
10e9			;      DE     Address of string2. 
10e9			 
10e9			; doc given but wrong??? 
10e9			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10e9			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10e9			; tested 
10e9			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10e9			 
10e9			strcmp_old: 
10e9 e5			    PUSH   HL 
10ea d5			    PUSH   DE 
10eb			 
10eb 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10ec be			    CP     (HL)            ; (want to minimize work). 
10ed 38 01		    JR     C, Str1IsBigger 
10ef 7e			    LD     A, (HL) 
10f0			 
10f0			Str1IsBigger: 
10f0 4f			    LD     C, A             ; Put length in BC 
10f1 06 00		    LD     B, 0 
10f3 13			    INC    DE              ; Increment pointers to meat of string. 
10f4 23			    INC    HL 
10f5			 
10f5			CmpLoop: 
10f5 1a			    LD     A, (DE)          ; Compare bytes. 
10f6 ed a1		    CPI 
10f8 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10fa 13			    INC    DE              ; Update pointer. 
10fb ea f5 10		    JP     PE, CmpLoop 
10fe			 
10fe d1			    POP    DE 
10ff e1			    POP    HL 
1100 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
1101 be			    CP     (HL) 
1102 c9			    RET 
1103			 
1103			NoMatch: 
1103 2b			    DEC    HL 
1104 be			    CP     (HL)            ; Compare again to affect carry. 
1105 d1			    POP    DE 
1106 e1			    POP    HL 
1107 c9			    RET 
