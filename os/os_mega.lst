10d5			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
10d5			 
10d5			; String Length 
10d5			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
10d5			 
10d5			; Get the length of the null-terminated string starting at $8000 hl 
10d5			;    LD     HL, $8000 
10d5			 
10d5			strlenz: 
10d5			 
10d5 af			    XOR    A               ; Zero is the value we are looking for. 
10d6 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
10d7 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
10d8			                           ; 65, 536 bytes (the entire addressable memory space). 
10d8 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10da			 
10da			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10da 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
10db 6f			    LD     L, A             ; number of bytes 
10dc ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10de 2b			    DEC    HL              ; Compensate for null. 
10df c9				ret 
10e0			 
10e0			; Get the length of the A terminated string starting at $8000 hl 
10e0			;    LD     HL, $8000 
10e0			 
10e0			strlent: 
10e0			 
10e0			                  ; A is the value we are looking for. 
10e0 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10e2 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10e4			                           ; 65, 536 bytes (the entire addressable memory space). 
10e4 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10e6			 
10e6			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10e6 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10e8 2e 00		    LD     L, 0             ; number of bytes 
10ea ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10ec 2b			    DEC    HL              ; Compensate for null. 
10ed c9				ret 
10ee			 
10ee			 
10ee			;Comparing Strings 
10ee			 
10ee			;IN    HL     Address of string1. 
10ee			;      DE     Address of string2. 
10ee			 
10ee			; doc given but wrong??? 
10ee			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10ee			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10ee			; tested 
10ee			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10ee			 
10ee			strcmp_old: 
10ee e5			    PUSH   HL 
10ef d5			    PUSH   DE 
10f0			 
10f0 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10f1 be			    CP     (HL)            ; (want to minimize work). 
10f2 38 01		    JR     C, Str1IsBigger 
10f4 7e			    LD     A, (HL) 
10f5			 
10f5			Str1IsBigger: 
10f5 4f			    LD     C, A             ; Put length in BC 
10f6 06 00		    LD     B, 0 
10f8 13			    INC    DE              ; Increment pointers to meat of string. 
10f9 23			    INC    HL 
10fa			 
10fa			CmpLoop: 
10fa 1a			    LD     A, (DE)          ; Compare bytes. 
10fb ed a1		    CPI 
10fd 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10ff 13			    INC    DE              ; Update pointer. 
1100 ea fa 10		    JP     PE, CmpLoop 
1103			 
1103 d1			    POP    DE 
1104 e1			    POP    HL 
1105 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
1106 be			    CP     (HL) 
1107 c9			    RET 
1108			 
1108			NoMatch: 
1108 2b			    DEC    HL 
1109 be			    CP     (HL)            ; Compare again to affect carry. 
110a d1			    POP    DE 
110b e1			    POP    HL 
110c c9			    RET 
110d			 
