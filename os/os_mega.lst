5355					ld a, (.dmark+2)  
5355					ld (debug_mark+2),a  
5355				endif  
5355 18 04			jr .pastdmark  
5357 ..			.dmark: db "VAR"  
535a				if DEMARK_VERSION = 1  
535a 00					db 0  
535b				endif  
535b				if DEMARK_VERSION = 1  
535b e1			.pastdmark: pop hl  
535c				endif  
535c				if DEMARK_VERSION = 0  
535c			.pastdmark: pop af  
535c				endif  
