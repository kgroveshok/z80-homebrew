cc12			;		call spi_ce_high 
cc12			 
cc12					NEXTW 
cc12			 
cc12			.SPII: 
cc12				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
cc12			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
cc12					if DEBUG_FORTH_WORDS_KEY 
cc12						DMARK "SPi" 
cc12						CALLMONITOR 
cc12					endif 
cc12			 
cc12					; TODO Get SPI byte 
cc12			 
cc12					call spi_read_byte 
cc12			 
cc12					if DEBUG_FORTH_WORDS 
cc12						DMARK "Si2" 
cc12						CALLMONITOR 
cc12					endif 
cc12					ld h, 0 
cc12					ld l, a 
cc12					if DEBUG_FORTH_WORDS 
cc12						DMARK "Si3" 
cc12						CALLMONITOR 
cc12					endif 
cc12					call forth_push_numhl 
