0f09			; from z80uartmonitor 
0f09			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0f09			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
0f09			; pass hl for where to put the text 
0f09			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0f09 c5			hexout:	PUSH BC 
0f0a f5					PUSH AF 
0f0b 47					LD B, A 
0f0c					; Upper nybble 
0f0c cb 3f				SRL A 
0f0e cb 3f				SRL A 
0f10 cb 3f				SRL A 
0f12 cb 3f				SRL A 
0f14 cd 24 0f				CALL tohex 
0f17 77					ld (hl),a 
0f18 23					inc hl	 
0f19					 
0f19					; Lower nybble 
0f19 78					LD A, B 
0f1a e6 0f				AND 0FH 
0f1c cd 24 0f				CALL tohex 
0f1f 77					ld (hl),a 
0f20 23					inc hl	 
0f21					 
0f21 f1					POP AF 
0f22 c1					POP BC 
0f23 c9					RET 
0f24					 
0f24			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0f24			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
0f24			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0f24			tohex: 
0f24 e5					PUSH HL 
0f25 d5					PUSH DE 
0f26 16 00				LD D, 0 
0f28 5f					LD E, A 
0f29 21 31 0f				LD HL, .DATA 
0f2c 19					ADD HL, DE 
0f2d 7e					LD A, (HL) 
0f2e d1					POP DE 
0f2f e1					POP HL 
0f30 c9					RET 
0f31			 
0f31			.DATA: 
0f31 30					DEFB	30h	; 0 
0f32 31					DEFB	31h	; 1 
0f33 32					DEFB	32h	; 2 
0f34 33					DEFB	33h	; 3 
0f35 34					DEFB	34h	; 4 
0f36 35					DEFB	35h	; 5 
0f37 36					DEFB	36h	; 6 
0f38 37					DEFB	37h	; 7 
0f39 38					DEFB	38h	; 8 
0f3a 39					DEFB	39h	; 9 
0f3b 41					DEFB	41h	; A 
0f3c 42					DEFB	42h	; B 
0f3d 43					DEFB	43h	; C 
0f3e 44					DEFB	44h	; D 
0f3f 45					DEFB	45h	; E 
0f40 46					DEFB	46h	; F 
0f41			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0f41			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0f41			;;    subtract $30, if result > 9 then subtract $7 more 
0f41			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0f41			atohex: 
0f41 d6 30				SUB $30 
0f43 fe 0a				CP 10 
0f45 f8					RET M		; If result negative it was 0-9 so we're done 
0f46 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0f48 c9					RET		 
