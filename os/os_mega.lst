22ee			user_word_eol:  
22ee				; hl contains the pointer to where to create a linked list item from the end 
22ee				; of the user dict to continue on at the system word dict 
22ee				 
22ee				; poke the stub of the word list linked list to repoint to rom words 
22ee			 
22ee				; stub format 
22ee				; db   word id 
22ee				; dw    link to next word 
22ee			        ; db char length of token 
22ee				; db string + 0 term 
22ee				; db exec code....  
22ee			 
22ee			;	ld a, WORD_SYS_ROOT     ; root word 
22ee 36 00			ld (hl), WORD_SYS_ROOT		; word id 
22f0 23				inc hl 
22f1			 
22f1 11 9a 24			ld de, sysdict 
22f4 73				ld (hl), e		; next word link ie system dict 
22f5 23				inc hl 
22f6 72				ld (hl), d		; next word link ie system dict 
22f7 23				inc hl	 
22f8			 
22f8			;	ld (hl), sysdict		; next word link ie system dict 
22f8			;	inc hl 
22f8			;	inc hl 
22f8			 
22f8			;	inc hl 
22f8			;	inc hl 
22f8			 
22f8			;	ld a, 2			; word length is 0 
22f8 36 02			ld (hl), 2 
22fa 23				inc hl 
22fb			 
22fb			;	ld a, '~'			; word length is 0 
22fb 36 7e			ld (hl), '~' 
22fd 23				inc hl 
22fe			;	ld a, 0			; save empty word 
22fe 36 00			ld (hl), 0 
