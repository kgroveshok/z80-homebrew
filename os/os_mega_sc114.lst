d26d			; stack over and underflow checks 
d26d			 
d26d			; init the words to detect the under/overflow 
d26d			 
d26d			chk_stk_init: 
d26d				; a vague random number to check so we dont get any "lucky" hits 
d26d 3e 2d			ld a, 45 
d26f 6f				ld l, a 
d270 00				nop 
d271 3e 17			ld a, 23 
d273 67				ld h, a 
d274			 
d274 22 81 e2			ld (chk_word), hl     ; the word we need to check against 
d277			 
d277			;	ld (chk_stund), hl	; stack points.... 
d277 22 00 ef			ld (chk_stovr), hl 
d27a 22 d0 e9			ld (chk_ret_und), hl 
d27d 22 8e e9			ld (chk_ret_ovr), hl 
d280 22 0c e9			ld (chk_loop_ovr), hl 
d283 22 0a e8			ld (chk_data_ovr), hl 
d286 c9				ret 
d287				 
d287			check_stacks: 
d287				; check all stack words 
d287			 
d287 e5				push hl 
d288 d5				push de 
d289			 
d289			;	ld de,(chk_word) 
d289			;	ld hl, (chk_stund)	; stack points.... 
d289			;	if DEBUG_STK_FAULT 
d289			;		DMARK "FAa" 
d289			;		CALLMONITOR 
d289			;	endif 
d289			;	call cmp16 
d289			;	jp z, .chk_faulta 
d289			; 
d289			;	ld de, sfaultsu 
d289			;	jp .chk_fault 
d289			 
d289 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
d28c ed 5b 81 e2		ld de,(chk_word) 
d290				if DEBUG_STK_FAULT 
d290					DMARK "FAb" 
d290					CALLMONITOR 
d290				endif 
d290 cd 58 8a			call cmp16 
d293 28 06			jr z, .chk_fault1 
d295 11 3a d3			ld de, sfaultso 
d298 c3 ea d2			jp .chk_fault 
d29b			.chk_fault1:  
d29b 2a d0 e9			ld hl, (chk_ret_und) 
d29e ed 5b 81 e2		ld de,(chk_word) 
d2a2				if DEBUG_STK_FAULT 
d2a2					DMARK "FAU" 
d2a2					CALLMONITOR 
d2a2				endif 
d2a2 cd 58 8a			call cmp16 
d2a5 ca ae d2			jp z, .chk_fault2 
d2a8 11 4a d3			ld de, sfaultru 
d2ab c3 ea d2			jp .chk_fault 
d2ae			.chk_fault2:  
d2ae 2a 8e e9			ld hl, (chk_ret_ovr) 
d2b1 ed 5b 81 e2		ld de,(chk_word) 
d2b5				if DEBUG_STK_FAULT 
d2b5					DMARK "FA1" 
d2b5					CALLMONITOR 
d2b5				endif 
d2b5 cd 58 8a			call cmp16 
d2b8 ca c1 d2			jp z, .chk_fault3 
d2bb 11 58 d3			ld de, sfaultro 
d2be c3 ea d2			jp .chk_fault 
d2c1			.chk_fault3:  
d2c1 2a 0c e9			ld hl, (chk_loop_ovr) 
d2c4 ed 5b 81 e2		ld de,(chk_word) 
d2c8				if DEBUG_STK_FAULT 
