12e0			if MALLOC_3 
12e0			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12e0			;heap_start        .equ  0x9000      ; Starting address of heap 
12e0			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12e0			; 
12e0			 ;     .org 0 
12e0			  ;    jp    main 
12e0			; 
12e0			; 
12e0			 ;     .org  0x100 
12e0			;main: 
12e0			 ;     ld    HL, 0x8100 
12e0			  ;    ld    SP, HL 
12e0			; 
12e0			;      call  heap_init 
12e0			 
12e0			      ; Make some allocations 
12e0			;      ld    HL, 12 
12e0			;      call  malloc            ; Allocates 0x9004 
12e0			; 
12e0			 ;     ld    HL, 12 
12e0			;      call  malloc            ; Allocates 0x9014 
12e0			 
12e0			;      ld    HL, 12 
12e0			;      call  malloc            ; Allocates 0x9024 
12e0			 
12e0			      ; Free some allocations 
12e0			;      ld    HL, 0x9014 
12e0			;      call  free 
12e0			 
12e0			;      ld    HL, 0x9004 
12e0			;      call  free 
12e0			; 
12e0			;      ld    HL, 0x9024 
12e0			;      call  free 
12e0			 
12e0			 
12e0			 ;     halt 
12e0			 
12e0			 
12e0			;------------------------------------------------------------------------------ 
12e0			;     heap_init                                                               : 
12e0			;                                                                             : 
12e0			; Description                                                                 : 
12e0			;     Initialise the heap and make it ready for malloc and free operations.   : 
12e0			;                                                                             : 
12e0			;     The heap is maintained as a linked list, starting with an initial       : 
12e0			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12e0			;     the first free block in the heap. Each block then points to the next    : 
12e0			;     free block within the heap, and the free list ends at the first block   : 
12e0			;     with a null pointer to the next free block.                             : 
12e0			;                                                                             : 
12e0			; Parameters                                                                  : 
12e0			;     Inputs are compile-time only. Two defines which specify the starting    : 
12e0			;     address of the heap and its size are required, along with a memory      : 
12e0			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12e0			;     principally stores a pointer to the first free block in the heap.       : 
12e0			;                                                                             : 
12e0			; Returns                                                                     : 
12e0			;     Nothing                                                                 : 
12e0			;------------------------------------------------------------------------------ 
12e0			heap_init: 
12e0			      push  HL 
12e0			 
12e0			      ; Initialise free list struct 
12e0			      ld    HL, heap_start 
12e0			      ld    (free_list), HL 
12e0			      ld    HL, 0 
12e0			      ld    (free_list+2), HL 
12e0			 
12e0			      ; Insert first free block at bottom of heap, consumes entire heap 
12e0			      ld    HL, heap_start+heap_size-4 
12e0			      ld    (heap_start), HL        ; Next block (end of free list) 
12e0			      ld    HL, heap_size-4 
12e0			      ld    (heap_start+2), HL      ; Block size 
12e0			 
12e0			      ; Insert end of free list block at top of heap - two null words will 
12e0			      ; terminate the free list 
12e0			      ld    HL, 0 
12e0			      ld    (heap_start+heap_size-2), HL 
12e0			      ld    (heap_start+heap_size-4), HL 
12e0			 
12e0			      pop   HL 
12e0			 
12e0			      ret 
12e0			 
12e0			 
12e0			;------------------------------------------------------------------------------ 
12e0			;     malloc                                                                  : 
12e0			;                                                                             : 
12e0			; Description                                                                 : 
12e0			;     Allocates the wanted space from the heap and returns the address of the : 
12e0			;     first useable byte of the allocation.                                   : 
12e0			;                                                                             : 
12e0			;     Allocations can happen in one of two ways:                              : 
12e0			;                                                                             : 
12e0			;     1. A free block may be found which is the exact size wanted. In this    : 
12e0			;        case the block is removed from the free list and retuedn to the      : 
12e0			;        caller.                                                              : 
12e0			;     2. A free block may be found which is larger than the size wanted. In   : 
12e0			;        this case, the larger block is split into two. The first portion of  : 
12e0			;        this block will become the requested space by the malloc call and    : 
12e0			;        is returned to the caller. The second portion becomes a new free     : 
12e0			;        block, and the free list is adjusted to maintain continuity via this : 
12e0			;        newly created block.                                                 : 
12e0			;                                                                             : 
12e0			;     malloc does not set any initial value in the allocated space, the       : 
12e0			;     caller is required to do this as required.                              : 
12e0			;                                                                             : 
12e0			;     This implementation of malloc uses the stack exclusively, and is        : 
12e0			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12e0			;     advisable to disable interrupts before calling malloc, and recommended  : 
12e0			;     to avoid the use of malloc inside ISRs in general.                      : 
12e0			;                                                                             : 
12e0			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12e0			;                                                                             : 
12e0			; Parameters                                                                  : 
12e0			;     HL  Number of bytes wanted                                              : 
12e0			;                                                                             : 
12e0			; Returns                                                                     : 
12e0			;     HL  Address of the first useable byte of the allocation                 : 
12e0			;                                                                             : 
12e0			; Flags                                                                       : 
12e0			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12e0			;                                                                             : 
12e0			; Stack frame                                                                 : 
12e0			;       |             |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |     BC      |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |     DE      |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |     IX      |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |  prev_free  |                                                       : 
12e0			;   +4  +-------------+                                                       : 
12e0			;       |  this_free  |                                                       : 
12e0			;   +2  +-------------+                                                       : 
12e0			;       |  next_free  |                                                       : 
12e0			;   +0  +-------------+                                                       : 
12e0			;       |             |                                                       : 
12e0			;                                                                             : 
12e0			;------------------------------------------------------------------------------ 
12e0			malloc: 
12e0			      push  BC 
12e0			      push  DE 
12e0			      push  IX 
12e0			 
12e0			      ld    A, H                    ; Exit if no space requested 
12e0			      or    L 
12e0			      jp    Z, malloc_early_exit 
12e0			 
12e0			      ; Set up stack frame 
12e0			      ex    DE, HL 
12e0			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12e0			      add   HL, SP 
12e0			      ld    SP, HL 
12e0			      ld    IX, 0                   ; Use IX as a frame pointer 
12e0			      add   IX, SP 
12e0			 
12e0			      ; Setup initial state 
12e0			      ld    HL, 4                   ; want must also include space used by block struct 
12e0			      add   HL, DE 
12e0			 
12e0			      ld    B, H                    ; Move want to BC 
12e0			      ld    C, L 
12e0			 
12e0			      ld    HL, free_list           ; Store prev_free ptr to stack 
12e0			      ld    (IX+4), L 
12e0			      ld    (IX+5), H 
12e0			 
12e0			      ld    E, (HL)                 ; Store this_free ptr to stack 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      ld    (IX+2), E 
12e0			      ld    (IX+3), D 
12e0			      ex    DE, HL                  ; this_free ptr into HL 
12e0			 
12e0			      ; Loop through free block list to find some space 
12e0			malloc_find_space: 
12e0			      ld    E, (HL)                 ; Load next_free ptr into DE 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			 
12e0			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12e0			      or    E 
12e0			      jp    Z, malloc_no_space 
12e0			 
12e0			      ld    (IX+0), E               ; Store next_free ptr to stack 
12e0			      ld    (IX+1), D 
12e0			 
12e0			      ; Does this block have enough space to make the allocation? 
12e0			      inc   HL                      ; Load free block size into DE 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			 
12e0			      ex    DE, HL                  ; Check size of block against want 
12e0			      or    A                       ; Ensure carry flag clear 
12e0			      sbc   HL, BC 
12e0			      push  HL                      ; Store the result for later (new block size) 
12e0			 
12e0			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12e0			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12e0			 
12e0			      ; this_free block is not big enough, setup ptrs to test next free block 
12e0			      pop   HL                      ; Discard previous result 
12e0			 
12e0			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12e0			      ld    H, (IX+3) 
12e0			      ld    (IX+4), L 
12e0			      ld    (IX+5), H 
12e0			 
12e0			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12e0			      ld    H, (IX+1) 
12e0			      ld    (IX+2), L 
12e0			      ld    (IX+3), H 
12e0			 
12e0			      jr    malloc_find_space 
12e0			 
12e0			      ; split a bigger block into two - requested size and remaining size 
12e0			malloc_alloc_split: 
12e0			      ex    DE, HL                  ; Calculate address of new free block 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			      add   HL, BC 
12e0			 
12e0			      ; Create a new block and point it at next_free 
12e0			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12e0			      ld    D, (IX+1) 
12e0			 
12e0			      ld    (HL), E                 ; Store next_free ptr into new block 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			      pop   DE                      ; Store size of new block into new block 
12e0			      inc   HL 
12e0			      ld    (HL), E 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			      ; Update this_free ptr to point to new block 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			 
12e0			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12e0			      ld    D, (IX+3) 
12e0			 
12e0			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12e0			      ld    (IX+3), H 
12e0			 
12e0			      ; Modify this_free block to be allocation 
12e0			      ex    DE, HL 
12e0			      xor   A                       ; Null the next block ptr of allocated block 
12e0			      ld    (HL), A 
12e0			      inc   HL 
12e0			      ld    (HL), A 
12e0			 
12e0			      inc   HL                      ; Store want size into allocated block 
12e0			      ld    (HL), C 
12e0			      inc   HL 
12e0			      ld    (HL), B 
12e0			      inc   HL 
12e0			      push  HL                      ; Address of allocation to return 
12e0			 
12e0			      jr    malloc_update_links 
12e0			 
12e0			malloc_alloc_fit: 
12e0			      pop   HL                      ; Dont need new block size, want is exact fit 
12e0			 
12e0			      ; Modify this_free block to be allocation 
12e0			      ex    DE, HL 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			 
12e0			      xor   A                       ; Null the next block ptr of allocated block 
12e0			      ld    (HL), A 
12e0			      inc   HL 
12e0			      ld    (HL), A 
12e0			 
12e0			      inc   HL                      ; Store address of allocation to return 
12e0			      inc   HL 
12e0			      inc   HL 
12e0			      push  HL 
12e0			 
12e0			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12e0			      ld    L, (IX+0)               ; next_free to HL 
12e0			      ld    H, (IX+1) 
12e0			 
12e0			      ld    (IX+2), L               ; HL to this_free 
12e0			      ld    (IX+3), H 
12e0			 
12e0			 
12e0			malloc_update_links: 
12e0			      ; Update prev_free ptr to point to this_free 
12e0			      ld    L, (IX+4)               ; prev_free ptr to HL 
12e0			      ld    H, (IX+5) 
12e0			 
12e0			      ld    E, (IX+2)               ; this_free ptr to DE 
12e0			      ld    D, (IX+3) 
12e0			 
12e0			      ld    (HL), E                 ; this_free ptr into prev_free 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			      ; Clear the Z flag to indicate successful allocation 
12e0			      ld    A, D 
12e0			      or    E 
12e0			 
12e0			      pop   DE                      ; Address of allocation 
12e0			 
12e0			malloc_no_space: 
12e0			      ld    HL, 6                   ; Clean up stack frame 
12e0			      add   HL, SP 
12e0			      ld    SP, HL 
12e0			 
12e0			      ex    DE, HL                  ; Alloc addr into HL for return 
12e0			 
12e0			malloc_early_exit: 
12e0			      pop   IX 
12e0			      pop   DE 
12e0			      pop   BC 
12e0			 
12e0			      ret 
12e0			 
12e0			 
12e0			;------------------------------------------------------------------------------ 
12e0			;     free                                                                    : 
12e0			;                                                                             : 
12e0			; Description                                                                 : 
12e0			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12e0			;     returned by malloc, otherwise the behaviour is undefined.               : 
12e0			;                                                                             : 
12e0			;     Where possible, directly adjacent free blocks will be merged together   : 
12e0			;     into larger blocks to help ensure that the heap does not become         : 
12e0			;     excessively fragmented.                                                 : 
12e0			;                                                                             : 
12e0			;     free does not clear or set any other value into the freed space, and    : 
12e0			;     therefore its contents may be visible through subsequent malloc's. The  : 
12e0			;     caller should clear the freed space as required.                        : 
12e0			;                                                                             : 
12e0			;     This implementation of free uses the stack exclusively, and is          : 
12e0			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12e0			;     advisable to disable interrupts before calling free, and recommended    : 
12e0			;     to avoid the use of free inside ISRs in general.                        : 
12e0			;                                                                             : 
12e0			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12e0			;                                                                             : 
12e0			; Parameters                                                                  : 
12e0			;     HL  Pointer to address of first byte of allocation to be freed          : 
12e0			;                                                                             : 
12e0			; Returns                                                                     : 
12e0			;     Nothing                                                                 : 
12e0			;                                                                             : 
12e0			; Stack frame                                                                 : 
12e0			;       |             |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |     BC      |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |     DE      |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |     IX      |                                                       : 
12e0			;       +-------------+                                                       : 
12e0			;       |  prev_free  |                                                       : 
12e0			;   +2  +-------------+                                                       : 
12e0			;       |  next_free  |                                                       : 
12e0			;   +0  +-------------+                                                       : 
12e0			;       |             |                                                       : 
12e0			;                                                                             : 
12e0			;------------------------------------------------------------------------------ 
12e0			free: 
12e0			      push  BC 
12e0			      push  DE 
12e0			      push  IX 
12e0			 
12e0			      ld    A, H                    ; Exit if ptr is null 
12e0			      or    L 
12e0			      jp    Z, free_early_exit 
12e0			 
12e0			      ; Set up stack frame 
12e0			      ex    DE, HL 
12e0			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12e0			      add   HL, SP 
12e0			      ld    SP, HL 
12e0			      ld    IX, 0                   ; Use IX as a frame pointer 
12e0			      add   IX, SP 
12e0			 
12e0			      ; The address in HL points to the start of the useable allocated space, 
12e0			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12e0			      ; address of the block itself. 
12e0			      ex    DE, HL 
12e0			      ld    DE, -4 
12e0			      add   HL, DE 
12e0			 
12e0			      ; An allocated block must have a null next block pointer in it 
12e0			      ld    A, (HL) 
12e0			      inc   HL 
12e0			      or    (HL) 
12e0			      jp    NZ, free_done 
12e0			 
12e0			      dec   HL 
12e0			 
12e0			      ld    B, H                    ; Copy HL to BC 
12e0			      ld    C, L 
12e0			 
12e0			      ; Loop through the free list to find the first block with an address 
12e0			      ; higher than the block being freed 
12e0			      ld    HL, free_list 
12e0			 
12e0			free_find_higher_block: 
12e0			      ld    E, (HL)                 ; Load next ptr from free block 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      dec   HL 
12e0			 
12e0			      ld    (IX+0), E               ; Save ptr to next free block 
12e0			      ld    (IX+1), D 
12e0			      ld    (IX+2), L               ; Save ptr to prev free block 
12e0			      ld    (IX+3), H 
12e0			 
12e0			      ld    A, B                    ; Check if DE is greater than BC 
12e0			      cp    D                       ; Compare MSB first 
12e0			      jr    Z, $+4                  ; MSB the same, compare LSB 
12e0			      jr    NC, free_find_higher_block_skip 
12e0			      ld    A, C 
12e0			      cp    E                       ; Then compare LSB 
12e0			      jr    C, free_found_higher_block 
12e0			 
12e0			free_find_higher_block_skip: 
12e0			      ld    A, D                    ; Reached the end of the free list? 
12e0			      or    E 
12e0			      jp    Z, free_done 
12e0			 
12e0			      ex    DE, HL 
12e0			 
12e0			      jr    free_find_higher_block 
12e0			 
12e0			free_found_higher_block: 
12e0			      ; Insert freed block between prev and next free blocks 
12e0			      ld    (HL), C                 ; Point prev free block to freed block 
12e0			      inc   HL 
12e0			      ld    (HL), B 
12e0			 
12e0			      ld    H, B                    ; Point freed block at next free block 
12e0			      ld    L, C 
12e0			      ld    (HL), E 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			      ; Check if the freed block is adjacent to the next free block 
12e0			      inc   HL                      ; Load size of freed block into HL 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      ex    DE, HL 
12e0			 
12e0			      add   HL, BC                  ; Add addr of freed block and its size 
12e0			 
12e0			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12e0			      ld    D, (IX+1) 
12e0			 
12e0			      or    A                       ; Clear the carry flag 
12e0			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12e0			      jr    NZ, free_check_adjacent_to_prev 
12e0			 
12e0			      ; Freed block is adjacent to next, merge into one bigger block 
12e0			      ex    DE, HL                  ; Load next ptr from next block into DE 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      push  HL                      ; Save ptr to next block for later 
12e0			 
12e0			      ld    H, B                    ; Store ptr from next block into freed block 
12e0			      ld    L, C 
12e0			      ld    (HL), E 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			      pop   HL                      ; Restore ptr to next block 
12e0			      inc   HL                      ; Load size of next block into DE 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      push  DE                      ; Save next block size for later 
12e0			 
12e0			      ld    H, B                    ; Load size of freed block into HL 
12e0			      ld    L, C 
12e0			      inc   HL 
12e0			      inc   HL 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      ex    DE, HL 
12e0			 
12e0			      pop   DE                      ; Restore size of next block 
12e0			      add   HL, DE                  ; Add sizes of both blocks 
12e0			      ex    DE, HL 
12e0			 
12e0			      ld    H, B                    ; Store new bigger size into freed block 
12e0			      ld    L, C 
12e0			      inc   HL 
12e0			      inc   HL 
12e0			      ld    (HL), E 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			free_check_adjacent_to_prev: 
12e0			      ; Check if the freed block is adjacent to the prev free block 
12e0			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12e0			      ld    H, (IX+3) 
12e0			 
12e0			      inc   HL                      ; Size of prev free block into DE 
12e0			      inc   HL 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			      dec   HL 
12e0			 
12e0			      add   HL, DE                  ; Add prev block addr and size 
12e0			 
12e0			      or    A                       ; Clear the carry flag 
12e0			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12e0			      jr    NZ, free_done 
12e0			 
12e0			      ; Freed block is adjacent to prev, merge into one bigger block 
12e0			      ld    H, B                    ; Load next ptr from freed block into DE 
12e0			      ld    L, C 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      push  HL                      ; Save freed block ptr for later 
12e0			 
12e0			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12e0			      ld    H, (IX+3) 
12e0			      ld    (HL), E 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			      pop   HL                      ; Restore freed block ptr 
12e0			      inc   HL                      ; Load size of freed block into DE 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			      push  DE                      ; Save freed block size for later 
12e0			 
12e0			      ld    L, (IX+2)               ; Load size of prev block into DE 
12e0			      ld    H, (IX+3) 
12e0			      inc   HL 
12e0			      inc   HL 
12e0			      ld    E, (HL) 
12e0			      inc   HL 
12e0			      ld    D, (HL) 
12e0			 
12e0			      pop   HL                      ; Add sizes of both blocks 
12e0			      add   HL, DE 
12e0			      ex    DE, HL 
12e0			 
12e0			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12e0			      ld    H, (IX+3) 
12e0			      inc   HL 
12e0			      inc   HL 
12e0			      ld    (HL), E 
12e0			      inc   HL 
12e0			      ld    (HL), D 
12e0			 
12e0			free_done: 
12e0			      ld    HL, 4                   ; Clean up stack frame 
12e0			      add   HL, SP 
12e0			      ld    SP, HL 
12e0			 
12e0			free_early_exit: 
12e0			      pop   IX 
12e0			      pop   DE 
12e0			      pop   BC 
12e0			 
12e0			      ret 
12e0			 
12e0			 
12e0			;      .org 0x8000 
12e0			; 
12e0			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12e0			 ;                 .dw   0 
12e0			 
12e0			endif 
