6956			  
6956			; Position cursor to specified location  
6956			;   On entry: A = Cursor position  
6956			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6956 f5			fLCD_Pos:   PUSH AF  
6957					; at this point set the E1 or E2 flag depending on position  
6957			  
6957 c5					push bc  
6958			;		push af  
6958 06 00				ld b, 0  
695a 4f					ld c, a  
695b 3e 4f				ld a, kLCD_Line3-1  
695d b7			 		or a      ;clear carry flag  
695e 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
695f 38 04				jr c, .pe1  
6961			  
6961					; E selection  
6961 cb 80				res 0, b         ; bit 0 unset e  
6963			;		pop af    ; before line 3 so recover orig pos  
6963			;		ld c, a    ; save for poking back  
6963 18 06				jr .peset	          
6965			.pe1:          	; E2 selection  
6965 cb c0				set 0, b         ; bit 0 set e1  
6967 79					ld a, c  
6968 de 4f				sbc a, kLCD_Line3-1  
696a 4f					ld c, a	         ; save caculated offset  
696b			;		pop af     ; bin this original value now we have calculated form  
696b			  
696b			.peset:		; set bit  
696b 78					ld a, b  
696c 32 fb fa				ld (display_lcde1e2), a 	  
696f 79					ld a, c  
6970 c1					pop bc  
6971			  
6971 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6973 cd d2 68		            CALL fLCD_Inst      ;Write instruction to LCD  
6976 f1			            POP  AF  
6977 c9			            RET  
6978			  
6978			  
6978			; Output text string to LCD  
6978			;   On entry: DE = Pointer to null terminated text string  
6978			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6978 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6979 b7			            OR   A              ;Null terminator?  
697a c8			            RET  Z              ;Yes, so finished  
697b cd 0e 69		            CALL fLCD_Data      ;Write character to display  
697e 13			            INC  DE             ;Point to next character  
697f 18 f7		            JR   fLCD_Str       ;Repeat  
6981 c9					ret  
6982			  
6982			; Define custom character  
6982			;   On entry: A = Character number (0 to 7)  
6982			;             DE = Pointer to character bitmap data  
6982			;   On exit:  A = Next character number  
6982			;             DE = Next location following bitmap  
6982			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6982			; Character is   
6982 c5			fLCD_Def:   PUSH BC  
6983 f5			            PUSH AF  
6984 07			            RLCA                ;Calculate location  
6985 07			            RLCA                ;  for bitmap data  
6986 07			            RLCA                ;  = 8 x CharacterNumber  
6987 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6989 cd d2 68		            CALL fLCD_Inst      ;Write instruction to LCD  
698c 06 00		            LD   B, 0  
698e 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
698f cd 0e 69		            CALL fLCD_Data      ;Write byte to display  
6992 13			            INC  DE             ;Point to next byte  
6993 04			            INC  B              ;Count bytes  
6994 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6996 28 f6		            JR   Z, Loop       ;No, so repeat  
6998 f1			            POP  AF  
6999 3c			            INC  A              ;Increment character number  
699a c1			            POP  BC  
699b c9			            RET  
