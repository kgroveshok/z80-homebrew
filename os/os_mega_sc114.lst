cd44					if DEBUG_FORTH_WORDS 
cd44						DMARK "Si2" 
cd44						CALLMONITOR 
cd44					endif 
cd44					ld h, 0 
cd44					ld l, a 
cd44					if DEBUG_FORTH_WORDS 
cd44						DMARK "Si3" 
