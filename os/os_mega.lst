6617 ed 5b b9 f0		ld de,(chk_word) 
661b				if DEBUG_STK_FAULT 
661b					DMARK "FAb" 
661b					CALLMONITOR 
661b				endif 
661b cd 99 0d			call cmp16 
661e 28 06			jr z, .chk_fault1 
6620 11 c5 66			ld de, sfaultso 
6623 c3 75 66			jp .chk_fault 
