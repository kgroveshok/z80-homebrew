cd44			    NEXTW 
cd44			 
cd44			 
cd44			.SPIOb: 
cd44			 
cd44				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
cd44			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
cd44			 
cd44					if DEBUG_FORTH_WORDS_KEY 
cd44						DMARK "SPo" 
cd44						CALLMONITOR 
cd44					endif 
cd44					; get port 
cd44			 
cd44			 
cd44					; get byte to send 
cd44			 
cd44					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cd44			 
cd44			;		push hl    ; u1  
cd44			 
cd44					; destroy value TOS 
cd44			 
cd44					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cd44			 
cd44					; one value on hl get other one back 
cd44			 
cd44			;		pop hl   ; u2 - addr 
cd44			 
cd44					; TODO Send SPI byte 
cd44			 
cd44			;		push hl 
cd44			;		call spi_ce_low 
cd44			;		pop hl 
cd44					ld a, l 
cd44					call spi_send_byte 
cd44			;		call spi_ce_high 
cd44			 
cd44					NEXTW 
cd44			 
cd44			.SPII: 
cd44				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
cd44			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
cd44					if DEBUG_FORTH_WORDS_KEY 
cd44						DMARK "SPi" 
cd44						CALLMONITOR 
cd44					endif 
cd44			 
cd44					; TODO Get SPI byte 
