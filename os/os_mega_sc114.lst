9884			; Stack operations for v5 parser on wards 
9884			; * DATA stack 
9884			; * LOOP stack 
9884			; * RETURN stack 
9884			 
9884			 
9884			 
9884			FORTH_CHK_DSP_UNDER: macro 
9884				push hl 
9884				push de 
9884				ld hl,(cli_data_sp) 
9884				ld de, cli_data_stack 
9884				call cmp16 
9884				jp c, fault_dsp_under 
9884				pop de 
9884				pop hl 
9884				endm 
9884			 
9884			 
9884			FORTH_CHK_RSP_UNDER: macro 
9884				push hl 
9884				push de 
9884				ld hl,(cli_ret_sp) 
9884				ld de, cli_ret_stack 
9884				call cmp16 
9884				jp c, fault_rsp_under 
9884				pop de 
9884				pop hl 
9884				endm 
9884			 
9884			FORTH_CHK_LOOP_UNDER: macro 
9884				push hl 
9884				push de 
9884				ld hl,(cli_loop_sp) 
9884				ld de, cli_loop_stack 
9884				call cmp16 
9884				jp c, fault_loop_under 
9884				pop de 
9884				pop hl 
9884				endm 
9884			 
9884			FORTH_ERR_TOS_NOTSTR: macro 
9884				; TOSO might need more for checks when used 
9884				push af 
9884				ld a,(hl) 
9884				cp DS_TYPE_STR 
9884				jp nz, type_faultn   
9884				pop af 
9884				endm 
9884			 
9884			FORTH_ERR_TOS_NOTNUM: macro 
9884				push af 
9884				ld a,(hl) 
9884				cp DS_TYPE_INUM 
9884				jp nz, type_faultn   
9884				pop af 
9884				endm 
9884			 
9884			 
9884			; increase data stack pointer and save hl to it 
9884				 
9884			FORTH_DSP_NEXT: macro 
9884				call macro_forth_dsp_next 
9884				endm 
9884			 
9884			 
9884			macro_forth_dsp_next: 
9884				if DEBUG_FORTH_STACK_GUARD 
9884 cd 05 d2				call check_stacks 
9887				endif 
9887 e5				push hl 
9888 d5				push de 
9889 eb				ex de,hl 
988a 2a d2 e9			ld hl,(cli_data_sp) 
988d 23				inc hl 
988e 23				inc hl 
988f			 
988f			; PARSEV5 
988f 23				inc hl 
9890 22 d2 e9			ld (cli_data_sp),hl 
9893 73				ld (hl), e 
9894 23				inc hl 
9895 72				ld (hl), d 
9896 d1				pop de 
9897 e1				pop hl 
9898				if DEBUG_FORTH_STACK_GUARD 
9898 cd 05 d2				call check_stacks 
989b				endif 
989b c9				ret 
