0f51			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
0f51			 
0f51			; String Length 
0f51			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
0f51			 
0f51			; Get the length of the null-terminated string starting at $8000 hl 
0f51			;    LD     HL, $8000 
0f51			 
0f51			strlenz: 
0f51			 
0f51 af			    XOR    A               ; Zero is the value we are looking for. 
0f52 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
0f53 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
0f54			                           ; 65, 536 bytes (the entire addressable memory space). 
0f54 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f56			 
0f56			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f56 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
0f57 6f			    LD     L, A             ; number of bytes 
0f58 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f5a 2b			    DEC    HL              ; Compensate for null. 
0f5b c9				ret 
0f5c			 
0f5c			; Get the length of the A terminated string starting at $8000 hl 
0f5c			;    LD     HL, $8000 
0f5c			 
0f5c			strlent: 
0f5c			 
0f5c			                  ; A is the value we are looking for. 
0f5c 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
0f5e 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
0f60			                           ; 65, 536 bytes (the entire addressable memory space). 
0f60 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f62			 
0f62			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f62 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
0f64 2e 00		    LD     L, 0             ; number of bytes 
0f66 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f68 2b			    DEC    HL              ; Compensate for null. 
0f69 c9				ret 
