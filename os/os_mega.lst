# End of macro CWHEAD
529f			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
529f			; | 
529f			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
529f			; | |  
529f			; | | e.g. 
529f			; | |         #30 a var ! 
529f			; | |         a var @ . 
529f			; | |   
529f			; | |     Displays the number 30 
529f			; | | 
529f			; | | Each variable pointer is a word so can use for any words that use that:  
529f			; | |  
529f			; | | e.g. 
529f			; | |  
529f			; | |         #30 a var 2! 
529f			; | |         a var 2@ . 
529f			; | |   
529f			; | |     Displays the number 30 
529f			; | |  
529f			; | | > [!NOTE]  
529f			; ! | > If a full string is passed then only the first char is looked at 
529f			; | | > Any other char could exceed bounds checks!  
529f			; | | > 
529f			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
529f			 
529f					if DEBUG_FORTH_WORDS_KEY 
