12cc			 
12cc			toUpper: 
12cc			;A is the char. 
12cc			;If A is a lowercase letter, this sets it to the matching uppercase 
12cc			;18cc or 30cc or 41cc 
12cc			;avg: 26.75cc 
12cc fe 61		  cp 'a' 
12ce d8			  ret c 
12cf fe 7b		  cp 'z'+1 
12d1 d0			  ret nc 
12d2 d6 20		  sub 'a'-'A' 
12d4 c9			  ret 
12d5			 
12d5			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
12d5			 
12d5			; String Length 
12d5			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
12d5			 
12d5			; Get the length of the null-terminated string starting at $8000 hl 
12d5			;    LD     HL, $8000 
12d5			 
12d5			strlenz: 
12d5			 
12d5 af			    XOR    A               ; Zero is the value we are looking for. 
12d6 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
12d7 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
12d8			                           ; 65, 536 bytes (the entire addressable memory space). 
12d8 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
12da			 
12da			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
12da 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
12db 6f			    LD     L, A             ; number of bytes 
12dc ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
12de 2b			    DEC    HL              ; Compensate for null. 
12df c9				ret 
12e0			 
12e0			; Get the length of the A terminated string starting at $8000 hl 
12e0			;    LD     HL, $8000 
12e0			 
12e0			strlent: 
12e0			 
12e0			                  ; A is the value we are looking for. 
12e0 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
12e2 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
12e4			                           ; 65, 536 bytes (the entire addressable memory space). 
12e4 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
12e6			 
12e6			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
12e6 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
12e8 2e 00		    LD     L, 0             ; number of bytes 
12ea ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
12ec 2b			    DEC    HL              ; Compensate for null. 
12ed c9				ret 
12ee			 
12ee			 
12ee			;Comparing Strings 
12ee			 
12ee			;IN    HL     Address of string1. 
12ee			;      DE     Address of string2. 
12ee			 
12ee			; doc given but wrong??? 
12ee			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
12ee			;      carry  Set if string1 > string2, reset if string1 <= string2. 
12ee			; tested 
12ee			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
12ee			 
12ee			strcmp_old: 
12ee e5			    PUSH   HL 
12ef d5			    PUSH   DE 
12f0			 
12f0 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
12f1 be			    CP     (HL)            ; (want to minimize work). 
12f2 38 01		    JR     C, Str1IsBigger 
12f4 7e			    LD     A, (HL) 
12f5			 
12f5			Str1IsBigger: 
12f5 4f			    LD     C, A             ; Put length in BC 
12f6 06 00		    LD     B, 0 
12f8 13			    INC    DE              ; Increment pointers to meat of string. 
12f9 23			    INC    HL 
12fa			 
12fa			CmpLoop: 
12fa 1a			    LD     A, (DE)          ; Compare bytes. 
12fb ed a1		    CPI 
12fd 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
12ff 13			    INC    DE              ; Update pointer. 
1300 ea fa 12		    JP     PE, CmpLoop 
1303			 
1303 d1			    POP    DE 
1304 e1			    POP    HL 
1305 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
1306 be			    CP     (HL) 
1307 c9			    RET 
1308			 
1308			NoMatch: 
1308 2b			    DEC    HL 
1309 be			    CP     (HL)            ; Compare again to affect carry. 
130a d1			    POP    DE 
130b e1			    POP    HL 
130c c9			    RET 
