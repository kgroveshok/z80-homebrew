10dd			StrictStrCmp: 
10dd				; Load next chars of each string 
10dd 1a				ld a, (de) 
10de 47				ld b, a 
10df 7e				ld a, (hl) 
10e0				; Compare 
10e0 b8				cp b 
10e1				; Return non-zero if chars don't match 
10e1 c0				ret nz 
10e2				; Check for end of both strings 
10e2 fe 00			cp "\0" 
10e4				; Return if strings have ended 
10e4 c8				ret z 
10e5				; Otherwise, advance to next chars 
10e5 23				inc hl 
10e6 13				inc de 
10e7 18 f4			jr StrictStrCmp 
10e9			 
