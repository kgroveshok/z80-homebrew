8c3f			; Get 2 ASCII characters as hex byte from pointer in hl 
8c3f			 
8c3f			BYTERD: 
8c3f 16 00			LD	D,00h		;Set up 
8c41 cd 49 8c			CALL	HEXCON		;Get byte and convert to hex 
8c44 87				ADD	A,A		;First nibble so 
8c45 87				ADD	A,A		;multiply by 16 
8c46 87				ADD	A,A		; 
8c47 87				ADD	A,A		; 
8c48 57				LD	D,A		;Save hi nibble in D 
8c49			HEXCON: 
8c49 7e				ld a, (hl)		;Get next chr 
8c4a 23				inc hl 
8c4b d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
8c4d fe 0a			CP	00Ah		;Is it 0-9 ? 
8c4f 38 02			JR	C,NALPHA	;If so miss next bit 
8c51 d6 07			SUB	007h		;Else convert alpha 
8c53			NALPHA: 
8c53 b2				OR	D		;Add hi nibble back 
8c54 c9				RET			; 
