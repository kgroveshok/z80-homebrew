8dab			 
8dab			;Comparing Strings 
8dab			 
8dab			;IN    HL     Address of string1. 
8dab			;      DE     Address of string2. 
8dab			 
8dab			; doc given but wrong??? 
8dab			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
8dab			;      carry  Set if string1 > string2, reset if string1 <= string2. 
8dab			; tested 
8dab			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
8dab			 
8dab			strcmp_old: 
8dab e5			    PUSH   HL 
8dac d5			    PUSH   DE 
8dad			 
8dad 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
8dae be			    CP     (HL)            ; (want to minimize work). 
8daf 38 01		    JR     C, Str1IsBigger 
8db1 7e			    LD     A, (HL) 
8db2			 
8db2			Str1IsBigger: 
8db2 4f			    LD     C, A             ; Put length in BC 
8db3 06 00		    LD     B, 0 
8db5 13			    INC    DE              ; Increment pointers to meat of string. 
8db6 23			    INC    HL 
8db7			 
8db7			CmpLoop: 
8db7 1a			    LD     A, (DE)          ; Compare bytes. 
8db8 ed a1		    CPI 
8dba 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
8dbc 13			    INC    DE              ; Update pointer. 
8dbd ea b7 8d		    JP     PE, CmpLoop 
8dc0			 
8dc0 d1			    POP    DE 
8dc1 e1			    POP    HL 
8dc2 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
8dc3 be			    CP     (HL) 
8dc4 c9			    RET 
8dc5			 
8dc5			NoMatch: 
8dc5 2b			    DEC    HL 
8dc6 be			    CP     (HL)            ; Compare again to affect carry. 
8dc7 d1			    POP    DE 
8dc8 e1			    POP    HL 
8dc9 c9			    RET 
