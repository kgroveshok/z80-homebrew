8fb7			 
8fb7			config_dir: 
8fb7			 
8fb7				; for the config menus that need to build a directory of storage call this routine 
8fb7				; it will construct a menu in scratch to pass to menu 
8fb7			 
8fb7				; open storage device 
8fb7			 
8fb7				; execute DIR to build a list of files and their ids into scratch in menu format 
8fb7				; once the menu has finished then will need to call config_fdir to release the strings 
8fb7				 
8fb7				; c = number items 
8fb7			 
8fb7				 
8fb7				call storage_get_block_0 
8fb7			 
8fb7				ld hl, store_page     ; get current id count 
8fb7				ld b, (hl) 
8fb7				ld c, 0    ; count of files   
8fb7			 
8fb7			 
8fb7				ld hl, scratch 
8fb7				ld (store_tmp2), hl    ; location to poke strings 
8fb7			 
8fb7				; check for empty drive 
8fb7			 
8fb7				ld a, 0 
8fb7				cp b 
8fb7				jp z, .dirdone 
8fb7			 
8fb7				 
8fb7					if DEBUG_FORTH_WORDS 
8fb7						DMARK "Cdc" 
8fb7						CALLMONITOR 
8fb7					endif 
8fb7			 
8fb7			 
8fb7			.diritem:	 
8fb7				push bc 
8fb7				; for each of the current ids do a search for them and if found push to stack 
8fb7			 
8fb7					ld hl, STORE_BLOCK_PHY 
8fb7					ld d, 0		 ; look for extent 0 of block id as this contains file name 
8fb7					ld e,b 
8fb7			 
8fb7					call storage_findnextid 
8fb7			 
8fb7			 
8fb7					; if found hl will be non zero 
8fb7			 
8fb7					call ishlzero 
8fb7					jr z, .dirnotfound 
8fb7			 
8fb7					; increase count 
8fb7			 
8fb7					pop bc	 
8fb7					inc c 
8fb7					push bc 
8fb7					 
8fb7			 
8fb7					; get file header and push the file name 
8fb7			 
8fb7					ld de, store_page 
8fb7					call storage_read_block 
8fb7			 
8fb7					; push file id to stack 
8fb7				 
8fb7					ld a, (store_page) 
8fb7					ld h, 0 
8fb7					ld l, a 
8fb7			 
8fb7					;call forth_push_numhl 
8fb7					; TODO store id 
8fb7			 
8fb7					push hl 
8fb7			 
8fb7					; push extent count to stack  
8fb7				 
8fb7					ld hl, store_page+3 
8fb7			 
8fb7					; get file name length 
8fb7			 
8fb7					call strlenz   
8fb7			 
8fb7					inc hl   ; cover zero term 
8fb7					inc hl  ; stick the id at the end of the area 
8fb7			 
8fb7					push hl 
8fb7					pop bc    ; move length to bc 
8fb7			 
8fb7					call malloc 
8fb7			 
8fb7					; TODO save malloc area to scratch 
8fb7			 
8fb7					ex de, hl 
8fb7					ld hl, (store_tmp2) 
8fb7					ld (hl), e 
8fb7					inc hl 
8fb7					ld (hl), d 
8fb7					inc hl 
8fb7					ld (store_tmp2), hl 
8fb7			 
8fb7					 
8fb7			 
8fb7					;pop hl   ; get source 
8fb7			;		ex de, hl    ; swap aronund	 
8fb7			 
8fb7					ld hl, store_page+3 
8fb7					if DEBUG_FORTH_WORDS 
8fb7						DMARK "CFd" 
8fb7						CALLMONITOR 
8fb7					endif 
8fb7					ldir 
8fb7			 
8fb7					; de is past string, move back one and store id 
8fb7					 
8fb7					dec de 
8fb7			 
8fb7					; store file id 
8fb7			 
8fb7					pop hl 
8fb7					ex de,hl 
8fb7					ld (hl), e 
8fb7			 
8fb7					if DEBUG_FORTH_WORDS 
8fb7						DMARK "Cdi" 
8fb7						CALLMONITOR 
8fb7					endif 
8fb7					 
8fb7			.dirnotfound: 
8fb7					pop bc     
8fb7					djnz .diritem 
8fb7				 
8fb7			.dirdone:	 
8fb7			 
8fb7			;		ld a, 0 
8fb7					ld hl, (store_tmp2) 
8fb7					ld (hl), 0 
8fb7					inc hl 
8fb7					ld (hl), 0 
8fb7					inc hl 
8fb7					; push a count of the dir items found 
8fb7			 
8fb7			;		ld h, 0 
8fb7			;		ld l, c 
8fb7			 
8fb7				ret 
8fb7			 
8fb7			endif 
