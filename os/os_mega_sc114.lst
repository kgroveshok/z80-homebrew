901f			 
901f cd c6 8f			call tape_gap 
9022 cd c6 8f			call tape_gap 
9025			 
9025 cd 68 87			call active 
9028 eb				ex de, hl 
9029 3e 00			ld a, 0 
902b cd 22 88			call  str_at_display 
902e cd 32 88			call update_display 
9031			 
9031 e1				pop hl 
9032 7e				ld a, (hl) 
9033 fe 00			cp 0 
9035 c8				ret z 
