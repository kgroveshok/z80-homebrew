8053			; resume memory alloocations....  
8053			  
8053			;os_view_disable: equ os_new_exec_ptr - 1  
8053			os_view_af: equ os_new_exec_ptr - 2  
8053			os_view_hl: equ os_view_af -2  
8053			os_view_de: equ os_view_hl - 2  
8053			os_view_bc: equ os_view_de - 2  
8053			  
8053			; stack checksum word  
8053			if DEBUG_STACK_IMB  
8053				curframe: equ  os_view_de - 5  
8053				store_sp: equ curframe - (STACK_IMB_STORE*4)  
8053				chk_word: equ store_sp - 2		 ; this is the word to init and then check against to detect stack corruption. Held far away from all stacks  
8053			else  
