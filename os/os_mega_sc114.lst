9982			; My forth kernel 
9982			include "forth_kernel.asm" 
9982			; 
9982			; kernel to the forth OS 
9982			 
9982			DS_TYPE_STR: equ 1     ; string type 
9982			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
9982			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
9982			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
9982			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
9982			 
9982			FORTH_PARSEV1: equ 0 
9982			FORTH_PARSEV2: equ 0 
9982			FORTH_PARSEV3: equ 0 
9982			FORTH_PARSEV4: equ 0 
9982			FORTH_PARSEV5: equ 0 
9982			FORTH_PARSEV6: equ 1 
9982			 
9982			;if FORTH_PARSEV5 
9982			;	FORTH_END_BUFFER: equ 0 
9982			;else 
9982			FORTH_END_BUFFER: equ 127 
9982			;endif 
9982			 
9982			FORTH_TRUE: equ 1 
9982			FORTH_FALSE: equ 0 
9982			 
9982			if FORTH_PARSEV4 
9982			include "forth_stackops.asm" 
9982			endif 
9982			 
9982			if FORTH_PARSEV5 
9982			include "forth_stackopsv5.asm" 
9982			endif 
9982			 
9982			if FORTH_PARSEV6 
9982			include "forth_stackopsv5.asm" 
9982			 
9982			; Stack operations for v5 parser on wards 
9982			; * DATA stack 
9982			; * LOOP stack 
9982			; * RETURN stack 
9982			 
9982			 
9982			 
9982			FORTH_CHK_DSP_UNDER: macro 
9982				push hl 
9982				push de 
9982				ld hl,(cli_data_sp) 
9982				ld de, cli_data_stack 
9982				call cmp16 
9982				jp c, fault_dsp_under 
9982				pop de 
9982				pop hl 
9982				endm 
9982			 
9982			 
9982			FORTH_CHK_RSP_UNDER: macro 
9982				push hl 
9982				push de 
9982				ld hl,(cli_ret_sp) 
9982				ld de, cli_ret_stack 
9982				call cmp16 
9982				jp c, fault_rsp_under 
9982				pop de 
9982				pop hl 
9982				endm 
9982			 
9982			FORTH_CHK_LOOP_UNDER: macro 
9982				push hl 
9982				push de 
9982				ld hl,(cli_loop_sp) 
9982				ld de, cli_loop_stack 
9982				call cmp16 
9982				jp c, fault_loop_under 
9982				pop de 
9982				pop hl 
9982				endm 
9982			 
9982			FORTH_ERR_TOS_NOTSTR: macro 
9982				; TOSO might need more for checks when used 
9982				push af 
9982				ld a,(hl) 
9982				cp DS_TYPE_STR 
9982				jp nz, type_faultn   
9982				pop af 
9982				endm 
9982			 
9982			FORTH_ERR_TOS_NOTNUM: macro 
9982				push af 
9982				ld a,(hl) 
9982				cp DS_TYPE_INUM 
9982				jp nz, type_faultn   
9982				pop af 
9982				endm 
9982			 
9982			 
9982			; increase data stack pointer and save hl to it 
9982				 
9982			FORTH_DSP_NEXT: macro 
9982				call macro_forth_dsp_next 
9982				endm 
9982			 
9982			 
9982			macro_forth_dsp_next: 
9982				if DEBUG_FORTH_STACK_GUARD 
9982 cd 33 d3				call check_stacks 
9985				endif 
9985 e5				push hl 
9986 d5				push de 
9987 eb				ex de,hl 
9988 2a cf e9			ld hl,(cli_data_sp) 
998b 23				inc hl 
998c 23				inc hl 
998d			 
998d			; PARSEV5 
998d 23				inc hl 
998e 22 cf e9			ld (cli_data_sp),hl 
9991 73				ld (hl), e 
9992 23				inc hl 
9993 72				ld (hl), d 
9994 d1				pop de 
9995 e1				pop hl 
9996				if DEBUG_FORTH_STACK_GUARD 
9996 cd 33 d3				call check_stacks 
9999				endif 
9999 c9				ret 
999a			 
999a			 
999a			; increase ret stack pointer and save hl to it 
999a				 
999a			FORTH_RSP_NEXT: macro 
999a				call macro_forth_rsp_next 
999a				endm 
999a			 
999a			macro_forth_rsp_next: 
999a				if DEBUG_FORTH_STACK_GUARD 
999a cd 33 d3				call check_stacks 
999d				endif 
999d e5				push hl 
999e d5				push de 
999f eb				ex de,hl 
99a0 2a d3 e9			ld hl,(cli_ret_sp) 
99a3 23				inc hl 
99a4 23				inc hl 
99a5 22 d3 e9			ld (cli_ret_sp),hl 
99a8 73				ld (hl), e 
99a9 23				inc hl 
99aa 72				ld (hl), d 
99ab d1				pop de 
99ac e1				pop hl 
99ad				if DEBUG_FORTH_STACK_GUARD 
99ad cd 33 d3				call check_stacks 
99b0				endif 
99b0 c9				ret 
