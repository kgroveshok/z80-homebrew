669b			; handle the auto run of code from files in storage 
669b			 
669b			 
669b			include "forth_startup.asm" 
669b			; Which startup method to use? 
669b			; 
669b			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
669b			; followed by loading of a list of scripts in eeprom 
669b			 
669b			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
669b			; from eeprom 
669b			 
669b			; Select with define in main stubs 
669b			 
669b			if STARTUP_V1 
669b				include "forth_startupv1.asm" 
669b			endif 
669b			if STARTUP_V2 
669b				include "forth_startupv2.asm" 
669b			; Version 2 of the startup  
669b			;  
669b			; Auto load any files in bank 1 that start with a '*' 
669b			; If no se storage then revert to using eprom 
669b			 
669b			 
669b			if STORAGE_SE = 0 
669b			 
669b			sprompt1: db "Startup load...",0 
669b			sprompt2: db "Run? 1=No *=End #=All",0 
669b			 
669b			 
669b			 
669b			 
669b			forth_startup: 
669b				ld hl, startcmds 
669b				ld a, 0 
669b				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
669b			 
669b			.start1:	push hl 
669b				call clear_display 
669b				ld de, sprompt1 
669b			        ld a, display_row_1 
669b				call str_at_display 
669b				ld de, sprompt2 
669b			        ld a, display_row_2 
669b				call str_at_display 
669b				pop hl 
669b				push hl 
669b				ld e,(hl) 
669b				inc hl 
669b				ld d,(hl) 
669b			        ld a, display_row_3 
669b				call str_at_display 
669b				call update_display 
669b			 
669b			 
669b				ld a, (os_last_cmd) 
669b			;	cp 0 
669b				or a 
669b				jr z, .startprompt 
669b				call delay250ms 
669b				jr .startdo 
669b				 
669b				 
669b			 
669b			.startprompt: 
669b			 
669b				ld a,display_row_4 + display_cols - 1 
669b			        ld de, endprg 
669b				call str_at_display 
669b				call update_display 
669b				call delay1s 
669b				call cin_wait 
669b						 
669b				cp '*' 
669b				jr z, .startupend1 
669b				cp '#' 
669b				jr nz, .startno 
669b				ld a, 1 
669b				ld (os_last_cmd),a 
669b				jr .startdo 
669b			.startno:	cp '1' 
669b				jr z,.startnxt  
669b			 
669b				; exec startup line 
669b			.startdo:	 
669b				pop hl 
669b				push hl 
669b				 
669b				ld e,(hl) 
669b				inc hl 
669b				ld d,(hl) 
669b				ex de,hl 
669b			 
669b				push hl 
669b			 
669b				ld a, 0 
669b				;ld a, FORTH_END_BUFFER 
669b				call strlent 
669b				inc hl   ; include zero term to copy 
669b				ld b,0 
669b				ld c,l 
669b				pop hl 
669b				ld de, scratch 
669b				ldir 
669b			 
669b			 
669b				ld hl, scratch 
669b				call forthparse 
669b				call forthexec 
669b				call forthexec_cleanup 
669b			 
669b				ld a, display_row_4 
669b				ld de, endprog 
669b			 
669b				call update_display		 
669b			 
669b				ld a, (os_last_cmd) 
669b			;	cp 0 
669b				or a 
669b				jr nz, .startnxt 
669b				call next_page_prompt 
669b			        call clear_display 
669b				call update_display		 
669b			 
669b				; move onto next startup line? 
669b			.startnxt: 
669b			 
669b				call delay250ms 
669b				pop hl 
669b			 
669b				inc hl 
669b				inc hl 
669b			 
669b				push hl 
669b				ld e, (hl) 
669b				inc hl 
669b				ld d, (hl) 
669b				pop hl 
669b				; TODO replace 0 test 
669b			 
669b				ex de, hl 
669b				call ishlzero 
669b			;	ld a,e 
669b			;	add d 
669b			;	cp 0    ; any left to do? 
669b				ex de, hl 
669b				jp nz, .start1 
669b				jr .startupend 
669b			 
669b			.startupend1: pop hl 
669b			.startupend: 
669b			 
669b				call clear_display 
669b				call update_display 
669b				ret 
669b			endif 
