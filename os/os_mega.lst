69ab f1					pop af  
69ac d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69ae cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
69b0 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
69b2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
69b4 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
69b6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69b8 18 0d			jr .wfskip  
69ba f1			.wfea2:		pop af  
69bb d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69bd cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
69bf cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
69c1 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
69c3 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
69c5 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69c7 3e 05		.wfskip:            LD  A, 5  
69c9 cd d0 69		            CALL LCDDelay       ;Delay 5 ms to complete  
69cc f1			            POP  AF  
69cd c9			            RET  
