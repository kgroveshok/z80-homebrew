6565			; stack over and underflow checks 
6565			 
6565			; init the words to detect the under/overflow 
6565			 
6565			chk_stk_init: 
6565				; a vague random number to check so we dont get any "lucky" hits 
6565 3e 2d			ld a, 45 
6567 6f				ld l, a 
6568 00				nop 
6569 3e 17			ld a, 23 
656b 67				ld h, a 
656c			 
656c 22 b4 f0			ld (chk_word), hl     ; the word we need to check against 
656f			 
656f			;	ld (chk_stund), hl	; stack points.... 
656f 22 3b fe			ld (chk_stovr), hl 
6572 22 03 f9			ld (chk_ret_und), hl 
6575 22 c1 f8			ld (chk_ret_ovr), hl 
6578 22 3f f8			ld (chk_loop_ovr), hl 
657b 22 3d f6			ld (chk_data_ovr), hl 
657e c9				ret 
657f				 
657f			check_stacks: 
657f				; check all stack words for corruption 
657f			 
657f				; Stack checks  
657f			 
657f			 
657f				; stack over 
657f				; return under 
657f				; return over 
657f				; loop over 
657f				; data over 
657f			 
657f			 
657f e5				push hl 
6580 2a af fd			ld hl, (hardware_config+1) 
6583 cb 7e			bit 7, (hl) 
6585			 
6585 20 02			jr nz, .dochecks 
6587			 
6587 e1				pop hl 
6588 c9				ret 
6589			 
6589			.dochecks: 
6589			 
6589 d5				push de 
658a			 
658a			;	ld de,(chk_word) 
658a			;	ld hl, (chk_stund)	; stack points.... 
658a			;	if DEBUG_STK_FAULT 
658a			;		DMARK "FAa" 
658a			;		CALLMONITOR 
658a			;	endif 
658a			;	call cmp16 
658a			;	jp z, .chk_faulta 
658a			; 
658a			;	ld de, sfaultsu 
658a			;	jp .chk_fault 
658a			 
658a 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
658d ed 5b b4 f0		ld de,(chk_word) 
6591				if DEBUG_STK_FAULT 
6591					DMARK "FAb" 
6591					CALLMONITOR 
6591				endif 
6591 cd d9 0d			call cmp16 
6594 28 06			jr z, .chk_fault1 
6596 11 3b 66			ld de, sfaultso 
6599 c3 eb 65			jp .chk_fault 
659c			.chk_fault1:  
659c 2a 03 f9			ld hl, (chk_ret_und) 
659f ed 5b b4 f0		ld de,(chk_word) 
65a3				if DEBUG_STK_FAULT 
65a3					DMARK "FAU" 
65a3					CALLMONITOR 
65a3				endif 
65a3 cd d9 0d			call cmp16 
65a6 ca af 65			jp z, .chk_fault2 
65a9 11 4b 66			ld de, sfaultru 
65ac c3 eb 65			jp .chk_fault 
65af			.chk_fault2:  
65af 2a c1 f8			ld hl, (chk_ret_ovr) 
65b2 ed 5b b4 f0		ld de,(chk_word) 
65b6				if DEBUG_STK_FAULT 
65b6					DMARK "FA1" 
65b6					CALLMONITOR 
65b6				endif 
65b6 cd d9 0d			call cmp16 
65b9 ca c2 65			jp z, .chk_fault3 
65bc 11 59 66			ld de, sfaultro 
65bf c3 eb 65			jp .chk_fault 
65c2			.chk_fault3:  
65c2 2a 3f f8			ld hl, (chk_loop_ovr) 
65c5 ed 5b b4 f0		ld de,(chk_word) 
65c9				if DEBUG_STK_FAULT 
65c9					DMARK "FA2" 
65c9					CALLMONITOR 
65c9				endif 
65c9 cd d9 0d			call cmp16 
65cc ca d5 65			jp z, .chk_fault4 
65cf 11 73 66			ld de, sfaultlo 
65d2 c3 eb 65			jp .chk_fault 
65d5			.chk_fault4:  
65d5 2a 3d f6			ld hl, (chk_data_ovr) 
65d8 ed 5b b4 f0		ld de,(chk_word) 
65dc				if DEBUG_STK_FAULT 
65dc					DMARK "FA3" 
65dc					CALLMONITOR 
65dc				endif 
65dc cd d9 0d			call cmp16 
65df ca e8 65			jp z, .chk_fault5 
65e2 11 8d 66			ld de, sfaultdo 
65e5 c3 eb 65			jp .chk_fault 
65e8			 
65e8			 
