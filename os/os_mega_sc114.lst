8dab			malloc_guard_entry: 
8dab				push hl 
8dab				push de 
8dab				push af 
8dab			 
8dab			 	or a      ;clear carry flag 
8dab				push hl 
8dab				ld de, 255 
8dab				sbc hl, de 
8dab				jr c, .lowalloc 
8dab			 
8dab				push de 
8dab					ld hl, display_fb0 
8dab					ld (display_fb_active), hl 
8dab				call clear_display 
8dab				ld a, 0 
8dab				ld de, .mallocsize 
8dab				call str_at_display 
8dab				call update_display 
8dab				call delay1s 
8dab				call delay1s 
8dab			;	ld a, 0 
8dab			;	ld (os_view_disable), a 
8dab				call bp_on 
8dab			 
8dab				pop de 
8dab				pop hl 
8dab			 
8dab				 
8dab			 
8dab				CALLMONITOR 
8dab				jr .lowdone 
8dab			.lowalloc: 
8dab			 
8dab			 
8dab				pop hl 
8dab			.lowdone:	pop af 
8dab				pop de 
8dab				pop hl 
8dab			ret 
8dab			 
8dab			malloc_guard_exit: 
8dab				push hl 
8dab				push de 
8dab				push af 
8dab			 
8dab			 	or a      ;clear carry flag 
8dab				push hl 
8dab				ld de, 255 
8dab				sbc hl, de 
8dab				jr c, .lowallocx 
8dab			 
8dab				push de 
8dab					ld hl, display_fb0 
8dab					ld (display_fb_active), hl 
8dab				call clear_display 
8dab				ld a, 0 
8dab				ld de, .mallocasize 
8dab				call str_at_display 
8dab				call update_display 
8dab				call delay1s 
8dab				call delay1s 
8dab			;	ld a, 0 
8dab			;	ld (os_view_disable), a 
8dab				call bp_on 
8dab				pop de 
8dab				pop hl 
8dab			 
8dab				CALLMONITOR 
8dab				jr .lowdonex 
8dab			.lowallocx: 
8dab			 
8dab				pop hl 
8dab			.lowdonex:	pop af 
8dab				pop de 
8dab				pop hl 
8dab			ret 
8dab			endif 
