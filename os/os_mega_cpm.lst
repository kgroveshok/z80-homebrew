43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					push hl    ; count 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43f6					  ; top string 
43f6					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43f6			 
43f6					pop bc    ; count 
43f6					pop de    ; file name 
43f6			 
43f6			; TODO handle more than one string 
43f6					call tape_save 
43f6							 
43f6					NEXTW 
