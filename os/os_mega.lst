6810			; handle the auto run of code from files in storage 
6810			 
6810			 
6810			include "forth_startup.asm" 
6810			; Which startup method to use? 
6810			; 
6810			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6810			; followed by loading of a list of scripts in eeprom 
6810			 
6810			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6810			; from eeprom 
6810			 
6810			; Select with define in main stubs 
6810			 
6810			if STARTUP_V1 
6810				include "forth_startupv1.asm" 
6810			endif 
6810			if STARTUP_V2 
6810				include "forth_startupv2.asm" 
6810			; Version 2 of the startup  
6810			;  
6810			; Auto load any files in bank 1 that start with a '*' 
6810			; If no se storage then revert to using eprom 
6810			 
6810			 
6810			if STORAGE_SE = 0 
6810			 
6810			sprompt1: db "Startup load...",0 
6810			sprompt2: db "Run? 1=No *=End #=All",0 
6810			 
6810			 
6810			 
6810			 
6810			forth_startup: 
6810				ld hl, startcmds 
6810				ld a, 0 
6810				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
6810			 
6810			.start1:	push hl 
6810				call clear_display 
6810				ld de, sprompt1 
6810			        ld a, display_row_1 
6810				call str_at_display 
6810				ld de, sprompt2 
6810			        ld a, display_row_2 
6810				call str_at_display 
6810				pop hl 
6810				push hl 
6810				ld e,(hl) 
6810				inc hl 
6810				ld d,(hl) 
6810			        ld a, display_row_3 
6810				call str_at_display 
6810				call update_display 
6810			 
6810			 
6810				ld a, (os_last_cmd) 
6810			;	cp 0 
6810				or a 
6810				jr z, .startprompt 
6810				call delay250ms 
6810				jr .startdo 
6810				 
6810				 
6810			 
6810			.startprompt: 
6810			 
6810				ld a,display_row_4 + display_cols - 1 
6810			        ld de, endprg 
6810				call str_at_display 
6810				call update_display 
6810				call delay1s 
6810				call cin_wait 
6810						 
6810				cp '*' 
6810				jr z, .startupend1 
6810				cp '#' 
6810				jr nz, .startno 
6810				ld a, 1 
6810				ld (os_last_cmd),a 
6810				jr .startdo 
6810			.startno:	cp '1' 
6810				jr z,.startnxt  
6810			 
6810				; exec startup line 
6810			.startdo:	 
6810				pop hl 
6810				push hl 
6810				 
6810				ld e,(hl) 
6810				inc hl 
6810				ld d,(hl) 
6810				ex de,hl 
6810			 
6810				push hl 
6810			 
6810				ld a, 0 
6810				;ld a, FORTH_END_BUFFER 
6810				call strlent 
6810				inc hl   ; include zero term to copy 
6810				ld b,0 
6810				ld c,l 
6810				pop hl 
6810				ld de, scratch 
6810				ldir 
6810			 
6810			 
6810				ld hl, scratch 
6810				call forthparse 
6810				call forthexec 
6810				call forthexec_cleanup 
6810			 
6810				ld a, display_row_4 
6810				ld de, endprog 
6810			 
6810				call update_display		 
6810			 
6810				ld a, (os_last_cmd) 
6810			;	cp 0 
6810				or a 
6810				jr nz, .startnxt 
6810				call next_page_prompt 
6810			        call clear_display 
6810				call update_display		 
6810			 
6810				; move onto next startup line? 
6810			.startnxt: 
6810			 
6810				call delay250ms 
6810				pop hl 
6810			 
6810				inc hl 
6810				inc hl 
6810			 
6810				push hl 
6810				ld e, (hl) 
6810				inc hl 
6810				ld d, (hl) 
6810				pop hl 
