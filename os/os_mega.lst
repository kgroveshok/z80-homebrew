0fa2 87				ADD	A,A		; 
0fa3 87				ADD	A,A		; 
0fa4 57				LD	D,A		;Save hi nibble in D 
0fa5			HEXCON: 
0fa5 7e				ld a, (hl)		;Get next chr 
0fa6 23				inc hl 
0fa7 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
0fa9 fe 0a			CP	00Ah		;Is it 0-9 ? 
0fab 38 02			JR	C,NALPHA	;If so miss next bit 
0fad d6 07			SUB	007h		;Else convert alpha 
0faf			NALPHA: 
0faf b2				OR	D		;Add hi nibble back 
0fb0 c9				RET			; 
