1897			; 
1897			; kernel to the forth OS 
1897			 
1897			DS_TYPE_STR: equ 1     ; string type 
1897			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
1897			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
1897			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
1897			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
1897			 
1897			FORTH_PARSEV1: equ 0 
1897			FORTH_PARSEV2: equ 0 
1897			FORTH_PARSEV3: equ 0 
1897			FORTH_PARSEV4: equ 0 
1897			FORTH_PARSEV5: equ 0 
1897			FORTH_PARSEV6: equ 1 
1897			 
1897			;if FORTH_PARSEV5 
1897			;	FORTH_END_BUFFER: equ 0 
1897			;else 
1897			FORTH_END_BUFFER: equ 127 
1897			;endif 
1897			 
1897			FORTH_TRUE: equ 1 
1897			FORTH_FALSE: equ 0 
1897			 
1897			if FORTH_PARSEV4 
1897			include "forth_stackops.asm" 
1897			endif 
1897			 
