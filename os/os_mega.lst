1093			; Decimal Unsigned Version 
1093			 
1093			;Number in a to decimal ASCII 
1093			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
1093			;Example: display a=56 as "056" 
1093			;input: a = number 
1093			;Output: a=0,value of a in the screen 
1093			;destroys af,bc (don't know about hl and de) 
1093			DispAToASCII: 
1093 0e 9c			ld	c,-100 
1095 cd 9f 10			call	.Na1 
1098 0e f6			ld	c,-10 
109a cd 9f 10			call	.Na1 
109d 0e ff			ld	c,-1 
109f 06 2f		.Na1:	ld	b,'0'-1 
10a1 04			.Na2:	inc	b 
10a2 81				add	a,c 
10a3 38 fc			jr	c,.Na2 
10a5 91				sub	c		;works as add 100/10/1 
10a6 f5				push af		;safer than ld c,a 
10a7 78				ld	a,b		;char is in b 
10a8			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
10a8 f1				pop af		;safer than ld a,c 
10a9 c9				ret 
10aa			 
10aa			; Decimal Signed Version 
10aa			 
10aa			; DispA 
10aa			; -------------------------------------------------------------- 
10aa			; Converts a signed integer value to a zero-terminated ASCII 
10aa			; string representative of that value (using radix 10). 
10aa			; -------------------------------------------------------------- 
10aa			; INPUTS: 
10aa			;     HL     Value to convert (two's complement integer). 
10aa			;     DE     Base address of string destination. (pointer). 
10aa			; -------------------------------------------------------------- 
10aa			; OUTPUTS: 
10aa			;     None 
10aa			; -------------------------------------------------------------- 
10aa			; REGISTERS/MEMORY DESTROYED 
10aa			; AF HL 
10aa			; -------------------------------------------------------------- 
10aa			 
10aa			;DispHLToASCII: 
10aa			;   push    de 
10aa			;   push    bc 
10aa			; 
10aa			;; Detect sign of HL. 
10aa			;    bit    7, h 
10aa			;    jr     z, ._DoConvert 
10aa			; 
10aa			;; HL is negative. Output '-' to string and negate HL. 
10aa			;    ld     a, '-' 
10aa			;    ld     (de), a 
10aa			;    inc    de 
10aa			; 
10aa			;; Negate HL (using two's complement) 
10aa			;    xor    a 
10aa			;    sub    l 
10aa			;    ld     l, a 
10aa			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
10aa			;    sbc    a, h 
10aa			;    ld     h, a 
10aa			; 
10aa			;; Convert HL to digit characters 
10aa			;._DoConvert: 
10aa			;    ld     b, 0     ; B will count character length of number 
10aa			;-   ld     a, 10 
10aa			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
10aa			;    push   af 
10aa			;    inc    b 
10aa			;    ld     a, h 
10aa			;    or     l 
10aa			;    jr     nz, - 
10aa			; 
10aa			;; Retrieve digits from stack 
10aa			;-   pop    af 
10aa			;    or     $30 
10aa			;    ld     (de), a 
10aa			;    inc    de 
10aa			;    djnz   - 
10aa			; 
10aa			;; Terminate string with NULL 
10aa			;    xor    a 
10aa			;    ld     (de), a 
10aa			; 
10aa			;    pop    bc 
10aa			;    pop    de 
10aa			;    ret 
10aa			 
10aa			;Comments 
10aa			; 
10aa			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
10aa			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
10aa			;    Note that the output string will not be fixed-width. 
10aa			; 
10aa			;Example Usage 
10aa			; 
10aa			;    ld    hl, -1004 
10aa			;    ld    de, OP1 
10aa			;    call  DispA 
10aa			;    ld    hl, OP1 
10aa			;    syscall  PutS 
10aa			 
10aa			 
10aa			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
10aa			 
10aa			 
10aa			;Converts an ASCII string to an unsigned 16-bit integer 
10aa			;Quits when it reaches a non-decimal digit 
10aa			 
10aa			string_to_uint16: 
10aa			atoui_16: 
10aa			;Input: 
10aa			;     DE points to the string 
10aa			;Outputs: 
10aa			;     HL is the result 
10aa			;     A is the 8-bit value of the number 
10aa			;     DE points to the byte after the number 
10aa			;Destroys: 
10aa			;     BC 
10aa			;       if the string is non-empty, BC is HL/10 
10aa			;Size:  24 bytes 
10aa			;Speed: 42+d(104+{0,9}) 
10aa			;       d is the number of digits in the number 
10aa			;       max is 640 cycles for a 5 digit number 
10aa			;Assuming no leading zeros: 
10aa			;1 digit:  146cc 
10aa			;2 digit:  250cc 
10aa			;3 digit:  354cc or 363cc (avg: 354.126cc) 
10aa			;4 digit:  458cc or 467cc (avg: 458.27cc) 
10aa			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
10aa			;avg: 544.81158447265625cc (544+13297/16384) 
10aa			;=============================================================== 
10aa 21 00 00		  ld hl,0 
10ad			.u16a: 
10ad 1a			  ld a,(de) 
10ae d6 30		  sub 30h 
10b0 fe 0a		  cp 10 
10b2 d0			  ret nc 
10b3 13			  inc de 
10b4 44			  ld b,h 
10b5 4d			  ld c,l 
10b6 29			  add hl,hl 
10b7 29			  add hl,hl 
10b8 09			  add hl,bc 
10b9 29			  add hl,hl 
10ba 85			  add a,l 
10bb 6f			  ld l,a 
10bc 30 ef		  jr nc,.u16a 
10be 24			  inc h 
10bf c3 ad 10		  jp .u16a 
10c2			 
10c2			 
10c2			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
10c2			 
10c2			;written by Zeda 
10c2			;Converts a 16-bit unsigned integer to an ASCII string. 
10c2			 
10c2			uitoa_16: 
10c2			;Input: 
10c2			;   DE is the number to convert 
10c2			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
10c2			;Output: 
10c2			;   HL points to the null-terminated ASCII string 
10c2			;      NOTE: This isn't necessarily the same as the input HL. 
10c2 d5			  push de 
10c3 c5			  push bc 
10c4 f5			  push af 
10c5 eb			  ex de,hl 
10c6			 
10c6 01 f0 d8		  ld bc,-10000 
10c9 3e 2f		  ld a,'0'-1 
10cb 3c			  inc a 
10cc 09			  add hl,bc  
10cd 38 fc		   jr c,$-2 
10cf 12			  ld (de),a 
10d0 13			  inc de 
10d1			 
10d1 01 e8 03		  ld bc,1000 
10d4 3e 3a		  ld a,'9'+1 
10d6 3d			  dec a  
10d7 09			  add hl,bc  
10d8 30 fc		   jr nc,$-2 
10da 12			  ld (de),a 
10db 13			  inc de 
10dc			 
10dc 01 9c ff		  ld bc,-100 
10df 3e 2f		  ld a,'0'-1 
10e1 3c			  inc a  
10e2 09			  add hl,bc  
10e3 38 fc		   jr c,$-2 
10e5 12			  ld (de),a 
10e6 13			  inc de 
10e7			 
10e7 7d			  ld a,l 
10e8 26 3a		  ld h,'9'+1 
10ea 25			  dec h  
10eb c6 0a		  add a,10  
10ed 30 fb		   jr nc,$-3 
10ef c6 30		  add a,'0' 
10f1 eb			  ex de,hl 
10f2 72			  ld (hl),d 
10f3 23			  inc hl 
10f4 77			  ld (hl),a 
10f5 23			  inc hl 
10f6 36 00		  ld (hl),0 
10f8			 
10f8			;Now strip the leading zeros 
10f8 0e fa		  ld c,-6 
10fa 09			  add hl,bc 
10fb 3e 30		  ld a,'0' 
10fd 23			  inc hl  
10fe be			  cp (hl)  
10ff 28 fc		  jr z,$-2 
1101			 
1101			;Make sure that the string is non-empty! 
1101 7e			  ld a,(hl) 
1102 b7			  or a 
1103 20 01		  jr nz,.atoub 
1105 2b			  dec hl 
1106			.atoub: 
1106			 
1106 f1			  pop af 
1107 c1			  pop bc 
1108 d1			  pop de 
1109 c9			  ret 
110a			 
110a			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
110a			 
110a			toUpper: 
110a			;A is the char. 
110a			;If A is a lowercase letter, this sets it to the matching uppercase 
110a			;18cc or 30cc or 41cc 
110a			;avg: 26.75cc 
110a fe 61		  cp 'a' 
110c d8			  ret c 
110d fe 7b		  cp 'z'+1 
110f d0			  ret nc 
1110 d6 20		  sub 'a'-'A' 
1112 c9			  ret 
