9929			;		DMARK "RPP" 
9929 cd 38 dc				call check_stacks 
992c					FORTH_CHK_RSP_UNDER 
992c e5				push hl 
992d d5				push de 
992e 2a e5 e9			ld hl,(cli_ret_sp) 
9931 11 9f e9			ld de, cli_ret_stack 
9934 cd 91 8c			call cmp16 
9937 da 4f dd			jp c, fault_rsp_under 
993a d1				pop de 
993b e1				pop hl 
993c				endm 
# End of macro FORTH_CHK_RSP_UNDER
