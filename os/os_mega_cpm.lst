0f6a			 
0f6a			;Comparing Strings 
0f6a			 
0f6a			;IN    HL     Address of string1. 
0f6a			;      DE     Address of string2. 
0f6a			 
0f6a			; doc given but wrong??? 
0f6a			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
0f6a			;      carry  Set if string1 > string2, reset if string1 <= string2. 
0f6a			; tested 
0f6a			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
0f6a			 
0f6a			strcmp_old: 
0f6a e5			    PUSH   HL 
0f6b d5			    PUSH   DE 
0f6c			 
0f6c 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
0f6d be			    CP     (HL)            ; (want to minimize work). 
0f6e 38 01		    JR     C, Str1IsBigger 
0f70 7e			    LD     A, (HL) 
0f71			 
0f71			Str1IsBigger: 
0f71 4f			    LD     C, A             ; Put length in BC 
0f72 06 00		    LD     B, 0 
0f74 13			    INC    DE              ; Increment pointers to meat of string. 
0f75 23			    INC    HL 
0f76			 
0f76			CmpLoop: 
0f76 1a			    LD     A, (DE)          ; Compare bytes. 
0f77 ed a1		    CPI 
0f79 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
0f7b 13			    INC    DE              ; Update pointer. 
0f7c ea 76 0f		    JP     PE, CmpLoop 
0f7f			 
0f7f d1			    POP    DE 
0f80 e1			    POP    HL 
0f81 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
0f82 be			    CP     (HL) 
0f83 c9			    RET 
0f84			 
0f84			NoMatch: 
0f84 2b			    DEC    HL 
0f85 be			    CP     (HL)            ; Compare again to affect carry. 
0f86 d1			    POP    DE 
0f87 e1			    POP    HL 
0f88 c9			    RET 
