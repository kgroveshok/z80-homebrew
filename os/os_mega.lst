20ea			; 
20ea			; kernel to the forth OS 
20ea			 
20ea			DS_TYPE_STR: equ 1     ; string type 
20ea			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
20ea			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
20ea			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
20ea			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
20ea			 
20ea			FORTH_PARSEV1: equ 0 
20ea			FORTH_PARSEV2: equ 0 
20ea			FORTH_PARSEV3: equ 0 
20ea			FORTH_PARSEV4: equ 0 
20ea			FORTH_PARSEV5: equ 0 
20ea			FORTH_PARSEV6: equ 1 
20ea			 
20ea			;if FORTH_PARSEV5 
20ea			;	FORTH_END_BUFFER: equ 0 
20ea			;else 
20ea			FORTH_END_BUFFER: equ 127 
20ea			;endif 
20ea			 
20ea			FORTH_TRUE: equ 1 
20ea			FORTH_FALSE: equ 0 
