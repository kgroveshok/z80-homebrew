100d			; 
100d			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
100d			; Since the routines get_byte and therefore get_nibble are called, only valid 
100d			; characters (0-9a-f) are accepted. 
100d			; 
100d			;get_word        push    af 
100d			;                call    get_byte        ; Get the upper byte 
100d			;                ld      h, a 
100d			;                call    get_byte        ; Get the lower byte 
100d			;                ld      l, a 
100d			;                pop     af 
100d			;                ret 
100d			; 
100d			; Get a byte in hexadecimal notation. The result is returned in A. Since 
100d			; the routine get_nibble is used only valid characters are accepted - the  
100d			; input routine only accepts characters 0-9a-f. 
100d			; 
100d c5			get_byte:        push    bc              ; Save contents of B (and C) 
100e 7e					ld a,(hl) 
100f 23					inc hl 
1010 cd 35 10		                call    nibble2val      ; Get upper nibble 
1013 cb 07		                rlc     a 
1015 cb 07		                rlc     a 
1017 cb 07		                rlc     a 
1019 cb 07		                rlc     a 
101b 47			                ld      b, a            ; Save upper four bits 
101c 7e					ld a,(hl) 
101d cd 35 10		                call    nibble2val      ; Get lower nibble 
1020 b0			                or      b               ; Combine both nibbles 
1021 c1			                pop     bc              ; Restore B (and C) 
1022 c9			                ret 
1023			; 
1023			; Get a hexadecimal digit from the serial line. This routine blocks until 
1023			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
1023			; to the serial line interface. The lower 4 bits of A contain the value of  
