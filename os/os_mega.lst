0137			spi_clk: 
0137 f5				push af 
0138 3a 8f f9			ld a, (spi_clktime) 
013b			;	cp 0 
013b b7				or a 
013c 28 03			jr z, .scskip 
013e cd 99 0a			call aDelayInMS 
0141			.scskip: 
0141 f1				pop af 
0142 c9				ret 
