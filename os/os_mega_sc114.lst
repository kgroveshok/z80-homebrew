8ca7			; 
8ca7			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8ca7			; Since the routines get_byte and therefore get_nibble are called, only valid 
8ca7			; characters (0-9a-f) are accepted. 
8ca7			; 
8ca7			;get_word        push    af 
8ca7			;                call    get_byte        ; Get the upper byte 
8ca7			;                ld      h, a 
8ca7			;                call    get_byte        ; Get the lower byte 
8ca7			;                ld      l, a 
8ca7			;                pop     af 
8ca7			;                ret 
8ca7			; 
8ca7			; Get a byte in hexadecimal notation. The result is returned in A. Since 
8ca7			; the routine get_nibble is used only valid characters are accepted - the  
8ca7			; input routine only accepts characters 0-9a-f. 
8ca7			; 
8ca7 c5			get_byte:        push    bc              ; Save contents of B (and C) 
8ca8 7e					ld a,(hl) 
8ca9 23					inc hl 
8caa cd cf 8c		                call    nibble2val      ; Get upper nibble 
8cad cb 07		                rlc     a 
8caf cb 07		                rlc     a 
8cb1 cb 07		                rlc     a 
8cb3 cb 07		                rlc     a 
8cb5 47			                ld      b, a            ; Save upper four bits 
8cb6 7e					ld a,(hl) 
8cb7 cd cf 8c		                call    nibble2val      ; Get lower nibble 
8cba b0			                or      b               ; Combine both nibbles 
8cbb c1			                pop     bc              ; Restore B (and C) 
8cbc c9			                ret 
8cbd			; 
8cbd			; Get a hexadecimal digit from the serial line. This routine blocks until 
8cbd			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
8cbd			; to the serial line interface. The lower 4 bits of A contain the value of  
8cbd			; that particular digit. 
8cbd			; 
8cbd			;get_nibble      ld a,(hl)           ; Read a character 
8cbd			;                call    to_upper        ; Convert to upper case 
8cbd			;                call    is_hex          ; Was it a hex digit? 
8cbd			;                jr      nc, get_nibble  ; No, get another character 
8cbd			 ;               call    nibble2val      ; Convert nibble to value 
8cbd			 ;               call    print_nibble 
8cbd			 ;               ret 
8cbd			; 
8cbd			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
8cbd			; A valid hexadecimal digit is denoted by a set C flag. 
8cbd			; 
