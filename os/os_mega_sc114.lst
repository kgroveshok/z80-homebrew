99b1				endm 
99b1			 
99b1			macro_forth_rsp_tos: 
99b1				;push de 
99b1 2a d3 e9			ld hl,(cli_ret_sp) 
99b4 cd e9 99			call loadhlptrtohl 
99b7				;ld e, (hl) 
99b7				;inc hl 
99b7				;ld d, (hl) 
99b7				;ex de, hl 
99b7					if DEBUG_FORTH_WORDS 
99b7			;			DMARK "RST" 
99b7						CALLMONITOR 
99b7				if BASE_CPM=1  
99b7					call debug_vector  
99b7				endif  
99b7				if BASE_KEV=1  
99b7					rst 8  
99b7				endif  
99b7				endm  
# End of macro CALLMONITOR
99b7					endif 
99b7				;pop de 
99b7 c9				ret 
