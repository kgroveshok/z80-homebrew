98a6 23				inc hl 
98a7 22 d6 e9			ld (cli_ret_sp),hl 
98aa 73				ld (hl), e 
98ab 23				inc hl 
98ac 72				ld (hl), d 
98ad d1				pop de 
98ae e1				pop hl 
98af				if DEBUG_FORTH_STACK_GUARD 
