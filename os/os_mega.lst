12e0			 
12e0			.contheap: 
12e0				ld hl, heap_start 
12e0			 
12e0			.startalloc: 
12e0			 
12e0					if DEBUG_FORTH_MALLOC_INT 
12e0						DMARK "mym" 
12e0						CALLMONITOR 
12e0					endif 
12e0			.findblock: 
12e0					if DEBUG_FORTH_MALLOC_INT 
12e0						DMARK "mmf" 
