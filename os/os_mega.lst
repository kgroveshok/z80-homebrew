0f60 17			    rla 
0f61 cb 11		    rl c 
0f63 30 07		    jr nc,Mult32_NoAdd 
0f65 19			    add hl,de 
0f66 ce 00		    adc a,0 
0f68 d2 6c 0f		    jp nc,Mult32_NoAdd 
0f6b 0c			    inc c 
0f6c			Mult32_NoAdd: 
