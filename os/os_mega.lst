693b			; **********************************************************************  
693b			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
693b			; **********************************************************************  
693b			;  
693b			; **  Written as a Small Computer Monitor App  
693b			; **  www.scc.me.uk  
693b			;  
693b			; History  
693b			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
693b			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
693b			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
693b			;  
693b			; **********************************************************************  
693b			;  
693b			; This program is an example of one of the methods of interfacing an   
693b			; alphanumeric LCD module.   
693b			;  
693b			; In this example the display is connected to either a Z80 PIO or a   
693b			; simple 8-bit output port.   
693b			;  
693b			; This interfacing method uses 4-bit data mode and uses time delays  
693b			; rather than polling the display's ready status. As a result the   
693b			; interface only requires 6 simple output lines:  
693b			;   Output bit 0 = not used  
693b			;   Output bit 1 = not used  
693b			;   Output bit 2 = RS         High = data, Low = instruction  
693b			;   Output bit 3 = E          Active high  
693b			;   Output bit 4 = DB4  
693b			;   Output bit 5 = DB5  
693b			;   Output bit 6 = DB6  
693b			;   Output bit 7 = DB7  
693b			; Display's R/W is connected to 0v so it is always in write mode  
693b			;  
693b			; This set up should work with any system supporting the RC2014 bus  
693b			  
693b			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
693b			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
693b			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
693b			;  
693b			; **********************************************************************  
693b			  
693b			; Additonal for 4x40. E1 and E2 instead of just E   
693b			; TODO swipe vidout signal on port a to activate E2  
693b			  
693b			; **********************************************************************  
693b			; **  Constants  
693b			; **********************************************************************  
693b			; LCD constants required by LCD support module  
693b			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
693b			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
693b			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
693b			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VICLK  
693b			kLCDBitLED:   EQU 1              ;Port bit for LCD E2 signal            VIDDO  
693b			; TODO Decide which E is being set  
693b			kLCDWidth:  EQU display_cols             ;Width in characters  
693b			  
693b			; **********************************************************************  
693b			; **  Code library usage  
693b			; **********************************************************************  
693b			  
693b			; send character to current cursor position  
693b			; wraps and/or scrolls screen automatically  
693b			  
693b			  
