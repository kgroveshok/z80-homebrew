20a2 cd d8 20			call loadhlptrtohl 
20a5				;ld e, (hl) 
20a5				;inc hl 
20a5				;ld d, (hl) 
20a5				;ex de, hl 
20a5					if DEBUG_FORTH_WORDS 
20a5			;			DMARK "RST" 
20a5						CALLMONITOR 
20a5				if BASE_CPM=1  
20a5					call debug_vector  
20a5				endif  
20a5				if BASE_KEV=1  
20a5 cf					rst 8  
20a6				endif  
20a6				endm  
# End of macro CALLMONITOR
20a6					endif 
20a6				;pop de 
20a6 c9				ret 
20a7			 
20a7			; pop ret stack pointer 
