9e50			.HEAP: 
9e50			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9e50 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e51 89 9e			dw .EXEC            
9e53 05				db 4 + 1 
9e54 .. 00			db "HEAP",0              
9e59				endm 
# End of macro CWHEAD
9e59			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9e59			; | | u1 - Current number of bytes in the heap 
9e59			; | | u2 - Remaining bytes left on the heap 
9e59			; | |  
9e59			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9e59			 
9e59			 
9e59				if DEBUG_FORTH_WORDS_KEY 
9e59					DMARK "HEP" 
9e59 f5				push af  
9e5a 3a 6e 9e			ld a, (.dmark)  
9e5d 32 5e ee			ld (debug_mark),a  
9e60 3a 6f 9e			ld a, (.dmark+1)  
9e63 32 5f ee			ld (debug_mark+1),a  
9e66 3a 70 9e			ld a, (.dmark+2)  
9e69 32 60 ee			ld (debug_mark+2),a  
9e6c 18 03			jr .pastdmark  
9e6e ..			.dmark: db "HEP"  
9e71 f1			.pastdmark: pop af  
9e72			endm  
# End of macro DMARK
9e72					CALLMONITOR 
9e72				if BASE_CPM=1  
9e72					call debug_vector  
9e72				endif  
9e72				if BASE_KEV=1  
9e72					rst 8  
9e72				endif  
9e72				endm  
# End of macro CALLMONITOR
9e72				endif 
