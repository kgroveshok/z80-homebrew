0f00			 
0f00			;http://z80-heaven.wikidot.com/math 
0f00			; 
0f00			;Inputs: 
0f00			;     DE and A are factors 
0f00			;Outputs: 
0f00			;     A is not changed 
0f00			;     B is 0 
0f00			;     C is not changed 
0f00			;     DE is not changed 
0f00			;     HL is the product 
0f00			;Time: 
0f00			;     342+6x 
0f00			; 
0f00			Mult16: 
0f00			 
0f00 06 08		     ld b,8          ;7           7 
0f02 21 00 00		     ld hl,0         ;10         10 
0f05 29			       add hl,hl     ;11*8       88 
0f06 07			       rlca          ;4*8        32 
0f07 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0f09 19			         add hl,de   ;--         -- 
0f0a 10 f9		       djnz $-5      ;13*7+8     99 
0f0c c9			ret 
0f0d			 
0f0d			; 
0f0d			; Square root of 16-bit value 
0f0d			; In:  HL = value 
0f0d			; Out:  D = result (rounded down) 
0f0d			; 
0f0d			;Sqr16: 
0f0d			;    ld de,#0040 
0f0d			;    ld a,l 
0f0d			;    ld l,h 
0f0d			;    ld h,d 
0f0d			;    or a 
0f0d			;    ld b,8 
0f0d			;Sqr16_Loop: 
0f0d			;    sbc hl,de 
0f0d			;    jr nc,Sqr16_Skip 
0f0d			;    add hl,de 
0f0d			;Sqr16_Skip: 
0f0d			;    ccf 
0f0d			;    rl d 
0f0d			;    add a,a 
0f0d			;    adc hl,hl 
0f0d			;    add a,a 
0f0d			;    adc hl,hl 
0f0d			;    djnz Sqr16_Loop 
0f0d			;    ret 
0f0d			; 
0f0d			; 
0f0d			; Divide 8-bit values 
0f0d			; In: Divide E by divider C 
0f0d			; Out: A = result, B = rest 
0f0d			; 
0f0d			Div8: 
0f0d af			    xor a 
0f0e 06 08		    ld b,8 
0f10			Div8_Loop: 
0f10 cb 13		    rl e 
0f12 17			    rla 
0f13 91			    sub c 
0f14 30 01		    jr nc,Div8_NoAdd 
0f16 81			    add a,c 
0f17			Div8_NoAdd: 
0f17 10 f7		    djnz Div8_Loop 
0f19 47			    ld b,a 
0f1a 7b			    ld a,e 
0f1b 17			    rla 
0f1c 2f			    cpl 
0f1d c9			    ret 
0f1e			 
0f1e			; 
0f1e			; Multiply 8-bit value with a 16-bit value (unrolled) 
0f1e			; In: Multiply A with DE 
0f1e			; Out: HL = result 
0f1e			; 
0f1e			Mult12U: 
0f1e 2e 00		    ld l,0 
0f20 87			    add a,a 
0f21 30 01		    jr nc,Mult12U_NoAdd0 
0f23 19			    add hl,de 
0f24			Mult12U_NoAdd0: 
0f24 29			    add hl,hl 
0f25 87			    add a,a 
0f26 30 01		    jr nc,Mult12U_NoAdd1 
0f28 19			    add hl,de 
0f29			Mult12U_NoAdd1: 
0f29 29			    add hl,hl 
0f2a 87			    add a,a 
0f2b 30 01		    jr nc,Mult12U_NoAdd2 
0f2d 19			    add hl,de 
0f2e			Mult12U_NoAdd2: 
0f2e 29			    add hl,hl 
0f2f 87			    add a,a 
0f30 30 01		    jr nc,Mult12U_NoAdd3 
0f32 19			    add hl,de 
0f33			Mult12U_NoAdd3: 
0f33 29			    add hl,hl 
0f34 87			    add a,a 
0f35 30 01		    jr nc,Mult12U_NoAdd4 
0f37 19			    add hl,de 
0f38			Mult12U_NoAdd4: 
0f38 29			    add hl,hl 
0f39 87			    add a,a 
0f3a 30 01		    jr nc,Mult12U_NoAdd5 
0f3c 19			    add hl,de 
0f3d			Mult12U_NoAdd5: 
0f3d 29			    add hl,hl 
0f3e 87			    add a,a 
0f3f 30 01		    jr nc,Mult12U_NoAdd6 
0f41 19			    add hl,de 
0f42			Mult12U_NoAdd6: 
