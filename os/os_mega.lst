748b 23			cpr1:	inc hl  
748c 0d				dec c  
748d 20 fc			jr nz, cpr1  
748f 05				dec b  
7490 20 f7			jr nz, cpr  
7492			  
7492				; add col	  
7492			  
7492 23			cpr2:	inc hl  
7493 1d				dec e  
7494 20 fc			jr nz, cpr2  
7496			  
7496 c1				pop bc  
7497 c9				ret  
