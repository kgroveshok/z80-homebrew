98ed			FORTH_DSP_NEXT: macro 
98ed				call macro_forth_dsp_next 
98ed				endm 
98ed			 
98ed			 
98ed			macro_forth_dsp_next: 
98ed				if DEBUG_FORTH_STACK_GUARD 
98ed cd 97 d2				call check_stacks 
98f0				endif 
98f0 e5				push hl 
98f1 d5				push de 
98f2 eb				ex de,hl 
98f3 2a d2 e9			ld hl,(cli_data_sp) 
98f6 23				inc hl 
98f7 23				inc hl 
98f8			 
98f8			; PARSEV5 
98f8 23				inc hl 
98f9 22 d2 e9			ld (cli_data_sp),hl 
98fc 73				ld (hl), e 
98fd 23				inc hl 
98fe 72				ld (hl), d 
98ff d1				pop de 
9900 e1				pop hl 
9901				if DEBUG_FORTH_STACK_GUARD 
9901 cd 97 d2				call check_stacks 
9904				endif 
9904 c9				ret 
