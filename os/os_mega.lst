1251			 
1251			;------------------------------------------------------------------------------ 
1251			;     free                                                                    : 
1251			;                                                                             : 
1251			; Description                                                                 : 
1251			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1251			;     returned by malloc, otherwise the behaviour is undefined.               : 
1251			;                                                                             : 
1251			;     Where possible, directly adjacent free blocks will be merged together   : 
1251			;     into larger blocks to help ensure that the heap does not become         : 
1251			;     excessively fragmented.                                                 : 
1251			;                                                                             : 
1251			;     free does not clear or set any other value into the freed space, and    : 
1251			;     therefore its contents may be visible through subsequent malloc's. The  : 
1251			;     caller should clear the freed space as required.                        : 
1251			;                                                                             : 
1251			;     This implementation of free uses the stack exclusively, and is          : 
1251			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1251			;     advisable to disable interrupts before calling free, and recommended    : 
1251			;     to avoid the use of free inside ISRs in general.                        : 
1251			;                                                                             : 
1251			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1251			;                                                                             : 
1251			; Parameters                                                                  : 
1251			;     HL  Pointer to address of first byte of allocation to be freed          : 
1251			;                                                                             : 
1251			; Returns                                                                     : 
1251			;     Nothing                                                                 : 
1251			;                                                                             : 
1251			; Stack frame                                                                 : 
1251			;       |             |                                                       : 
1251			;       +-------------+                                                       : 
1251			;       |     BC      |                                                       : 
1251			;       +-------------+                                                       : 
1251			;       |     DE      |                                                       : 
1251			;       +-------------+                                                       : 
1251			;       |     IX      |                                                       : 
1251			;       +-------------+                                                       : 
1251			;       |  prev_free  |                                                       : 
1251			;   +2  +-------------+                                                       : 
1251			;       |  next_free  |                                                       : 
1251			;   +0  +-------------+                                                       : 
1251			;       |             |                                                       : 
1251			;                                                                             : 
1251			;------------------------------------------------------------------------------ 
1251			free: 
1251 c5			      push  BC 
1252 d5			      push  DE 
1253 dd e5		      push  IX 
1255			 
1255 7c			      ld    A, H                    ; Exit if ptr is null 
1256 b5			      or    L 
1257 ca 1b 13		      jp    Z, free_early_exit 
125a			 
125a			      ; Set up stack frame 
125a eb			      ex    DE, HL 
125b 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
125e 39			      add   HL, SP 
125f f9			      ld    SP, HL 
1260 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1264 dd 39		      add   IX, SP 
1266			 
1266			      ; The address in HL points to the start of the useable allocated space, 
1266			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1266			      ; address of the block itself. 
1266 eb			      ex    DE, HL 
1267 11 fc ff		      ld    DE, -4 
126a 19			      add   HL, DE 
126b			 
126b			      ; An allocated block must have a null next block pointer in it 
126b 7e			      ld    A, (HL) 
126c 23			      inc   HL 
126d b6			      or    (HL) 
126e c2 16 13		      jp    NZ, free_done 
1271			 
1271 2b			      dec   HL 
1272			 
1272 44			      ld    B, H                    ; Copy HL to BC 
1273 4d			      ld    C, L 
1274			 
1274			      ; Loop through the free list to find the first block with an address 
1274			      ; higher than the block being freed 
1274 21 0a 80		      ld    HL, free_list 
1277			 
1277			free_find_higher_block: 
1277 5e			      ld    E, (HL)                 ; Load next ptr from free block 
1278 23			      inc   HL 
1279 56			      ld    D, (HL) 
127a 2b			      dec   HL 
127b			 
127b dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
127e dd 72 01		      ld    (IX+1), D 
1281 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1284 dd 74 03		      ld    (IX+3), H 
1287			 
1287 78			      ld    A, B                    ; Check if DE is greater than BC 
1288 ba			      cp    D                       ; Compare MSB first 
1289 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
128b 30 04		      jr    NC, free_find_higher_block_skip 
128d 79			      ld    A, C 
128e bb			      cp    E                       ; Then compare LSB 
128f 38 08		      jr    C, free_found_higher_block 
1291			 
1291			free_find_higher_block_skip: 
1291 7a			      ld    A, D                    ; Reached the end of the free list? 
1292 b3			      or    E 
1293 ca 16 13		      jp    Z, free_done 
1296			 
1296 eb			      ex    DE, HL 
1297			 
1297 18 de		      jr    free_find_higher_block 
1299			 
1299			free_found_higher_block: 
1299			      ; Insert freed block between prev and next free blocks 
1299 71			      ld    (HL), C                 ; Point prev free block to freed block 
129a 23			      inc   HL 
129b 70			      ld    (HL), B 
129c			 
129c 60			      ld    H, B                    ; Point freed block at next free block 
129d 69			      ld    L, C 
129e 73			      ld    (HL), E 
129f 23			      inc   HL 
12a0 72			      ld    (HL), D 
12a1			 
12a1			      ; Check if the freed block is adjacent to the next free block 
12a1 23			      inc   HL                      ; Load size of freed block into HL 
12a2 5e			      ld    E, (HL) 
12a3 23			      inc   HL 
12a4 56			      ld    D, (HL) 
12a5 eb			      ex    DE, HL 
12a6			 
12a6 09			      add   HL, BC                  ; Add addr of freed block and its size 
12a7			 
12a7 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
12aa dd 56 01		      ld    D, (IX+1) 
12ad			 
12ad b7			      or    A                       ; Clear the carry flag 
12ae ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12b0 20 22		      jr    NZ, free_check_adjacent_to_prev 
12b2			 
12b2			      ; Freed block is adjacent to next, merge into one bigger block 
12b2 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
12b3 5e			      ld    E, (HL) 
12b4 23			      inc   HL 
12b5 56			      ld    D, (HL) 
12b6 e5			      push  HL                      ; Save ptr to next block for later 
12b7			 
12b7 60			      ld    H, B                    ; Store ptr from next block into freed block 
12b8 69			      ld    L, C 
12b9 73			      ld    (HL), E 
12ba 23			      inc   HL 
12bb 72			      ld    (HL), D 
12bc			 
12bc e1			      pop   HL                      ; Restore ptr to next block 
12bd 23			      inc   HL                      ; Load size of next block into DE 
12be 5e			      ld    E, (HL) 
12bf 23			      inc   HL 
12c0 56			      ld    D, (HL) 
12c1 d5			      push  DE                      ; Save next block size for later 
12c2			 
12c2 60			      ld    H, B                    ; Load size of freed block into HL 
12c3 69			      ld    L, C 
12c4 23			      inc   HL 
12c5 23			      inc   HL 
12c6 5e			      ld    E, (HL) 
12c7 23			      inc   HL 
12c8 56			      ld    D, (HL) 
12c9 eb			      ex    DE, HL 
12ca			 
12ca d1			      pop   DE                      ; Restore size of next block 
12cb 19			      add   HL, DE                  ; Add sizes of both blocks 
12cc eb			      ex    DE, HL 
12cd			 
12cd 60			      ld    H, B                    ; Store new bigger size into freed block 
12ce 69			      ld    L, C 
12cf 23			      inc   HL 
12d0 23			      inc   HL 
12d1 73			      ld    (HL), E 
12d2 23			      inc   HL 
12d3 72			      ld    (HL), D 
12d4			 
12d4			free_check_adjacent_to_prev: 
12d4			      ; Check if the freed block is adjacent to the prev free block 
12d4 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
12d7 dd 66 03		      ld    H, (IX+3) 
12da			 
12da 23			      inc   HL                      ; Size of prev free block into DE 
12db 23			      inc   HL 
12dc 5e			      ld    E, (HL) 
12dd 23			      inc   HL 
12de 56			      ld    D, (HL) 
12df 2b			      dec   HL 
12e0 2b			      dec   HL 
12e1 2b			      dec   HL 
12e2			 
12e2 19			      add   HL, DE                  ; Add prev block addr and size 
12e3			 
12e3 b7			      or    A                       ; Clear the carry flag 
12e4 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12e6 20 2e		      jr    NZ, free_done 
12e8			 
12e8			      ; Freed block is adjacent to prev, merge into one bigger block 
12e8 60			      ld    H, B                    ; Load next ptr from freed block into DE 
12e9 69			      ld    L, C 
12ea 5e			      ld    E, (HL) 
12eb 23			      inc   HL 
12ec 56			      ld    D, (HL) 
12ed e5			      push  HL                      ; Save freed block ptr for later 
12ee			 
12ee dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12f1 dd 66 03		      ld    H, (IX+3) 
12f4 73			      ld    (HL), E 
12f5 23			      inc   HL 
12f6 72			      ld    (HL), D 
12f7			 
12f7 e1			      pop   HL                      ; Restore freed block ptr 
12f8 23			      inc   HL                      ; Load size of freed block into DE 
12f9 5e			      ld    E, (HL) 
12fa 23			      inc   HL 
12fb 56			      ld    D, (HL) 
12fc d5			      push  DE                      ; Save freed block size for later 
12fd			 
12fd dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
1300 dd 66 03		      ld    H, (IX+3) 
1303 23			      inc   HL 
1304 23			      inc   HL 
1305 5e			      ld    E, (HL) 
1306 23			      inc   HL 
1307 56			      ld    D, (HL) 
1308			 
1308 e1			      pop   HL                      ; Add sizes of both blocks 
1309 19			      add   HL, DE 
130a eb			      ex    DE, HL 
130b			 
130b dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
130e dd 66 03		      ld    H, (IX+3) 
1311 23			      inc   HL 
1312 23			      inc   HL 
1313 73			      ld    (HL), E 
1314 23			      inc   HL 
1315 72			      ld    (HL), D 
1316			 
1316			free_done: 
1316 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
1319 39			      add   HL, SP 
131a f9			      ld    SP, HL 
131b			 
131b			free_early_exit: 
131b dd e1		      pop   IX 
131d d1			      pop   DE 
131e c1			      pop   BC 
131f			 
131f c9			      ret 
1320			 
