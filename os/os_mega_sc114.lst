9c03				dw nxtword            
9c03				; link to next dict word block 
9c03				db len + 1 
9c03				; literal length of dict word inc zero term 
9c03				db lit,0              
9c03				; literal dict word 
9c03			        ; TODO db opflags        
9c03				endm 
