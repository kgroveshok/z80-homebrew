0d08			; 
0d08			; Divide 8-bit values 
0d08			; In: Divide E by divider C 
0d08			; Out: A = result, B = rest 
0d08			; 
0d08			Div8: 
0d08 af			    xor a 
0d09 06 08		    ld b,8 
0d0b			Div8_Loop: 
0d0b cb 13		    rl e 
0d0d 17			    rla 
0d0e 91			    sub c 
0d0f 30 01		    jr nc,Div8_NoAdd 
0d11 81			    add a,c 
0d12			Div8_NoAdd: 
0d12 10 f7		    djnz Div8_Loop 
0d14 47			    ld b,a 
0d15 7b			    ld a,e 
0d16 17			    rla 
0d17 2f			    cpl 
0d18 c9			    ret 
