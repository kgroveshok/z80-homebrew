0fc0			;------------------------------------------------------------------------------ 
0fc0			;     malloc                                                                  : 
0fc0			;                                                                             : 
0fc0			; Description                                                                 : 
0fc0			;     Allocates the wanted space from the heap and returns the address of the : 
0fc0			;     first useable byte of the allocation.                                   : 
0fc0			;                                                                             : 
0fc0			;     Allocations can happen in one of two ways:                              : 
0fc0			;                                                                             : 
0fc0			;     1. A free block may be found which is the exact size wanted. In this    : 
0fc0			;        case the block is removed from the free list and retuedn to the      : 
0fc0			;        caller.                                                              : 
0fc0			;     2. A free block may be found which is larger than the size wanted. In   : 
0fc0			;        this case, the larger block is split into two. The first portion of  : 
0fc0			;        this block will become the requested space by the malloc call and    : 
0fc0			;        is returned to the caller. The second portion becomes a new free     : 
0fc0			;        block, and the free list is adjusted to maintain continuity via this : 
0fc0			;        newly created block.                                                 : 
0fc0			;                                                                             : 
0fc0			;     malloc does not set any initial value in the allocated space, the       : 
0fc0			;     caller is required to do this as required.                              : 
0fc0			;                                                                             : 
0fc0			;     This implementation of malloc uses the stack exclusively, and is        : 
0fc0			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
0fc0			;     advisable to disable interrupts before calling malloc, and recommended  : 
0fc0			;     to avoid the use of malloc inside ISRs in general.                      : 
0fc0			;                                                                             : 
0fc0			;     NOTE: heap_init must be called before malloc and free can be used.      : 
0fc0			;                                                                             : 
0fc0			; Parameters                                                                  : 
0fc0			;     HL  Number of bytes wanted                                              : 
0fc0			;                                                                             : 
0fc0			; Returns                                                                     : 
0fc0			;     HL  Address of the first useable byte of the allocation                 : 
0fc0			;                                                                             : 
0fc0			; Flags                                                                       : 
0fc0			;     Z   Set if the allocation did not succeed, clear otherwise              : 
0fc0			;                                                                             : 
0fc0			; Stack frame                                                                 : 
0fc0			;       |             |                                                       : 
0fc0			;       +-------------+                                                       : 
0fc0			;       |     BC      |                                                       : 
0fc0			;       +-------------+                                                       : 
0fc0			;       |     DE      |                                                       : 
0fc0			;       +-------------+                                                       : 
0fc0			;       |     IX      |                                                       : 
0fc0			;       +-------------+                                                       : 
0fc0			;       |  prev_free  |                                                       : 
0fc0			;   +4  +-------------+                                                       : 
0fc0			;       |  this_free  |                                                       : 
0fc0			;   +2  +-------------+                                                       : 
0fc0			;       |  next_free  |                                                       : 
0fc0			;   +0  +-------------+                                                       : 
0fc0			;       |             |                                                       : 
0fc0			;                                                                             : 
0fc0			;------------------------------------------------------------------------------ 
0fc0			 
0fc0			 
0fc0			;malloc: 
0fc0			; 
0fc0			;	SAVESP ON 1 
0fc0			; 
0fc0			;	call malloc_code 
0fc0			; 
0fc0			;	CHECKSP ON 1 
0fc0			;	ret 
