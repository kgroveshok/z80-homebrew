0f02			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
0f02			 
0f02			; String Length 
0f02			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
0f02			 
0f02			; Get the length of the null-terminated string starting at $8000 hl 
0f02			;    LD     HL, $8000 
0f02			 
0f02			strlenz: 
0f02			 
0f02 af			    XOR    A               ; Zero is the value we are looking for. 
0f03 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
0f04 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
0f05			                           ; 65, 536 bytes (the entire addressable memory space). 
0f05 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f07			 
0f07			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f07 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
0f08 6f			    LD     L, A             ; number of bytes 
0f09 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f0b 2b			    DEC    HL              ; Compensate for null. 
0f0c c9				ret 
0f0d			 
0f0d			; Get the length of the A terminated string starting at $8000 hl 
0f0d			;    LD     HL, $8000 
0f0d			 
0f0d			strlent: 
0f0d			 
0f0d			                  ; A is the value we are looking for. 
0f0d 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
0f0f 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
0f11			                           ; 65, 536 bytes (the entire addressable memory space). 
0f11 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f13			 
0f13			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f13 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
0f15 2e 00		    LD     L, 0             ; number of bytes 
0f17 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f19 2b			    DEC    HL              ; Compensate for null. 
0f1a c9				ret 
