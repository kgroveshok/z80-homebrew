8fb5			free:  
8fb5				push hl 
8fb5				push af 
8fb5				; get address in hl 
8fb5			 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "fre" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5				; data is at hl - move to block count 
8fb5				dec hl 
8fb5				dec hl    ; get past pointer 
8fb5				dec hl 
8fb5			 
8fb5				ld a, (hl)    ; need this for a validation check 
8fb5			 
8fb5				dec hl    ; move to block marker 
8fb5			 
8fb5				; now check that the block count and block marker are the same  
8fb5			        ; this checks that we are on a malloc node and not random memory 
8fb5			        ; OK a faint chance this could be a problem but rare - famous last words! 
8fb5			 
8fb5				ld c, a 
8fb5				ld a, (hl)    
8fb5			 
8fb5				cp c 
8fb5				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
8fb5			 
8fb5				; yes good chance we are on a malloc node 
8fb5			 
8fb5			;	ld a, 0      
8fb5				ld (hl), 0   ; mark as free 
8fb5			 
8fb5				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
8fb5			 
8fb5			.freeignore:  
8fb5			 
8fb5				pop af 
8fb5				pop hl 
8fb5			 
8fb5				ret 
8fb5			 
8fb5			 
8fb5			 
8fb5			endif 
