9140			; wait for rising edge and then count pulses until possible gap (ie no pulses detected for 5ms) 
9140			 
9140			tape_detect: 
9140 3e 00			ld a, 0 
9142 2a 49 ea			ld hl, (tape_sync)     ; high pulse count 
9145 2a 4a ea			ld hl, (tape_sync+1)   ; low pulse count 
