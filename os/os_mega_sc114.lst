8d93			 
8d93			; only care about direct match or not 
8d93			; hl and de strings 
8d93			; zero set if the same 
8d93			 
8d93			strcmp: 
8d93 1a				ld a, (de) 
8d94 be				cp (hl) 
8d95 28 02			jr z, .ssame 
8d97 b7				or a 
8d98 c9				ret 
8d99			 
