244c			; | DUP ( u -- u u )     Duplicate whatever item is on TOS | DONE 
244c			; | | >[!NOTE] 
244c			; | | > If the duplicated item is a string it is safely duplicated 
244c			 
244c				if DEBUG_FORTH_WORDS_KEY 
244c					DMARK "DUP" 
244c				if DEMARK_VERSION = 1  
244c e5					push hl  
244d 21 55 24				ld hl, .dmark  
2450 22 9b fd				ld (debug_mark), hl  
2453				endif  
2453				if DEMARK_VERSION = 0  
2453					push af  
2453					ld a, (.dmark)  
2453					ld (debug_mark),a  
2453					ld a, (.dmark+1)  
2453					ld (debug_mark+1),a  
2453					ld a, (.dmark+2)  
2453					ld (debug_mark+2),a  
2453				endif  
2453 18 04			jr .pastdmark  
2455 ..			.dmark: db "DUP"  
2458				if DEMARK_VERSION = 1  
2458 00					db 0  
2459				endif  
2459				if DEMARK_VERSION = 1  
2459 e1			.pastdmark: pop hl  
245a				endif  
245a				if DEMARK_VERSION = 0  
245a			.pastdmark: pop af  
245a				endif  
245a			endm  
