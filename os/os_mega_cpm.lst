4428						DMARK "LOD" 
4428						CALLMONITOR 
4428					endif 
4428			 
4428					NEXTW 
4428			 
4428			.TCAL: 
4428				CWHEAD .TTEST 31 "TAPECAL" 7 WORD_FLAG_CODE 
4428			; | TAPECAL (  -- )    Listen to a tape header and report on bit detection pulses | TO DO 
4428					if DEBUG_FORTH_WORDS_KEY 
4428						DMARK "TCA" 
