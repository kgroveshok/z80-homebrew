0d82 5f			    ld    e, a    ; L = A+L 
0d83 8a			    adc   a, d    ; A = A+L+H+carry 
0d84 93			    sub   e       ; A = H+carry 
0d85 57			    ld    d, a    ; H = H+carry 
0d86 c9			ret 
