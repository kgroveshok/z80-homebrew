8c2c 1a			strcpy:   LD   A, (DE)        ;Get character from string 
8c2d b7			            OR   A              ;Null terminator? 
8c2e c8			            RET  Z              ;Yes, so finished 
8c2f 1a					ld a,(de) 
8c30 77					ld (hl),a 
8c31 13			            INC  DE             ;Point to next character 
8c32 23					inc hl 
8c33 18 f7		            JR   strcpy       ;Repeat 
8c35 c9					ret 
