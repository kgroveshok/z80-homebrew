8ca2			;                ret     nc              ; Yes 
8ca2			;                cp      '0'             ; Less than '0'? 
8ca2			;                jr      nc, is_hex_1    ; No, continue 
8ca2			;                ccf                     ; Complement carry (i.e. clear it) 
8ca2			;                ret 
8ca2			;is_hex_1        cp      '9' + 1         ; Less or equal '9*? 
8ca2			;                ret     c               ; Yes 
8ca2			;                cp      'A'             ; Less than 'A'? 
8ca2			;                jr      nc, is_hex_2    ; No, continue 
8ca2			;                ccf                     ; Yes - clear carry and return 
8ca2			;                ret 
8ca2			;is_hex_2        scf                     ; Set carry 
8ca2			;                ret 
8ca2			; 
8ca2			; Convert a single character contained in A to upper case: 
8ca2			; 
8ca2 fe 61		to_upper:        cp      'a'             ; Nothing to do if not lower case 
8ca4 d8			                ret     c 
8ca5 fe 7b		                cp      'z' + 1         ; > 'z'? 
8ca7 d0			                ret     nc              ; Nothing to do, either 
8ca8 e6 5f		                and     $5f             ; Convert to upper case 
8caa c9			                ret 
