69a8			; **********************************************************************  
69a8			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
69a8			; **********************************************************************  
69a8			;  
69a8			; **  Written as a Small Computer Monitor App  
69a8			; **  www.scc.me.uk  
69a8			;  
69a8			; History  
69a8			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
69a8			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
69a8			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
69a8			;  
69a8			; **********************************************************************  
69a8			;  
69a8			; This program is an example of one of the methods of interfacing an   
69a8			; alphanumeric LCD module.   
69a8			;  
69a8			; In this example the display is connected to either a Z80 PIO or a   
69a8			; simple 8-bit output port.   
69a8			;  
69a8			; This interfacing method uses 4-bit data mode and uses time delays  
69a8			; rather than polling the display's ready status. As a result the   
69a8			; interface only requires 6 simple output lines:  
69a8			;   Output bit 0 = not used  
69a8			;   Output bit 1 = not used  
69a8			;   Output bit 2 = RS         High = data, Low = instruction  
69a8			;   Output bit 3 = E          Active high  
69a8			;   Output bit 4 = DB4  
69a8			;   Output bit 5 = DB5  
69a8			;   Output bit 6 = DB6  
69a8			;   Output bit 7 = DB7  
69a8			; Display's R/W is connected to 0v so it is always in write mode  
69a8			;  
69a8			; This set up should work with any system supporting the RC2014 bus  
69a8			  
69a8			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
69a8			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
69a8			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
69a8			;  
69a8			; **********************************************************************  
69a8			  
69a8			; Additonal for 4x40. E1 and E2 instead of just E   
69a8			; TODO swipe vidout signal on port a to activate E2  
69a8			  
69a8			; **********************************************************************  
69a8			; **  Constants  
69a8			; **********************************************************************  
69a8			; LCD constants required by LCD support module  
69a8			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
69a8			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
69a8			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
69a8			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
69a8			; TODO Decide which E is being set  
69a8			kLCDWidth:  EQU display_cols             ;Width in characters  
69a8			  
69a8			; **********************************************************************  
69a8			; **  Code library usage  
69a8			; **********************************************************************  
69a8			  
69a8			; send character to current cursor position  
69a8			; wraps and/or scrolls screen automatically  
69a8			  
69a8			  
69a8			  
69a8			lcd_init:  
69a8			  
69a8			; SCMonAPI functions used  
69a8			  
69a8			; Alphanumeric LCD functions used  
69a8			; no need to specify specific functions for this module  
69a8			  
69a8 3e cf		            LD   A, 11001111b  
69aa d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
69ac 3e 00		            LD   A, 00000000b  
69ae d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
69b0			  
69b0			; Initialise alphanumeric LCD module  
69b0 3e 00				ld a, 0  
69b2 32 fb fa				ld (display_lcde1e2), a  
69b5 cd 36 6a		            CALL fLCD_Init      ;Initialise LCD module  
69b8 3e 01				ld a, 1  
69ba 32 fb fa				ld (display_lcde1e2), a  
69bd cd 36 6a		            CALL fLCD_Init      ;Initialise LCD module  
69c0			  
69c0 c9				ret  
69c1			  
69c1			;  
69c1			;;  
69c1			; lcd functions  
69c1			;  
69c1			;  
69c1			  
69c1			; what is at cursor position   
69c1			  
69c1			;get_cursor:	ld de, (cursor_row)   ;  row + col  
69c1			;		call curptr  
69c1			;		ret  
69c1			  
69c1			  
69c1			; take current custor pos in de (d=row,e=col) and return a pointer to the frame buffer  
69c1			  
69c1			curptr:  
69c1 c5				push bc  
69c2 21 e1 fc			ld hl, display_fb0  
69c5			cpr:	  
69c5				; loop for cursor whole row  
69c5 0e 28			ld c, display_cols  
69c7 23			cpr1:	inc hl  
69c8 0d				dec c  
69c9 20 fc			jr nz, cpr1  
69cb 05				dec b  
69cc 20 f7			jr nz, cpr  
69ce			  
69ce				; add col	  
69ce			  
69ce 23			cpr2:	inc hl  
69cf 1d				dec e  
69d0 20 fc			jr nz, cpr2  
69d2			  
69d2 c1				pop bc  
69d3 c9				ret  
69d4				  
69d4			  
69d4			  
69d4			  
69d4			  
69d4			; write the frame buffer given in hl to hardware   
69d4 22 f9 fa		write_display: ld (display_write_tmp), hl 	   
69d7 3e 00			ld a, kLCD_Line1  
69d9 cd e3 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69dc 06 28			ld b, display_cols  
69de ed 5b f9 fa		ld de, (display_write_tmp)  
69e2 cd 2e 6a			call write_len_string  
69e5				  
69e5				  
69e5 2a f9 fa			ld hl, (display_write_tmp)  
69e8 11 28 00			ld de, display_cols  
69eb 19				add hl,de  
69ec 22 f9 fa			ld (display_write_tmp),hl  
69ef			  
69ef				  
69ef 3e 28			ld a, kLCD_Line2  
69f1 cd e3 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
69f4 06 28			ld b, display_cols  
69f6 ed 5b f9 fa		ld de, (display_write_tmp)  
69fa cd 2e 6a			call write_len_string  
69fd				  
69fd 2a f9 fa			ld hl, (display_write_tmp)  
6a00 11 28 00			ld de, display_cols  
6a03 19				add hl,de  
6a04 22 f9 fa			ld (display_write_tmp),hl  
6a07			  
6a07				  
6a07 3e 50			ld a, kLCD_Line3  
6a09 cd e3 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
6a0c 06 28			ld b, display_cols  
6a0e ed 5b f9 fa		ld de, (display_write_tmp)  
6a12 cd 2e 6a			call write_len_string  
6a15				  
6a15 2a f9 fa			ld hl, (display_write_tmp)  
6a18 11 28 00			ld de, display_cols  
6a1b 19				add hl,de  
6a1c 22 f9 fa			ld (display_write_tmp),hl  
6a1f			  
6a1f				  
6a1f 3e 78			ld a, kLCD_Line4  
6a21 cd e3 6a		            CALL fLCD_Pos       ;Position cursor to location in A  
6a24 06 28			ld b, display_cols  
6a26 ed 5b f9 fa		ld de, (display_write_tmp)  
6a2a cd 2e 6a			call write_len_string  
6a2d c9					ret  
6a2e				  
6a2e				; write out a fixed length string given in b from de  
6a2e			  
6a2e 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
6a2f cd 9b 6a		            CALL fLCD_Data      ;Write character to display  
6a32 13				inc de  
6a33 10 f9			djnz write_len_string  
