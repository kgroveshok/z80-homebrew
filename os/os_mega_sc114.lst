8a49			subafromhl: 
8a49			   ; If A=0 do nothing 
8a49			    ; Otherwise flip A's sign. Since 
8a49			    ; the upper byte becomes -1, also 
8a49			    ; substract 1 from H. 
8a49 ed 44		    neg 
8a4b ca 54 8a		    jp    z, Skip 
8a4e 25			    dec   h 
8a4f			     
8a4f			    ; Now add the low byte as usual 
8a4f			    ; Two's complement takes care of 
8a4f			    ; ensuring the result is correct 
8a4f 85			    add   a, l 
8a50 6f			    ld    l, a 
8a51 8c			    adc   a, h 
8a52 95			    sub   l 
8a53 67			    ld    h, a 
8a54			Skip: 
8a54 c9				ret 
