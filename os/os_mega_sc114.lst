9e0c 00					db 0  
9e0d				endif  
9e0d				if DEMARK_VERSION = 1  
9e0d e1			.pastdmark: pop hl  
9e0e				endif  
9e0e				if DEMARK_VERSION = 0  
9e0e			.pastdmark: pop af  
9e0e				endif  
9e0e			endm  
