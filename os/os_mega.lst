22c0			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
22c0			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
22c0			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
22c0			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
22c0			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
22c0			WORD_SYS_END: equ 0   ; Opcode for all user words 
22c0			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
22c0			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
22c0			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
22c0			 
22c0			; Core word preamble macro 
22c0			 
22c0			CWHEAD:   macro nxtword opcode lit len opflags 
22c0				db WORD_SYS_CORE+opcode             
