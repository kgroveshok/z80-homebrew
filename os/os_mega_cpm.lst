0ee3			 
0ee3			;Converts an ASCII string to an unsigned 16-bit integer 
0ee3			;Quits when it reaches a non-decimal digit 
0ee3			 
0ee3			string_to_uint16: 
0ee3			atoui_16: 
0ee3			;Input: 
0ee3			;     DE points to the string 
0ee3			;Outputs: 
0ee3			;     HL is the result 
0ee3			;     A is the 8-bit value of the number 
0ee3			;     DE points to the byte after the number 
0ee3			;Destroys: 
0ee3			;     BC 
0ee3			;       if the string is non-empty, BC is HL/10 
0ee3			;Size:  24 bytes 
0ee3			;Speed: 42+d(104+{0,9}) 
0ee3			;       d is the number of digits in the number 
0ee3			;       max is 640 cycles for a 5 digit number 
0ee3			;Assuming no leading zeros: 
0ee3			;1 digit:  146cc 
0ee3			;2 digit:  250cc 
0ee3			;3 digit:  354cc or 363cc (avg: 354.126cc) 
0ee3			;4 digit:  458cc or 467cc (avg: 458.27cc) 
0ee3			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
0ee3			;avg: 544.81158447265625cc (544+13297/16384) 
0ee3			;=============================================================== 
0ee3 21 00 00		  ld hl,0 
0ee6			.u16a: 
0ee6 1a			  ld a,(de) 
0ee7 d6 30		  sub 30h 
0ee9 fe 0a		  cp 10 
0eeb d0			  ret nc 
0eec 13			  inc de 
0eed 44			  ld b,h 
0eee 4d			  ld c,l 
0eef 29			  add hl,hl 
0ef0 29			  add hl,hl 
0ef1 09			  add hl,bc 
0ef2 29			  add hl,hl 
0ef3 85			  add a,l 
0ef4 6f			  ld l,a 
0ef5 30 ef		  jr nc,.u16a 
0ef7 24			  inc h 
0ef8 c3 e6 0e		  jp .u16a 
