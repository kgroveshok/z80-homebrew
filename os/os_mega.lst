12e0			 
12e0			 
12e0			.foundemptyblock:	 
12e0					if DEBUG_FORTH_MALLOC_INT 
12e0						DMARK "mme" 
12e0						CALLMONITOR 
12e0					endif 
12e0			 
12e0			; TODO has block enough space if reusing??? 
12e0			 
12e0				;  
12e0			 
