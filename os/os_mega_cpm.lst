250c			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
250c			; | | At start the current various registers will be displayed with contents. 
250c			; | | Top right corner will show the most recent debug marker seen. 
250c			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
250c			; | | and the return stack pointer (RSP). 
250c			; | | Pressing: 
250c			; | |  
250c			; | |    1 - Initial screen 
250c			; | |  
250c			; | |    2 - Display a data dump of HL 
250c			; | |  
250c			; | |    3 - Display a data dump of DE 
250c			; | |  
250c			; | |    4 - Display a data dump of BC 
250c			; | |  
250c			; | |    5 - Display a data dump of HL 
250c			; | |  
250c			; | |    6 - Display a data dump of DSP 
250c			; | |  
250c			; | |    7 - Display a data dump of RSP 
250c			; | |  
250c			; | |    8 - Display a data dump of what is at DSP 
250c			; | |  
250c			; | |    9 - Display a data dump of what is at RSP 
250c			; | |  
250c			; | |    0 - Exit monitor and continue running. This will also enable break points 
250c			; | |  
250c			; | |    * - Disable break points 
250c			; | |  
250c			; | |    # - Enter traditional monitor mode 
250c			; | |  
250c			; | | 
250c			; | | Monitor Mode 
250c			; | | ------------ 
250c			; | | A prompt of '>' will be shown for various commands: 
250c			; | |  
250c			; | |    D xxxx - Display a data dump starting from hex address xxxx 
250c			; | |  
250c			; | |    C - Continue display a data dump from the last set address 
250c			; | |  
250c			; | |    M xxxx - Set start of memory edit at address xx 
250c			; | |  
250c			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
250c			; | |  
250c			; | |    G xxxx - Exec code at specific address 
250c			; | |  
250c			; | |    Q - Return to previous 
250c				if DEBUG_FORTH_WORDS_KEY 
250c					DMARK "MON" 
250c				if DEMARK_VERSION = 1  
250c e5					push hl  
250d 21 15 25				ld hl, .dmark  
2510 22 60 ee				ld (debug_mark), hl  
2513				endif  
2513				if DEMARK_VERSION = 0  
2513					push af  
2513					ld a, (.dmark)  
2513					ld (debug_mark),a  
2513					ld a, (.dmark+1)  
2513					ld (debug_mark+1),a  
2513					ld a, (.dmark+2)  
2513					ld (debug_mark+2),a  
2513				endif  
2513 18 04			jr .pastdmark  
2515 ..			.dmark: db "MON"  
2518				if DEMARK_VERSION = 1  
2518 00					db 0  
2519				endif  
2519				if DEMARK_VERSION = 1  
2519 e1			.pastdmark: pop hl  
251a				endif  
251a				if DEMARK_VERSION = 0  
251a			.pastdmark: pop af  
251a				endif  
251a			endm  
# End of macro DMARK
251a					CALLMONITOR 
251a				if BASE_CPM=1  
251a cd 6b ee				call debug_vector  
251d				endif  
251d				if BASE_KEV=1  
251d					rst 8  
251d				endif  
251d				endm  
# End of macro CALLMONITOR
251d				endif 
251d			;		ld a, 0 
