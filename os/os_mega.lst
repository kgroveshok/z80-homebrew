20fd			 
20fd			 
20fd			FORTH_CHK_DSP_UNDER: macro 
20fd				push hl 
20fd				push de 
20fd				ld hl,(cli_data_sp) 
20fd				ld de, cli_data_stack 
20fd				call cmp16 
20fd				jp c, fault_dsp_under 
20fd				pop de 
20fd				pop hl 
20fd				endm 
20fd			 
20fd			 
20fd			FORTH_CHK_RSP_UNDER: macro 
20fd				push hl 
20fd				push de 
20fd				ld hl,(cli_ret_sp) 
20fd				ld de, cli_ret_stack 
20fd				call cmp16 
20fd				jp c, fault_rsp_under 
20fd				pop de 
20fd				pop hl 
20fd				endm 
20fd			 
20fd			FORTH_CHK_LOOP_UNDER: macro 
20fd				push hl 
20fd				push de 
20fd				ld hl,(cli_loop_sp) 
20fd				ld de, cli_loop_stack 
20fd				call cmp16 
20fd				jp c, fault_loop_under 
20fd				pop de 
20fd				pop hl 
20fd				endm 
20fd			 
20fd			FORTH_ERR_TOS_NOTSTR: macro 
20fd				; TOSO might need more for checks when used 
20fd				push af 
20fd				ld a,(hl) 
20fd				cp DS_TYPE_STR 
20fd				jp nz, type_faultn   
20fd				pop af 
20fd				endm 
20fd			 
20fd			FORTH_ERR_TOS_NOTNUM: macro 
20fd				push af 
20fd				ld a,(hl) 
20fd				cp DS_TYPE_INUM 
20fd				jp nz, type_faultn   
20fd				pop af 
20fd				endm 
20fd			 
20fd			 
20fd			; increase data stack pointer and save hl to it 
