8dc7			;	endif 
8dc7			;.z1: 
8dc7			; 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "ZZ1" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			; 
8dc7			;ld de, .str1 
8dc7			;ld hl, .str1 
8dc7			;call strcmp 
8dc7			;jr z, .z2 
8dc7			;;this 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "NZ2" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			;.z2: 
8dc7			; 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "ZZ2" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			; 
8dc7			;ld de, .str1 
8dc7			;ld hl, .str2 
8dc7			;call strcmp 
8dc7			;jr c, .c1 
8dc7			; 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "Nc1" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			;.c1: 
8dc7			;;this 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "cc1" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			; 
8dc7			;ld de, .str1 
8dc7			;ld hl, .str1 
8dc7			;call strcmp 
8dc7			;jr c, .c2 
8dc7			;;this 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "Nc2" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			;.c2: 
8dc7			; 
8dc7			;	if DEBUG_FORTH_WORDS 
8dc7			;		DMARK "cc2" 
8dc7			;		CALLMONITOR 
8dc7			;	endif 
8dc7			;	NEXTW 
8dc7			;.str1:   db "string1",0 
8dc7			;.str2:   db "string2",0 
8dc7			 
8dc7			; only care about direct match or not 
8dc7			; hl and de strings 
8dc7			; zero set if the same 
8dc7			 
8dc7			strcmp: 
8dc7 1a				ld a, (de) 
8dc8 be				cp (hl) 
8dc9 28 02			jr z, .ssame 
8dcb b7				or a 
8dcc c9				ret 
8dcd			 
8dcd			.ssame:  
8dcd			;	cp 0 
8dcd b7				or a 
8dce c8				ret z 
8dcf			 
8dcf 23				inc hl 
8dd0 13				inc de 
8dd1 18 f4			jr strcmp 
