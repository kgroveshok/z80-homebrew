66d9			 
66d9			include "forth_startup.asm" 
66d9			; Which startup method to use? 
66d9			; 
66d9			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
66d9			; followed by loading of a list of scripts in eeprom 
66d9			 
66d9			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
66d9			; from eeprom 
66d9			 
66d9			; Select with define in main stubs 
66d9			 
66d9			if STARTUP_V1 
66d9				include "forth_startupv1.asm" 
66d9			endif 
66d9			if STARTUP_V2 
66d9				include "forth_startupv2.asm" 
66d9			; Version 2 of the startup  
66d9			;  
66d9			; Auto load any files in bank 1 that start with a '*' 
66d9			; If no se storage then revert to using eprom 
66d9			 
66d9			 
66d9			if STORAGE_SE = 0 
66d9			 
66d9			sprompt1: db "Startup load...",0 
66d9			sprompt2: db "Run? 1=No *=End #=All",0 
66d9			 
66d9			 
66d9			 
66d9			 
66d9			forth_startup: 
66d9				ld hl, startcmds 
66d9				ld a, 0 
66d9				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
66d9			 
66d9			.start1:	push hl 
66d9				call clear_display 
66d9				ld de, sprompt1 
66d9			        ld a, display_row_1 
66d9				call str_at_display 
66d9				ld de, sprompt2 
66d9			        ld a, display_row_2 
66d9				call str_at_display 
66d9				pop hl 
66d9				push hl 
66d9				ld e,(hl) 
66d9				inc hl 
66d9				ld d,(hl) 
66d9			        ld a, display_row_3 
66d9				call str_at_display 
66d9				call update_display 
66d9			 
66d9			 
66d9				ld a, (os_last_cmd) 
66d9			;	cp 0 
66d9				or a 
66d9				jr z, .startprompt 
66d9				call delay250ms 
66d9				jr .startdo 
66d9				 
66d9				 
66d9			 
66d9			.startprompt: 
66d9			 
66d9				ld a,display_row_4 + display_cols - 1 
66d9			        ld de, endprg 
66d9				call str_at_display 
66d9				call update_display 
66d9				call delay1s 
66d9				call cin_wait 
66d9						 
66d9				cp '*' 
66d9				jr z, .startupend1 
66d9				cp '#' 
66d9				jr nz, .startno 
66d9				ld a, 1 
66d9				ld (os_last_cmd),a 
66d9				jr .startdo 
66d9			.startno:	cp '1' 
66d9				jr z,.startnxt  
66d9			 
66d9				; exec startup line 
66d9			.startdo:	 
66d9				pop hl 
66d9				push hl 
66d9				 
66d9				ld e,(hl) 
66d9				inc hl 
66d9				ld d,(hl) 
66d9				ex de,hl 
66d9			 
66d9				push hl 
66d9			 
66d9				ld a, 0 
66d9				;ld a, FORTH_END_BUFFER 
66d9				call strlent 
66d9				inc hl   ; include zero term to copy 
66d9				ld b,0 
66d9				ld c,l 
66d9				pop hl 
66d9				ld de, scratch 
66d9				ldir 
66d9			 
66d9			 
66d9				ld hl, scratch 
66d9				call forthparse 
66d9				call forthexec 
66d9				call forthexec_cleanup 
66d9			 
66d9				ld a, display_row_4 
66d9				ld de, endprog 
66d9			 
66d9				call update_display		 
66d9			 
66d9				ld a, (os_last_cmd) 
66d9			;	cp 0 
66d9				or a 
66d9				jr nz, .startnxt 
66d9				call next_page_prompt 
66d9			        call clear_display 
66d9				call update_display		 
66d9			 
66d9				; move onto next startup line? 
66d9			.startnxt: 
66d9			 
66d9				call delay250ms 
66d9				pop hl 
66d9			 
66d9				inc hl 
66d9				inc hl 
66d9			 
66d9				push hl 
66d9				ld e, (hl) 
66d9				inc hl 
66d9				ld d, (hl) 
66d9				pop hl 
66d9				; TODO replace 0 test 
66d9			 
66d9				ex de, hl 
66d9				call ishlzero 
66d9			;	ld a,e 
66d9			;	add d 
66d9			;	cp 0    ; any left to do? 
66d9				ex de, hl 
66d9				jp nz, .start1 
66d9				jr .startupend 
66d9			 
66d9			.startupend1: pop hl 
66d9			.startupend: 
66d9			 
66d9				call clear_display 
66d9				call update_display 
66d9				ret 
66d9			endif 
