23f9			.NEW: 
23f9			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
23f9 15				db WORD_SYS_CORE+OPCODE_HEAP             
23fa 13 24			dw .HEAP            
23fc 04				db 3 + 1 
23fd .. 00			db "NEW",0              
2401				endm 
# End of macro CWHEAD
2401			; | NEW ( -- ) Clears all user words and stack | DONE 
2401				 
2401				if MALLOC_4 
2401					call  heap_init 
2401				endif 
2401				; reset uword pointers 
2401 21 00 80			ld hl, baseram 
2404 22 dd f3			ld (os_last_new_uword), hl 
2407 cd 4d 22			call user_word_eol 
240a				; clear stack 
240a cd 66 22			call forth_warmstart 
240d				NEXTW 
240d cd a3 fd			call parse_vector 
2410 c3 c0 22			jp macro_next 
2413				endm 
# End of macro NEXTW
2413			 
2413			.HEAP: 
2413			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
2413 15				db WORD_SYS_CORE+OPCODE_HEAP             
2414 44 24			dw .EXEC            
2416 05				db 4 + 1 
2417 .. 00			db "HEAP",0              
241c				endm 
# End of macro CWHEAD
241c			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
241c			; | | u1 - Current number of bytes in the heap 
241c			; | | u2 - Remaining bytes left on the heap 
241c			; | |  
241c			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
241c			 
241c			 
241c				if DEBUG_FORTH_WORDS_KEY 
241c					DMARK "HEP" 
241c				if DEMARK_VERSION = 1  
241c e5					push hl  
241d 21 25 24				ld hl, .dmark  
2420 22 9b fd				ld (debug_mark), hl  
2423				endif  
2423				if DEMARK_VERSION = 0  
2423					push af  
2423					ld a, (.dmark)  
2423					ld (debug_mark),a  
2423					ld a, (.dmark+1)  
2423					ld (debug_mark+1),a  
2423					ld a, (.dmark+2)  
2423					ld (debug_mark+2),a  
2423				endif  
2423 18 04			jr .pastdmark  
2425 ..			.dmark: db "HEP"  
2428				if DEMARK_VERSION = 1  
2428 00					db 0  
2429				endif  
2429				if DEMARK_VERSION = 1  
2429 e1			.pastdmark: pop hl  
242a				endif  
242a				if DEMARK_VERSION = 0  
242a			.pastdmark: pop af  
242a				endif  
242a			endm  
# End of macro DMARK
242a					CALLMONITOR 
242a				if BASE_CPM=1  
242a					call debug_vector  
242a				endif  
242a				if BASE_KEV=1  
242a cf					rst 8  
242b				endif  
242b				endm  
# End of macro CALLMONITOR
242b				endif 
242b 2a 0a 80			ld hl, (free_list )      
242e 11 0e 80			ld de, heap_start 
