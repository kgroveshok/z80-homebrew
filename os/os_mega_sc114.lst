8978			; 
8978			 
8978			; 16-bit xorshift pseudorandom number generator by John Metcalf 
8978			; 20 bytes, 86 cycles (excluding ret) 
8978			 
8978			; returns   hl = pseudorandom number 
8978			; corrupts   a 
8978			 
8978			; generates 16-bit pseudorandom numbers with a period of 65535 
8978			; using the xorshift method: 
8978			 
8978			; hl ^= hl << 7 
8978			; hl ^= hl >> 9 
8978			; hl ^= hl << 8 
8978			 
8978			; some alternative shift triplets which also perform well are: 
8978			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
8978			 
8978			;  org 32768 
8978			 
8978			xrnd: 
8978 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
897b 3e 00		  ld a,0 
897d bd			  cp l 
897e 20 02		  jr nz, .xrnd1 
8980 2e 01		  ld l, 1 
8982			.xrnd1: 
8982			 
8982 7c			  ld a,h 
8983 1f			  rra 
8984 7d			  ld a,l 
8985 1f			  rra 
8986 ac			  xor h 
8987 67			  ld h,a 
8988 7d			  ld a,l 
8989 1f			  rra 
898a 7c			  ld a,h 
898b 1f			  rra 
898c ad			  xor l 
898d 6f			  ld l,a 
898e ac			  xor h 
898f 67			  ld h,a 
8990			 
8990 22 9e eb		  ld (xrandc),hl 
8993			 
8993 c9			  ret 
