7702			; **********************************************************************  
7702			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
7702			; **********************************************************************  
7702			;  
7702			; **  Written as a Small Computer Monitor App   
7702			; **  Version 0.1 SCC 2018-05-16  
7702			; **  www.scc.me.uk  
7702			;  
7702			; **********************************************************************  
7702			;  
7702			; This module provides support for alphanumeric LCD modules using with  
7702			; *  HD44780 (or compatible) controller  
7702			; *  5 x 7 pixel fonts  
7702			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
7702			; *  Interface via six digital outputs to the display (see below)  
7702			;  
7702			; LCD module pinout:  
7702			;   1  Vss   0v supply  
7702			;   2  Vdd   5v supply  
7702			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
7702			;   4  RS    High = data, Low = instruction  
7702			;   5  R/W   High = Read, Low = Write  
7702			;   6  E     Enable signal (active high)  
7702			;   7  DB0   Data bit 0  
7702			;   8  DB1   Data bit 1  
7702			;   9  DB2   Data bit 2  
7702			;  10  DB3   Data bit 3  
7702			;  11  DB4   Data bit 4  
7702			;  12  DB5   Data bit 5  
7702			;  13  DB6   Data bit 6  
7702			;  14  DB7   Data bit 7  
7702			;  15  A     Backlight anode (+)  
7702			;  16  K     Backlight cathode (-)  
7702			;  
7702			; This interfacing method uses 4-bit data mode and uses time delays  
7702			; rather than polling the display's ready status. As a result the   
7702			; interface only requires 6 simple output lines:  
7702			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
7702			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
7702			;   LCD DB4 = Microcomputer output port bit 4  
7702			;   LCD DB5 = Microcomputer output port bit 5  
7702			;   LCD DB6 = Microcomputer output port bit 6  
7702			;   LCD DB7 = Microcomputer output port bit 7  
7702			; Display's R/W is connected to 0v so it is always in write mode  
7702			; All 6 connections must be on the same port address <kLCDPrt>  
7702			; This method also allows a decent length of cable from micro to LCD  
7702			;  
7702			; **********************************************************************  
7702			;  
7702			; To include the code for any given function provided by this module,   
7702			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
7702			; the parent source file.  
7702			; For example:  #REQUIRES   uHexPrefix  
7702			;  
7702			; Also #INCLUDE this file at some point after the #REQUIRES statements  
7702			; in the parent source file.  
7702			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
7702			;  
7702			; These are the function names provided by this module:  
7702			; fLCD_Init                     ;Initialise LCD  
7702			; fLCD_Inst                     ;Send instruction to LCD  
7702			; fLCD_Data                     ;Send data byte to LCD  
7702			; fLCD_Pos                      ;Position cursor  
7702			; fLCD_Str                      ;Display string  
7702			; fLCD_Def                      ;Define custom character  
7702			;  
7702			; **********************************************************************  
7702			;  
7702			; Requires SCMonAPI.asm to also be included in the project  
7702			;  
7702			  
7702			  
7702			; **********************************************************************  
7702			; **  Constants  
7702			; **********************************************************************  
7702			  
7702			; Constants that must be defined externally  
7702			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
7702			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
7702			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
7702			;kLCDWidth: EQU 20             ;Width in characters  
7702			  
7702			; general line offsets in any frame buffer  
7702			  
7702			  
7702			display_row_1: equ 0  
7702			display_row_2: equ display_row_1+display_cols  
7702			display_row_3: equ display_row_2 + display_cols  
7702			display_row_4: equ display_row_3 + display_cols  
7702			;display_row_4_eol:   
7702			  
7702			  
7702			; Cursor position values for the start of each line  
7702			  
7702			; E  
7702			kLCD_Line1: EQU 0x00   
7702			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
7702			; E1  
7702			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
7702			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
7702			  
7702			; Instructions to send as A register to fLCD_Inst  
7702			kLCD_Clear: EQU 00000001b     ;LCD clear  
7702			kLCD_Off:   EQU 00001000b     ;LCD off  
7702			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
7702			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
7702			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
7702			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
7702			  
7702			; Constants used by this code module  
7702			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
7702			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
7702			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
7702			  
7702			  
7702			  
7702			; **********************************************************************  
7702			; **  LCD support functions  
7702			; **********************************************************************  
7702			  
7702			; Initialise alphanumeric LCD module  
7702			; LCD control register codes:  
7702			;   DL   0 = 4-bit mode        1 = 8-bit mode  
7702			;   N    0 = 1-line mode       1 = 2-line mode  
7702			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
7702			;   D    0 = Display off       1 = Display on  
7702			;   C    0 = Cursor off        1 = Cursor on  
7702			;   B    0 = Blinking off      1 = Blinking on  
7702			;   ID   0 = Decrement mode    1 = Increment mode  
7702			;   SH   0 = Entire shift off  1 = Entire shift on  
7702 3e 28		fLCD_Init:  LD   A, 40  
7704 cd 29 78		            CALL LCDDelay       ;Delay 40ms after power up  
7707			; For reliable reset set 8-bit mode - 3 times  
7707 cd f9 77		            CALL WrFn8bit       ;Function = 8-bit mode  
770a cd f9 77		            CALL WrFn8bit       ;Function = 8-bit mode  
770d cd f9 77		            CALL WrFn8bit       ;Function = 8-bit mode  
7710			; Set 4-bit mode  
7710 cd f5 77		            CALL WrFn4bit       ;Function = 4-bit mode  
7713 cd 27 78		            CALL LCDDelay1      ;Delay 37 us or more  
7716			; Function set  
7716 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
7718 cd 2b 77		            CALL fLCD_Inst      ;2 line, display on  
771b			; Display On/Off control  
771b 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
771d cd 2b 77		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
7720			; Display Clear  
7720 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
7722 cd 2b 77		            CALL fLCD_Inst      ;Clear display  
7725			; Entry mode  
7725 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
7727 cd 2b 77		            CALL fLCD_Inst      ;Increment mode, shift off  
772a			; Display module now initialised  
772a c9			            RET  
772b			; ok to here  
772b			  
772b			; Write instruction to LCD  
772b			;   On entry: A = Instruction byte to be written  
772b			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
772b f5			fLCD_Inst:  PUSH AF  
772c f5			            PUSH AF  
772d cd 3f 77		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
7730 f1			            POP  AF  
7731 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
7732 17			            RLA  
7733 17			            RLA  
7734 17			            RLA  
7735 cd 3f 77		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
7738 3e 02		            LD   A, 2  
773a cd 29 78		            CALL LCDDelay       ;Delay 2 ms to complete   
773d f1			            POP  AF  
773e c9			            RET  
773f			Wr4bits:   
773f f5					push af  
7740 3a f9 fa				ld a, (display_lcde1e2)  
7743 fe 00				cp 0     ; e  
7745 20 10				jr nz, .wea2	  
7747 f1					pop af  
7748 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
774a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
774c cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
774e cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
7750 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7752 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
7754 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7756 c9			            RET  
7757 f1			.wea2:		pop af  
7758 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
775a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
775c cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
775e cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
7760 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7762 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
7764 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7766 c9			            RET  
7767			  
7767			  
7767			; Write data to LCD  
7767			;   On entry: A = Data byte to be written  
7767			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7767 f5			fLCD_Data:  PUSH AF  
7768 f5			            PUSH AF  
7769 cd 7b 77		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
776c f1			            POP  AF  
776d 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
776e 17			            RLA  
776f 17			            RLA  
7770 17			            RLA  
7771 cd 7b 77		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
7774 3e 96		            LD   A, 150  
7776 3d			Wait:      DEC  A              ;Wait a while to allow data   
7777 20 fd		            JR   NZ, Wait      ;  write to complete  
7779 f1			            POP  AF  
777a c9			            RET  
777b			Wr4bitsa:     
777b f5					push af  
777c 3a f9 fa				ld a, (display_lcde1e2)  
777f fe 00				cp 0     ; e1  
7781 20 16				jr nz, .we2	  
7783 f1					pop af  
7784 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7786 cb d7		            SET  kLCDBitRS, A  
7788 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
778a cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
778c cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
778e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
7790 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
7792 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
7794 cb 97		            RES  kLCDBitRS, A  
7796 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7798 c9			            RET  
7799 f1			.we2:		pop af  
779a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
779c cb d7		            SET  kLCDBitRS, A  
779e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
77a0 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
77a2 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
77a4 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
77a6 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
77a8 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
77aa cb 97		            RES  kLCDBitRS, A  
77ac d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
77ae c9			            RET  
77af			  
77af			  
77af			; Position cursor to specified location  
77af			;   On entry: A = Cursor position  
77af			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
77af f5			fLCD_Pos:   PUSH AF  
77b0					; at this point set the E1 or E2 flag depending on position  
77b0			  
77b0 c5					push bc  
77b1			;		push af  
77b1 06 00				ld b, 0  
77b3 4f					ld c, a  
77b4 3e 4f				ld a, kLCD_Line3-1  
77b6 b7			 		or a      ;clear carry flag  
77b7 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
77b8 38 04				jr c, .pe1  
77ba			  
77ba					; E selection  
77ba cb 80				res 0, b         ; bit 0 unset e  
77bc			;		pop af    ; before line 3 so recover orig pos  
77bc			;		ld c, a    ; save for poking back  
77bc 18 06				jr .peset	          
77be			.pe1:          	; E2 selection  
77be cb c0				set 0, b         ; bit 0 set e1  
77c0 79					ld a, c  
77c1 de 4f				sbc a, kLCD_Line3-1  
77c3 4f					ld c, a	         ; save caculated offset  
77c4			;		pop af     ; bin this original value now we have calculated form  
77c4			  
77c4			.peset:		; set bit  
77c4 78					ld a, b  
77c5 32 f9 fa				ld (display_lcde1e2), a 	  
77c8 79					ld a, c  
77c9 c1					pop bc  
77ca			  
77ca f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
77cc cd 2b 77		            CALL fLCD_Inst      ;Write instruction to LCD  
77cf f1			            POP  AF  
77d0 c9			            RET  
77d1			  
77d1			  
77d1			; Output text string to LCD  
77d1			;   On entry: DE = Pointer to null terminated text string  
77d1			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
77d1 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
77d2 b7			            OR   A              ;Null terminator?  
77d3 c8			            RET  Z              ;Yes, so finished  
77d4 cd 67 77		            CALL fLCD_Data      ;Write character to display  
77d7 13			            INC  DE             ;Point to next character  
77d8 18 f7		            JR   fLCD_Str       ;Repeat  
77da c9					ret  
77db			  
77db			; Define custom character  
77db			;   On entry: A = Character number (0 to 7)  
77db			;             DE = Pointer to character bitmap data  
77db			;   On exit:  A = Next character number  
77db			;             DE = Next location following bitmap  
77db			;             BC HL IX IY I AF' BC' DE' HL' preserved  
77db			; Character is   
77db c5			fLCD_Def:   PUSH BC  
77dc f5			            PUSH AF  
77dd 07			            RLCA                ;Calculate location  
77de 07			            RLCA                ;  for bitmap data  
77df 07			            RLCA                ;  = 8 x CharacterNumber  
77e0 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
77e2 cd 2b 77		            CALL fLCD_Inst      ;Write instruction to LCD  
77e5 06 00		            LD   B, 0  
77e7 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
77e8 cd 67 77		            CALL fLCD_Data      ;Write byte to display  
77eb 13			            INC  DE             ;Point to next byte  
77ec 04			            INC  B              ;Count bytes  
77ed cb 58		            BIT  3, B           ;Finish all 8 bytes?  
77ef 28 f6		            JR   Z, Loop       ;No, so repeat  
77f1 f1			            POP  AF  
77f2 3c			            INC  A              ;Increment character number  
77f3 c1			            POP  BC  
77f4 c9			            RET  
77f5			  
77f5			  
77f5			; **********************************************************************  
77f5			; **  Private functions  
77f5			; **********************************************************************  
77f5			  
77f5			; Write function to LCD  
77f5			;   On entry: A = Function byte to be written  
77f5			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
77f5 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
77f7 18 02		            JR   WrFunc  
77f9 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
77fb f5			WrFunc:     PUSH AF  
77fc f5					push af  
77fd 3a f9 fa				ld a, (display_lcde1e2)  
7800 fe 00				cp 0     ; e1  
7802 20 0f				jr nz, .wfea2	  
