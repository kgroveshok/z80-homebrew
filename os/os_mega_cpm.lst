4479			 
4479			.SESEL: 
4479				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
4479			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
4479			; | | Zero is disabled storage. 
4479					if DEBUG_FORTH_WORDS_KEY 
4479						DMARK "BN?" 
4479						CALLMONITOR 
4479					endif 
4479					ld a, (spi_device_id) 
4479					sub '0' 
4479					ld h, 0 
4479					ld l, a 
4479					FORTH_PUSH_VALUEHL 
4479					;call forth_push_numhl 
4479					NEXTW 
4479			.SESELS: 
4479				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
4479			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
4479			; | | Set to zero to disable storage. 
4479					if DEBUG_FORTH_WORDS_KEY 
4479						DMARK "BNK" 
4479						CALLMONITOR 
4479					endif 
4479			 
4479					ld a, 255 
4479					ld (spi_cartdev), a 
4479			 
4479					; get bank 
4479			 
4479					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4479			 
4479			;		push hl 
4479			 
4479					; destroy value TOS 
4479			 
4479					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4479			 
4479					; one value on hl get other one back 
4479			 
4479			;		pop hl 
4479			 
4479			 
4479					ld c, SPI_CE_HIGH 
4479					ld b, '0'    ; human readable bank number 
4479			 
4479					ld a, l 
4479			 
4479					if DEBUG_FORTH_WORDS 
4479						DMARK "BNK" 
4479						CALLMONITOR 
4479					endif 
4479			 
4479					; active low 
4479			 
4479			;		cp 0 
4479					or a 
4479					jr z, .bset 
4479					cp 1 
4479					jr nz, .b2 
4479					res 0, c 
4479					ld b, '1'    ; human readable bank number 
4479			.b2:		cp 2 
4479					jr nz, .b3 
4479					res 1, c 
4479					ld b, '2'    ; human readable bank number 
4479			.b3:		cp 3 
4479					jr nz, .b4 
4479					res 2, c 
4479					ld b, '3'    ; human readable bank number 
4479			.b4:		cp 4 
4479					jr nz, .b5 
4479					res 3, c 
4479					ld b, '4'    ; human readable bank number 
4479			.b5:		cp 5 
4479					jr nz, .bset 
4479					res 4, c 
4479					ld b, '5'    ; human readable bank number 
4479			 
4479			.bset: 
4479					ld a, c 
4479					ld (spi_device),a 
4479					ld a, b 
4479					ld (spi_device_id),a 
4479					if DEBUG_FORTH_WORDS 
4479						DMARK "BN2" 
4479						CALLMONITOR 
4479					endif 
4479			 
4479					; set default SPI clk pulse time as disabled for BANK use 
4479			 
4479					ld a, 0 
4479					ld (spi_clktime), a 
4479			 
4479					NEXTW 
4479			 
4479			.CARTDEV: 
4479				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
4479			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
4479			; | | Set to zero to disable devices. 
4479					if DEBUG_FORTH_WORDS_KEY 
4479						DMARK "CDV" 
4479						CALLMONITOR 
4479					endif 
4479			 
4479					; disable se storage bank selection 
4479			 
4479					ld a, SPI_CE_HIGH		; ce high 
4479					ld (spi_device), a 
4479			 
4479					; get bank 
4479			 
4479					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4479			 
4479			;		push hl 
4479			 
4479					; destroy value TOS 
4479			 
4479					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4479			 
4479					; one value on hl get other one back 
4479			 
4479			;		pop hl 
4479			 
4479					; active low 
4479			 
4479					ld c, 255 
4479			 
4479					ld a, l 
4479					if DEBUG_FORTH_WORDS 
4479						DMARK "CDV" 
4479						CALLMONITOR 
4479					endif 
4479			;		cp 0 
4479					or a 
4479					jr z, .cset 
4479					cp 1 
4479					jr nz, .c2 
4479					res 0, c 
4479			.c2:		cp 2 
4479					jr nz, .c3 
4479					res 1, c 
4479			.c3:		cp 3 
4479					jr nz, .c4 
4479					res 2, c 
4479			.c4:		cp 4 
4479					jr nz, .c5 
4479					res 3, c 
4479			.c5:		cp 5 
4479					jr nz, .c6 
4479					res 4, c 
4479			.c6:		cp 6 
4479					jr nz, .c7 
4479					res 5, c 
4479			.c7:		cp 7 
4479					jr nz, .c8 
4479					res 6, c 
4479			.c8:		cp 8 
4479					jr nz, .cset 
4479					res 7, c 
4479			.cset:		ld a, c 
4479					ld (spi_cartdev),a 
4479			 
4479					if DEBUG_FORTH_WORDS 
4479						DMARK "CD2" 
4479						CALLMONITOR 
4479					endif 
4479			 
4479					; set default SPI clk pulse time as 10ms for CARTDEV use 
4479			 
4479					ld a, $0a 
4479					ld (spi_clktime), a 
4479					NEXTW 
4479			endif 
4479			 
4479			.ENDDEVICE: 
4479			; eof 
