cad7					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cad7			 
cad7			;		push hl    ; u1  
cad7			 
cad7					; destroy value TOS 
cad7			 
cad7					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cad7			 
cad7					; one value on hl get other one back 
cad7			 
cad7			;		pop hl   ; u2 - addr 
cad7			 
cad7					; TODO Send SPI byte 
cad7			 
cad7			;		push hl 
cad7			;		call spi_ce_low 
cad7			;		pop hl 
cad7					ld a, l 
cad7					call spi_send_byte 
cad7			;		call spi_ce_high 
cad7			 
cad7					NEXTW 
cad7			 
cad7			.SPII: 
cad7				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
cad7			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
cad7					if DEBUG_FORTH_WORDS_KEY 
cad7						DMARK "SPi" 
cad7						CALLMONITOR 
cad7					endif 
cad7			 
cad7					; TODO Get SPI byte 
cad7			 
cad7					call spi_read_byte 
cad7			 
cad7					if DEBUG_FORTH_WORDS 
cad7						DMARK "Si2" 
cad7						CALLMONITOR 
cad7					endif 
cad7					ld h, 0 
cad7					ld l, a 
