bfbb			.SPIO: 
bfbb			 
bfbb			if STORAGE_SE 
bfbb				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
bfbb			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
bfbb			 
bfbb					call spi_ce_low 
bfbb			    NEXTW 
bfbb			 
bfbb			.SPICEH: 
bfbb				CWHEAD .SPIBOb 61 "SPICEH" 6 WORD_FLAG_CODE 
bfbb			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
bfbb			 
bfbb					call spi_ce_high 
bfbb			    NEXTW 
bfbb			 
bfbb			.SPIBOb: 
bfbb			 
bfbb				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
bfbb			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
bfbb			 
bfbb					if DEBUG_FORTH_WORDS_KEY 
bfbb						DMARK "SPo" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb					; get port 
bfbb			 
bfbb			 
bfbb					; get byte to send 
bfbb			 
bfbb					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfbb			 
bfbb			;		push hl    ; u1  
bfbb			 
bfbb					; destroy value TOS 
bfbb			 
bfbb					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfbb			 
bfbb					; one value on hl get other one back 
bfbb			 
bfbb			;		pop hl   ; u2 - addr 
bfbb			 
bfbb					; TODO Send SPI byte 
bfbb			 
bfbb			;		push hl 
bfbb			;		call spi_ce_low 
bfbb			;		pop hl 
bfbb					ld a, l 
bfbb					call spi_send_byte 
bfbb			;		call spi_ce_high 
bfbb			 
bfbb					NEXTW 
bfbb			 
bfbb			.SPII: 
bfbb				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bfbb			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bfbb					if DEBUG_FORTH_WORDS_KEY 
bfbb						DMARK "SPi" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			 
bfbb					; TODO Get SPI byte 
bfbb			 
bfbb					call spi_read_byte 
bfbb			 
bfbb					if DEBUG_FORTH_WORDS 
bfbb						DMARK "Si2" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb					ld h, 0 
bfbb					ld l, a 
bfbb					if DEBUG_FORTH_WORDS 
bfbb						DMARK "Si3" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb					;call forth_push_numhl 
bfbb					FORTH_PUSH_VALUEHL 
bfbb			 
bfbb					NEXTW 
bfbb			 
bfbb			 
bfbb			 
bfbb			.SESEL: 
bfbb				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bfbb			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bfbb			; | | Zero is disabled storage. 
bfbb					if DEBUG_FORTH_WORDS_KEY 
bfbb						DMARK "BN?" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb					ld a, (spi_device_id) 
bfbb					sub '0' 
bfbb					ld h, 0 
bfbb					ld l, a 
bfbb					FORTH_PUSH_VALUEHL 
bfbb					;call forth_push_numhl 
bfbb					NEXTW 
bfbb			.SESELS: 
bfbb				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bfbb			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bfbb			; | | Set to zero to disable storage. 
bfbb					if DEBUG_FORTH_WORDS_KEY 
bfbb						DMARK "BNK" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			 
bfbb					ld a, 255 
bfbb					ld (spi_cartdev), a 
bfbb			 
bfbb					; get bank 
bfbb			 
bfbb					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfbb			 
bfbb			;		push hl 
bfbb			 
bfbb					; destroy value TOS 
bfbb			 
bfbb					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfbb			 
bfbb					; one value on hl get other one back 
bfbb			 
bfbb			;		pop hl 
bfbb			 
bfbb			 
bfbb					ld c, SPI_CE_HIGH 
bfbb					ld b, '0'    ; human readable bank number 
bfbb			 
bfbb					ld a, l 
bfbb			 
bfbb					if DEBUG_FORTH_WORDS 
bfbb						DMARK "BNK" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			 
bfbb					; active low 
bfbb			 
bfbb			;		cp 0 
bfbb					or a 
bfbb					jr z, .bset 
bfbb					cp 1 
bfbb					jr nz, .b2 
bfbb					res 0, c 
bfbb					ld b, '1'    ; human readable bank number 
bfbb			.b2:		cp 2 
bfbb					jr nz, .b3 
bfbb					res 1, c 
bfbb					ld b, '2'    ; human readable bank number 
bfbb			.b3:		cp 3 
bfbb					jr nz, .b4 
bfbb					res 2, c 
bfbb					ld b, '3'    ; human readable bank number 
bfbb			.b4:		cp 4 
bfbb					jr nz, .b5 
bfbb					res 3, c 
bfbb					ld b, '4'    ; human readable bank number 
bfbb			.b5:		cp 5 
bfbb					jr nz, .bset 
bfbb					res 4, c 
bfbb					ld b, '5'    ; human readable bank number 
bfbb			 
bfbb			.bset: 
bfbb					ld a, c 
bfbb					ld (spi_device),a 
bfbb					ld a, b 
bfbb					ld (spi_device_id),a 
bfbb					if DEBUG_FORTH_WORDS 
bfbb						DMARK "BN2" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			 
bfbb					; set default SPI clk pulse time as disabled for BANK use 
bfbb			 
bfbb					ld a, 0 
bfbb					ld (spi_clktime), a 
bfbb			 
bfbb					NEXTW 
bfbb			 
bfbb			.CARTDEV: 
bfbb				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bfbb			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bfbb			; | | Set to zero to disable devices. 
bfbb					if DEBUG_FORTH_WORDS_KEY 
bfbb						DMARK "CDV" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			 
bfbb					; disable se storage bank selection 
bfbb			 
bfbb					ld a, SPI_CE_HIGH		; ce high 
bfbb					ld (spi_device), a 
bfbb			 
bfbb					; get bank 
bfbb			 
bfbb					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bfbb			 
bfbb			;		push hl 
bfbb			 
bfbb					; destroy value TOS 
bfbb			 
bfbb					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bfbb			 
bfbb					; one value on hl get other one back 
bfbb			 
bfbb			;		pop hl 
bfbb			 
bfbb					; active low 
bfbb			 
bfbb					ld c, 255 
bfbb			 
bfbb					ld a, l 
bfbb					if DEBUG_FORTH_WORDS 
bfbb						DMARK "CDV" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			;		cp 0 
bfbb					or a 
bfbb					jr z, .cset 
bfbb					cp 1 
bfbb					jr nz, .c2 
bfbb					res 0, c 
bfbb			.c2:		cp 2 
bfbb					jr nz, .c3 
bfbb					res 1, c 
bfbb			.c3:		cp 3 
bfbb					jr nz, .c4 
bfbb					res 2, c 
bfbb			.c4:		cp 4 
bfbb					jr nz, .c5 
bfbb					res 3, c 
bfbb			.c5:		cp 5 
bfbb					jr nz, .c6 
bfbb					res 4, c 
bfbb			.c6:		cp 6 
bfbb					jr nz, .c7 
bfbb					res 5, c 
bfbb			.c7:		cp 7 
bfbb					jr nz, .c8 
bfbb					res 6, c 
bfbb			.c8:		cp 8 
bfbb					jr nz, .cset 
bfbb					res 7, c 
bfbb			.cset:		ld a, c 
bfbb					ld (spi_cartdev),a 
bfbb			 
bfbb					if DEBUG_FORTH_WORDS 
bfbb						DMARK "CD2" 
bfbb						CALLMONITOR 
bfbb					endif 
bfbb			 
bfbb					; set default SPI clk pulse time as 10ms for CARTDEV use 
bfbb			 
bfbb					ld a, $0a 
bfbb					ld (spi_clktime), a 
bfbb					NEXTW 
bfbb			endif 
bfbb			 
bfbb			.ENDDEVICE: 
bfbb			; eof 
bfbb			 
