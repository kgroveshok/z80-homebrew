115e			 
115e			config_dir: 
115e			 
115e				; for the config menus that need to build a directory of storage call this routine 
115e				; it will construct a menu in scratch to pass to menu 
115e			 
115e				; open storage device 
115e			 
115e				; execute DIR to build a list of files and their ids into scratch in menu format 
115e				; once the menu has finished then will need to call config_fdir to release the strings 
115e				 
115e				; c = number items 
115e			 
115e				 
115e				call storage_get_block_0 
115e			 
115e				ld hl, store_page     ; get current id count 
115e				ld b, (hl) 
115e				ld c, 0    ; count of files   
115e			 
115e			 
115e				ld hl, scratch 
115e				ld (store_tmp2), hl    ; location to poke strings 
115e			 
115e				; check for empty drive 
115e			 
115e				ld a, 0 
115e				cp b 
115e				jp z, .dirdone 
115e			 
115e				 
115e					if DEBUG_FORTH_WORDS 
115e						DMARK "Cdc" 
115e						CALLMONITOR 
115e					endif 
115e			 
115e			 
115e			.diritem:	 
115e				push bc 
115e				; for each of the current ids do a search for them and if found push to stack 
115e			 
115e					ld hl, STORE_BLOCK_PHY 
115e					ld d, 0		 ; look for extent 0 of block id as this contains file name 
115e					ld e,b 
115e			 
115e					call storage_findnextid 
115e			 
115e			 
115e					; if found hl will be non zero 
115e			 
115e					call ishlzero 
115e					jr z, .dirnotfound 
115e			 
115e					; increase count 
115e			 
115e					pop bc	 
115e					inc c 
115e					push bc 
115e					 
115e			 
115e					; get file header and push the file name 
115e			 
115e					ld de, store_page 
115e					call storage_read_block 
115e			 
115e					; push file id to stack 
115e				 
115e					ld a, (store_page) 
115e					ld h, 0 
115e					ld l, a 
115e			 
115e					;call forth_push_numhl 
115e					; TODO store id 
115e			 
115e					push hl 
115e			 
115e					; push extent count to stack  
115e				 
115e					ld hl, store_page+3 
115e			 
115e					; get file name length 
115e			 
115e					call strlenz   
115e			 
115e					inc hl   ; cover zero term 
115e					inc hl  ; stick the id at the end of the area 
115e			 
115e					push hl 
115e					pop bc    ; move length to bc 
115e			 
115e					call malloc 
115e			 
115e					; TODO save malloc area to scratch 
115e			 
115e					ex de, hl 
115e					ld hl, (store_tmp2) 
115e					ld (hl), e 
115e					inc hl 
115e					ld (hl), d 
115e					inc hl 
115e					ld (store_tmp2), hl 
115e			 
115e					 
115e			 
115e					;pop hl   ; get source 
115e			;		ex de, hl    ; swap aronund	 
115e			 
115e					ld hl, store_page+3 
115e					if DEBUG_FORTH_WORDS 
115e						DMARK "CFd" 
115e						CALLMONITOR 
115e					endif 
115e					ldir 
115e			 
115e					; de is past string, move back one and store id 
115e					 
115e					dec de 
115e			 
115e					; store file id 
115e			 
115e					pop hl 
115e					ex de,hl 
115e					ld (hl), e 
115e			 
115e					if DEBUG_FORTH_WORDS 
115e						DMARK "Cdi" 
115e						CALLMONITOR 
115e					endif 
115e					 
