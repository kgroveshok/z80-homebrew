13ce			 
13ce			config_dir: 
13ce			 
13ce				; for the config menus that need to build a directory of storage call this routine 
13ce				; it will construct a menu in scratch to pass to menu 
13ce			 
13ce				; open storage device 
13ce			 
13ce				; execute DIR to build a list of files and their ids into scratch in menu format 
13ce				; once the menu has finished then will need to call config_fdir to release the strings 
13ce				 
13ce				; c = number items 
13ce			 
13ce				 
13ce				call storage_get_block_0 
13ce			 
13ce				ld hl, store_page     ; get current id count 
13ce				ld b, (hl) 
13ce				ld c, 0    ; count of files   
13ce			 
13ce			 
13ce				ld hl, scratch 
13ce				ld (store_tmp2), hl    ; location to poke strings 
13ce			 
13ce				; check for empty drive 
13ce			 
13ce				ld a, 0 
13ce				cp b 
13ce				jp z, .dirdone 
13ce			 
13ce				 
13ce					if DEBUG_FORTH_WORDS 
13ce						DMARK "Cdc" 
13ce						CALLMONITOR 
13ce					endif 
13ce			 
13ce			 
13ce			.diritem:	 
13ce				push bc 
13ce				; for each of the current ids do a search for them and if found push to stack 
13ce			 
13ce					ld hl, STORE_BLOCK_PHY 
13ce					ld d, 0		 ; look for extent 0 of block id as this contains file name 
13ce					ld e,b 
13ce			 
13ce					call storage_findnextid 
13ce			 
13ce			 
13ce					; if found hl will be non zero 
13ce			 
13ce					call ishlzero 
13ce					jr z, .dirnotfound 
13ce			 
13ce					; increase count 
13ce			 
13ce					pop bc	 
13ce					inc c 
13ce					push bc 
13ce					 
13ce			 
13ce					; get file header and push the file name 
13ce			 
13ce					ld de, store_page 
13ce					call storage_read_block 
13ce			 
