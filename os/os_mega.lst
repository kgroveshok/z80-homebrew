10e9			.malloczero: db "MALLOC gives zero",0 
10e9			 
10e9			malloc_guard_zerolen: 
10e9				push hl 
10e9				push de 
10e9				push af 
10e9			 
10e9				ld de, 0 
10e9			        call cmp16 
10e9				jr nz, .lowalloz 
10e9			 
10e9				push hl 
10e9				push de 
10e9					ld hl, display_fb0 
10e9					ld (display_fb_active), hl 
10e9				call clear_display 
10e9				ld a, 0 
10e9				ld de, .malloczero 
10e9				call str_at_display 
10e9				call update_display 
10e9				call delay1s 
10e9				call delay1s 
10e9				call bp_on 
10e9			;	ld a, 0 
10e9			;	ld (os_view_disable), a 
10e9			 
10e9				pop de 
10e9				pop hl 
10e9			 
10e9				 
10e9			 
10e9				CALLMONITOR 
10e9			.lowalloz: 
10e9			 
10e9			 
10e9				pop af 
10e9				pop de 
10e9				pop hl 
10e9			ret 
10e9			 
10e9			malloc_guard_entry: 
10e9				push hl 
10e9				push de 
10e9				push af 
10e9			 
10e9			 	or a      ;clear carry flag 
10e9				push hl 
10e9				ld de, 255 
10e9				sbc hl, de 
10e9				jr c, .lowalloc 
10e9			 
10e9				push de 
10e9					ld hl, display_fb0 
10e9					ld (display_fb_active), hl 
10e9				call clear_display 
10e9				ld a, 0 
10e9				ld de, .mallocsize 
10e9				call str_at_display 
10e9				call update_display 
10e9				call delay1s 
10e9				call delay1s 
10e9			;	ld a, 0 
10e9			;	ld (os_view_disable), a 
10e9				call bp_on 
10e9			 
10e9				pop de 
10e9				pop hl 
10e9			 
10e9				 
10e9			 
10e9				CALLMONITOR 
10e9				jr .lowdone 
10e9			.lowalloc: 
10e9			 
10e9			 
10e9				pop hl 
10e9			.lowdone:	pop af 
10e9				pop de 
10e9				pop hl 
10e9			ret 
10e9			 
10e9			malloc_guard_exit: 
10e9				push hl 
10e9				push de 
10e9				push af 
10e9			 
10e9			 	or a      ;clear carry flag 
10e9				push hl 
10e9				ld de, 255 
10e9				sbc hl, de 
10e9				jr c, .lowallocx 
10e9			 
10e9				push de 
10e9					ld hl, display_fb0 
10e9					ld (display_fb_active), hl 
10e9				call clear_display 
10e9				ld a, 0 
10e9				ld de, .mallocasize 
10e9				call str_at_display 
10e9				call update_display 
10e9				call delay1s 
10e9				call delay1s 
10e9			;	ld a, 0 
10e9			;	ld (os_view_disable), a 
10e9				call bp_on 
10e9				pop de 
10e9				pop hl 
10e9			 
10e9				CALLMONITOR 
10e9				jr .lowdonex 
10e9			.lowallocx: 
10e9			 
10e9				pop hl 
10e9			.lowdonex:	pop af 
10e9				pop de 
10e9				pop hl 
10e9			ret 
10e9			endif 
