12b0			 
12b0			;------------------------------------------------------------------------------ 
12b0			;     free                                                                    : 
12b0			;                                                                             : 
12b0			; Description                                                                 : 
12b0			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12b0			;     returned by malloc, otherwise the behaviour is undefined.               : 
12b0			;                                                                             : 
12b0			;     Where possible, directly adjacent free blocks will be merged together   : 
12b0			;     into larger blocks to help ensure that the heap does not become         : 
12b0			;     excessively fragmented.                                                 : 
12b0			;                                                                             : 
12b0			;     free does not clear or set any other value into the freed space, and    : 
12b0			;     therefore its contents may be visible through subsequent malloc's. The  : 
12b0			;     caller should clear the freed space as required.                        : 
12b0			;                                                                             : 
12b0			;     This implementation of free uses the stack exclusively, and is          : 
12b0			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12b0			;     advisable to disable interrupts before calling free, and recommended    : 
12b0			;     to avoid the use of free inside ISRs in general.                        : 
12b0			;                                                                             : 
12b0			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12b0			;                                                                             : 
12b0			; Parameters                                                                  : 
12b0			;     HL  Pointer to address of first byte of allocation to be freed          : 
12b0			;                                                                             : 
12b0			; Returns                                                                     : 
12b0			;     Nothing                                                                 : 
12b0			;                                                                             : 
12b0			; Stack frame                                                                 : 
12b0			;       |             |                                                       : 
12b0			;       +-------------+                                                       : 
12b0			;       |     BC      |                                                       : 
12b0			;       +-------------+                                                       : 
12b0			;       |     DE      |                                                       : 
12b0			;       +-------------+                                                       : 
12b0			;       |     IX      |                                                       : 
12b0			;       +-------------+                                                       : 
12b0			;       |  prev_free  |                                                       : 
12b0			;   +2  +-------------+                                                       : 
12b0			;       |  next_free  |                                                       : 
12b0			;   +0  +-------------+                                                       : 
12b0			;       |             |                                                       : 
12b0			;                                                                             : 
12b0			;------------------------------------------------------------------------------ 
12b0			free: 
12b0 c5			      push  BC 
12b1 d5			      push  DE 
12b2 dd e5		      push  IX 
12b4			 
12b4 7c			      ld    A, H                    ; Exit if ptr is null 
12b5 b5			      or    L 
12b6 ca 7a 13		      jp    Z, free_early_exit 
12b9			 
12b9			      ; Set up stack frame 
12b9 eb			      ex    DE, HL 
12ba 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12bd 39			      add   HL, SP 
12be f9			      ld    SP, HL 
12bf dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
12c3 dd 39		      add   IX, SP 
12c5			 
12c5			      ; The address in HL points to the start of the useable allocated space, 
12c5			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12c5			      ; address of the block itself. 
12c5 eb			      ex    DE, HL 
12c6 11 fc ff		      ld    DE, -4 
12c9 19			      add   HL, DE 
12ca			 
12ca			      ; An allocated block must have a null next block pointer in it 
12ca 7e			      ld    A, (HL) 
12cb 23			      inc   HL 
12cc b6			      or    (HL) 
12cd c2 75 13		      jp    NZ, free_done 
12d0			 
12d0 2b			      dec   HL 
12d1			 
12d1 44			      ld    B, H                    ; Copy HL to BC 
12d2 4d			      ld    C, L 
12d3			 
12d3			      ; Loop through the free list to find the first block with an address 
12d3			      ; higher than the block being freed 
12d3 21 de 67		      ld    HL, free_list 
12d6			 
12d6			free_find_higher_block: 
12d6 5e			      ld    E, (HL)                 ; Load next ptr from free block 
12d7 23			      inc   HL 
12d8 56			      ld    D, (HL) 
12d9 2b			      dec   HL 
12da			 
12da dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
12dd dd 72 01		      ld    (IX+1), D 
12e0 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
12e3 dd 74 03		      ld    (IX+3), H 
12e6			 
12e6 78			      ld    A, B                    ; Check if DE is greater than BC 
12e7 ba			      cp    D                       ; Compare MSB first 
12e8 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
12ea 30 04		      jr    NC, free_find_higher_block_skip 
12ec 79			      ld    A, C 
12ed bb			      cp    E                       ; Then compare LSB 
12ee 38 08		      jr    C, free_found_higher_block 
12f0			 
12f0			free_find_higher_block_skip: 
12f0 7a			      ld    A, D                    ; Reached the end of the free list? 
12f1 b3			      or    E 
12f2 ca 75 13		      jp    Z, free_done 
12f5			 
12f5 eb			      ex    DE, HL 
12f6			 
12f6 18 de		      jr    free_find_higher_block 
12f8			 
12f8			free_found_higher_block: 
12f8			      ; Insert freed block between prev and next free blocks 
12f8 71			      ld    (HL), C                 ; Point prev free block to freed block 
12f9 23			      inc   HL 
12fa 70			      ld    (HL), B 
12fb			 
12fb 60			      ld    H, B                    ; Point freed block at next free block 
12fc 69			      ld    L, C 
12fd 73			      ld    (HL), E 
12fe 23			      inc   HL 
12ff 72			      ld    (HL), D 
1300			 
1300			      ; Check if the freed block is adjacent to the next free block 
1300 23			      inc   HL                      ; Load size of freed block into HL 
1301 5e			      ld    E, (HL) 
1302 23			      inc   HL 
1303 56			      ld    D, (HL) 
1304 eb			      ex    DE, HL 
1305			 
1305 09			      add   HL, BC                  ; Add addr of freed block and its size 
1306			 
1306 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
1309 dd 56 01		      ld    D, (IX+1) 
130c			 
130c b7			      or    A                       ; Clear the carry flag 
130d ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
130f 20 22		      jr    NZ, free_check_adjacent_to_prev 
1311			 
1311			      ; Freed block is adjacent to next, merge into one bigger block 
1311 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1312 5e			      ld    E, (HL) 
1313 23			      inc   HL 
1314 56			      ld    D, (HL) 
1315 e5			      push  HL                      ; Save ptr to next block for later 
1316			 
1316 60			      ld    H, B                    ; Store ptr from next block into freed block 
1317 69			      ld    L, C 
1318 73			      ld    (HL), E 
1319 23			      inc   HL 
131a 72			      ld    (HL), D 
131b			 
131b e1			      pop   HL                      ; Restore ptr to next block 
131c 23			      inc   HL                      ; Load size of next block into DE 
131d 5e			      ld    E, (HL) 
131e 23			      inc   HL 
131f 56			      ld    D, (HL) 
1320 d5			      push  DE                      ; Save next block size for later 
1321			 
1321 60			      ld    H, B                    ; Load size of freed block into HL 
1322 69			      ld    L, C 
1323 23			      inc   HL 
1324 23			      inc   HL 
1325 5e			      ld    E, (HL) 
1326 23			      inc   HL 
1327 56			      ld    D, (HL) 
1328 eb			      ex    DE, HL 
1329			 
1329 d1			      pop   DE                      ; Restore size of next block 
132a 19			      add   HL, DE                  ; Add sizes of both blocks 
132b eb			      ex    DE, HL 
132c			 
132c 60			      ld    H, B                    ; Store new bigger size into freed block 
132d 69			      ld    L, C 
132e 23			      inc   HL 
132f 23			      inc   HL 
1330 73			      ld    (HL), E 
1331 23			      inc   HL 
1332 72			      ld    (HL), D 
1333			 
1333			free_check_adjacent_to_prev: 
1333			      ; Check if the freed block is adjacent to the prev free block 
1333 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1336 dd 66 03		      ld    H, (IX+3) 
1339			 
1339 23			      inc   HL                      ; Size of prev free block into DE 
133a 23			      inc   HL 
133b 5e			      ld    E, (HL) 
133c 23			      inc   HL 
133d 56			      ld    D, (HL) 
133e 2b			      dec   HL 
133f 2b			      dec   HL 
1340 2b			      dec   HL 
1341			 
1341 19			      add   HL, DE                  ; Add prev block addr and size 
1342			 
1342 b7			      or    A                       ; Clear the carry flag 
1343 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1345 20 2e		      jr    NZ, free_done 
1347			 
1347			      ; Freed block is adjacent to prev, merge into one bigger block 
1347 60			      ld    H, B                    ; Load next ptr from freed block into DE 
1348 69			      ld    L, C 
1349 5e			      ld    E, (HL) 
134a 23			      inc   HL 
134b 56			      ld    D, (HL) 
134c e5			      push  HL                      ; Save freed block ptr for later 
134d			 
134d dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1350 dd 66 03		      ld    H, (IX+3) 
1353 73			      ld    (HL), E 
1354 23			      inc   HL 
1355 72			      ld    (HL), D 
1356			 
1356 e1			      pop   HL                      ; Restore freed block ptr 
1357 23			      inc   HL                      ; Load size of freed block into DE 
1358 5e			      ld    E, (HL) 
1359 23			      inc   HL 
135a 56			      ld    D, (HL) 
135b d5			      push  DE                      ; Save freed block size for later 
135c			 
135c dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
135f dd 66 03		      ld    H, (IX+3) 
1362 23			      inc   HL 
1363 23			      inc   HL 
1364 5e			      ld    E, (HL) 
1365 23			      inc   HL 
1366 56			      ld    D, (HL) 
1367			 
1367 e1			      pop   HL                      ; Add sizes of both blocks 
1368 19			      add   HL, DE 
1369 eb			      ex    DE, HL 
136a			 
136a dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
136d dd 66 03		      ld    H, (IX+3) 
1370 23			      inc   HL 
1371 23			      inc   HL 
1372 73			      ld    (HL), E 
1373 23			      inc   HL 
1374 72			      ld    (HL), D 
1375			 
1375			free_done: 
1375 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
1378 39			      add   HL, SP 
1379 f9			      ld    SP, HL 
137a			 
137a			free_early_exit: 
137a dd e1		      pop   IX 
137c d1			      pop   DE 
137d c1			      pop   BC 
137e			 
137e c9			      ret 
