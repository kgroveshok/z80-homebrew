0e35			 
0e35			 
0e35			; Get 2 ASCII characters as hex byte from pointer in hl 
0e35			 
0e35			BYTERD: 
0e35 16 00			LD	D,00h		;Set up 
0e37 cd 3f 0e			CALL	HEXCON		;Get byte and convert to hex 
0e3a 87				ADD	A,A		;First nibble so 
0e3b 87				ADD	A,A		;multiply by 16 
0e3c 87				ADD	A,A		; 
0e3d 87				ADD	A,A		; 
0e3e 57				LD	D,A		;Save hi nibble in D 
0e3f			HEXCON: 
0e3f 7e				ld a, (hl)		;Get next chr 
0e40 23				inc hl 
0e41 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
0e43 fe 0a			CP	00Ah		;Is it 0-9 ? 
0e45 38 02			JR	C,NALPHA	;If so miss next bit 
0e47 d6 07			SUB	007h		;Else convert alpha 
0e49			NALPHA: 
0e49 b2				OR	D		;Add hi nibble back 
0e4a c9				RET			; 
