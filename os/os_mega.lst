673b			 
673b			; handle the auto run of code from files in storage 
673b			 
673b			 
673b			include "forth_startup.asm" 
673b			; Which startup method to use? 
673b			; 
673b			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
673b			; followed by loading of a list of scripts in eeprom 
673b			 
673b			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
673b			; from eeprom 
673b			 
673b			; Select with define in main stubs 
673b			 
673b			if STARTUP_V1 
673b				include "forth_startupv1.asm" 
673b			endif 
673b			if STARTUP_V2 
673b				include "forth_startupv2.asm" 
673b			; Version 2 of the startup  
673b			;  
673b			; Auto load any files in bank 1 that start with a '*' 
673b			; If no se storage then revert to using eprom 
673b			 
673b			 
673b			if STORAGE_SE = 0 
673b			 
673b			sprompt1: db "Startup load...",0 
673b			sprompt2: db "Run? 1=No *=End #=All",0 
673b			 
673b			 
673b			 
673b			 
673b			forth_startup: 
673b				ld hl, startcmds 
673b				ld a, 0 
673b				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
673b			 
673b			.start1:	push hl 
673b				call clear_display 
673b				ld de, sprompt1 
673b			        ld a, display_row_1 
673b				call str_at_display 
673b				ld de, sprompt2 
673b			        ld a, display_row_2 
673b				call str_at_display 
673b				pop hl 
673b				push hl 
673b				ld e,(hl) 
673b				inc hl 
673b				ld d,(hl) 
673b			        ld a, display_row_3 
673b				call str_at_display 
673b				call update_display 
673b			 
673b			 
673b				ld a, (os_last_cmd) 
673b			;	cp 0 
673b				or a 
673b				jr z, .startprompt 
673b				call delay250ms 
673b				jr .startdo 
673b				 
673b				 
673b			 
673b			.startprompt: 
673b			 
673b				ld a,display_row_4 + display_cols - 1 
673b			        ld de, endprg 
673b				call str_at_display 
673b				call update_display 
673b				call delay1s 
673b				call cin_wait 
673b						 
673b				cp '*' 
673b				jr z, .startupend1 
673b				cp '#' 
673b				jr nz, .startno 
673b				ld a, 1 
673b				ld (os_last_cmd),a 
673b				jr .startdo 
673b			.startno:	cp '1' 
673b				jr z,.startnxt  
673b			 
673b				; exec startup line 
673b			.startdo:	 
673b				pop hl 
673b				push hl 
673b				 
673b				ld e,(hl) 
673b				inc hl 
673b				ld d,(hl) 
673b				ex de,hl 
673b			 
673b				push hl 
673b			 
673b				ld a, 0 
673b				;ld a, FORTH_END_BUFFER 
673b				call strlent 
673b				inc hl   ; include zero term to copy 
673b				ld b,0 
673b				ld c,l 
673b				pop hl 
673b				ld de, scratch 
673b				ldir 
673b			 
673b			 
673b				ld hl, scratch 
673b				call forthparse 
673b				call forthexec 
673b				call forthexec_cleanup 
673b			 
673b				ld a, display_row_4 
673b				ld de, endprog 
673b			 
673b				call update_display		 
673b			 
673b				ld a, (os_last_cmd) 
673b			;	cp 0 
673b				or a 
673b				jr nz, .startnxt 
673b				call next_page_prompt 
673b			        call clear_display 
673b				call update_display		 
673b			 
673b				; move onto next startup line? 
673b			.startnxt: 
673b			 
673b				call delay250ms 
673b				pop hl 
673b			 
673b				inc hl 
673b				inc hl 
673b			 
673b				push hl 
673b				ld e, (hl) 
673b				inc hl 
673b				ld d, (hl) 
673b				pop hl 
673b				; TODO replace 0 test 
673b			 
673b				ex de, hl 
673b				call ishlzero 
673b			;	ld a,e 
673b			;	add d 
673b			;	cp 0    ; any left to do? 
673b				ex de, hl 
673b				jp nz, .start1 
673b				jr .startupend 
673b			 
673b			.startupend1: pop hl 
673b			.startupend: 
673b			 
673b				call clear_display 
673b				call update_display 
673b				ret 
673b			endif 
