a6f4 32 60 ee			ld (debug_mark+2),a  
a6f7 18 03			jr .pastdmark  
a6f9 ..			.dmark: db "BP."  
a6fc f1			.pastdmark: pop af  
a6fd			endm  
# End of macro DMARK
