029c				include "firmware_seeprom.asm"  
029c			; 
029c			; persisent storage interface via microchip serial eeprom 
029c			 
029c			; port a pio 2 
029c			; pa 7 - si 
029c			; pa 6 - sclk  
029c			; pa 5 - so 
029c			; pa 4 - cs 
029c			; pa 3 - cs 
029c			; pa 2 - cs 
029c			; pa 1 - cs 
029c			; pa 0 - cs 
029c			; 
029c			; TODO get block 
029c			; TODO save block 
029c			; TODO load file 
029c			; TODO save file 
029c			; TODO get dir  
029c			 
029c			;  
029c			storage_adata: equ Device_C    ; device c port a - onboard storage 
029c			storage_actl: equ Device_C+2     ; device c port a 
029c			storage_bdata: equ Device_C+1    ; device c port b - ext storage cart 
029c			storage_bctl: equ Device_C+3     ; device c port b 
029c			 
029c			 
029c			; TODO move these to hardware driver file 
029c			 
029c			;STORE_BLOCK_PHY:   equ 64    ; physical block size on storage   64byte on 256k eeprom 
029c			;STORE_DEVICE_MAXBLOCKS:  equ  512 ; how many blocks are there on this storage device 
029c			; storage bank file system format 
029c			; 
029c			; first page of bank: 
029c			; 	addr 0 - status check 
029c			;       addr 1 - write protect flag 
029c			;       addr 2 - zero if all data is held on this device. >0 - next device number (not used right now) 
029c			;       addr 3 - last file id (to save on scanning for spare file id). or could have bit mask of file ids in use????  
029c			;         TODO see if scanning whole of for available next file id is fast enough 
029c			;	addr 4 > zero term string of bank label 
029c			; 
029c			;        
029c			;  
029c			; first page of any file: 
029c			;      byte 0 - file id  
029c			;      byte 1-17 - fixed file name  
029c			;      byte 18-end of page - extra meta data tba (date? description? keywords?) 
029c			; 
029c			; other pages of any file: 
029c			;      byte 0 - file id 
029c			;      byte 1> - file data 
029c			; 
029c			; TODO depending on how long it takes to load a file in if scanning the whole bank for the file id, could speed it up by having last file page flag??? high bit? that would max 127 files 
029c			;  
029c			; TODO need a bank format which places a 0 in each of the first byte of every page and updates the meta in page 0 
029c			 
029c			 
029c			;storage_so_bit: 5 
029c			;storage_si_bit: 7 
029c			;storage_sclk_bit: 6 
029c			  
029c			 
029c			; init storage pio 
029c			 
029c			storage_init: 
029c			 
029c			 
029c					; set default SPI clk pulse time as disabled 
029c			 
029c 3e 00				ld a, 0 
029e 32 8f f9				ld (spi_clktime), a 
02a1			 
02a1					; init hardware 
02a1			 
02a1 3e cf		            LD   A, 11001111b 
02a3 d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
02a5 3e 00		            LD   A, 00000000b 
02a7 cb f7			set SPI_DO,a 
02a9			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
02a9 d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
02ab			 
02ab 3e cf		            LD   A, 11001111b 
02ad d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
02af 3e 00		            LD   A, 00000000b 
02b1 d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
02b3			 
02b3				; set all external spi devices off  
02b3 3e ff			ld a, 255 
02b5 32 8b f9			ld (spi_device), a 
02b8 32 8e f9			ld (spi_cartdev), a 
02bb			 
02bb					; ensure the spi bus is in a default stable state 
02bb cd 43 01				call se_stable_spi 
02be			 
02be			; TODO scan spi bus and gather which storage banks are present 
02be			 
02be			; populate store_bank_active  
02be			; for each ce line activate and attempt to write first byte of bank and read back 
02be			; if zero is returned then bank is empty 
02be			;   
02be			; 
02be			 
02be					; init file extent cache to save on slow reads 
02be			 
02be			;	ld hl, store_filecache 
02be			;	ld de, 0 
02be			;	ld hl,(de)	 
02be			 
02be			 
02be c9			    ret 
