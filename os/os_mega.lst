69a4			; Position cursor to specified location  
69a4			;   On entry: A = Cursor position  
69a4			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
69a4 f5			fLCD_Pos:   PUSH AF  
69a5					; at this point set the E1 or E2 flag depending on position  
69a5			  
69a5 c5					push bc  
69a6			;		push af  
69a6 06 00				ld b, 0  
69a8 4f					ld c, a  
69a9 3e 4f				ld a, kLCD_Line3-1  
69ab b7			 		or a      ;clear carry flag  
69ac 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
69ad 38 04				jr c, .pe1  
69af			  
69af					; E selection  
69af cb 80				res 0, b         ; bit 0 unset e  
69b1			;		pop af    ; before line 3 so recover orig pos  
69b1			;		ld c, a    ; save for poking back  
69b1 18 06				jr .peset	          
69b3			.pe1:          	; E2 selection  
69b3 cb c0				set 0, b         ; bit 0 set e1  
69b5 79					ld a, c  
69b6 de 4f				sbc a, kLCD_Line3-1  
69b8 4f					ld c, a	         ; save caculated offset  
69b9			;		pop af     ; bin this original value now we have calculated form  
69b9			  
69b9			.peset:		; set bit  
69b9 78					ld a, b  
69ba 32 fb fa				ld (display_lcde1e2), a 	  
69bd 79					ld a, c  
69be c1					pop bc  
69bf			  
69bf f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
69c1 cd 20 69		            CALL fLCD_Inst      ;Write instruction to LCD  
69c4 f1			            POP  AF  
69c5 c9			            RET  
69c6			  
69c6			  
69c6			; Output text string to LCD  
69c6			;   On entry: DE = Pointer to null terminated text string  
69c6			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
69c6 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
69c7 b7			            OR   A              ;Null terminator?  
69c8 c8			            RET  Z              ;Yes, so finished  
69c9 cd 5c 69		            CALL fLCD_Data      ;Write character to display  
69cc 13			            INC  DE             ;Point to next character  
69cd 18 f7		            JR   fLCD_Str       ;Repeat  
69cf c9					ret  
69d0			  
69d0			; Define custom character  
69d0			;   On entry: A = Character number (0 to 7)  
69d0			;             DE = Pointer to character bitmap data  
69d0			;   On exit:  A = Next character number  
69d0			;             DE = Next location following bitmap  
69d0			;             BC HL IX IY I AF' BC' DE' HL' preserved  
69d0			; Character is   
69d0 c5			fLCD_Def:   PUSH BC  
69d1 f5			            PUSH AF  
69d2 07			            RLCA                ;Calculate location  
69d3 07			            RLCA                ;  for bitmap data  
69d4 07			            RLCA                ;  = 8 x CharacterNumber  
69d5 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
69d7 cd 20 69		            CALL fLCD_Inst      ;Write instruction to LCD  
69da 06 00		            LD   B, 0  
69dc 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
69dd cd 5c 69		            CALL fLCD_Data      ;Write byte to display  
69e0 13			            INC  DE             ;Point to next byte  
69e1 04			            INC  B              ;Count bytes  
69e2 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
69e4 28 f6		            JR   Z, Loop       ;No, so repeat  
69e6 f1			            POP  AF  
69e7 3c			            INC  A              ;Increment character number  
69e8 c1			            POP  BC  
69e9 c9			            RET  
