d562 cd 22 88			call str_at_display 
d565 e1				pop hl 
d566 e5				push hl 
d567 5e				ld e,(hl) 
d568 23				inc hl 
d569 56				ld d,(hl) 
d56a 3e 50		        ld a, display_row_3 
d56c cd 22 88			call str_at_display 
d56f cd 32 88			call update_display 
