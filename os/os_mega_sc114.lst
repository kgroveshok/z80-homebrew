91c6 dd 66 03		      ld    H, (IX+3) 
91c9 23			      inc   HL 
91ca 23			      inc   HL 
91cb 73			      ld    (HL), E 
91cc 23			      inc   HL 
91cd 72			      ld    (HL), D 
