0eff 1a			strcpy:   LD   A, (DE)        ;Get character from string 
0f00 b7			            OR   A              ;Null terminator? 
0f01 c8			            RET  Z              ;Yes, so finished 
0f02 1a					ld a,(de) 
0f03 77					ld (hl),a 
0f04 13			            INC  DE             ;Point to next character 
0f05 23					inc hl 
0f06 18 f7		            JR   strcpy       ;Repeat 
0f08 c9					ret 
