0294			storage_init: 
0294			 
0294			 
0294					; set default SPI clk pulse time as disabled 
0294			 
0294 3e 00				ld a, 0 
0296 32 94 f9				ld (spi_clktime), a 
0299			 
0299					; init hardware 
0299			 
0299 3e cf		            LD   A, 11001111b 
029b d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
029d 3e 00		            LD   A, 00000000b 
029f cb f7			set SPI_DO,a 
02a1			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
02a1 d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
02a3			 
02a3 3e cf		            LD   A, 11001111b 
02a5 d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
02a7 3e 00		            LD   A, 00000000b 
02a9 d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
02ab			 
02ab				; set all external spi devices off  
02ab 3e ff			ld a, 255 
02ad 32 90 f9			ld (spi_device), a 
02b0 32 93 f9			ld (spi_cartdev), a 
02b3			 
02b3					; ensure the spi bus is in a default stable state 
02b3 cd 3b 01				call se_stable_spi 
02b6			 
02b6			; TODO scan spi bus and gather which storage banks are present 
02b6			 
02b6			; populate store_bank_active  
02b6			; for each ce line activate and attempt to write first byte of bank and read back 
02b6			; if zero is returned then bank is empty 
02b6			;   
02b6			; 
02b6			 
02b6					; init file extent cache to save on slow reads 
02b6			 
02b6			;	ld hl, store_filecache 
02b6			;	ld de, 0 
02b6			;	ld hl,(de)	 
02b6			 
02b6			 
02b6 c9			    ret 
02b7			 
02b7			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
02b7			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
02b7			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
02b7			 
02b7			; INSTRUCTION SET 
02b7			; READ 0000 0011 Read data from memory array beginning at selected address 
02b7			; WRITE 0000 0010 Write data to memory array beginning at selected address 
02b7			; WREN 0000 0110 Set the write enable latch (enable write operations) 
02b7			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
02b7			; RDSR 0000 0101 Read STATUS register 
02b7			; WRSR 0000 0001 Write STATUS register 
02b7			; PE 0100 0010 Page Erase – erase one page in memory array 
02b7			; SE 1101 1000 Sector Erase – erase one sector in memory array 
02b7			; CE 1100 0111 Chip Erase – erase all sectors in memory array 
02b7			; RDID 1010 1011 Release from Deep power-down and read electronic signature 
02b7			 
02b7			; TODO send byte steam for page without setting the address for every single byte 
02b7			; TODO read byte  
02b7			 
02b7			; byte in a 
02b7			; address in hl  
02b7			se_writebyte: 
02b7			        
02b7			    ;   ld c, a 
02b7 f5			        push af 
02b8 e5			        push hl 
02b9			 
02b9			    ; initi write mode 
02b9			    ; 
02b9			    ;CS low 
02b9			 
02b9 3a 91 f9		       ld a,(spi_portbyte) 
02bc cd 60 02			call spi_ce_low 
02bf			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02bf d3 80		       out (storage_adata),a 
02c1 32 91 f9		       ld (spi_portbyte), a 
02c4			 
02c4			    ;clock out wren instruction 
02c4			 
02c4 3e 06		    ld a, store_wren_ins 
02c6 cd 61 01		    call spi_send_byte  
02c9			 
02c9			    ;cs high to enable write latch 
02c9			 
02c9 3a 91 f9		       ld a,(spi_portbyte) 
02cc cd 4f 02			call spi_ce_high 
02cf			;       set SPI_CE0,a           ; TODO pass the ce bank bit mask 
02cf d3 80		       out (storage_adata),a 
02d1 32 91 f9		       ld (spi_portbyte), a 
02d4			 
02d4			;	nop 
02d4			    ; 
02d4			    ; intial write data 
02d4			    ; 
02d4			    ; cs low 
02d4			     
02d4			;       ld a,(spi_portbyte) 
02d4 cd 60 02			call spi_ce_low 
02d7			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02d7 d3 80		       out (storage_adata),a 
02d9 32 91 f9		       ld (spi_portbyte), a 
02dc			 
02dc			    ; clock out write instruction 
02dc			     
02dc 3e 02		    ld a, store_write_ins  
02de cd 61 01		    call spi_send_byte  
02e1			 
02e1			    ; clock out address (depending on address size) 
02e1			     
02e1 e1			    pop hl 
02e2 7c			    ld a,h    ; address out msb first 
02e3 cd 61 01		    call spi_send_byte  
02e6 7d			    ld a,l 
02e7 cd 61 01		    call spi_send_byte  
02ea			 
02ea			    ; clock out byte(s) for page 
