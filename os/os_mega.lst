147e fe 00			cp 0 
1480 20 09			jr nz, .td4 
1482 2a 85 f9			ld hl, (tape_sync+1) 
1485 34				inc (hl) 
1486 7e				ld a,(hl) 
1487 fe 05			cp 5 
1489 18 e8			jr .td2 
148b			 
148b			.td4: 
148b				 ; in gap 
148b			; wait for rising edge 
148b			; on edge  
148b			; count pulse 
148b			; count no pulse 
148b			; if no pulse for 5ms then must be gap 
148b			; save pulse size for each gap found 
148b			; once gap count is 6 then exit and report counts 
148b			 
148b c9					ret 
