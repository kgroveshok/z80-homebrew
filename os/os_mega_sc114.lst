8a55			 
8a55			; compare hl and de 
8a55			; returns:  
8a55			; if hl = de, z=1, s=0, c0=0 
8a55			; if hl > de, z=0, s=0, c=0 
8a55			; if hl < de, z=0, s=1, c=1 
8a55			cmp16:	 
8a55 b7				or a 
8a56 ed 52			sbc hl,de 
8a58 e0				ret po 
8a59 7c				ld a,h 
8a5a 1f				rra 
8a5b ee 40			xor 01000000B 
8a5d 37				scf 
8a5e 8f				adc a,a 
8a5f c9				ret 
