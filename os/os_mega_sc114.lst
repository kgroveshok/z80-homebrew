91b6				; need hl to be the id 
91b6				; need de to be the string ptr 
91b6				 
91b6				call storage_append 
91b6			 
91b6				pop de 
91b6				pop hl 
91b6			 
91b6				inc de 
91b6				inc de 
91b6			 
91b6				ld a,(de) 
91b6				cp 0 
91b6				jr nz, .genloop 
91b6				inc de 
91b6				ld a, (de) 
91b6				dec de 
91b6				cp 0 
91b6				jr nz, .genloop	 
91b6			 
91b6				ret 
