12e0				dec hl    ; get past pointer 
12e0				dec hl 
12e0			 
12e0				ld a, (hl)    ; need this for a validation check 
12e0			 
12e0				dec hl    ; move to block marker 
12e0			 
12e0				; now check that the block count and block marker are the same  
12e0			        ; this checks that we are on a malloc node and not random memory 
12e0			        ; OK a faint chance this could be a problem but rare - famous last words! 
12e0			 
12e0				ld c, a 
12e0				ld a, (hl)    
12e0			 
12e0				cp c 
12e0				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12e0			 
12e0				; yes good chance we are on a malloc node 
12e0			 
12e0			;	ld a, 0      
12e0				ld (hl), 0   ; mark as free 
12e0			 
12e0				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12e0			 
12e0			.freeignore:  
12e0			 
12e0				pop af 
12e0				pop hl 
12e0			 
12e0				ret 
