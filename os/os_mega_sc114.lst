d526 c5				push bc 
d527 0e 02			ld c, $02 
d529 f7				rst $30 
d52a c1				pop bc 
d52b c9				ret 
d52c			 
d52c			; position the cursor on the screen using A as realtive point in screen buffer (i.e. A=(x+(width/y))) 
d52c			fLCD_Pos: 
d52c				; use ASCII escape to position 
d52c			        ;out (SC114_SIO_1_OUT),a 
d52c c5				push bc 
d52d 0e 02			ld c, $02 
d52f f7				rst $30 
d530 c1				pop bc 
d531			 
d531 c9				ret 
d532			 
d532			; output char at pos 
d532			fLCD_Data: 
d532			      ;  out (SC114_SIO_1_OUT),a 
d532 c5				push bc 
d533 0e 02			ld c, $02 
d535 f7				rst $30 
d536 c1				pop bc 
d537			 
d537 c9				ret 
d538			 
d538			; ascii cls  
d538			 
d538 1b 5b 48 00	.cls:   db 27, '[', 'H', 0 
d53c			 
d53c			; write the frame buffer given in hl to hardware  
d53c			write_display: 
d53c			 
d53c			API: equ 0 
d53c			 
d53c			if API 
d53c				push bc 
d53c				ld b, 4 
d53c			 
d53c			        ld (display_write_tmp), hl 	  
d53c			 
d53c				; clear and home cursor 
d53c			 
d53c				ld c, 6 
d53c				ld de, .cls 
d53c				rst $30 
d53c			 
d53c			 
d53c			.writeln: 
d53c			 
d53c				ld de, (display_write_tmp) 
d53c				ld c, 6 
d53c				rst $30 
d53c				ld c, 7 
d53c				rst $30 
d53c			 
d53c				ld hl, (display_write_tmp) 
d53c				ld de, display_cols 
d53c				add hl,de 
d53c				ld (display_write_tmp),hl 
d53c			 
d53c				djnz  .writeln 
d53c			 
d53c				pop bc 
d53c			 
d53c			 
d53c				ret 
