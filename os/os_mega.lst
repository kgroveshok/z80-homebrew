00ca cd 50 0a			call delay1s  
00cd 3e 2b			ld a,'+'  
00cf cd 16 0b			call fill_display  
00d2 cd 33 0b			call update_display  
00d5 cd 50 0a			call delay1s  
00d8 3e 2a			ld a,'*'  
00da cd 16 0b			call fill_display  
00dd cd 33 0b			call update_display  
00e0 cd 50 0a			call delay1s  
