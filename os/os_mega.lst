6786			include "forth_startup.asm" 
6786			; Which startup method to use? 
6786			; 
6786			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6786			; followed by loading of a list of scripts in eeprom 
6786			 
6786			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6786			; from eeprom 
6786			 
6786			; Select with define in main stubs 
6786			 
6786			if STARTUP_V1 
6786				include "forth_startupv1.asm" 
6786			endif 
6786			if STARTUP_V2 
6786				include "forth_startupv2.asm" 
6786			; Version 2 of the startup  
6786			;  
6786			; Auto load any files in bank 1 that start with a '*' 
6786			; If no se storage then revert to using eprom 
6786			 
6786			 
6786			if STORAGE_SE = 0 
6786			 
6786			sprompt1: db "Startup load...",0 
6786			sprompt2: db "Run? 1=No *=End #=All",0 
6786			 
6786			 
6786			 
6786			 
6786			forth_startup: 
6786				ld hl, startcmds 
6786				ld a, 0 
6786				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
6786			 
6786			.start1:	push hl 
6786				call clear_display 
6786				ld de, sprompt1 
6786			        ld a, display_row_1 
6786				call str_at_display 
6786				ld de, sprompt2 
6786			        ld a, display_row_2 
6786				call str_at_display 
6786				pop hl 
6786				push hl 
6786				ld e,(hl) 
6786				inc hl 
6786				ld d,(hl) 
6786			        ld a, display_row_3 
6786				call str_at_display 
6786				call update_display 
6786			 
6786			 
6786				ld a, (os_last_cmd) 
6786			;	cp 0 
6786				or a 
6786				jr z, .startprompt 
6786				call delay250ms 
6786				jr .startdo 
6786				 
6786				 
6786			 
6786			.startprompt: 
6786			 
6786				ld a,display_row_4 + display_cols - 1 
6786			        ld de, endprg 
6786				call str_at_display 
6786				call update_display 
6786				call delay1s 
6786				call cin_wait 
6786						 
6786				cp '*' 
6786				jr z, .startupend1 
6786				cp '#' 
6786				jr nz, .startno 
6786				ld a, 1 
6786				ld (os_last_cmd),a 
6786				jr .startdo 
6786			.startno:	cp '1' 
6786				jr z,.startnxt  
6786			 
6786				; exec startup line 
6786			.startdo:	 
6786				pop hl 
6786				push hl 
6786				 
6786				ld e,(hl) 
6786				inc hl 
6786				ld d,(hl) 
6786				ex de,hl 
6786			 
6786				push hl 
6786			 
6786				ld a, 0 
6786				;ld a, FORTH_END_BUFFER 
6786				call strlent 
6786				inc hl   ; include zero term to copy 
6786				ld b,0 
6786				ld c,l 
6786				pop hl 
6786				ld de, scratch 
6786				ldir 
6786			 
6786			 
6786				ld hl, scratch 
6786				call forthparse 
6786				call forthexec 
6786				call forthexec_cleanup 
6786			 
6786				ld a, display_row_4 
6786				ld de, endprog 
6786			 
6786				call update_display		 
6786			 
6786				ld a, (os_last_cmd) 
6786			;	cp 0 
6786				or a 
6786				jr nz, .startnxt 
6786				call next_page_prompt 
6786			        call clear_display 
6786				call update_display		 
6786			 
6786				; move onto next startup line? 
6786			.startnxt: 
6786			 
6786				call delay250ms 
6786				pop hl 
6786			 
6786				inc hl 
6786				inc hl 
6786			 
6786				push hl 
6786				ld e, (hl) 
6786				inc hl 
6786				ld d, (hl) 
6786				pop hl 
