8ddf			if MALLOC_2 
8ddf			; Z80 Malloc and Free Functions 
8ddf			 
8ddf			; Malloc Function: 
8ddf			; Input: 
8ddf			;   HL: Size of block to allocate 
8ddf			; Output: 
8ddf			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8ddf			 
8ddf			malloc: 
8ddf				 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf			call malloc_guard_entry 
8ddf			endif 
8ddf			 
8ddf			 
8ddf			 
8ddf			 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "mal" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			    push af            ; Save AF register 
8ddf			    ld a, l            ; Load low byte of size into A 
8ddf			    or h               ; Check if size is zero 
8ddf			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
8ddf			 
8ddf			    ; Allocate memory 
8ddf			    ld hl, (heap_start) ; Load start of heap into HL 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "ma1" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			    call malloc_internal ; Call internal malloc function 
8ddf			    pop af             ; Restore AF register 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret                ; Return 
8ddf			 
8ddf			; Free Function: 
8ddf			; Input: 
8ddf			;   HL: Pointer to memory block to free 
8ddf			; Output: 
8ddf			;   None 
8ddf			 
8ddf			free: 
8ddf			    push af            ; Save AF register 
8ddf			    ld a, l            ; Load low byte of pointer into A 
8ddf			    or h               ; Check if pointer is NULL 
8ddf			    jp z, free_exit    ; If pointer is NULL, exit 
8ddf			 
8ddf			    ; Free memory 
8ddf			    ld hl, (heap_start) ; Load start of heap into HL 
8ddf			    call free_internal  ; Call internal free function 
8ddf			    pop af             ; Restore AF register 
8ddf			    ret                ; Return 
8ddf			 
8ddf			; Internal Malloc Function: 
8ddf			; Input: 
8ddf			;   HL: Size of block to allocate 
8ddf			; Output: 
8ddf			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8ddf			 
8ddf			malloc_internal: 
8ddf			    ld bc, 2           ; Number of bytes to allocate for management overhead 
8ddf			    add hl, bc         ; Add management overhead to requested size 
8ddf			    ex de, hl          ; Save total size in DE, and keep it in HL 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "ma2" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			 
8ddf			    ; Search for free memory block 
8ddf			    ld de, (heap_end)  ; Load end of heap into DE 
8ddf			    ld bc, 0           ; Initialize counter 
8ddf			 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "ma2" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			malloc_search_loop: 
8ddf			    ; Check if current block is free 
8ddf			    ld a, (hl)         ; Load current block's status (free or used) 
8ddf			;    cp 0               ; Compare with zero (free) 
8ddf				or a 
8ddf			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
8ddf			 
8ddf			    ; Check if current block is large enough 
8ddf			    ld a, (hl+1)       ; Load high byte of block size 
8ddf			    cp l               ; Compare with low byte of requested size 
8ddf			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
8ddf			 
8ddf			    ld a, (hl+2)       ; Load low byte of block size 
8ddf			    cp h               ; Compare with high byte of requested size 
8ddf			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
8ddf			 
8ddf			    ; Mark block as used 
8ddf			    ld (hl), 0xFF      ; Set status byte to indicate used block 
8ddf			 
8ddf			    ; Calculate remaining space in block 
8ddf			    ld bc, 0           ; Clear BC 
8ddf			    add hl, bc         ; Increment HL to point to start of data block 
8ddf			    add hl, de         ; HL = HL + DE (total size) 
8ddf			    ld bc, 1           ; Number of bytes to allocate for management overhead 
8ddf			    add hl, bc         ; Add management overhead to start of data block 
8ddf			 
8ddf			    ; Save pointer to allocated block in HL 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf						DMARK "ma5" 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret 
8ddf			 
8ddf			malloc_skip_block_check: 
8ddf			    ; Move to the next block 
8ddf			    ld bc, 3           ; Size of management overhead 
8ddf			    add hl, bc         ; Move to the next block 
8ddf			    inc de             ; Increment counter 
8ddf			 
8ddf			    ; Check if we have reached the end of heap 
8ddf			    ld a, e            ; Load low byte of heap end address 
8ddf			    cp (hl)            ; Compare with low byte of current address 
8ddf			    jr nz, malloc_search_loop  ; If not equal, continue searching 
8ddf			    ld a, d            ; Load high byte of heap end address 
8ddf			;    cp 0               ; Check if it's zero (end of memory) 
8ddf				or a 
8ddf			    jr nz, malloc_search_loop  ; If not zero, continue searching 
8ddf			 
8ddf			    ; If we reached here, allocation failed 
8ddf			    xor a              ; Set result to NULL 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf						DMARK "ma6" 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret 
8ddf			malloc_exit: 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf						DMARK "ma7" 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret 
8ddf			 
8ddf			; Internal Free Function: 
8ddf			; Input: 
8ddf			;   HL: Pointer to memory block to free 
8ddf			; Output: 
8ddf			;   None 
8ddf			 
8ddf			free_internal: 
8ddf			    ld de, (heap_start) ; Load start of heap into DE 
8ddf			    ld bc, 0            ; Initialize counter 
8ddf			 
8ddf			free_search_loop: 
8ddf			    ; Check if current block contains the pointer 
8ddf			    ld a, l             ; Load low byte of pointer 
8ddf			    cp (hl+1)           ; Compare with high byte of current block's address 
8ddf			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8ddf			    ld a, h             ; Load high byte of pointer 
8ddf			    cp (hl+2)           ; Compare with low byte of current block's address 
8ddf			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8ddf			 
8ddf			    ; Mark block as free 
8ddf			    ld (hl), 0          ; Set status byte to indicate free block 
8ddf			    ret                 ; Return 
8ddf			 
8ddf			free_skip_block_check: 
8ddf			    ; Move to the next block 
8ddf			    ld bc, 3            ; Size of management overhead 
8ddf			    add hl, bc          ; Move to the next block 
8ddf			    inc de              ; Increment counter 
8ddf			 
8ddf			    ; Check if we have reached the end of heap 
8ddf			    ld a, e             ; Load low byte of heap end address 
8ddf			    cp (hl)             ; Compare with low byte of current address 
8ddf			    jr nz, free_search_loop  ; If not equal, continue searching 
8ddf			    ld a, d             ; Load high byte of heap end address 
8ddf			;    cp 0                ; Check if it's zero (end of memory) 
8ddf				or a 
8ddf			    jr nz, free_search_loop  ; If not zero, continue searching 
8ddf			 
8ddf			    ; If we reached here, pointer is not found in heap 
8ddf			    ret 
8ddf			 
8ddf			free_exit: 
8ddf			    ret                 ; Return 
8ddf			 
8ddf			; Define heap start and end addresses 
8ddf			;heap_start:    .dw 0xC000   ; Start of heap 
8ddf			;heap_end:      .dw 0xE000   ; End of heap 
8ddf			 
8ddf			endif 
8ddf			 
8ddf			 
8ddf			if MALLOC_1 
8ddf			 
8ddf			 
8ddf			 
8ddf			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
8ddf			 
8ddf			;moved to firmware.asm 
