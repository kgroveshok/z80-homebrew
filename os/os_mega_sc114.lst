8efb			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8efb			      ; address of the block itself. 
8efb eb			      ex    DE, HL 
8efc 11 fc ff		      ld    DE, -4 
8eff 19			      add   HL, DE 
