24ed 32 9b fd			ld (debug_mark+2),a  
24f0 18 03			jr .pastdmark  
24f2 ..			.dmark: db "HEP"  
24f5 f1			.pastdmark: pop af  
24f6			endm  
# End of macro DMARK
24f6					CALLMONITOR 
24f6				if BASE_CPM=1  
24f6					call debug_vector  
24f6				endif  
24f6				if BASE_KEV=1  
