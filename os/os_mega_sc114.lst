96ba					call debug_vector  
96ba				endif  
96ba				if BASE_KEV=1  
96ba					rst 8  
96ba				endif  
96ba				endm  
# End of macro CALLMONITOR
96ba					endif 
96ba				;pop de 
96ba c9				ret 
