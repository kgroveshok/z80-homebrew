20f5			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
20f5			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
20f5			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
20f5			WORD_SYS_END: equ 0   ; Opcode for all user words 
20f5			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
20f5			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
20f5			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
