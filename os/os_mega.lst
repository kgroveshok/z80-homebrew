0cec			; 
0cec			; Divide 8-bit values 
0cec			; In: Divide E by divider C 
0cec			; Out: A = result, B = rest 
0cec			; 
0cec			Div8: 
0cec af			    xor a 
0ced 06 08		    ld b,8 
0cef			Div8_Loop: 
0cef cb 13		    rl e 
0cf1 17			    rla 
0cf2 91			    sub c 
0cf3 30 01		    jr nc,Div8_NoAdd 
0cf5 81			    add a,c 
0cf6			Div8_NoAdd: 
0cf6 10 f7		    djnz Div8_Loop 
0cf8 47			    ld b,a 
0cf9 7b			    ld a,e 
0cfa 17			    rla 
0cfb 2f			    cpl 
0cfc c9			    ret 
