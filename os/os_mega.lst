20ee			; 
20ee			; kernel to the forth OS 
20ee			 
20ee			DS_TYPE_STR: equ 1     ; string type 
20ee			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
20ee			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
20ee			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
20ee			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
20ee			 
20ee			FORTH_PARSEV1: equ 0 
20ee			FORTH_PARSEV2: equ 0 
20ee			FORTH_PARSEV3: equ 0 
20ee			FORTH_PARSEV4: equ 0 
20ee			FORTH_PARSEV5: equ 0 
20ee			FORTH_PARSEV6: equ 1 
