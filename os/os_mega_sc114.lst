8e6f			; from z80uartmonitor 
8e6f			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8e6f			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
8e6f			; pass hl for where to put the text 
8e6f			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8e6f c5			hexout:	PUSH BC 
8e70 f5					PUSH AF 
8e71 47					LD B, A 
8e72					; Upper nybble 
8e72 cb 3f				SRL A 
8e74 cb 3f				SRL A 
8e76 cb 3f				SRL A 
8e78 cb 3f				SRL A 
8e7a cd 8a 8e				CALL tohex 
8e7d 77					ld (hl),a 
8e7e 23					inc hl	 
8e7f					 
8e7f					; Lower nybble 
8e7f 78					LD A, B 
8e80 e6 0f				AND 0FH 
8e82 cd 8a 8e				CALL tohex 
8e85 77					ld (hl),a 
8e86 23					inc hl	 
8e87					 
8e87 f1					POP AF 
8e88 c1					POP BC 
8e89 c9					RET 
8e8a					 
8e8a			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8e8a			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
8e8a			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8e8a			tohex: 
8e8a e5					PUSH HL 
8e8b d5					PUSH DE 
8e8c 16 00				LD D, 0 
8e8e 5f					LD E, A 
8e8f 21 97 8e				LD HL, .DATA 
8e92 19					ADD HL, DE 
8e93 7e					LD A, (HL) 
8e94 d1					POP DE 
8e95 e1					POP HL 
8e96 c9					RET 
8e97			 
8e97			.DATA: 
8e97 30					DEFB	30h	; 0 
8e98 31					DEFB	31h	; 1 
8e99 32					DEFB	32h	; 2 
8e9a 33					DEFB	33h	; 3 
8e9b 34					DEFB	34h	; 4 
8e9c 35					DEFB	35h	; 5 
8e9d 36					DEFB	36h	; 6 
8e9e 37					DEFB	37h	; 7 
8e9f 38					DEFB	38h	; 8 
8ea0 39					DEFB	39h	; 9 
8ea1 41					DEFB	41h	; A 
8ea2 42					DEFB	42h	; B 
8ea3 43					DEFB	43h	; C 
8ea4 44					DEFB	44h	; D 
8ea5 45					DEFB	45h	; E 
8ea6 46					DEFB	46h	; F 
8ea7			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8ea7			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
8ea7			;;    subtract $30, if result > 9 then subtract $7 more 
8ea7			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
8ea7			atohex: 
8ea7 d6 30				SUB $30 
8ea9 fe 0a				CP 10 
8eab f8					RET M		; If result negative it was 0-9 so we're done 
8eac d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
8eae c9					RET		 
8eaf			 
8eaf			 
8eaf			 
8eaf			 
8eaf			; Get 2 ASCII characters as hex byte from pointer in hl 
8eaf			 
8eaf			BYTERD: 
8eaf 16 00			LD	D,00h		;Set up 
8eb1 cd b9 8e			CALL	HEXCON		;Get byte and convert to hex 
8eb4 87				ADD	A,A		;First nibble so 
8eb5 87				ADD	A,A		;multiply by 16 
8eb6 87				ADD	A,A		; 
8eb7 87				ADD	A,A		; 
8eb8 57				LD	D,A		;Save hi nibble in D 
8eb9			HEXCON: 
8eb9 7e				ld a, (hl)		;Get next chr 
8eba 23				inc hl 
8ebb d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
8ebd fe 0a			CP	00Ah		;Is it 0-9 ? 
8ebf 38 02			JR	C,NALPHA	;If so miss next bit 
8ec1 d6 07			SUB	007h		;Else convert alpha 
8ec3			NALPHA: 
8ec3 b2				OR	D		;Add hi nibble back 
8ec4 c9				RET			; 
