24d5					ld a, (.dmark)  
24d5					ld (debug_mark),a  
24d5					ld a, (.dmark+1)  
24d5					ld (debug_mark+1),a  
24d5					ld a, (.dmark+2)  
24d5					ld (debug_mark+2),a  
24d5				endif  
24d5 18 04			jr .pastdmark  
24d7 ..			.dmark: db "HEP"  
24da				if DEMARK_VERSION = 1  
24da 00					db 0  
24db				endif  
24db				if DEMARK_VERSION = 1  
24db e1			.pastdmark: pop hl  
24dc				endif  
24dc				if DEMARK_VERSION = 0  
24dc			.pastdmark: pop af  
24dc				endif  
