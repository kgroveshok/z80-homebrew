a1de				if BASE_CPM=1  
a1de					call debug_vector  
a1de				endif  
a1de				if BASE_KEV=1  
a1de					rst 8  
a1de				endif  
a1de				endm  
# End of macro CALLMONITOR
a1de				endif 
