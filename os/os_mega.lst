0c34			 
0c34			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0c34			 
0c34			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0c34			 
0c34			 
0c34			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0c34			 
0c34			prng16: 
0c34			;Inputs: 
0c34			;   (seed1) contains a 16-bit seed value 
0c34			;   (seed2) contains a NON-ZERO 16-bit seed value 
0c34			;Outputs: 
0c34			;   HL is the result 
0c34			;   BC is the result of the LCG, so not that great of quality 
0c34			;   DE is preserved 
0c34			;Destroys: 
0c34			;   AF 
0c34			;cycle: 4,294,901,760 (almost 4.3 billion) 
0c34			;160cc 
0c34			;26 bytes 
0c34 2a d3 fa		    ld hl,(seed1) 
0c37 44			    ld b,h 
0c38 4d			    ld c,l 
0c39 29			    add hl,hl 
0c3a 29			    add hl,hl 
0c3b 2c			    inc l 
0c3c 09			    add hl,bc 
0c3d 22 d3 fa		    ld (seed1),hl 
0c40 2a d1 fa		    ld hl,(seed2) 
0c43 29			    add hl,hl 
0c44 9f			    sbc a,a 
0c45 e6 2d		    and %00101101 
0c47 ad			    xor l 
0c48 6f			    ld l,a 
0c49 22 d1 fa		    ld (seed2),hl 
0c4c 09			    add hl,bc 
0c4d c9			    ret 
0c4e			 
0c4e			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0c4e			 
0c4e			rand32: 
0c4e			;Inputs: 
0c4e			;   (seed1_0) holds the lower 16 bits of the first seed 
0c4e			;   (seed1_1) holds the upper 16 bits of the first seed 
0c4e			;   (seed2_0) holds the lower 16 bits of the second seed 
0c4e			;   (seed2_1) holds the upper 16 bits of the second seed 
0c4e			;   **NOTE: seed2 must be non-zero 
0c4e			;Outputs: 
0c4e			;   HL is the result 
0c4e			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0c4e			;Destroys: 
0c4e			;   AF 
0c4e			;Tested and passes all CAcert tests 
0c4e			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0c4e			;it has a period of 18,446,744,069,414,584,320 
0c4e			;roughly 18.4 quintillion. 
0c4e			;LFSR taps: 0,2,6,7  = 11000101 
0c4e			;291cc 
0c4e			;seed1_0=$+1 
0c4e			;    ld hl,12345 
0c4e			;seed1_1=$+1 
0c4e			;    ld de,6789 
0c4e			;    ld b,h 
0c4e			;    ld c,l 
0c4e			;    add hl,hl \ rl e \ rl d 
0c4e			;    add hl,hl \ rl e \ rl d 
0c4e			;    inc l 
0c4e			;    add hl,bc 
0c4e			;    ld (seed1_0),hl 
0c4e			;    ld hl,(seed1_1) 
0c4e			;    adc hl,de 
0c4e			;    ld (seed1_1),hl 
0c4e			;    ex de,hl 
0c4e			;seed2_0=$+1 
0c4e			;    ld hl,9876 
0c4e			;seed2_1=$+1 
0c4e			;    ld bc,54321 
0c4e			;    add hl,hl \ rl c \ rl b 
0c4e			;    ld (seed2_1),bc 
0c4e			;    sbc a,a 
0c4e			;    and %11000101 
0c4e			;    xor l 
0c4e			;    ld l,a 
0c4e			;    ld (seed2_0),hl 
0c4e			;    ex de,hl 
0c4e			;    add hl,bc 
0c4e			;    ret 
0c4e			; 
0c4e			 
0c4e			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0c4e			; 20 bytes, 86 cycles (excluding ret) 
0c4e			 
0c4e			; returns   hl = pseudorandom number 
0c4e			; corrupts   a 
0c4e			 
0c4e			; generates 16-bit pseudorandom numbers with a period of 65535 
0c4e			; using the xorshift method: 
0c4e			 
0c4e			; hl ^= hl << 7 
0c4e			; hl ^= hl >> 9 
0c4e			; hl ^= hl << 8 
0c4e			 
0c4e			; some alternative shift triplets which also perform well are: 
0c4e			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0c4e			 
0c4e			;  org 32768 
0c4e			 
0c4e			xrnd: 
0c4e 2a d7 fa		  ld hl,(xrandc)       ; seed must not be 0 
0c51 3e 00		  ld a,0 
0c53 bd			  cp l 
0c54 20 02		  jr nz, .xrnd1 
0c56 2e 01		  ld l, 1 
0c58			.xrnd1: 
0c58			 
0c58 7c			  ld a,h 
0c59 1f			  rra 
0c5a 7d			  ld a,l 
0c5b 1f			  rra 
0c5c ac			  xor h 
0c5d 67			  ld h,a 
0c5e 7d			  ld a,l 
0c5f 1f			  rra 
0c60 7c			  ld a,h 
0c61 1f			  rra 
0c62 ad			  xor l 
0c63 6f			  ld l,a 
0c64 ac			  xor h 
0c65 67			  ld h,a 
0c66			 
0c66 22 d7 fa		  ld (xrandc),hl 
0c69			 
0c69 c9			  ret 
