dfcf c5				push bc 
dfd0 0e 01			ld c, $01 
dfd2 f7				rst $30 
dfd3 c1				pop bc 
dfd4 c9				ret 
dfd5			 
dfd5			cinndb: 	 
dfd5			cin: 
dfd5			 
dfd5			 
dfd5 c5				push bc 
dfd6			 
dfd6				; any key waiting to process? 
