28e9			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
28e9			; | | At start the current various registers will be displayed with contents. 
28e9			; | | Top right corner will show the most recent debug marker seen. 
28e9			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
28e9			; | | and the return stack pointer (RSP). 
28e9			; | | Pressing: 
28e9			; | |  
28e9			; | |    1 - Initial screen 
28e9			; | |  
28e9			; | |    2 - Display a data dump of HL 
28e9			; | |  
28e9			; | |    3 - Display a data dump of DE 
28e9			; | |  
28e9			; | |    4 - Display a data dump of BC 
28e9			; | |  
28e9			; | |    5 - Display a data dump of HL 
28e9			; | |  
28e9			; | |    6 - Display a data dump of DSP 
28e9			; | |  
28e9			; | |    7 - Display a data dump of RSP 
28e9			; | |  
28e9			; | |    8 - Display a data dump of what is at DSP 
28e9			; | |  
28e9			; | |    9 - Display a data dump of what is at RSP 
28e9			; | |  
28e9			; | |    0 - Exit monitor and continue running. This will also enable break points 
28e9			; | |  
28e9			; | |    * - Disable break points 
28e9			; | |  
28e9			; | |    # - Enter traditional monitor mode 
28e9			; | |  
28e9			; | | 
28e9			; | | Monitor Mode 
28e9			; | | ------------ 
28e9			; | | A prompt of '>' will be shown for various commands: 
28e9			; | |  
28e9			; | |    D xxxx - Display a data dump starting from hex address xxxx 
28e9			; | |  
28e9			; | |    C - Continue display a data dump from the last set address 
28e9			; | |  
28e9			; | |    M xxxx - Set start of memory edit at address xx 
28e9			; | |  
28e9			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
28e9			; | |  
28e9			; | |    G xxxx - Exec code at specific address 
28e9			; | |  
28e9			; | |    Q - Return to previous 
28e9				if DEBUG_FORTH_WORDS_KEY 
28e9					DMARK "MON" 
28e9				if DEMARK_VERSION = 1  
28e9 e5					push hl  
28ea 21 f2 28				ld hl, .dmark  
28ed 22 9b fd				ld (debug_mark), hl  
28f0				endif  
28f0				if DEMARK_VERSION = 0  
28f0					push af  
28f0					ld a, (.dmark)  
28f0					ld (debug_mark),a  
28f0					ld a, (.dmark+1)  
28f0					ld (debug_mark+1),a  
28f0					ld a, (.dmark+2)  
28f0					ld (debug_mark+2),a  
28f0				endif  
28f0 18 04			jr .pastdmark  
28f2 ..			.dmark: db "MON"  
28f5				if DEMARK_VERSION = 1  
28f5 00					db 0  
28f6				endif  
28f6				if DEMARK_VERSION = 1  
28f6 e1			.pastdmark: pop hl  
28f7				endif  
28f7				if DEMARK_VERSION = 0  
28f7			.pastdmark: pop af  
28f7				endif  
28f7			endm  
# End of macro DMARK
28f7					CALLMONITOR 
28f7				if BASE_CPM=1  
28f7					call debug_vector  
28f7				endif  
28f7				if BASE_KEV=1  
28f7 cf					rst 8  
28f8				endif  
28f8				endm  
# End of macro CALLMONITOR
28f8				endif 
