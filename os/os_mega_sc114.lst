a4d4			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a4d4			; | | At start the current various registers will be displayed with contents. 
a4d4			; | | Top right corner will show the most recent debug marker seen. 
a4d4			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a4d4			; | | and the return stack pointer (RSP). 
a4d4			; | | Pressing: 
a4d4			; | |  
a4d4			; | |    1 - Initial screen 
a4d4			; | |  
a4d4			; | |    2 - Display a data dump of HL 
a4d4			; | |  
a4d4			; | |    3 - Display a data dump of DE 
a4d4			; | |  
a4d4			; | |    4 - Display a data dump of BC 
a4d4			; | |  
a4d4			; | |    5 - Display a data dump of HL 
a4d4			; | |  
a4d4			; | |    6 - Display a data dump of DSP 
a4d4			; | |  
a4d4			; | |    7 - Display a data dump of RSP 
a4d4			; | |  
a4d4			; | |    8 - Display a data dump of what is at DSP 
a4d4			; | |  
a4d4			; | |    9 - Display a data dump of what is at RSP 
a4d4			; | |  
a4d4			; | |    0 - Exit monitor and continue running. This will also enable break points 
a4d4			; | |  
a4d4			; | |    * - Disable break points 
a4d4			; | |  
a4d4			; | |    # - Enter traditional monitor mode 
a4d4			; | |  
a4d4			; | | 
a4d4			; | | Monitor Mode 
a4d4			; | | ------------ 
a4d4			; | | A prompt of '>' will be shown for various commands: 
a4d4			; | |  
a4d4			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a4d4			; | |  
a4d4			; | |    C - Continue display a data dump from the last set address 
a4d4			; | |  
a4d4			; | |    M xxxx - Set start of memory edit at address xx 
a4d4			; | |  
a4d4			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a4d4			; | |  
a4d4			; | |    G xxxx - Exec code at specific address 
a4d4			; | |  
a4d4			; | |    Q - Return to previous 
a4d4				if DEBUG_FORTH_WORDS_KEY 
a4d4					DMARK "MON" 
a4d4				if DEMARK_VERSION = 1  
a4d4 e5					push hl  
a4d5 21 dd a4				ld hl, .dmark  
a4d8 22 60 ee				ld (debug_mark), hl  
a4db				endif  
a4db				if DEMARK_VERSION = 0  
a4db					push af  
a4db					ld a, (.dmark)  
a4db					ld (debug_mark),a  
a4db					ld a, (.dmark+1)  
a4db					ld (debug_mark+1),a  
a4db					ld a, (.dmark+2)  
a4db					ld (debug_mark+2),a  
a4db				endif  
a4db 18 04			jr .pastdmark  
a4dd ..			.dmark: db "MON"  
a4e0				if DEMARK_VERSION = 1  
a4e0 00					db 0  
a4e1				endif  
a4e1				if DEMARK_VERSION = 1  
a4e1 e1			.pastdmark: pop hl  
a4e2				endif  
a4e2				if DEMARK_VERSION = 0  
a4e2			.pastdmark: pop af  
a4e2				endif  
a4e2			endm  
# End of macro DMARK
a4e2					CALLMONITOR 
a4e2				if BASE_CPM=1  
a4e2					call debug_vector  
a4e2				endif  
a4e2				if BASE_KEV=1  
a4e2					rst 8  
a4e2				endif  
a4e2				endm  
# End of macro CALLMONITOR
a4e2				endif 
