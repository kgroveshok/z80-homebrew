1194				cp 0 
1194				ret z 
1194				 
1194				; set the bank number from the result 
1194			 
1194				 
1194					ld c, SPI_CE_HIGH 
1194					ld b, '0'    ; human readable bank number 
1194			 
1194			 
1194					; active low 
1194			 
1194			;		cp 0 
1194					or a 
1194					jr z, .bset 
1194					cp 1 
1194					jr nz, .b2 
1194					res 0, c 
1194					ld b, '1'    ; human readable bank number 
1194			.b2:		cp 2 
1194					jr nz, .b3 
1194					res 1, c 
1194					ld b, '2'    ; human readable bank number 
1194			.b3:		cp 3 
1194					jr nz, .b4 
1194					res 2, c 
1194					ld b, '3'    ; human readable bank number 
1194			.b4:		cp 4 
1194					jr nz, .b5 
1194					res 3, c 
1194					ld b, '4'    ; human readable bank number 
1194			.b5:		cp 5 
1194					jr nz, .bset 
1194					res 4, c 
1194					ld b, '5'    ; human readable bank number 
