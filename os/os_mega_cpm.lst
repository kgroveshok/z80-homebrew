137f			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
137f			;heap_start        .equ  0x9000      ; Starting address of heap 
137f			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
137f			; 
137f			 ;     .org 0 
137f			  ;    jp    main 
137f			; 
137f			; 
137f			 ;     .org  0x100 
137f			;main: 
137f			 ;     ld    HL, 0x8100 
137f			  ;    ld    SP, HL 
137f			; 
137f			;      call  heap_init 
137f			 
137f			      ; Make some allocations 
137f			;      ld    HL, 12 
137f			;      call  malloc            ; Allocates 0x9004 
137f			; 
137f			 ;     ld    HL, 12 
137f			;      call  malloc            ; Allocates 0x9014 
137f			 
137f			;      ld    HL, 12 
137f			;      call  malloc            ; Allocates 0x9024 
137f			 
137f			      ; Free some allocations 
137f			;      ld    HL, 0x9014 
137f			;      call  free 
137f			 
137f			;      ld    HL, 0x9004 
137f			;      call  free 
137f			; 
