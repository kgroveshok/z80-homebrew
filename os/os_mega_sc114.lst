8f01 23			      inc   HL 
8f02 b6			      or    (HL) 
8f03 c2 ab 8f		      jp    NZ, free_done 
8f06			 
8f06 2b			      dec   HL 
8f07			 
8f07 44			      ld    B, H                    ; Copy HL to BC 
8f08 4d			      ld    C, L 
