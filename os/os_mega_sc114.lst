8d44			 
8d44			;Converts an ASCII string to an unsigned 16-bit integer 
8d44			;Quits when it reaches a non-decimal digit 
8d44			 
8d44			string_to_uint16: 
8d44			atoui_16: 
8d44			;Input: 
8d44			;     DE points to the string 
8d44			;Outputs: 
8d44			;     HL is the result 
8d44			;     A is the 8-bit value of the number 
8d44			;     DE points to the byte after the number 
8d44			;Destroys: 
8d44			;     BC 
8d44			;       if the string is non-empty, BC is HL/10 
8d44			;Size:  24 bytes 
8d44			;Speed: 42+d(104+{0,9}) 
8d44			;       d is the number of digits in the number 
8d44			;       max is 640 cycles for a 5 digit number 
8d44			;Assuming no leading zeros: 
8d44			;1 digit:  146cc 
8d44			;2 digit:  250cc 
8d44			;3 digit:  354cc or 363cc (avg: 354.126cc) 
8d44			;4 digit:  458cc or 467cc (avg: 458.27cc) 
8d44			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
8d44			;avg: 544.81158447265625cc (544+13297/16384) 
8d44			;=============================================================== 
8d44 21 00 00		  ld hl,0 
8d47			.u16a: 
8d47 1a			  ld a,(de) 
8d48 d6 30		  sub 30h 
8d4a fe 0a		  cp 10 
8d4c d0			  ret nc 
8d4d 13			  inc de 
8d4e 44			  ld b,h 
8d4f 4d			  ld c,l 
8d50 29			  add hl,hl 
8d51 29			  add hl,hl 
8d52 09			  add hl,bc 
8d53 29			  add hl,hl 
8d54 85			  add a,l 
8d55 6f			  ld l,a 
8d56 30 ef		  jr nc,.u16a 
8d58 24			  inc h 
8d59 c3 47 8d		  jp .u16a 
