24c1 22 9b fd				ld (debug_mark), hl  
24c4				endif  
24c4				if DEMARK_VERSION = 0  
24c4					push af  
24c4					ld a, (.dmark)  
24c4					ld (debug_mark),a  
24c4					ld a, (.dmark+1)  
24c4					ld (debug_mark+1),a  
24c4					ld a, (.dmark+2)  
24c4					ld (debug_mark+2),a  
24c4				endif  
24c4 18 04			jr .pastdmark  
24c6 ..			.dmark: db "HEP"  
24c9				if DEMARK_VERSION = 1  
24c9 00					db 0  
24ca				endif  
24ca				if DEMARK_VERSION = 1  
24ca e1			.pastdmark: pop hl  
24cb				endif  
24cb				if DEMARK_VERSION = 0  
24cb			.pastdmark: pop af  
24cb				endif  
24cb			endm  
