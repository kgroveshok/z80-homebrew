9d94 15				db WORD_SYS_CORE+OPCODE_HEAP             
9d95 ae 9d			dw .HEAP            
9d97 04				db 3 + 1 
9d98 .. 00			db "NEW",0              
9d9c				endm 
# End of macro CWHEAD
9d9c			; | NEW ( -- ) Clears all user words and stack | DONE 
9d9c				 
9d9c				if MALLOC_4 
9d9c					call  heap_init 
9d9c				endif 
9d9c				; reset uword pointers 
9d9c 21 36 d6			ld hl, baseram 
