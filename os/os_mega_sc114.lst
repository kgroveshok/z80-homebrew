d53f cd 4f 87			call delay1s 
d542 cd 6e d6			call cin_wait 
d545						 
d545 fe 2a			cp '*' 
d547 28 5e			jr z, .startupend1 
d549 fe 23			cp '#' 
d54b 20 07			jr nz, .startno 
d54d 3e 01			ld a, 1 
d54f 32 ca e6			ld (os_last_cmd),a 
d552 18 04			jr .startdo 
d554 fe 31		.startno:	cp '1' 
d556 28 3a			jr z,.startnxt  
d558			 
d558				; exec startup line 
