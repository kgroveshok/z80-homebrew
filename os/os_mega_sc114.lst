98ed			; 
98ed			; kernel to the forth OS 
98ed			 
98ed			DS_TYPE_STR: equ 1     ; string type 
98ed			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
98ed			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
98ed			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
98ed			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
98ed			 
98ed			FORTH_PARSEV1: equ 0 
98ed			FORTH_PARSEV2: equ 0 
98ed			FORTH_PARSEV3: equ 0 
98ed			FORTH_PARSEV4: equ 0 
98ed			FORTH_PARSEV5: equ 0 
98ed			FORTH_PARSEV6: equ 1 
98ed			 
98ed			;if FORTH_PARSEV5 
98ed			;	FORTH_END_BUFFER: equ 0 
98ed			;else 
98ed			FORTH_END_BUFFER: equ 127 
98ed			;endif 
98ed			 
98ed			FORTH_TRUE: equ 1 
98ed			FORTH_FALSE: equ 0 
98ed			 
98ed			if FORTH_PARSEV4 
98ed			include "forth_stackops.asm" 
98ed			endif 
98ed			 
