1004 e5			      push  HL                      ; Store the result for later (new block size) 
1005			 
1005 ca 54 10		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1008 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
100a			 
