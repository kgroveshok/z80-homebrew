7284			; handle the auto run of code from files in storage 
7284			 
7284			 
7284			include "forth_startup.asm" 
7284			; Which startup method to use? 
7284			; 
7284			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
7284			; followed by loading of a list of scripts in eeprom 
7284			 
7284			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
7284			; from eeprom 
7284			 
7284			; Select with define in main stubs 
7284			 
7284			if STARTUP_V1 
7284				include "forth_startupv1.asm" 
7284			endif 
7284			if STARTUP_V2 
7284				include "forth_startupv2.asm" 
7284			; Version 2 of the startup  
7284			;  
7284			; Auto load any files in bank 1 that start with a '*' 
7284			; If no se storage then revert to using eprom 
7284			 
7284			 
7284			if STORAGE_SE = 0 
7284			 
7284			sprompt1: db "Startup load...",0 
7284			sprompt2: db "Run? 1=No *=End #=All",0 
7284			 
7284			 
7284			 
7284			 
7284			forth_startup: 
7284				ld hl, startcmds 
7284				ld a, 0 
7284				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
7284			 
7284			.start1:	push hl 
7284				call clear_display 
7284				ld de, sprompt1 
7284			        ld a, display_row_1 
7284				call str_at_display 
7284				ld de, sprompt2 
7284			        ld a, display_row_2 
7284				call str_at_display 
7284				pop hl 
7284				push hl 
7284				ld e,(hl) 
7284				inc hl 
7284				ld d,(hl) 
7284			        ld a, display_row_3 
7284				call str_at_display 
7284				call update_display 
7284			 
7284			 
7284				ld a, (os_last_cmd) 
7284			;	cp 0 
7284				or a 
7284				jr z, .startprompt 
7284				call delay250ms 
7284				jr .startdo 
7284				 
7284				 
7284			 
7284			.startprompt: 
7284			 
7284				ld a,display_row_4 + display_cols - 1 
7284			        ld de, endprg 
7284				call str_at_display 
7284				call update_display 
7284				call delay1s 
7284				call cin_wait 
7284						 
7284				cp '*' 
7284				jr z, .startupend1 
7284				cp '#' 
7284				jr nz, .startno 
7284				ld a, 1 
7284				ld (os_last_cmd),a 
7284				jr .startdo 
7284			.startno:	cp '1' 
7284				jr z,.startnxt  
7284			 
7284				; exec startup line 
7284			.startdo:	 
7284				pop hl 
7284				push hl 
7284				 
7284				ld e,(hl) 
7284				inc hl 
7284				ld d,(hl) 
7284				ex de,hl 
7284			 
7284				push hl 
7284			 
7284				ld a, 0 
7284				;ld a, FORTH_END_BUFFER 
7284				call strlent 
7284				inc hl   ; include zero term to copy 
7284				ld b,0 
7284				ld c,l 
7284				pop hl 
7284				ld de, scratch 
7284				ldir 
7284			 
7284			 
7284				ld hl, scratch 
7284				call forthparse 
7284				call forthexec 
7284				call forthexec_cleanup 
7284			 
7284				ld a, display_row_4 
7284				ld de, endprog 
7284			 
7284				call update_display		 
7284			 
7284				ld a, (os_last_cmd) 
7284			;	cp 0 
7284				or a 
7284				jr nz, .startnxt 
7284				call next_page_prompt 
7284			        call clear_display 
7284				call update_display		 
7284			 
7284				; move onto next startup line? 
7284			.startnxt: 
7284			 
7284				call delay250ms 
7284				pop hl 
7284			 
7284				inc hl 
7284				inc hl 
7284			 
7284				push hl 
7284				ld e, (hl) 
7284				inc hl 
7284				ld d, (hl) 
7284				pop hl 
7284				; TODO replace 0 test 
7284			 
7284				ex de, hl 
7284				call ishlzero 
7284			;	ld a,e 
7284			;	add d 
7284			;	cp 0    ; any left to do? 
7284				ex de, hl 
7284				jp nz, .start1 
7284				jr .startupend 
7284			 
7284			.startupend1: pop hl 
7284			.startupend: 
7284			 
7284				call clear_display 
7284				call update_display 
7284				ret 
7284			endif 
