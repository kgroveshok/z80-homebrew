7730			testlcd:  
7730 3e 00			ld a, kLCD_Line1  
7732 cd ad 76			call fLCD_Pos  
7735 06 28			ld b, 40  
7737 11 65 77			ld de, .ttext1  
773a cd f8 75			call write_len_string  
773d			  
773d 3e 28			ld a, kLCD_Line2  
773f cd ad 76			call fLCD_Pos  
7742 06 28			ld b, 40  
7744 11 8e 77			ld de, .ttext2  
7747 cd f8 75			call write_len_string  
774a 3e 50			ld a, kLCD_Line3  
774c cd ad 76			call fLCD_Pos  
774f 06 28			ld b, 40  
7751 11 b7 77			ld de, .ttext3  
