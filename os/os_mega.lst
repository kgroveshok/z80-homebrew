15fb 00				nop  
15fc 00				nop  
15fd 00				nop  
15fe 00				nop  
15ff				; we high 
15ff d3 00			out (SOUND_DEVICE), a 
1601			;	ld a, 1 
1601			;	call aDelayInMS 
1601 00				nop  
1602 00				nop  
1603 00				nop  
1604 00				nop  
