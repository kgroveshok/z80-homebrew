0f1b			;Comparing Strings 
0f1b			 
0f1b			;IN    HL     Address of string1. 
0f1b			;      DE     Address of string2. 
0f1b			 
0f1b			; doc given but wrong??? 
0f1b			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
0f1b			;      carry  Set if string1 > string2, reset if string1 <= string2. 
0f1b			; tested 
0f1b			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
0f1b			 
0f1b			strcmp_old: 
0f1b e5			    PUSH   HL 
0f1c d5			    PUSH   DE 
0f1d			 
0f1d 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
0f1e be			    CP     (HL)            ; (want to minimize work). 
0f1f 38 01		    JR     C, Str1IsBigger 
0f21 7e			    LD     A, (HL) 
0f22			 
0f22			Str1IsBigger: 
0f22 4f			    LD     C, A             ; Put length in BC 
0f23 06 00		    LD     B, 0 
0f25 13			    INC    DE              ; Increment pointers to meat of string. 
0f26 23			    INC    HL 
0f27			 
0f27			CmpLoop: 
0f27 1a			    LD     A, (DE)          ; Compare bytes. 
0f28 ed a1		    CPI 
0f2a 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
0f2c 13			    INC    DE              ; Update pointer. 
0f2d ea 27 0f		    JP     PE, CmpLoop 
0f30			 
0f30 d1			    POP    DE 
0f31 e1			    POP    HL 
0f32 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
0f33 be			    CP     (HL) 
0f34 c9			    RET 
0f35			 
0f35			NoMatch: 
0f35 2b			    DEC    HL 
0f36 be			    CP     (HL)            ; Compare again to affect carry. 
0f37 d1			    POP    DE 
0f38 e1			    POP    HL 
0f39 c9			    RET 
