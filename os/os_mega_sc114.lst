91d8			free:  
91d8				push hl 
91d8				push af 
91d8				; get address in hl 
91d8			 
91d8					if DEBUG_FORTH_MALLOC_INT 
91d8						DMARK "fre" 
91d8						CALLMONITOR 
91d8					endif 
91d8				; data is at hl - move to block count 
91d8				dec hl 
91d8				dec hl    ; get past pointer 
91d8				dec hl 
91d8			 
91d8				ld a, (hl)    ; need this for a validation check 
91d8			 
91d8				dec hl    ; move to block marker 
91d8			 
91d8				; now check that the block count and block marker are the same  
91d8			        ; this checks that we are on a malloc node and not random memory 
91d8			        ; OK a faint chance this could be a problem but rare - famous last words! 
91d8			 
91d8				ld c, a 
91d8				ld a, (hl)    
91d8			 
91d8				cp c 
91d8				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
91d8			 
91d8				; yes good chance we are on a malloc node 
91d8			 
91d8			;	ld a, 0      
91d8				ld (hl), 0   ; mark as free 
91d8			 
91d8				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
91d8			 
91d8			.freeignore:  
91d8			 
91d8				pop af 
91d8				pop hl 
91d8			 
91d8				ret 
91d8			 
91d8			 
91d8			 
91d8			endif 
