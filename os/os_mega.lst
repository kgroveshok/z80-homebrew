0d78			; 
0d78			;       sla e        ;128 
0d78			;       rl d         ;128 
0d78			;       adc hl,hl    ;240 
0d78			;       sbc hl,bc    ;240 
0d78			;       jr nc,.DivLoop ;23|21 
0d78			;       inc e        ;-- 
0d78			;       jp .DivLoop+1 
0d78			; 
0d78			;.DivLoopEnd: 
0d78			 
0d78			;HL_Div_C: 
0d78			;Inputs: 
0d78			;     HL is the numerator 
0d78			;     C is the denominator 
0d78			;Outputs: 
0d78			;     A is the remainder 
0d78			;     B is 0 
0d78			;     C is not changed 
0d78			;     DE is not changed 
0d78			;     HL is the quotient 
0d78			; 
0d78			;       ld b,16 
0d78			;       xor a 
0d78			;         add hl,hl 
0d78			;         rla 
0d78			;         cp c 
0d78			;         jr c,$+4 
0d78			;           inc l 
0d78			;           sub c 
0d78			;         djnz $-7 
