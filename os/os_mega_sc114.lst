9104			; Listen to the start of a tape header and calculate pulse lengths and confirm can read 
9104			 
9104			tape_calibration: 
9104 cd 43 90				call tape_ready_load 
9107			 
9107				; start a counter for 1s max length of header 
9107			 
9107			 
9107				; init sync fields 
9107			 
9107 21 49 ea			ld hl, tape_sync 
910a 3e 00			ld a, 0 
910c 77				ld (hl), a 
910d 11 4a ea			ld de, tape_sync+1 
9110 01 0a 00			ld bc, 10 
9113 ed b0			ldir 
9115			 
9115 cd 40 91			call tape_detect 
9118			 
9118 16 00			ld d, 0 
911a 3a 49 ea			ld a, (tape_sync) 
911d 5f				ld e, a 
911e 21 a5 e2		        ld hl, scratch 
9121 cd 41 8d			call uitoa_16 
9124 eb				ex de, hl 
9125 3e 00			ld a, 0	 
9127 cd 22 88			call  str_at_display 
912a 16 00			ld d, 0 
912c 3a 4a ea			ld a, (tape_sync+1) 
912f 5f				ld e, a 
9130 21 a5 e2		        ld hl, scratch 
9133 cd 41 8d			call uitoa_16 
9136 eb				ex de,hl 
9137 3e 05			ld a, 5 
9139 cd 22 88			call  str_at_display 
913c cd 32 88			call update_display 
913f			 
913f c9				ret 
