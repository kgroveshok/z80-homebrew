6955			; Alphanumeric LCD functions used  
6955			; no need to specify specific functions for this module  
6955			  
6955 3e cf		            LD   A, 11001111b  
6957 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
6959 3e 00		            LD   A, 00000000b  
695b d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
695d			  
695d			; Initialise alphanumeric LCD module  
695d 3e 00				ld a, 0  
695f 32 fb fa				ld (display_lcde1e2), a  
6962 cd e3 69		            CALL fLCD_Init      ;Initialise LCD module  
6965 3e 01				ld a, 1  
6967 32 fb fa				ld (display_lcde1e2), a  
696a cd e3 69		            CALL fLCD_Init      ;Initialise LCD module  
696d			  
696d c9				ret  
