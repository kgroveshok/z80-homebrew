1d48			; the core word dictionary v4 
1d48			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
1d48			 
1d48			; this is a linked list for each of the system words used 
1d48			; user defined words will follow the same format but will be in ram 
1d48			 
1d48			 
1d48			; 
1d48			; 
1d48			; define linked list: 
1d48			; 
1d48			; 1. compiled byte op code 
1d48			; 2. len of text word 
1d48			; 3. text word 
1d48			; 4. ptr to next dictionary word 
1d48			; 5. asm, calls etc for the word 
1d48			; 
1d48			;  if 1 == 0 then last word in dict  
1d48			;   
1d48			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
1d48			;  
1d48			;  
1d48			; create basic standard set of words 
1d48			; 
1d48			;  
1d48			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
1d48			; 2DUP 2DROP 2SWAP  
1d48			; @ C@ - get byte  
1d48			; ! C! - store byte 
1d48			; 0< true if less than zero 
1d48			; 0= true if zero 
1d48			; < >  
1d48			; = true if same 
1d48			; variables 
