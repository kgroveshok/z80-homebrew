0f1f 13			  inc de 
0f20			 
0f20 7d			  ld a,l 
0f21 26 3a		  ld h,'9'+1 
0f23 25			  dec h  
0f24 c6 0a		  add a,10  
0f26 30 fb		   jr nc,$-3 
0f28 c6 30		  add a,'0' 
