15a9			SIOA_D: equ    Device_Dart    ;SIO CHANNEL A DATA REGISTER 
15a9			SIOA_C: equ    Device_Dart+2    ;SIO CHANNEL A CONTROL REGISTER 
15a9			SIOB_D: equ    Device_Dart+1    ;SIO CHANNEL B DATA REGISTER 
15a9			SIOB_C: equ    Device_Dart+3    ;SIO CHANNEL B CONTROL REGISTER 
15a9			 
15a9			dart_init:  
15a9			; init Z80 SIO A 
15a9			; Z80 SIO Register Mnemonics 
15a9			 
15a9			; TODO CHANGEME 
15a9			;;// initialize SIO port A CLK 1X 8N1 
15a9			 
15a9			; TODO CHANGEME 
15a9			 
15a9 3e 00		        LD A,00H                ;REQUEST REGISTER #0 
15ab d3 02		        OUT (SIOA_C),A 
15ad 3e 18		        LD A,18H                ;LOAD #0 WITH 18H - CHANNEL RESET 
15af d3 02		    	OUT (SIOA_C),A 
15b1			; 
15b1 3e 01		        LD A,01H 
15b3 d3 02		        OUT (SIOA_C),A 
15b5 3e 00		        LD A,00H 
15b7 d3 02		    	OUT (SIOA_C),A 
15b9			; 
15b9 3e 04			    LD A,04H                ;REQUEST TRANSFER TO REGISTER #4 
15bb d3 02			    OUT (SIOA_C),A 
15bd 3e c4		        LD A,0C4H               ;WRITE #4 WITH X/0 CLOCK 1X STOP BIT 
15bf d3 02		        OUT (SIOA_C),A          ;  AND NO PARITY 
15c1			; 
15c1 3e 03		        LD A,03H                ;REQUEST TRANSFER TO REGISTER #3 
15c3 d3 02		        OUT (SIOA_C),A 
15c5 3e c1		        LD A,0C1H 
15c7 d3 02		        OUT (SIOA_C),A          ;WRITE #3 WITH COH - RECEIVER 8 BITS & RX ENABLE 
15c9			; 
15c9 3e 05		        LD A,05H                ;REQUEST TRANSFER TO REGISTER #5 
15cb d3 02		        OUT (SIOA_C),A 
15cd 3e 68		        LD A,068H 
15cf d3 02		        OUT (SIOA_C),A          ;WRITE #5 WITH 60H - TRANSMIT 8 BITS & TX ENABLE 
15d1			 
15d1			        ;SETUP PORT B 
15d1 3e 00		        LD A,00H                ;REQUEST REGISTER #0 
15d3 d3 03		        OUT (SIOB_C),A 
15d5 3e 18		        LD A,018H                ;LOAD #0 WITH 18H - CHANNEL RESET 
15d7 d3 03			    OUT (SIOB_C),A 
15d9 c9				ret 
