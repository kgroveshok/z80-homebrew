115e			config_fdir: 
115e				; using the scratch dir go through and release the memory allocated for each string 
115e				 
115e				ld hl, scratch 
115e			.cfdir:	ld e,(hl) 
115e				inc hl 
115e				ld d,(hl) 
115e				inc hl 
115e			 
115e				ex de, hl 
115e				call ishlzero 
115e				ret z     ; return on null pointer 
115e				call free 
115e				ex de, hl 
115e				jr .cfdir 
115e			 
115e			 
115e				ret 
