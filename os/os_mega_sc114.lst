9e70			.HEAP: 
9e70			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9e70 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e71 9e 9e			dw .EXEC            
9e73 05				db 4 + 1 
9e74 .. 00			db "HEAP",0              
9e79				endm 
# End of macro CWHEAD
9e79			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9e79			; | | u1 - Current number of bytes in the heap 
9e79			; | | u2 - Remaining bytes left on the heap 
9e79			; | |  
9e79			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9e79			 
9e79			 
9e79				if DEBUG_FORTH_WORDS_KEY 
9e79					DMARK "HEP" 
9e79				if DEMARK_VERSION = 1  
9e79 e5					push hl  
9e7a 21 82 9e				ld hl, .dmark  
9e7d 22 60 ee				ld (debug_mark), hl  
9e80				endif  
9e80				if DEMARK_VERSION = 0  
9e80					push af  
9e80					ld a, (.dmark)  
9e80					ld (debug_mark),a  
9e80					ld a, (.dmark+1)  
9e80					ld (debug_mark+1),a  
9e80					ld a, (.dmark+2)  
9e80					ld (debug_mark+2),a  
9e80				endif  
9e80 18 04			jr .pastdmark  
9e82 ..			.dmark: db "HEP"  
9e85				if DEMARK_VERSION = 1  
9e85 00					db 0  
9e86				endif  
9e86				if DEMARK_VERSION = 1  
9e86 e1			.pastdmark: pop hl  
9e87				endif  
9e87				if DEMARK_VERSION = 0  
9e87			.pastdmark: pop af  
9e87				endif  
9e87			endm  
