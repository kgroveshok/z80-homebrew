6295			  
6295			; **********************************************************************  
6295			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6295			; **********************************************************************  
6295			;  
6295			; **  Written as a Small Computer Monitor App   
6295			; **  Version 0.1 SCC 2018-05-16  
6295			; **  www.scc.me.uk  
6295			;  
6295			; **********************************************************************  
6295			;  
6295			; This module provides support for alphanumeric LCD modules using with  
6295			; *  HD44780 (or compatible) controller  
6295			; *  5 x 7 pixel fonts  
6295			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6295			; *  Interface via six digital outputs to the display (see below)  
6295			;  
6295			; LCD module pinout:  
6295			;   1  Vss   0v supply  
6295			;   2  Vdd   5v supply  
6295			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6295			;   4  RS    High = data, Low = instruction  
6295			;   5  R/W   High = Read, Low = Write  
6295			;   6  E     Enable signal (active high)  
6295			;   7  DB0   Data bit 0  
6295			;   8  DB1   Data bit 1  
6295			;   9  DB2   Data bit 2  
6295			;  10  DB3   Data bit 3  
6295			;  11  DB4   Data bit 4  
6295			;  12  DB5   Data bit 5  
6295			;  13  DB6   Data bit 6  
6295			;  14  DB7   Data bit 7  
6295			;  15  A     Backlight anode (+)  
6295			;  16  K     Backlight cathode (-)  
6295			;  
6295			; This interfacing method uses 4-bit data mode and uses time delays  
6295			; rather than polling the display's ready status. As a result the   
6295			; interface only requires 6 simple output lines:  
6295			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6295			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6295			;   LCD DB4 = Microcomputer output port bit 4  
6295			;   LCD DB5 = Microcomputer output port bit 5  
6295			;   LCD DB6 = Microcomputer output port bit 6  
6295			;   LCD DB7 = Microcomputer output port bit 7  
6295			; Display's R/W is connected to 0v so it is always in write mode  
6295			; All 6 connections must be on the same port address <kLCDPrt>  
6295			; This method also allows a decent length of cable from micro to LCD  
6295			;  
6295			; **********************************************************************  
6295			;  
6295			; To include the code for any given function provided by this module,   
6295			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6295			; the parent source file.  
6295			; For example:  #REQUIRES   uHexPrefix  
6295			;  
6295			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6295			; in the parent source file.  
6295			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6295			;  
6295			; These are the function names provided by this module:  
6295			; fLCD_Init                     ;Initialise LCD  
6295			; fLCD_Inst                     ;Send instruction to LCD  
6295			; fLCD_Data                     ;Send data byte to LCD  
6295			; fLCD_Pos                      ;Position cursor  
6295			; fLCD_Str                      ;Display string  
6295			; fLCD_Def                      ;Define custom character  
6295			;  
6295			; **********************************************************************  
6295			;  
6295			; Requires SCMonAPI.asm to also be included in the project  
6295			;  
6295			  
6295			  
6295			; **********************************************************************  
6295			; **  Constants  
6295			; **********************************************************************  
6295			  
6295			; Constants that must be defined externally  
6295			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6295			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6295			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6295			;kLCDWidth: EQU 20             ;Width in characters  
6295			  
6295			; general line offsets in any frame buffer  
6295			  
6295			  
6295			display_row_1: equ 0  
6295			display_row_2: equ display_row_1+display_cols  
6295			display_row_3: equ display_row_2 + display_cols  
6295			display_row_4: equ display_row_3 + display_cols  
6295			;display_row_4_eol:   
6295			  
6295			  
6295			; Cursor position values for the start of each line  
6295			  
6295			; E  
6295			kLCD_Line1: EQU 0x00   
6295			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6295			; E1  
6295			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6295			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6295			  
6295			; Instructions to send as A register to fLCD_Inst  
6295			kLCD_Clear: EQU 00000001b     ;LCD clear  
6295			kLCD_Off:   EQU 00001000b     ;LCD off  
6295			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6295			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6295			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6295			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6295			  
6295			; Constants used by this code module  
6295			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6295			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6295			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6295			  
6295			  
6295			  
6295			; **********************************************************************  
6295			; **  LCD support functions  
6295			; **********************************************************************  
6295			  
6295			; Initialise alphanumeric LCD module  
6295			; LCD control register codes:  
6295			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6295			;   N    0 = 1-line mode       1 = 2-line mode  
6295			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6295			;   D    0 = Display off       1 = Display on  
6295			;   C    0 = Cursor off        1 = Cursor on  
6295			;   B    0 = Blinking off      1 = Blinking on  
6295			;   ID   0 = Decrement mode    1 = Increment mode  
6295			;   SH   0 = Entire shift off  1 = Entire shift on  
6295 3e 28		fLCD_Init:  LD   A, 40  
6297 cd bc 63		            CALL LCDDelay       ;Delay 40ms after power up  
629a			; For reliable reset set 8-bit mode - 3 times  
629a cd 8c 63		            CALL WrFn8bit       ;Function = 8-bit mode  
629d cd 8c 63		            CALL WrFn8bit       ;Function = 8-bit mode  
62a0 cd 8c 63		            CALL WrFn8bit       ;Function = 8-bit mode  
62a3			; Set 4-bit mode  
62a3 cd 88 63		            CALL WrFn4bit       ;Function = 4-bit mode  
62a6 cd ba 63		            CALL LCDDelay1      ;Delay 37 us or more  
62a9			; Function set  
62a9 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
62ab cd be 62		            CALL fLCD_Inst      ;2 line, display on  
62ae			; Display On/Off control  
62ae 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
62b0 cd be 62		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
62b3			; Display Clear  
62b3 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
62b5 cd be 62		            CALL fLCD_Inst      ;Clear display  
62b8			; Entry mode  
62b8 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
62ba cd be 62		            CALL fLCD_Inst      ;Increment mode, shift off  
62bd			; Display module now initialised  
62bd c9			            RET  
62be			; ok to here  
62be			  
62be			; Write instruction to LCD  
62be			;   On entry: A = Instruction byte to be written  
62be			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
62be f5			fLCD_Inst:  PUSH AF  
62bf f5			            PUSH AF  
62c0 cd d2 62		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
62c3 f1			            POP  AF  
62c4 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
62c5 17			            RLA  
62c6 17			            RLA  
62c7 17			            RLA  
62c8 cd d2 62		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
62cb 3e 02		            LD   A, 2  
62cd cd bc 63		            CALL LCDDelay       ;Delay 2 ms to complete   
62d0 f1			            POP  AF  
62d1 c9			            RET  
62d2			Wr4bits:   
62d2 f5					push af  
62d3 3a fb fa				ld a, (display_lcde1e2)  
62d6 fe 00				cp 0     ; e  
62d8 20 10				jr nz, .wea2	  
62da f1					pop af  
62db e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
62dd d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
62df cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
62e1 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
62e3 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
62e5 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
62e7 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
62e9 c9			            RET  
62ea f1			.wea2:		pop af  
62eb e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
62ed d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
62ef cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
62f1 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
62f3 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
62f5 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
62f7 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
62f9 c9			            RET  
62fa			  
62fa			  
62fa			; Write data to LCD  
62fa			;   On entry: A = Data byte to be written  
62fa			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
62fa f5			fLCD_Data:  PUSH AF  
62fb f5			            PUSH AF  
62fc cd 0e 63		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
62ff f1			            POP  AF  
6300 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6301 17			            RLA  
6302 17			            RLA  
6303 17			            RLA  
6304 cd 0e 63		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6307 3e 96		            LD   A, 150  
6309 3d			Wait:      DEC  A              ;Wait a while to allow data   
630a 20 fd		            JR   NZ, Wait      ;  write to complete  
630c f1			            POP  AF  
630d c9			            RET  
630e			Wr4bitsa:     
630e f5					push af  
630f 3a fb fa				ld a, (display_lcde1e2)  
6312 fe 00				cp 0     ; e1  
6314 20 16				jr nz, .we2	  
6316 f1					pop af  
6317 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6319 cb d7		            SET  kLCDBitRS, A  
631b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
631d cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
631f cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6321 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6323 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6325 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6327 cb 97		            RES  kLCDBitRS, A  
6329 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
632b c9			            RET  
632c f1			.we2:		pop af  
632d e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
632f cb d7		            SET  kLCDBitRS, A  
6331 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6333 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6335 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6337 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6339 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
633b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
633d cb 97		            RES  kLCDBitRS, A  
633f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6341 c9			            RET  
6342			  
6342			  
6342			; Position cursor to specified location  
6342			;   On entry: A = Cursor position  
6342			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6342 f5			fLCD_Pos:   PUSH AF  
6343					; at this point set the E1 or E2 flag depending on position  
6343			  
6343 c5					push bc  
6344			;		push af  
6344 06 00				ld b, 0  
6346 4f					ld c, a  
6347 3e 4f				ld a, kLCD_Line3-1  
6349 b7			 		or a      ;clear carry flag  
634a 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
634b 38 04				jr c, .pe1  
634d			  
634d					; E selection  
634d cb 80				res 0, b         ; bit 0 unset e  
634f			;		pop af    ; before line 3 so recover orig pos  
634f			;		ld c, a    ; save for poking back  
634f 18 06				jr .peset	          
6351			.pe1:          	; E2 selection  
6351 cb c0				set 0, b         ; bit 0 set e1  
6353 79					ld a, c  
6354 de 4f				sbc a, kLCD_Line3-1  
6356 4f					ld c, a	         ; save caculated offset  
6357			;		pop af     ; bin this original value now we have calculated form  
6357			  
6357			.peset:		; set bit  
6357 78					ld a, b  
6358 32 fb fa				ld (display_lcde1e2), a 	  
635b 79					ld a, c  
635c c1					pop bc  
635d			  
635d f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
635f cd be 62		            CALL fLCD_Inst      ;Write instruction to LCD  
6362 f1			            POP  AF  
6363 c9			            RET  
6364			  
6364			  
6364			; Output text string to LCD  
6364			;   On entry: DE = Pointer to null terminated text string  
6364			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6364 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6365 b7			            OR   A              ;Null terminator?  
6366 c8			            RET  Z              ;Yes, so finished  
6367 cd fa 62		            CALL fLCD_Data      ;Write character to display  
636a 13			            INC  DE             ;Point to next character  
636b 18 f7		            JR   fLCD_Str       ;Repeat  
636d c9					ret  
636e			  
636e			; Define custom character  
636e			;   On entry: A = Character number (0 to 7)  
636e			;             DE = Pointer to character bitmap data  
636e			;   On exit:  A = Next character number  
636e			;             DE = Next location following bitmap  
636e			;             BC HL IX IY I AF' BC' DE' HL' preserved  
636e			; Character is   
636e c5			fLCD_Def:   PUSH BC  
636f f5			            PUSH AF  
6370 07			            RLCA                ;Calculate location  
6371 07			            RLCA                ;  for bitmap data  
6372 07			            RLCA                ;  = 8 x CharacterNumber  
6373 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6375 cd be 62		            CALL fLCD_Inst      ;Write instruction to LCD  
6378 06 00		            LD   B, 0  
637a 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
637b cd fa 62		            CALL fLCD_Data      ;Write byte to display  
637e 13			            INC  DE             ;Point to next byte  
637f 04			            INC  B              ;Count bytes  
6380 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6382 28 f6		            JR   Z, Loop       ;No, so repeat  
6384 f1			            POP  AF  
6385 3c			            INC  A              ;Increment character number  
6386 c1			            POP  BC  
6387 c9			            RET  
