9884			; 
9884			; kernel to the forth OS 
9884			 
9884			DS_TYPE_STR: equ 1     ; string type 
9884			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
9884			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
9884			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
