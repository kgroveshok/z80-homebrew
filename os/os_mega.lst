69d4			;            DB  01110b  
69d4			;            DB  11011b  
69d4			;            DB  10001b  
69d4			;            DB  10001b  
69d4			;            DB  11111b  
69d4			;            DB  11111b  
69d4			;            DB  11111b  
69d4			;            DB  11111b  
69d4			;; Character 0x01 = Bluetooth icon  
69d4			;            DB  01100b  
69d4			;            DB  01010b  
69d4			;            DB  11100b  
69d4			;            DB  01000b  
69d4			;            DB  11100b  
69d4			;            DB  01010b  
69d4			;            DB  01100b  
