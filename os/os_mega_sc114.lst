bf3d				endm 
# End of macro CWHEAD
bf3d			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bf3d			; | 
bf3d			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bf3d			; | |  
bf3d			; | | e.g. 
bf3d			; | |         #30 a var ! 
bf3d			; | |         a var @ . 
bf3d			; | |   
bf3d			; | |     Displays the number 30 
bf3d			; | | 
bf3d			; | | Each variable pointer is a word so can use for any words that use that:  
bf3d			; | |  
bf3d			; | | e.g. 
bf3d			; | |  
bf3d			; | |         #30 a var 2! 
bf3d			; | |         a var 2@ . 
bf3d			; | |   
bf3d			; | |     Displays the number 30 
bf3d			; | |  
bf3d			; | | > [!NOTE]  
bf3d			; ! | > If a full string is passed then only the first char is looked at 
bf3d			; | | > Any other char could exceed bounds checks!  
bf3d			; | | > 
bf3d			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bf3d			 
bf3d					if DEBUG_FORTH_WORDS_KEY 
bf3d						DMARK "VAR" 
bf3d				if DEMARK_VERSION = 1  
bf3d e5					push hl  
bf3e 21 46 bf				ld hl, .dmark  
bf41 22 60 ee				ld (debug_mark), hl  
bf44				endif  
bf44				if DEMARK_VERSION = 0  
bf44					push af  
bf44					ld a, (.dmark)  
bf44					ld (debug_mark),a  
bf44					ld a, (.dmark+1)  
bf44					ld (debug_mark+1),a  
bf44					ld a, (.dmark+2)  
bf44					ld (debug_mark+2),a  
bf44				endif  
bf44 18 04			jr .pastdmark  
bf46 ..			.dmark: db "VAR"  
bf49				if DEMARK_VERSION = 1  
bf49 00					db 0  
bf4a				endif  
bf4a				if DEMARK_VERSION = 1  
bf4a e1			.pastdmark: pop hl  
bf4b				endif  
bf4b				if DEMARK_VERSION = 0  
bf4b			.pastdmark: pop af  
bf4b				endif  
bf4b			endm  
# End of macro DMARK
bf4b						CALLMONITOR 
bf4b				if BASE_CPM=1  
bf4b					call debug_vector  
bf4b				endif  
bf4b				if BASE_KEV=1  
bf4b					rst 8  
bf4b				endif  
bf4b				endm  
# End of macro CALLMONITOR
bf4b					endif 
