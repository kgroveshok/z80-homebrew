0fb1			; 
0fb1			; Get a byte in hexadecimal notation. The result is returned in A. Since 
0fb1			; the routine get_nibble is used only valid characters are accepted - the  
0fb1			; input routine only accepts characters 0-9a-f. 
0fb1			; 
0fb1 c5			get_byte:        push    bc              ; Save contents of B (and C) 
0fb2 7e					ld a,(hl) 
0fb3 23					inc hl 
0fb4 cd d9 0f		                call    nibble2val      ; Get upper nibble 
0fb7 cb 07		                rlc     a 
0fb9 cb 07		                rlc     a 
0fbb cb 07		                rlc     a 
0fbd cb 07		                rlc     a 
0fbf 47			                ld      b, a            ; Save upper four bits 
0fc0 7e					ld a,(hl) 
0fc1 cd d9 0f		                call    nibble2val      ; Get lower nibble 
0fc4 b0			                or      b               ; Combine both nibbles 
0fc5 c1			                pop     bc              ; Restore B (and C) 
0fc6 c9			                ret 
