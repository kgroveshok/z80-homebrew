2055			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
2055			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
2055			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
2055			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
2055			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
2055			WORD_SYS_END: equ 0   ; Opcode for all user words 
2055			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
2055			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
2055			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
2055			 
2055			; Core word preamble macro 
2055			 
2055			CWHEAD:   macro nxtword opcode lit len opflags 
2055				db WORD_SYS_CORE+opcode             
2055				; internal op code number 
2055				dw nxtword            
2055				; link to next dict word block 
2055				db len + 1 
2055				; literal length of dict word inc zero term 
2055				db lit,0              
2055				; literal dict word 
2055			        ; TODO db opflags        
2055				endm 
