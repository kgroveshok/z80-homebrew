20be					inc hl 
20be					ld d, (hl) 
20be			 
20be					ex de, hl 
20be					call free 
20be			 
20be					pop hl 
20be					pop de 
20be			 
20be			 
20be				endif 
20be			 
20be			 
20be 2b				dec hl 
