1d7f			; 
1d7f			; 
1d7f			; define linked list: 
1d7f			; 
1d7f			; 1. compiled byte op code 
1d7f			; 2. len of text word 
1d7f			; 3. text word 
1d7f			; 4. ptr to next dictionary word 
1d7f			; 5. asm, calls etc for the word 
1d7f			; 
1d7f			;  if 1 == 0 then last word in dict  
1d7f			;   
1d7f			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
1d7f			;  
1d7f			;  
1d7f			; create basic standard set of words 
1d7f			; 
1d7f			;  
1d7f			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
1d7f			; 2DUP 2DROP 2SWAP  
1d7f			; @ C@ - get byte  
1d7f			; ! C! - store byte 
1d7f			; 0< true if less than zero 
1d7f			; 0= true if zero 
1d7f			; < >  
1d7f			; = true if same 
