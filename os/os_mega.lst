00a0			; memory allocation   
00a0			  
00a0			chk_stund: equ tos+2           ; underflow check word  
00a0			chk_stovr: equ chk_stund-stacksize -2; overflow check word  
00a0			  
00a0			; keyscan table needs rows x cols buffer  
00a0			;key_rows: equ 5     ; TODO move out to mini and maxi + 1 null  
00a0			;key_cols: equ 10    ; TODO move out to mini and maxi + 1 null  
00a0			  
00a0			key_macroroot:  equ chk_stovr - 2       ; root ptr for start of keyboard macro strings  
00a0			key_macrolast:  equ key_macroroot - 2   ; last macro defined to aid linked list ptr  
00a0			;  
00a0			; Macro linked list format  
00a0			; key code single byte   
00a0			; ptr to next or zero if last in the list  
00a0			; zero term string   
00a0			  
00a0			;keyscan_table_row1: equ chk_stovr -key_cols-1  
00a0			keyscan_table_row1: equ key_macrolast -key_cols-1  
00a0			keyscan_table_row2: equ keyscan_table_row1-key_cols-1  
00a0			keyscan_table_row3: equ keyscan_table_row2-key_cols-1  
00a0			keyscan_table_row4: equ keyscan_table_row3-key_cols-1  
00a0			keyscan_table_row5: equ keyscan_table_row4-key_cols-1  
00a0			keyscan_table: equ keyscan_table_row5-(key_cols*key_rows)-1  
00a0			keyscan_scancol: equ keyscan_table-key_cols  
00a0			;keyscan_table_len: equ key_rows*key_cols  
00a0			;keybufptr: equ keyscan_table - 2  
00a0			;keysymbol: equ keybufptr - 1  
00a0			key_held: equ keyscan_scancol-1	; currently held  
00a0			key_held_prev: equ key_held - 1   ; previously held (to detect bounce and cycle of key if required)  
00a0			key_repeat_ct: equ key_held_prev - 4 ; timers (two words)  
00a0			key_fa: equ key_repeat_ct -1 ;  
00a0			key_fb: equ key_fa -1 ;  
00a0			key_fc: equ key_fb -1 ;  
00a0			key_fd: equ key_fc -1 ;  
00a0			key_face_held: equ key_fd - 1   
00a0			; flag for enabling/disabling various hardware diag loading via block 0 on bank 1  
00a0			  
00a0			hardware_config: equ key_face_held - 10  
00a0			  
00a0			; hardware config switches  
00a0			; TODO add bitmasks on includes for hardware  
00a0			; high byte for expansion ids  
00a0			;     0000 0000  no card inserted  
00a0			;     0000 0001  storage card inserted  
00a0			;     0000 0010  spi sd card active  
00a0			  
00a0			;       
00a0			; low byte:  
00a0			;     0000 0001   4x4 keypad  
00a0			;     0000 0010   full keyboard  
00a0			;     0000 0011   spi/ext keyboard  
00a0			;     0000 0100   20x4 lcd  
00a0			;     0000 1000   40x4 lcd  
00a0			;     0000 1100   spi/ext display  
00a0			;     0001 0000   ide interface available  
00a0			  
00a0			hardware_word: equ hardware_config - 2  
00a0			  
00a0			; debug marker - optional display of debug point on the debug screens  
00a0			  
00a0			nmi_vector:  equ hardware_word - 3   ; vector to the nmi handler  
00a0			debug_vector:  equ nmi_vector - 3   ; vector to the debug handler  
00a0			parse_vector:  equ debug_vector - 3 ; vector to the parser vector  
00a0			  
00a0			debug_umark: equ parse_vector - 6  ; current user mark  
00a0			  
00a0			if DEMARK_VERSION = 1  
00a0			debug_mark: equ debug_umark - 2    ; internal word debug points - pointer to the string to print  
00a0			endif  
00a0			if DEMARK_VERSION = 0  
00a0			debug_mark: equ debug_umark - 4    ; internal word debug points - poke a four char string with zero term  
00a0			endif  
00a0			  
00a0			; input_str vars  
00a0			input_ptr:  equ debug_mark - 2    ; ptr to the current cursor position of string currently being edited  on entry starting   
00a0			input_start:  equ input_ptr - 2    ; ptr to the start of string   
00a0			input_size: equ input_start -1  ; number of chars  
00a0			input_display_size: equ input_size -1  ; TODO number of chars that are displayable. if < input_size then scroll   
00a0			input_at_pos: equ input_display_size - 1 ; frame buffer offset for start of input  
00a0			input_under_cursor: equ input_at_pos - 1 ; char under the cursor so we can blink it  
00a0			input_at_cursor: equ input_under_cursor - 1 ; offset of cursor to current start of string  
00a0			input_cur_flash: equ input_at_cursor - 2 ;  timeout for cursor flash  
00a0			input_cur_onoff: equ input_cur_flash - 1 ;  cursor blink on or off  
00a0			input_len: equ input_cur_onoff - 5 ; length of current input  
00a0			input_cursor: equ input_len - 5 ; offset of cursor to current start of string  
00a0			  
00a0			; cursor blink rate  
00a0			CUR_BLINK_RATE: equ $09  
00a0			;CUR_BLINK_RATE: equ 15  
00a0			  
00a0			key_actual_pressed: equ input_cursor - 1   
00a0			key_symbol: equ key_actual_pressed - 1   
00a0			key_shift: equ key_symbol - 1   
00a0			  
00a0			; Display allocation  
00a0			  
00a0			;display_rows: equ 4     ; move out to mini and mega files  
00a0			;display_cols: equ 20  
00a0			  
00a0			display_fb_len: equ display_rows*display_cols  
00a0			  
00a0			; primary frame buffer     
00a0			display_fb0: equ  key_shift-display_fb_len -1 ; -display_fb_len-1          ; cli input     TODO why is that doubling up?  
00a0			; working frame buffers  
00a0			display_fb1: equ  display_fb0-display_fb_len -1 ; -display_fb_len-1          ; default running program  
00a0			display_fb3: equ  display_fb1-display_fb_len - 1  
00a0			display_fb2: equ  display_fb3-display_fb_len - 1  
00a0			;  
00a0			; pointer to active frame buffer  
00a0			display_fb_active: equ display_fb2 - 2  
00a0			display_lcde1e2: equ display_fb_active - 1         ; 0=e1, 1=e2   For E1/E2 selection when using the lcd 4x40 display  
00a0			display_write_tmp: equ display_lcde1e2 - 2  
00a0			display_active:  equ display_write_tmp-3   ; current state of activity char (plus room to write string)  
00a0			  
00a0			;  
00a0			  
00a0			;; can load into de directory  
00a0			cursor_col: equ display_active-1  
00a0			cursor_row: equ cursor_col-1  
00a0			cursor_ptr: equ cursor_row - 1     ;  actual offset into lcd memory for row and col combo  
00a0			cursor_shape: equ cursor_ptr - 2   ; char used for the current cursor   
00a0			  
00a0			; maths vars  
00a0			  
00a0			LFSRSeed: equ cursor_shape -20   
00a0			randData: equ LFSRSeed - 2  
00a0			xrandc: equ randData - 2  
00a0			stackstore: equ xrandc - 2  
00a0			seed1: equ  stackstore -2   
00a0			seed2: equ seed1 - 2  
00a0			  
00a0			; cf storage vars  
00a0			  
00a0			iErrorNum:  equ seed2-1         ;Error number  
00a0			iErrorReg:  equ iErrorNum -1              ;Error register  
00a0			iErrorVer:  equ iErrorReg - 1              ;Verify error flag  
00a0			  
00a0			store_bank_active: equ iErrorVer - (5 + 8 ) 		; TODO not used.  indicator of which storage banks are available to use 5 on board and 8 in cart  
00a0			  
00a0			STORE_BLOCK_LOG:  equ   280      ; TODO remove.... Logical block size     
00a0			  
00a0			store_page: equ store_bank_active-STORE_BLOCK_LOG-1            ; bigger than page size for eeprom so we can join multiple blocks if they are continuation records  
00a0			;?????store_ffpage: equ store_page-STORE_BLOCK_LOG            ; page size for eeprom?????  
00a0			store_readptr: equ store_page-2       ; tracks the file extent during storage_read of continuation blocks  
00a0			store_readbuf: equ store_readptr-2       ; tracks the position for the buffer during storage_read of continuation blocks  
00a0			store_longread: equ store_readbuf -1 ;   if zero then only read one block. If not zero then do a read for as long as required  
00a0			store_tmp1: equ store_longread - 2      ; temp pointer holders during ops  
00a0			store_tmp2: equ store_tmp1 - 2        ; temp pointer holders during ops  
00a0			store_tmp3: equ store_tmp2 - 2        ; temp pointer holders during ops  
00a0			store_tmpid: equ store_tmp3 - 1		; page temp id  
00a0			store_tmpext: equ store_tmpid - 1		; file extent temp  
00a0			store_readcont: equ store_tmpid - 1		; If current read results in an overflow buffer to next record flag it up  
00a0			store_openaddr: equ store_readcont - 2		; file block address of current opened file for read  
00a0			store_openext: equ store_openaddr - 1		; file extent of current opened file for read  
00a0			store_openmaxext: equ store_openext - 1		; max extent of current opened file for read  
00a0			store_filecache: equ store_openmaxext-2   ;  TODO (using just one for now)  file id + extent count cache * 5  
00a0			store_tmppageid: equ store_filecache-2    ; phyical page id temp  
00a0			;  
00a0			; spi vars  
00a0			  
00a0			  
00a0			spi_clktime: equ store_tmppageid - 1      ; holds the number of ms that happens between spi clock pulses  
00a0			spi_cartdev: equ spi_clktime - 1      ; holds bit mask to send to portb (ext spi) devices  
00a0			spi_cartdev2: equ spi_cartdev - 1      ; holds bit mask to send to portb's shift reg devices  
00a0			spi_portbyte: equ spi_cartdev2 - 1      ; holds bit mask to send to spi bus   
00a0			spi_device: equ spi_portbyte - 1    ; bit mask to send to porta (eeproms) devices  
00a0			spi_device_id: equ spi_device - 1    ; human readable bank number  
00a0			  
00a0			;;;;; Tape support params  
00a0			  
00a0			tape_port: equ spi_device_id - 1  
00a0			tape_sync: equ tape_port-10     ; counters used in detecting tape header  
00a0			tape_tm_gap: equ tape_sync - 1  
00a0			tape_tm_freq: equ tape_tm_gap - 1  
00a0			tape_tm_high: equ tape_tm_freq - 2  
00a0			tape_tm_low: equ tape_tm_high - 2  
00a0			  
00a0			;;;;; forth cli params  
00a0			  
00a0			; TODO use a different frame buffer for forth???  
00a0			  
00a0			f_cursor_ptr:  equ tape_tm_low - 1  ; offset into frame buffer for any . or EMIT output  
00a0			cli_buffer: equ f_cursor_ptr - 20     ; temp hold - maybe not needed  
00a0			cli_origtoken: equ cli_buffer - 2     ; pointer to the text of token for this word being checked  
00a0			cli_token: equ cli_origtoken - 2     ; pointer to the text of token for this word being checked  
00a0			cli_execword: equ cli_token - 2      ; pointer to start of code for this word  
00a0			cli_nextword: equ cli_execword - 2      ; pointer to start of next word in dict  
00a0			cli_ptr: equ cli_nextword - 2           ; pointer to start of word to parse by forth kernel (working)  
00a0			cli_origptr: equ cli_ptr - 2           ; pointer to start of word to parse which resets cli_ptr on each word test  
00a0			  
00a0			cli_mvdot: equ cli_origptr - 1 ;     ; true will move the cursor once something is displayed  
00a0			cli_autodisplay: equ cli_mvdot - 1 ;     ; true will auto update the display (slow) otherwise need to use DRAW  
00a0			cli_var_array: equ cli_autodisplay - ( 10 * 2 ) ; word or string pointer variables using V@0-V@9  
00a0			cli_var_array2: equ cli_var_array - ( 26 * 2 ) ; word or string pointer variables using VAR word  
00a0			cli_ret_sp: equ cli_var_array2 - 2    ; ret stack pointer  
00a0			cli_loop_sp: equ cli_ret_sp - 2   ; data stack pointer  
00a0			cli_data_sp: equ cli_loop_sp - 2   ; data stack pointer  
00a0			  
00a0			chk_ret_und: equ cli_data_sp-2           ; underflow check word  
00a0			cli_ret_stack: equ chk_ret_und - STACK_RET_SIZE      ; TODO could I just use normal stack for this? - use linked list for looping  
00a0			chk_ret_ovr: equ cli_ret_stack -2; overflow check word  
00a0			cli_loop_stack: equ chk_ret_ovr - STACK_LOOP_SIZE      ; TODO could I just use normal stack for this? - use linked list for looping  
00a0			chk_loop_ovr: equ cli_loop_stack -2; overflow check word  
00a0			cli_data_stack: equ chk_loop_ovr - STACK_DATA_SIZE		 ;   
00a0			chk_data_ovr: equ cli_data_stack -2; overflow check word  
00a0			  
00a0			os_var_array: equ chk_data_ovr - (32 * 2)      ;   32 word array for use using the SCRATCH word  
00a0			  
00a0			; os/forth token vars  
00a0			  
00a0			os_last_cmd: equ os_var_array-255  
00a0			os_cli_cmd: equ os_last_cmd-255              ; cli command entry line  
00a0			os_current_i: equ os_cli_cmd-2  
00a0			os_cur_ptr: equ os_current_i-2  
00a0			os_word_scratch: equ os_cur_ptr-30  
00a0			os_tok_len: equ os_word_scratch - 2  
00a0			os_tok_ptr: equ os_tok_len - 2               ; our current PC ptr  
00a0			os_tok_malloc: equ os_tok_ptr - 2  
00a0			os_last_new_uword: equ os_tok_malloc - 2    ; hold start of last user word added  
00a0			os_input: equ os_last_new_uword-255    ; buffer for EDIT word  
00a0			execscratch: equ os_input-255        ; exec cmd eval buffer  
00a0			scratch: equ execscratch-255  
00a0			  
00a0			os_stack_1: equ scratch - 3       ; stack holding area 1  
00a0			os_stack_2: equ os_stack_1 - 3       ; stack holding area 2  
00a0			os_stack_3: equ os_stack_2 - 3       ; stack holding area 3  
00a0			os_stack_4: equ os_stack_3 - 3       ; stack holding area 4  
00a0			  
00a0			  
00a0			; temp locations for new word processing to save on adding more   
00a0			  
00a0			os_new_malloc: equ os_stack_4-2  
00a0			os_new_parse_len: equ os_new_malloc - 2  
00a0			os_new_word_len: equ os_new_parse_len - 2  
00a0			os_new_work_ptr: equ os_new_word_len - 2  
00a0			os_new_src_ptr: equ os_new_work_ptr - 2  
00a0			os_new_exec: equ os_new_src_ptr - 2  
00a0			os_new_exec_ptr: equ os_new_exec - 2  
00a0			  
00a0			; resume memory alloocations....  
00a0			  
00a0			;os_view_disable: equ os_new_exec_ptr - 1  
00a0			os_view_af: equ os_new_exec_ptr - 2  
00a0			os_view_hl: equ os_view_af -2  
00a0			os_view_de: equ os_view_hl - 2  
00a0			os_view_bc: equ os_view_de - 2  
00a0			  
00a0			; stack checksum word  
00a0			if DEBUG_STACK_IMB  
00a0				curframe: equ  os_view_de - 5  
00a0				store_sp: equ curframe - (STACK_IMB_STORE*4)  
00a0				chk_word: equ store_sp - 2		 ; this is the word to init and then check against to detect stack corruption. Held far away from all stacks  
00a0			else  
00a0				chk_word: equ os_view_bc - 2		 ; this is the word to init and then check against to detect stack corruption. Held far away from all stacks  
00a0			endif  
00a0			  
00a0			; with data stack could see memory filled with junk. need some memory management   
00a0			; malloc and free entry points added  
00a0			  
00a0			;free_list:  equ chk_word - 4     ; Block struct for start of free list (MUST be 4 bytes)  
00a0			;heap_size: equ  (free_list-08100h)      ; Number of bytes available in heap   TODO make all of user ram  
00a0			;;heap_start: equ free_list - heap_size  ; Starting address of heap  
00a0			;heap_end: equ free_list-1  ; Starting address of heap  
