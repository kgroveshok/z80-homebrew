0f9c			if DEBUG_FORTH_MALLOC_HIGH 
0f9c			.mallocsize: db "Wants malloc >256",0 
0f9c			.mallocasize: db "MALLOC gives >256",0 
0f9c			.malloczero: db "MALLOC gives zero",0 
0f9c			 
0f9c			malloc_guard_zerolen: 
0f9c				push hl 
0f9c				push de 
0f9c				push af 
0f9c			 
0f9c				ld de, 0 
0f9c			        call cmp16 
0f9c				jr nz, .lowalloz 
0f9c			 
0f9c				push hl 
0f9c				push de 
0f9c					ld hl, display_fb0 
0f9c					ld (display_fb_active), hl 
0f9c				call clear_display 
0f9c				ld a, 0 
0f9c				ld de, .malloczero 
0f9c				call str_at_display 
0f9c				call update_display 
0f9c				call delay1s 
0f9c				call delay1s 
0f9c				call bp_on 
0f9c			;	ld a, 0 
0f9c			;	ld (os_view_disable), a 
0f9c			 
0f9c				pop de 
0f9c				pop hl 
0f9c			 
0f9c				 
0f9c			 
0f9c				CALLMONITOR 
0f9c			.lowalloz: 
0f9c			 
0f9c			 
0f9c				pop af 
0f9c				pop de 
0f9c				pop hl 
0f9c			ret 
0f9c			 
0f9c			malloc_guard_entry: 
0f9c				push hl 
0f9c				push de 
0f9c				push af 
0f9c			 
0f9c			 	or a      ;clear carry flag 
0f9c				push hl 
0f9c				ld de, 255 
0f9c				sbc hl, de 
0f9c				jr c, .lowalloc 
0f9c			 
0f9c				push de 
0f9c					ld hl, display_fb0 
0f9c					ld (display_fb_active), hl 
0f9c				call clear_display 
0f9c				ld a, 0 
0f9c				ld de, .mallocsize 
0f9c				call str_at_display 
0f9c				call update_display 
0f9c				call delay1s 
0f9c				call delay1s 
0f9c			;	ld a, 0 
0f9c			;	ld (os_view_disable), a 
0f9c				call bp_on 
0f9c			 
0f9c				pop de 
0f9c				pop hl 
0f9c			 
0f9c				 
0f9c			 
0f9c				CALLMONITOR 
0f9c				jr .lowdone 
0f9c			.lowalloc: 
0f9c			 
0f9c			 
0f9c				pop hl 
0f9c			.lowdone:	pop af 
0f9c				pop de 
0f9c				pop hl 
0f9c			ret 
0f9c			 
0f9c			malloc_guard_exit: 
0f9c				push hl 
0f9c				push de 
0f9c				push af 
0f9c			 
0f9c			 	or a      ;clear carry flag 
0f9c				push hl 
0f9c				ld de, 255 
0f9c				sbc hl, de 
0f9c				jr c, .lowallocx 
0f9c			 
0f9c				push de 
0f9c					ld hl, display_fb0 
0f9c					ld (display_fb_active), hl 
0f9c				call clear_display 
0f9c				ld a, 0 
0f9c				ld de, .mallocasize 
0f9c				call str_at_display 
0f9c				call update_display 
0f9c				call delay1s 
0f9c				call delay1s 
0f9c			;	ld a, 0 
0f9c			;	ld (os_view_disable), a 
0f9c				call bp_on 
0f9c				pop de 
0f9c				pop hl 
0f9c			 
0f9c				CALLMONITOR 
0f9c				jr .lowdonex 
0f9c			.lowallocx: 
0f9c			 
0f9c				pop hl 
0f9c			.lowdonex:	pop af 
0f9c				pop de 
0f9c				pop hl 
0f9c			ret 
