1359 e5				push hl 
135a cd 3f 13			call tape_byte_out 
135d			 
135d cd f3 12			call tape_gap 
1360 cd f3 12			call tape_gap 
1363			 
1363 cd 87 0a			call active 
1366 eb				ex de, hl 
1367 3e 00			ld a, 0 
1369 cd 41 0b			call  str_at_display 
136c cd 51 0b			call update_display 
136f			 
136f e1				pop hl 
1370 7e				ld a, (hl) 
1371 fe 00			cp 0 
1373 c8				ret z 
1374 23				inc hl 
1375 18 e1			jr tape_strz_out 
