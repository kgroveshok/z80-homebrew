5e04			; | | > Compatible with PicoSPINet  
5e04 2a 99 f9				ld hl, (store_openaddr) 
5e07 e5					push hl 
5e08 c1					pop bc 
5e09 16 00				ld d, 0 
5e0b 1e 40				ld e, STORE_BLOCK_PHY 
5e0d cd da 0e				call Div16 
5e10 c5					push bc 
5e11 e1					pop hl 
5e12 cd d6 1f				call forth_push_numhl 
5e15					NEXTW 
5e15 cd a3 fd			call parse_vector 
5e18 c3 9d 23			jp macro_next 
5e1b				endm 
# End of macro NEXTW
5e1b			.SCONST6: 
5e1b				CWHEAD .ENDSTORAGE 89 "READCONT" 8 WORD_FLAG_CODE 
5e1b 6d				db WORD_SYS_CORE+89             
5e1c 37 5e			dw .ENDSTORAGE            
5e1e 09				db 8 + 1 
5e1f .. 00			db "READCONT",0              
5e28				endm 
# End of macro CWHEAD
5e28			; | READCONT (  -- u1  )  Pushes the READ continuation flag to stack | DONE 
5e28			; | | If the most recent READ results in a full buffer load then this flag is set and will indicate that 
5e28			; | | a further read should, if applicable, be CONCAT to the previous read. 
5e28			; | | > [!NOTE] 
5e28			; | | > Compatible with PicoSPINet  
5e28 3a 9b f9				ld a, (store_readcont) 
5e2b 26 00				ld h, 0 
5e2d 6f					ld l, a 
5e2e cd d6 1f				call forth_push_numhl 
5e31					NEXTW 
5e31 cd a3 fd			call parse_vector 
5e34 c3 9d 23			jp macro_next 
5e37				endm 
# End of macro NEXTW
