1109			; Decimal Signed Version 
1109			 
1109			; DispA 
1109			; -------------------------------------------------------------- 
1109			; Converts a signed integer value to a zero-terminated ASCII 
1109			; string representative of that value (using radix 10). 
1109			; -------------------------------------------------------------- 
1109			; INPUTS: 
1109			;     HL     Value to convert (two's complement integer). 
1109			;     DE     Base address of string destination. (pointer). 
1109			; -------------------------------------------------------------- 
1109			; OUTPUTS: 
1109			;     None 
1109			; -------------------------------------------------------------- 
1109			; REGISTERS/MEMORY DESTROYED 
1109			; AF HL 
1109			; -------------------------------------------------------------- 
1109			 
1109			;DispHLToASCII: 
1109			;   push    de 
1109			;   push    bc 
1109			; 
1109			;; Detect sign of HL. 
1109			;    bit    7, h 
1109			;    jr     z, ._DoConvert 
1109			; 
1109			;; HL is negative. Output '-' to string and negate HL. 
1109			;    ld     a, '-' 
1109			;    ld     (de), a 
1109			;    inc    de 
1109			; 
1109			;; Negate HL (using two's complement) 
1109			;    xor    a 
1109			;    sub    l 
1109			;    ld     l, a 
1109			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
1109			;    sbc    a, h 
1109			;    ld     h, a 
1109			; 
1109			;; Convert HL to digit characters 
1109			;._DoConvert: 
1109			;    ld     b, 0     ; B will count character length of number 
1109			;-   ld     a, 10 
1109			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
1109			;    push   af 
1109			;    inc    b 
1109			;    ld     a, h 
1109			;    or     l 
1109			;    jr     nz, - 
1109			; 
1109			;; Retrieve digits from stack 
1109			;-   pop    af 
1109			;    or     $30 
1109			;    ld     (de), a 
1109			;    inc    de 
1109			;    djnz   - 
1109			; 
1109			;; Terminate string with NULL 
1109			;    xor    a 
1109			;    ld     (de), a 
1109			; 
1109			;    pop    bc 
1109			;    pop    de 
1109			;    ret 
1109			 
1109			;Comments 
1109			; 
1109			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
1109			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
1109			;    Note that the output string will not be fixed-width. 
1109			; 
1109			;Example Usage 
1109			; 
1109			;    ld    hl, -1004 
1109			;    ld    de, OP1 
1109			;    call  DispA 
1109			;    ld    hl, OP1 
1109			;    syscall  PutS 
1109			 
