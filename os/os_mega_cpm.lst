0ee3			; Decimal Signed Version 
0ee3			 
0ee3			; DispA 
0ee3			; -------------------------------------------------------------- 
0ee3			; Converts a signed integer value to a zero-terminated ASCII 
0ee3			; string representative of that value (using radix 10). 
0ee3			; -------------------------------------------------------------- 
0ee3			; INPUTS: 
0ee3			;     HL     Value to convert (two's complement integer). 
0ee3			;     DE     Base address of string destination. (pointer). 
0ee3			; -------------------------------------------------------------- 
0ee3			; OUTPUTS: 
0ee3			;     None 
0ee3			; -------------------------------------------------------------- 
0ee3			; REGISTERS/MEMORY DESTROYED 
0ee3			; AF HL 
0ee3			; -------------------------------------------------------------- 
0ee3			 
0ee3			;DispHLToASCII: 
0ee3			;   push    de 
0ee3			;   push    bc 
0ee3			; 
0ee3			;; Detect sign of HL. 
0ee3			;    bit    7, h 
0ee3			;    jr     z, ._DoConvert 
0ee3			; 
0ee3			;; HL is negative. Output '-' to string and negate HL. 
0ee3			;    ld     a, '-' 
0ee3			;    ld     (de), a 
0ee3			;    inc    de 
0ee3			; 
0ee3			;; Negate HL (using two's complement) 
0ee3			;    xor    a 
0ee3			;    sub    l 
0ee3			;    ld     l, a 
0ee3			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
0ee3			;    sbc    a, h 
0ee3			;    ld     h, a 
0ee3			; 
0ee3			;; Convert HL to digit characters 
0ee3			;._DoConvert: 
0ee3			;    ld     b, 0     ; B will count character length of number 
0ee3			;-   ld     a, 10 
0ee3			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
0ee3			;    push   af 
0ee3			;    inc    b 
0ee3			;    ld     a, h 
0ee3			;    or     l 
0ee3			;    jr     nz, - 
0ee3			; 
0ee3			;; Retrieve digits from stack 
0ee3			;-   pop    af 
0ee3			;    or     $30 
0ee3			;    ld     (de), a 
0ee3			;    inc    de 
0ee3			;    djnz   - 
0ee3			; 
0ee3			;; Terminate string with NULL 
0ee3			;    xor    a 
0ee3			;    ld     (de), a 
0ee3			; 
0ee3			;    pop    bc 
0ee3			;    pop    de 
0ee3			;    ret 
0ee3			 
0ee3			;Comments 
0ee3			; 
0ee3			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
0ee3			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
0ee3			;    Note that the output string will not be fixed-width. 
0ee3			; 
0ee3			;Example Usage 
0ee3			; 
0ee3			;    ld    hl, -1004 
0ee3			;    ld    de, OP1 
0ee3			;    call  DispA 
0ee3			;    ld    hl, OP1 
0ee3			;    syscall  PutS 
