2552			.HEAP: 
2552			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
2552 15				db WORD_SYS_CORE+OPCODE_HEAP             
2553 83 25			dw .EXEC            
2555 05				db 4 + 1 
2556 .. 00			db "HEAP",0              
255b				endm 
# End of macro CWHEAD
255b			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
255b			; | | u1 - Current number of bytes in the heap 
255b			; | | u2 - Remaining bytes left on the heap 
255b			; | |  
255b			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
255b			 
255b			 
255b				if DEBUG_FORTH_WORDS_KEY 
255b					DMARK "HEP" 
255b				if DEMARK_VERSION = 1  
255b e5					push hl  
255c 21 64 25				ld hl, .dmark  
255f 22 9b fd				ld (debug_mark), hl  
2562				endif  
2562				if DEMARK_VERSION = 0  
2562					push af  
2562					ld a, (.dmark)  
2562					ld (debug_mark),a  
2562					ld a, (.dmark+1)  
2562					ld (debug_mark+1),a  
2562					ld a, (.dmark+2)  
2562					ld (debug_mark+2),a  
2562				endif  
2562 18 04			jr .pastdmark  
2564 ..			.dmark: db "HEP"  
2567				if DEMARK_VERSION = 1  
2567 00					db 0  
2568				endif  
2568				if DEMARK_VERSION = 1  
2568 e1			.pastdmark: pop hl  
2569				endif  
2569				if DEMARK_VERSION = 0  
2569			.pastdmark: pop af  
2569				endif  
2569			endm  
