cadb .. 00			db "VAR",0              
cadf				endm 
# End of macro CWHEAD
cadf			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
cadf			; | 
cadf			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
cadf			; | |  
cadf			; | | e.g. 
cadf			; | |         #30 a var ! 
cadf			; | |         a var @ . 
cadf			; | |   
cadf			; | |     Displays the number 30 
cadf			; | | 
cadf			; | | Each variable pointer is a word so can use for any words that use that:  
cadf			; | |  
cadf			; | | e.g. 
cadf			; | |  
cadf			; | |         #30 a var 2! 
cadf			; | |         a var 2@ . 
cadf			; | |   
cadf			; | |     Displays the number 30 
cadf			; | |  
cadf			; | | > [!NOTE]  
cadf			; ! | > If a full string is passed then only the first char is looked at 
cadf			; | | > Any other char could exceed bounds checks!  
cadf			; | | > 
cadf			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
cadf			 
cadf					if DEBUG_FORTH_WORDS_KEY 
cadf						DMARK "VAR" 
cadf f5				push af  
cae0 3a f4 ca			ld a, (.dmark)  
cae3 32 5e ee			ld (debug_mark),a  
cae6 3a f5 ca			ld a, (.dmark+1)  
cae9 32 5f ee			ld (debug_mark+1),a  
caec 3a f6 ca			ld a, (.dmark+2)  
caef 32 60 ee			ld (debug_mark+2),a  
caf2 18 03			jr .pastdmark  
caf4 ..			.dmark: db "VAR"  
caf7 f1			.pastdmark: pop af  
caf8			endm  
# End of macro DMARK
caf8						CALLMONITOR 
caf8				if BASE_CPM=1  
caf8					call debug_vector  
caf8				endif  
caf8				if BASE_KEV=1  
caf8					rst 8  
caf8				endif  
caf8				endm  
# End of macro CALLMONITOR
caf8					endif 
caf8			 
caf8					FORTH_DSP_VALUEHL 
caf8				if BASE_CPM=1 
caf8				call macro_dsp_valuehl 
caf8				endif 
caf8				if BASE_KEV=1 
caf8					rst $18 
caf8				endif 
caf8				endm 
# End of macro FORTH_DSP_VALUEHL
