91d8						DMARK "mmf" 
91d8						CALLMONITOR 
91d8					endif 
91d8			 
91d8				ld a,(hl)  
91d8				; if byte is zero then clear to use 
91d8			 
91d8			;	cp 0 
91d8				or a 
91d8				jr z, .foundemptyblock 
91d8			 
91d8				; if byte is not clear 
91d8				;     then byte is offset to next block 
91d8			 
91d8				inc hl 
91d8				ld a, (hl) ; get size 
91d8			.nextblock:	inc hl 
91d8					ld e, (hl) 
91d8					inc hl 
91d8					ld d, (hl) 
91d8					ex de, hl 
91d8			;	inc hl  ; move past the store space 
91d8			;	inc hl  ; move past zero index  
91d8			 
91d8				; TODO detect no more space 
91d8			 
91d8				push hl 
91d8				ld de, heap_end 
91d8				call cmp16 
91d8				pop hl 
91d8				jr nc, .nospace 
91d8			 
91d8				jr .findblock 
91d8			 
91d8			.nospace: ld hl, 0 
91d8				jp .exit 
