1163			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
1163			 
1163			;moved to firmware.asm 
1163			;heap_start        .equ  0x9000      ; Starting address of heap 
1163			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
1163			 
1163			;      .org 0 
1163			;      jp    main 
1163			 
1163			 
1163			;      .org  0x100 
1163			;main: 
1163			;      ld    HL, 0x8100 
1163			;      ld    SP, HL 
1163			; 
1163			;      call  heap_init 
1163			; 
1163			;      ; Make some allocations 
1163			;      ld    HL, 12 
1163			;      call  malloc            ; Allocates 0x9004 
1163			; 
1163			;      ld    HL, 12 
1163			;      call  malloc            ; Allocates 0x9014 
1163			; 
1163			;      ld    HL, 12 
1163			;      call  malloc            ; Allocates 0x9024 
1163			; 
1163			;      ; Free some allocations 
1163			;      ld    HL, 0x9014 
1163			;      call  free 
1163			; 
1163			;      ld    HL, 0x9004 
1163			;      call  free 
1163			; 
1163			;      ld    HL, 0x9024 
1163			;      call  free 
1163			; 
1163			; 
1163			;      halt 
1163			 
1163			 
1163			;------------------------------------------------------------------------------ 
1163			;     heap_init                                                               : 
1163			;                                                                             : 
1163			; Description                                                                 : 
1163			;     Initialise the heap and make it ready for malloc and free operations.   : 
1163			;                                                                             : 
1163			;     The heap is maintained as a linked list, starting with an initial       : 
1163			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1163			;     the first free block in the heap. Each block then points to the next    : 
1163			;     free block within the heap, and the free list ends at the first block   : 
1163			;     with a null pointer to the next free block.                             : 
1163			;                                                                             : 
1163			; Parameters                                                                  : 
1163			;     Inputs are compile-time only. Two defines which specify the starting    : 
1163			;     address of the heap and its size are required, along with a memory      : 
1163			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1163			;     principally stores a pointer to the first free block in the heap.       : 
1163			;                                                                             : 
1163			; Returns                                                                     : 
1163			;     Nothing                                                                 : 
1163			;------------------------------------------------------------------------------ 
1163			heap_init: 
1163 e5			      push  HL 
1164			 
1164			      ; Initialise free list struct 
1164 21 0e 80		      ld    HL, heap_start 
1167 22 0a 80		      ld    (free_list), HL 
116a 21 00 00		      ld    HL, 0 
116d 22 0c 80		      ld    (free_list+2), HL 
1170			 
1170			      ; Insert first free block at bottom of heap, consumes entire heap 
1170 21 af f0		      ld    HL, heap_start+heap_size-4 
1173 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
1176 21 a1 70		      ld    HL, heap_size-4 
1179 22 10 80		      ld    (heap_start+2), HL      ; Block size 
117c			 
117c			      ; Insert end of free list block at top of heap - two null words will 
117c			      ; terminate the free list 
117c 21 00 00		      ld    HL, 0 
117f 22 b1 f0		      ld    (heap_start+heap_size-2), HL 
1182 22 af f0		      ld    (heap_start+heap_size-4), HL 
1185			 
1185 e1			      pop   HL 
1186			 
1186 c9			      ret 
1187			 
1187			 
1187			;------------------------------------------------------------------------------ 
1187			;     malloc                                                                  : 
1187			;                                                                             : 
1187			; Description                                                                 : 
1187			;     Allocates the wanted space from the heap and returns the address of the : 
1187			;     first useable byte of the allocation.                                   : 
1187			;                                                                             : 
1187			;     Allocations can happen in one of two ways:                              : 
1187			;                                                                             : 
1187			;     1. A free block may be found which is the exact size wanted. In this    : 
1187			;        case the block is removed from the free list and retuedn to the      : 
1187			;        caller.                                                              : 
1187			;     2. A free block may be found which is larger than the size wanted. In   : 
1187			;        this case, the larger block is split into two. The first portion of  : 
1187			;        this block will become the requested space by the malloc call and    : 
1187			;        is returned to the caller. The second portion becomes a new free     : 
1187			;        block, and the free list is adjusted to maintain continuity via this : 
1187			;        newly created block.                                                 : 
1187			;                                                                             : 
1187			;     malloc does not set any initial value in the allocated space, the       : 
1187			;     caller is required to do this as required.                              : 
1187			;                                                                             : 
1187			;     This implementation of malloc uses the stack exclusively, and is        : 
1187			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1187			;     advisable to disable interrupts before calling malloc, and recommended  : 
1187			;     to avoid the use of malloc inside ISRs in general.                      : 
1187			;                                                                             : 
1187			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1187			;                                                                             : 
1187			; Parameters                                                                  : 
1187			;     HL  Number of bytes wanted                                              : 
1187			;                                                                             : 
1187			; Returns                                                                     : 
1187			;     HL  Address of the first useable byte of the allocation                 : 
1187			;                                                                             : 
1187			; Flags                                                                       : 
1187			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1187			;                                                                             : 
1187			; Stack frame                                                                 : 
1187			;       |             |                                                       : 
1187			;       +-------------+                                                       : 
1187			;       |     BC      |                                                       : 
1187			;       +-------------+                                                       : 
1187			;       |     DE      |                                                       : 
1187			;       +-------------+                                                       : 
1187			;       |     IX      |                                                       : 
1187			;       +-------------+                                                       : 
1187			;       |  prev_free  |                                                       : 
1187			;   +4  +-------------+                                                       : 
1187			;       |  this_free  |                                                       : 
1187			;   +2  +-------------+                                                       : 
1187			;       |  next_free  |                                                       : 
1187			;   +0  +-------------+                                                       : 
1187			;       |             |                                                       : 
1187			;                                                                             : 
1187			;------------------------------------------------------------------------------ 
1187			 
1187			 
1187			;malloc: 
1187			; 
1187			;	SAVESP ON 1 
1187			; 
1187			;	call malloc_code 
1187			; 
1187			;	CHECKSP ON 1 
1187			;	ret 
1187			 
1187			 
1187			malloc: 
1187 c5			      push  BC 
1188 d5			      push  DE 
1189 dd e5		      push  IX 
118b			if DEBUG_FORTH_MALLOC_HIGH 
118b			call malloc_guard_entry 
118b			endif 
118b			 
118b					if DEBUG_FORTH_MALLOC 
118b						DMARK "mal" 
118b						CALLMONITOR 
118b					endif 
118b 7c			      ld    A, H                    ; Exit if no space requested 
118c b5			      or    L 
118d ca 4c 12		      jp    Z, malloc_early_exit 
1190			 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			; 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			;inc hl 
1190			 
1190			 
1190			 
1190			 
1190					if DEBUG_FORTH_MALLOC 
1190						DMARK "maA" 
1190						CALLMONITOR 
1190					endif 
1190			      ; Set up stack frame 
1190 eb			      ex    DE, HL 
1191 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1194 39			      add   HL, SP 
1195 f9			      ld    SP, HL 
1196 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
119a dd 39		      add   IX, SP 
119c			 
119c			      ; Setup initial state 
119c 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
119f 19			      add   HL, DE 
11a0			 
11a0 44			      ld    B, H                    ; Move want to BC 
11a1 4d			      ld    C, L 
11a2			 
11a2 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
11a5 dd 75 04		      ld    (IX+4), L 
11a8 dd 74 05		      ld    (IX+5), H 
11ab			 
11ab 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
11ac 23			      inc   HL 
11ad 56			      ld    D, (HL) 
11ae dd 73 02		      ld    (IX+2), E 
11b1 dd 72 03		      ld    (IX+3), D 
11b4 eb			      ex    DE, HL                  ; this_free ptr into HL 
11b5			 
11b5					if DEBUG_FORTH_MALLOC 
11b5						DMARK "maB" 
11b5						CALLMONITOR 
11b5					endif 
11b5			      ; Loop through free block list to find some space 
11b5			malloc_find_space: 
11b5 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
11b6 23			      inc   HL 
11b7 56			      ld    D, (HL) 
11b8			 
11b8 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
11b9 b3			      or    E 
11ba ca 46 12		      jp    Z, malloc_no_space 
11bd			 
11bd dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
11c0 dd 72 01		      ld    (IX+1), D 
11c3			 
11c3			      ; Does this block have enough space to make the allocation? 
11c3 23			      inc   HL                      ; Load free block size into DE 
11c4 5e			      ld    E, (HL) 
11c5 23			      inc   HL 
11c6 56			      ld    D, (HL) 
11c7			 
11c7 eb			      ex    DE, HL                  ; Check size of block against want 
11c8 b7			      or    A                       ; Ensure carry flag clear 
11c9 ed 42		      sbc   HL, BC 
11cb e5			      push  HL                      ; Store the result for later (new block size) 
11cc			 
11cc ca 1b 12		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
11cf 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
11d1			 
11d1			      ; this_free block is not big enough, setup ptrs to test next free block 
11d1 e1			      pop   HL                      ; Discard previous result 
11d2			 
11d2 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
11d5 dd 66 03		      ld    H, (IX+3) 
11d8 dd 75 04		      ld    (IX+4), L 
11db dd 74 05		      ld    (IX+5), H 
11de			 
11de dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
11e1 dd 66 01		      ld    H, (IX+1) 
11e4 dd 75 02		      ld    (IX+2), L 
11e7 dd 74 03		      ld    (IX+3), H 
11ea			 
11ea					if DEBUG_FORTH_MALLOC 
11ea						DMARK "MA>" 
11ea						CALLMONITOR 
11ea					endif 
11ea 18 c9		      jr    malloc_find_space 
11ec			 
11ec			      ; split a bigger block into two - requested size and remaining size 
11ec			malloc_alloc_split: 
11ec					if DEBUG_FORTH_MALLOC 
11ec						DMARK "MAs" 
11ec						CALLMONITOR 
11ec					endif 
11ec eb			      ex    DE, HL                  ; Calculate address of new free block 
11ed 2b			      dec   HL 
11ee 2b			      dec   HL 
11ef 2b			      dec   HL 
11f0 09			      add   HL, BC 
11f1			 
11f1			      ; Create a new block and point it at next_free 
11f1 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
11f4 dd 56 01		      ld    D, (IX+1) 
11f7			 
11f7 73			      ld    (HL), E                 ; Store next_free ptr into new block 
11f8 23			      inc   HL 
11f9 72			      ld    (HL), D 
11fa			 
11fa d1			      pop   DE                      ; Store size of new block into new block 
11fb 23			      inc   HL 
11fc 73			      ld    (HL), E 
11fd 23			      inc   HL 
11fe 72			      ld    (HL), D 
11ff			 
11ff			      ; Update this_free ptr to point to new block 
11ff 2b			      dec   HL 
1200 2b			      dec   HL 
1201 2b			      dec   HL 
1202			 
1202 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1205 dd 56 03		      ld    D, (IX+3) 
1208			 
1208 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
120b dd 74 03		      ld    (IX+3), H 
120e			 
120e			      ; Modify this_free block to be allocation 
120e eb			      ex    DE, HL 
120f af			      xor   A                       ; Null the next block ptr of allocated block 
1210 77			      ld    (HL), A 
1211 23			      inc   HL 
1212 77			      ld    (HL), A 
1213			 
1213 23			      inc   HL                      ; Store want size into allocated block 
1214 71			      ld    (HL), C 
1215 23			      inc   HL 
1216 70			      ld    (HL), B 
1217 23			      inc   HL 
1218 e5			      push  HL                      ; Address of allocation to return 
1219			 
1219 18 19		      jr    malloc_update_links 
121b			 
121b			malloc_alloc_fit: 
121b e1			      pop   HL                      ; Dont need new block size, want is exact fit 
121c			 
121c					if DEBUG_FORTH_MALLOC 
121c						DMARK "MAf" 
121c						CALLMONITOR 
121c					endif 
121c			      ; Modify this_free block to be allocation 
121c eb			      ex    DE, HL 
121d 2b			      dec   HL 
121e 2b			      dec   HL 
121f 2b			      dec   HL 
1220			 
1220 af			      xor   A                       ; Null the next block ptr of allocated block 
1221 77			      ld    (HL), A 
1222 23			      inc   HL 
1223 77			      ld    (HL), A 
1224			 
1224 23			      inc   HL                      ; Store address of allocation to return 
1225 23			      inc   HL 
1226 23			      inc   HL 
1227 e5			      push  HL 
1228			 
1228			      ; Copy next_free ptr to this_free, remove allocated block from free list 
1228 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
122b dd 66 01		      ld    H, (IX+1) 
122e			 
122e dd 75 02		      ld    (IX+2), L               ; HL to this_free 
1231 dd 74 03		      ld    (IX+3), H 
1234			 
1234			 
1234			malloc_update_links: 
1234			      ; Update prev_free ptr to point to this_free 
1234 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
1237 dd 66 05		      ld    H, (IX+5) 
123a			 
123a dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
123d dd 56 03		      ld    D, (IX+3) 
1240			 
1240 73			      ld    (HL), E                 ; this_free ptr into prev_free 
1241 23			      inc   HL 
1242 72			      ld    (HL), D 
1243			 
1243					if DEBUG_FORTH_MALLOC 
1243						DMARK "Mul" 
1243						CALLMONITOR 
1243					endif 
1243			      ; Clear the Z flag to indicate successful allocation 
1243 7a			      ld    A, D 
1244 b3			      or    E 
1245			 
1245 d1			      pop   DE                      ; Address of allocation 
1246					if DEBUG_FORTH_MALLOC 
1246						DMARK "MAu" 
1246						CALLMONITOR 
1246					endif 
1246			 
1246			malloc_no_space: 
1246 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
1249 39			      add   HL, SP 
124a f9			      ld    SP, HL 
124b			 
124b eb			      ex    DE, HL                  ; Alloc addr into HL for return 
124c					if DEBUG_FORTH_MALLOC 
124c						DMARK "MAN" 
124c						CALLMONITOR 
124c					endif 
124c			 
124c			malloc_early_exit: 
124c					if DEBUG_FORTH_MALLOC 
124c						DMARK "MAx" 
124c						CALLMONITOR 
124c					endif 
124c dd e1		      pop   IX 
124e d1			      pop   DE 
124f c1			      pop   BC 
1250			 
1250			if DEBUG_FORTH_MALLOC_HIGH 
1250			call malloc_guard_exit 
1250			call malloc_guard_zerolen 
1250			endif 
1250 c9			      ret 
