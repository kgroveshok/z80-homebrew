# End of macro CWHEAD
a4b3			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a4b3			; | | At start the current various registers will be displayed with contents. 
a4b3			; | | Top right corner will show the most recent debug marker seen. 
a4b3			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a4b3			; | | and the return stack pointer (RSP). 
a4b3			; | | Pressing: 
a4b3			; | |  
a4b3			; | |    1 - Initial screen 
a4b3			; | |  
a4b3			; | |    2 - Display a data dump of HL 
a4b3			; | |  
a4b3			; | |    3 - Display a data dump of DE 
a4b3			; | |  
a4b3			; | |    4 - Display a data dump of BC 
a4b3			; | |  
a4b3			; | |    5 - Display a data dump of HL 
a4b3			; | |  
a4b3			; | |    6 - Display a data dump of DSP 
a4b3			; | |  
a4b3			; | |    7 - Display a data dump of RSP 
a4b3			; | |  
a4b3			; | |    8 - Display a data dump of what is at DSP 
a4b3			; | |  
a4b3			; | |    9 - Display a data dump of what is at RSP 
a4b3			; | |  
a4b3			; | |    0 - Exit monitor and continue running. This will also enable break points 
a4b3			; | |  
a4b3			; | |    * - Disable break points 
a4b3			; | |  
a4b3			; | |    # - Enter traditional monitor mode 
a4b3			; | |  
a4b3			; | | 
a4b3			; | | Monitor Mode 
a4b3			; | | ------------ 
a4b3			; | | A prompt of '>' will be shown for various commands: 
a4b3			; | |  
a4b3			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a4b3			; | |  
a4b3			; | |    C - Continue display a data dump from the last set address 
a4b3			; | |  
a4b3			; | |    M xxxx - Set start of memory edit at address xx 
a4b3			; | |  
a4b3			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a4b3			; | |  
a4b3			; | |    G xxxx - Exec code at specific address 
a4b3			; | |  
a4b3			; | |    Q - Return to previous 
a4b3				if DEBUG_FORTH_WORDS_KEY 
a4b3					DMARK "MON" 
a4b3				if DEMARK_VERSION = 1  
a4b3 e5					push hl  
a4b4 21 bc a4				ld hl, .dmark  
a4b7 22 60 ee				ld (debug_mark), hl  
a4ba				endif  
a4ba				if DEMARK_VERSION = 0  
a4ba					push af  
a4ba					ld a, (.dmark)  
a4ba					ld (debug_mark),a  
a4ba					ld a, (.dmark+1)  
a4ba					ld (debug_mark+1),a  
a4ba					ld a, (.dmark+2)  
a4ba					ld (debug_mark+2),a  
a4ba				endif  
a4ba 18 04			jr .pastdmark  
a4bc ..			.dmark: db "MON"  
a4bf				if DEMARK_VERSION = 1  
a4bf 00					db 0  
a4c0				endif  
a4c0				if DEMARK_VERSION = 1  
a4c0 e1			.pastdmark: pop hl  
a4c1				endif  
a4c1				if DEMARK_VERSION = 0  
a4c1			.pastdmark: pop af  
a4c1				endif  
a4c1			endm  
# End of macro DMARK
a4c1					CALLMONITOR 
a4c1				if BASE_CPM=1  
a4c1					call debug_vector  
a4c1				endif  
a4c1				if BASE_KEV=1  
a4c1					rst 8  
a4c1				endif  
a4c1				endm  
# End of macro CALLMONITOR
a4c1				endif 
a4c1			;		ld a, 0 
