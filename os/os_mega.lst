00a0			hardware_init:  
00a0			  
00a0				  
00a0			  
00a0					;ld a, 0  
00a0					;ld (hardware_diag), a  
00a0			  
00a0					; clear all the buffers  
00a0			  
00a0 21 40 fc				ld hl, display_fb1  
00a3 22 fc fa				ld (display_fb_active), hl  
00a6			  
00a6 cd 2f 0b				call clear_display  
00a9			  
00a9 21 fe fa				ld hl, display_fb2  
00ac 22 fc fa				ld (display_fb_active), hl  
00af			  
00af cd 2f 0b				call clear_display  
00b2			  
00b2					; init primary frame buffer area  
00b2 21 e1 fc				ld hl, display_fb0  
00b5 22 fc fa				ld (display_fb_active), hl  
00b8			  
00b8 cd 2f 0b				call clear_display  
00bb			  
00bb			  
00bb cd 1a 68				call lcd_init		; lcd hardware first as some screen functions called during key_init e.g. cursor shapes  
00be			  
00be cd b1 6a			call key_init  
00c1 cd 94 02			call storage_init  
00c4				if TAPE_SUPPORT  
00c4 cd c4 12				call tape_init  
00c7				endif  
00c7			  
00c7				; setup malloc functions  
00c7			  
00c7				if MALLOC_1  
00c7 cd 07 11				call  heap_init  
00ca				endif  
00ca				if MALLOC_4  
00ca					call  heap_init  
00ca				endif  
00ca			  
00ca				; init sound hardware if present  
00ca			  
00ca				if SOUND_ENABLE  
00ca					call sound_init  
00ca				endif  
00ca			  
00ca				; lcd test sequence  
00ca					  
00ca cd 51 0b			call update_display  
00cd cd 6e 0a			call delay1s  
00d0 3e 2b			ld a,'+'  
00d2 cd 34 0b			call fill_display  
00d5 cd 51 0b			call update_display  
00d8 cd 6e 0a			call delay1s  
00db 3e 2a			ld a,'*'  
00dd cd 34 0b			call fill_display  
00e0 cd 51 0b			call update_display  
00e3 cd 6e 0a			call delay1s  
00e6 3e 2d			ld a,'-'  
00e8 cd 34 0b			call fill_display  
00eb cd 51 0b			call update_display  
00ee cd 6e 0a			call delay1s  
00f1			  
00f1			; boot splash screen  
00f1			if display_cols == 20	  
00f1			        ld a, display_row_1    
00f1			else  
00f1 3e 0a		        ld a, display_row_1 +10   
00f3			endif  
00f3 11 96 1a			ld de, prom_bootmsg  
00f6 cd 41 0b			call str_at_display  
00f9 cd 51 0b			call update_display  
00fc			  
00fc			  
00fc cd 6e 0a			call delay1s  
00ff cd 6e 0a			call delay1s  
0102			if display_cols == 20	  
0102			            LD   A, display_row_3+2  
0102			else  
0102 3e 5c		            LD   A, display_row_3+12  
0104			endif  
0104 11 ab 1a			ld de, prom_bootmsg1  
0107 cd 41 0b			call str_at_display  
010a			; display debug level  
010a 3e 78		            LD   A, display_row_4  
010c 11 03 00			ld de, debuglevel  
010f cd 41 0b			call str_at_display  
0112			  
0112 cd 51 0b			call update_display  
0115 cd 6e 0a			call delay1s  
0118 cd 6e 0a			call delay1s  
011b			  
011b			;	ld a, display_row_4+3  
011b			;	ld de, bootmsg2  
011b			;	call str_at_display  
011b			;	call update_display  
011b			;	call delay1s  
011b			;	call delay1s  
011b			  
011b			; debug mark setup  
011b			  
011b 3e 5f		ld a, '_'  
011d 32 9b fd		ld (debug_mark),a  
0120 32 9c fd		ld (debug_mark+1),a  
0123 32 9d fd		ld (debug_mark+2),a  
0126 3e 00		ld a,0  
0128 32 9e fd		ld (debug_mark+3),a  
012b 32 9d fd		ld (debug_umark),a  
012e			  
012e c9					ret  
