63ce			; handle the auto run of code from files in storage 
63ce			 
63ce			 
63ce			include "forth_startup.asm" 
63ce			; Which startup method to use? 
63ce			; 
63ce			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
63ce			; followed by loading of a list of scripts in eeprom 
63ce			 
63ce			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
63ce			; from eeprom 
63ce			 
63ce			; Select with define in main stubs 
63ce			 
63ce			if STARTUP_V1 
63ce				include "forth_startupv1.asm" 
63ce			endif 
63ce			if STARTUP_V2 
63ce				include "forth_startupv2.asm" 
63ce			; Version 2 of the startup  
63ce			;  
63ce			; Auto load any files in bank 1 that start with a '*' 
63ce			; If no se storage then revert to using eprom 
63ce			 
63ce			 
63ce			if STORAGE_SE = 0 
63ce			 
63ce			sprompt1: db "Startup load...",0 
63ce			sprompt2: db "Run? 1=No *=End #=All",0 
63ce			 
63ce			 
63ce			 
63ce			 
63ce			forth_startup: 
63ce				ld hl, startcmds 
63ce				ld a, 0 
63ce				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
63ce			 
63ce			.start1:	push hl 
63ce				call clear_display 
63ce				ld de, sprompt1 
63ce			        ld a, display_row_1 
63ce				call str_at_display 
63ce				ld de, sprompt2 
63ce			        ld a, display_row_2 
63ce				call str_at_display 
63ce				pop hl 
63ce				push hl 
63ce				ld e,(hl) 
63ce				inc hl 
63ce				ld d,(hl) 
63ce			        ld a, display_row_3 
63ce				call str_at_display 
63ce				call update_display 
63ce			 
63ce			 
63ce				ld a, (os_last_cmd) 
63ce			;	cp 0 
63ce				or a 
63ce				jr z, .startprompt 
63ce				call delay250ms 
63ce				jr .startdo 
63ce				 
63ce				 
63ce			 
63ce			.startprompt: 
63ce			 
63ce				ld a,display_row_4 + display_cols - 1 
63ce			        ld de, endprg 
63ce				call str_at_display 
63ce				call update_display 
63ce				call delay1s 
63ce				call cin_wait 
63ce						 
63ce				cp '*' 
63ce				jr z, .startupend1 
63ce				cp '#' 
63ce				jr nz, .startno 
63ce				ld a, 1 
63ce				ld (os_last_cmd),a 
63ce				jr .startdo 
63ce			.startno:	cp '1' 
63ce				jr z,.startnxt  
63ce			 
63ce				; exec startup line 
63ce			.startdo:	 
63ce				pop hl 
63ce				push hl 
63ce				 
63ce				ld e,(hl) 
63ce				inc hl 
63ce				ld d,(hl) 
63ce				ex de,hl 
63ce			 
63ce				push hl 
63ce			 
63ce				ld a, 0 
63ce				;ld a, FORTH_END_BUFFER 
63ce				call strlent 
63ce				inc hl   ; include zero term to copy 
63ce				ld b,0 
63ce				ld c,l 
63ce				pop hl 
63ce				ld de, scratch 
63ce				ldir 
63ce			 
63ce			 
63ce				ld hl, scratch 
63ce				call forthparse 
63ce				call forthexec 
63ce				call forthexec_cleanup 
63ce			 
63ce				ld a, display_row_4 
63ce				ld de, endprog 
63ce			 
63ce				call update_display		 
63ce			 
63ce				ld a, (os_last_cmd) 
63ce			;	cp 0 
63ce				or a 
63ce				jr nz, .startnxt 
63ce				call next_page_prompt 
63ce			        call clear_display 
63ce				call update_display		 
63ce			 
63ce				; move onto next startup line? 
63ce			.startnxt: 
63ce			 
63ce				call delay250ms 
63ce				pop hl 
63ce			 
63ce				inc hl 
63ce				inc hl 
63ce			 
63ce				push hl 
63ce				ld e, (hl) 
63ce				inc hl 
63ce				ld d, (hl) 
63ce				pop hl 
