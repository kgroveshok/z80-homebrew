8c8c			; 
8c8c			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8c8c			; Since the routines get_byte and therefore get_nibble are called, only valid 
8c8c			; characters (0-9a-f) are accepted. 
8c8c			; 
8c8c			;get_word        push    af 
8c8c			;                call    get_byte        ; Get the upper byte 
8c8c			;                ld      h, a 
