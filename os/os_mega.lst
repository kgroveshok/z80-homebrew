121f			free_found_higher_block: 
121f			      ; Insert freed block between prev and next free blocks 
121f 71			      ld    (HL), C                 ; Point prev free block to freed block 
1220 23			      inc   HL 
1221 70			      ld    (HL), B 
1222			 
1222 60			      ld    H, B                    ; Point freed block at next free block 
1223 69			      ld    L, C 
1224 73			      ld    (HL), E 
1225 23			      inc   HL 
1226 72			      ld    (HL), D 
1227			 
1227			      ; Check if the freed block is adjacent to the next free block 
1227 23			      inc   HL                      ; Load size of freed block into HL 
1228 5e			      ld    E, (HL) 
1229 23			      inc   HL 
122a 56			      ld    D, (HL) 
122b eb			      ex    DE, HL 
122c			 
122c 09			      add   HL, BC                  ; Add addr of freed block and its size 
122d			 
122d dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
1230 dd 56 01		      ld    D, (IX+1) 
1233			 
1233 b7			      or    A                       ; Clear the carry flag 
1234 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1236 20 22		      jr    NZ, free_check_adjacent_to_prev 
1238			 
1238			      ; Freed block is adjacent to next, merge into one bigger block 
1238 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1239 5e			      ld    E, (HL) 
123a 23			      inc   HL 
123b 56			      ld    D, (HL) 
123c e5			      push  HL                      ; Save ptr to next block for later 
123d			 
123d 60			      ld    H, B                    ; Store ptr from next block into freed block 
123e 69			      ld    L, C 
123f 73			      ld    (HL), E 
1240 23			      inc   HL 
1241 72			      ld    (HL), D 
1242			 
1242 e1			      pop   HL                      ; Restore ptr to next block 
1243 23			      inc   HL                      ; Load size of next block into DE 
1244 5e			      ld    E, (HL) 
1245 23			      inc   HL 
1246 56			      ld    D, (HL) 
1247 d5			      push  DE                      ; Save next block size for later 
1248			 
1248 60			      ld    H, B                    ; Load size of freed block into HL 
1249 69			      ld    L, C 
124a 23			      inc   HL 
124b 23			      inc   HL 
124c 5e			      ld    E, (HL) 
124d 23			      inc   HL 
124e 56			      ld    D, (HL) 
124f eb			      ex    DE, HL 
1250			 
1250 d1			      pop   DE                      ; Restore size of next block 
1251 19			      add   HL, DE                  ; Add sizes of both blocks 
1252 eb			      ex    DE, HL 
1253			 
1253 60			      ld    H, B                    ; Store new bigger size into freed block 
1254 69			      ld    L, C 
1255 23			      inc   HL 
1256 23			      inc   HL 
1257 73			      ld    (HL), E 
1258 23			      inc   HL 
1259 72			      ld    (HL), D 
