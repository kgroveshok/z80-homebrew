694e			  
694e			; SCMonAPI functions used  
694e			  
694e			; Alphanumeric LCD functions used  
694e			; no need to specify specific functions for this module  
694e			  
694e 3e cf		            LD   A, 11001111b  
6950 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
6952 3e 00		            LD   A, 00000000b  
6954 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6956			  
