1104			;------------------------------------------------------------------------------ 
1104			;     heap_init                                                               : 
1104			;                                                                             : 
1104			; Description                                                                 : 
1104			;     Initialise the heap and make it ready for malloc and free operations.   : 
1104			;                                                                             : 
1104			;     The heap is maintained as a linked list, starting with an initial       : 
1104			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1104			;     the first free block in the heap. Each block then points to the next    : 
1104			;     free block within the heap, and the free list ends at the first block   : 
1104			;     with a null pointer to the next free block.                             : 
1104			;                                                                             : 
1104			; Parameters                                                                  : 
1104			;     Inputs are compile-time only. Two defines which specify the starting    : 
1104			;     address of the heap and its size are required, along with a memory      : 
1104			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1104			;     principally stores a pointer to the first free block in the heap.       : 
1104			;                                                                             : 
1104			; Returns                                                                     : 
1104			;     Nothing                                                                 : 
1104			;------------------------------------------------------------------------------ 
1104			heap_init: 
1104 e5			      push  HL 
1105			 
1105			      ; Initialise free list struct 
1105 21 0e 80		      ld    HL, heap_start 
1108 22 0a 80		      ld    (free_list), HL 
110b 21 00 00		      ld    HL, 0 
110e 22 0c 80		      ld    (free_list+2), HL 
1111			 
1111			      ; Insert first free block at bottom of heap, consumes entire heap 
1111 21 c8 f0		      ld    HL, heap_start+heap_size-4 
1114 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
1117 21 ba 70		      ld    HL, heap_size-4 
111a 22 10 80		      ld    (heap_start+2), HL      ; Block size 
111d			 
111d			      ; Insert end of free list block at top of heap - two null words will 
111d			      ; terminate the free list 
111d 21 00 00		      ld    HL, 0 
1120 22 ca f0		      ld    (heap_start+heap_size-2), HL 
1123 22 c8 f0		      ld    (heap_start+heap_size-4), HL 
1126			 
1126 e1			      pop   HL 
1127			 
1127 c9			      ret 
1128			 
