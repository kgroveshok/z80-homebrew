8d3e			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
8d3e			 
8d3e			;written by Zeda 
8d3e			;Converts a 16-bit unsigned integer to an ASCII string. 
8d3e			 
8d3e			uitoa_16: 
8d3e			;Input: 
8d3e			;   DE is the number to convert 
8d3e			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
8d3e			;Output: 
8d3e			;   HL points to the null-terminated ASCII string 
8d3e			;      NOTE: This isn't necessarily the same as the input HL. 
8d3e d5			  push de 
8d3f c5			  push bc 
8d40 f5			  push af 
8d41 eb			  ex de,hl 
8d42			 
8d42 01 f0 d8		  ld bc,-10000 
8d45 3e 2f		  ld a,'0'-1 
8d47 3c			  inc a 
8d48 09			  add hl,bc  
8d49 38 fc		   jr c,$-2 
8d4b 12			  ld (de),a 
8d4c 13			  inc de 
8d4d			 
8d4d 01 e8 03		  ld bc,1000 
8d50 3e 3a		  ld a,'9'+1 
8d52 3d			  dec a  
8d53 09			  add hl,bc  
8d54 30 fc		   jr nc,$-2 
8d56 12			  ld (de),a 
8d57 13			  inc de 
8d58			 
8d58 01 9c ff		  ld bc,-100 
8d5b 3e 2f		  ld a,'0'-1 
8d5d 3c			  inc a  
8d5e 09			  add hl,bc  
8d5f 38 fc		   jr c,$-2 
8d61 12			  ld (de),a 
8d62 13			  inc de 
8d63			 
8d63 7d			  ld a,l 
8d64 26 3a		  ld h,'9'+1 
8d66 25			  dec h  
8d67 c6 0a		  add a,10  
8d69 30 fb		   jr nc,$-3 
8d6b c6 30		  add a,'0' 
8d6d eb			  ex de,hl 
8d6e 72			  ld (hl),d 
8d6f 23			  inc hl 
8d70 77			  ld (hl),a 
8d71 23			  inc hl 
8d72 36 00		  ld (hl),0 
8d74			 
8d74			;Now strip the leading zeros 
8d74 0e fa		  ld c,-6 
8d76 09			  add hl,bc 
8d77 3e 30		  ld a,'0' 
8d79 23			  inc hl  
8d7a be			  cp (hl)  
8d7b 28 fc		  jr z,$-2 
8d7d			 
8d7d			;Make sure that the string is non-empty! 
8d7d 7e			  ld a,(hl) 
8d7e b7			  or a 
8d7f 20 01		  jr nz,.atoub 
8d81 2b			  dec hl 
8d82			.atoub: 
8d82			 
8d82 f1			  pop af 
8d83 c1			  pop bc 
8d84 d1			  pop de 
8d85 c9			  ret 
