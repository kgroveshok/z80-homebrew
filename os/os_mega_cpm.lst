1030			 
1030 73			      ld    (HL), E                 ; Store next_free ptr into new block 
1031 23			      inc   HL 
1032 72			      ld    (HL), D 
1033			 
1033 d1			      pop   DE                      ; Store size of new block into new block 
1034 23			      inc   HL 
1035 73			      ld    (HL), E 
1036 23			      inc   HL 
