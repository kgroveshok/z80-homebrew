6833 c5				push bc  
6834 21 e1 fc			ld hl, display_fb0  
6837			cpr:	  
6837				; loop for cursor whole row  
6837 0e 28			ld c, display_cols  
6839 23			cpr1:	inc hl  
683a 0d				dec c  
683b 20 fc			jr nz, cpr1  
683d 05				dec b  
683e 20 f7			jr nz, cpr  
6840			  
