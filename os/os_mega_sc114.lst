8a2e			; 
8a2e			; Multiply 8-bit values 
8a2e			; In:  Multiply H with E 
8a2e			; Out: HL = result 
8a2e			; 
8a2e			Mult8: 
8a2e 16 00		    ld d,0 
8a30 6a			    ld l,d 
8a31 06 08		    ld b,8 
8a33			Mult8_Loop: 
8a33 29			    add hl,hl 
8a34 30 01		    jr nc,Mult8_NoAdd 
8a36 19			    add hl,de 
8a37			Mult8_NoAdd: 
