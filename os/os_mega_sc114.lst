9d3d 56 9d			dw .HEAP            
9d3f 04				db 3 + 1 
9d40 .. 00			db "NEW",0              
9d44				endm 
# End of macro CWHEAD
9d44			; | NEW ( -- ) Clears all user words and stack | DONE 
9d44				 
9d44				if MALLOC_4 
