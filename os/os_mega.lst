4c58					ld (debug_mark+2),a  
4c58				endif  
4c58 18 04			jr .pastdmark  
4c5a ..			.dmark: db "REA"  
4c5d				if DEMARK_VERSION = 1  
4c5d 00					db 0  
4c5e				endif  
4c5e				if DEMARK_VERSION = 1  
4c5e e1			.pastdmark: pop hl  
4c5f				endif  
4c5f				if DEMARK_VERSION = 0  
