8f33 23			      inc   HL 
8f34 56			      ld    D, (HL) 
8f35 e5			      push  HL                      ; Save ptr to next block for later 
8f36			 
8f36 60			      ld    H, B                    ; Store ptr from next block into freed block 
8f37 69			      ld    L, C 
8f38 73			      ld    (HL), E 
8f39 23			      inc   HL 
8f3a 72			      ld    (HL), D 
8f3b			 
8f3b e1			      pop   HL                      ; Restore ptr to next block 
8f3c 23			      inc   HL                      ; Load size of next block into DE 
8f3d 5e			      ld    E, (HL) 
8f3e 23			      inc   HL 
8f3f 56			      ld    D, (HL) 
