6b6a 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6b6c 18 02		            JR   WrFunc  
6b6e 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6b70 f5			WrFunc:     PUSH AF  
6b71 f5					push af  
6b72 3a fb fa				ld a, (display_lcde1e2)  
6b75 fe 00				cp 0     ; e1  
6b77 20 0f				jr nz, .wfea2	  
6b79 f1					pop af  
6b7a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b7c cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6b7e cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b80 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b82 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b84 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b86 18 0d			jr .wfskip  
6b88 f1			.wfea2:		pop af  
6b89 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b8b cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6b8d cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b8f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b91 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b93 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b95 3e 05		.wfskip:            LD  A, 5  
6b97 cd 9e 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b9a f1			            POP  AF  
6b9b c9			            RET  
