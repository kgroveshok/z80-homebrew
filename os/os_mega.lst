693b			; no need to specify specific functions for this module  
693b			  
693b 3e cf		            LD   A, 11001111b  
693d d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
693f 3e 00		            LD   A, 00000000b  
6941 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
