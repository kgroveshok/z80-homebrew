# End of macro CWHEAD
ca2e			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
ca2e			; | 
ca2e			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
ca2e			; | |  
ca2e			; | | e.g. 
ca2e			; | |         #30 a var ! 
ca2e			; | |         a var @ . 
ca2e			; | |   
ca2e			; | |     Displays the number 30 
ca2e			; | | 
ca2e			; | | Each variable pointer is a word so can use for any words that use that:  
ca2e			; | |  
ca2e			; | | e.g. 
ca2e			; | |  
ca2e			; | |         #30 a var 2! 
ca2e			; | |         a var 2@ . 
ca2e			; | |   
ca2e			; | |     Displays the number 30 
ca2e			; | |  
ca2e			; | | > [!NOTE]  
ca2e			; ! | > If a full string is passed then only the first char is looked at 
ca2e			; | | > Any other char could exceed bounds checks!  
ca2e			; | | > 
ca2e			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
ca2e			 
ca2e					if DEBUG_FORTH_WORDS_KEY 
ca2e						DMARK "VAR" 
ca2e f5				push af  
ca2f 3a 43 ca			ld a, (.dmark)  
ca32 32 5e ee			ld (debug_mark),a  
ca35 3a 44 ca			ld a, (.dmark+1)  
ca38 32 5f ee			ld (debug_mark+1),a  
ca3b 3a 45 ca			ld a, (.dmark+2)  
ca3e 32 60 ee			ld (debug_mark+2),a  
ca41 18 03			jr .pastdmark  
ca43 ..			.dmark: db "VAR"  
ca46 f1			.pastdmark: pop af  
ca47			endm  
# End of macro DMARK
ca47						CALLMONITOR 
ca47				if BASE_CPM=1  
ca47					call debug_vector  
ca47				endif  
ca47				if BASE_KEV=1  
ca47					rst 8  
ca47				endif  
ca47				endm  
# End of macro CALLMONITOR
ca47					endif 
ca47			 
ca47					FORTH_DSP_VALUEHL 
ca47				if BASE_CPM=1 
ca47				call macro_dsp_valuehl 
ca47				endif 
ca47				if BASE_KEV=1 
ca47					rst $18 
ca47				endif 
ca47				endm 
# End of macro FORTH_DSP_VALUEHL
