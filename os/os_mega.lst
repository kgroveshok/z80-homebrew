508e fc 50			dw .V0            
5090 04				db 3 + 1 
5091 .. 00			db "VAR",0              
5095				endm 
# End of macro CWHEAD
5095			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5095			; | 
5095			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5095			; | |  
5095			; | | e.g. 
5095			; | |         #30 a var ! 
5095			; | |         a var @ . 
5095			; | |   
5095			; | |     Displays the number 30 
5095			; | | 
5095			; | | Each variable pointer is a word so can use for any words that use that:  
5095			; | |  
5095			; | | e.g. 
5095			; | |  
5095			; | |         #30 a var 2! 
5095			; | |         a var 2@ . 
5095			; | |   
5095			; | |     Displays the number 30 
5095			; | |  
5095			; | | > [!NOTE]  
5095			; ! | > If a full string is passed then only the first char is looked at 
5095			; | | > Any other char could exceed bounds checks!  
5095			; | | > 
5095			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5095			 
5095					if DEBUG_FORTH_WORDS_KEY 
5095						DMARK "VAR" 
5095				if DEMARK_VERSION = 1  
5095 e5					push hl  
5096 21 9e 50				ld hl, .dmark  
5099 22 9b fd				ld (debug_mark), hl  
509c				endif  
509c				if DEMARK_VERSION = 0  
509c					push af  
509c					ld a, (.dmark)  
509c					ld (debug_mark),a  
509c					ld a, (.dmark+1)  
509c					ld (debug_mark+1),a  
509c					ld a, (.dmark+2)  
509c					ld (debug_mark+2),a  
509c				endif  
509c 18 04			jr .pastdmark  
509e ..			.dmark: db "VAR"  
50a1				if DEMARK_VERSION = 1  
50a1 00					db 0  
50a2				endif  
50a2				if DEMARK_VERSION = 1  
50a2 e1			.pastdmark: pop hl  
50a3				endif  
50a3				if DEMARK_VERSION = 0  
50a3			.pastdmark: pop af  
50a3				endif  
50a3			endm  
# End of macro DMARK
50a3						CALLMONITOR 
50a3				if BASE_CPM=1  
50a3					call debug_vector  
50a3				endif  
50a3				if BASE_KEV=1  
