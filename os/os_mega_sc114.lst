# End of macro CWHEAD
a3b5			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a3b5			; | | At start the current various registers will be displayed with contents. 
a3b5			; | | Top right corner will show the most recent debug marker seen. 
a3b5			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a3b5			; | | and the return stack pointer (RSP). 
a3b5			; | | Pressing: 
a3b5			; | |  
a3b5			; | |    1 - Initial screen 
a3b5			; | |  
a3b5			; | |    2 - Display a data dump of HL 
a3b5			; | |  
a3b5			; | |    3 - Display a data dump of DE 
a3b5			; | |  
a3b5			; | |    4 - Display a data dump of BC 
a3b5			; | |  
a3b5			; | |    5 - Display a data dump of HL 
a3b5			; | |  
a3b5			; | |    6 - Display a data dump of DSP 
a3b5			; | |  
a3b5			; | |    7 - Display a data dump of RSP 
a3b5			; | |  
a3b5			; | |    8 - Display a data dump of what is at DSP 
a3b5			; | |  
a3b5			; | |    9 - Display a data dump of what is at RSP 
a3b5			; | |  
a3b5			; | |    0 - Exit monitor and continue running. This will also enable break points 
a3b5			; | |  
a3b5			; | |    * - Disable break points 
a3b5			; | |  
a3b5			; | |    # - Enter traditional monitor mode 
a3b5			; | |  
a3b5			; | | 
a3b5			; | | Monitor Mode 
a3b5			; | | ------------ 
a3b5			; | | A prompt of '>' will be shown for various commands: 
a3b5			; | |  
a3b5			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a3b5			; | |  
a3b5			; | |    C - Continue display a data dump from the last set address 
a3b5			; | |  
a3b5			; | |    M xxxx - Set start of memory edit at address xx 
a3b5			; | |  
a3b5			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a3b5			; | |  
a3b5			; | |    G xxxx - Exec code at specific address 
a3b5			; | |  
a3b5			; | |    Q - Return to previous 
a3b5				if DEBUG_FORTH_WORDS_KEY 
a3b5					DMARK "MON" 
a3b5				if DEMARK_VERSION = 1  
a3b5 e5					push hl  
a3b6 21 be a3				ld hl, .dmark  
a3b9 22 60 ee				ld (debug_mark), hl  
a3bc				endif  
a3bc				if DEMARK_VERSION = 0  
a3bc					push af  
a3bc					ld a, (.dmark)  
a3bc					ld (debug_mark),a  
a3bc					ld a, (.dmark+1)  
a3bc					ld (debug_mark+1),a  
a3bc					ld a, (.dmark+2)  
a3bc					ld (debug_mark+2),a  
a3bc				endif  
a3bc 18 04			jr .pastdmark  
a3be ..			.dmark: db "MON"  
a3c1				if DEMARK_VERSION = 1  
a3c1 00					db 0  
a3c2				endif  
a3c2				if DEMARK_VERSION = 1  
a3c2 e1			.pastdmark: pop hl  
a3c3				endif  
a3c3				if DEMARK_VERSION = 0  
a3c3			.pastdmark: pop af  
a3c3				endif  
a3c3			endm  
# End of macro DMARK
a3c3					CALLMONITOR 
a3c3				if BASE_CPM=1  
a3c3					call debug_vector  
a3c3				endif  
a3c3				if BASE_KEV=1  
a3c3					rst 8  
a3c3				endif  
a3c3				endm  
# End of macro CALLMONITOR
a3c3				endif 
