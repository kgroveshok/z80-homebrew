0115 cd 6e 0a			call delay1s  
0118 cd 6e 0a			call delay1s  
011b			  
011b			;	ld a, display_row_4+3  
011b			;	ld de, bootmsg2  
011b			;	call str_at_display  
011b			;	call update_display  
011b			;	call delay1s  
011b			;	call delay1s  
