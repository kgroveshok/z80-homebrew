74fa			; **********************************************************************  
74fa			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
74fa			; **********************************************************************  
74fa			;  
74fa			; **  Written as a Small Computer Monitor App   
74fa			; **  Version 0.1 SCC 2018-05-16  
74fa			; **  www.scc.me.uk  
74fa			;  
74fa			; **********************************************************************  
74fa			;  
74fa			; This module provides support for alphanumeric LCD modules using with  
74fa			; *  HD44780 (or compatible) controller  
74fa			; *  5 x 7 pixel fonts  
74fa			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
74fa			; *  Interface via six digital outputs to the display (see below)  
74fa			;  
74fa			; LCD module pinout:  
74fa			;   1  Vss   0v supply  
74fa			;   2  Vdd   5v supply  
74fa			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
74fa			;   4  RS    High = data, Low = instruction  
74fa			;   5  R/W   High = Read, Low = Write  
74fa			;   6  E     Enable signal (active high)  
74fa			;   7  DB0   Data bit 0  
74fa			;   8  DB1   Data bit 1  
74fa			;   9  DB2   Data bit 2  
74fa			;  10  DB3   Data bit 3  
74fa			;  11  DB4   Data bit 4  
74fa			;  12  DB5   Data bit 5  
74fa			;  13  DB6   Data bit 6  
74fa			;  14  DB7   Data bit 7  
74fa			;  15  A     Backlight anode (+)  
74fa			;  16  K     Backlight cathode (-)  
74fa			;  
74fa			; This interfacing method uses 4-bit data mode and uses time delays  
74fa			; rather than polling the display's ready status. As a result the   
74fa			; interface only requires 6 simple output lines:  
74fa			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
74fa			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
74fa			;   LCD DB4 = Microcomputer output port bit 4  
74fa			;   LCD DB5 = Microcomputer output port bit 5  
74fa			;   LCD DB6 = Microcomputer output port bit 6  
74fa			;   LCD DB7 = Microcomputer output port bit 7  
74fa			; Display's R/W is connected to 0v so it is always in write mode  
74fa			; All 6 connections must be on the same port address <kLCDPrt>  
74fa			; This method also allows a decent length of cable from micro to LCD  
74fa			;  
74fa			; **********************************************************************  
74fa			;  
74fa			; To include the code for any given function provided by this module,   
74fa			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
74fa			; the parent source file.  
74fa			; For example:  #REQUIRES   uHexPrefix  
74fa			;  
74fa			; Also #INCLUDE this file at some point after the #REQUIRES statements  
74fa			; in the parent source file.  
74fa			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
74fa			;  
74fa			; These are the function names provided by this module:  
74fa			; fLCD_Init                     ;Initialise LCD  
74fa			; fLCD_Inst                     ;Send instruction to LCD  
74fa			; fLCD_Data                     ;Send data byte to LCD  
74fa			; fLCD_Pos                      ;Position cursor  
74fa			; fLCD_Str                      ;Display string  
74fa			; fLCD_Def                      ;Define custom character  
74fa			;  
74fa			; **********************************************************************  
74fa			;  
74fa			; Requires SCMonAPI.asm to also be included in the project  
74fa			;  
74fa			  
74fa			  
74fa			; **********************************************************************  
74fa			; **  Constants  
74fa			; **********************************************************************  
74fa			  
74fa			; Constants that must be defined externally  
74fa			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
74fa			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
74fa			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
74fa			;kLCDWidth: EQU 20             ;Width in characters  
74fa			  
74fa			; general line offsets in any frame buffer  
74fa			  
74fa			  
74fa			display_row_1: equ 0  
74fa			display_row_2: equ display_row_1+display_cols  
74fa			display_row_3: equ display_row_2 + display_cols  
74fa			display_row_4: equ display_row_3 + display_cols  
74fa			;display_row_4_eol:   
74fa			  
74fa			  
74fa			; Cursor position values for the start of each line  
74fa			  
74fa			; E  
74fa			kLCD_Line1: EQU 0x00   
74fa			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
74fa			; E1  
74fa			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
74fa			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
74fa			  
74fa			; Instructions to send as A register to fLCD_Inst  
74fa			kLCD_Clear: EQU 00000001b     ;LCD clear  
74fa			kLCD_Off:   EQU 00001000b     ;LCD off  
74fa			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
74fa			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
74fa			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
74fa			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
74fa			  
74fa			; Constants used by this code module  
74fa			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
74fa			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
74fa			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
74fa			  
74fa			  
74fa			  
74fa			; **********************************************************************  
74fa			; **  LCD support functions  
74fa			; **********************************************************************  
74fa			  
74fa			; Initialise alphanumeric LCD module  
74fa			; LCD control register codes:  
74fa			;   DL   0 = 4-bit mode        1 = 8-bit mode  
74fa			;   N    0 = 1-line mode       1 = 2-line mode  
74fa			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
74fa			;   D    0 = Display off       1 = Display on  
74fa			;   C    0 = Cursor off        1 = Cursor on  
74fa			;   B    0 = Blinking off      1 = Blinking on  
74fa			;   ID   0 = Decrement mode    1 = Increment mode  
74fa			;   SH   0 = Entire shift off  1 = Entire shift on  
74fa 3e 28		fLCD_Init:  LD   A, 40  
74fc cd 21 76		            CALL LCDDelay       ;Delay 40ms after power up  
74ff			; For reliable reset set 8-bit mode - 3 times  
74ff cd f1 75		            CALL WrFn8bit       ;Function = 8-bit mode  
7502 cd f1 75		            CALL WrFn8bit       ;Function = 8-bit mode  
7505 cd f1 75		            CALL WrFn8bit       ;Function = 8-bit mode  
7508			; Set 4-bit mode  
7508 cd ed 75		            CALL WrFn4bit       ;Function = 4-bit mode  
750b cd 1f 76		            CALL LCDDelay1      ;Delay 37 us or more  
750e			; Function set  
750e 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
7510 cd 23 75		            CALL fLCD_Inst      ;2 line, display on  
7513			; Display On/Off control  
7513 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
7515 cd 23 75		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
7518			; Display Clear  
7518 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
751a cd 23 75		            CALL fLCD_Inst      ;Clear display  
751d			; Entry mode  
751d 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
751f cd 23 75		            CALL fLCD_Inst      ;Increment mode, shift off  
7522			; Display module now initialised  
7522 c9			            RET  
7523			; ok to here  
7523			  
7523			; Write instruction to LCD  
7523			;   On entry: A = Instruction byte to be written  
7523			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7523 f5			fLCD_Inst:  PUSH AF  
7524 f5			            PUSH AF  
7525 cd 37 75		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
7528 f1			            POP  AF  
7529 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
752a 17			            RLA  
752b 17			            RLA  
752c 17			            RLA  
752d cd 37 75		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
7530 3e 02		            LD   A, 2  
7532 cd 21 76		            CALL LCDDelay       ;Delay 2 ms to complete   
7535 f1			            POP  AF  
7536 c9			            RET  
7537			Wr4bits:   
7537 f5					push af  
7538 3a f9 fa				ld a, (display_lcde1e2)  
753b fe 00				cp 0     ; e  
753d 20 10				jr nz, .wea2	  
753f f1					pop af  
7540 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7542 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7544 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
7546 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
7548 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
754a cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
754c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
754e c9			            RET  
754f f1			.wea2:		pop af  
7550 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7552 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7554 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
7556 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
7558 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
755a cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
755c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
755e c9			            RET  
755f			  
755f			  
755f			; Write data to LCD  
755f			;   On entry: A = Data byte to be written  
755f			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
755f f5			fLCD_Data:  PUSH AF  
7560 f5			            PUSH AF  
7561 cd 73 75		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
7564 f1			            POP  AF  
7565 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
7566 17			            RLA  
7567 17			            RLA  
7568 17			            RLA  
7569 cd 73 75		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
756c 3e 96		            LD   A, 150  
756e 3d			Wait:      DEC  A              ;Wait a while to allow data   
756f 20 fd		            JR   NZ, Wait      ;  write to complete  
7571 f1			            POP  AF  
7572 c9			            RET  
7573			Wr4bitsa:     
7573 f5					push af  
7574 3a f9 fa				ld a, (display_lcde1e2)  
7577 fe 00				cp 0     ; e1  
7579 20 16				jr nz, .we2	  
757b f1					pop af  
757c e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
757e cb d7		            SET  kLCDBitRS, A  
7580 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
7582 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
7584 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
7586 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
7588 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
758a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
758c cb 97		            RES  kLCDBitRS, A  
758e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7590 c9			            RET  
7591 f1			.we2:		pop af  
7592 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7594 cb d7		            SET  kLCDBitRS, A  
7596 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
7598 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
759a cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
759c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
759e cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
75a0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
75a2 cb 97		            RES  kLCDBitRS, A  
75a4 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
75a6 c9			            RET  
75a7			  
75a7			  
75a7			; Position cursor to specified location  
75a7			;   On entry: A = Cursor position  
75a7			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
75a7 f5			fLCD_Pos:   PUSH AF  
75a8					; at this point set the E1 or E2 flag depending on position  
75a8			  
75a8 c5					push bc  
75a9			;		push af  
75a9 06 00				ld b, 0  
75ab 4f					ld c, a  
75ac 3e 4f				ld a, kLCD_Line3-1  
75ae b7			 		or a      ;clear carry flag  
75af 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
75b0 38 04				jr c, .pe1  
75b2			  
75b2					; E selection  
75b2 cb 80				res 0, b         ; bit 0 unset e  
75b4			;		pop af    ; before line 3 so recover orig pos  
75b4			;		ld c, a    ; save for poking back  
75b4 18 06				jr .peset	          
75b6			.pe1:          	; E2 selection  
75b6 cb c0				set 0, b         ; bit 0 set e1  
75b8 79					ld a, c  
75b9 de 4f				sbc a, kLCD_Line3-1  
75bb 4f					ld c, a	         ; save caculated offset  
75bc			;		pop af     ; bin this original value now we have calculated form  
75bc			  
75bc			.peset:		; set bit  
75bc 78					ld a, b  
75bd 32 f9 fa				ld (display_lcde1e2), a 	  
75c0 79					ld a, c  
75c1 c1					pop bc  
75c2			  
75c2 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
75c4 cd 23 75		            CALL fLCD_Inst      ;Write instruction to LCD  
75c7 f1			            POP  AF  
75c8 c9			            RET  
75c9			  
75c9			  
75c9			; Output text string to LCD  
75c9			;   On entry: DE = Pointer to null terminated text string  
75c9			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
75c9 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
75ca b7			            OR   A              ;Null terminator?  
75cb c8			            RET  Z              ;Yes, so finished  
75cc cd 5f 75		            CALL fLCD_Data      ;Write character to display  
75cf 13			            INC  DE             ;Point to next character  
75d0 18 f7		            JR   fLCD_Str       ;Repeat  
75d2 c9					ret  
75d3			  
75d3			; Define custom character  
75d3			;   On entry: A = Character number (0 to 7)  
75d3			;             DE = Pointer to character bitmap data  
75d3			;   On exit:  A = Next character number  
75d3			;             DE = Next location following bitmap  
75d3			;             BC HL IX IY I AF' BC' DE' HL' preserved  
75d3			; Character is   
75d3 c5			fLCD_Def:   PUSH BC  
75d4 f5			            PUSH AF  
75d5 07			            RLCA                ;Calculate location  
75d6 07			            RLCA                ;  for bitmap data  
75d7 07			            RLCA                ;  = 8 x CharacterNumber  
75d8 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
75da cd 23 75		            CALL fLCD_Inst      ;Write instruction to LCD  
75dd 06 00		            LD   B, 0  
75df 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
75e0 cd 5f 75		            CALL fLCD_Data      ;Write byte to display  
75e3 13			            INC  DE             ;Point to next byte  
75e4 04			            INC  B              ;Count bytes  
75e5 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
75e7 28 f6		            JR   Z, Loop       ;No, so repeat  
75e9 f1			            POP  AF  
75ea 3c			            INC  A              ;Increment character number  
75eb c1			            POP  BC  
75ec c9			            RET  
75ed			  
75ed			  
75ed			; **********************************************************************  
75ed			; **  Private functions  
75ed			; **********************************************************************  
75ed			  
75ed			; Write function to LCD  
75ed			;   On entry: A = Function byte to be written  
75ed			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
75ed 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
75ef 18 02		            JR   WrFunc  
75f1 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
75f3 f5			WrFunc:     PUSH AF  
75f4 f5					push af  
75f5 3a f9 fa				ld a, (display_lcde1e2)  
75f8 fe 00				cp 0     ; e1  
75fa 20 0f				jr nz, .wfea2	  
75fc f1					pop af  
75fd d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
75ff cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
7601 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
7603 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7605 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
7607 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7609 18 0d			jr .wfskip  
760b f1			.wfea2:		pop af  
760c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
760e cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
7610 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
7612 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7614 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
7616 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7618 3e 05		.wfskip:            LD  A, 5  
761a cd 21 76		            CALL LCDDelay       ;Delay 5 ms to complete  
761d f1			            POP  AF  
761e c9			            RET  
761f			  
761f			  
761f			; Delay in milliseconds  
761f			;   On entry: A = Number of milliseconds delay  
761f			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
761f 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
7621 d5			LCDDelay:   PUSH DE  
7622 5f			            LD   E, A           ;Delay by 'A' ms  
7623 16 00		            LD   D, 0  
7625 cd 71 0c		            CALL aDelayInMS  
7628 d1			            POP  DE  
7629 c9			            RET  
762a			  
762a			  
762a			testlcd:  
762a 3e 00			ld a, kLCD_Line1  
762c cd a7 75			call fLCD_Pos  
762f 06 28			ld b, 40  
7631 11 5f 76			ld de, .ttext1  
7634 cd f2 74			call write_len_string  
7637			  
7637 3e 28			ld a, kLCD_Line2  
7639 cd a7 75			call fLCD_Pos  
763c 06 28			ld b, 40  
763e 11 88 76			ld de, .ttext2  
7641 cd f2 74			call write_len_string  
7644 3e 50			ld a, kLCD_Line3  
7646 cd a7 75			call fLCD_Pos  
7649 06 28			ld b, 40  
764b 11 b1 76			ld de, .ttext3  
764e cd f2 74			call write_len_string  
7651 3e 78			ld a, kLCD_Line4  
7653 cd a7 75			call fLCD_Pos  
7656 06 28			ld b, 40  
7658 11 da 76			ld de, .ttext4  
765b cd f2 74			call write_len_string  
765e			  
765e 76				halt  
