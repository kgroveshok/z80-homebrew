8a67			subafromhl: 
8a67			   ; If A=0 do nothing 
8a67			    ; Otherwise flip A's sign. Since 
8a67			    ; the upper byte becomes -1, also 
8a67			    ; substract 1 from H. 
8a67 ed 44		    neg 
8a69 ca 72 8a		    jp    z, Skip 
8a6c 25			    dec   h 
8a6d			     
8a6d			    ; Now add the low byte as usual 
8a6d			    ; Two's complement takes care of 
8a6d			    ; ensuring the result is correct 
8a6d 85			    add   a, l 
8a6e 6f			    ld    l, a 
8a6f 8c			    adc   a, h 
8a70 95			    sub   l 
8a71 67			    ld    h, a 
8a72			Skip: 
8a72 c9				ret 
