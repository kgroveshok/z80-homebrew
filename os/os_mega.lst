1349			;------------------------------------------------------------------------------ 
1349			;     malloc                                                                  : 
1349			;                                                                             : 
1349			; Description                                                                 : 
1349			;     Allocates the wanted space from the heap and returns the address of the : 
1349			;     first useable byte of the allocation.                                   : 
1349			;                                                                             : 
1349			;     Allocations can happen in one of two ways:                              : 
1349			;                                                                             : 
1349			;     1. A free block may be found which is the exact size wanted. In this    : 
1349			;        case the block is removed from the free list and retuedn to the      : 
1349			;        caller.                                                              : 
1349			;     2. A free block may be found which is larger than the size wanted. In   : 
1349			;        this case, the larger block is split into two. The first portion of  : 
1349			;        this block will become the requested space by the malloc call and    : 
1349			;        is returned to the caller. The second portion becomes a new free     : 
1349			;        block, and the free list is adjusted to maintain continuity via this : 
1349			;        newly created block.                                                 : 
1349			;                                                                             : 
1349			;     malloc does not set any initial value in the allocated space, the       : 
1349			;     caller is required to do this as required.                              : 
1349			;                                                                             : 
1349			;     This implementation of malloc uses the stack exclusively, and is        : 
1349			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1349			;     advisable to disable interrupts before calling malloc, and recommended  : 
1349			;     to avoid the use of malloc inside ISRs in general.                      : 
1349			;                                                                             : 
1349			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1349			;                                                                             : 
1349			; Parameters                                                                  : 
1349			;     HL  Number of bytes wanted                                              : 
1349			;                                                                             : 
1349			; Returns                                                                     : 
1349			;     HL  Address of the first useable byte of the allocation                 : 
1349			;                                                                             : 
1349			; Flags                                                                       : 
1349			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1349			;                                                                             : 
1349			; Stack frame                                                                 : 
1349			;       |             |                                                       : 
1349			;       +-------------+                                                       : 
1349			;       |     BC      |                                                       : 
1349			;       +-------------+                                                       : 
1349			;       |     DE      |                                                       : 
1349			;       +-------------+                                                       : 
1349			;       |     IX      |                                                       : 
1349			;       +-------------+                                                       : 
1349			;       |  prev_free  |                                                       : 
1349			;   +4  +-------------+                                                       : 
1349			;       |  this_free  |                                                       : 
1349			;   +2  +-------------+                                                       : 
1349			;       |  next_free  |                                                       : 
1349			;   +0  +-------------+                                                       : 
1349			;       |             |                                                       : 
1349			;                                                                             : 
1349			;------------------------------------------------------------------------------ 
1349			 
1349			 
1349			;malloc: 
1349			; 
1349			;	SAVESP ON 1 
1349			; 
1349			;	call malloc_code 
1349			; 
1349			;	CHECKSP ON 1 
1349			;	ret 
1349			 
1349			 
1349			malloc: 
1349 c5			      push  BC 
134a d5			      push  DE 
134b dd e5		      push  IX 
134d			if DEBUG_FORTH_MALLOC_HIGH 
134d			call malloc_guard_entry 
134d			endif 
134d			 
134d					if DEBUG_FORTH_MALLOC 
134d						DMARK "mal" 
134d						CALLMONITOR 
134d					endif 
134d 7c			      ld    A, H                    ; Exit if no space requested 
134e b5			      or    L 
134f ca 0e 14		      jp    Z, malloc_early_exit 
1352			 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			; 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			;inc hl 
1352			 
1352			 
1352			 
1352			 
1352					if DEBUG_FORTH_MALLOC 
1352						DMARK "maA" 
1352						CALLMONITOR 
1352					endif 
1352			      ; Set up stack frame 
1352 eb			      ex    DE, HL 
1353 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1356 39			      add   HL, SP 
1357 f9			      ld    SP, HL 
1358 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
135c dd 39		      add   IX, SP 
135e			 
135e			      ; Setup initial state 
135e 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
1361 19			      add   HL, DE 
1362			 
1362 44			      ld    B, H                    ; Move want to BC 
1363 4d			      ld    C, L 
1364			 
1364 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
1367 dd 75 04		      ld    (IX+4), L 
136a dd 74 05		      ld    (IX+5), H 
136d			 
136d 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
136e 23			      inc   HL 
136f 56			      ld    D, (HL) 
1370 dd 73 02		      ld    (IX+2), E 
1373 dd 72 03		      ld    (IX+3), D 
1376 eb			      ex    DE, HL                  ; this_free ptr into HL 
1377			 
1377					if DEBUG_FORTH_MALLOC 
1377						DMARK "maB" 
1377						CALLMONITOR 
1377					endif 
1377			      ; Loop through free block list to find some space 
1377			malloc_find_space: 
1377 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
1378 23			      inc   HL 
1379 56			      ld    D, (HL) 
137a			 
137a 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
137b b3			      or    E 
137c ca 08 14		      jp    Z, malloc_no_space 
137f			 
137f dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1382 dd 72 01		      ld    (IX+1), D 
1385			 
1385			      ; Does this block have enough space to make the allocation? 
1385 23			      inc   HL                      ; Load free block size into DE 
1386 5e			      ld    E, (HL) 
1387 23			      inc   HL 
1388 56			      ld    D, (HL) 
1389			 
1389 eb			      ex    DE, HL                  ; Check size of block against want 
138a b7			      or    A                       ; Ensure carry flag clear 
138b ed 42		      sbc   HL, BC 
138d e5			      push  HL                      ; Store the result for later (new block size) 
138e			 
138e ca dd 13		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1391 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1393			 
1393			      ; this_free block is not big enough, setup ptrs to test next free block 
1393 e1			      pop   HL                      ; Discard previous result 
1394			 
1394 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1397 dd 66 03		      ld    H, (IX+3) 
139a dd 75 04		      ld    (IX+4), L 
139d dd 74 05		      ld    (IX+5), H 
13a0			 
13a0 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
13a3 dd 66 01		      ld    H, (IX+1) 
13a6 dd 75 02		      ld    (IX+2), L 
13a9 dd 74 03		      ld    (IX+3), H 
13ac			 
13ac					if DEBUG_FORTH_MALLOC 
13ac						DMARK "MA>" 
13ac						CALLMONITOR 
13ac					endif 
13ac 18 c9		      jr    malloc_find_space 
13ae			 
13ae			      ; split a bigger block into two - requested size and remaining size 
13ae			malloc_alloc_split: 
13ae					if DEBUG_FORTH_MALLOC 
13ae						DMARK "MAs" 
13ae						CALLMONITOR 
13ae					endif 
13ae eb			      ex    DE, HL                  ; Calculate address of new free block 
13af 2b			      dec   HL 
13b0 2b			      dec   HL 
13b1 2b			      dec   HL 
13b2 09			      add   HL, BC 
13b3			 
13b3			      ; Create a new block and point it at next_free 
13b3 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
13b6 dd 56 01		      ld    D, (IX+1) 
13b9			 
13b9 73			      ld    (HL), E                 ; Store next_free ptr into new block 
13ba 23			      inc   HL 
13bb 72			      ld    (HL), D 
13bc			 
13bc d1			      pop   DE                      ; Store size of new block into new block 
13bd 23			      inc   HL 
13be 73			      ld    (HL), E 
13bf 23			      inc   HL 
13c0 72			      ld    (HL), D 
13c1			 
13c1			      ; Update this_free ptr to point to new block 
13c1 2b			      dec   HL 
13c2 2b			      dec   HL 
13c3 2b			      dec   HL 
13c4			 
13c4 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
13c7 dd 56 03		      ld    D, (IX+3) 
13ca			 
13ca dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
13cd dd 74 03		      ld    (IX+3), H 
13d0			 
13d0			      ; Modify this_free block to be allocation 
13d0 eb			      ex    DE, HL 
13d1 af			      xor   A                       ; Null the next block ptr of allocated block 
13d2 77			      ld    (HL), A 
13d3 23			      inc   HL 
13d4 77			      ld    (HL), A 
13d5			 
13d5 23			      inc   HL                      ; Store want size into allocated block 
13d6 71			      ld    (HL), C 
13d7 23			      inc   HL 
13d8 70			      ld    (HL), B 
13d9 23			      inc   HL 
13da e5			      push  HL                      ; Address of allocation to return 
13db			 
13db 18 19		      jr    malloc_update_links 
13dd			 
13dd			malloc_alloc_fit: 
13dd e1			      pop   HL                      ; Dont need new block size, want is exact fit 
13de			 
13de					if DEBUG_FORTH_MALLOC 
13de						DMARK "MAf" 
13de						CALLMONITOR 
13de					endif 
13de			      ; Modify this_free block to be allocation 
13de eb			      ex    DE, HL 
13df 2b			      dec   HL 
13e0 2b			      dec   HL 
13e1 2b			      dec   HL 
13e2			 
13e2 af			      xor   A                       ; Null the next block ptr of allocated block 
13e3 77			      ld    (HL), A 
13e4 23			      inc   HL 
13e5 77			      ld    (HL), A 
13e6			 
13e6 23			      inc   HL                      ; Store address of allocation to return 
13e7 23			      inc   HL 
13e8 23			      inc   HL 
13e9 e5			      push  HL 
13ea			 
13ea			      ; Copy next_free ptr to this_free, remove allocated block from free list 
13ea dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
13ed dd 66 01		      ld    H, (IX+1) 
13f0			 
13f0 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
13f3 dd 74 03		      ld    (IX+3), H 
13f6			 
13f6			 
13f6			malloc_update_links: 
13f6			      ; Update prev_free ptr to point to this_free 
13f6 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
13f9 dd 66 05		      ld    H, (IX+5) 
13fc			 
13fc dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
13ff dd 56 03		      ld    D, (IX+3) 
1402			 
1402 73			      ld    (HL), E                 ; this_free ptr into prev_free 
1403 23			      inc   HL 
1404 72			      ld    (HL), D 
1405			 
1405					if DEBUG_FORTH_MALLOC 
1405						DMARK "Mul" 
1405						CALLMONITOR 
1405					endif 
1405			      ; Clear the Z flag to indicate successful allocation 
1405 7a			      ld    A, D 
1406 b3			      or    E 
1407			 
1407 d1			      pop   DE                      ; Address of allocation 
1408					if DEBUG_FORTH_MALLOC 
1408						DMARK "MAu" 
1408						CALLMONITOR 
1408					endif 
1408			 
1408			malloc_no_space: 
1408 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
140b 39			      add   HL, SP 
140c f9			      ld    SP, HL 
140d			 
140d eb			      ex    DE, HL                  ; Alloc addr into HL for return 
140e					if DEBUG_FORTH_MALLOC 
140e						DMARK "MAN" 
140e						CALLMONITOR 
140e					endif 
140e			 
140e			malloc_early_exit: 
140e					if DEBUG_FORTH_MALLOC 
140e						DMARK "MAx" 
140e						CALLMONITOR 
140e					endif 
140e dd e1		      pop   IX 
1410 d1			      pop   DE 
1411 c1			      pop   BC 
1412			 
1412			if DEBUG_FORTH_MALLOC_HIGH 
1412			call malloc_guard_exit 
1412			call malloc_guard_zerolen 
1412			endif 
