67f5 ..			.dmark: db "ASx"  
67f8				if DEMARK_VERSION = 1  
67f8 00					db 0  
67f9				endif  
67f9				if DEMARK_VERSION = 1  
67f9 e1			.pastdmark: pop hl  
67fa				endif  
