8c8c c5			get_byte:        push    bc              ; Save contents of B (and C) 
8c8d 7e					ld a,(hl) 
8c8e 23					inc hl 
8c8f cd b4 8c		                call    nibble2val      ; Get upper nibble 
8c92 cb 07		                rlc     a 
8c94 cb 07		                rlc     a 
8c96 cb 07		                rlc     a 
8c98 cb 07		                rlc     a 
8c9a 47			                ld      b, a            ; Save upper four bits 
8c9b 7e					ld a,(hl) 
8c9c cd b4 8c		                call    nibble2val      ; Get lower nibble 
8c9f b0			                or      b               ; Combine both nibbles 
8ca0 c1			                pop     bc              ; Restore B (and C) 
8ca1 c9			                ret 
8ca2			; 
8ca2			; Get a hexadecimal digit from the serial line. This routine blocks until 
8ca2			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
8ca2			; to the serial line interface. The lower 4 bits of A contain the value of  
8ca2			; that particular digit. 
