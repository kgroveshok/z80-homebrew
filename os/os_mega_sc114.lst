8d28			;destroys af,bc (don't know about hl and de) 
8d28			DispAToASCII: 
8d28 0e 9c			ld	c,-100 
8d2a cd 34 8d			call	.Na1 
8d2d 0e f6			ld	c,-10 
8d2f cd 34 8d			call	.Na1 
8d32 0e ff			ld	c,-1 
8d34 06 2f		.Na1:	ld	b,'0'-1 
8d36 04			.Na2:	inc	b 
8d37 81				add	a,c 
8d38 38 fc			jr	c,.Na2 
