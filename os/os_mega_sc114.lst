8f92			 
8f92 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
8f95 dd 66 03		      ld    H, (IX+3) 
8f98 23			      inc   HL 
8f99 23			      inc   HL 
8f9a 5e			      ld    E, (HL) 
8f9b 23			      inc   HL 
8f9c 56			      ld    D, (HL) 
8f9d			 
8f9d e1			      pop   HL                      ; Add sizes of both blocks 
8f9e 19			      add   HL, DE 
8f9f eb			      ex    DE, HL 
