7270			; stack over and underflow checks 
7270			 
7270			; init the words to detect the under/overflow 
7270			 
7270			chk_stk_init: 
7270				; a vague random number to check so we dont get any "lucky" hits 
7270 3e 2d			ld a, 45 
7272 6f				ld l, a 
7273 00				nop 
7274 3e 17			ld a, 23 
7276 67				ld h, a 
7277			 
7277 22 cb f0			ld (chk_word), hl     ; the word we need to check against 
727a			 
727a			;	ld (chk_stund), hl	; stack points.... 
727a 22 3b fe			ld (chk_stovr), hl 
727d 22 1a f9			ld (chk_ret_und), hl 
7280 22 d8 f8			ld (chk_ret_ovr), hl 
7283 22 56 f8			ld (chk_loop_ovr), hl 
7286 22 54 f6			ld (chk_data_ovr), hl 
7289 c9				ret 
728a				 
728a			check_stacks: 
728a				; check all stack words 
728a			 
728a e5				push hl 
728b d5				push de 
728c			 
728c			;	ld de,(chk_word) 
728c			;	ld hl, (chk_stund)	; stack points.... 
728c			;	if DEBUG_STK_FAULT 
728c			;		DMARK "FAa" 
728c			;		CALLMONITOR 
728c			;	endif 
728c			;	call cmp16 
728c			;	jp z, .chk_faulta 
728c			; 
728c			;	ld de, sfaultsu 
728c			;	jp .chk_fault 
728c			 
728c 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
728f ed 5b cb f0		ld de,(chk_word) 
7293				if DEBUG_STK_FAULT 
7293					DMARK "FAb" 
7293					CALLMONITOR 
7293				endif 
7293 cd 9b 0f			call cmp16 
7296 28 06			jr z, .chk_fault1 
7298 11 3c 73			ld de, sfaultso 
729b c3 ed 72			jp .chk_fault 
729e			.chk_fault1:  
729e 2a 1a f9			ld hl, (chk_ret_und) 
72a1 ed 5b cb f0		ld de,(chk_word) 
72a5				if DEBUG_STK_FAULT 
72a5					DMARK "FAU" 
72a5					CALLMONITOR 
72a5				endif 
72a5 cd 9b 0f			call cmp16 
72a8 ca b1 72			jp z, .chk_fault2 
72ab 11 4c 73			ld de, sfaultru 
72ae c3 ed 72			jp .chk_fault 
72b1			.chk_fault2:  
72b1 2a d8 f8			ld hl, (chk_ret_ovr) 
72b4 ed 5b cb f0		ld de,(chk_word) 
72b8				if DEBUG_STK_FAULT 
72b8					DMARK "FA1" 
72b8					CALLMONITOR 
72b8				endif 
72b8 cd 9b 0f			call cmp16 
72bb ca c4 72			jp z, .chk_fault3 
72be 11 5a 73			ld de, sfaultro 
72c1 c3 ed 72			jp .chk_fault 
72c4			.chk_fault3:  
72c4 2a 56 f8			ld hl, (chk_loop_ovr) 
72c7 ed 5b cb f0		ld de,(chk_word) 
72cb				if DEBUG_STK_FAULT 
72cb					DMARK "FA2" 
72cb					CALLMONITOR 
72cb				endif 
72cb cd 9b 0f			call cmp16 
72ce ca d7 72			jp z, .chk_fault4 
72d1 11 74 73			ld de, sfaultlo 
72d4 c3 ed 72			jp .chk_fault 
72d7			.chk_fault4:  
72d7 2a 54 f6			ld hl, (chk_data_ovr) 
72da ed 5b cb f0		ld de,(chk_word) 
72de				if DEBUG_STK_FAULT 
72de					DMARK "FA3" 
72de					CALLMONITOR 
72de				endif 
72de cd 9b 0f			call cmp16 
72e1 ca ea 72			jp z, .chk_fault5 
72e4 11 8e 73			ld de, sfaultdo 
72e7 c3 ed 72			jp .chk_fault 
