4ccb			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4ccb			; | | e.g. 
4ccb			; | | $01 OPEN $01 DO READ . LOOP 
4ccb			; | | 
4ccb			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4ccb			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4ccb			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4ccb			; | | two bytes contain the file id and extent. 
4ccb			; | |  
4ccb			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4ccb			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4ccb			; | | > [!NOTE] 
4ccb			; | | > Compatible with PicoSPINet  
4ccb			 
4ccb					if DEBUG_FORTH_WORDS_KEY 
4ccb						DMARK "REA" 
4ccb				if DEMARK_VERSION = 1  
4ccb e5					push hl  
4ccc 21 d4 4c				ld hl, .dmark  
4ccf 22 9b fd				ld (debug_mark), hl  
4cd2				endif  
