1104			malloc_guard_zerolen: 
1104				push hl 
1104				push de 
1104				push af 
1104			 
1104				ld de, 0 
1104			        call cmp16 
1104				jr nz, .lowalloz 
1104			 
1104				push hl 
1104				push de 
1104					ld hl, display_fb0 
1104					ld (display_fb_active), hl 
1104				call clear_display 
1104				ld a, 0 
1104				ld de, .malloczero 
1104				call str_at_display 
1104				call update_display 
1104				call delay1s 
1104				call delay1s 
1104				call bp_on 
1104			;	ld a, 0 
1104			;	ld (os_view_disable), a 
1104			 
1104				pop de 
1104				pop hl 
1104			 
1104				 
1104			 
1104				CALLMONITOR 
1104			.lowalloz: 
1104			 
1104			 
1104				pop af 
1104				pop de 
1104				pop hl 
1104			ret 
1104			 
1104			malloc_guard_entry: 
1104				push hl 
1104				push de 
1104				push af 
1104			 
1104			 	or a      ;clear carry flag 
1104				push hl 
1104				ld de, 255 
1104				sbc hl, de 
1104				jr c, .lowalloc 
1104			 
1104				push de 
1104					ld hl, display_fb0 
1104					ld (display_fb_active), hl 
1104				call clear_display 
1104				ld a, 0 
1104				ld de, .mallocsize 
1104				call str_at_display 
1104				call update_display 
1104				call delay1s 
1104				call delay1s 
1104			;	ld a, 0 
1104			;	ld (os_view_disable), a 
1104				call bp_on 
1104			 
1104				pop de 
1104				pop hl 
1104			 
1104				 
1104			 
1104				CALLMONITOR 
1104				jr .lowdone 
1104			.lowalloc: 
1104			 
1104			 
1104				pop hl 
1104			.lowdone:	pop af 
1104				pop de 
1104				pop hl 
1104			ret 
1104			 
1104			malloc_guard_exit: 
1104				push hl 
1104				push de 
1104				push af 
1104			 
1104			 	or a      ;clear carry flag 
1104				push hl 
1104				ld de, 255 
1104				sbc hl, de 
1104				jr c, .lowallocx 
1104			 
1104				push de 
1104					ld hl, display_fb0 
1104					ld (display_fb_active), hl 
1104				call clear_display 
1104				ld a, 0 
1104				ld de, .mallocasize 
1104				call str_at_display 
1104				call update_display 
1104				call delay1s 
1104				call delay1s 
1104			;	ld a, 0 
1104			;	ld (os_view_disable), a 
1104				call bp_on 
1104				pop de 
1104				pop hl 
1104			 
1104				CALLMONITOR 
1104				jr .lowdonex 
1104			.lowallocx: 
1104			 
1104				pop hl 
1104			.lowdonex:	pop af 
1104				pop de 
1104				pop hl 
1104			ret 
1104			endif 
