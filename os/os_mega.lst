0291				include "firmware_seeprom.asm"  
0291			; 
0291			; persisent storage interface via microchip serial eeprom 
0291			 
0291			; port a pio 2 
0291			; pa 7 - si 
0291			; pa 6 - sclk  
0291			; pa 5 - so 
0291			; pa 4 - cs 
0291			; pa 3 - cs 
0291			; pa 2 - cs 
0291			; pa 1 - cs 
0291			; pa 0 - cs 
0291			; 
0291			; TODO get block 
0291			; TODO save block 
0291			; TODO load file 
0291			; TODO save file 
0291			; TODO get dir  
0291			 
0291			;  
0291			storage_adata: equ Device_C    ; device c port a - onboard storage 
0291			storage_actl: equ Device_C+2     ; device c port a 
0291			storage_bdata: equ Device_C+1    ; device c port b - ext storage cart 
0291			storage_bctl: equ Device_C+3     ; device c port b 
0291			 
0291			 
0291			; TODO move these to hardware driver file 
0291			 
0291			;STORE_BLOCK_PHY:   equ 64    ; physical block size on storage   64byte on 256k eeprom 
0291			;STORE_DEVICE_MAXBLOCKS:  equ  512 ; how many blocks are there on this storage device 
0291			; storage bank file system format 
0291			; 
0291			; first page of bank: 
0291			; 	addr 0 - status check 
0291			;       addr 1 - write protect flag 
0291			;       addr 2 - zero if all data is held on this device. >0 - next device number (not used right now) 
0291			;       addr 3 - last file id (to save on scanning for spare file id). or could have bit mask of file ids in use????  
0291			;         TODO see if scanning whole of for available next file id is fast enough 
0291			;	addr 4 > zero term string of bank label 
0291			; 
0291			;        
0291			;  
0291			; first page of any file: 
0291			;      byte 0 - file id  
0291			;      byte 1-17 - fixed file name  
0291			;      byte 18-end of page - extra meta data tba (date? description? keywords?) 
0291			; 
0291			; other pages of any file: 
0291			;      byte 0 - file id 
0291			;      byte 1> - file data 
0291			; 
0291			; TODO depending on how long it takes to load a file in if scanning the whole bank for the file id, could speed it up by having last file page flag??? high bit? that would max 127 files 
0291			;  
0291			; TODO need a bank format which places a 0 in each of the first byte of every page and updates the meta in page 0 
0291			 
0291			 
0291			;storage_so_bit: 5 
0291			;storage_si_bit: 7 
0291			;storage_sclk_bit: 6 
0291			  
