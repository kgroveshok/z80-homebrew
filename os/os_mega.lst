6858 2a f9 fa			ld hl, (display_write_tmp)  
685b 11 28 00			ld de, display_cols  
685e 19				add hl,de  
685f 22 f9 fa			ld (display_write_tmp),hl  
6862			  
6862				  
6862 3e 28			ld a, kLCD_Line2  
6864 cd 56 69		            CALL fLCD_Pos       ;Position cursor to location in A  
6867 06 28			ld b, display_cols  
6869 ed 5b f9 fa		ld de, (display_write_tmp)  
686d cd a1 68			call write_len_string  
6870				  
6870 2a f9 fa			ld hl, (display_write_tmp)  
6873 11 28 00			ld de, display_cols  
6876 19				add hl,de  
6877 22 f9 fa			ld (display_write_tmp),hl  
687a			  
687a				  
687a 3e 50			ld a, kLCD_Line3  
687c cd 56 69		            CALL fLCD_Pos       ;Position cursor to location in A  
687f 06 28			ld b, display_cols  
6881 ed 5b f9 fa		ld de, (display_write_tmp)  
6885 cd a1 68			call write_len_string  
6888				  
6888 2a f9 fa			ld hl, (display_write_tmp)  
688b 11 28 00			ld de, display_cols  
688e 19				add hl,de  
688f 22 f9 fa			ld (display_write_tmp),hl  
6892			  
6892				  
6892 3e 78			ld a, kLCD_Line4  
6894 cd 56 69		            CALL fLCD_Pos       ;Position cursor to location in A  
6897 06 28			ld b, display_cols  
6899 ed 5b f9 fa		ld de, (display_write_tmp)  
689d cd a1 68			call write_len_string  
68a0 c9					ret  
68a1				  
68a1				; write out a fixed length string given in b from de  
68a1			  
68a1 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
68a2 cd 0e 69		            CALL fLCD_Data      ;Write character to display  
68a5 13				inc de  
68a6 10 f9			djnz write_len_string  
68a8 c9				ret  
