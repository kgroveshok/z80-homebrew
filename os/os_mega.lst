0c3a			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
0c3a			; random number generators 
0c3a			 
0c3a			 
0c3a			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0c3a			 
0c3a			 
0c3a			;-----> Generate a random number 
0c3a			; output a=answer 0<=a<=255 
0c3a			; all registers are preserved except: af 
0c3a			random: 
0c3a e5			        push    hl 
0c3b d5			        push    de 
0c3c 2a db fa		        ld      hl,(randData) 
0c3f ed 5f		        ld      a,r 
0c41 57			        ld      d,a 
0c42 5e			        ld      e,(hl) 
0c43 19			        add     hl,de 
0c44 85			        add     a,l 
0c45 ac			        xor     h 
0c46 22 db fa		        ld      (randData),hl 
0c49 d1			        pop     de 
0c4a e1			        pop     hl 
0c4b c9			        ret 
0c4c			 
0c4c			 
0c4c			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0c4c			 
0c4c			 
0c4c			 
0c4c			;------LFSR------ 
0c4c			;James Montelongo 
0c4c			;optimized by Spencer Putt 
0c4c			;out: 
0c4c			; a = 8 bit random number 
0c4c			RandLFSR: 
0c4c 21 e1 fa		        ld hl,LFSRSeed+4 
0c4f 5e			        ld e,(hl) 
0c50 23			        inc hl 
0c51 56			        ld d,(hl) 
0c52 23			        inc hl 
0c53 4e			        ld c,(hl) 
0c54 23			        inc hl 
0c55 7e			        ld a,(hl) 
0c56 47			        ld b,a 
0c57 cb 13		        rl e  
0c59 cb 12			rl d 
0c5b cb 11		        rl c  
0c5d 17				rla 
0c5e cb 13		        rl e  
0c60 cb 12			rl d 
0c62 cb 11		        rl c  
0c64 17				rla 
0c65 cb 13		        rl e  
0c67 cb 12			rl d 
0c69 cb 11		        rl c  
0c6b 17				rla 
0c6c 67			        ld h,a 
0c6d cb 13		        rl e  
0c6f cb 12			rl d 
0c71 cb 11		        rl c  
0c73 17				rla 
0c74 a8			        xor b 
0c75 cb 13		        rl e  
0c77 cb 12			rl d 
0c79 ac			        xor h 
0c7a a9			        xor c 
0c7b aa			        xor d 
0c7c 21 e3 fa		        ld hl,LFSRSeed+6 
0c7f 11 e4 fa		        ld de,LFSRSeed+7 
0c82 01 07 00		        ld bc,7 
0c85 ed b8		        lddr 
0c87 12			        ld (de),a 
0c88 c9			        ret 
0c89			 
0c89			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0c89			 
0c89			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0c89			 
0c89			 
0c89			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0c89			 
0c89			prng16: 
0c89			;Inputs: 
0c89			;   (seed1) contains a 16-bit seed value 
0c89			;   (seed2) contains a NON-ZERO 16-bit seed value 
0c89			;Outputs: 
0c89			;   HL is the result 
0c89			;   BC is the result of the LCG, so not that great of quality 
0c89			;   DE is preserved 
0c89			;Destroys: 
0c89			;   AF 
0c89			;cycle: 4,294,901,760 (almost 4.3 billion) 
0c89			;160cc 
0c89			;26 bytes 
0c89 2a d5 fa		    ld hl,(seed1) 
0c8c 44			    ld b,h 
0c8d 4d			    ld c,l 
0c8e 29			    add hl,hl 
0c8f 29			    add hl,hl 
0c90 2c			    inc l 
0c91 09			    add hl,bc 
0c92 22 d5 fa		    ld (seed1),hl 
0c95 2a d3 fa		    ld hl,(seed2) 
0c98 29			    add hl,hl 
0c99 9f			    sbc a,a 
0c9a e6 2d		    and %00101101 
0c9c ad			    xor l 
0c9d 6f			    ld l,a 
0c9e 22 d3 fa		    ld (seed2),hl 
0ca1 09			    add hl,bc 
0ca2 c9			    ret 
0ca3			 
0ca3			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0ca3			 
0ca3			rand32: 
0ca3			;Inputs: 
0ca3			;   (seed1_0) holds the lower 16 bits of the first seed 
0ca3			;   (seed1_1) holds the upper 16 bits of the first seed 
0ca3			;   (seed2_0) holds the lower 16 bits of the second seed 
0ca3			;   (seed2_1) holds the upper 16 bits of the second seed 
0ca3			;   **NOTE: seed2 must be non-zero 
0ca3			;Outputs: 
0ca3			;   HL is the result 
0ca3			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0ca3			;Destroys: 
0ca3			;   AF 
0ca3			;Tested and passes all CAcert tests 
0ca3			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0ca3			;it has a period of 18,446,744,069,414,584,320 
0ca3			;roughly 18.4 quintillion. 
0ca3			;LFSR taps: 0,2,6,7  = 11000101 
0ca3			;291cc 
0ca3			;seed1_0=$+1 
0ca3			;    ld hl,12345 
0ca3			;seed1_1=$+1 
0ca3			;    ld de,6789 
0ca3			;    ld b,h 
0ca3			;    ld c,l 
0ca3			;    add hl,hl \ rl e \ rl d 
0ca3			;    add hl,hl \ rl e \ rl d 
0ca3			;    inc l 
0ca3			;    add hl,bc 
0ca3			;    ld (seed1_0),hl 
0ca3			;    ld hl,(seed1_1) 
0ca3			;    adc hl,de 
0ca3			;    ld (seed1_1),hl 
0ca3			;    ex de,hl 
0ca3			;seed2_0=$+1 
0ca3			;    ld hl,9876 
0ca3			;seed2_1=$+1 
0ca3			;    ld bc,54321 
0ca3			;    add hl,hl \ rl c \ rl b 
0ca3			;    ld (seed2_1),bc 
0ca3			;    sbc a,a 
0ca3			;    and %11000101 
0ca3			;    xor l 
0ca3			;    ld l,a 
0ca3			;    ld (seed2_0),hl 
0ca3			;    ex de,hl 
0ca3			;    add hl,bc 
0ca3			;    ret 
0ca3			; 
0ca3			 
0ca3			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0ca3			; 20 bytes, 86 cycles (excluding ret) 
0ca3			 
0ca3			; returns   hl = pseudorandom number 
0ca3			; corrupts   a 
0ca3			 
0ca3			; generates 16-bit pseudorandom numbers with a period of 65535 
0ca3			; using the xorshift method: 
0ca3			 
0ca3			; hl ^= hl << 7 
0ca3			; hl ^= hl >> 9 
0ca3			; hl ^= hl << 8 
0ca3			 
0ca3			; some alternative shift triplets which also perform well are: 
0ca3			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0ca3			 
0ca3			;  org 32768 
0ca3			 
0ca3			xrnd: 
0ca3 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0ca6 3e 00		  ld a,0 
0ca8 bd			  cp l 
0ca9 20 02		  jr nz, .xrnd1 
0cab 2e 01		  ld l, 1 
0cad			.xrnd1: 
0cad			 
0cad 7c			  ld a,h 
0cae 1f			  rra 
0caf 7d			  ld a,l 
0cb0 1f			  rra 
0cb1 ac			  xor h 
0cb2 67			  ld h,a 
0cb3 7d			  ld a,l 
0cb4 1f			  rra 
0cb5 7c			  ld a,h 
0cb6 1f			  rra 
0cb7 ad			  xor l 
0cb8 6f			  ld l,a 
0cb9 ac			  xor h 
0cba 67			  ld h,a 
0cbb			 
0cbb 22 d9 fa		  ld (xrandc),hl 
0cbe			 
0cbe c9			  ret 
0cbf			;  
0cbf			 
0cbf			 
0cbf			;;;; int maths 
0cbf			 
0cbf			; https://map.grauw.nl/articles/mult_div_shifts.php 
0cbf			; Divide 16-bit values (with 16-bit result) 
0cbf			; In: Divide BC by divider DE 
0cbf			; Out: BC = result, HL = rest 
0cbf			; 
0cbf			Div16: 
0cbf 21 00 00		    ld hl,0 
0cc2 78			    ld a,b 
0cc3 06 08		    ld b,8 
0cc5			Div16_Loop1: 
0cc5 17			    rla 
0cc6 ed 6a		    adc hl,hl 
0cc8 ed 52		    sbc hl,de 
0cca 30 01		    jr nc,Div16_NoAdd1 
0ccc 19			    add hl,de 
0ccd			Div16_NoAdd1: 
0ccd 10 f6		    djnz Div16_Loop1 
0ccf 17			    rla 
0cd0 2f			    cpl 
0cd1 47			    ld b,a 
0cd2 79			    ld a,c 
0cd3 48			    ld c,b 
0cd4 06 08		    ld b,8 
0cd6			Div16_Loop2: 
0cd6 17			    rla 
0cd7 ed 6a		    adc hl,hl 
0cd9 ed 52		    sbc hl,de 
0cdb 30 01		    jr nc,Div16_NoAdd2 
0cdd 19			    add hl,de 
0cde			Div16_NoAdd2: 
0cde 10 f6		    djnz Div16_Loop2 
0ce0 17			    rla 
0ce1 2f			    cpl 
0ce2 41			    ld b,c 
0ce3 4f			    ld c,a 
0ce4 c9			ret 
0ce5			 
0ce5			 
0ce5			;http://z80-heaven.wikidot.com/math 
0ce5			; 
0ce5			;Inputs: 
0ce5			;     DE and A are factors 
0ce5			;Outputs: 
0ce5			;     A is not changed 
0ce5			;     B is 0 
0ce5			;     C is not changed 
0ce5			;     DE is not changed 
0ce5			;     HL is the product 
0ce5			;Time: 
0ce5			;     342+6x 
0ce5			; 
0ce5			Mult16: 
0ce5			 
0ce5 06 08		     ld b,8          ;7           7 
0ce7 21 00 00		     ld hl,0         ;10         10 
0cea 29			       add hl,hl     ;11*8       88 
0ceb 07			       rlca          ;4*8        32 
0cec 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0cee 19			         add hl,de   ;--         -- 
0cef 10 f9		       djnz $-5      ;13*7+8     99 
0cf1 c9			ret 
0cf2			 
0cf2			; 
0cf2			; Square root of 16-bit value 
0cf2			; In:  HL = value 
0cf2			; Out:  D = result (rounded down) 
0cf2			; 
0cf2			;Sqr16: 
0cf2			;    ld de,#0040 
0cf2			;    ld a,l 
0cf2			;    ld l,h 
0cf2			;    ld h,d 
0cf2			;    or a 
0cf2			;    ld b,8 
0cf2			;Sqr16_Loop: 
0cf2			;    sbc hl,de 
0cf2			;    jr nc,Sqr16_Skip 
0cf2			;    add hl,de 
0cf2			;Sqr16_Skip: 
0cf2			;    ccf 
0cf2			;    rl d 
0cf2			;    add a,a 
0cf2			;    adc hl,hl 
0cf2			;    add a,a 
0cf2			;    adc hl,hl 
0cf2			;    djnz Sqr16_Loop 
0cf2			;    ret 
0cf2			; 
0cf2			; 
0cf2			; Divide 8-bit values 
0cf2			; In: Divide E by divider C 
0cf2			; Out: A = result, B = rest 
0cf2			; 
0cf2			Div8: 
0cf2 af			    xor a 
0cf3 06 08		    ld b,8 
0cf5			Div8_Loop: 
0cf5 cb 13		    rl e 
0cf7 17			    rla 
0cf8 91			    sub c 
0cf9 30 01		    jr nc,Div8_NoAdd 
0cfb 81			    add a,c 
0cfc			Div8_NoAdd: 
0cfc 10 f7		    djnz Div8_Loop 
0cfe 47			    ld b,a 
0cff 7b			    ld a,e 
0d00 17			    rla 
0d01 2f			    cpl 
0d02 c9			    ret 
0d03			 
0d03			; 
0d03			; Multiply 8-bit value with a 16-bit value (unrolled) 
0d03			; In: Multiply A with DE 
0d03			; Out: HL = result 
0d03			; 
0d03			Mult12U: 
0d03 2e 00		    ld l,0 
0d05 87			    add a,a 
0d06 30 01		    jr nc,Mult12U_NoAdd0 
0d08 19			    add hl,de 
0d09			Mult12U_NoAdd0: 
0d09 29			    add hl,hl 
0d0a 87			    add a,a 
0d0b 30 01		    jr nc,Mult12U_NoAdd1 
0d0d 19			    add hl,de 
0d0e			Mult12U_NoAdd1: 
0d0e 29			    add hl,hl 
0d0f 87			    add a,a 
0d10 30 01		    jr nc,Mult12U_NoAdd2 
0d12 19			    add hl,de 
0d13			Mult12U_NoAdd2: 
0d13 29			    add hl,hl 
0d14 87			    add a,a 
0d15 30 01		    jr nc,Mult12U_NoAdd3 
0d17 19			    add hl,de 
0d18			Mult12U_NoAdd3: 
0d18 29			    add hl,hl 
0d19 87			    add a,a 
0d1a 30 01		    jr nc,Mult12U_NoAdd4 
0d1c 19			    add hl,de 
0d1d			Mult12U_NoAdd4: 
0d1d 29			    add hl,hl 
0d1e 87			    add a,a 
0d1f 30 01		    jr nc,Mult12U_NoAdd5 
0d21 19			    add hl,de 
0d22			Mult12U_NoAdd5: 
0d22 29			    add hl,hl 
0d23 87			    add a,a 
0d24 30 01		    jr nc,Mult12U_NoAdd6 
0d26 19			    add hl,de 
0d27			Mult12U_NoAdd6: 
0d27 29			    add hl,hl 
0d28 87			    add a,a 
0d29 d0			    ret nc 
0d2a 19			    add hl,de 
0d2b c9			    ret 
0d2c			 
0d2c			; 
0d2c			; Multiply 8-bit value with a 16-bit value (right rotating) 
0d2c			; In: Multiply A with DE 
0d2c			;      Put lowest value in A for most efficient calculation 
0d2c			; Out: HL = result 
0d2c			; 
0d2c			Mult12R: 
0d2c 21 00 00		    ld hl,0 
0d2f			Mult12R_Loop: 
0d2f cb 3f		    srl a 
0d31 30 01		    jr nc,Mult12R_NoAdd 
0d33 19			    add hl,de 
0d34			Mult12R_NoAdd: 
0d34 cb 23		    sla e 
0d36 cb 12		    rl d 
0d38 b7			    or a 
0d39 c2 2f 0d		    jp nz,Mult12R_Loop 
0d3c c9			    ret 
0d3d			 
0d3d			; 
0d3d			; Multiply 16-bit values (with 32-bit result) 
0d3d			; In: Multiply BC with DE 
0d3d			; Out: BCHL = result 
0d3d			; 
0d3d			Mult32: 
0d3d 79			    ld a,c 
0d3e 48			    ld c,b 
0d3f 21 00 00		    ld hl,0 
0d42 06 10		    ld b,16 
0d44			Mult32_Loop: 
0d44 29			    add hl,hl 
0d45 17			    rla 
0d46 cb 11		    rl c 
0d48 30 07		    jr nc,Mult32_NoAdd 
0d4a 19			    add hl,de 
0d4b ce 00		    adc a,0 
0d4d d2 51 0d		    jp nc,Mult32_NoAdd 
0d50 0c			    inc c 
0d51			Mult32_NoAdd: 
0d51 10 f1		    djnz Mult32_Loop 
0d53 41			    ld b,c 
0d54 4f			    ld c,a 
0d55 c9			    ret 
