9e53			; 
9e53			;  
9e53			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
9e53			; 2DUP 2DROP 2SWAP  
9e53			; @ C@ - get byte  
9e53			; ! C! - store byte 
9e53			; 0< true if less than zero 
9e53			; 0= true if zero 
9e53			; < >  
9e53			; = true if same 
9e53			; variables 
