239d			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
239d			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
239d			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
239d			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
239d			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
239d			WORD_SYS_END: equ 0   ; Opcode for all user words 
239d			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
239d			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
239d			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
239d			 
239d			; Core word preamble macro 
239d			 
239d			CWHEAD:   macro nxtword opcode lit len opflags 
239d				db WORD_SYS_CORE+opcode             
239d				; internal op code number 
239d				dw nxtword            
239d				; link to next dict word block 
239d				db len + 1 
239d				; literal length of dict word inc zero term 
239d				db lit,0              
239d				; literal dict word 
239d			        ; TODO db opflags        
239d				endm 
