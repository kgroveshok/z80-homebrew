8ca2			;                call    to_upper        ; Convert to upper case 
8ca2			;                call    is_hex          ; Was it a hex digit? 
8ca2			;                jr      nc, get_nibble  ; No, get another character 
8ca2			 ;               call    nibble2val      ; Convert nibble to value 
8ca2			 ;               call    print_nibble 
8ca2			 ;               ret 
8ca2			; 
