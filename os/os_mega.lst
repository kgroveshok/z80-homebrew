668a			 
668a			forth_startup: 
668a				ld hl, startcmds 
668a				ld a, 0 
668a				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
668a			 
668a			.start1:	push hl 
668a				call clear_display 
668a				ld de, sprompt1 
668a			        ld a, display_row_1 
668a				call str_at_display 
668a				ld de, sprompt2 
668a			        ld a, display_row_2 
668a				call str_at_display 
668a				pop hl 
668a				push hl 
668a				ld e,(hl) 
668a				inc hl 
668a				ld d,(hl) 
668a			        ld a, display_row_3 
668a				call str_at_display 
668a				call update_display 
668a			 
668a			 
668a				ld a, (os_last_cmd) 
668a			;	cp 0 
668a				or a 
668a				jr z, .startprompt 
668a				call delay250ms 
668a				jr .startdo 
668a				 
668a				 
668a			 
668a			.startprompt: 
668a			 
668a				ld a,display_row_4 + display_cols - 1 
668a			        ld de, endprg 
668a				call str_at_display 
668a				call update_display 
668a				call delay1s 
668a				call cin_wait 
668a						 
668a				cp '*' 
668a				jr z, .startupend1 
668a				cp '#' 
668a				jr nz, .startno 
668a				ld a, 1 
668a				ld (os_last_cmd),a 
668a				jr .startdo 
668a			.startno:	cp '1' 
668a				jr z,.startnxt  
668a			 
668a				; exec startup line 
668a			.startdo:	 
668a				pop hl 
668a				push hl 
668a				 
668a				ld e,(hl) 
668a				inc hl 
668a				ld d,(hl) 
668a				ex de,hl 
668a			 
668a				push hl 
668a			 
668a				ld a, 0 
668a				;ld a, FORTH_END_BUFFER 
668a				call strlent 
668a				inc hl   ; include zero term to copy 
668a				ld b,0 
668a				ld c,l 
668a				pop hl 
668a				ld de, scratch 
668a				ldir 
668a			 
668a			 
668a				ld hl, scratch 
668a				call forthparse 
668a				call forthexec 
668a				call forthexec_cleanup 
668a			 
668a				ld a, display_row_4 
668a				ld de, endprog 
668a			 
668a				call update_display		 
668a			 
668a				ld a, (os_last_cmd) 
668a			;	cp 0 
668a				or a 
668a				jr nz, .startnxt 
668a				call next_page_prompt 
668a			        call clear_display 
668a				call update_display		 
668a			 
668a				; move onto next startup line? 
668a			.startnxt: 
668a			 
668a				call delay250ms 
668a				pop hl 
668a			 
668a				inc hl 
668a				inc hl 
668a			 
668a				push hl 
668a				ld e, (hl) 
668a				inc hl 
668a				ld d, (hl) 
668a				pop hl 
