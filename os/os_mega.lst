4b71					ld a, (.dmark+2)  
4b71					ld (debug_mark+2),a  
4b71				endif  
4b71 18 04			jr .pastdmark  
4b73 ..			.dmark: db "REA"  
4b76				if DEMARK_VERSION = 1  
4b76 00					db 0  
4b77				endif  
4b77				if DEMARK_VERSION = 1  
4b77 e1			.pastdmark: pop hl  
4b78				endif  
4b78				if DEMARK_VERSION = 0  
4b78			.pastdmark: pop af  
4b78				endif  
4b78			endm  
