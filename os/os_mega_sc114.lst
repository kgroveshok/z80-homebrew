9925			; 
9925			; kernel to the forth OS 
9925			 
9925			DS_TYPE_STR: equ 1     ; string type 
9925			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
9925			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
9925			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
9925			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
9925			 
9925			FORTH_PARSEV1: equ 0 
9925			FORTH_PARSEV2: equ 0 
9925			FORTH_PARSEV3: equ 0 
9925			FORTH_PARSEV4: equ 0 
9925			FORTH_PARSEV5: equ 0 
9925			FORTH_PARSEV6: equ 1 
9925			 
9925			;if FORTH_PARSEV5 
9925			;	FORTH_END_BUFFER: equ 0 
9925			;else 
9925			FORTH_END_BUFFER: equ 127 
9925			;endif 
9925			 
9925			FORTH_TRUE: equ 1 
9925			FORTH_FALSE: equ 0 
