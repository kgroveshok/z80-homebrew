115e				cp 1 
115e				call z, .genlsword 
115e				cp 2 
115e				call z, .genedword 
115e			 
115e				cp 3 
115e				call z, .gendemword 
115e			 
115e				cp 4 
115e				call z, .genutlword 
115e				cp 5 
115e				call z, .genspiword 
115e				cp 6 
115e				call z, .genkeyword 
115e				cp 7 
