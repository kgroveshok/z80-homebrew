8f66 eb			      ex    DE, HL 
8f67			 
8f67 60			      ld    H, B                    ; Store new bigger size into freed block 
8f68 69			      ld    L, C 
8f69 23			      inc   HL 
8f6a 23			      inc   HL 
8f6b 73			      ld    (HL), E 
8f6c 23			      inc   HL 
8f6d 72			      ld    (HL), D 
