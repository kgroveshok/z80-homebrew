d563				; get file id to load from and get the file name to display 
d563			 
d563					ld a, (store_page+STORE_0_FILERUN) 
d563			 
d563					ld l, 0 
d563					ld h, a 
d563					ld de, store_page 
d563			 
d563					if DEBUG_FORTH_WORDS 
