744c			; **********************************************************************  
744c			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
744c			; **********************************************************************  
744c			;  
744c			; **  Written as a Small Computer Monitor App   
744c			; **  Version 0.1 SCC 2018-05-16  
744c			; **  www.scc.me.uk  
744c			;  
744c			; **********************************************************************  
744c			;  
744c			; This module provides support for alphanumeric LCD modules using with  
744c			; *  HD44780 (or compatible) controller  
744c			; *  5 x 7 pixel fonts  
744c			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
744c			; *  Interface via six digital outputs to the display (see below)  
744c			;  
744c			; LCD module pinout:  
744c			;   1  Vss   0v supply  
744c			;   2  Vdd   5v supply  
744c			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
744c			;   4  RS    High = data, Low = instruction  
744c			;   5  R/W   High = Read, Low = Write  
744c			;   6  E     Enable signal (active high)  
744c			;   7  DB0   Data bit 0  
744c			;   8  DB1   Data bit 1  
744c			;   9  DB2   Data bit 2  
744c			;  10  DB3   Data bit 3  
744c			;  11  DB4   Data bit 4  
744c			;  12  DB5   Data bit 5  
744c			;  13  DB6   Data bit 6  
744c			;  14  DB7   Data bit 7  
744c			;  15  A     Backlight anode (+)  
744c			;  16  K     Backlight cathode (-)  
744c			;  
744c			; This interfacing method uses 4-bit data mode and uses time delays  
744c			; rather than polling the display's ready status. As a result the   
744c			; interface only requires 6 simple output lines:  
744c			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
744c			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
744c			;   LCD DB4 = Microcomputer output port bit 4  
744c			;   LCD DB5 = Microcomputer output port bit 5  
744c			;   LCD DB6 = Microcomputer output port bit 6  
744c			;   LCD DB7 = Microcomputer output port bit 7  
744c			; Display's R/W is connected to 0v so it is always in write mode  
744c			; All 6 connections must be on the same port address <kLCDPrt>  
744c			; This method also allows a decent length of cable from micro to LCD  
744c			;  
744c			; **********************************************************************  
744c			;  
744c			; To include the code for any given function provided by this module,   
744c			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
744c			; the parent source file.  
744c			; For example:  #REQUIRES   uHexPrefix  
744c			;  
744c			; Also #INCLUDE this file at some point after the #REQUIRES statements  
744c			; in the parent source file.  
744c			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
744c			;  
744c			; These are the function names provided by this module:  
744c			; fLCD_Init                     ;Initialise LCD  
744c			; fLCD_Inst                     ;Send instruction to LCD  
744c			; fLCD_Data                     ;Send data byte to LCD  
744c			; fLCD_Pos                      ;Position cursor  
744c			; fLCD_Str                      ;Display string  
744c			; fLCD_Def                      ;Define custom character  
744c			;  
744c			; **********************************************************************  
744c			;  
744c			; Requires SCMonAPI.asm to also be included in the project  
744c			;  
744c			  
744c			  
744c			; **********************************************************************  
744c			; **  Constants  
744c			; **********************************************************************  
744c			  
744c			; Constants that must be defined externally  
744c			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
744c			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
744c			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
744c			;kLCDWidth: EQU 20             ;Width in characters  
744c			  
744c			; general line offsets in any frame buffer  
744c			  
744c			  
744c			display_row_1: equ 0  
744c			display_row_2: equ display_row_1+display_cols  
744c			display_row_3: equ display_row_2 + display_cols  
744c			display_row_4: equ display_row_3 + display_cols  
744c			;display_row_4_eol:   
744c			  
744c			  
744c			; Cursor position values for the start of each line  
744c			  
744c			; E  
744c			kLCD_Line1: EQU 0x00   
744c			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
744c			; E1  
744c			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
744c			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
744c			  
744c			; Instructions to send as A register to fLCD_Inst  
744c			kLCD_Clear: EQU 00000001b     ;LCD clear  
744c			kLCD_Off:   EQU 00001000b     ;LCD off  
744c			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
744c			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
744c			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
744c			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
744c			  
744c			; Constants used by this code module  
744c			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
744c			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
744c			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
744c			  
744c			  
744c			  
744c			; **********************************************************************  
744c			; **  LCD support functions  
744c			; **********************************************************************  
744c			  
744c			; Initialise alphanumeric LCD module  
744c			; LCD control register codes:  
744c			;   DL   0 = 4-bit mode        1 = 8-bit mode  
744c			;   N    0 = 1-line mode       1 = 2-line mode  
744c			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
744c			;   D    0 = Display off       1 = Display on  
744c			;   C    0 = Cursor off        1 = Cursor on  
744c			;   B    0 = Blinking off      1 = Blinking on  
744c			;   ID   0 = Decrement mode    1 = Increment mode  
744c			;   SH   0 = Entire shift off  1 = Entire shift on  
744c 3e 28		fLCD_Init:  LD   A, 40  
744e cd 73 75		            CALL LCDDelay       ;Delay 40ms after power up  
7451			; For reliable reset set 8-bit mode - 3 times  
7451 cd 43 75		            CALL WrFn8bit       ;Function = 8-bit mode  
7454 cd 43 75		            CALL WrFn8bit       ;Function = 8-bit mode  
7457 cd 43 75		            CALL WrFn8bit       ;Function = 8-bit mode  
745a			; Set 4-bit mode  
745a cd 3f 75		            CALL WrFn4bit       ;Function = 4-bit mode  
745d cd 71 75		            CALL LCDDelay1      ;Delay 37 us or more  
7460			; Function set  
7460 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
7462 cd 75 74		            CALL fLCD_Inst      ;2 line, display on  
7465			; Display On/Off control  
7465 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
7467 cd 75 74		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
746a			; Display Clear  
746a 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
746c cd 75 74		            CALL fLCD_Inst      ;Clear display  
746f			; Entry mode  
746f 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
7471 cd 75 74		            CALL fLCD_Inst      ;Increment mode, shift off  
7474			; Display module now initialised  
7474 c9			            RET  
7475			; ok to here  
7475			  
7475			; Write instruction to LCD  
7475			;   On entry: A = Instruction byte to be written  
7475			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7475 f5			fLCD_Inst:  PUSH AF  
7476 f5			            PUSH AF  
7477 cd 89 74		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
747a f1			            POP  AF  
747b 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
747c 17			            RLA  
747d 17			            RLA  
747e 17			            RLA  
747f cd 89 74		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
7482 3e 02		            LD   A, 2  
7484 cd 73 75		            CALL LCDDelay       ;Delay 2 ms to complete   
7487 f1			            POP  AF  
7488 c9			            RET  
7489			Wr4bits:   
7489 f5					push af  
748a 3a f9 fa				ld a, (display_lcde1e2)  
748d fe 00				cp 0     ; e  
748f 20 10				jr nz, .wea2	  
7491 f1					pop af  
7492 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7494 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7496 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
7498 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
749a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
749c cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
749e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
74a0 c9			            RET  
74a1 f1			.wea2:		pop af  
74a2 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
74a4 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
74a6 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
74a8 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
74aa d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
74ac cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
74ae d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
74b0 c9			            RET  
74b1			  
74b1			  
74b1			; Write data to LCD  
74b1			;   On entry: A = Data byte to be written  
74b1			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
74b1 f5			fLCD_Data:  PUSH AF  
74b2 f5			            PUSH AF  
74b3 cd c5 74		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
74b6 f1			            POP  AF  
74b7 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
74b8 17			            RLA  
74b9 17			            RLA  
74ba 17			            RLA  
74bb cd c5 74		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
74be 3e 96		            LD   A, 150  
74c0 3d			Wait:      DEC  A              ;Wait a while to allow data   
74c1 20 fd		            JR   NZ, Wait      ;  write to complete  
74c3 f1			            POP  AF  
74c4 c9			            RET  
74c5			Wr4bitsa:     
74c5 f5					push af  
74c6 3a f9 fa				ld a, (display_lcde1e2)  
74c9 fe 00				cp 0     ; e1  
74cb 20 16				jr nz, .we2	  
74cd f1					pop af  
74ce e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
74d0 cb d7		            SET  kLCDBitRS, A  
74d2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
74d4 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
74d6 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
74d8 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
74da cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
74dc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
74de cb 97		            RES  kLCDBitRS, A  
74e0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
74e2 c9			            RET  
74e3 f1			.we2:		pop af  
74e4 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
74e6 cb d7		            SET  kLCDBitRS, A  
74e8 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
74ea cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
74ec cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
74ee d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
74f0 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
74f2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
74f4 cb 97		            RES  kLCDBitRS, A  
74f6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
74f8 c9			            RET  
74f9			  
74f9			  
74f9			; Position cursor to specified location  
74f9			;   On entry: A = Cursor position  
74f9			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
74f9 f5			fLCD_Pos:   PUSH AF  
74fa					; at this point set the E1 or E2 flag depending on position  
74fa			  
74fa c5					push bc  
74fb			;		push af  
74fb 06 00				ld b, 0  
74fd 4f					ld c, a  
74fe 3e 4f				ld a, kLCD_Line3-1  
7500 b7			 		or a      ;clear carry flag  
7501 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
7502 38 04				jr c, .pe1  
7504			  
7504					; E selection  
7504 cb 80				res 0, b         ; bit 0 unset e  
7506			;		pop af    ; before line 3 so recover orig pos  
7506			;		ld c, a    ; save for poking back  
7506 18 06				jr .peset	          
7508			.pe1:          	; E2 selection  
7508 cb c0				set 0, b         ; bit 0 set e1  
750a 79					ld a, c  
750b de 4f				sbc a, kLCD_Line3-1  
750d 4f					ld c, a	         ; save caculated offset  
750e			;		pop af     ; bin this original value now we have calculated form  
750e			  
750e			.peset:		; set bit  
750e 78					ld a, b  
750f 32 f9 fa				ld (display_lcde1e2), a 	  
7512 79					ld a, c  
7513 c1					pop bc  
7514			  
7514 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
7516 cd 75 74		            CALL fLCD_Inst      ;Write instruction to LCD  
7519 f1			            POP  AF  
751a c9			            RET  
751b			  
751b			  
751b			; Output text string to LCD  
751b			;   On entry: DE = Pointer to null terminated text string  
751b			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
751b 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
751c b7			            OR   A              ;Null terminator?  
751d c8			            RET  Z              ;Yes, so finished  
751e cd b1 74		            CALL fLCD_Data      ;Write character to display  
7521 13			            INC  DE             ;Point to next character  
7522 18 f7		            JR   fLCD_Str       ;Repeat  
7524 c9					ret  
7525			  
7525			; Define custom character  
7525			;   On entry: A = Character number (0 to 7)  
7525			;             DE = Pointer to character bitmap data  
7525			;   On exit:  A = Next character number  
7525			;             DE = Next location following bitmap  
7525			;             BC HL IX IY I AF' BC' DE' HL' preserved  
7525			; Character is   
7525 c5			fLCD_Def:   PUSH BC  
7526 f5			            PUSH AF  
7527 07			            RLCA                ;Calculate location  
7528 07			            RLCA                ;  for bitmap data  
7529 07			            RLCA                ;  = 8 x CharacterNumber  
752a f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
752c cd 75 74		            CALL fLCD_Inst      ;Write instruction to LCD  
752f 06 00		            LD   B, 0  
7531 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
7532 cd b1 74		            CALL fLCD_Data      ;Write byte to display  
7535 13			            INC  DE             ;Point to next byte  
7536 04			            INC  B              ;Count bytes  
7537 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
7539 28 f6		            JR   Z, Loop       ;No, so repeat  
753b f1			            POP  AF  
753c 3c			            INC  A              ;Increment character number  
753d c1			            POP  BC  
753e c9			            RET  
753f			  
753f			  
753f			; **********************************************************************  
753f			; **  Private functions  
753f			; **********************************************************************  
753f			  
753f			; Write function to LCD  
753f			;   On entry: A = Function byte to be written  
753f			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
753f 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
7541 18 02		            JR   WrFunc  
7543 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
7545 f5			WrFunc:     PUSH AF  
7546 f5					push af  
7547 3a f9 fa				ld a, (display_lcde1e2)  
754a fe 00				cp 0     ; e1  
754c 20 0f				jr nz, .wfea2	  
754e f1					pop af  
754f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7551 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
7553 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
7555 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7557 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
7559 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
755b 18 0d			jr .wfskip  
755d f1			.wfea2:		pop af  
755e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7560 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
7562 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
7564 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7566 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
7568 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
756a 3e 05		.wfskip:            LD  A, 5  
756c cd 73 75		            CALL LCDDelay       ;Delay 5 ms to complete  
756f f1			            POP  AF  
7570 c9			            RET  
7571			  
7571			  
7571			; Delay in milliseconds  
7571			;   On entry: A = Number of milliseconds delay  
7571			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7571 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
7573 d5			LCDDelay:   PUSH DE  
7574 5f			            LD   E, A           ;Delay by 'A' ms  
7575 16 00		            LD   D, 0  
