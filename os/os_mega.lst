0c62			;out: 
0c62			; a = 8 bit random number 
0c62			RandLFSR: 
0c62 21 e1 fa		        ld hl,LFSRSeed+4 
0c65 5e			        ld e,(hl) 
0c66 23			        inc hl 
0c67 56			        ld d,(hl) 
0c68 23			        inc hl 
0c69 4e			        ld c,(hl) 
0c6a 23			        inc hl 
0c6b 7e			        ld a,(hl) 
0c6c 47			        ld b,a 
0c6d cb 13		        rl e  
0c6f cb 12			rl d 
0c71 cb 11		        rl c  
0c73 17				rla 
0c74 cb 13		        rl e  
0c76 cb 12			rl d 
0c78 cb 11		        rl c  
0c7a 17				rla 
0c7b cb 13		        rl e  
0c7d cb 12			rl d 
0c7f cb 11		        rl c  
0c81 17				rla 
0c82 67			        ld h,a 
0c83 cb 13		        rl e  
0c85 cb 12			rl d 
0c87 cb 11		        rl c  
0c89 17				rla 
0c8a a8			        xor b 
0c8b cb 13		        rl e  
0c8d cb 12			rl d 
0c8f ac			        xor h 
0c90 a9			        xor c 
0c91 aa			        xor d 
0c92 21 e3 fa		        ld hl,LFSRSeed+6 
0c95 11 e4 fa		        ld de,LFSRSeed+7 
0c98 01 07 00		        ld bc,7 
0c9b ed b8		        lddr 
0c9d 12			        ld (de),a 
0c9e c9			        ret 
0c9f			 
0c9f			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0c9f			 
0c9f			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0c9f			 
0c9f			 
0c9f			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0c9f			 
0c9f			prng16: 
0c9f			;Inputs: 
0c9f			;   (seed1) contains a 16-bit seed value 
0c9f			;   (seed2) contains a NON-ZERO 16-bit seed value 
0c9f			;Outputs: 
0c9f			;   HL is the result 
0c9f			;   BC is the result of the LCG, so not that great of quality 
0c9f			;   DE is preserved 
0c9f			;Destroys: 
0c9f			;   AF 
0c9f			;cycle: 4,294,901,760 (almost 4.3 billion) 
0c9f			;160cc 
0c9f			;26 bytes 
0c9f 2a d5 fa		    ld hl,(seed1) 
0ca2 44			    ld b,h 
0ca3 4d			    ld c,l 
0ca4 29			    add hl,hl 
0ca5 29			    add hl,hl 
0ca6 2c			    inc l 
0ca7 09			    add hl,bc 
0ca8 22 d5 fa		    ld (seed1),hl 
0cab 2a d3 fa		    ld hl,(seed2) 
0cae 29			    add hl,hl 
0caf 9f			    sbc a,a 
0cb0 e6 2d		    and %00101101 
0cb2 ad			    xor l 
0cb3 6f			    ld l,a 
0cb4 22 d3 fa		    ld (seed2),hl 
0cb7 09			    add hl,bc 
0cb8 c9			    ret 
0cb9			 
0cb9			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0cb9			 
0cb9			rand32: 
0cb9			;Inputs: 
0cb9			;   (seed1_0) holds the lower 16 bits of the first seed 
0cb9			;   (seed1_1) holds the upper 16 bits of the first seed 
0cb9			;   (seed2_0) holds the lower 16 bits of the second seed 
0cb9			;   (seed2_1) holds the upper 16 bits of the second seed 
0cb9			;   **NOTE: seed2 must be non-zero 
0cb9			;Outputs: 
0cb9			;   HL is the result 
0cb9			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0cb9			;Destroys: 
0cb9			;   AF 
0cb9			;Tested and passes all CAcert tests 
0cb9			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0cb9			;it has a period of 18,446,744,069,414,584,320 
0cb9			;roughly 18.4 quintillion. 
0cb9			;LFSR taps: 0,2,6,7  = 11000101 
0cb9			;291cc 
0cb9			;seed1_0=$+1 
0cb9			;    ld hl,12345 
0cb9			;seed1_1=$+1 
0cb9			;    ld de,6789 
0cb9			;    ld b,h 
0cb9			;    ld c,l 
0cb9			;    add hl,hl \ rl e \ rl d 
0cb9			;    add hl,hl \ rl e \ rl d 
0cb9			;    inc l 
0cb9			;    add hl,bc 
0cb9			;    ld (seed1_0),hl 
0cb9			;    ld hl,(seed1_1) 
0cb9			;    adc hl,de 
0cb9			;    ld (seed1_1),hl 
0cb9			;    ex de,hl 
0cb9			;seed2_0=$+1 
0cb9			;    ld hl,9876 
0cb9			;seed2_1=$+1 
0cb9			;    ld bc,54321 
0cb9			;    add hl,hl \ rl c \ rl b 
0cb9			;    ld (seed2_1),bc 
0cb9			;    sbc a,a 
0cb9			;    and %11000101 
0cb9			;    xor l 
0cb9			;    ld l,a 
0cb9			;    ld (seed2_0),hl 
0cb9			;    ex de,hl 
0cb9			;    add hl,bc 
0cb9			;    ret 
0cb9			; 
0cb9			 
0cb9			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0cb9			; 20 bytes, 86 cycles (excluding ret) 
0cb9			 
0cb9			; returns   hl = pseudorandom number 
0cb9			; corrupts   a 
0cb9			 
0cb9			; generates 16-bit pseudorandom numbers with a period of 65535 
0cb9			; using the xorshift method: 
0cb9			 
0cb9			; hl ^= hl << 7 
0cb9			; hl ^= hl >> 9 
0cb9			; hl ^= hl << 8 
0cb9			 
0cb9			; some alternative shift triplets which also perform well are: 
0cb9			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0cb9			 
0cb9			;  org 32768 
0cb9			 
0cb9			xrnd: 
0cb9 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0cbc 3e 00		  ld a,0 
0cbe bd			  cp l 
0cbf 20 02		  jr nz, .xrnd1 
0cc1 2e 01		  ld l, 1 
0cc3			.xrnd1: 
0cc3			 
0cc3 7c			  ld a,h 
0cc4 1f			  rra 
0cc5 7d			  ld a,l 
0cc6 1f			  rra 
0cc7 ac			  xor h 
0cc8 67			  ld h,a 
0cc9 7d			  ld a,l 
0cca 1f			  rra 
0ccb 7c			  ld a,h 
0ccc 1f			  rra 
0ccd ad			  xor l 
0cce 6f			  ld l,a 
0ccf ac			  xor h 
0cd0 67			  ld h,a 
0cd1			 
0cd1 22 d9 fa		  ld (xrandc),hl 
0cd4			 
0cd4 c9			  ret 
