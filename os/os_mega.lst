6818			; handle the auto run of code from files in storage 
6818			 
6818			 
6818			include "forth_startup.asm" 
6818			; Which startup method to use? 
6818			; 
6818			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6818			; followed by loading of a list of scripts in eeprom 
6818			 
6818			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6818			; from eeprom 
6818			 
6818			; Select with define in main stubs 
6818			 
6818			if STARTUP_V1 
6818				include "forth_startupv1.asm" 
6818			endif 
6818			if STARTUP_V2 
6818				include "forth_startupv2.asm" 
6818			; Version 2 of the startup  
6818			;  
6818			; Auto load any files in bank 1 that start with a '*' 
6818			; If no se storage then revert to using eprom 
6818			 
6818			 
