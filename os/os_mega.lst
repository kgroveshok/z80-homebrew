0d08			; Out:  D = result (rounded down) 
0d08			; 
0d08			;Sqr16: 
0d08			;    ld de,#0040 
0d08			;    ld a,l 
0d08			;    ld l,h 
0d08			;    ld h,d 
0d08			;    or a 
0d08			;    ld b,8 
0d08			;Sqr16_Loop: 
0d08			;    sbc hl,de 
0d08			;    jr nc,Sqr16_Skip 
0d08			;    add hl,de 
0d08			;Sqr16_Skip: 
0d08			;    ccf 
0d08			;    rl d 
0d08			;    add a,a 
0d08			;    adc hl,hl 
0d08			;    add a,a 
0d08			;    adc hl,hl 
0d08			;    djnz Sqr16_Loop 
0d08			;    ret 
