bea3			 
bea3			.SPII: 
bea3				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bea3			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bea3					if DEBUG_FORTH_WORDS_KEY 
bea3						DMARK "SPi" 
bea3						CALLMONITOR 
bea3					endif 
bea3			 
bea3					; TODO Get SPI byte 
bea3			 
bea3					call spi_read_byte 
bea3			 
bea3					if DEBUG_FORTH_WORDS 
bea3						DMARK "Si2" 
bea3						CALLMONITOR 
bea3					endif 
bea3					ld h, 0 
bea3					ld l, a 
bea3					if DEBUG_FORTH_WORDS 
bea3						DMARK "Si3" 
