23db			user_word_eol:  
23db				; hl contains the pointer to where to create a linked list item from the end 
23db				; of the user dict to continue on at the system word dict 
23db				 
23db				; poke the stub of the word list linked list to repoint to rom words 
23db			 
23db				; stub format 
23db				; db   word id 
23db				; dw    link to next word 
23db			        ; db char length of token 
23db				; db string + 0 term 
23db				; db exec code....  
23db			 
23db			;	ld a, WORD_SYS_ROOT     ; root word 
23db 36 00			ld (hl), WORD_SYS_ROOT		; word id 
23dd 23				inc hl 
23de			 
23de 11 87 25			ld de, sysdict 
23e1 73				ld (hl), e		; next word link ie system dict 
23e2 23				inc hl 
23e3 72				ld (hl), d		; next word link ie system dict 
23e4 23				inc hl	 
23e5			 
23e5			;	ld (hl), sysdict		; next word link ie system dict 
23e5			;	inc hl 
23e5			;	inc hl 
23e5			 
23e5			;	inc hl 
23e5			;	inc hl 
23e5			 
23e5			;	ld a, 2			; word length is 0 
23e5 36 02			ld (hl), 2 
23e7 23				inc hl 
23e8			 
23e8			;	ld a, '~'			; word length is 0 
23e8 36 7e			ld (hl), '~' 
23ea 23				inc hl 
23eb			;	ld a, 0			; save empty word 
23eb 36 00			ld (hl), 0 
