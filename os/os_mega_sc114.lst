8053			STORE_0_AUTOFILE: equ $21  
8053			STORE_0_BANKRUN: equ $23  
8053			STORE_0_FILERUN: equ $24  
8053			STORE_0_BANKRUNN: equ $25   ; human readable bank id  
8053			  
8053			; Block 0 offsets for settings  
8053			  
8053			; if set then skip prompt for start up and accept all  
8053			  
8053			STORE_0_QUICKSTART: equ $25  
