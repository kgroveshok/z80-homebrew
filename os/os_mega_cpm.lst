4447			.SESEL: 
4447				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
4447			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
4447			; | | Zero is disabled storage. 
4447					if DEBUG_FORTH_WORDS_KEY 
4447						DMARK "BN?" 
4447						CALLMONITOR 
4447					endif 
4447					ld a, (spi_device_id) 
4447					sub '0' 
4447					ld h, 0 
4447					ld l, a 
4447					FORTH_PUSH_VALUEHL 
4447					;call forth_push_numhl 
4447					NEXTW 
4447			.SESELS: 
4447				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
4447			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
4447			; | | Set to zero to disable storage. 
4447					if DEBUG_FORTH_WORDS_KEY 
4447						DMARK "BNK" 
4447						CALLMONITOR 
4447					endif 
4447			 
4447					ld a, 255 
4447					ld (spi_cartdev), a 
4447			 
4447					; get bank 
4447			 
4447					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4447			 
4447			;		push hl 
4447			 
4447					; destroy value TOS 
4447			 
4447					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4447			 
4447					; one value on hl get other one back 
4447			 
4447			;		pop hl 
4447			 
4447			 
4447					ld c, SPI_CE_HIGH 
4447					ld b, '0'    ; human readable bank number 
4447			 
4447					ld a, l 
4447			 
4447					if DEBUG_FORTH_WORDS 
4447						DMARK "BNK" 
4447						CALLMONITOR 
4447					endif 
4447			 
4447					; active low 
4447			 
4447			;		cp 0 
4447					or a 
4447					jr z, .bset 
4447					cp 1 
4447					jr nz, .b2 
4447					res 0, c 
4447					ld b, '1'    ; human readable bank number 
4447			.b2:		cp 2 
4447					jr nz, .b3 
4447					res 1, c 
4447					ld b, '2'    ; human readable bank number 
4447			.b3:		cp 3 
4447					jr nz, .b4 
4447					res 2, c 
4447					ld b, '3'    ; human readable bank number 
4447			.b4:		cp 4 
4447					jr nz, .b5 
4447					res 3, c 
4447					ld b, '4'    ; human readable bank number 
4447			.b5:		cp 5 
4447					jr nz, .bset 
4447					res 4, c 
4447					ld b, '5'    ; human readable bank number 
4447			 
4447			.bset: 
4447					ld a, c 
4447					ld (spi_device),a 
4447					ld a, b 
4447					ld (spi_device_id),a 
4447					if DEBUG_FORTH_WORDS 
4447						DMARK "BN2" 
4447						CALLMONITOR 
4447					endif 
4447			 
4447					; set default SPI clk pulse time as disabled for BANK use 
4447			 
4447					ld a, 0 
4447					ld (spi_clktime), a 
4447			 
4447					NEXTW 
4447			 
4447			.CARTDEV: 
4447				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
4447			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
4447			; | | Set to zero to disable devices. 
4447					if DEBUG_FORTH_WORDS_KEY 
4447						DMARK "CDV" 
4447						CALLMONITOR 
4447					endif 
4447			 
4447					; disable se storage bank selection 
4447			 
4447					ld a, SPI_CE_HIGH		; ce high 
4447					ld (spi_device), a 
4447			 
4447					; get bank 
4447			 
4447					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4447			 
4447			;		push hl 
4447			 
4447					; destroy value TOS 
4447			 
4447					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4447			 
4447					; one value on hl get other one back 
4447			 
4447			;		pop hl 
4447			 
4447					; active low 
4447			 
4447					ld c, 255 
4447			 
4447					ld a, l 
4447					if DEBUG_FORTH_WORDS 
4447						DMARK "CDV" 
4447						CALLMONITOR 
4447					endif 
4447			;		cp 0 
4447					or a 
4447					jr z, .cset 
4447					cp 1 
4447					jr nz, .c2 
4447					res 0, c 
4447			.c2:		cp 2 
4447					jr nz, .c3 
4447					res 1, c 
4447			.c3:		cp 3 
4447					jr nz, .c4 
4447					res 2, c 
4447			.c4:		cp 4 
4447					jr nz, .c5 
4447					res 3, c 
4447			.c5:		cp 5 
4447					jr nz, .c6 
4447					res 4, c 
4447			.c6:		cp 6 
4447					jr nz, .c7 
4447					res 5, c 
4447			.c7:		cp 7 
4447					jr nz, .c8 
4447					res 6, c 
4447			.c8:		cp 8 
4447					jr nz, .cset 
4447					res 7, c 
4447			.cset:		ld a, c 
4447					ld (spi_cartdev),a 
4447			 
4447					if DEBUG_FORTH_WORDS 
4447						DMARK "CD2" 
4447						CALLMONITOR 
4447					endif 
4447			 
4447					; set default SPI clk pulse time as 10ms for CARTDEV use 
4447			 
4447					ld a, $0a 
4447					ld (spi_clktime), a 
4447					NEXTW 
4447			endif 
4447			 
