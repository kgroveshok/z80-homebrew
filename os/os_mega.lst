6849 3e 00			ld a, kLCD_Line1  
684b cd 55 69		            CALL fLCD_Pos       ;Position cursor to location in A  
684e 06 28			ld b, display_cols  
6850 ed 5b f9 fa		ld de, (display_write_tmp)  
6854 cd a0 68			call write_len_string  
6857				  
