0f36			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
0f36			 
0f36			; String Length 
0f36			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
0f36			 
0f36			; Get the length of the null-terminated string starting at $8000 hl 
0f36			;    LD     HL, $8000 
0f36			 
0f36			strlenz: 
0f36			 
0f36 af			    XOR    A               ; Zero is the value we are looking for. 
0f37 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
0f38 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
0f39			                           ; 65, 536 bytes (the entire addressable memory space). 
0f39 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f3b			 
0f3b			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f3b 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
0f3c 6f			    LD     L, A             ; number of bytes 
0f3d ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f3f 2b			    DEC    HL              ; Compensate for null. 
0f40 c9				ret 
0f41			 
0f41			; Get the length of the A terminated string starting at $8000 hl 
0f41			;    LD     HL, $8000 
0f41			 
0f41			strlent: 
0f41			 
0f41			                  ; A is the value we are looking for. 
0f41 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
0f43 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
0f45			                           ; 65, 536 bytes (the entire addressable memory space). 
0f45 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
0f47			 
0f47			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
0f47 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
0f49 2e 00		    LD     L, 0             ; number of bytes 
0f4b ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
0f4d 2b			    DEC    HL              ; Compensate for null. 
0f4e c9				ret 
