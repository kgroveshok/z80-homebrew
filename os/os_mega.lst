2b27			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2b27			; | | At start the current various registers will be displayed with contents. 
2b27			; | | Top right corner will show the most recent debug marker seen. 
2b27			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2b27			; | | and the return stack pointer (RSP). 
2b27			; | | Pressing: 
2b27			; | |  
2b27			; | |    1 - Initial screen 
2b27			; | |  
2b27			; | |    2 - Display a data dump of HL 
2b27			; | |  
2b27			; | |    3 - Display a data dump of DE 
2b27			; | |  
2b27			; | |    4 - Display a data dump of BC 
2b27			; | |  
2b27			; | |    5 - Display a data dump of HL 
2b27			; | |  
2b27			; | |    6 - Display a data dump of DSP 
2b27			; | |  
2b27			; | |    7 - Display a data dump of RSP 
2b27			; | |  
2b27			; | |    8 - Display a data dump of what is at DSP 
2b27			; | |  
2b27			; | |    9 - Display a data dump of what is at RSP 
2b27			; | |  
2b27			; | |    0 - Exit monitor and continue running. This will also enable break points 
2b27			; | |  
2b27			; | |    * - Disable break points 
2b27			; | |  
2b27			; | |    # - Enter traditional monitor mode 
2b27			; | |  
2b27			; | | 
2b27			; | | Monitor Mode 
2b27			; | | ------------ 
2b27			; | | A prompt of '>' will be shown for various commands: 
2b27			; | |  
2b27			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2b27			; | |  
2b27			; | |    C - Continue display a data dump from the last set address 
2b27			; | |  
2b27			; | |    M xxxx - Set start of memory edit at address xx 
2b27			; | |  
2b27			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2b27			; | |  
2b27			; | |    G xxxx - Exec code at specific address 
2b27			; | |  
2b27			; | |    Q - Return to previous 
2b27				if DEBUG_FORTH_WORDS_KEY 
2b27					DMARK "MON" 
2b27				if DEMARK_VERSION = 1  
2b27 e5					push hl  
2b28 21 30 2b				ld hl, .dmark  
2b2b 22 9b fd				ld (debug_mark), hl  
2b2e				endif  
2b2e				if DEMARK_VERSION = 0  
2b2e					push af  
2b2e					ld a, (.dmark)  
2b2e					ld (debug_mark),a  
2b2e					ld a, (.dmark+1)  
2b2e					ld (debug_mark+1),a  
2b2e					ld a, (.dmark+2)  
2b2e					ld (debug_mark+2),a  
2b2e				endif  
2b2e 18 04			jr .pastdmark  
2b30 ..			.dmark: db "MON"  
2b33				if DEMARK_VERSION = 1  
2b33 00					db 0  
2b34				endif  
2b34				if DEMARK_VERSION = 1  
2b34 e1			.pastdmark: pop hl  
2b35				endif  
2b35				if DEMARK_VERSION = 0  
