9c8e			user_word_eol:  
9c8e				; hl contains the pointer to where to create a linked list item from the end 
9c8e				; of the user dict to continue on at the system word dict 
9c8e				 
9c8e				; poke the stub of the word list linked list to repoint to rom words 
9c8e			 
9c8e				; stub format 
9c8e				; db   word id 
9c8e				; dw    link to next word 
9c8e			        ; db char length of token 
9c8e				; db string + 0 term 
9c8e				; db exec code....  
9c8e			 
9c8e			;	ld a, WORD_SYS_ROOT     ; root word 
9c8e 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9c90 23				inc hl 
9c91			 
9c91 11 3a 9e			ld de, sysdict 
9c94 73				ld (hl), e		; next word link ie system dict 
9c95 23				inc hl 
9c96 72				ld (hl), d		; next word link ie system dict 
9c97 23				inc hl	 
9c98			 
9c98			;	ld (hl), sysdict		; next word link ie system dict 
9c98			;	inc hl 
9c98			;	inc hl 
9c98			 
9c98			;	inc hl 
9c98			;	inc hl 
9c98			 
9c98			;	ld a, 2			; word length is 0 
9c98 36 02			ld (hl), 2 
9c9a 23				inc hl 
9c9b			 
9c9b			;	ld a, '~'			; word length is 0 
9c9b 36 7e			ld (hl), '~' 
9c9d 23				inc hl 
9c9e			;	ld a, 0			; save empty word 
9c9e 36 00			ld (hl), 0 
