10eb			      ; Freed block is adjacent to next, merge into one bigger block 
10eb eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
10ec 5e			      ld    E, (HL) 
10ed 23			      inc   HL 
10ee 56			      ld    D, (HL) 
10ef e5			      push  HL                      ; Save ptr to next block for later 
10f0			 
10f0 60			      ld    H, B                    ; Store ptr from next block into freed block 
10f1 69			      ld    L, C 
10f2 73			      ld    (HL), E 
10f3 23			      inc   HL 
10f4 72			      ld    (HL), D 
10f5			 
10f5 e1			      pop   HL                      ; Restore ptr to next block 
10f6 23			      inc   HL                      ; Load size of next block into DE 
10f7 5e			      ld    E, (HL) 
10f8 23			      inc   HL 
10f9 56			      ld    D, (HL) 
10fa d5			      push  DE                      ; Save next block size for later 
10fb			 
10fb 60			      ld    H, B                    ; Load size of freed block into HL 
10fc 69			      ld    L, C 
10fd 23			      inc   HL 
10fe 23			      inc   HL 
10ff 5e			      ld    E, (HL) 
1100 23			      inc   HL 
1101 56			      ld    D, (HL) 
1102 eb			      ex    DE, HL 
1103			 
1103 d1			      pop   DE                      ; Restore size of next block 
1104 19			      add   HL, DE                  ; Add sizes of both blocks 
1105 eb			      ex    DE, HL 
1106			 
1106 60			      ld    H, B                    ; Store new bigger size into freed block 
1107 69			      ld    L, C 
1108 23			      inc   HL 
1109 23			      inc   HL 
110a 73			      ld    (HL), E 
110b 23			      inc   HL 
110c 72			      ld    (HL), D 
