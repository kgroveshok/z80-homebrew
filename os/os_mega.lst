7600			; **********************************************************************  
7600			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
7600			; **********************************************************************  
7600			;  
7600			; **  Written as a Small Computer Monitor App   
7600			; **  Version 0.1 SCC 2018-05-16  
7600			; **  www.scc.me.uk  
7600			;  
7600			; **********************************************************************  
7600			;  
7600			; This module provides support for alphanumeric LCD modules using with  
7600			; *  HD44780 (or compatible) controller  
7600			; *  5 x 7 pixel fonts  
7600			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
7600			; *  Interface via six digital outputs to the display (see below)  
7600			;  
7600			; LCD module pinout:  
7600			;   1  Vss   0v supply  
7600			;   2  Vdd   5v supply  
7600			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
7600			;   4  RS    High = data, Low = instruction  
7600			;   5  R/W   High = Read, Low = Write  
7600			;   6  E     Enable signal (active high)  
7600			;   7  DB0   Data bit 0  
7600			;   8  DB1   Data bit 1  
7600			;   9  DB2   Data bit 2  
7600			;  10  DB3   Data bit 3  
7600			;  11  DB4   Data bit 4  
7600			;  12  DB5   Data bit 5  
7600			;  13  DB6   Data bit 6  
7600			;  14  DB7   Data bit 7  
7600			;  15  A     Backlight anode (+)  
7600			;  16  K     Backlight cathode (-)  
7600			;  
7600			; This interfacing method uses 4-bit data mode and uses time delays  
7600			; rather than polling the display's ready status. As a result the   
7600			; interface only requires 6 simple output lines:  
7600			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
7600			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
7600			;   LCD DB4 = Microcomputer output port bit 4  
7600			;   LCD DB5 = Microcomputer output port bit 5  
7600			;   LCD DB6 = Microcomputer output port bit 6  
7600			;   LCD DB7 = Microcomputer output port bit 7  
7600			; Display's R/W is connected to 0v so it is always in write mode  
7600			; All 6 connections must be on the same port address <kLCDPrt>  
7600			; This method also allows a decent length of cable from micro to LCD  
7600			;  
7600			; **********************************************************************  
7600			;  
7600			; To include the code for any given function provided by this module,   
7600			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
7600			; the parent source file.  
7600			; For example:  #REQUIRES   uHexPrefix  
7600			;  
7600			; Also #INCLUDE this file at some point after the #REQUIRES statements  
7600			; in the parent source file.  
7600			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
7600			;  
7600			; These are the function names provided by this module:  
7600			; fLCD_Init                     ;Initialise LCD  
7600			; fLCD_Inst                     ;Send instruction to LCD  
7600			; fLCD_Data                     ;Send data byte to LCD  
7600			; fLCD_Pos                      ;Position cursor  
7600			; fLCD_Str                      ;Display string  
7600			; fLCD_Def                      ;Define custom character  
7600			;  
7600			; **********************************************************************  
7600			;  
7600			; Requires SCMonAPI.asm to also be included in the project  
7600			;  
7600			  
7600			  
7600			; **********************************************************************  
7600			; **  Constants  
7600			; **********************************************************************  
7600			  
7600			; Constants that must be defined externally  
7600			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
7600			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
7600			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
7600			;kLCDWidth: EQU 20             ;Width in characters  
7600			  
7600			; general line offsets in any frame buffer  
7600			  
7600			  
7600			display_row_1: equ 0  
7600			display_row_2: equ display_row_1+display_cols  
7600			display_row_3: equ display_row_2 + display_cols  
7600			display_row_4: equ display_row_3 + display_cols  
7600			;display_row_4_eol:   
7600			  
7600			  
7600			; Cursor position values for the start of each line  
7600			  
7600			; E  
7600			kLCD_Line1: EQU 0x00   
7600			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
7600			; E1  
7600			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
7600			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
7600			  
7600			; Instructions to send as A register to fLCD_Inst  
7600			kLCD_Clear: EQU 00000001b     ;LCD clear  
7600			kLCD_Off:   EQU 00001000b     ;LCD off  
7600			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
7600			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
7600			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
7600			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
7600			  
7600			; Constants used by this code module  
7600			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
7600			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
7600			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
7600			  
7600			  
7600			  
7600			; **********************************************************************  
7600			; **  LCD support functions  
7600			; **********************************************************************  
7600			  
7600			; Initialise alphanumeric LCD module  
7600			; LCD control register codes:  
7600			;   DL   0 = 4-bit mode        1 = 8-bit mode  
7600			;   N    0 = 1-line mode       1 = 2-line mode  
7600			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
7600			;   D    0 = Display off       1 = Display on  
7600			;   C    0 = Cursor off        1 = Cursor on  
7600			;   B    0 = Blinking off      1 = Blinking on  
7600			;   ID   0 = Decrement mode    1 = Increment mode  
7600			;   SH   0 = Entire shift off  1 = Entire shift on  
7600 3e 28		fLCD_Init:  LD   A, 40  
7602 cd 27 77		            CALL LCDDelay       ;Delay 40ms after power up  
7605			; For reliable reset set 8-bit mode - 3 times  
7605 cd f7 76		            CALL WrFn8bit       ;Function = 8-bit mode  
7608 cd f7 76		            CALL WrFn8bit       ;Function = 8-bit mode  
760b cd f7 76		            CALL WrFn8bit       ;Function = 8-bit mode  
760e			; Set 4-bit mode  
760e cd f3 76		            CALL WrFn4bit       ;Function = 4-bit mode  
7611 cd 25 77		            CALL LCDDelay1      ;Delay 37 us or more  
7614			; Function set  
7614 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
7616 cd 29 76		            CALL fLCD_Inst      ;2 line, display on  
7619			; Display On/Off control  
7619 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
761b cd 29 76		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
761e			; Display Clear  
761e 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
7620 cd 29 76		            CALL fLCD_Inst      ;Clear display  
7623			; Entry mode  
7623 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
7625 cd 29 76		            CALL fLCD_Inst      ;Increment mode, shift off  
7628			; Display module now initialised  
7628 c9			            RET  
7629			; ok to here  
7629			  
7629			; Write instruction to LCD  
7629			;   On entry: A = Instruction byte to be written  
7629			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7629 f5			fLCD_Inst:  PUSH AF  
762a f5			            PUSH AF  
762b cd 3d 76		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
762e f1			            POP  AF  
762f 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
7630 17			            RLA  
7631 17			            RLA  
7632 17			            RLA  
7633 cd 3d 76		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
7636 3e 02		            LD   A, 2  
7638 cd 27 77		            CALL LCDDelay       ;Delay 2 ms to complete   
763b f1			            POP  AF  
763c c9			            RET  
763d			Wr4bits:   
763d f5					push af  
763e 3a f9 fa				ld a, (display_lcde1e2)  
7641 fe 00				cp 0     ; e  
7643 20 10				jr nz, .wea2	  
7645 f1					pop af  
7646 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7648 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
764a cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
764c cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
764e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7650 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
7652 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7654 c9			            RET  
7655 f1			.wea2:		pop af  
7656 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7658 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
765a cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
765c cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
765e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
7660 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
7662 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7664 c9			            RET  
7665			  
7665			  
7665			; Write data to LCD  
7665			;   On entry: A = Data byte to be written  
7665			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7665 f5			fLCD_Data:  PUSH AF  
7666 f5			            PUSH AF  
7667 cd 79 76		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
766a f1			            POP  AF  
766b 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
766c 17			            RLA  
766d 17			            RLA  
766e 17			            RLA  
766f cd 79 76		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
7672 3e 96		            LD   A, 150  
7674 3d			Wait:      DEC  A              ;Wait a while to allow data   
7675 20 fd		            JR   NZ, Wait      ;  write to complete  
7677 f1			            POP  AF  
7678 c9			            RET  
7679			Wr4bitsa:     
7679 f5					push af  
767a 3a f9 fa				ld a, (display_lcde1e2)  
767d fe 00				cp 0     ; e1  
767f 20 16				jr nz, .we2	  
7681 f1					pop af  
7682 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
7684 cb d7		            SET  kLCDBitRS, A  
7686 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
7688 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
768a cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
768c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
768e cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
7690 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
7692 cb 97		            RES  kLCDBitRS, A  
7694 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7696 c9			            RET  
7697 f1			.we2:		pop af  
7698 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
769a cb d7		            SET  kLCDBitRS, A  
769c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
769e cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
76a0 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
76a2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
76a4 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
76a6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
76a8 cb 97		            RES  kLCDBitRS, A  
76aa d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
76ac c9			            RET  
76ad			  
76ad			  
76ad			; Position cursor to specified location  
76ad			;   On entry: A = Cursor position  
76ad			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
76ad f5			fLCD_Pos:   PUSH AF  
76ae					; at this point set the E1 or E2 flag depending on position  
76ae			  
76ae c5					push bc  
76af			;		push af  
76af 06 00				ld b, 0  
76b1 4f					ld c, a  
76b2 3e 4f				ld a, kLCD_Line3-1  
76b4 b7			 		or a      ;clear carry flag  
76b5 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
76b6 38 04				jr c, .pe1  
76b8			  
76b8					; E selection  
76b8 cb 80				res 0, b         ; bit 0 unset e  
76ba			;		pop af    ; before line 3 so recover orig pos  
76ba			;		ld c, a    ; save for poking back  
76ba 18 06				jr .peset	          
76bc			.pe1:          	; E2 selection  
76bc cb c0				set 0, b         ; bit 0 set e1  
76be 79					ld a, c  
76bf de 4f				sbc a, kLCD_Line3-1  
76c1 4f					ld c, a	         ; save caculated offset  
76c2			;		pop af     ; bin this original value now we have calculated form  
76c2			  
76c2			.peset:		; set bit  
76c2 78					ld a, b  
76c3 32 f9 fa				ld (display_lcde1e2), a 	  
76c6 79					ld a, c  
76c7 c1					pop bc  
76c8			  
76c8 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
76ca cd 29 76		            CALL fLCD_Inst      ;Write instruction to LCD  
76cd f1			            POP  AF  
76ce c9			            RET  
76cf			  
76cf			  
76cf			; Output text string to LCD  
76cf			;   On entry: DE = Pointer to null terminated text string  
76cf			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
76cf 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
76d0 b7			            OR   A              ;Null terminator?  
76d1 c8			            RET  Z              ;Yes, so finished  
76d2 cd 65 76		            CALL fLCD_Data      ;Write character to display  
76d5 13			            INC  DE             ;Point to next character  
76d6 18 f7		            JR   fLCD_Str       ;Repeat  
76d8 c9					ret  
76d9			  
76d9			; Define custom character  
76d9			;   On entry: A = Character number (0 to 7)  
76d9			;             DE = Pointer to character bitmap data  
76d9			;   On exit:  A = Next character number  
76d9			;             DE = Next location following bitmap  
76d9			;             BC HL IX IY I AF' BC' DE' HL' preserved  
76d9			; Character is   
76d9 c5			fLCD_Def:   PUSH BC  
76da f5			            PUSH AF  
76db 07			            RLCA                ;Calculate location  
76dc 07			            RLCA                ;  for bitmap data  
76dd 07			            RLCA                ;  = 8 x CharacterNumber  
76de f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
76e0 cd 29 76		            CALL fLCD_Inst      ;Write instruction to LCD  
76e3 06 00		            LD   B, 0  
76e5 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
76e6 cd 65 76		            CALL fLCD_Data      ;Write byte to display  
76e9 13			            INC  DE             ;Point to next byte  
76ea 04			            INC  B              ;Count bytes  
76eb cb 58		            BIT  3, B           ;Finish all 8 bytes?  
76ed 28 f6		            JR   Z, Loop       ;No, so repeat  
76ef f1			            POP  AF  
76f0 3c			            INC  A              ;Increment character number  
76f1 c1			            POP  BC  
76f2 c9			            RET  
76f3			  
76f3			  
76f3			; **********************************************************************  
76f3			; **  Private functions  
76f3			; **********************************************************************  
76f3			  
76f3			; Write function to LCD  
76f3			;   On entry: A = Function byte to be written  
76f3			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
76f3 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
76f5 18 02		            JR   WrFunc  
76f7 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
76f9 f5			WrFunc:     PUSH AF  
76fa f5					push af  
76fb 3a f9 fa				ld a, (display_lcde1e2)  
76fe fe 00				cp 0     ; e1  
7700 20 0f				jr nz, .wfea2	  
7702 f1					pop af  
7703 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7705 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
7707 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
7709 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
770b cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
770d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
770f 18 0d			jr .wfskip  
7711 f1			.wfea2:		pop af  
7712 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
7714 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
7716 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
7718 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
771a cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
771c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
771e 3e 05		.wfskip:            LD  A, 5  
7720 cd 27 77		            CALL LCDDelay       ;Delay 5 ms to complete  
7723 f1			            POP  AF  
7724 c9			            RET  
7725			  
7725			  
7725			; Delay in milliseconds  
7725			;   On entry: A = Number of milliseconds delay  
7725			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
7725 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
7727 d5			LCDDelay:   PUSH DE  
7728 5f			            LD   E, A           ;Delay by 'A' ms  
7729 16 00		            LD   D, 0  
772b cd 71 0c		            CALL aDelayInMS  
772e d1			            POP  DE  
772f c9			            RET  
