9151 71			      ld    (HL), C                 ; Point prev free block to freed block 
9152 23			      inc   HL 
9153 70			      ld    (HL), B 
9154			 
9154 60			      ld    H, B                    ; Point freed block at next free block 
9155 69			      ld    L, C 
9156 73			      ld    (HL), E 
9157 23			      inc   HL 
9158 72			      ld    (HL), D 
9159			 
9159			      ; Check if the freed block is adjacent to the next free block 
9159 23			      inc   HL                      ; Load size of freed block into HL 
915a 5e			      ld    E, (HL) 
915b 23			      inc   HL 
915c 56			      ld    D, (HL) 
915d eb			      ex    DE, HL 
915e			 
915e 09			      add   HL, BC                  ; Add addr of freed block and its size 
915f			 
915f dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
9162 dd 56 01		      ld    D, (IX+1) 
9165			 
9165 b7			      or    A                       ; Clear the carry flag 
9166 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
9168 20 22		      jr    NZ, free_check_adjacent_to_prev 
916a			 
916a			      ; Freed block is adjacent to next, merge into one bigger block 
916a eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
916b 5e			      ld    E, (HL) 
916c 23			      inc   HL 
916d 56			      ld    D, (HL) 
916e e5			      push  HL                      ; Save ptr to next block for later 
916f			 
916f 60			      ld    H, B                    ; Store ptr from next block into freed block 
9170 69			      ld    L, C 
9171 73			      ld    (HL), E 
9172 23			      inc   HL 
9173 72			      ld    (HL), D 
9174			 
9174 e1			      pop   HL                      ; Restore ptr to next block 
9175 23			      inc   HL                      ; Load size of next block into DE 
9176 5e			      ld    E, (HL) 
9177 23			      inc   HL 
9178 56			      ld    D, (HL) 
9179 d5			      push  DE                      ; Save next block size for later 
917a			 
917a 60			      ld    H, B                    ; Load size of freed block into HL 
917b 69			      ld    L, C 
917c 23			      inc   HL 
917d 23			      inc   HL 
917e 5e			      ld    E, (HL) 
917f 23			      inc   HL 
9180 56			      ld    D, (HL) 
9181 eb			      ex    DE, HL 
9182			 
9182 d1			      pop   DE                      ; Restore size of next block 
9183 19			      add   HL, DE                  ; Add sizes of both blocks 
9184 eb			      ex    DE, HL 
9185			 
9185 60			      ld    H, B                    ; Store new bigger size into freed block 
9186 69			      ld    L, C 
9187 23			      inc   HL 
9188 23			      inc   HL 
9189 73			      ld    (HL), E 
918a 23			      inc   HL 
918b 72			      ld    (HL), D 
