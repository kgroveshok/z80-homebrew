0ed0 1a			  ld a,(de) 
0ed1 d6 30		  sub 30h 
0ed3 fe 0a		  cp 10 
0ed5 d0			  ret nc 
0ed6 13			  inc de 
0ed7 44			  ld b,h 
0ed8 4d			  ld c,l 
0ed9 29			  add hl,hl 
0eda 29			  add hl,hl 
0edb 09			  add hl,bc 
0edc 29			  add hl,hl 
0edd 85			  add a,l 
0ede 6f			  ld l,a 
0edf 30 ef		  jr nc,.u16a 
0ee1 24			  inc h 
0ee2 c3 d0 0e		  jp .u16a 
