d2c5				endif 
d2c5 cd 58 8a			call cmp16 
d2c8 ca d1 d2			jp z, .chk_fault3 
d2cb 11 68 d3			ld de, sfaultro 
d2ce c3 fa d2			jp .chk_fault 
d2d1			.chk_fault3:  
