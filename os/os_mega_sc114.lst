bf2d				endm 
# End of macro CWHEAD
bf2d			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bf2d			; | 
bf2d			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bf2d			; | |  
bf2d			; | | e.g. 
bf2d			; | |         #30 a var ! 
bf2d			; | |         a var @ . 
bf2d			; | |   
bf2d			; | |     Displays the number 30 
bf2d			; | | 
bf2d			; | | Each variable pointer is a word so can use for any words that use that:  
bf2d			; | |  
bf2d			; | | e.g. 
bf2d			; | |  
bf2d			; | |         #30 a var 2! 
bf2d			; | |         a var 2@ . 
bf2d			; | |   
bf2d			; | |     Displays the number 30 
bf2d			; | |  
bf2d			; | | > [!NOTE]  
bf2d			; ! | > If a full string is passed then only the first char is looked at 
bf2d			; | | > Any other char could exceed bounds checks!  
bf2d			; | | > 
bf2d			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bf2d			 
bf2d					if DEBUG_FORTH_WORDS_KEY 
bf2d						DMARK "VAR" 
bf2d				if DEMARK_VERSION = 1  
bf2d e5					push hl  
bf2e 21 36 bf				ld hl, .dmark  
bf31 22 60 ee				ld (debug_mark), hl  
bf34				endif  
