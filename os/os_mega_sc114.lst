920f			.diritem:	 
920f				push bc 
920f				; for each of the current ids do a search for them and if found push to stack 
920f			 
920f					ld hl, STORE_BLOCK_PHY 
920f					ld d, 0		 ; look for extent 0 of block id as this contains file name 
920f					ld e,b 
920f			 
920f					call storage_findnextid 
920f			 
920f			 
920f					; if found hl will be non zero 
920f			 
920f					call ishlzero 
920f					jr z, .dirnotfound 
920f			 
920f					; increase count 
920f			 
920f					pop bc	 
920f					inc c 
920f					push bc 
920f					 
920f			 
920f					; get file header and push the file name 
920f			 
920f					ld de, store_page 
920f					call storage_read_block 
920f			 
920f					; push file id to stack 
920f				 
920f					ld a, (store_page) 
920f					ld h, 0 
920f					ld l, a 
920f			 
920f					;call forth_push_numhl 
920f					; TODO store id 
920f			 
920f					push hl 
920f			 
920f					; push extent count to stack  
920f				 
920f					ld hl, store_page+3 
920f			 
920f					; get file name length 
920f			 
920f					call strlenz   
920f			 
920f					inc hl   ; cover zero term 
920f					inc hl  ; stick the id at the end of the area 
920f			 
920f					push hl 
920f					pop bc    ; move length to bc 
920f			 
920f					call malloc 
920f			 
920f					; TODO save malloc area to scratch 
920f			 
920f					ex de, hl 
920f					ld hl, (store_tmp2) 
920f					ld (hl), e 
920f					inc hl 
920f					ld (hl), d 
920f					inc hl 
920f					ld (store_tmp2), hl 
920f			 
920f					 
920f			 
920f					;pop hl   ; get source 
920f			;		ex de, hl    ; swap aronund	 
920f			 
920f					ld hl, store_page+3 
920f					if DEBUG_FORTH_WORDS 
920f						DMARK "CFd" 
920f						CALLMONITOR 
920f					endif 
920f					ldir 
920f			 
920f					; de is past string, move back one and store id 
920f					 
920f					dec de 
920f			 
920f					; store file id 
920f			 
920f					pop hl 
920f					ex de,hl 
920f					ld (hl), e 
920f			 
920f					if DEBUG_FORTH_WORDS 
920f						DMARK "Cdi" 
920f						CALLMONITOR 
920f					endif 
920f					 
920f			.dirnotfound: 
920f					pop bc     
920f					djnz .diritem 
920f				 
920f			.dirdone:	 
920f			 
920f			;		ld a, 0 
920f					ld hl, (store_tmp2) 
920f					ld (hl), 0 
920f					inc hl 
920f					ld (hl), 0 
920f					inc hl 
920f					; push a count of the dir items found 
920f			 
920f			;		ld h, 0 
920f			;		ld l, c 
920f			 
920f				ret 
920f			 
920f			endif 
