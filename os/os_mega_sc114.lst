8f49 23			      inc   HL 
8f4a 56			      ld    D, (HL) 
8f4b e5			      push  HL                      ; Save ptr to next block for later 
8f4c			 
8f4c 60			      ld    H, B                    ; Store ptr from next block into freed block 
8f4d 69			      ld    L, C 
8f4e 73			      ld    (HL), E 
8f4f 23			      inc   HL 
8f50 72			      ld    (HL), D 
8f51			 
8f51 e1			      pop   HL                      ; Restore ptr to next block 
8f52 23			      inc   HL                      ; Load size of next block into DE 
8f53 5e			      ld    E, (HL) 
8f54 23			      inc   HL 
8f55 56			      ld    D, (HL) 
8f56 d5			      push  DE                      ; Save next block size for later 
8f57			 
8f57 60			      ld    H, B                    ; Load size of freed block into HL 
8f58 69			      ld    L, C 
8f59 23			      inc   HL 
8f5a 23			      inc   HL 
8f5b 5e			      ld    E, (HL) 
8f5c 23			      inc   HL 
8f5d 56			      ld    D, (HL) 
8f5e eb			      ex    DE, HL 
8f5f			 
8f5f d1			      pop   DE                      ; Restore size of next block 
8f60 19			      add   HL, DE                  ; Add sizes of both blocks 
8f61 eb			      ex    DE, HL 
8f62			 
8f62 60			      ld    H, B                    ; Store new bigger size into freed block 
8f63 69			      ld    L, C 
8f64 23			      inc   HL 
8f65 23			      inc   HL 
8f66 73			      ld    (HL), E 
8f67 23			      inc   HL 
8f68 72			      ld    (HL), D 
