240a			user_word_eol:  
240a				; hl contains the pointer to where to create a linked list item from the end 
240a				; of the user dict to continue on at the system word dict 
240a				 
240a				; poke the stub of the word list linked list to repoint to rom words 
240a			 
240a				; stub format 
240a				; db   word id 
240a				; dw    link to next word 
240a			        ; db char length of token 
240a				; db string + 0 term 
240a				; db exec code....  
240a			 
240a			;	ld a, WORD_SYS_ROOT     ; root word 
240a 36 00			ld (hl), WORD_SYS_ROOT		; word id 
240c 23				inc hl 
240d			 
240d 11 b6 25			ld de, sysdict 
2410 73				ld (hl), e		; next word link ie system dict 
2411 23				inc hl 
2412 72				ld (hl), d		; next word link ie system dict 
2413 23				inc hl	 
2414			 
2414			;	ld (hl), sysdict		; next word link ie system dict 
2414			;	inc hl 
2414			;	inc hl 
2414			 
2414			;	inc hl 
2414			;	inc hl 
2414			 
2414			;	ld a, 2			; word length is 0 
2414 36 02			ld (hl), 2 
2416 23				inc hl 
2417			 
2417			;	ld a, '~'			; word length is 0 
2417 36 7e			ld (hl), '~' 
2419 23				inc hl 
241a			;	ld a, 0			; save empty word 
241a 36 00			ld (hl), 0 
