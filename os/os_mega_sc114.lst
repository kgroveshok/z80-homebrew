8dfd			if MALLOC_2 
8dfd			; Z80 Malloc and Free Functions 
8dfd			 
8dfd			; Malloc Function: 
8dfd			; Input: 
8dfd			;   HL: Size of block to allocate 
8dfd			; Output: 
8dfd			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8dfd			 
8dfd			malloc: 
8dfd				 
8dfd			if DEBUG_FORTH_MALLOC_HIGH 
8dfd			call malloc_guard_entry 
8dfd			endif 
8dfd			 
8dfd			 
8dfd			 
8dfd			 
8dfd					if DEBUG_FORTH_MALLOC 
8dfd						DMARK "mal" 
8dfd						CALLMONITOR 
8dfd					endif 
8dfd			    push af            ; Save AF register 
8dfd			    ld a, l            ; Load low byte of size into A 
8dfd			    or h               ; Check if size is zero 
8dfd			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
8dfd			 
8dfd			    ; Allocate memory 
8dfd			    ld hl, (heap_start) ; Load start of heap into HL 
8dfd					if DEBUG_FORTH_MALLOC 
8dfd						DMARK "ma1" 
8dfd						CALLMONITOR 
8dfd					endif 
8dfd			    call malloc_internal ; Call internal malloc function 
8dfd			    pop af             ; Restore AF register 
8dfd			if DEBUG_FORTH_MALLOC_HIGH 
8dfd			call malloc_guard_exit 
8dfd			call malloc_guard_zerolen 
8dfd			endif 
8dfd			    ret                ; Return 
8dfd			 
8dfd			; Free Function: 
8dfd			; Input: 
8dfd			;   HL: Pointer to memory block to free 
8dfd			; Output: 
8dfd			;   None 
8dfd			 
8dfd			free: 
8dfd			    push af            ; Save AF register 
8dfd			    ld a, l            ; Load low byte of pointer into A 
8dfd			    or h               ; Check if pointer is NULL 
8dfd			    jp z, free_exit    ; If pointer is NULL, exit 
8dfd			 
8dfd			    ; Free memory 
8dfd			    ld hl, (heap_start) ; Load start of heap into HL 
8dfd			    call free_internal  ; Call internal free function 
8dfd			    pop af             ; Restore AF register 
8dfd			    ret                ; Return 
8dfd			 
8dfd			; Internal Malloc Function: 
8dfd			; Input: 
8dfd			;   HL: Size of block to allocate 
8dfd			; Output: 
8dfd			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8dfd			 
8dfd			malloc_internal: 
8dfd			    ld bc, 2           ; Number of bytes to allocate for management overhead 
8dfd			    add hl, bc         ; Add management overhead to requested size 
8dfd			    ex de, hl          ; Save total size in DE, and keep it in HL 
8dfd					if DEBUG_FORTH_MALLOC 
8dfd						DMARK "ma2" 
8dfd						CALLMONITOR 
8dfd					endif 
8dfd			 
8dfd			    ; Search for free memory block 
8dfd			    ld de, (heap_end)  ; Load end of heap into DE 
8dfd			    ld bc, 0           ; Initialize counter 
8dfd			 
8dfd					if DEBUG_FORTH_MALLOC 
8dfd						DMARK "ma2" 
8dfd						CALLMONITOR 
8dfd					endif 
8dfd			malloc_search_loop: 
8dfd			    ; Check if current block is free 
8dfd			    ld a, (hl)         ; Load current block's status (free or used) 
8dfd			;    cp 0               ; Compare with zero (free) 
8dfd				or a 
8dfd			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
8dfd			 
8dfd			    ; Check if current block is large enough 
8dfd			    ld a, (hl+1)       ; Load high byte of block size 
8dfd			    cp l               ; Compare with low byte of requested size 
8dfd			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
8dfd			 
8dfd			    ld a, (hl+2)       ; Load low byte of block size 
8dfd			    cp h               ; Compare with high byte of requested size 
8dfd			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
8dfd			 
8dfd			    ; Mark block as used 
8dfd			    ld (hl), 0xFF      ; Set status byte to indicate used block 
8dfd			 
8dfd			    ; Calculate remaining space in block 
8dfd			    ld bc, 0           ; Clear BC 
8dfd			    add hl, bc         ; Increment HL to point to start of data block 
8dfd			    add hl, de         ; HL = HL + DE (total size) 
8dfd			    ld bc, 1           ; Number of bytes to allocate for management overhead 
8dfd			    add hl, bc         ; Add management overhead to start of data block 
8dfd			 
8dfd			    ; Save pointer to allocated block in HL 
8dfd			if DEBUG_FORTH_MALLOC_HIGH 
8dfd						DMARK "ma5" 
8dfd			call malloc_guard_exit 
8dfd			call malloc_guard_zerolen 
8dfd			endif 
8dfd			    ret 
8dfd			 
8dfd			malloc_skip_block_check: 
8dfd			    ; Move to the next block 
8dfd			    ld bc, 3           ; Size of management overhead 
8dfd			    add hl, bc         ; Move to the next block 
8dfd			    inc de             ; Increment counter 
8dfd			 
8dfd			    ; Check if we have reached the end of heap 
8dfd			    ld a, e            ; Load low byte of heap end address 
8dfd			    cp (hl)            ; Compare with low byte of current address 
8dfd			    jr nz, malloc_search_loop  ; If not equal, continue searching 
8dfd			    ld a, d            ; Load high byte of heap end address 
8dfd			;    cp 0               ; Check if it's zero (end of memory) 
8dfd				or a 
8dfd			    jr nz, malloc_search_loop  ; If not zero, continue searching 
8dfd			 
8dfd			    ; If we reached here, allocation failed 
8dfd			    xor a              ; Set result to NULL 
8dfd			if DEBUG_FORTH_MALLOC_HIGH 
8dfd						DMARK "ma6" 
8dfd			call malloc_guard_exit 
8dfd			call malloc_guard_zerolen 
8dfd			endif 
8dfd			    ret 
8dfd			malloc_exit: 
8dfd			if DEBUG_FORTH_MALLOC_HIGH 
8dfd						DMARK "ma7" 
8dfd			call malloc_guard_exit 
8dfd			call malloc_guard_zerolen 
8dfd			endif 
8dfd			    ret 
8dfd			 
8dfd			; Internal Free Function: 
8dfd			; Input: 
8dfd			;   HL: Pointer to memory block to free 
8dfd			; Output: 
8dfd			;   None 
8dfd			 
8dfd			free_internal: 
8dfd			    ld de, (heap_start) ; Load start of heap into DE 
8dfd			    ld bc, 0            ; Initialize counter 
8dfd			 
8dfd			free_search_loop: 
8dfd			    ; Check if current block contains the pointer 
8dfd			    ld a, l             ; Load low byte of pointer 
8dfd			    cp (hl+1)           ; Compare with high byte of current block's address 
8dfd			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8dfd			    ld a, h             ; Load high byte of pointer 
8dfd			    cp (hl+2)           ; Compare with low byte of current block's address 
8dfd			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8dfd			 
8dfd			    ; Mark block as free 
8dfd			    ld (hl), 0          ; Set status byte to indicate free block 
8dfd			    ret                 ; Return 
8dfd			 
8dfd			free_skip_block_check: 
8dfd			    ; Move to the next block 
8dfd			    ld bc, 3            ; Size of management overhead 
8dfd			    add hl, bc          ; Move to the next block 
8dfd			    inc de              ; Increment counter 
8dfd			 
8dfd			    ; Check if we have reached the end of heap 
8dfd			    ld a, e             ; Load low byte of heap end address 
8dfd			    cp (hl)             ; Compare with low byte of current address 
8dfd			    jr nz, free_search_loop  ; If not equal, continue searching 
8dfd			    ld a, d             ; Load high byte of heap end address 
8dfd			;    cp 0                ; Check if it's zero (end of memory) 
8dfd				or a 
8dfd			    jr nz, free_search_loop  ; If not zero, continue searching 
8dfd			 
8dfd			    ; If we reached here, pointer is not found in heap 
8dfd			    ret 
8dfd			 
8dfd			free_exit: 
8dfd			    ret                 ; Return 
8dfd			 
8dfd			; Define heap start and end addresses 
8dfd			;heap_start:    .dw 0xC000   ; Start of heap 
8dfd			;heap_end:      .dw 0xE000   ; End of heap 
8dfd			 
8dfd			endif 
8dfd			 
