0cec			;    ld de,#0040 
0cec			;    ld a,l 
0cec			;    ld l,h 
0cec			;    ld h,d 
0cec			;    or a 
0cec			;    ld b,8 
0cec			;Sqr16_Loop: 
0cec			;    sbc hl,de 
0cec			;    jr nc,Sqr16_Skip 
0cec			;    add hl,de 
0cec			;Sqr16_Skip: 
0cec			;    ccf 
0cec			;    rl d 
0cec			;    add a,a 
0cec			;    adc hl,hl 
0cec			;    add a,a 
0cec			;    adc hl,hl 
