8a21			 
8a21			; compare hl and de 
8a21			; returns:  
8a21			; if hl = de, z=1, s=0, c0=0 
8a21			; if hl > de, z=0, s=0, c=0 
8a21			; if hl < de, z=0, s=1, c=1 
8a21			cmp16:	 
8a21 b7				or a 
8a22 ed 52			sbc hl,de 
8a24 e0				ret po 
8a25 7c				ld a,h 
8a26 1f				rra 
8a27 ee 40			xor 01000000B 
8a29 37				scf 
8a2a 8f				adc a,a 
8a2b c9				ret 
