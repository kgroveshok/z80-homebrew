8dab			if MALLOC_2 
8dab			; Z80 Malloc and Free Functions 
8dab			 
8dab			; Malloc Function: 
8dab			; Input: 
8dab			;   HL: Size of block to allocate 
8dab			; Output: 
8dab			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8dab			 
8dab			malloc: 
8dab				 
8dab			if DEBUG_FORTH_MALLOC_HIGH 
8dab			call malloc_guard_entry 
8dab			endif 
8dab			 
8dab			 
8dab			 
8dab			 
8dab					if DEBUG_FORTH_MALLOC 
8dab						DMARK "mal" 
8dab						CALLMONITOR 
8dab					endif 
8dab			    push af            ; Save AF register 
8dab			    ld a, l            ; Load low byte of size into A 
8dab			    or h               ; Check if size is zero 
8dab			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
8dab			 
8dab			    ; Allocate memory 
8dab			    ld hl, (heap_start) ; Load start of heap into HL 
8dab					if DEBUG_FORTH_MALLOC 
8dab						DMARK "ma1" 
8dab						CALLMONITOR 
8dab					endif 
8dab			    call malloc_internal ; Call internal malloc function 
8dab			    pop af             ; Restore AF register 
8dab			if DEBUG_FORTH_MALLOC_HIGH 
8dab			call malloc_guard_exit 
8dab			call malloc_guard_zerolen 
8dab			endif 
8dab			    ret                ; Return 
8dab			 
8dab			; Free Function: 
8dab			; Input: 
8dab			;   HL: Pointer to memory block to free 
8dab			; Output: 
8dab			;   None 
8dab			 
8dab			free: 
8dab			    push af            ; Save AF register 
8dab			    ld a, l            ; Load low byte of pointer into A 
8dab			    or h               ; Check if pointer is NULL 
8dab			    jp z, free_exit    ; If pointer is NULL, exit 
8dab			 
8dab			    ; Free memory 
8dab			    ld hl, (heap_start) ; Load start of heap into HL 
8dab			    call free_internal  ; Call internal free function 
8dab			    pop af             ; Restore AF register 
8dab			    ret                ; Return 
8dab			 
8dab			; Internal Malloc Function: 
8dab			; Input: 
8dab			;   HL: Size of block to allocate 
8dab			; Output: 
8dab			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8dab			 
8dab			malloc_internal: 
8dab			    ld bc, 2           ; Number of bytes to allocate for management overhead 
8dab			    add hl, bc         ; Add management overhead to requested size 
8dab			    ex de, hl          ; Save total size in DE, and keep it in HL 
8dab					if DEBUG_FORTH_MALLOC 
8dab						DMARK "ma2" 
8dab						CALLMONITOR 
8dab					endif 
8dab			 
8dab			    ; Search for free memory block 
8dab			    ld de, (heap_end)  ; Load end of heap into DE 
8dab			    ld bc, 0           ; Initialize counter 
8dab			 
8dab					if DEBUG_FORTH_MALLOC 
8dab						DMARK "ma2" 
8dab						CALLMONITOR 
8dab					endif 
8dab			malloc_search_loop: 
8dab			    ; Check if current block is free 
8dab			    ld a, (hl)         ; Load current block's status (free or used) 
8dab			;    cp 0               ; Compare with zero (free) 
8dab				or a 
8dab			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
8dab			 
8dab			    ; Check if current block is large enough 
8dab			    ld a, (hl+1)       ; Load high byte of block size 
8dab			    cp l               ; Compare with low byte of requested size 
8dab			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
8dab			 
8dab			    ld a, (hl+2)       ; Load low byte of block size 
8dab			    cp h               ; Compare with high byte of requested size 
8dab			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
8dab			 
8dab			    ; Mark block as used 
8dab			    ld (hl), 0xFF      ; Set status byte to indicate used block 
8dab			 
8dab			    ; Calculate remaining space in block 
8dab			    ld bc, 0           ; Clear BC 
8dab			    add hl, bc         ; Increment HL to point to start of data block 
8dab			    add hl, de         ; HL = HL + DE (total size) 
8dab			    ld bc, 1           ; Number of bytes to allocate for management overhead 
8dab			    add hl, bc         ; Add management overhead to start of data block 
8dab			 
8dab			    ; Save pointer to allocated block in HL 
8dab			if DEBUG_FORTH_MALLOC_HIGH 
8dab						DMARK "ma5" 
8dab			call malloc_guard_exit 
8dab			call malloc_guard_zerolen 
8dab			endif 
8dab			    ret 
8dab			 
8dab			malloc_skip_block_check: 
8dab			    ; Move to the next block 
8dab			    ld bc, 3           ; Size of management overhead 
8dab			    add hl, bc         ; Move to the next block 
8dab			    inc de             ; Increment counter 
8dab			 
8dab			    ; Check if we have reached the end of heap 
8dab			    ld a, e            ; Load low byte of heap end address 
8dab			    cp (hl)            ; Compare with low byte of current address 
8dab			    jr nz, malloc_search_loop  ; If not equal, continue searching 
8dab			    ld a, d            ; Load high byte of heap end address 
8dab			;    cp 0               ; Check if it's zero (end of memory) 
8dab				or a 
8dab			    jr nz, malloc_search_loop  ; If not zero, continue searching 
8dab			 
8dab			    ; If we reached here, allocation failed 
8dab			    xor a              ; Set result to NULL 
8dab			if DEBUG_FORTH_MALLOC_HIGH 
8dab						DMARK "ma6" 
8dab			call malloc_guard_exit 
8dab			call malloc_guard_zerolen 
8dab			endif 
8dab			    ret 
8dab			malloc_exit: 
8dab			if DEBUG_FORTH_MALLOC_HIGH 
8dab						DMARK "ma7" 
8dab			call malloc_guard_exit 
8dab			call malloc_guard_zerolen 
8dab			endif 
8dab			    ret 
8dab			 
8dab			; Internal Free Function: 
8dab			; Input: 
8dab			;   HL: Pointer to memory block to free 
8dab			; Output: 
8dab			;   None 
8dab			 
8dab			free_internal: 
8dab			    ld de, (heap_start) ; Load start of heap into DE 
8dab			    ld bc, 0            ; Initialize counter 
8dab			 
8dab			free_search_loop: 
8dab			    ; Check if current block contains the pointer 
8dab			    ld a, l             ; Load low byte of pointer 
8dab			    cp (hl+1)           ; Compare with high byte of current block's address 
8dab			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8dab			    ld a, h             ; Load high byte of pointer 
8dab			    cp (hl+2)           ; Compare with low byte of current block's address 
8dab			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8dab			 
8dab			    ; Mark block as free 
8dab			    ld (hl), 0          ; Set status byte to indicate free block 
8dab			    ret                 ; Return 
8dab			 
8dab			free_skip_block_check: 
8dab			    ; Move to the next block 
8dab			    ld bc, 3            ; Size of management overhead 
8dab			    add hl, bc          ; Move to the next block 
8dab			    inc de              ; Increment counter 
8dab			 
8dab			    ; Check if we have reached the end of heap 
8dab			    ld a, e             ; Load low byte of heap end address 
8dab			    cp (hl)             ; Compare with low byte of current address 
8dab			    jr nz, free_search_loop  ; If not equal, continue searching 
8dab			    ld a, d             ; Load high byte of heap end address 
8dab			;    cp 0                ; Check if it's zero (end of memory) 
8dab				or a 
8dab			    jr nz, free_search_loop  ; If not zero, continue searching 
8dab			 
8dab			    ; If we reached here, pointer is not found in heap 
8dab			    ret 
8dab			 
8dab			free_exit: 
8dab			    ret                 ; Return 
8dab			 
8dab			; Define heap start and end addresses 
8dab			;heap_start:    .dw 0xC000   ; Start of heap 
8dab			;heap_end:      .dw 0xE000   ; End of heap 
8dab			 
8dab			endif 
8dab			 
8dab			 
8dab			if MALLOC_1 
