89b8 17			    rla 
89b9 ed 6a		    adc hl,hl 
89bb ed 52		    sbc hl,de 
89bd 30 01		    jr nc,Div16_NoAdd1 
89bf 19			    add hl,de 
89c0			Div16_NoAdd1: 
89c0 10 f6		    djnz Div16_Loop1 
89c2 17			    rla 
89c3 2f			    cpl 
89c4 47			    ld b,a 
89c5 79			    ld a,c 
89c6 48			    ld c,b 
89c7 06 08		    ld b,8 
89c9			Div16_Loop2: 
89c9 17			    rla 
89ca ed 6a		    adc hl,hl 
89cc ed 52		    sbc hl,de 
89ce 30 01		    jr nc,Div16_NoAdd2 
89d0 19			    add hl,de 
