6955			  
6955			; Position cursor to specified location  
6955			;   On entry: A = Cursor position  
6955			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6955 f5			fLCD_Pos:   PUSH AF  
6956					; at this point set the E1 or E2 flag depending on position  
6956			  
6956 c5					push bc  
6957			;		push af  
6957 06 00				ld b, 0  
6959 4f					ld c, a  
695a 3e 4f				ld a, kLCD_Line3-1  
695c b7			 		or a      ;clear carry flag  
695d 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
695e 38 04				jr c, .pe1  
6960			  
6960					; E selection  
6960 cb 80				res 0, b         ; bit 0 unset e  
6962			;		pop af    ; before line 3 so recover orig pos  
6962			;		ld c, a    ; save for poking back  
6962 18 06				jr .peset	          
6964			.pe1:          	; E2 selection  
6964 cb c0				set 0, b         ; bit 0 set e1  
6966 79					ld a, c  
6967 de 4f				sbc a, kLCD_Line3-1  
6969 4f					ld c, a	         ; save caculated offset  
696a			;		pop af     ; bin this original value now we have calculated form  
696a			  
696a			.peset:		; set bit  
696a 78					ld a, b  
696b 32 fb fa				ld (display_lcde1e2), a 	  
696e 79					ld a, c  
696f c1					pop bc  
6970			  
6970 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6972 cd d1 68		            CALL fLCD_Inst      ;Write instruction to LCD  
6975 f1			            POP  AF  
6976 c9			            RET  
6977			  
6977			  
6977			; Output text string to LCD  
6977			;   On entry: DE = Pointer to null terminated text string  
6977			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6977 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6978 b7			            OR   A              ;Null terminator?  
6979 c8			            RET  Z              ;Yes, so finished  
697a cd 0d 69		            CALL fLCD_Data      ;Write character to display  
697d 13			            INC  DE             ;Point to next character  
697e 18 f7		            JR   fLCD_Str       ;Repeat  
6980 c9					ret  
6981			  
6981			; Define custom character  
6981			;   On entry: A = Character number (0 to 7)  
6981			;             DE = Pointer to character bitmap data  
6981			;   On exit:  A = Next character number  
6981			;             DE = Next location following bitmap  
6981			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6981			; Character is   
6981 c5			fLCD_Def:   PUSH BC  
6982 f5			            PUSH AF  
6983 07			            RLCA                ;Calculate location  
6984 07			            RLCA                ;  for bitmap data  
6985 07			            RLCA                ;  = 8 x CharacterNumber  
6986 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6988 cd d1 68		            CALL fLCD_Inst      ;Write instruction to LCD  
698b 06 00		            LD   B, 0  
698d 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
698e cd 0d 69		            CALL fLCD_Data      ;Write byte to display  
6991 13			            INC  DE             ;Point to next byte  
6992 04			            INC  B              ;Count bytes  
6993 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6995 28 f6		            JR   Z, Loop       ;No, so repeat  
6997 f1			            POP  AF  
6998 3c			            INC  A              ;Increment character number  
6999 c1			            POP  BC  
699a c9			            RET  
