0fe4 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
0fe5 23			      inc   HL 
0fe6 56			      ld    D, (HL) 
0fe7 dd 73 02		      ld    (IX+2), E 
0fea dd 72 03		      ld    (IX+3), D 
