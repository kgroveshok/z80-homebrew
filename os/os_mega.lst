4b72					ld a, (.dmark+2)  
4b72					ld (debug_mark+2),a  
4b72				endif  
4b72 18 04			jr .pastdmark  
4b74 ..			.dmark: db "REA"  
4b77				if DEMARK_VERSION = 1  
4b77 00					db 0  
4b78				endif  
4b78				if DEMARK_VERSION = 1  
4b78 e1			.pastdmark: pop hl  
4b79				endif  
