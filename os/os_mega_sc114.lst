8c73			addatohl: 
8c73 85			    add   a, l    ; A = A+L 
8c74 6f			    ld    l, a    ; L = A+L 
8c75 8c			    adc   a, h    ; A = A+L+H+carry 
8c76 95			    sub   l       ; A = H+carry 
8c77 67			    ld    h, a    ; H = H+carry 
8c78 c9			ret 
