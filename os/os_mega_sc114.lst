aa49 32 60 ee			ld (debug_mark+2),a  
aa4c 18 03			jr .pastdmark  
aa4e ..			.dmark: db "FRG"  
aa51 f1			.pastdmark: pop af  
aa52			endm  
# End of macro DMARK
