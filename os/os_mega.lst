5121					ld (debug_mark+1),a  
5121					ld a, (.dmark+2)  
5121					ld (debug_mark+2),a  
5121				endif  
5121 18 04			jr .pastdmark  
5123 ..			.dmark: db "VAR"  
5126				if DEMARK_VERSION = 1  
5126 00					db 0  
5127				endif  
5127				if DEMARK_VERSION = 1  
5127 e1			.pastdmark: pop hl  
5128				endif  
5128				if DEMARK_VERSION = 0  
5128			.pastdmark: pop af  
5128				endif  
5128			endm  
# End of macro DMARK
