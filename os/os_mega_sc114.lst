bfed			; var handler 
bfed			 
bfed			 
bfed			.VARS: 
bfed				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
bfed 77				db WORD_SYS_CORE+99             
bfee 55 c0			dw .V0            
bff0 04				db 3 + 1 
bff1 .. 00			db "VAR",0              
bff5				endm 
# End of macro CWHEAD
bff5			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bff5			; | 
bff5			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bff5			; | |  
bff5			; | | e.g. 
bff5			; | |         #30 a var ! 
bff5			; | |         a var @ . 
bff5			; | |   
bff5			; | |     Displays the number 30 
bff5			; | | 
bff5			; | | Each variable pointer is a word so can use for any words that use that:  
bff5			; | |  
bff5			; | | e.g. 
bff5			; | |  
bff5			; | |         #30 a var 2! 
bff5			; | |         a var 2@ . 
bff5			; | |   
bff5			; | |     Displays the number 30 
bff5			; | |  
bff5			; | | > [!NOTE]  
bff5			; ! | > If a full string is passed then only the first char is looked at 
bff5			; | | > Any other char could exceed bounds checks!  
bff5			; | | > 
bff5			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bff5			 
bff5					if DEBUG_FORTH_WORDS_KEY 
bff5						DMARK "VAR" 
bff5				if DEMARK_VERSION = 1  
bff5 e5					push hl  
bff6 21 fe bf				ld hl, .dmark  
bff9 22 60 ee				ld (debug_mark), hl  
bffc				endif  
bffc				if DEMARK_VERSION = 0  
bffc					push af  
bffc					ld a, (.dmark)  
bffc					ld (debug_mark),a  
bffc					ld a, (.dmark+1)  
bffc					ld (debug_mark+1),a  
bffc					ld a, (.dmark+2)  
bffc					ld (debug_mark+2),a  
bffc				endif  
bffc 18 04			jr .pastdmark  
bffe ..			.dmark: db "VAR"  
c001				if DEMARK_VERSION = 1  
c001 00					db 0  
c002				endif  
c002				if DEMARK_VERSION = 1  
c002 e1			.pastdmark: pop hl  
c003				endif  
c003				if DEMARK_VERSION = 0  
c003			.pastdmark: pop af  
c003				endif  
c003			endm  
# End of macro DMARK
c003						CALLMONITOR 
c003				if BASE_CPM=1  
c003					call debug_vector  
c003				endif  
c003				if BASE_KEV=1  
c003					rst 8  
c003				endif  
c003				endm  
# End of macro CALLMONITOR
c003					endif 
c003			 
