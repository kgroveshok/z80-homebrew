68a2			; **********************************************************************  
68a2			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
68a2			; **********************************************************************  
68a2			;  
68a2			; **  Written as a Small Computer Monitor App  
68a2			; **  www.scc.me.uk  
68a2			;  
68a2			; History  
68a2			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
68a2			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
68a2			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
68a2			;  
68a2			; **********************************************************************  
68a2			;  
68a2			; This program is an example of one of the methods of interfacing an   
68a2			; alphanumeric LCD module.   
68a2			;  
68a2			; In this example the display is connected to either a Z80 PIO or a   
68a2			; simple 8-bit output port.   
68a2			;  
68a2			; This interfacing method uses 4-bit data mode and uses time delays  
68a2			; rather than polling the display's ready status. As a result the   
68a2			; interface only requires 6 simple output lines:  
68a2			;   Output bit 0 = not used  
68a2			;   Output bit 1 = not used  
68a2			;   Output bit 2 = RS         High = data, Low = instruction  
68a2			;   Output bit 3 = E          Active high  
68a2			;   Output bit 4 = DB4  
68a2			;   Output bit 5 = DB5  
68a2			;   Output bit 6 = DB6  
68a2			;   Output bit 7 = DB7  
68a2			; Display's R/W is connected to 0v so it is always in write mode  
68a2			;  
68a2			; This set up should work with any system supporting the RC2014 bus  
68a2			  
68a2			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
68a2			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
68a2			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
68a2			;  
68a2			; **********************************************************************  
68a2			  
68a2			; Additonal for 4x40. E1 and E2 instead of just E   
68a2			; TODO swipe vidout signal on port a to activate E2  
68a2			  
68a2			; **********************************************************************  
68a2			; **  Constants  
68a2			; **********************************************************************  
68a2			; LCD constants required by LCD support module  
68a2			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
68a2			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
68a2			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
68a2			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
68a2			; TODO Decide which E is being set  
68a2			kLCDWidth:  EQU display_cols             ;Width in characters  
68a2			  
68a2			; **********************************************************************  
68a2			; **  Code library usage  
68a2			; **********************************************************************  
68a2			  
68a2			; send character to current cursor position  
68a2			; wraps and/or scrolls screen automatically  
68a2			  
68a2			  
68a2			  
68a2			lcd_init:  
68a2			  
68a2			; SCMonAPI functions used  
68a2			  
68a2			; Alphanumeric LCD functions used  
68a2			; no need to specify specific functions for this module  
68a2			  
68a2 3e cf		            LD   A, 11001111b  
68a4 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
68a6 3e 00		            LD   A, 00000000b  
68a8 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
68aa			  
