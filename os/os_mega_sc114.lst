d5f9				call str_at_display 
d5f9			 
d5f9				call update_display 
d5f9			 
d5f9				call cin_wait 
d5f9				cp 'n' 
d5f9				ret z 
d5f9				cp 'N' 
d5f9				ret z 
d5f9			 
d5f9				call delay1s 
d5f9			 
d5f9				ld a, (store_page+2) 
