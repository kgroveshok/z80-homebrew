89c7			; 
89c7			; Divide 8-bit values 
89c7			; In: Divide E by divider C 
89c7			; Out: A = result, B = rest 
89c7			; 
89c7			Div8: 
89c7 af			    xor a 
89c8 06 08		    ld b,8 
89ca			Div8_Loop: 
89ca cb 13		    rl e 
89cc 17			    rla 
89cd 91			    sub c 
89ce 30 01		    jr nc,Div8_NoAdd 
89d0 81			    add a,c 
89d1			Div8_NoAdd: 
89d1 10 f7		    djnz Div8_Loop 
89d3 47			    ld b,a 
89d4 7b			    ld a,e 
89d5 17			    rla 
89d6 2f			    cpl 
89d7 c9			    ret 
