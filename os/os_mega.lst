4baa			.READ: 
4baa				CWHEAD .EOF 88 "READ" 4 WORD_FLAG_CODE 
4baa 6c				db WORD_SYS_CORE+88             
4bab 71 4c			dw .EOF            
4bad 05				db 4 + 1 
4bae .. 00			db "READ",0              
4bb3				endm 
# End of macro CWHEAD
4bb3			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4bb3			; | | e.g. 
4bb3			; | | $01 OPEN $01 DO READ . LOOP 
4bb3			; | | 
4bb3			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4bb3			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4bb3			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4bb3			; | | two bytes contain the file id and extent. 
4bb3			; | |  
4bb3			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4bb3			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4bb3			; | | > [!NOTE] 
4bb3			; | | > Compatible with PicoSPINet  
4bb3			 
4bb3					if DEBUG_FORTH_WORDS_KEY 
4bb3						DMARK "REA" 
4bb3				if DEMARK_VERSION = 1  
4bb3 e5					push hl  
4bb4 21 bc 4b				ld hl, .dmark  
4bb7 22 9b fd				ld (debug_mark), hl  
4bba				endif  
4bba				if DEMARK_VERSION = 0  
4bba					push af  
4bba					ld a, (.dmark)  
4bba					ld (debug_mark),a  
4bba					ld a, (.dmark+1)  
4bba					ld (debug_mark+1),a  
4bba					ld a, (.dmark+2)  
4bba					ld (debug_mark+2),a  
4bba				endif  
4bba 18 04			jr .pastdmark  
4bbc ..			.dmark: db "REA"  
4bbf				if DEMARK_VERSION = 1  
4bbf 00					db 0  
4bc0				endif  
4bc0				if DEMARK_VERSION = 1  
4bc0 e1			.pastdmark: pop hl  
4bc1				endif  
4bc1				if DEMARK_VERSION = 0  
4bc1			.pastdmark: pop af  
4bc1				endif  
4bc1			endm  
# End of macro DMARK
4bc1						CALLMONITOR 
4bc1				if BASE_CPM=1  
4bc1					call debug_vector  
4bc1				endif  
4bc1				if BASE_KEV=1  
4bc1 cf					rst 8  
4bc2				endif  
4bc2				endm  
# End of macro CALLMONITOR
4bc2					endif 
