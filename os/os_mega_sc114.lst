921f				inc hl 
921f				ld d,(hl) 
921f				inc hl 
921f			 
921f				ex de, hl 
921f				call ishlzero 
921f				ret z     ; return on null pointer 
921f				call free 
921f				ex de, hl 
921f				jr .cfdir 
921f			 
921f			 
921f				ret 
921f			 
921f			 
921f			config_dir: 
921f			 
921f				; for the config menus that need to build a directory of storage call this routine 
921f				; it will construct a menu in scratch to pass to menu 
921f			 
921f				; open storage device 
921f			 
921f				; execute DIR to build a list of files and their ids into scratch in menu format 
921f				; once the menu has finished then will need to call config_fdir to release the strings 
921f				 
921f				; c = number items 
921f			 
921f				 
921f				call storage_get_block_0 
921f			 
921f				ld hl, store_page     ; get current id count 
921f				ld b, (hl) 
921f				ld c, 0    ; count of files   
921f			 
921f			 
921f				ld hl, scratch 
921f				ld (store_tmp2), hl    ; location to poke strings 
921f			 
921f				; check for empty drive 
921f			 
921f				ld a, 0 
921f				cp b 
921f				jp z, .dirdone 
921f			 
921f				 
921f					if DEBUG_FORTH_WORDS 
921f						DMARK "Cdc" 
921f						CALLMONITOR 
921f					endif 
921f			 
921f			 
921f			.diritem:	 
921f				push bc 
921f				; for each of the current ids do a search for them and if found push to stack 
921f			 
921f					ld hl, STORE_BLOCK_PHY 
921f					ld d, 0		 ; look for extent 0 of block id as this contains file name 
921f					ld e,b 
921f			 
921f					call storage_findnextid 
921f			 
921f			 
921f					; if found hl will be non zero 
921f			 
921f					call ishlzero 
921f					jr z, .dirnotfound 
921f			 
921f					; increase count 
921f			 
921f					pop bc	 
921f					inc c 
921f					push bc 
921f					 
921f			 
921f					; get file header and push the file name 
921f			 
921f					ld de, store_page 
921f					call storage_read_block 
921f			 
921f					; push file id to stack 
921f				 
921f					ld a, (store_page) 
921f					ld h, 0 
921f					ld l, a 
921f			 
921f					;call forth_push_numhl 
921f					; TODO store id 
921f			 
921f					push hl 
921f			 
921f					; push extent count to stack  
921f				 
921f					ld hl, store_page+3 
921f			 
921f					; get file name length 
921f			 
921f					call strlenz   
921f			 
921f					inc hl   ; cover zero term 
921f					inc hl  ; stick the id at the end of the area 
921f			 
921f					push hl 
921f					pop bc    ; move length to bc 
921f			 
921f					call malloc 
921f			 
921f					; TODO save malloc area to scratch 
921f			 
921f					ex de, hl 
921f					ld hl, (store_tmp2) 
921f					ld (hl), e 
921f					inc hl 
921f					ld (hl), d 
921f					inc hl 
921f					ld (store_tmp2), hl 
921f			 
921f					 
921f			 
921f					;pop hl   ; get source 
921f			;		ex de, hl    ; swap aronund	 
921f			 
921f					ld hl, store_page+3 
921f					if DEBUG_FORTH_WORDS 
921f						DMARK "CFd" 
921f						CALLMONITOR 
921f					endif 
921f					ldir 
921f			 
921f					; de is past string, move back one and store id 
921f					 
921f					dec de 
921f			 
921f					; store file id 
921f			 
921f					pop hl 
921f					ex de,hl 
921f					ld (hl), e 
921f			 
921f					if DEBUG_FORTH_WORDS 
921f						DMARK "Cdi" 
921f						CALLMONITOR 
921f					endif 
921f					 
921f			.dirnotfound: 
921f					pop bc     
921f					djnz .diritem 
921f				 
921f			.dirdone:	 
921f			 
921f			;		ld a, 0 
921f					ld hl, (store_tmp2) 
921f					ld (hl), 0 
921f					inc hl 
921f					ld (hl), 0 
921f					inc hl 
921f					; push a count of the dir items found 
921f			 
921f			;		ld h, 0 
921f			;		ld l, c 
921f			 
921f				ret 
921f			 
921f			endif 
