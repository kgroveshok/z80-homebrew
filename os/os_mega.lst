6972			; **********************************************************************  
6972			; **  LCD support functions  
6972			; **********************************************************************  
6972			  
6972			; Initialise alphanumeric LCD module  
6972			; LCD control register codes:  
6972			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6972			;   N    0 = 1-line mode       1 = 2-line mode  
6972			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6972			;   D    0 = Display off       1 = Display on  
6972			;   C    0 = Cursor off        1 = Cursor on  
6972			;   B    0 = Blinking off      1 = Blinking on  
6972			;   ID   0 = Decrement mode    1 = Increment mode  
6972			;   SH   0 = Entire shift off  1 = Entire shift on  
6972 3e 28		fLCD_Init:  LD   A, 40  
6974 cd b5 6a		            CALL LCDDelay       ;Delay 40ms after power up  
6977			; For reliable reset set 8-bit mode - 3 times  
6977 cd 85 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
697a cd 85 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
697d cd 85 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
6980			; Set 4-bit mode  
6980 cd 81 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
6983 cd b3 6a		            CALL LCDDelay1      ;Delay 37 us or more  
6986			; Function set  
6986 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6988 cd ab 69		            CALL fLCD_Inst      ;2 line, display on  
698b			; Display On/Off control  
698b 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
698d cd ab 69		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6990			; Display Clear  
6990 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6992 cd ab 69		            CALL fLCD_Inst      ;Clear display  
6995			; Entry mode  
6995 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6997 cd ab 69		            CALL fLCD_Inst      ;Increment mode, shift off  
699a			; Display module now initialised  
699a c9			            RET  
699b			; ok to here  
699b			  
699b			; decide on setting bit for LED on or off  
699b			; Set correct bit in A  
699b e5			IsLED: push hl  
699c 21 ad fd			ld hl, hardware_word+1  
699f cb 56			bit 2, (hl)    ; led bit  
69a1 20 04			jr nz, .isled1  
69a3 cb 8f			res kLCDBitLED, a  
69a5 18 02			jr .isleddone  
69a7 cb cf		.isled1: set kLCDBitLED, a  
69a9			.isleddone:  	  
69a9 e1				pop hl  
69aa			  
69aa c9				ret  
69ab			  
69ab			  
69ab			; Write instruction to LCD  
69ab			;   On entry: A = Instruction byte to be written  
69ab			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
69ab f5			fLCD_Inst:  PUSH AF  
69ac f5			            PUSH AF  
69ad cd bf 69		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
69b0 f1			            POP  AF  
69b1 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
69b2 17			            RLA  
69b3 17			            RLA  
69b4 17			            RLA  
69b5 cd bf 69		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
69b8 3e 02		            LD   A, 2  
69ba cd b5 6a		            CALL LCDDelay       ;Delay 2 ms to complete   
69bd f1			            POP  AF  
69be c9			            RET  
69bf			Wr4bits:   
69bf f5					push af  
69c0 3a fb fa				ld a, (display_lcde1e2)  
69c3 fe 00				cp 0     ; e  
69c5 20 13				jr nz, .wea2	  
69c7 f1					pop af  
69c8 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
69ca cd 9b 69				call IsLED  
69cd d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69cf cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
69d1 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
69d3 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
69d5 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
69d7 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69d9 c9			            RET  
69da f1			.wea2:		pop af  
69db e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
69dd cd 9b 69				call IsLED  
69e0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69e2 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
69e4 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
69e6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
69e8 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
69ea d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69ec c9			            RET  
69ed			  
69ed			  
69ed			; Write data to LCD  
69ed			;   On entry: A = Data byte to be written  
69ed			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
69ed f5			fLCD_Data:  PUSH AF  
69ee f5			            PUSH AF  
69ef cd 01 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
69f2 f1			            POP  AF  
69f3 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
69f4 17			            RLA  
69f5 17			            RLA  
69f6 17			            RLA  
69f7 cd 01 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
69fa 3e 96		            LD   A, 150  
69fc 3d			Wait:      DEC  A              ;Wait a while to allow data   
69fd 20 fd		            JR   NZ, Wait      ;  write to complete  
69ff f1			            POP  AF  
6a00 c9			            RET  
6a01			Wr4bitsa:     
6a01 f5					push af  
6a02 3a fb fa				ld a, (display_lcde1e2)  
6a05 fe 00				cp 0     ; e1  
6a07 20 19				jr nz, .we2	  
6a09 f1					pop af  
6a0a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a0c cd 9b 69				call IsLED  
6a0f cb d7		            SET  kLCDBitRS, A  
6a11 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a13 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6a15 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6a17 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a19 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6a1b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a1d cb 97		            RES  kLCDBitRS, A  
6a1f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a21 c9			            RET  
6a22 f1			.we2:		pop af  
6a23 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a25 cd 9b 69				call IsLED  
6a28 cb d7		            SET  kLCDBitRS, A  
6a2a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a2c cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6a2e cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6a30 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a32 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6a34 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a36 cb 97		            RES  kLCDBitRS, A  
6a38 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a3a c9			            RET  
6a3b			  
6a3b			  
6a3b			; Position cursor to specified location  
6a3b			;   On entry: A = Cursor position  
6a3b			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a3b f5			fLCD_Pos:   PUSH AF  
6a3c					; at this point set the E1 or E2 flag depending on position  
6a3c			  
6a3c c5					push bc  
6a3d			;		push af  
6a3d 06 00				ld b, 0  
6a3f 4f					ld c, a  
6a40 3e 4f				ld a, kLCD_Line3-1  
6a42 b7			 		or a      ;clear carry flag  
6a43 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6a44 38 04				jr c, .pe1  
6a46			  
6a46					; E selection  
6a46 cb 80				res 0, b         ; bit 0 unset e  
6a48			;		pop af    ; before line 3 so recover orig pos  
6a48			;		ld c, a    ; save for poking back  
6a48 18 06				jr .peset	          
6a4a			.pe1:          	; E2 selection  
6a4a cb c0				set 0, b         ; bit 0 set e1  
6a4c 79					ld a, c  
6a4d de 4f				sbc a, kLCD_Line3-1  
6a4f 4f					ld c, a	         ; save caculated offset  
6a50			;		pop af     ; bin this original value now we have calculated form  
6a50			  
6a50			.peset:		; set bit  
6a50 78					ld a, b  
6a51 32 fb fa				ld (display_lcde1e2), a 	  
6a54 79					ld a, c  
6a55 c1					pop bc  
6a56			  
6a56 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6a58 cd ab 69		            CALL fLCD_Inst      ;Write instruction to LCD  
6a5b f1			            POP  AF  
6a5c c9			            RET  
6a5d			  
6a5d			  
6a5d			; Output text string to LCD  
6a5d			;   On entry: DE = Pointer to null terminated text string  
6a5d			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6a5d 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6a5e b7			            OR   A              ;Null terminator?  
6a5f c8			            RET  Z              ;Yes, so finished  
6a60 cd ed 69		            CALL fLCD_Data      ;Write character to display  
6a63 13			            INC  DE             ;Point to next character  
6a64 18 f7		            JR   fLCD_Str       ;Repeat  
6a66 c9					ret  
6a67			  
6a67			; Define custom character  
6a67			;   On entry: A = Character number (0 to 7)  
6a67			;             DE = Pointer to character bitmap data  
6a67			;   On exit:  A = Next character number  
6a67			;             DE = Next location following bitmap  
6a67			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6a67			; Character is   
6a67 c5			fLCD_Def:   PUSH BC  
6a68 f5			            PUSH AF  
6a69 07			            RLCA                ;Calculate location  
6a6a 07			            RLCA                ;  for bitmap data  
6a6b 07			            RLCA                ;  = 8 x CharacterNumber  
6a6c f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6a6e cd ab 69		            CALL fLCD_Inst      ;Write instruction to LCD  
6a71 06 00		            LD   B, 0  
6a73 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6a74 cd ed 69		            CALL fLCD_Data      ;Write byte to display  
6a77 13			            INC  DE             ;Point to next byte  
6a78 04			            INC  B              ;Count bytes  
6a79 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6a7b 28 f6		            JR   Z, Loop       ;No, so repeat  
6a7d f1			            POP  AF  
6a7e 3c			            INC  A              ;Increment character number  
6a7f c1			            POP  BC  
6a80 c9			            RET  
