1d2a			include "firmware_595shiftreg.asm"  
1d2a			; common code for handling a 595 shift reg out on whatever output port 
1d2a			 
1d2a			; port in c 
1d2a			; byte in a 
1d2a			 
1d2a			 
1d2a			shift_bit_data: equ 0 
1d2a			shift_bit_clk: equ 1 
1d2a			shift_bit_latch: equ 2 
1d2a			 
1d2a			 
1d2a			; shift out a byte to the sound chip 
1d2a			 
1d2a			; A contains byte to send 
1d2a			 
1d2a			shift_byte: 
1d2a			 
1d2a 06 08			ld b, 8   ; 8 bits to shift 
1d2c			 
1d2c 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
1d2e			 
1d2e				; set data bit state 
1d2e			 
1d2e cb 7f			bit 7, a 
1d30				; high bit is set 
1d30 28 02			jr z, .nb2 
1d32 cb c2			set shift_bit_data, d 
1d34			 
1d34				; set latches state  
1d34 cb ca		.nb2:	set shift_bit_clk, d 
1d36 cb 92			res shift_bit_latch, d    ; latch is inverted 
1d38 ed 51			out (c), d 
1d3a				 
1d3a				; clock the bit out 
1d3a cb 8a			res shift_bit_clk, d 
1d3c ed 51			out (c), d 
1d3e			 
1d3e				; shift a left one bit and repeat 
1d3e 17				rla 
1d3f			 
1d3f 10 eb			djnz .nb1 
1d41			 
1d41				; latch 
1d41 cb d2			set shift_bit_latch, d 
1d43 ed 51			out (c), d 
1d45					 
1d45			 
1d45				; set  
1d45 c9				ret 
# End of file firmware_595shiftreg.asm
