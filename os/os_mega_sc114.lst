d319			; stack over and underflow checks 
d319			 
d319			; init the words to detect the under/overflow 
d319			 
d319			chk_stk_init: 
d319				; a vague random number to check so we dont get any "lucky" hits 
d319 3e 2d			ld a, 45 
d31b 6f				ld l, a 
d31c 00				nop 
d31d 3e 17			ld a, 23 
d31f 67				ld h, a 
d320			 
d320 22 7e e2			ld (chk_word), hl     ; the word we need to check against 
d323			 
d323			;	ld (chk_stund), hl	; stack points.... 
d323 22 00 ef			ld (chk_stovr), hl 
d326 22 cd e9			ld (chk_ret_und), hl 
d329 22 8b e9			ld (chk_ret_ovr), hl 
d32c 22 09 e9			ld (chk_loop_ovr), hl 
d32f 22 07 e8			ld (chk_data_ovr), hl 
d332 c9				ret 
d333				 
d333			check_stacks: 
d333				; check all stack words 
d333			 
d333 e5				push hl 
d334 d5				push de 
d335			 
d335			;	ld de,(chk_word) 
d335			;	ld hl, (chk_stund)	; stack points.... 
d335			;	if DEBUG_STK_FAULT 
d335			;		DMARK "FAa" 
d335			;		CALLMONITOR 
d335			;	endif 
d335			;	call cmp16 
d335			;	jp z, .chk_faulta 
d335			; 
d335			;	ld de, sfaultsu 
d335			;	jp .chk_fault 
d335			 
d335 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
d338 ed 5b 7e e2		ld de,(chk_word) 
d33c				if DEBUG_STK_FAULT 
d33c					DMARK "FAb" 
d33c					CALLMONITOR 
d33c				endif 
d33c cd 6e 8a			call cmp16 
d33f 28 06			jr z, .chk_fault1 
d341 11 e6 d3			ld de, sfaultso 
d344 c3 96 d3			jp .chk_fault 
d347			.chk_fault1:  
d347 2a cd e9			ld hl, (chk_ret_und) 
d34a ed 5b 7e e2		ld de,(chk_word) 
d34e				if DEBUG_STK_FAULT 
d34e					DMARK "FAU" 
d34e					CALLMONITOR 
d34e				endif 
d34e cd 6e 8a			call cmp16 
d351 ca 5a d3			jp z, .chk_fault2 
d354 11 f6 d3			ld de, sfaultru 
d357 c3 96 d3			jp .chk_fault 
d35a			.chk_fault2:  
d35a 2a 8b e9			ld hl, (chk_ret_ovr) 
d35d ed 5b 7e e2		ld de,(chk_word) 
d361				if DEBUG_STK_FAULT 
d361					DMARK "FA1" 
d361					CALLMONITOR 
d361				endif 
d361 cd 6e 8a			call cmp16 
d364 ca 6d d3			jp z, .chk_fault3 
d367 11 04 d4			ld de, sfaultro 
d36a c3 96 d3			jp .chk_fault 
