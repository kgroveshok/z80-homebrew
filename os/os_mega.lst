7444				; write out a fixed length string given in b from de  
7444			  
7444 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
7445 cd b1 74		            CALL fLCD_Data      ;Write character to display  
7448 13				inc de  
7449 10 f9			djnz write_len_string  
744b c9				ret  
