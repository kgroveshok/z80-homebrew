8fa3			 
8fa3			 
8fa3					; active low 
8fa3			 
8fa3			;		cp 0 
8fa3					or a 
8fa3					jr z, .bset 
8fa3					cp 1 
8fa3					jr nz, .b2 
8fa3					res 0, c 
8fa3					ld b, '1'    ; human readable bank number 
8fa3			.b2:		cp 2 
8fa3					jr nz, .b3 
8fa3					res 1, c 
8fa3					ld b, '2'    ; human readable bank number 
8fa3			.b3:		cp 3 
8fa3					jr nz, .b4 
8fa3					res 2, c 
8fa3					ld b, '3'    ; human readable bank number 
8fa3			.b4:		cp 4 
