10e9			if MALLOC_2 
10e9			; Z80 Malloc and Free Functions 
10e9			 
10e9			; Malloc Function: 
10e9			; Input: 
10e9			;   HL: Size of block to allocate 
10e9			; Output: 
10e9			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
10e9			 
10e9			malloc: 
10e9				 
10e9			if DEBUG_FORTH_MALLOC_HIGH 
10e9			call malloc_guard_entry 
10e9			endif 
10e9			 
10e9			 
10e9			 
10e9			 
10e9					if DEBUG_FORTH_MALLOC 
10e9						DMARK "mal" 
10e9						CALLMONITOR 
10e9					endif 
10e9			    push af            ; Save AF register 
10e9			    ld a, l            ; Load low byte of size into A 
10e9			    or h               ; Check if size is zero 
10e9			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
10e9			 
10e9			    ; Allocate memory 
10e9			    ld hl, (heap_start) ; Load start of heap into HL 
10e9					if DEBUG_FORTH_MALLOC 
10e9						DMARK "ma1" 
10e9						CALLMONITOR 
10e9					endif 
10e9			    call malloc_internal ; Call internal malloc function 
10e9			    pop af             ; Restore AF register 
10e9			if DEBUG_FORTH_MALLOC_HIGH 
10e9			call malloc_guard_exit 
10e9			call malloc_guard_zerolen 
10e9			endif 
10e9			    ret                ; Return 
10e9			 
10e9			; Free Function: 
10e9			; Input: 
10e9			;   HL: Pointer to memory block to free 
10e9			; Output: 
10e9			;   None 
10e9			 
10e9			free: 
10e9			    push af            ; Save AF register 
10e9			    ld a, l            ; Load low byte of pointer into A 
10e9			    or h               ; Check if pointer is NULL 
10e9			    jp z, free_exit    ; If pointer is NULL, exit 
10e9			 
10e9			    ; Free memory 
10e9			    ld hl, (heap_start) ; Load start of heap into HL 
10e9			    call free_internal  ; Call internal free function 
10e9			    pop af             ; Restore AF register 
10e9			    ret                ; Return 
10e9			 
10e9			; Internal Malloc Function: 
10e9			; Input: 
10e9			;   HL: Size of block to allocate 
10e9			; Output: 
10e9			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
10e9			 
10e9			malloc_internal: 
10e9			    ld bc, 2           ; Number of bytes to allocate for management overhead 
10e9			    add hl, bc         ; Add management overhead to requested size 
10e9			    ex de, hl          ; Save total size in DE, and keep it in HL 
10e9					if DEBUG_FORTH_MALLOC 
10e9						DMARK "ma2" 
10e9						CALLMONITOR 
10e9					endif 
10e9			 
10e9			    ; Search for free memory block 
10e9			    ld de, (heap_end)  ; Load end of heap into DE 
10e9			    ld bc, 0           ; Initialize counter 
10e9			 
10e9					if DEBUG_FORTH_MALLOC 
10e9						DMARK "ma2" 
10e9						CALLMONITOR 
10e9					endif 
10e9			malloc_search_loop: 
10e9			    ; Check if current block is free 
10e9			    ld a, (hl)         ; Load current block's status (free or used) 
10e9			;    cp 0               ; Compare with zero (free) 
10e9				or a 
10e9			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
10e9			 
10e9			    ; Check if current block is large enough 
10e9			    ld a, (hl+1)       ; Load high byte of block size 
10e9			    cp l               ; Compare with low byte of requested size 
10e9			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
10e9			 
10e9			    ld a, (hl+2)       ; Load low byte of block size 
10e9			    cp h               ; Compare with high byte of requested size 
10e9			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
10e9			 
10e9			    ; Mark block as used 
10e9			    ld (hl), 0xFF      ; Set status byte to indicate used block 
10e9			 
10e9			    ; Calculate remaining space in block 
10e9			    ld bc, 0           ; Clear BC 
10e9			    add hl, bc         ; Increment HL to point to start of data block 
10e9			    add hl, de         ; HL = HL + DE (total size) 
10e9			    ld bc, 1           ; Number of bytes to allocate for management overhead 
10e9			    add hl, bc         ; Add management overhead to start of data block 
10e9			 
10e9			    ; Save pointer to allocated block in HL 
10e9			if DEBUG_FORTH_MALLOC_HIGH 
10e9						DMARK "ma5" 
10e9			call malloc_guard_exit 
10e9			call malloc_guard_zerolen 
10e9			endif 
10e9			    ret 
10e9			 
10e9			malloc_skip_block_check: 
10e9			    ; Move to the next block 
10e9			    ld bc, 3           ; Size of management overhead 
10e9			    add hl, bc         ; Move to the next block 
10e9			    inc de             ; Increment counter 
10e9			 
10e9			    ; Check if we have reached the end of heap 
10e9			    ld a, e            ; Load low byte of heap end address 
10e9			    cp (hl)            ; Compare with low byte of current address 
10e9			    jr nz, malloc_search_loop  ; If not equal, continue searching 
10e9			    ld a, d            ; Load high byte of heap end address 
10e9			;    cp 0               ; Check if it's zero (end of memory) 
10e9				or a 
10e9			    jr nz, malloc_search_loop  ; If not zero, continue searching 
10e9			 
10e9			    ; If we reached here, allocation failed 
10e9			    xor a              ; Set result to NULL 
10e9			if DEBUG_FORTH_MALLOC_HIGH 
10e9						DMARK "ma6" 
10e9			call malloc_guard_exit 
10e9			call malloc_guard_zerolen 
10e9			endif 
10e9			    ret 
10e9			malloc_exit: 
10e9			if DEBUG_FORTH_MALLOC_HIGH 
10e9						DMARK "ma7" 
10e9			call malloc_guard_exit 
10e9			call malloc_guard_zerolen 
10e9			endif 
10e9			    ret 
10e9			 
10e9			; Internal Free Function: 
10e9			; Input: 
10e9			;   HL: Pointer to memory block to free 
10e9			; Output: 
10e9			;   None 
10e9			 
10e9			free_internal: 
10e9			    ld de, (heap_start) ; Load start of heap into DE 
10e9			    ld bc, 0            ; Initialize counter 
10e9			 
10e9			free_search_loop: 
10e9			    ; Check if current block contains the pointer 
10e9			    ld a, l             ; Load low byte of pointer 
10e9			    cp (hl+1)           ; Compare with high byte of current block's address 
10e9			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
10e9			    ld a, h             ; Load high byte of pointer 
10e9			    cp (hl+2)           ; Compare with low byte of current block's address 
10e9			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
10e9			 
10e9			    ; Mark block as free 
10e9			    ld (hl), 0          ; Set status byte to indicate free block 
10e9			    ret                 ; Return 
10e9			 
10e9			free_skip_block_check: 
10e9			    ; Move to the next block 
10e9			    ld bc, 3            ; Size of management overhead 
10e9			    add hl, bc          ; Move to the next block 
10e9			    inc de              ; Increment counter 
10e9			 
10e9			    ; Check if we have reached the end of heap 
10e9			    ld a, e             ; Load low byte of heap end address 
10e9			    cp (hl)             ; Compare with low byte of current address 
10e9			    jr nz, free_search_loop  ; If not equal, continue searching 
10e9			    ld a, d             ; Load high byte of heap end address 
10e9			;    cp 0                ; Check if it's zero (end of memory) 
10e9				or a 
10e9			    jr nz, free_search_loop  ; If not zero, continue searching 
10e9			 
10e9			    ; If we reached here, pointer is not found in heap 
10e9			    ret 
10e9			 
10e9			free_exit: 
10e9			    ret                 ; Return 
10e9			 
10e9			; Define heap start and end addresses 
10e9			;heap_start:    .dw 0xC000   ; Start of heap 
10e9			;heap_end:      .dw 0xE000   ; End of heap 
10e9			 
10e9			endif 
