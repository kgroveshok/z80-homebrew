516f					ld a, (.dmark+2)  
516f					ld (debug_mark+2),a  
516f				endif  
516f 18 04			jr .pastdmark  
5171 ..			.dmark: db "VAR"  
5174				if DEMARK_VERSION = 1  
5174 00					db 0  
5175				endif  
5175				if DEMARK_VERSION = 1  
5175 e1			.pastdmark: pop hl  
5176				endif  
5176				if DEMARK_VERSION = 0  
5176			.pastdmark: pop af  
5176				endif  
