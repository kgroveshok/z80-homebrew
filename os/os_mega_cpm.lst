3ad3			 
3ad3 cd aa 0f				call malloc 
3ad6			 
3ad6			        ;     copy string to block 
3ad6			 
3ad6 c1					pop bc 
3ad7 eb					ex de, hl 
3ad8 e1					pop hl 
3ad9 d5					push de 
3ada			 
3ada ed b0				ldir 
3adc			 
3adc			 
