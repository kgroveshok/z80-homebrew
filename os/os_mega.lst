1128 c5			      push  BC 
1129 d5			      push  DE 
112a dd e5		      push  IX 
112c			if DEBUG_FORTH_MALLOC_HIGH 
112c			call malloc_guard_entry 
112c			endif 
112c			 
112c					if DEBUG_FORTH_MALLOC 
112c						DMARK "mal" 
112c						CALLMONITOR 
112c					endif 
112c 7c			      ld    A, H                    ; Exit if no space requested 
112d b5			      or    L 
112e ca ed 11		      jp    Z, malloc_early_exit 
1131			 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			; 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			;inc hl 
1131			 
1131			 
1131			 
1131			 
1131					if DEBUG_FORTH_MALLOC 
1131						DMARK "maA" 
1131						CALLMONITOR 
1131					endif 
1131			      ; Set up stack frame 
1131 eb			      ex    DE, HL 
1132 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1135 39			      add   HL, SP 
1136 f9			      ld    SP, HL 
1137 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
113b dd 39		      add   IX, SP 
113d			 
113d			      ; Setup initial state 
113d 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
1140 19			      add   HL, DE 
1141			 
1141 44			      ld    B, H                    ; Move want to BC 
1142 4d			      ld    C, L 
1143			 
1143 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
1146 dd 75 04		      ld    (IX+4), L 
1149 dd 74 05		      ld    (IX+5), H 
114c			 
114c 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
114d 23			      inc   HL 
114e 56			      ld    D, (HL) 
114f dd 73 02		      ld    (IX+2), E 
1152 dd 72 03		      ld    (IX+3), D 
1155 eb			      ex    DE, HL                  ; this_free ptr into HL 
1156			 
1156					if DEBUG_FORTH_MALLOC 
1156						DMARK "maB" 
1156						CALLMONITOR 
1156					endif 
1156			      ; Loop through free block list to find some space 
1156			malloc_find_space: 
1156 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
1157 23			      inc   HL 
1158 56			      ld    D, (HL) 
1159			 
1159 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
115a b3			      or    E 
115b ca e7 11		      jp    Z, malloc_no_space 
115e			 
115e dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1161 dd 72 01		      ld    (IX+1), D 
1164			 
1164			      ; Does this block have enough space to make the allocation? 
1164 23			      inc   HL                      ; Load free block size into DE 
1165 5e			      ld    E, (HL) 
1166 23			      inc   HL 
1167 56			      ld    D, (HL) 
1168			 
1168 eb			      ex    DE, HL                  ; Check size of block against want 
1169 b7			      or    A                       ; Ensure carry flag clear 
116a ed 42		      sbc   HL, BC 
116c e5			      push  HL                      ; Store the result for later (new block size) 
116d			 
116d ca bc 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1170 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1172			 
1172			      ; this_free block is not big enough, setup ptrs to test next free block 
1172 e1			      pop   HL                      ; Discard previous result 
1173			 
1173 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1176 dd 66 03		      ld    H, (IX+3) 
1179 dd 75 04		      ld    (IX+4), L 
117c dd 74 05		      ld    (IX+5), H 
117f			 
117f dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1182 dd 66 01		      ld    H, (IX+1) 
1185 dd 75 02		      ld    (IX+2), L 
1188 dd 74 03		      ld    (IX+3), H 
118b			 
118b					if DEBUG_FORTH_MALLOC 
118b						DMARK "MA>" 
118b						CALLMONITOR 
118b					endif 
118b 18 c9		      jr    malloc_find_space 
118d			 
118d			      ; split a bigger block into two - requested size and remaining size 
118d			malloc_alloc_split: 
118d					if DEBUG_FORTH_MALLOC 
118d						DMARK "MAs" 
118d						CALLMONITOR 
118d					endif 
118d eb			      ex    DE, HL                  ; Calculate address of new free block 
118e 2b			      dec   HL 
118f 2b			      dec   HL 
1190 2b			      dec   HL 
1191 09			      add   HL, BC 
1192			 
1192			      ; Create a new block and point it at next_free 
1192 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
1195 dd 56 01		      ld    D, (IX+1) 
1198			 
1198 73			      ld    (HL), E                 ; Store next_free ptr into new block 
1199 23			      inc   HL 
119a 72			      ld    (HL), D 
119b			 
119b d1			      pop   DE                      ; Store size of new block into new block 
119c 23			      inc   HL 
119d 73			      ld    (HL), E 
119e 23			      inc   HL 
119f 72			      ld    (HL), D 
11a0			 
11a0			      ; Update this_free ptr to point to new block 
11a0 2b			      dec   HL 
11a1 2b			      dec   HL 
11a2 2b			      dec   HL 
11a3			 
11a3 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
11a6 dd 56 03		      ld    D, (IX+3) 
11a9			 
11a9 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
11ac dd 74 03		      ld    (IX+3), H 
11af			 
11af			      ; Modify this_free block to be allocation 
11af eb			      ex    DE, HL 
11b0 af			      xor   A                       ; Null the next block ptr of allocated block 
11b1 77			      ld    (HL), A 
11b2 23			      inc   HL 
11b3 77			      ld    (HL), A 
11b4			 
11b4 23			      inc   HL                      ; Store want size into allocated block 
11b5 71			      ld    (HL), C 
11b6 23			      inc   HL 
11b7 70			      ld    (HL), B 
11b8 23			      inc   HL 
11b9 e5			      push  HL                      ; Address of allocation to return 
11ba			 
11ba 18 19		      jr    malloc_update_links 
11bc			 
11bc			malloc_alloc_fit: 
11bc e1			      pop   HL                      ; Dont need new block size, want is exact fit 
11bd			 
11bd					if DEBUG_FORTH_MALLOC 
11bd						DMARK "MAf" 
11bd						CALLMONITOR 
11bd					endif 
11bd			      ; Modify this_free block to be allocation 
11bd eb			      ex    DE, HL 
11be 2b			      dec   HL 
11bf 2b			      dec   HL 
11c0 2b			      dec   HL 
11c1			 
11c1 af			      xor   A                       ; Null the next block ptr of allocated block 
11c2 77			      ld    (HL), A 
11c3 23			      inc   HL 
11c4 77			      ld    (HL), A 
11c5			 
11c5 23			      inc   HL                      ; Store address of allocation to return 
11c6 23			      inc   HL 
11c7 23			      inc   HL 
11c8 e5			      push  HL 
11c9			 
11c9			      ; Copy next_free ptr to this_free, remove allocated block from free list 
11c9 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11cc dd 66 01		      ld    H, (IX+1) 
11cf			 
11cf dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11d2 dd 74 03		      ld    (IX+3), H 
11d5			 
11d5			 
11d5			malloc_update_links: 
11d5			      ; Update prev_free ptr to point to this_free 
11d5 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
11d8 dd 66 05		      ld    H, (IX+5) 
11db			 
11db dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
11de dd 56 03		      ld    D, (IX+3) 
11e1			 
11e1 73			      ld    (HL), E                 ; this_free ptr into prev_free 
11e2 23			      inc   HL 
11e3 72			      ld    (HL), D 
11e4			 
11e4					if DEBUG_FORTH_MALLOC 
11e4						DMARK "Mul" 
11e4						CALLMONITOR 
11e4					endif 
11e4			      ; Clear the Z flag to indicate successful allocation 
11e4 7a			      ld    A, D 
11e5 b3			      or    E 
11e6			 
11e6 d1			      pop   DE                      ; Address of allocation 
11e7					if DEBUG_FORTH_MALLOC 
11e7						DMARK "MAu" 
11e7						CALLMONITOR 
11e7					endif 
11e7			 
11e7			malloc_no_space: 
11e7 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
11ea 39			      add   HL, SP 
11eb f9			      ld    SP, HL 
11ec			 
11ec eb			      ex    DE, HL                  ; Alloc addr into HL for return 
11ed					if DEBUG_FORTH_MALLOC 
11ed						DMARK "MAN" 
11ed						CALLMONITOR 
11ed					endif 
11ed			 
11ed			malloc_early_exit: 
11ed					if DEBUG_FORTH_MALLOC 
11ed						DMARK "MAx" 
11ed						CALLMONITOR 
11ed					endif 
11ed dd e1		      pop   IX 
11ef d1			      pop   DE 
11f0 c1			      pop   BC 
11f1			 
11f1			if DEBUG_FORTH_MALLOC_HIGH 
11f1			call malloc_guard_exit 
11f1			call malloc_guard_zerolen 
11f1			endif 
11f1 c9			      ret 
