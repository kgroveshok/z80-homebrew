239b			 
239b			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
239b			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
239b			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
239b			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
239b			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
239b			WORD_SYS_END: equ 0   ; Opcode for all user words 
239b			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
239b			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
239b			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
239b			 
239b			; Core word preamble macro 
239b			 
239b			CWHEAD:   macro nxtword opcode lit len opflags 
239b				db WORD_SYS_CORE+opcode             
239b				; internal op code number 
239b				dw nxtword            
239b				; link to next dict word block 
239b				db len + 1 
239b				; literal length of dict word inc zero term 
239b				db lit,0              
239b				; literal dict word 
239b			        ; TODO db opflags        
239b				endm 
