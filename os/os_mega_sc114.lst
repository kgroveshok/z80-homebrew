92a0					ld b, '1'    ; human readable bank number 
92a0			.b2:		cp 2 
92a0					jr nz, .b3 
92a0					res 1, c 
92a0					ld b, '2'    ; human readable bank number 
92a0			.b3:		cp 3 
92a0					jr nz, .b4 
92a0					res 2, c 
92a0					ld b, '3'    ; human readable bank number 
