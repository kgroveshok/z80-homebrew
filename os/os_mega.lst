15a6			 
15a6			; Device support for SN76489AN sound chip 
15a6			 
15a6			; https://arduinoplusplus.wordpress.com/2019/10/05/making-noise-with-a-sn76489-digital-sound-generator-part-1/ 
15a6			; http://danceswithferrets.org/geekblog/?p=93 
15a6			; https://www.smspower.org/Development/SN76489 
15a6			 
15a6			; D0 [ 3] 
15a6			; D1 [ 2] 
15a6			; D2 [ 1] 
15a6			; D3 [15] 
15a6			; D4 [13] 
15a6			; D5 [12] 
15a6			; D6 [11] 
15a6			; D7 [10] 
15a6			; /WE [ 5] 
15a6			; CLK [14] 
15a6			; /OE [ 6] 
15a6			; AUDIO [ 7] 
15a6			; GND 8 
15a6			; +5 16 
15a6			; 
15a6			 
15a6			; Write sequence: 
15a6			; CE low 
15a6			; Data bus 
15a6			; WE low then high 
15a6			; 32 clock cycles / 8ns write time at 4mhz 
15a6			; 
15a6			; https://github.com/jblang/SN76489 
15a6			; Shows that the clock needs to be enabled when required. Noticed that with the clock connected it interupted the bus 
15a6			; Tried: 
15a6			; 
15a6			; CE/OE -> Both pins of NAND -> To one pin of second NAND and second pin to full clock -> CLK on chip 
15a6			; 
15a6			; Connected WE to OR too 
15a6			;  
15a6			; That enabled the clock when required 
15a6			; However still random bus corruption. Need further investigation 
15a6			 
15a6			 
15a6			SOUND_LATCH: equ 10000000B 
15a6			SOUND_DATA: equ 0B 
15a6			SOUND_CH0:  equ 0B    ; Tone 
15a6			SOUND_CH1: equ 0100000B        ; Tone 
15a6			SOUND_CH2: equ 1000000B   ; Tone 
15a6			SOUND_CH3: equ 1100000B    ; Noise 
15a6			SOUND_VOL: equ 10000B 
15a6			SOUND_TONE: equ 0B 
15a6			 
15a6			 
15a6 c9			sound_init: ret 
