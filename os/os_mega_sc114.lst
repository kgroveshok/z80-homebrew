89db			; 
89db			; Multiply 8-bit value with a 16-bit value (unrolled) 
89db			; In: Multiply A with DE 
89db			; Out: HL = result 
89db			; 
89db			Mult12U: 
89db 2e 00		    ld l,0 
89dd 87			    add a,a 
89de 30 01		    jr nc,Mult12U_NoAdd0 
89e0 19			    add hl,de 
89e1			Mult12U_NoAdd0: 
89e1 29			    add hl,hl 
89e2 87			    add a,a 
89e3 30 01		    jr nc,Mult12U_NoAdd1 
89e5 19			    add hl,de 
89e6			Mult12U_NoAdd1: 
89e6 29			    add hl,hl 
89e7 87			    add a,a 
89e8 30 01		    jr nc,Mult12U_NoAdd2 
89ea 19			    add hl,de 
89eb			Mult12U_NoAdd2: 
89eb 29			    add hl,hl 
89ec 87			    add a,a 
89ed 30 01		    jr nc,Mult12U_NoAdd3 
89ef 19			    add hl,de 
89f0			Mult12U_NoAdd3: 
89f0 29			    add hl,hl 
89f1 87			    add a,a 
89f2 30 01		    jr nc,Mult12U_NoAdd4 
89f4 19			    add hl,de 
89f5			Mult12U_NoAdd4: 
89f5 29			    add hl,hl 
89f6 87			    add a,a 
89f7 30 01		    jr nc,Mult12U_NoAdd5 
89f9 19			    add hl,de 
89fa			Mult12U_NoAdd5: 
89fa 29			    add hl,hl 
89fb 87			    add a,a 
89fc 30 01		    jr nc,Mult12U_NoAdd6 
89fe 19			    add hl,de 
89ff			Mult12U_NoAdd6: 
89ff 29			    add hl,hl 
8a00 87			    add a,a 
8a01 d0			    ret nc 
8a02 19			    add hl,de 
8a03 c9			    ret 
8a04			 
8a04			; 
8a04			; Multiply 8-bit value with a 16-bit value (right rotating) 
8a04			; In: Multiply A with DE 
8a04			;      Put lowest value in A for most efficient calculation 
8a04			; Out: HL = result 
8a04			; 
8a04			Mult12R: 
8a04 21 00 00		    ld hl,0 
8a07			Mult12R_Loop: 
8a07 cb 3f		    srl a 
8a09 30 01		    jr nc,Mult12R_NoAdd 
8a0b 19			    add hl,de 
8a0c			Mult12R_NoAdd: 
8a0c cb 23		    sla e 
8a0e cb 12		    rl d 
8a10 b7			    or a 
8a11 c2 07 8a		    jp nz,Mult12R_Loop 
8a14 c9			    ret 
