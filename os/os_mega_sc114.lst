bf75 .. 00			db "VAR",0              
bf79				endm 
# End of macro CWHEAD
bf79			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bf79			; | 
bf79			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bf79			; | |  
bf79			; | | e.g. 
bf79			; | |         #30 a var ! 
bf79			; | |         a var @ . 
bf79			; | |   
bf79			; | |     Displays the number 30 
bf79			; | | 
bf79			; | | Each variable pointer is a word so can use for any words that use that:  
bf79			; | |  
bf79			; | | e.g. 
bf79			; | |  
bf79			; | |         #30 a var 2! 
bf79			; | |         a var 2@ . 
bf79			; | |   
bf79			; | |     Displays the number 30 
bf79			; | |  
bf79			; | | > [!NOTE]  
bf79			; ! | > If a full string is passed then only the first char is looked at 
bf79			; | | > Any other char could exceed bounds checks!  
bf79			; | | > 
bf79			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bf79			 
bf79					if DEBUG_FORTH_WORDS_KEY 
bf79						DMARK "VAR" 
bf79				if DEMARK_VERSION = 1  
bf79 e5					push hl  
bf7a 21 82 bf				ld hl, .dmark  
bf7d 22 60 ee				ld (debug_mark), hl  
bf80				endif  
bf80				if DEMARK_VERSION = 0  
bf80					push af  
