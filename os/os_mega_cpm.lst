0f52			malloc_guard_entry: 
0f52				push hl 
0f52				push de 
0f52				push af 
0f52			 
0f52			 	or a      ;clear carry flag 
0f52				push hl 
0f52				ld de, 255 
0f52				sbc hl, de 
0f52				jr c, .lowalloc 
0f52			 
0f52				push de 
0f52					ld hl, display_fb0 
0f52					ld (display_fb_active), hl 
0f52				call clear_display 
0f52				ld a, 0 
0f52				ld de, .mallocsize 
0f52				call str_at_display 
0f52				call update_display 
0f52				call delay1s 
0f52				call delay1s 
0f52			;	ld a, 0 
