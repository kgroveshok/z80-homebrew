0b2f 21 00 00		     ld hl,0         ;10         10 
0b32 29			       add hl,hl     ;11*8       88 
0b33 07			       rlca          ;4*8        32 
0b34 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0b36 19			         add hl,de   ;--         -- 
