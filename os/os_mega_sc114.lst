901b			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
901b			 
901b			;moved to firmware.asm 
901b			;heap_start        .equ  0x9000      ; Starting address of heap 
901b			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
901b			 
901b			;      .org 0 
901b			;      jp    main 
901b			 
901b			 
901b			;      .org  0x100 
901b			;main: 
901b			;      ld    HL, 0x8100 
901b			;      ld    SP, HL 
901b			; 
901b			;      call  heap_init 
901b			; 
901b			;      ; Make some allocations 
901b			;      ld    HL, 12 
901b			;      call  malloc            ; Allocates 0x9004 
901b			; 
901b			;      ld    HL, 12 
901b			;      call  malloc            ; Allocates 0x9014 
901b			; 
901b			;      ld    HL, 12 
901b			;      call  malloc            ; Allocates 0x9024 
901b			; 
901b			;      ; Free some allocations 
901b			;      ld    HL, 0x9014 
901b			;      call  free 
901b			; 
901b			;      ld    HL, 0x9004 
901b			;      call  free 
901b			; 
901b			;      ld    HL, 0x9024 
901b			;      call  free 
901b			; 
901b			; 
901b			;      halt 
901b			 
901b			 
901b			;------------------------------------------------------------------------------ 
901b			;     heap_init                                                               : 
901b			;                                                                             : 
901b			; Description                                                                 : 
901b			;     Initialise the heap and make it ready for malloc and free operations.   : 
901b			;                                                                             : 
901b			;     The heap is maintained as a linked list, starting with an initial       : 
901b			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
901b			;     the first free block in the heap. Each block then points to the next    : 
901b			;     free block within the heap, and the free list ends at the first block   : 
901b			;     with a null pointer to the next free block.                             : 
901b			;                                                                             : 
901b			; Parameters                                                                  : 
901b			;     Inputs are compile-time only. Two defines which specify the starting    : 
901b			;     address of the heap and its size are required, along with a memory      : 
901b			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
901b			;     principally stores a pointer to the first free block in the heap.       : 
901b			;                                                                             : 
901b			; Returns                                                                     : 
901b			;     Nothing                                                                 : 
901b			;------------------------------------------------------------------------------ 
901b			heap_init: 
901b e5			      push  HL 
901c			 
901c			      ; Initialise free list struct 
901c 21 3d e1		      ld    HL, heap_start 
901f 22 38 e1		      ld    (free_list), HL 
9022 21 00 00		      ld    HL, 0 
9025 22 3a e1		      ld    (free_list+2), HL 
9028			 
9028			      ; Insert first free block at bottom of heap, consumes entire heap 
9028 21 8b e2		      ld    HL, heap_start+heap_size-4 
902b 22 3d e1		      ld    (heap_start), HL        ; Next block (end of free list) 
902e 21 4e 01		      ld    HL, heap_size-4 
9031 22 3f e1		      ld    (heap_start+2), HL      ; Block size 
9034			 
9034			      ; Insert end of free list block at top of heap - two null words will 
9034			      ; terminate the free list 
9034 21 00 00		      ld    HL, 0 
9037 22 8d e2		      ld    (heap_start+heap_size-2), HL 
903a 22 8b e2		      ld    (heap_start+heap_size-4), HL 
903d			 
903d e1			      pop   HL 
903e			 
903e c9			      ret 
903f			 
903f			 
903f			;------------------------------------------------------------------------------ 
903f			;     malloc                                                                  : 
903f			;                                                                             : 
903f			; Description                                                                 : 
903f			;     Allocates the wanted space from the heap and returns the address of the : 
903f			;     first useable byte of the allocation.                                   : 
903f			;                                                                             : 
903f			;     Allocations can happen in one of two ways:                              : 
903f			;                                                                             : 
903f			;     1. A free block may be found which is the exact size wanted. In this    : 
903f			;        case the block is removed from the free list and retuedn to the      : 
903f			;        caller.                                                              : 
903f			;     2. A free block may be found which is larger than the size wanted. In   : 
903f			;        this case, the larger block is split into two. The first portion of  : 
903f			;        this block will become the requested space by the malloc call and    : 
903f			;        is returned to the caller. The second portion becomes a new free     : 
903f			;        block, and the free list is adjusted to maintain continuity via this : 
903f			;        newly created block.                                                 : 
903f			;                                                                             : 
903f			;     malloc does not set any initial value in the allocated space, the       : 
903f			;     caller is required to do this as required.                              : 
903f			;                                                                             : 
903f			;     This implementation of malloc uses the stack exclusively, and is        : 
903f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
903f			;     advisable to disable interrupts before calling malloc, and recommended  : 
903f			;     to avoid the use of malloc inside ISRs in general.                      : 
903f			;                                                                             : 
903f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
903f			;                                                                             : 
903f			; Parameters                                                                  : 
903f			;     HL  Number of bytes wanted                                              : 
903f			;                                                                             : 
903f			; Returns                                                                     : 
903f			;     HL  Address of the first useable byte of the allocation                 : 
903f			;                                                                             : 
903f			; Flags                                                                       : 
903f			;     Z   Set if the allocation did not succeed, clear otherwise              : 
903f			;                                                                             : 
903f			; Stack frame                                                                 : 
903f			;       |             |                                                       : 
903f			;       +-------------+                                                       : 
903f			;       |     BC      |                                                       : 
903f			;       +-------------+                                                       : 
903f			;       |     DE      |                                                       : 
903f			;       +-------------+                                                       : 
903f			;       |     IX      |                                                       : 
903f			;       +-------------+                                                       : 
903f			;       |  prev_free  |                                                       : 
903f			;   +4  +-------------+                                                       : 
903f			;       |  this_free  |                                                       : 
903f			;   +2  +-------------+                                                       : 
903f			;       |  next_free  |                                                       : 
903f			;   +0  +-------------+                                                       : 
903f			;       |             |                                                       : 
903f			;                                                                             : 
903f			;------------------------------------------------------------------------------ 
903f			 
903f			 
903f			;malloc: 
903f			; 
903f			;	SAVESP ON 1 
903f			; 
903f			;	call malloc_code 
903f			; 
903f			;	CHECKSP ON 1 
903f			;	ret 
903f			 
903f			 
903f			malloc: 
903f c5			      push  BC 
9040 d5			      push  DE 
