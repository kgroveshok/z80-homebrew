7068			; stack over and underflow checks 
7068			 
7068			; init the words to detect the under/overflow 
7068			 
7068			chk_stk_init: 
7068				; a vague random number to check so we dont get any "lucky" hits 
7068 3e 2d			ld a, 45 
706a 6f				ld l, a 
706b 00				nop 
706c 3e 17			ld a, 23 
706e 67				ld h, a 
706f			 
706f 22 cb f0			ld (chk_word), hl     ; the word we need to check against 
7072			 
7072			;	ld (chk_stund), hl	; stack points.... 
7072 22 3b fe			ld (chk_stovr), hl 
7075 22 1a f9			ld (chk_ret_und), hl 
7078 22 d8 f8			ld (chk_ret_ovr), hl 
707b 22 56 f8			ld (chk_loop_ovr), hl 
707e 22 54 f6			ld (chk_data_ovr), hl 
7081 c9				ret 
7082				 
7082			check_stacks: 
7082				; check all stack words 
7082			 
7082 e5				push hl 
7083 d5				push de 
7084			 
7084			;	ld de,(chk_word) 
7084			;	ld hl, (chk_stund)	; stack points.... 
7084			;	if DEBUG_STK_FAULT 
7084			;		DMARK "FAa" 
7084			;		CALLMONITOR 
7084			;	endif 
7084			;	call cmp16 
7084			;	jp z, .chk_faulta 
7084			; 
7084			;	ld de, sfaultsu 
7084			;	jp .chk_fault 
7084			 
7084 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
7087 ed 5b cb f0		ld de,(chk_word) 
708b				if DEBUG_STK_FAULT 
708b					DMARK "FAb" 
708b					CALLMONITOR 
708b				endif 
708b cd 9b 0f			call cmp16 
708e 28 06			jr z, .chk_fault1 
7090 11 34 71			ld de, sfaultso 
7093 c3 e5 70			jp .chk_fault 
7096			.chk_fault1:  
7096 2a 1a f9			ld hl, (chk_ret_und) 
7099 ed 5b cb f0		ld de,(chk_word) 
709d				if DEBUG_STK_FAULT 
709d					DMARK "FAU" 
709d					CALLMONITOR 
709d				endif 
709d cd 9b 0f			call cmp16 
70a0 ca a9 70			jp z, .chk_fault2 
70a3 11 44 71			ld de, sfaultru 
70a6 c3 e5 70			jp .chk_fault 
70a9			.chk_fault2:  
70a9 2a d8 f8			ld hl, (chk_ret_ovr) 
70ac ed 5b cb f0		ld de,(chk_word) 
70b0				if DEBUG_STK_FAULT 
70b0					DMARK "FA1" 
70b0					CALLMONITOR 
70b0				endif 
70b0 cd 9b 0f			call cmp16 
70b3 ca bc 70			jp z, .chk_fault3 
70b6 11 52 71			ld de, sfaultro 
70b9 c3 e5 70			jp .chk_fault 
70bc			.chk_fault3:  
70bc 2a 56 f8			ld hl, (chk_loop_ovr) 
70bf ed 5b cb f0		ld de,(chk_word) 
70c3				if DEBUG_STK_FAULT 
70c3					DMARK "FA2" 
70c3					CALLMONITOR 
70c3				endif 
70c3 cd 9b 0f			call cmp16 
70c6 ca cf 70			jp z, .chk_fault4 
70c9 11 6c 71			ld de, sfaultlo 
70cc c3 e5 70			jp .chk_fault 
70cf			.chk_fault4:  
70cf 2a 54 f6			ld hl, (chk_data_ovr) 
70d2 ed 5b cb f0		ld de,(chk_word) 
70d6				if DEBUG_STK_FAULT 
70d6					DMARK "FA3" 
70d6					CALLMONITOR 
70d6				endif 
70d6 cd 9b 0f			call cmp16 
70d9 ca e2 70			jp z, .chk_fault5 
70dc 11 86 71			ld de, sfaultdo 
70df c3 e5 70			jp .chk_fault 
