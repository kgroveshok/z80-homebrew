6824			; **********************************************************************  
6824			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6824			; **********************************************************************  
6824			;  
6824			; **  Written as a Small Computer Monitor App   
6824			; **  Version 0.1 SCC 2018-05-16  
6824			; **  www.scc.me.uk  
6824			;  
6824			; **********************************************************************  
6824			;  
6824			; This module provides support for alphanumeric LCD modules using with  
6824			; *  HD44780 (or compatible) controller  
6824			; *  5 x 7 pixel fonts  
6824			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6824			; *  Interface via six digital outputs to the display (see below)  
6824			;  
6824			; LCD module pinout:  
6824			;   1  Vss   0v supply  
6824			;   2  Vdd   5v supply  
6824			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6824			;   4  RS    High = data, Low = instruction  
6824			;   5  R/W   High = Read, Low = Write  
6824			;   6  E     Enable signal (active high)  
6824			;   7  DB0   Data bit 0  
6824			;   8  DB1   Data bit 1  
6824			;   9  DB2   Data bit 2  
6824			;  10  DB3   Data bit 3  
6824			;  11  DB4   Data bit 4  
6824			;  12  DB5   Data bit 5  
6824			;  13  DB6   Data bit 6  
6824			;  14  DB7   Data bit 7  
6824			;  15  A     Backlight anode (+)  
6824			;  16  K     Backlight cathode (-)  
6824			;  
6824			; This interfacing method uses 4-bit data mode and uses time delays  
6824			; rather than polling the display's ready status. As a result the   
6824			; interface only requires 6 simple output lines:  
6824			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6824			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6824			;   LCD DB4 = Microcomputer output port bit 4  
6824			;   LCD DB5 = Microcomputer output port bit 5  
6824			;   LCD DB6 = Microcomputer output port bit 6  
6824			;   LCD DB7 = Microcomputer output port bit 7  
6824			; Display's R/W is connected to 0v so it is always in write mode  
6824			; All 6 connections must be on the same port address <kLCDPrt>  
6824			; This method also allows a decent length of cable from micro to LCD  
6824			;  
6824			; **********************************************************************  
6824			;  
6824			; To include the code for any given function provided by this module,   
6824			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6824			; the parent source file.  
6824			; For example:  #REQUIRES   uHexPrefix  
6824			;  
6824			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6824			; in the parent source file.  
6824			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6824			;  
6824			; These are the function names provided by this module:  
6824			; fLCD_Init                     ;Initialise LCD  
6824			; fLCD_Inst                     ;Send instruction to LCD  
6824			; fLCD_Data                     ;Send data byte to LCD  
6824			; fLCD_Pos                      ;Position cursor  
6824			; fLCD_Str                      ;Display string  
6824			; fLCD_Def                      ;Define custom character  
6824			;  
6824			; **********************************************************************  
6824			;  
6824			; Requires SCMonAPI.asm to also be included in the project  
6824			;  
6824			  
6824			  
6824			; **********************************************************************  
6824			; **  Constants  
6824			; **********************************************************************  
6824			  
6824			; Constants that must be defined externally  
6824			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6824			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6824			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6824			;kLCDWidth: EQU 20             ;Width in characters  
6824			  
6824			; general line offsets in any frame buffer  
6824			  
6824			  
6824			display_row_1: equ 0  
6824			display_row_2: equ display_row_1+display_cols  
6824			display_row_3: equ display_row_2 + display_cols  
6824			display_row_4: equ display_row_3 + display_cols  
6824			;display_row_4_eol:   
6824			  
6824			  
6824			; Cursor position values for the start of each line  
6824			  
6824			; E  
6824			kLCD_Line1: EQU 0x00   
6824			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6824			; E1  
6824			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6824			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6824			  
6824			; Instructions to send as A register to fLCD_Inst  
6824			kLCD_Clear: EQU 00000001b     ;LCD clear  
6824			kLCD_Off:   EQU 00001000b     ;LCD off  
6824			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6824			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6824			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6824			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6824			  
6824			; Constants used by this code module  
6824			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6824			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6824			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6824			  
6824			  
6824			  
6824			; **********************************************************************  
6824			; **  LCD support functions  
6824			; **********************************************************************  
6824			  
6824			; Initialise alphanumeric LCD module  
6824			; LCD control register codes:  
6824			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6824			;   N    0 = 1-line mode       1 = 2-line mode  
6824			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6824			;   D    0 = Display off       1 = Display on  
6824			;   C    0 = Cursor off        1 = Cursor on  
6824			;   B    0 = Blinking off      1 = Blinking on  
6824			;   ID   0 = Decrement mode    1 = Increment mode  
6824			;   SH   0 = Entire shift off  1 = Entire shift on  
6824 3e 28		fLCD_Init:  LD   A, 40  
6826 cd 4b 69		            CALL LCDDelay       ;Delay 40ms after power up  
6829			; For reliable reset set 8-bit mode - 3 times  
6829 cd 1b 69		            CALL WrFn8bit       ;Function = 8-bit mode  
682c cd 1b 69		            CALL WrFn8bit       ;Function = 8-bit mode  
682f cd 1b 69		            CALL WrFn8bit       ;Function = 8-bit mode  
6832			; Set 4-bit mode  
6832 cd 17 69		            CALL WrFn4bit       ;Function = 4-bit mode  
6835 cd 49 69		            CALL LCDDelay1      ;Delay 37 us or more  
6838			; Function set  
6838 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
683a cd 4d 68		            CALL fLCD_Inst      ;2 line, display on  
683d			; Display On/Off control  
683d 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
683f cd 4d 68		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6842			; Display Clear  
6842 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6844 cd 4d 68		            CALL fLCD_Inst      ;Clear display  
6847			; Entry mode  
6847 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6849 cd 4d 68		            CALL fLCD_Inst      ;Increment mode, shift off  
684c			; Display module now initialised  
684c c9			            RET  
684d			; ok to here  
684d			  
684d			; Write instruction to LCD  
684d			;   On entry: A = Instruction byte to be written  
684d			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
684d f5			fLCD_Inst:  PUSH AF  
684e f5			            PUSH AF  
684f cd 61 68		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6852 f1			            POP  AF  
6853 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6854 17			            RLA  
6855 17			            RLA  
6856 17			            RLA  
6857 cd 61 68		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
685a 3e 02		            LD   A, 2  
685c cd 4b 69		            CALL LCDDelay       ;Delay 2 ms to complete   
685f f1			            POP  AF  
6860 c9			            RET  
6861			Wr4bits:   
6861 f5					push af  
6862 3a fb fa				ld a, (display_lcde1e2)  
6865 fe 00				cp 0     ; e  
6867 20 10				jr nz, .wea2	  
6869 f1					pop af  
686a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
686c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
686e cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6870 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6872 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6874 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6876 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6878 c9			            RET  
6879 f1			.wea2:		pop af  
687a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
687c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
687e cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6880 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6882 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6884 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6886 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6888 c9			            RET  
6889			  
6889			  
6889			; Write data to LCD  
6889			;   On entry: A = Data byte to be written  
6889			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6889 f5			fLCD_Data:  PUSH AF  
688a f5			            PUSH AF  
688b cd 9d 68		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
688e f1			            POP  AF  
688f 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6890 17			            RLA  
6891 17			            RLA  
6892 17			            RLA  
6893 cd 9d 68		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6896 3e 96		            LD   A, 150  
6898 3d			Wait:      DEC  A              ;Wait a while to allow data   
6899 20 fd		            JR   NZ, Wait      ;  write to complete  
689b f1			            POP  AF  
689c c9			            RET  
689d			Wr4bitsa:     
689d f5					push af  
689e 3a fb fa				ld a, (display_lcde1e2)  
68a1 fe 00				cp 0     ; e1  
68a3 20 16				jr nz, .we2	  
68a5 f1					pop af  
68a6 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
68a8 cb d7		            SET  kLCDBitRS, A  
68aa d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
68ac cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
68ae cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
68b0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
68b2 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
68b4 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
68b6 cb 97		            RES  kLCDBitRS, A  
68b8 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
68ba c9			            RET  
68bb f1			.we2:		pop af  
68bc e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
68be cb d7		            SET  kLCDBitRS, A  
68c0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
68c2 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
68c4 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
68c6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
68c8 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
68ca d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
68cc cb 97		            RES  kLCDBitRS, A  
68ce d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
68d0 c9			            RET  
68d1			  
68d1			  
68d1			; Position cursor to specified location  
68d1			;   On entry: A = Cursor position  
68d1			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
68d1 f5			fLCD_Pos:   PUSH AF  
68d2					; at this point set the E1 or E2 flag depending on position  
68d2			  
68d2 c5					push bc  
68d3			;		push af  
68d3 06 00				ld b, 0  
68d5 4f					ld c, a  
68d6 3e 4f				ld a, kLCD_Line3-1  
68d8 b7			 		or a      ;clear carry flag  
68d9 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
68da 38 04				jr c, .pe1  
68dc			  
68dc					; E selection  
68dc cb 80				res 0, b         ; bit 0 unset e  
68de			;		pop af    ; before line 3 so recover orig pos  
68de			;		ld c, a    ; save for poking back  
68de 18 06				jr .peset	          
68e0			.pe1:          	; E2 selection  
68e0 cb c0				set 0, b         ; bit 0 set e1  
68e2 79					ld a, c  
68e3 de 4f				sbc a, kLCD_Line3-1  
68e5 4f					ld c, a	         ; save caculated offset  
68e6			;		pop af     ; bin this original value now we have calculated form  
68e6			  
68e6			.peset:		; set bit  
68e6 78					ld a, b  
68e7 32 fb fa				ld (display_lcde1e2), a 	  
68ea 79					ld a, c  
68eb c1					pop bc  
68ec			  
68ec f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
68ee cd 4d 68		            CALL fLCD_Inst      ;Write instruction to LCD  
68f1 f1			            POP  AF  
68f2 c9			            RET  
68f3			  
68f3			  
68f3			; Output text string to LCD  
68f3			;   On entry: DE = Pointer to null terminated text string  
68f3			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
68f3 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
68f4 b7			            OR   A              ;Null terminator?  
68f5 c8			            RET  Z              ;Yes, so finished  
68f6 cd 89 68		            CALL fLCD_Data      ;Write character to display  
68f9 13			            INC  DE             ;Point to next character  
68fa 18 f7		            JR   fLCD_Str       ;Repeat  
68fc c9					ret  
68fd			  
68fd			; Define custom character  
68fd			;   On entry: A = Character number (0 to 7)  
68fd			;             DE = Pointer to character bitmap data  
68fd			;   On exit:  A = Next character number  
68fd			;             DE = Next location following bitmap  
68fd			;             BC HL IX IY I AF' BC' DE' HL' preserved  
68fd			; Character is   
68fd c5			fLCD_Def:   PUSH BC  
68fe f5			            PUSH AF  
68ff 07			            RLCA                ;Calculate location  
6900 07			            RLCA                ;  for bitmap data  
6901 07			            RLCA                ;  = 8 x CharacterNumber  
6902 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6904 cd 4d 68		            CALL fLCD_Inst      ;Write instruction to LCD  
6907 06 00		            LD   B, 0  
6909 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
690a cd 89 68		            CALL fLCD_Data      ;Write byte to display  
690d 13			            INC  DE             ;Point to next byte  
690e 04			            INC  B              ;Count bytes  
690f cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6911 28 f6		            JR   Z, Loop       ;No, so repeat  
6913 f1			            POP  AF  
6914 3c			            INC  A              ;Increment character number  
6915 c1			            POP  BC  
6916 c9			            RET  
6917			  
6917			  
6917			; **********************************************************************  
6917			; **  Private functions  
6917			; **********************************************************************  
6917			  
6917			; Write function to LCD  
6917			;   On entry: A = Function byte to be written  
6917			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6917 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6919 18 02		            JR   WrFunc  
691b 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
691d f5			WrFunc:     PUSH AF  
691e f5					push af  
691f 3a fb fa				ld a, (display_lcde1e2)  
6922 fe 00				cp 0     ; e1  
6924 20 0f				jr nz, .wfea2	  
6926 f1					pop af  
6927 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6929 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
692b cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
692d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
692f cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6931 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6933 18 0d			jr .wfskip  
6935 f1			.wfea2:		pop af  
6936 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6938 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
693a cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
693c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
693e cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6940 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6942 3e 05		.wfskip:            LD  A, 5  
6944 cd 4b 69		            CALL LCDDelay       ;Delay 5 ms to complete  
6947 f1			            POP  AF  
6948 c9			            RET  
6949			  
6949			  
6949			; Delay in milliseconds  
6949			;   On entry: A = Number of milliseconds delay  
6949			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6949 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
694b d5			LCDDelay:   PUSH DE  
694c 5f			            LD   E, A           ;Delay by 'A' ms  
694d 16 00		            LD   D, 0  
694f cd 53 0a		            CALL aDelayInMS  
6952 d1			            POP  DE  
6953 c9			            RET  
