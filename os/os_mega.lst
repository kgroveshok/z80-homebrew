681a			; **********************************************************************  
681a			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
681a			; **********************************************************************  
681a			;  
681a			; **  Written as a Small Computer Monitor App  
681a			; **  www.scc.me.uk  
681a			;  
681a			; History  
681a			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
681a			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
681a			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
681a			;  
681a			; **********************************************************************  
681a			;  
681a			; This program is an example of one of the methods of interfacing an   
681a			; alphanumeric LCD module.   
681a			;  
681a			; In this example the display is connected to either a Z80 PIO or a   
681a			; simple 8-bit output port.   
681a			;  
681a			; This interfacing method uses 4-bit data mode and uses time delays  
681a			; rather than polling the display's ready status. As a result the   
681a			; interface only requires 6 simple output lines:  
681a			;   Output bit 0 = not used  
681a			;   Output bit 1 = not used  
681a			;   Output bit 2 = RS         High = data, Low = instruction  
681a			;   Output bit 3 = E          Active high  
681a			;   Output bit 4 = DB4  
681a			;   Output bit 5 = DB5  
681a			;   Output bit 6 = DB6  
681a			;   Output bit 7 = DB7  
681a			; Display's R/W is connected to 0v so it is always in write mode  
681a			;  
681a			; This set up should work with any system supporting the RC2014 bus  
681a			  
681a			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
681a			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
681a			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
681a			;  
681a			; **********************************************************************  
681a			  
681a			; Additonal for 4x40. E1 and E2 instead of just E   
681a			; TODO swipe vidout signal on port a to activate E2  
681a			  
681a			; **********************************************************************  
681a			; **  Constants  
681a			; **********************************************************************  
681a			; LCD constants required by LCD support module  
681a			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
681a			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
681a			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
681a			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
681a			; TODO Decide which E is being set  
681a			kLCDWidth:  EQU display_cols             ;Width in characters  
681a			  
681a			; **********************************************************************  
681a			; **  Code library usage  
681a			; **********************************************************************  
681a			  
681a			; send character to current cursor position  
681a			; wraps and/or scrolls screen automatically  
681a			  
681a			  
681a			  
681a			lcd_init:  
681a			  
681a			; SCMonAPI functions used  
681a			  
681a			; Alphanumeric LCD functions used  
681a			; no need to specify specific functions for this module  
681a			  
681a 3e cf		            LD   A, 11001111b  
681c d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
681e 3e 00		            LD   A, 00000000b  
6820 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6822			  
6822			; Initialise alphanumeric LCD module  
6822 3e 00				ld a, 0  
6824 32 fb fa				ld (display_lcde1e2), a  
6827 cd a8 68		            CALL fLCD_Init      ;Initialise LCD module  
682a 3e 01				ld a, 1  
682c 32 fb fa				ld (display_lcde1e2), a  
682f cd a8 68		            CALL fLCD_Init      ;Initialise LCD module  
6832			  
6832 c9				ret  
6833			  
