0291			storage_init: 
0291			 
0291			 
0291					; set default SPI clk pulse time as disabled 
0291			 
0291 3e 00				ld a, 0 
0293 32 94 f9				ld (spi_clktime), a 
0296			 
0296					; init hardware 
0296			 
0296 3e cf		            LD   A, 11001111b 
0298 d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
029a 3e 00		            LD   A, 00000000b 
029c cb f7			set SPI_DO,a 
029e			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
029e d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
02a0			 
02a0 3e cf		            LD   A, 11001111b 
02a2 d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
02a4 3e 00		            LD   A, 00000000b 
02a6 d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
02a8			 
02a8				; set all external spi devices off  
02a8 3e ff			ld a, 255 
02aa 32 90 f9			ld (spi_device), a 
02ad 32 93 f9			ld (spi_cartdev), a 
02b0			 
02b0					; ensure the spi bus is in a default stable state 
02b0 cd 38 01				call se_stable_spi 
02b3			 
02b3			; TODO scan spi bus and gather which storage banks are present 
02b3			 
02b3			; populate store_bank_active  
02b3			; for each ce line activate and attempt to write first byte of bank and read back 
02b3			; if zero is returned then bank is empty 
02b3			;   
02b3			; 
02b3			 
02b3					; init file extent cache to save on slow reads 
02b3			 
02b3			;	ld hl, store_filecache 
02b3			;	ld de, 0 
02b3			;	ld hl,(de)	 
02b3			 
02b3			 
02b3 c9			    ret 
02b4			 
02b4			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
02b4			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
02b4			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
02b4			 
02b4			; INSTRUCTION SET 
02b4			; READ 0000 0011 Read data from memory array beginning at selected address 
02b4			; WRITE 0000 0010 Write data to memory array beginning at selected address 
02b4			; WREN 0000 0110 Set the write enable latch (enable write operations) 
02b4			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
02b4			; RDSR 0000 0101 Read STATUS register 
02b4			; WRSR 0000 0001 Write STATUS register 
02b4			; PE 0100 0010 Page Erase – erase one page in memory array 
02b4			; SE 1101 1000 Sector Erase – erase one sector in memory array 
02b4			; CE 1100 0111 Chip Erase – erase all sectors in memory array 
02b4			; RDID 1010 1011 Release from Deep power-down and read electronic signature 
02b4			 
02b4			; TODO send byte steam for page without setting the address for every single byte 
02b4			; TODO read byte  
02b4			 
02b4			; byte in a 
02b4			; address in hl  
02b4			se_writebyte: 
02b4			        
02b4			    ;   ld c, a 
02b4 f5			        push af 
02b5 e5			        push hl 
02b6			 
02b6			    ; initi write mode 
02b6			    ; 
02b6			    ;CS low 
02b6			 
02b6 3a 91 f9		       ld a,(spi_portbyte) 
02b9 cd 5d 02			call spi_ce_low 
02bc			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02bc d3 80		       out (storage_adata),a 
02be 32 91 f9		       ld (spi_portbyte), a 
02c1			 
02c1			    ;clock out wren instruction 
02c1			 
02c1 3e 06		    ld a, store_wren_ins 
02c3 cd 5e 01		    call spi_send_byte  
02c6			 
02c6			    ;cs high to enable write latch 
02c6			 
02c6 3a 91 f9		       ld a,(spi_portbyte) 
02c9 cd 4c 02			call spi_ce_high 
02cc			;       set SPI_CE0,a           ; TODO pass the ce bank bit mask 
02cc d3 80		       out (storage_adata),a 
02ce 32 91 f9		       ld (spi_portbyte), a 
02d1			 
02d1			;	nop 
02d1			    ; 
02d1			    ; intial write data 
02d1			    ; 
02d1			    ; cs low 
02d1			     
02d1			;       ld a,(spi_portbyte) 
02d1 cd 5d 02			call spi_ce_low 
02d4			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02d4 d3 80		       out (storage_adata),a 
02d6 32 91 f9		       ld (spi_portbyte), a 
02d9			 
02d9			    ; clock out write instruction 
02d9			     
02d9 3e 02		    ld a, store_write_ins  
02db cd 5e 01		    call spi_send_byte  
02de			 
02de			    ; clock out address (depending on address size) 
02de			     
02de e1			    pop hl 
02df 7c			    ld a,h    ; address out msb first 
02e0 cd 5e 01		    call spi_send_byte  
02e3 7d			    ld a,l 
02e4 cd 5e 01		    call spi_send_byte  
02e7			 
02e7			    ; clock out byte(s) for page 
02e7			 
02e7 f1			    pop af 
02e8 cd 5e 01		    call spi_send_byte  
02eb			 
02eb			    ; end write with ce high 
02eb 3a 91 f9		       ld a,(spi_portbyte) 
02ee			;       set SPI_CE0,a           ; TODO pass the ce bank bit mask - perhaps have a call that sets it 
02ee cd 4c 02			call spi_ce_high 
02f1 d3 80		       out (storage_adata),a 
02f3 32 91 f9		       ld (spi_portbyte), a 
02f6			 
