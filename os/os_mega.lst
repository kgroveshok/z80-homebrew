6c12 1f			            DB  11111b  
6c13 1f			            DB  11111b  
6c14 1f			            DB  11111b  
6c15 1f			            DB  11111b  
6c16 1f			            DB  11111b  
6c17 1f			            DB  11111b  
6c18 1f			            DB  11111b  
