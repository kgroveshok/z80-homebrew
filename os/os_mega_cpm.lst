182c			; Stack operations for v5 parser on wards 
182c			; * DATA stack 
182c			; * LOOP stack 
182c			; * RETURN stack 
182c			 
182c			 
182c			 
182c			FORTH_CHK_DSP_UNDER: macro 
182c				push hl 
182c				push de 
182c				ld hl,(cli_data_sp) 
182c				ld de, cli_data_stack 
182c				call cmp16 
182c				jp c, fault_dsp_under 
182c				pop de 
182c				pop hl 
182c				endm 
182c			 
182c			 
182c			FORTH_CHK_RSP_UNDER: macro 
182c				push hl 
182c				push de 
182c				ld hl,(cli_ret_sp) 
182c				ld de, cli_ret_stack 
182c				call cmp16 
182c				jp c, fault_rsp_under 
182c				pop de 
182c				pop hl 
182c				endm 
182c			 
182c			FORTH_CHK_LOOP_UNDER: macro 
182c				push hl 
182c				push de 
182c				ld hl,(cli_loop_sp) 
182c				ld de, cli_loop_stack 
182c				call cmp16 
182c				jp c, fault_loop_under 
182c				pop de 
182c				pop hl 
182c				endm 
182c			 
182c			FORTH_ERR_TOS_NOTSTR: macro 
182c				; TOSO might need more for checks when used 
182c				push af 
182c				ld a,(hl) 
182c				cp DS_TYPE_STR 
182c				jp nz, type_faultn   
182c				pop af 
182c				endm 
182c			 
182c			FORTH_ERR_TOS_NOTNUM: macro 
182c				push af 
182c				ld a,(hl) 
182c				cp DS_TYPE_INUM 
182c				jp nz, type_faultn   
182c				pop af 
182c				endm 
182c			 
