5b06				ld a, display_row_3+15 
5b06				ld de, sprompt4 
5b06				call str_at_display 
5b06			 
5b06				call update_display 
5b06			 
5b06				call cin_wait 
5b06				cp 'n' 
5b06				ret z 
5b06				cp 'N' 
5b06				ret z 
5b06			 
5b06				call delay1s 
5b06			 
5b06				ld a, (store_page+2) 
5b06				ld (store_openmaxext), a    ; save count of ext 
5b06				ld a, 1  
5b06				ld (store_openext), a    ; save count of ext 
5b06			 
