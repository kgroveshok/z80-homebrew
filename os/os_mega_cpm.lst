11c2			if MALLOC_2 
11c2			; Z80 Malloc and Free Functions 
11c2			 
11c2			; Malloc Function: 
11c2			; Input: 
11c2			;   HL: Size of block to allocate 
11c2			; Output: 
11c2			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
11c2			 
11c2			malloc: 
11c2				 
11c2			if DEBUG_FORTH_MALLOC_HIGH 
11c2			call malloc_guard_entry 
11c2			endif 
11c2			 
11c2			 
11c2			 
11c2			 
11c2					if DEBUG_FORTH_MALLOC 
11c2						DMARK "mal" 
11c2						CALLMONITOR 
11c2					endif 
11c2			    push af            ; Save AF register 
11c2			    ld a, l            ; Load low byte of size into A 
11c2			    or h               ; Check if size is zero 
11c2			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
11c2			 
11c2			    ; Allocate memory 
11c2			    ld hl, (heap_start) ; Load start of heap into HL 
11c2					if DEBUG_FORTH_MALLOC 
11c2						DMARK "ma1" 
11c2						CALLMONITOR 
11c2					endif 
11c2			    call malloc_internal ; Call internal malloc function 
11c2			    pop af             ; Restore AF register 
11c2			if DEBUG_FORTH_MALLOC_HIGH 
11c2			call malloc_guard_exit 
11c2			call malloc_guard_zerolen 
11c2			endif 
11c2			    ret                ; Return 
11c2			 
11c2			; Free Function: 
11c2			; Input: 
11c2			;   HL: Pointer to memory block to free 
11c2			; Output: 
11c2			;   None 
11c2			 
11c2			free: 
11c2			    push af            ; Save AF register 
11c2			    ld a, l            ; Load low byte of pointer into A 
11c2			    or h               ; Check if pointer is NULL 
11c2			    jp z, free_exit    ; If pointer is NULL, exit 
11c2			 
11c2			    ; Free memory 
11c2			    ld hl, (heap_start) ; Load start of heap into HL 
11c2			    call free_internal  ; Call internal free function 
11c2			    pop af             ; Restore AF register 
11c2			    ret                ; Return 
11c2			 
11c2			; Internal Malloc Function: 
11c2			; Input: 
11c2			;   HL: Size of block to allocate 
11c2			; Output: 
11c2			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
11c2			 
11c2			malloc_internal: 
11c2			    ld bc, 2           ; Number of bytes to allocate for management overhead 
11c2			    add hl, bc         ; Add management overhead to requested size 
11c2			    ex de, hl          ; Save total size in DE, and keep it in HL 
11c2					if DEBUG_FORTH_MALLOC 
11c2						DMARK "ma2" 
11c2						CALLMONITOR 
11c2					endif 
11c2			 
11c2			    ; Search for free memory block 
11c2			    ld de, (heap_end)  ; Load end of heap into DE 
11c2			    ld bc, 0           ; Initialize counter 
11c2			 
11c2					if DEBUG_FORTH_MALLOC 
11c2						DMARK "ma2" 
11c2						CALLMONITOR 
11c2					endif 
11c2			malloc_search_loop: 
11c2			    ; Check if current block is free 
11c2			    ld a, (hl)         ; Load current block's status (free or used) 
11c2			;    cp 0               ; Compare with zero (free) 
11c2				or a 
11c2			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
11c2			 
11c2			    ; Check if current block is large enough 
11c2			    ld a, (hl+1)       ; Load high byte of block size 
11c2			    cp l               ; Compare with low byte of requested size 
11c2			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
11c2			 
11c2			    ld a, (hl+2)       ; Load low byte of block size 
11c2			    cp h               ; Compare with high byte of requested size 
11c2			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
11c2			 
11c2			    ; Mark block as used 
11c2			    ld (hl), 0xFF      ; Set status byte to indicate used block 
11c2			 
11c2			    ; Calculate remaining space in block 
11c2			    ld bc, 0           ; Clear BC 
11c2			    add hl, bc         ; Increment HL to point to start of data block 
11c2			    add hl, de         ; HL = HL + DE (total size) 
11c2			    ld bc, 1           ; Number of bytes to allocate for management overhead 
11c2			    add hl, bc         ; Add management overhead to start of data block 
11c2			 
11c2			    ; Save pointer to allocated block in HL 
11c2			if DEBUG_FORTH_MALLOC_HIGH 
11c2						DMARK "ma5" 
11c2			call malloc_guard_exit 
11c2			call malloc_guard_zerolen 
11c2			endif 
11c2			    ret 
11c2			 
11c2			malloc_skip_block_check: 
11c2			    ; Move to the next block 
11c2			    ld bc, 3           ; Size of management overhead 
11c2			    add hl, bc         ; Move to the next block 
11c2			    inc de             ; Increment counter 
11c2			 
11c2			    ; Check if we have reached the end of heap 
11c2			    ld a, e            ; Load low byte of heap end address 
11c2			    cp (hl)            ; Compare with low byte of current address 
11c2			    jr nz, malloc_search_loop  ; If not equal, continue searching 
11c2			    ld a, d            ; Load high byte of heap end address 
11c2			;    cp 0               ; Check if it's zero (end of memory) 
11c2				or a 
11c2			    jr nz, malloc_search_loop  ; If not zero, continue searching 
11c2			 
11c2			    ; If we reached here, allocation failed 
11c2			    xor a              ; Set result to NULL 
11c2			if DEBUG_FORTH_MALLOC_HIGH 
11c2						DMARK "ma6" 
11c2			call malloc_guard_exit 
11c2			call malloc_guard_zerolen 
11c2			endif 
11c2			    ret 
11c2			malloc_exit: 
11c2			if DEBUG_FORTH_MALLOC_HIGH 
11c2						DMARK "ma7" 
11c2			call malloc_guard_exit 
11c2			call malloc_guard_zerolen 
11c2			endif 
11c2			    ret 
11c2			 
11c2			; Internal Free Function: 
11c2			; Input: 
11c2			;   HL: Pointer to memory block to free 
11c2			; Output: 
11c2			;   None 
11c2			 
11c2			free_internal: 
11c2			    ld de, (heap_start) ; Load start of heap into DE 
11c2			    ld bc, 0            ; Initialize counter 
11c2			 
11c2			free_search_loop: 
11c2			    ; Check if current block contains the pointer 
11c2			    ld a, l             ; Load low byte of pointer 
11c2			    cp (hl+1)           ; Compare with high byte of current block's address 
11c2			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
11c2			    ld a, h             ; Load high byte of pointer 
11c2			    cp (hl+2)           ; Compare with low byte of current block's address 
11c2			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
11c2			 
11c2			    ; Mark block as free 
11c2			    ld (hl), 0          ; Set status byte to indicate free block 
11c2			    ret                 ; Return 
11c2			 
11c2			free_skip_block_check: 
11c2			    ; Move to the next block 
11c2			    ld bc, 3            ; Size of management overhead 
11c2			    add hl, bc          ; Move to the next block 
11c2			    inc de              ; Increment counter 
11c2			 
11c2			    ; Check if we have reached the end of heap 
11c2			    ld a, e             ; Load low byte of heap end address 
11c2			    cp (hl)             ; Compare with low byte of current address 
11c2			    jr nz, free_search_loop  ; If not equal, continue searching 
11c2			    ld a, d             ; Load high byte of heap end address 
11c2			;    cp 0                ; Check if it's zero (end of memory) 
11c2				or a 
11c2			    jr nz, free_search_loop  ; If not zero, continue searching 
11c2			 
11c2			    ; If we reached here, pointer is not found in heap 
11c2			    ret 
11c2			 
11c2			free_exit: 
11c2			    ret                 ; Return 
11c2			 
11c2			; Define heap start and end addresses 
11c2			;heap_start:    .dw 0xC000   ; Start of heap 
11c2			;heap_end:      .dw 0xE000   ; End of heap 
11c2			 
11c2			endif 
