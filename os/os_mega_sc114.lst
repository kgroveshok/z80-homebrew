8a55			addatohl: 
8a55 85			    add   a, l    ; A = A+L 
8a56 6f			    ld    l, a    ; L = A+L 
8a57 8c			    adc   a, h    ; A = A+L+H+carry 
8a58 95			    sub   l       ; A = H+carry 
8a59 67			    ld    h, a    ; H = H+carry 
8a5a c9			ret 
