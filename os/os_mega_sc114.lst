bc0d			.VARS: 
bc0d				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
bc0d 77				db WORD_SYS_CORE+99             
bc0e 75 bc			dw .V0            
bc10 04				db 3 + 1 
bc11 .. 00			db "VAR",0              
bc15				endm 
# End of macro CWHEAD
bc15			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bc15			; | 
bc15			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bc15			; | |  
bc15			; | | e.g. 
bc15			; | |         #30 a var ! 
bc15			; | |         a var @ . 
bc15			; | |   
bc15			; | |     Displays the number 30 
bc15			; | | 
bc15			; | | Each variable pointer is a word so can use for any words that use that:  
bc15			; | |  
bc15			; | | e.g. 
bc15			; | |  
bc15			; | |         #30 a var 2! 
bc15			; | |         a var 2@ . 
bc15			; | |   
bc15			; | |     Displays the number 30 
bc15			; | |  
bc15			; | | > [!NOTE]  
bc15			; ! | > If a full string is passed then only the first char is looked at 
bc15			; | | > Any other char could exceed bounds checks!  
bc15			; | | > 
bc15			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bc15			 
bc15					if DEBUG_FORTH_WORDS_KEY 
bc15						DMARK "VAR" 
bc15				if DEMARK_VERSION = 1  
bc15 e5					push hl  
bc16 21 1e bc				ld hl, .dmark  
bc19 22 60 ee				ld (debug_mark), hl  
bc1c				endif  
bc1c				if DEMARK_VERSION = 0  
bc1c					push af  
bc1c					ld a, (.dmark)  
bc1c					ld (debug_mark),a  
bc1c					ld a, (.dmark+1)  
bc1c					ld (debug_mark+1),a  
bc1c					ld a, (.dmark+2)  
bc1c					ld (debug_mark+2),a  
bc1c				endif  
bc1c 18 04			jr .pastdmark  
bc1e ..			.dmark: db "VAR"  
bc21				if DEMARK_VERSION = 1  
bc21 00					db 0  
bc22				endif  
bc22				if DEMARK_VERSION = 1  
bc22 e1			.pastdmark: pop hl  
bc23				endif  
bc23				if DEMARK_VERSION = 0  
bc23			.pastdmark: pop af  
bc23				endif  
bc23			endm  
# End of macro DMARK
bc23						CALLMONITOR 
bc23				if BASE_CPM=1  
bc23					call debug_vector  
bc23				endif  
bc23				if BASE_KEV=1  
bc23					rst 8  
bc23				endif  
bc23				endm  
# End of macro CALLMONITOR
bc23					endif 
bc23			 
bc23					FORTH_DSP_VALUEHL 
bc23				if BASE_CPM=1 
bc23				call macro_dsp_valuehl 
bc23				endif 
bc23				if BASE_KEV=1 
bc23					rst $18 
bc23				endif 
bc23				endm 
# End of macro FORTH_DSP_VALUEHL
