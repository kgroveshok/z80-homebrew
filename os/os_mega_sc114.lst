8053			; Macro to make adding debug marks easier  
8053			  
8053			  
8053			DEMARK_VERSION: equ 1  
8053			  
8053			DMARK: macro str  
8053			  
8053				if DEMARK_VERSION = 1  
8053					push hl  
8053					ld hl, .dmark  
8053					ld (debug_mark), hl  
8053				endif  
8053			  
8053			  
8053				if DEMARK_VERSION = 0  
8053					push af  
8053					ld a, (.dmark)  
8053					ld (debug_mark),a  
8053					ld a, (.dmark+1)  
8053					ld (debug_mark+1),a  
8053					ld a, (.dmark+2)  
8053					ld (debug_mark+2),a  
8053			  
8053				endif  
8053			  
8053				jr .pastdmark  
8053			.dmark: db str  
8053			  
8053				if DEMARK_VERSION = 1  
8053			.pastdmark: pop hl  
8053				endif  
8053			  
8053				if DEMARK_VERSION = 0  
8053			.pastdmark: pop af  
8053				endif  
8053			  
8053			endm  
