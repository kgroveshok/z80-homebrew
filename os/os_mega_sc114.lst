96be e5				push hl 
96bf d5				push de 
96c0 2a e5 e9			ld hl,(cli_ret_sp) 
96c3 11 9f e9			ld de, cli_ret_stack 
96c6 cd 21 8a			call cmp16 
96c9 da b3 cc			jp c, fault_rsp_under 
96cc d1				pop de 
96cd e1				pop hl 
96ce				endm 
