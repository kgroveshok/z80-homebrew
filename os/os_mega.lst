029a				include "firmware_seeprom.asm"  
029a			; 
029a			; persisent storage interface via microchip serial eeprom 
029a			 
029a			; port a pio 2 
029a			; pa 7 - si 
029a			; pa 6 - sclk  
029a			; pa 5 - so 
029a			; pa 4 - cs 
029a			; pa 3 - cs 
029a			; pa 2 - cs 
029a			; pa 1 - cs 
029a			; pa 0 - cs 
029a			; 
029a			; TODO get block 
029a			; TODO save block 
029a			; TODO load file 
029a			; TODO save file 
029a			; TODO get dir  
029a			 
029a			;  
029a			storage_adata: equ Device_C    ; device c port a - onboard storage 
029a			storage_actl: equ Device_C+2     ; device c port a 
029a			storage_bdata: equ Device_C+1    ; device c port b - ext storage cart 
029a			storage_bctl: equ Device_C+3     ; device c port b 
029a			 
029a			 
029a			; TODO move these to hardware driver file 
029a			 
029a			;STORE_BLOCK_PHY:   equ 64    ; physical block size on storage   64byte on 256k eeprom 
029a			;STORE_DEVICE_MAXBLOCKS:  equ  512 ; how many blocks are there on this storage device 
029a			; storage bank file system format 
029a			; 
029a			; first page of bank: 
029a			; 	addr 0 - status check 
029a			;       addr 1 - write protect flag 
029a			;       addr 2 - zero if all data is held on this device. >0 - next device number (not used right now) 
029a			;       addr 3 - last file id (to save on scanning for spare file id). or could have bit mask of file ids in use????  
029a			;         TODO see if scanning whole of for available next file id is fast enough 
029a			;	addr 4 > zero term string of bank label 
029a			; 
029a			;        
029a			;  
029a			; first page of any file: 
029a			;      byte 0 - file id  
029a			;      byte 1-17 - fixed file name  
029a			;      byte 18-end of page - extra meta data tba (date? description? keywords?) 
029a			; 
029a			; other pages of any file: 
029a			;      byte 0 - file id 
029a			;      byte 1> - file data 
029a			; 
029a			; TODO depending on how long it takes to load a file in if scanning the whole bank for the file id, could speed it up by having last file page flag??? high bit? that would max 127 files 
029a			;  
029a			; TODO need a bank format which places a 0 in each of the first byte of every page and updates the meta in page 0 
029a			 
029a			 
029a			;storage_so_bit: 5 
029a			;storage_si_bit: 7 
029a			;storage_sclk_bit: 6 
029a			  
029a			 
029a			; init storage pio 
029a			 
029a			storage_init: 
029a			 
029a			 
029a					; set default SPI clk pulse time as disabled 
029a			 
029a 3e 00				ld a, 0 
029c 32 94 f9				ld (spi_clktime), a 
029f			 
029f					; init hardware 
029f			 
029f 3e cf		            LD   A, 11001111b 
02a1 d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
02a3 3e 00		            LD   A, 00000000b 
02a5 cb f7			set SPI_DO,a 
02a7			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
02a7 d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
02a9			 
02a9 3e cf		            LD   A, 11001111b 
02ab d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
02ad 3e 00		            LD   A, 00000000b 
02af d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
02b1			 
02b1				; set all external spi devices off  
02b1 3e ff			ld a, 255 
02b3 32 90 f9			ld (spi_device), a 
02b6 32 93 f9			ld (spi_cartdev), a 
02b9			 
02b9					; ensure the spi bus is in a default stable state 
02b9 cd 41 01				call se_stable_spi 
02bc			 
02bc			; TODO scan spi bus and gather which storage banks are present 
02bc			 
02bc			; populate store_bank_active  
02bc			; for each ce line activate and attempt to write first byte of bank and read back 
02bc			; if zero is returned then bank is empty 
02bc			;   
02bc			; 
02bc			 
02bc					; init file extent cache to save on slow reads 
02bc			 
02bc			;	ld hl, store_filecache 
02bc			;	ld de, 0 
02bc			;	ld hl,(de)	 
02bc			 
02bc			 
02bc c9			    ret 
02bd			 
02bd			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
02bd			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
02bd			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
02bd			 
02bd			; INSTRUCTION SET 
02bd			; READ 0000 0011 Read data from memory array beginning at selected address 
02bd			; WRITE 0000 0010 Write data to memory array beginning at selected address 
02bd			; WREN 0000 0110 Set the write enable latch (enable write operations) 
02bd			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
02bd			; RDSR 0000 0101 Read STATUS register 
02bd			; WRSR 0000 0001 Write STATUS register 
02bd			; PE 0100 0010 Page Erase – erase one page in memory array 
02bd			; SE 1101 1000 Sector Erase – erase one sector in memory array 
02bd			; CE 1100 0111 Chip Erase – erase all sectors in memory array 
02bd			; RDID 1010 1011 Release from Deep power-down and read electronic signature 
02bd			 
02bd			; TODO send byte steam for page without setting the address for every single byte 
02bd			; TODO read byte  
02bd			 
02bd			; byte in a 
02bd			; address in hl  
02bd			se_writebyte: 
02bd			        
02bd			    ;   ld c, a 
02bd f5			        push af 
02be e5			        push hl 
02bf			 
02bf			    ; initi write mode 
02bf			    ; 
02bf			    ;CS low 
02bf			 
02bf 3a 91 f9		       ld a,(spi_portbyte) 
02c2 cd 66 02			call spi_ce_low 
02c5			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02c5 d3 80		       out (storage_adata),a 
02c7 32 91 f9		       ld (spi_portbyte), a 
02ca			 
02ca			    ;clock out wren instruction 
02ca			 
02ca 3e 06		    ld a, store_wren_ins 
02cc cd 67 01		    call spi_send_byte  
02cf			 
02cf			    ;cs high to enable write latch 
02cf			 
02cf 3a 91 f9		       ld a,(spi_portbyte) 
02d2 cd 55 02			call spi_ce_high 
02d5			;       set SPI_CE0,a           ; TODO pass the ce bank bit mask 
02d5 d3 80		       out (storage_adata),a 
02d7 32 91 f9		       ld (spi_portbyte), a 
02da			 
02da			;	nop 
02da			    ; 
02da			    ; intial write data 
02da			    ; 
02da			    ; cs low 
02da			     
02da			;       ld a,(spi_portbyte) 
02da cd 66 02			call spi_ce_low 
02dd			       ;res SPI_CE0,a           ; TODO pass the ce bank bit mask 
02dd d3 80		       out (storage_adata),a 
02df 32 91 f9		       ld (spi_portbyte), a 
02e2			 
02e2			    ; clock out write instruction 
02e2			     
02e2 3e 02		    ld a, store_write_ins  
02e4 cd 67 01		    call spi_send_byte  
02e7			 
