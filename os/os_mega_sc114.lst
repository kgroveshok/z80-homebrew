a7f8					push af  
a7f8					ld a, (.dmark)  
a7f8					ld (debug_mark),a  
a7f8					ld a, (.dmark+1)  
a7f8					ld (debug_mark+1),a  
a7f8					ld a, (.dmark+2)  
a7f8					ld (debug_mark+2),a  
a7f8				endif  
a7f8 18 04			jr .pastdmark  
a7fa ..			.dmark: db "SCR"  
a7fd				if DEMARK_VERSION = 1  
a7fd 00					db 0  
a7fe				endif  
a7fe				if DEMARK_VERSION = 1  
a7fe e1			.pastdmark: pop hl  
a7ff				endif  
a7ff				if DEMARK_VERSION = 0  
a7ff			.pastdmark: pop af  
a7ff				endif  
a7ff			endm  
# End of macro DMARK
