cad7			 
cad7			.SESEL: 
cad7				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
cad7			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
cad7			; | | Zero is disabled storage. 
cad7					if DEBUG_FORTH_WORDS_KEY 
cad7						DMARK "BN?" 
cad7						CALLMONITOR 
cad7					endif 
cad7					ld a, (spi_device_id) 
cad7					sub '0' 
cad7					ld h, 0 
cad7					ld l, a 
cad7					call forth_push_numhl 
cad7					NEXTW 
cad7			.SESELS: 
cad7				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
cad7			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
cad7			; | | Set to zero to disable storage. 
cad7					if DEBUG_FORTH_WORDS_KEY 
cad7						DMARK "BNK" 
cad7						CALLMONITOR 
cad7					endif 
cad7			 
cad7					ld a, 255 
cad7					ld (spi_cartdev), a 
cad7			 
cad7					; get bank 
cad7			 
cad7					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cad7			 
cad7			;		push hl 
cad7			 
cad7					; destroy value TOS 
cad7			 
cad7					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cad7			 
cad7					; one value on hl get other one back 
cad7			 
cad7			;		pop hl 
cad7			 
cad7			 
cad7					ld c, SPI_CE_HIGH 
cad7					ld b, '0'    ; human readable bank number 
cad7			 
cad7					ld a, l 
cad7			 
cad7					if DEBUG_FORTH_WORDS 
cad7						DMARK "BNK" 
cad7						CALLMONITOR 
cad7					endif 
cad7			 
cad7					; active low 
cad7			 
cad7			;		cp 0 
cad7					or a 
cad7					jr z, .bset 
cad7					cp 1 
cad7					jr nz, .b2 
cad7					res 0, c 
cad7					ld b, '1'    ; human readable bank number 
cad7			.b2:		cp 2 
cad7					jr nz, .b3 
cad7					res 1, c 
cad7					ld b, '2'    ; human readable bank number 
cad7			.b3:		cp 3 
cad7					jr nz, .b4 
cad7					res 2, c 
cad7					ld b, '3'    ; human readable bank number 
cad7			.b4:		cp 4 
cad7					jr nz, .b5 
cad7					res 3, c 
cad7					ld b, '4'    ; human readable bank number 
cad7			.b5:		cp 5 
cad7					jr nz, .bset 
cad7					res 4, c 
cad7					ld b, '5'    ; human readable bank number 
cad7			 
cad7			.bset: 
cad7					ld a, c 
cad7					ld (spi_device),a 
cad7					ld a, b 
cad7					ld (spi_device_id),a 
cad7					if DEBUG_FORTH_WORDS 
cad7						DMARK "BN2" 
cad7						CALLMONITOR 
cad7					endif 
cad7			 
cad7					; set default SPI clk pulse time as disabled for BANK use 
cad7			 
cad7					ld a, 0 
cad7					ld (spi_clktime), a 
cad7			 
cad7					NEXTW 
cad7			 
cad7			.CARTDEV: 
cad7				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
cad7			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
cad7			; | | Set to zero to disable devices. 
cad7					if DEBUG_FORTH_WORDS_KEY 
cad7						DMARK "CDV" 
cad7						CALLMONITOR 
cad7					endif 
cad7			 
cad7					; disable se storage bank selection 
cad7			 
cad7					ld a, SPI_CE_HIGH		; ce high 
cad7					ld (spi_device), a 
cad7			 
cad7					; get bank 
cad7			 
cad7					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cad7			 
cad7			;		push hl 
cad7			 
cad7					; destroy value TOS 
cad7			 
cad7					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cad7			 
cad7					; one value on hl get other one back 
cad7			 
cad7			;		pop hl 
cad7			 
cad7					; active low 
cad7			 
cad7					ld c, 255 
cad7			 
cad7					ld a, l 
cad7					if DEBUG_FORTH_WORDS 
cad7						DMARK "CDV" 
cad7						CALLMONITOR 
cad7					endif 
cad7			;		cp 0 
cad7					or a 
cad7					jr z, .cset 
cad7					cp 1 
cad7					jr nz, .c2 
cad7					res 0, c 
cad7			.c2:		cp 2 
cad7					jr nz, .c3 
cad7					res 1, c 
cad7			.c3:		cp 3 
cad7					jr nz, .c4 
cad7					res 2, c 
cad7			.c4:		cp 4 
cad7					jr nz, .c5 
cad7					res 3, c 
cad7			.c5:		cp 5 
cad7					jr nz, .c6 
cad7					res 4, c 
cad7			.c6:		cp 6 
cad7					jr nz, .c7 
cad7					res 5, c 
cad7			.c7:		cp 7 
cad7					jr nz, .c8 
cad7					res 6, c 
cad7			.c8:		cp 8 
cad7					jr nz, .cset 
cad7					res 7, c 
cad7			.cset:		ld a, c 
cad7					ld (spi_cartdev),a 
cad7			 
cad7					if DEBUG_FORTH_WORDS 
cad7						DMARK "CD2" 
cad7						CALLMONITOR 
cad7					endif 
cad7			 
cad7					; set default SPI clk pulse time as 10ms for CARTDEV use 
cad7			 
cad7					ld a, $0a 
cad7					ld (spi_clktime), a 
cad7					NEXTW 
cad7			endif 
cad7			 
cad7			.ENDDEVICE: 
cad7			; eof 
