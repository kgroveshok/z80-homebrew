67af			  
67af			  
67af			; take current custor pos in de (d=row,e=col) and return a pointer to the frame buffer  
67af			  
67af			curptr:  
67af c5				push bc  
67b0 21 e1 fc			ld hl, display_fb0  
67b3			cpr:	  
67b3				; loop for cursor whole row  
67b3 0e 28			ld c, display_cols  
67b5 23			cpr1:	inc hl  
67b6 0d				dec c  
67b7 20 fc			jr nz, cpr1  
67b9 05				dec b  
67ba 20 f7			jr nz, cpr  
67bc			  
67bc				; add col	  
67bc			  
67bc 23			cpr2:	inc hl  
67bd 1d				dec e  
67be 20 fc			jr nz, cpr2  
67c0			  
67c0 c1				pop bc  
67c1 c9				ret  
67c2				  
