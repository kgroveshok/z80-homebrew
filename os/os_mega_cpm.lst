0f52			 
0f52			;------------------------------------------------------------------------------ 
0f52			;     heap_init                                                               : 
0f52			;                                                                             : 
0f52			; Description                                                                 : 
0f52			;     Initialise the heap and make it ready for malloc and free operations.   : 
0f52			;                                                                             : 
0f52			;     The heap is maintained as a linked list, starting with an initial       : 
0f52			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
0f52			;     the first free block in the heap. Each block then points to the next    : 
0f52			;     free block within the heap, and the free list ends at the first block   : 
0f52			;     with a null pointer to the next free block.                             : 
0f52			;                                                                             : 
0f52			; Parameters                                                                  : 
0f52			;     Inputs are compile-time only. Two defines which specify the starting    : 
0f52			;     address of the heap and its size are required, along with a memory      : 
0f52			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
0f52			;     principally stores a pointer to the first free block in the heap.       : 
0f52			;                                                                             : 
0f52			; Returns                                                                     : 
0f52			;     Nothing                                                                 : 
0f52			;------------------------------------------------------------------------------ 
0f52			heap_init: 
0f52 e5			      push  HL 
0f53			 
0f53			      ; Initialise free list struct 
0f53 21 fb 57		      ld    HL, heap_start 
0f56 22 f6 57		      ld    (free_list), HL 
0f59 21 00 00		      ld    HL, 0 
0f5c 22 f8 57		      ld    (free_list+2), HL 
0f5f			 
0f5f			      ; Insert first free block at bottom of heap, consumes entire heap 
0f5f 21 8b e2		      ld    HL, heap_start+heap_size-4 
0f62 22 fb 57		      ld    (heap_start), HL        ; Next block (end of free list) 
0f65 21 90 8a		      ld    HL, heap_size-4 
0f68 22 fd 57		      ld    (heap_start+2), HL      ; Block size 
0f6b			 
0f6b			      ; Insert end of free list block at top of heap - two null words will 
0f6b			      ; terminate the free list 
0f6b 21 00 00		      ld    HL, 0 
0f6e 22 8d e2		      ld    (heap_start+heap_size-2), HL 
0f71 22 8b e2		      ld    (heap_start+heap_size-4), HL 
0f74			 
0f74 e1			      pop   HL 
0f75			 
0f75 c9			      ret 
0f76			 
0f76			 
0f76			;------------------------------------------------------------------------------ 
0f76			;     malloc                                                                  : 
0f76			;                                                                             : 
0f76			; Description                                                                 : 
0f76			;     Allocates the wanted space from the heap and returns the address of the : 
0f76			;     first useable byte of the allocation.                                   : 
0f76			;                                                                             : 
0f76			;     Allocations can happen in one of two ways:                              : 
0f76			;                                                                             : 
0f76			;     1. A free block may be found which is the exact size wanted. In this    : 
0f76			;        case the block is removed from the free list and retuedn to the      : 
0f76			;        caller.                                                              : 
0f76			;     2. A free block may be found which is larger than the size wanted. In   : 
0f76			;        this case, the larger block is split into two. The first portion of  : 
0f76			;        this block will become the requested space by the malloc call and    : 
0f76			;        is returned to the caller. The second portion becomes a new free     : 
0f76			;        block, and the free list is adjusted to maintain continuity via this : 
0f76			;        newly created block.                                                 : 
0f76			;                                                                             : 
0f76			;     malloc does not set any initial value in the allocated space, the       : 
0f76			;     caller is required to do this as required.                              : 
0f76			;                                                                             : 
0f76			;     This implementation of malloc uses the stack exclusively, and is        : 
0f76			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
0f76			;     advisable to disable interrupts before calling malloc, and recommended  : 
0f76			;     to avoid the use of malloc inside ISRs in general.                      : 
0f76			;                                                                             : 
0f76			;     NOTE: heap_init must be called before malloc and free can be used.      : 
0f76			;                                                                             : 
0f76			; Parameters                                                                  : 
0f76			;     HL  Number of bytes wanted                                              : 
0f76			;                                                                             : 
0f76			; Returns                                                                     : 
0f76			;     HL  Address of the first useable byte of the allocation                 : 
0f76			;                                                                             : 
0f76			; Flags                                                                       : 
0f76			;     Z   Set if the allocation did not succeed, clear otherwise              : 
0f76			;                                                                             : 
0f76			; Stack frame                                                                 : 
0f76			;       |             |                                                       : 
0f76			;       +-------------+                                                       : 
0f76			;       |     BC      |                                                       : 
0f76			;       +-------------+                                                       : 
0f76			;       |     DE      |                                                       : 
0f76			;       +-------------+                                                       : 
0f76			;       |     IX      |                                                       : 
0f76			;       +-------------+                                                       : 
0f76			;       |  prev_free  |                                                       : 
0f76			;   +4  +-------------+                                                       : 
0f76			;       |  this_free  |                                                       : 
0f76			;   +2  +-------------+                                                       : 
0f76			;       |  next_free  |                                                       : 
0f76			;   +0  +-------------+                                                       : 
0f76			;       |             |                                                       : 
0f76			;                                                                             : 
0f76			;------------------------------------------------------------------------------ 
0f76			 
0f76			 
0f76			;malloc: 
0f76			; 
0f76			;	SAVESP ON 1 
0f76			; 
0f76			;	call malloc_code 
0f76			; 
0f76			;	CHECKSP ON 1 
0f76			;	ret 
0f76			 
0f76			 
0f76			malloc: 
0f76 c5			      push  BC 
0f77 d5			      push  DE 
0f78 dd e5		      push  IX 
0f7a			if DEBUG_FORTH_MALLOC_HIGH 
0f7a			call malloc_guard_entry 
0f7a			endif 
0f7a			 
0f7a					if DEBUG_FORTH_MALLOC 
0f7a						DMARK "mal" 
0f7a						CALLMONITOR 
0f7a					endif 
0f7a 7c			      ld    A, H                    ; Exit if no space requested 
0f7b b5			      or    L 
0f7c ca 3b 10		      jp    Z, malloc_early_exit 
0f7f			 
0f7f			;inc hl 
0f7f			;inc hl 
0f7f			;inc hl 
0f7f			; 
0f7f			;inc hl 
0f7f			;inc hl 
