8fcd cd 4f 87			call delay1s  
8fd0 cd 4f 87			call delay1s  
8fd3 cd 4f 87			call delay1s  
8fd6 cd 4f 87			call delay1s  
8fd9 cd 4f 87			call delay1s  
8fdc			endif 
8fdc c9				ret 
8fdd			 
8fdd			; output a high period 
8fdd			 
8fdd			tape_high: 
