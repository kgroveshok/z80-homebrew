12c4			 
12c4			; setup default tape params 
12c4			tape_init:     
12c4 3e 00			ld a, Device_A 
12c6 32 8e f9			ld (tape_port), a 
12c9			 
12c9 3e fa			ld a, 250 
12cb 32 83 f9			ld (tape_tm_gap), a 
12ce			 
12ce 3e 01			ld a, 1 
12d0 32 82 f9			ld (tape_tm_freq), a 
12d3			 
12d3 21 32 00			ld hl, 50 
12d6 22 80 f9			ld (tape_tm_high), hl 
12d9			 
12d9 21 0a 00			ld hl, 10 
12dc 22 7e f9			ld (tape_tm_low), hl 
12df c9				ret 
12e0			 
12e0			; support routinues for tape 
12e0			 
12e0			 
12e0			; Tape Output 
12e0			 
12e0			; osciallate the pin for the required duration 
12e0			 
12e0			tape_osc:  
12e0				; hl has the number of iterations 
12e0				; c = port number 
12e0				; d = bus data 
12e0				 
12e0 ed 51			out (c), d 
12e2 3a 82 f9			ld a, (tape_tm_freq) 
12e5 fe 00			cp 0 
12e7 28 03			jr z, .fski 
12e9			;	ld a, 1 
12e9 cd 53 0a			call aDelayInMS 
12ec			;	ld b, a 
12ec			;.flo:	bit 0,a 
12ec			;	bit 0,a 
12ec			;	bit 0,a 
12ec			;	djnz .flo 
12ec				 
12ec			.fski:	 
12ec 2b				dec hl 
12ed cd 88 0d			call ishlzero 
12f0 20 ee			jr nz, tape_osc 
12f2				 
12f2 c9				ret 
12f3			 
12f3			; output a gap period 
12f3			tape_gap:  
12f3 3a 83 f9			ld a, (tape_tm_gap) 
12f6 cd 53 0a			call aDelayInMS 
12f9			 
12f9			if DEBUG_TAPE 
12f9 cd 6e 0a			call delay1s  
12fc cd 6e 0a			call delay1s  
12ff cd 6e 0a			call delay1s  
1302 cd 6e 0a			call delay1s  
1305 cd 6e 0a			call delay1s  
1308 cd 6e 0a			call delay1s  
130b			endif 
130b c9				ret 
130c			 
130c			; output a high period 
130c			 
130c			tape_high: 
130c 3a 8e f9			ld a, (tape_port) 
130f 4f				ld c, a 
1310 16 ff			ld d, 255 
1312 2a 80 f9			ld hl, (tape_tm_high) 
1315 cd e0 12			call tape_osc 
1318 c9				 ret 
1319			 
1319			; output a low period 
1319			 
1319			tape_low:  
1319			 
1319 3a 8e f9			ld a, (tape_port) 
131c 4f				ld c, a 
131d 16 ff			ld d, 255 
131f 2a 7e f9			ld hl, (tape_tm_low) 
1322 cd e0 12			call tape_osc 
1325 c9				 ret 
1326			 
1326			; end of save marker 
1326			 
1326			tape_end: 
1326 3e ff			ld a, 255 
1328 cd 3f 13			call tape_byte_out 
132b cd f3 12			call tape_gap 
132e			 
132e 3e ff			ld a, 255 
1330 cd 3f 13			call tape_byte_out 
1333 cd f3 12			call tape_gap 
1336 3e ff			ld a, 255 
1338 cd 3f 13			call tape_byte_out 
133b cd f3 12			call tape_gap 
133e c9				 ret 
133f			 
133f			; output an encoded byte 
133f			 
133f			tape_byte_out: 
133f				; a = byte to output 
133f 06 08			ld b, 8 
1341 4f				ld c, a 
1342			.tbo:    
1342 c5				push bc 
1343 cb 79			bit 7, c 
1345 28 05			jr z, .tbol 
1347 cd 0c 13			call tape_high 
134a 18 03			jr .tbn 
134c			.tbol: 
134c cd 19 13			call tape_low 
134f			.tbn: 
134f cd f3 12			call tape_gap 
1352 c1				pop bc 
1353 cb 21			sla c 
1355 10 eb			djnz .tbo 
1357			 
1357			 
1357 c9				 ret 
1358			 
1358			; output a string 
1358			 
1358			; hl - pointer to string 
