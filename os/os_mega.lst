4d47			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
4d47			; | 
4d47			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
4d47			; | |  
4d47			; | | e.g. 
4d47			; | |         #30 a var ! 
4d47			; | |         a var @ . 
4d47			; | |   
4d47			; | |     Displays the number 30 
4d47			; | | 
4d47			; | | Each variable pointer is a word so can use for any words that use that:  
4d47			; | |  
4d47			; | | e.g. 
4d47			; | |  
4d47			; | |         #30 a var 2! 
4d47			; | |         a var 2@ . 
4d47			; | |   
4d47			; | |     Displays the number 30 
4d47			; | |  
4d47			; | | > [!NOTE]  
4d47			; ! | > If a full string is passed then only the first char is looked at 
4d47			; | | > Any other char could exceed bounds checks!  
4d47			; | | > 
4d47			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
4d47			 
4d47					if DEBUG_FORTH_WORDS_KEY 
4d47						DMARK "VAR" 
4d47				if DEMARK_VERSION = 1  
4d47 e5					push hl  
