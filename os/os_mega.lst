110a			;------------------------------------------------------------------------------ 
110a			;     heap_init                                                               : 
110a			;                                                                             : 
110a			; Description                                                                 : 
110a			;     Initialise the heap and make it ready for malloc and free operations.   : 
110a			;                                                                             : 
110a			;     The heap is maintained as a linked list, starting with an initial       : 
110a			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
110a			;     the first free block in the heap. Each block then points to the next    : 
110a			;     free block within the heap, and the free list ends at the first block   : 
110a			;     with a null pointer to the next free block.                             : 
110a			;                                                                             : 
110a			; Parameters                                                                  : 
110a			;     Inputs are compile-time only. Two defines which specify the starting    : 
110a			;     address of the heap and its size are required, along with a memory      : 
110a			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
110a			;     principally stores a pointer to the first free block in the heap.       : 
110a			;                                                                             : 
110a			; Returns                                                                     : 
110a			;     Nothing                                                                 : 
110a			;------------------------------------------------------------------------------ 
110a			heap_init: 
110a e5			      push  HL 
110b			 
110b			      ; Initialise free list struct 
110b 21 0e 80		      ld    HL, heap_start 
110e 22 0a 80		      ld    (free_list), HL 
1111 21 00 00		      ld    HL, 0 
1114 22 0c 80		      ld    (free_list+2), HL 
1117			 
1117			      ; Insert first free block at bottom of heap, consumes entire heap 
1117 21 b4 f0		      ld    HL, heap_start+heap_size-4 
111a 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
111d 21 a6 70		      ld    HL, heap_size-4 
1120 22 10 80		      ld    (heap_start+2), HL      ; Block size 
1123			 
1123			      ; Insert end of free list block at top of heap - two null words will 
1123			      ; terminate the free list 
1123 21 00 00		      ld    HL, 0 
1126 22 b6 f0		      ld    (heap_start+heap_size-2), HL 
1129 22 b4 f0		      ld    (heap_start+heap_size-4), HL 
112c			 
112c e1			      pop   HL 
112d			 
112d c9			      ret 
112e			 
112e			 
112e			;------------------------------------------------------------------------------ 
112e			;     malloc                                                                  : 
112e			;                                                                             : 
112e			; Description                                                                 : 
112e			;     Allocates the wanted space from the heap and returns the address of the : 
112e			;     first useable byte of the allocation.                                   : 
112e			;                                                                             : 
112e			;     Allocations can happen in one of two ways:                              : 
112e			;                                                                             : 
112e			;     1. A free block may be found which is the exact size wanted. In this    : 
112e			;        case the block is removed from the free list and retuedn to the      : 
112e			;        caller.                                                              : 
112e			;     2. A free block may be found which is larger than the size wanted. In   : 
112e			;        this case, the larger block is split into two. The first portion of  : 
112e			;        this block will become the requested space by the malloc call and    : 
112e			;        is returned to the caller. The second portion becomes a new free     : 
112e			;        block, and the free list is adjusted to maintain continuity via this : 
112e			;        newly created block.                                                 : 
112e			;                                                                             : 
112e			;     malloc does not set any initial value in the allocated space, the       : 
112e			;     caller is required to do this as required.                              : 
112e			;                                                                             : 
112e			;     This implementation of malloc uses the stack exclusively, and is        : 
112e			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
112e			;     advisable to disable interrupts before calling malloc, and recommended  : 
112e			;     to avoid the use of malloc inside ISRs in general.                      : 
112e			;                                                                             : 
112e			;     NOTE: heap_init must be called before malloc and free can be used.      : 
112e			;                                                                             : 
112e			; Parameters                                                                  : 
112e			;     HL  Number of bytes wanted                                              : 
112e			;                                                                             : 
112e			; Returns                                                                     : 
112e			;     HL  Address of the first useable byte of the allocation                 : 
112e			;                                                                             : 
112e			; Flags                                                                       : 
112e			;     Z   Set if the allocation did not succeed, clear otherwise              : 
112e			;                                                                             : 
112e			; Stack frame                                                                 : 
112e			;       |             |                                                       : 
112e			;       +-------------+                                                       : 
112e			;       |     BC      |                                                       : 
112e			;       +-------------+                                                       : 
112e			;       |     DE      |                                                       : 
112e			;       +-------------+                                                       : 
112e			;       |     IX      |                                                       : 
112e			;       +-------------+                                                       : 
112e			;       |  prev_free  |                                                       : 
112e			;   +4  +-------------+                                                       : 
112e			;       |  this_free  |                                                       : 
112e			;   +2  +-------------+                                                       : 
112e			;       |  next_free  |                                                       : 
112e			;   +0  +-------------+                                                       : 
112e			;       |             |                                                       : 
112e			;                                                                             : 
112e			;------------------------------------------------------------------------------ 
112e			 
112e			 
112e			;malloc: 
112e			; 
112e			;	SAVESP ON 1 
112e			; 
112e			;	call malloc_code 
112e			; 
112e			;	CHECKSP ON 1 
112e			;	ret 
112e			 
