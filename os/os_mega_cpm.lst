0dc1			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
0dc1			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0dc1			tohex: 
0dc1 e5					PUSH HL 
0dc2 d5					PUSH DE 
0dc3 16 00				LD D, 0 
0dc5 5f					LD E, A 
0dc6 21 ce 0d				LD HL, .DATA 
0dc9 19					ADD HL, DE 
0dca 7e					LD A, (HL) 
0dcb d1					POP DE 
0dcc e1					POP HL 
0dcd c9					RET 
