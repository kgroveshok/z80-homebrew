89d8			; 
89d8			;Inputs: 
89d8			;     DE and A are factors 
89d8			;Outputs: 
89d8			;     A is not changed 
89d8			;     B is 0 
89d8			;     C is not changed 
89d8			;     DE is not changed 
89d8			;     HL is the product 
89d8			;Time: 
89d8			;     342+6x 
89d8			; 
89d8			Mult16: 
89d8			 
89d8 06 08		     ld b,8          ;7           7 
89da 21 00 00		     ld hl,0         ;10         10 
89dd 29			       add hl,hl     ;11*8       88 
89de 07			       rlca          ;4*8        32 
89df 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
89e1 19			         add hl,de   ;--         -- 
89e2 10 f9		       djnz $-5      ;13*7+8     99 
89e4 c9			ret 
