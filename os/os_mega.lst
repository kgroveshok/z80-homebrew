1050			; Decimal Unsigned Version 
1050			 
1050			;Number in a to decimal ASCII 
1050			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
1050			;Example: display a=56 as "056" 
1050			;input: a = number 
1050			;Output: a=0,value of a in the screen 
1050			;destroys af,bc (don't know about hl and de) 
1050			DispAToASCII: 
1050 0e 9c			ld	c,-100 
1052 cd 5c 10			call	.Na1 
1055 0e f6			ld	c,-10 
1057 cd 5c 10			call	.Na1 
105a 0e ff			ld	c,-1 
105c 06 2f		.Na1:	ld	b,'0'-1 
105e 04			.Na2:	inc	b 
105f 81				add	a,c 
1060 38 fc			jr	c,.Na2 
1062 91				sub	c		;works as add 100/10/1 
1063 f5				push af		;safer than ld c,a 
1064 78				ld	a,b		;char is in b 
1065			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
1065 f1				pop af		;safer than ld a,c 
1066 c9				ret 
