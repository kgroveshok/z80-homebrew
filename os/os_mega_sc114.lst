dc1e			; stack over and underflow checks 
dc1e			 
dc1e			; init the words to detect the under/overflow 
dc1e			 
dc1e			chk_stk_init: 
dc1e				; a vague random number to check so we dont get any "lucky" hits 
dc1e 3e 2d			ld a, 45 
dc20 6f				ld l, a 
dc21 00				nop 
dc22 3e 17			ld a, 23 
dc24 67				ld h, a 
dc25			 
dc25 22 90 e2			ld (chk_word), hl     ; the word we need to check against 
dc28			 
dc28			;	ld (chk_stund), hl	; stack points.... 
dc28 22 00 ef			ld (chk_stovr), hl 
dc2b 22 df e9			ld (chk_ret_und), hl 
dc2e 22 9d e9			ld (chk_ret_ovr), hl 
dc31 22 1b e9			ld (chk_loop_ovr), hl 
dc34 22 19 e8			ld (chk_data_ovr), hl 
dc37 c9				ret 
dc38				 
dc38			check_stacks: 
dc38				; check all stack words 
dc38			 
dc38 e5				push hl 
dc39 d5				push de 
dc3a			 
dc3a			;	ld de,(chk_word) 
dc3a			;	ld hl, (chk_stund)	; stack points.... 
dc3a			;	if DEBUG_STK_FAULT 
dc3a			;		DMARK "FAa" 
dc3a			;		CALLMONITOR 
dc3a			;	endif 
dc3a			;	call cmp16 
dc3a			;	jp z, .chk_faulta 
dc3a			; 
dc3a			;	ld de, sfaultsu 
dc3a			;	jp .chk_fault 
dc3a			 
dc3a 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
dc3d ed 5b 90 e2		ld de,(chk_word) 
dc41				if DEBUG_STK_FAULT 
dc41					DMARK "FAb" 
dc41					CALLMONITOR 
dc41				endif 
dc41 cd 91 8c			call cmp16 
dc44 28 06			jr z, .chk_fault1 
dc46 11 ea dc			ld de, sfaultso 
dc49 c3 9b dc			jp .chk_fault 
dc4c			.chk_fault1:  
dc4c 2a df e9			ld hl, (chk_ret_und) 
dc4f ed 5b 90 e2		ld de,(chk_word) 
dc53				if DEBUG_STK_FAULT 
dc53					DMARK "FAU" 
dc53					CALLMONITOR 
dc53				endif 
dc53 cd 91 8c			call cmp16 
dc56 ca 5f dc			jp z, .chk_fault2 
dc59 11 fa dc			ld de, sfaultru 
dc5c c3 9b dc			jp .chk_fault 
dc5f			.chk_fault2:  
dc5f 2a 9d e9			ld hl, (chk_ret_ovr) 
dc62 ed 5b 90 e2		ld de,(chk_word) 
dc66				if DEBUG_STK_FAULT 
dc66					DMARK "FA1" 
dc66					CALLMONITOR 
dc66				endif 
dc66 cd 91 8c			call cmp16 
dc69 ca 72 dc			jp z, .chk_fault3 
dc6c 11 08 dd			ld de, sfaultro 
dc6f c3 9b dc			jp .chk_fault 
dc72			.chk_fault3:  
dc72 2a 1b e9			ld hl, (chk_loop_ovr) 
dc75 ed 5b 90 e2		ld de,(chk_word) 
dc79				if DEBUG_STK_FAULT 
dc79					DMARK "FA2" 
dc79					CALLMONITOR 
dc79				endif 
dc79 cd 91 8c			call cmp16 
dc7c ca 85 dc			jp z, .chk_fault4 
dc7f 11 22 dd			ld de, sfaultlo 
dc82 c3 9b dc			jp .chk_fault 
dc85			.chk_fault4:  
dc85 2a 19 e8			ld hl, (chk_data_ovr) 
dc88 ed 5b 90 e2		ld de,(chk_word) 
dc8c				if DEBUG_STK_FAULT 
dc8c					DMARK "FA3" 
dc8c					CALLMONITOR 
dc8c				endif 
dc8c cd 91 8c			call cmp16 
dc8f ca 98 dc			jp z, .chk_fault5 
dc92 11 3c dd			ld de, sfaultdo 
dc95 c3 9b dc			jp .chk_fault 
dc98			 
dc98			 
dc98			.chk_fault5:  
dc98 d1				pop de 
dc99 e1				pop hl 
dc9a			 
dc9a c9				ret 
