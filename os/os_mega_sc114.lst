8df8			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
8df8			 
8df8			;moved to firmware.asm 
8df8			;heap_start        .equ  0x9000      ; Starting address of heap 
8df8			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8df8			 
8df8			;      .org 0 
8df8			;      jp    main 
8df8			 
8df8			 
8df8			;      .org  0x100 
8df8			;main: 
8df8			;      ld    HL, 0x8100 
8df8			;      ld    SP, HL 
8df8			; 
8df8			;      call  heap_init 
8df8			; 
8df8			;      ; Make some allocations 
8df8			;      ld    HL, 12 
8df8			;      call  malloc            ; Allocates 0x9004 
8df8			; 
8df8			;      ld    HL, 12 
8df8			;      call  malloc            ; Allocates 0x9014 
8df8			; 
8df8			;      ld    HL, 12 
8df8			;      call  malloc            ; Allocates 0x9024 
8df8			; 
8df8			;      ; Free some allocations 
8df8			;      ld    HL, 0x9014 
8df8			;      call  free 
8df8			; 
8df8			;      ld    HL, 0x9004 
8df8			;      call  free 
8df8			; 
8df8			;      ld    HL, 0x9024 
8df8			;      call  free 
8df8			; 
8df8			; 
8df8			;      halt 
8df8			 
8df8			 
8df8			;------------------------------------------------------------------------------ 
8df8			;     heap_init                                                               : 
8df8			;                                                                             : 
8df8			; Description                                                                 : 
8df8			;     Initialise the heap and make it ready for malloc and free operations.   : 
8df8			;                                                                             : 
8df8			;     The heap is maintained as a linked list, starting with an initial       : 
8df8			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8df8			;     the first free block in the heap. Each block then points to the next    : 
8df8			;     free block within the heap, and the free list ends at the first block   : 
8df8			;     with a null pointer to the next free block.                             : 
8df8			;                                                                             : 
8df8			; Parameters                                                                  : 
8df8			;     Inputs are compile-time only. Two defines which specify the starting    : 
8df8			;     address of the heap and its size are required, along with a memory      : 
8df8			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8df8			;     principally stores a pointer to the first free block in the heap.       : 
8df8			;                                                                             : 
8df8			; Returns                                                                     : 
8df8			;     Nothing                                                                 : 
8df8			;------------------------------------------------------------------------------ 
8df8			heap_init: 
8df8 e5			      push  HL 
8df9			 
8df9			      ; Initialise free list struct 
8df9 21 f2 d6		      ld    HL, heap_start 
8dfc 22 ed d6		      ld    (free_list), HL 
8dff 21 00 00		      ld    HL, 0 
8e02 22 ef d6		      ld    (free_list+2), HL 
8e05			 
8e05			      ; Insert first free block at bottom of heap, consumes entire heap 
8e05 21 79 e2		      ld    HL, heap_start+heap_size-4 
8e08 22 f2 d6		      ld    (heap_start), HL        ; Next block (end of free list) 
8e0b 21 87 0b		      ld    HL, heap_size-4 
8e0e 22 f4 d6		      ld    (heap_start+2), HL      ; Block size 
8e11			 
8e11			      ; Insert end of free list block at top of heap - two null words will 
8e11			      ; terminate the free list 
8e11 21 00 00		      ld    HL, 0 
8e14 22 7b e2		      ld    (heap_start+heap_size-2), HL 
8e17 22 79 e2		      ld    (heap_start+heap_size-4), HL 
8e1a			 
8e1a e1			      pop   HL 
8e1b			 
8e1b c9			      ret 
8e1c			 
8e1c			 
8e1c			;------------------------------------------------------------------------------ 
8e1c			;     malloc                                                                  : 
8e1c			;                                                                             : 
8e1c			; Description                                                                 : 
8e1c			;     Allocates the wanted space from the heap and returns the address of the : 
8e1c			;     first useable byte of the allocation.                                   : 
8e1c			;                                                                             : 
8e1c			;     Allocations can happen in one of two ways:                              : 
8e1c			;                                                                             : 
8e1c			;     1. A free block may be found which is the exact size wanted. In this    : 
8e1c			;        case the block is removed from the free list and retuedn to the      : 
8e1c			;        caller.                                                              : 
8e1c			;     2. A free block may be found which is larger than the size wanted. In   : 
8e1c			;        this case, the larger block is split into two. The first portion of  : 
8e1c			;        this block will become the requested space by the malloc call and    : 
8e1c			;        is returned to the caller. The second portion becomes a new free     : 
8e1c			;        block, and the free list is adjusted to maintain continuity via this : 
8e1c			;        newly created block.                                                 : 
8e1c			;                                                                             : 
8e1c			;     malloc does not set any initial value in the allocated space, the       : 
8e1c			;     caller is required to do this as required.                              : 
8e1c			;                                                                             : 
8e1c			;     This implementation of malloc uses the stack exclusively, and is        : 
8e1c			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8e1c			;     advisable to disable interrupts before calling malloc, and recommended  : 
8e1c			;     to avoid the use of malloc inside ISRs in general.                      : 
8e1c			;                                                                             : 
8e1c			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8e1c			;                                                                             : 
8e1c			; Parameters                                                                  : 
8e1c			;     HL  Number of bytes wanted                                              : 
8e1c			;                                                                             : 
8e1c			; Returns                                                                     : 
8e1c			;     HL  Address of the first useable byte of the allocation                 : 
8e1c			;                                                                             : 
8e1c			; Flags                                                                       : 
8e1c			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8e1c			;                                                                             : 
8e1c			; Stack frame                                                                 : 
8e1c			;       |             |                                                       : 
8e1c			;       +-------------+                                                       : 
8e1c			;       |     BC      |                                                       : 
8e1c			;       +-------------+                                                       : 
8e1c			;       |     DE      |                                                       : 
8e1c			;       +-------------+                                                       : 
8e1c			;       |     IX      |                                                       : 
8e1c			;       +-------------+                                                       : 
8e1c			;       |  prev_free  |                                                       : 
8e1c			;   +4  +-------------+                                                       : 
8e1c			;       |  this_free  |                                                       : 
8e1c			;   +2  +-------------+                                                       : 
8e1c			;       |  next_free  |                                                       : 
8e1c			;   +0  +-------------+                                                       : 
8e1c			;       |             |                                                       : 
8e1c			;                                                                             : 
