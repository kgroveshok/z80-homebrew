0d7d			addatohl: 
0d7d 85			    add   a, l    ; A = A+L 
0d7e 6f			    ld    l, a    ; L = A+L 
0d7f 8c			    adc   a, h    ; A = A+L+H+carry 
0d80 95			    sub   l       ; A = H+carry 
0d81 67			    ld    h, a    ; H = H+carry 
0d82 c9			ret 
