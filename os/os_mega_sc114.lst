890f			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
890f			; random number generators 
890f			 
890f			 
890f			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
890f			 
890f			 
890f			;-----> Generate a random number 
890f			; output a=answer 0<=a<=255 
890f			; all registers are preserved except: af 
890f			random: 
890f e5			        push    hl 
8910 d5			        push    de 
8911 2a a0 eb		        ld      hl,(randData) 
8914 ed 5f		        ld      a,r 
8916 57			        ld      d,a 
8917 5e			        ld      e,(hl) 
8918 19			        add     hl,de 
8919 85			        add     a,l 
891a ac			        xor     h 
891b 22 a0 eb		        ld      (randData),hl 
891e d1			        pop     de 
891f e1			        pop     hl 
8920 c9			        ret 
8921			 
8921			 
8921			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
8921			 
8921			 
8921			 
8921			;------LFSR------ 
8921			;James Montelongo 
8921			;optimized by Spencer Putt 
8921			;out: 
8921			; a = 8 bit random number 
8921			RandLFSR: 
8921 21 a6 eb		        ld hl,LFSRSeed+4 
8924 5e			        ld e,(hl) 
8925 23			        inc hl 
8926 56			        ld d,(hl) 
8927 23			        inc hl 
8928 4e			        ld c,(hl) 
8929 23			        inc hl 
892a 7e			        ld a,(hl) 
892b 47			        ld b,a 
892c cb 13		        rl e  
892e cb 12			rl d 
8930 cb 11		        rl c  
8932 17				rla 
8933 cb 13		        rl e  
8935 cb 12			rl d 
8937 cb 11		        rl c  
8939 17				rla 
893a cb 13		        rl e  
893c cb 12			rl d 
893e cb 11		        rl c  
8940 17				rla 
8941 67			        ld h,a 
8942 cb 13		        rl e  
8944 cb 12			rl d 
8946 cb 11		        rl c  
8948 17				rla 
8949 a8			        xor b 
894a cb 13		        rl e  
894c cb 12			rl d 
894e ac			        xor h 
894f a9			        xor c 
8950 aa			        xor d 
8951 21 a8 eb		        ld hl,LFSRSeed+6 
8954 11 a9 eb		        ld de,LFSRSeed+7 
8957 01 07 00		        ld bc,7 
895a ed b8		        lddr 
895c 12			        ld (de),a 
895d c9			        ret 
895e			 
895e			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
895e			 
895e			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
895e			 
895e			 
895e			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
895e			 
895e			prng16: 
895e			;Inputs: 
895e			;   (seed1) contains a 16-bit seed value 
895e			;   (seed2) contains a NON-ZERO 16-bit seed value 
895e			;Outputs: 
895e			;   HL is the result 
895e			;   BC is the result of the LCG, so not that great of quality 
895e			;   DE is preserved 
895e			;Destroys: 
895e			;   AF 
895e			;cycle: 4,294,901,760 (almost 4.3 billion) 
895e			;160cc 
895e			;26 bytes 
895e 2a 9a eb		    ld hl,(seed1) 
8961 44			    ld b,h 
8962 4d			    ld c,l 
8963 29			    add hl,hl 
8964 29			    add hl,hl 
8965 2c			    inc l 
8966 09			    add hl,bc 
8967 22 9a eb		    ld (seed1),hl 
896a 2a 98 eb		    ld hl,(seed2) 
896d 29			    add hl,hl 
896e 9f			    sbc a,a 
896f e6 2d		    and %00101101 
8971 ad			    xor l 
8972 6f			    ld l,a 
8973 22 98 eb		    ld (seed2),hl 
8976 09			    add hl,bc 
8977 c9			    ret 
8978			 
8978			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
8978			 
8978			rand32: 
8978			;Inputs: 
8978			;   (seed1_0) holds the lower 16 bits of the first seed 
8978			;   (seed1_1) holds the upper 16 bits of the first seed 
8978			;   (seed2_0) holds the lower 16 bits of the second seed 
8978			;   (seed2_1) holds the upper 16 bits of the second seed 
8978			;   **NOTE: seed2 must be non-zero 
8978			;Outputs: 
8978			;   HL is the result 
8978			;   BC,DE can be used as lower quality values, but are not independent of HL. 
8978			;Destroys: 
8978			;   AF 
8978			;Tested and passes all CAcert tests 
8978			;Uses a very simple 32-bit LCG and 32-bit LFSR 
8978			;it has a period of 18,446,744,069,414,584,320 
8978			;roughly 18.4 quintillion. 
8978			;LFSR taps: 0,2,6,7  = 11000101 
8978			;291cc 
8978			;seed1_0=$+1 
8978			;    ld hl,12345 
8978			;seed1_1=$+1 
8978			;    ld de,6789 
8978			;    ld b,h 
8978			;    ld c,l 
8978			;    add hl,hl \ rl e \ rl d 
8978			;    add hl,hl \ rl e \ rl d 
8978			;    inc l 
