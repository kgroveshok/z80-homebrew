2b6f			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2b6f			; | | At start the current various registers will be displayed with contents. 
2b6f			; | | Top right corner will show the most recent debug marker seen. 
2b6f			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2b6f			; | | and the return stack pointer (RSP). 
2b6f			; | | Pressing: 
2b6f			; | |  
2b6f			; | |    1 - Initial screen 
2b6f			; | |  
2b6f			; | |    2 - Display a data dump of HL 
2b6f			; | |  
2b6f			; | |    3 - Display a data dump of DE 
2b6f			; | |  
2b6f			; | |    4 - Display a data dump of BC 
2b6f			; | |  
2b6f			; | |    5 - Display a data dump of HL 
2b6f			; | |  
2b6f			; | |    6 - Display a data dump of DSP 
2b6f			; | |  
2b6f			; | |    7 - Display a data dump of RSP 
2b6f			; | |  
2b6f			; | |    8 - Display a data dump of what is at DSP 
2b6f			; | |  
2b6f			; | |    9 - Display a data dump of what is at RSP 
2b6f			; | |  
2b6f			; | |    0 - Exit monitor and continue running. This will also enable break points 
2b6f			; | |  
2b6f			; | |    * - Disable break points 
2b6f			; | |  
2b6f			; | |    # - Enter traditional monitor mode 
2b6f			; | |  
2b6f			; | | 
2b6f			; | | Monitor Mode 
2b6f			; | | ------------ 
2b6f			; | | A prompt of '>' will be shown for various commands: 
2b6f			; | |  
2b6f			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2b6f			; | |  
2b6f			; | |    C - Continue display a data dump from the last set address 
2b6f			; | |  
2b6f			; | |    M xxxx - Set start of memory edit at address xx 
2b6f			; | |  
2b6f			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2b6f			; | |  
2b6f			; | |    G xxxx - Exec code at specific address 
2b6f			; | |  
2b6f			; | |    Q - Return to previous 
2b6f				if DEBUG_FORTH_WORDS_KEY 
2b6f					DMARK "MON" 
2b6f				if DEMARK_VERSION = 1  
2b6f e5					push hl  
2b70 21 78 2b				ld hl, .dmark  
2b73 22 9b fd				ld (debug_mark), hl  
2b76				endif  
