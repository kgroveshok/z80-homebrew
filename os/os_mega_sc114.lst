9c3d 23				inc hl 
9c3e			 
9c3e			;	ld a, '~'			; word length is 0 
9c3e 36 7e			ld (hl), '~' 
9c40 23				inc hl 
9c41			;	ld a, 0			; save empty word 
9c41 36 00			ld (hl), 0 
