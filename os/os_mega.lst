1123			;------------------------------------------------------------------------------ 
1123			;     heap_init                                                               : 
1123			;                                                                             : 
1123			; Description                                                                 : 
1123			;     Initialise the heap and make it ready for malloc and free operations.   : 
1123			;                                                                             : 
1123			;     The heap is maintained as a linked list, starting with an initial       : 
1123			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1123			;     the first free block in the heap. Each block then points to the next    : 
1123			;     free block within the heap, and the free list ends at the first block   : 
1123			;     with a null pointer to the next free block.                             : 
1123			;                                                                             : 
1123			; Parameters                                                                  : 
1123			;     Inputs are compile-time only. Two defines which specify the starting    : 
1123			;     address of the heap and its size are required, along with a memory      : 
1123			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1123			;     principally stores a pointer to the first free block in the heap.       : 
1123			;                                                                             : 
1123			; Returns                                                                     : 
1123			;     Nothing                                                                 : 
1123			;------------------------------------------------------------------------------ 
1123			heap_init: 
1123 e5			      push  HL 
1124			 
1124			      ; Initialise free list struct 
1124 21 0e 80		      ld    HL, heap_start 
1127 22 0a 80		      ld    (free_list), HL 
112a 21 00 00		      ld    HL, 0 
112d 22 0c 80		      ld    (free_list+2), HL 
1130			 
1130			      ; Insert first free block at bottom of heap, consumes entire heap 
1130 21 b4 f0		      ld    HL, heap_start+heap_size-4 
1133 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
1136 21 a6 70		      ld    HL, heap_size-4 
1139 22 10 80		      ld    (heap_start+2), HL      ; Block size 
113c			 
113c			      ; Insert end of free list block at top of heap - two null words will 
113c			      ; terminate the free list 
113c 21 00 00		      ld    HL, 0 
113f 22 b6 f0		      ld    (heap_start+heap_size-2), HL 
1142 22 b4 f0		      ld    (heap_start+heap_size-4), HL 
1145			 
1145 e1			      pop   HL 
1146			 
1146 c9			      ret 
1147			 
1147			 
1147			;------------------------------------------------------------------------------ 
1147			;     malloc                                                                  : 
1147			;                                                                             : 
1147			; Description                                                                 : 
1147			;     Allocates the wanted space from the heap and returns the address of the : 
1147			;     first useable byte of the allocation.                                   : 
1147			;                                                                             : 
1147			;     Allocations can happen in one of two ways:                              : 
1147			;                                                                             : 
1147			;     1. A free block may be found which is the exact size wanted. In this    : 
1147			;        case the block is removed from the free list and retuedn to the      : 
1147			;        caller.                                                              : 
1147			;     2. A free block may be found which is larger than the size wanted. In   : 
1147			;        this case, the larger block is split into two. The first portion of  : 
1147			;        this block will become the requested space by the malloc call and    : 
1147			;        is returned to the caller. The second portion becomes a new free     : 
1147			;        block, and the free list is adjusted to maintain continuity via this : 
1147			;        newly created block.                                                 : 
1147			;                                                                             : 
1147			;     malloc does not set any initial value in the allocated space, the       : 
1147			;     caller is required to do this as required.                              : 
1147			;                                                                             : 
1147			;     This implementation of malloc uses the stack exclusively, and is        : 
1147			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1147			;     advisable to disable interrupts before calling malloc, and recommended  : 
1147			;     to avoid the use of malloc inside ISRs in general.                      : 
1147			;                                                                             : 
1147			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1147			;                                                                             : 
1147			; Parameters                                                                  : 
1147			;     HL  Number of bytes wanted                                              : 
1147			;                                                                             : 
1147			; Returns                                                                     : 
1147			;     HL  Address of the first useable byte of the allocation                 : 
1147			;                                                                             : 
1147			; Flags                                                                       : 
1147			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1147			;                                                                             : 
1147			; Stack frame                                                                 : 
1147			;       |             |                                                       : 
1147			;       +-------------+                                                       : 
1147			;       |     BC      |                                                       : 
1147			;       +-------------+                                                       : 
1147			;       |     DE      |                                                       : 
1147			;       +-------------+                                                       : 
1147			;       |     IX      |                                                       : 
1147			;       +-------------+                                                       : 
1147			;       |  prev_free  |                                                       : 
1147			;   +4  +-------------+                                                       : 
1147			;       |  this_free  |                                                       : 
1147			;   +2  +-------------+                                                       : 
1147			;       |  next_free  |                                                       : 
1147			;   +0  +-------------+                                                       : 
1147			;       |             |                                                       : 
1147			;                                                                             : 
1147			;------------------------------------------------------------------------------ 
1147			 
1147			 
1147			;malloc: 
1147			; 
1147			;	SAVESP ON 1 
1147			; 
1147			;	call malloc_code 
1147			; 
1147			;	CHECKSP ON 1 
1147			;	ret 
1147			 
1147			 
1147			malloc: 
1147 c5			      push  BC 
1148 d5			      push  DE 
1149 dd e5		      push  IX 
114b			if DEBUG_FORTH_MALLOC_HIGH 
114b			call malloc_guard_entry 
114b			endif 
114b			 
114b					if DEBUG_FORTH_MALLOC 
114b						DMARK "mal" 
114b						CALLMONITOR 
114b					endif 
114b 7c			      ld    A, H                    ; Exit if no space requested 
114c b5			      or    L 
114d ca 0c 12		      jp    Z, malloc_early_exit 
1150			 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			; 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			;inc hl 
1150			 
1150			 
1150			 
1150			 
1150					if DEBUG_FORTH_MALLOC 
1150						DMARK "maA" 
1150						CALLMONITOR 
1150					endif 
1150			      ; Set up stack frame 
1150 eb			      ex    DE, HL 
1151 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1154 39			      add   HL, SP 
1155 f9			      ld    SP, HL 
1156 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
115a dd 39		      add   IX, SP 
115c			 
115c			      ; Setup initial state 
115c 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
115f 19			      add   HL, DE 
1160			 
1160 44			      ld    B, H                    ; Move want to BC 
1161 4d			      ld    C, L 
1162			 
1162 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
1165 dd 75 04		      ld    (IX+4), L 
1168 dd 74 05		      ld    (IX+5), H 
116b			 
116b 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
116c 23			      inc   HL 
116d 56			      ld    D, (HL) 
116e dd 73 02		      ld    (IX+2), E 
1171 dd 72 03		      ld    (IX+3), D 
1174 eb			      ex    DE, HL                  ; this_free ptr into HL 
1175			 
1175					if DEBUG_FORTH_MALLOC 
1175						DMARK "maB" 
1175						CALLMONITOR 
1175					endif 
1175			      ; Loop through free block list to find some space 
1175			malloc_find_space: 
1175 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
1176 23			      inc   HL 
1177 56			      ld    D, (HL) 
1178			 
1178 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1179 b3			      or    E 
117a ca 06 12		      jp    Z, malloc_no_space 
117d			 
117d dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1180 dd 72 01		      ld    (IX+1), D 
1183			 
1183			      ; Does this block have enough space to make the allocation? 
1183 23			      inc   HL                      ; Load free block size into DE 
1184 5e			      ld    E, (HL) 
1185 23			      inc   HL 
1186 56			      ld    D, (HL) 
1187			 
1187 eb			      ex    DE, HL                  ; Check size of block against want 
1188 b7			      or    A                       ; Ensure carry flag clear 
1189 ed 42		      sbc   HL, BC 
118b e5			      push  HL                      ; Store the result for later (new block size) 
118c			 
118c ca db 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
118f 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1191			 
1191			      ; this_free block is not big enough, setup ptrs to test next free block 
1191 e1			      pop   HL                      ; Discard previous result 
1192			 
1192 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1195 dd 66 03		      ld    H, (IX+3) 
1198 dd 75 04		      ld    (IX+4), L 
119b dd 74 05		      ld    (IX+5), H 
119e			 
119e dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
11a1 dd 66 01		      ld    H, (IX+1) 
11a4 dd 75 02		      ld    (IX+2), L 
11a7 dd 74 03		      ld    (IX+3), H 
11aa			 
11aa					if DEBUG_FORTH_MALLOC 
11aa						DMARK "MA>" 
11aa						CALLMONITOR 
11aa					endif 
11aa 18 c9		      jr    malloc_find_space 
11ac			 
11ac			      ; split a bigger block into two - requested size and remaining size 
11ac			malloc_alloc_split: 
11ac					if DEBUG_FORTH_MALLOC 
11ac						DMARK "MAs" 
11ac						CALLMONITOR 
11ac					endif 
11ac eb			      ex    DE, HL                  ; Calculate address of new free block 
11ad 2b			      dec   HL 
11ae 2b			      dec   HL 
11af 2b			      dec   HL 
11b0 09			      add   HL, BC 
11b1			 
11b1			      ; Create a new block and point it at next_free 
11b1 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
11b4 dd 56 01		      ld    D, (IX+1) 
11b7			 
11b7 73			      ld    (HL), E                 ; Store next_free ptr into new block 
11b8 23			      inc   HL 
11b9 72			      ld    (HL), D 
11ba			 
11ba d1			      pop   DE                      ; Store size of new block into new block 
11bb 23			      inc   HL 
11bc 73			      ld    (HL), E 
11bd 23			      inc   HL 
11be 72			      ld    (HL), D 
11bf			 
11bf			      ; Update this_free ptr to point to new block 
11bf 2b			      dec   HL 
11c0 2b			      dec   HL 
11c1 2b			      dec   HL 
11c2			 
11c2 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
11c5 dd 56 03		      ld    D, (IX+3) 
11c8			 
11c8 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
11cb dd 74 03		      ld    (IX+3), H 
11ce			 
11ce			      ; Modify this_free block to be allocation 
11ce eb			      ex    DE, HL 
11cf af			      xor   A                       ; Null the next block ptr of allocated block 
11d0 77			      ld    (HL), A 
11d1 23			      inc   HL 
11d2 77			      ld    (HL), A 
11d3			 
11d3 23			      inc   HL                      ; Store want size into allocated block 
11d4 71			      ld    (HL), C 
11d5 23			      inc   HL 
11d6 70			      ld    (HL), B 
11d7 23			      inc   HL 
11d8 e5			      push  HL                      ; Address of allocation to return 
11d9			 
11d9 18 19		      jr    malloc_update_links 
11db			 
11db			malloc_alloc_fit: 
11db e1			      pop   HL                      ; Dont need new block size, want is exact fit 
11dc			 
11dc					if DEBUG_FORTH_MALLOC 
11dc						DMARK "MAf" 
11dc						CALLMONITOR 
11dc					endif 
11dc			      ; Modify this_free block to be allocation 
11dc eb			      ex    DE, HL 
11dd 2b			      dec   HL 
11de 2b			      dec   HL 
11df 2b			      dec   HL 
11e0			 
11e0 af			      xor   A                       ; Null the next block ptr of allocated block 
11e1 77			      ld    (HL), A 
11e2 23			      inc   HL 
11e3 77			      ld    (HL), A 
11e4			 
11e4 23			      inc   HL                      ; Store address of allocation to return 
11e5 23			      inc   HL 
11e6 23			      inc   HL 
11e7 e5			      push  HL 
11e8			 
11e8			      ; Copy next_free ptr to this_free, remove allocated block from free list 
11e8 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11eb dd 66 01		      ld    H, (IX+1) 
11ee			 
11ee dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11f1 dd 74 03		      ld    (IX+3), H 
11f4			 
11f4			 
11f4			malloc_update_links: 
11f4			      ; Update prev_free ptr to point to this_free 
11f4 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
11f7 dd 66 05		      ld    H, (IX+5) 
11fa			 
11fa dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
11fd dd 56 03		      ld    D, (IX+3) 
1200			 
1200 73			      ld    (HL), E                 ; this_free ptr into prev_free 
1201 23			      inc   HL 
1202 72			      ld    (HL), D 
1203			 
1203					if DEBUG_FORTH_MALLOC 
1203						DMARK "Mul" 
1203						CALLMONITOR 
1203					endif 
1203			      ; Clear the Z flag to indicate successful allocation 
1203 7a			      ld    A, D 
1204 b3			      or    E 
1205			 
1205 d1			      pop   DE                      ; Address of allocation 
1206					if DEBUG_FORTH_MALLOC 
1206						DMARK "MAu" 
1206						CALLMONITOR 
1206					endif 
1206			 
1206			malloc_no_space: 
1206 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
1209 39			      add   HL, SP 
120a f9			      ld    SP, HL 
120b			 
120b eb			      ex    DE, HL                  ; Alloc addr into HL for return 
120c					if DEBUG_FORTH_MALLOC 
120c						DMARK "MAN" 
120c						CALLMONITOR 
120c					endif 
120c			 
120c			malloc_early_exit: 
120c					if DEBUG_FORTH_MALLOC 
120c						DMARK "MAx" 
120c						CALLMONITOR 
120c					endif 
120c dd e1		      pop   IX 
120e d1			      pop   DE 
120f c1			      pop   BC 
1210			 
1210			if DEBUG_FORTH_MALLOC_HIGH 
1210			call malloc_guard_exit 
1210			call malloc_guard_zerolen 
1210			endif 
1210 c9			      ret 
