# End of macro CWHEAD
a726			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a726			; | | At start the current various registers will be displayed with contents. 
a726			; | | Top right corner will show the most recent debug marker seen. 
a726			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a726			; | | and the return stack pointer (RSP). 
a726			; | | Pressing: 
a726			; | |  
a726			; | |    1 - Initial screen 
a726			; | |  
a726			; | |    2 - Display a data dump of HL 
a726			; | |  
a726			; | |    3 - Display a data dump of DE 
a726			; | |  
a726			; | |    4 - Display a data dump of BC 
a726			; | |  
a726			; | |    5 - Display a data dump of HL 
a726			; | |  
a726			; | |    6 - Display a data dump of DSP 
a726			; | |  
a726			; | |    7 - Display a data dump of RSP 
a726			; | |  
a726			; | |    8 - Display a data dump of what is at DSP 
a726			; | |  
a726			; | |    9 - Display a data dump of what is at RSP 
a726			; | |  
a726			; | |    0 - Exit monitor and continue running. This will also enable break points 
a726			; | |  
a726			; | |    * - Disable break points 
a726			; | |  
a726			; | |    # - Enter traditional monitor mode 
a726			; | |  
a726			; | | 
a726			; | | Monitor Mode 
a726			; | | ------------ 
a726			; | | A prompt of '>' will be shown for various commands: 
a726			; | |  
a726			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a726			; | |  
a726			; | |    C - Continue display a data dump from the last set address 
a726			; | |  
a726			; | |    M xxxx - Set start of memory edit at address xx 
a726			; | |  
a726			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a726			; | |  
a726			; | |    G xxxx - Exec code at specific address 
a726			; | |  
a726			; | |    Q - Return to previous 
a726				if DEBUG_FORTH_WORDS_KEY 
a726					DMARK "MON" 
a726 f5				push af  
a727 3a 3b a7			ld a, (.dmark)  
a72a 32 5e ee			ld (debug_mark),a  
a72d 3a 3c a7			ld a, (.dmark+1)  
a730 32 5f ee			ld (debug_mark+1),a  
a733 3a 3d a7			ld a, (.dmark+2)  
a736 32 60 ee			ld (debug_mark+2),a  
a739 18 03			jr .pastdmark  
a73b ..			.dmark: db "MON"  
a73e f1			.pastdmark: pop af  
a73f			endm  
# End of macro DMARK
a73f					CALLMONITOR 
a73f				if BASE_CPM=1  
a73f					call debug_vector  
a73f				endif  
a73f				if BASE_KEV=1  
a73f					rst 8  
a73f				endif  
a73f				endm  
# End of macro CALLMONITOR
a73f				endif 
a73f			;		ld a, 0 
a73f			;		ld (os_view_disable), a 
a73f cd e3 92			call bp_on 
