1159			 
1159			;------------------------------------------------------------------------------ 
1159			;     heap_init                                                               : 
1159			;                                                                             : 
1159			; Description                                                                 : 
1159			;     Initialise the heap and make it ready for malloc and free operations.   : 
1159			;                                                                             : 
1159			;     The heap is maintained as a linked list, starting with an initial       : 
1159			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1159			;     the first free block in the heap. Each block then points to the next    : 
1159			;     free block within the heap, and the free list ends at the first block   : 
1159			;     with a null pointer to the next free block.                             : 
1159			;                                                                             : 
1159			; Parameters                                                                  : 
1159			;     Inputs are compile-time only. Two defines which specify the starting    : 
1159			;     address of the heap and its size are required, along with a memory      : 
1159			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1159			;     principally stores a pointer to the first free block in the heap.       : 
1159			;                                                                             : 
1159			; Returns                                                                     : 
1159			;     Nothing                                                                 : 
1159			;------------------------------------------------------------------------------ 
1159			heap_init: 
1159			      push  HL 
1159			 
1159			      ; Initialise free list struct 
1159			      ld    HL, heap_start 
1159			      ld    (free_list), HL 
1159			      ld    HL, 0 
1159			      ld    (free_list+2), HL 
1159			 
1159			      ; Insert first free block at bottom of heap, consumes entire heap 
1159			      ld    HL, heap_start+heap_size-4 
1159			      ld    (heap_start), HL        ; Next block (end of free list) 
1159			      ld    HL, heap_size-4 
1159			      ld    (heap_start+2), HL      ; Block size 
1159			 
1159			      ; Insert end of free list block at top of heap - two null words will 
1159			      ; terminate the free list 
1159			      ld    HL, 0 
1159			      ld    (heap_start+heap_size-2), HL 
1159			      ld    (heap_start+heap_size-4), HL 
1159			 
1159			      pop   HL 
1159			 
1159			      ret 
1159			 
1159			 
1159			;------------------------------------------------------------------------------ 
1159			;     malloc                                                                  : 
1159			;                                                                             : 
1159			; Description                                                                 : 
1159			;     Allocates the wanted space from the heap and returns the address of the : 
1159			;     first useable byte of the allocation.                                   : 
1159			;                                                                             : 
1159			;     Allocations can happen in one of two ways:                              : 
1159			;                                                                             : 
1159			;     1. A free block may be found which is the exact size wanted. In this    : 
1159			;        case the block is removed from the free list and retuedn to the      : 
1159			;        caller.                                                              : 
1159			;     2. A free block may be found which is larger than the size wanted. In   : 
1159			;        this case, the larger block is split into two. The first portion of  : 
1159			;        this block will become the requested space by the malloc call and    : 
1159			;        is returned to the caller. The second portion becomes a new free     : 
1159			;        block, and the free list is adjusted to maintain continuity via this : 
1159			;        newly created block.                                                 : 
1159			;                                                                             : 
1159			;     malloc does not set any initial value in the allocated space, the       : 
1159			;     caller is required to do this as required.                              : 
1159			;                                                                             : 
1159			;     This implementation of malloc uses the stack exclusively, and is        : 
1159			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1159			;     advisable to disable interrupts before calling malloc, and recommended  : 
1159			;     to avoid the use of malloc inside ISRs in general.                      : 
1159			;                                                                             : 
1159			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1159			;                                                                             : 
1159			; Parameters                                                                  : 
1159			;     HL  Number of bytes wanted                                              : 
1159			;                                                                             : 
1159			; Returns                                                                     : 
1159			;     HL  Address of the first useable byte of the allocation                 : 
1159			;                                                                             : 
1159			; Flags                                                                       : 
1159			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1159			;                                                                             : 
1159			; Stack frame                                                                 : 
1159			;       |             |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |     BC      |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |     DE      |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |     IX      |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |  prev_free  |                                                       : 
1159			;   +4  +-------------+                                                       : 
1159			;       |  this_free  |                                                       : 
1159			;   +2  +-------------+                                                       : 
1159			;       |  next_free  |                                                       : 
1159			;   +0  +-------------+                                                       : 
1159			;       |             |                                                       : 
1159			;                                                                             : 
1159			;------------------------------------------------------------------------------ 
1159			malloc: 
1159			      push  BC 
1159			      push  DE 
1159			      push  IX 
1159			 
1159			      ld    A, H                    ; Exit if no space requested 
1159			      or    L 
1159			      jp    Z, malloc_early_exit 
1159			 
1159			      ; Set up stack frame 
1159			      ex    DE, HL 
1159			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1159			      add   HL, SP 
1159			      ld    SP, HL 
1159			      ld    IX, 0                   ; Use IX as a frame pointer 
1159			      add   IX, SP 
1159			 
1159			      ; Setup initial state 
1159			      ld    HL, 4                   ; want must also include space used by block struct 
1159			      add   HL, DE 
1159			 
1159			      ld    B, H                    ; Move want to BC 
1159			      ld    C, L 
1159			 
1159			      ld    HL, free_list           ; Store prev_free ptr to stack 
1159			      ld    (IX+4), L 
1159			      ld    (IX+5), H 
1159			 
1159			      ld    E, (HL)                 ; Store this_free ptr to stack 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      ld    (IX+2), E 
1159			      ld    (IX+3), D 
1159			      ex    DE, HL                  ; this_free ptr into HL 
1159			 
1159			      ; Loop through free block list to find some space 
1159			malloc_find_space: 
1159			      ld    E, (HL)                 ; Load next_free ptr into DE 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			 
1159			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1159			      or    E 
1159			      jp    Z, malloc_no_space 
1159			 
1159			      ld    (IX+0), E               ; Store next_free ptr to stack 
1159			      ld    (IX+1), D 
1159			 
1159			      ; Does this block have enough space to make the allocation? 
1159			      inc   HL                      ; Load free block size into DE 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			 
1159			      ex    DE, HL                  ; Check size of block against want 
1159			      or    A                       ; Ensure carry flag clear 
1159			      sbc   HL, BC 
1159			      push  HL                      ; Store the result for later (new block size) 
1159			 
1159			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1159			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1159			 
1159			      ; this_free block is not big enough, setup ptrs to test next free block 
1159			      pop   HL                      ; Discard previous result 
1159			 
1159			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1159			      ld    H, (IX+3) 
1159			      ld    (IX+4), L 
1159			      ld    (IX+5), H 
1159			 
1159			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1159			      ld    H, (IX+1) 
1159			      ld    (IX+2), L 
1159			      ld    (IX+3), H 
1159			 
1159			      jr    malloc_find_space 
1159			 
1159			      ; split a bigger block into two - requested size and remaining size 
1159			malloc_alloc_split: 
1159			      ex    DE, HL                  ; Calculate address of new free block 
1159			      dec   HL 
1159			      dec   HL 
1159			      dec   HL 
1159			      add   HL, BC 
1159			 
1159			      ; Create a new block and point it at next_free 
1159			      ld    E, (IX+0)               ; Load next_free ptr into DE 
1159			      ld    D, (IX+1) 
1159			 
1159			      ld    (HL), E                 ; Store next_free ptr into new block 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			      pop   DE                      ; Store size of new block into new block 
1159			      inc   HL 
1159			      ld    (HL), E 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			      ; Update this_free ptr to point to new block 
1159			      dec   HL 
1159			      dec   HL 
1159			      dec   HL 
1159			 
1159			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1159			      ld    D, (IX+3) 
1159			 
1159			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
1159			      ld    (IX+3), H 
1159			 
1159			      ; Modify this_free block to be allocation 
1159			      ex    DE, HL 
1159			      xor   A                       ; Null the next block ptr of allocated block 
1159			      ld    (HL), A 
1159			      inc   HL 
1159			      ld    (HL), A 
1159			 
1159			      inc   HL                      ; Store want size into allocated block 
1159			      ld    (HL), C 
1159			      inc   HL 
1159			      ld    (HL), B 
1159			      inc   HL 
1159			      push  HL                      ; Address of allocation to return 
1159			 
1159			      jr    malloc_update_links 
1159			 
1159			malloc_alloc_fit: 
1159			      pop   HL                      ; Dont need new block size, want is exact fit 
1159			 
1159			      ; Modify this_free block to be allocation 
1159			      ex    DE, HL 
1159			      dec   HL 
1159			      dec   HL 
1159			      dec   HL 
1159			 
1159			      xor   A                       ; Null the next block ptr of allocated block 
1159			      ld    (HL), A 
1159			      inc   HL 
1159			      ld    (HL), A 
1159			 
1159			      inc   HL                      ; Store address of allocation to return 
1159			      inc   HL 
1159			      inc   HL 
1159			      push  HL 
1159			 
1159			      ; Copy next_free ptr to this_free, remove allocated block from free list 
1159			      ld    L, (IX+0)               ; next_free to HL 
1159			      ld    H, (IX+1) 
1159			 
1159			      ld    (IX+2), L               ; HL to this_free 
1159			      ld    (IX+3), H 
1159			 
1159			 
1159			malloc_update_links: 
1159			      ; Update prev_free ptr to point to this_free 
1159			      ld    L, (IX+4)               ; prev_free ptr to HL 
1159			      ld    H, (IX+5) 
1159			 
1159			      ld    E, (IX+2)               ; this_free ptr to DE 
1159			      ld    D, (IX+3) 
1159			 
1159			      ld    (HL), E                 ; this_free ptr into prev_free 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			      ; Clear the Z flag to indicate successful allocation 
1159			      ld    A, D 
1159			      or    E 
1159			 
1159			      pop   DE                      ; Address of allocation 
1159			 
1159			malloc_no_space: 
1159			      ld    HL, 6                   ; Clean up stack frame 
1159			      add   HL, SP 
1159			      ld    SP, HL 
1159			 
1159			      ex    DE, HL                  ; Alloc addr into HL for return 
1159			 
1159			malloc_early_exit: 
1159			      pop   IX 
1159			      pop   DE 
1159			      pop   BC 
1159			 
1159			      ret 
1159			 
1159			 
1159			;------------------------------------------------------------------------------ 
1159			;     free                                                                    : 
1159			;                                                                             : 
1159			; Description                                                                 : 
1159			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1159			;     returned by malloc, otherwise the behaviour is undefined.               : 
1159			;                                                                             : 
1159			;     Where possible, directly adjacent free blocks will be merged together   : 
1159			;     into larger blocks to help ensure that the heap does not become         : 
1159			;     excessively fragmented.                                                 : 
1159			;                                                                             : 
1159			;     free does not clear or set any other value into the freed space, and    : 
1159			;     therefore its contents may be visible through subsequent malloc's. The  : 
1159			;     caller should clear the freed space as required.                        : 
1159			;                                                                             : 
1159			;     This implementation of free uses the stack exclusively, and is          : 
1159			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1159			;     advisable to disable interrupts before calling free, and recommended    : 
1159			;     to avoid the use of free inside ISRs in general.                        : 
1159			;                                                                             : 
1159			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1159			;                                                                             : 
1159			; Parameters                                                                  : 
1159			;     HL  Pointer to address of first byte of allocation to be freed          : 
1159			;                                                                             : 
1159			; Returns                                                                     : 
1159			;     Nothing                                                                 : 
1159			;                                                                             : 
1159			; Stack frame                                                                 : 
1159			;       |             |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |     BC      |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |     DE      |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |     IX      |                                                       : 
1159			;       +-------------+                                                       : 
1159			;       |  prev_free  |                                                       : 
1159			;   +2  +-------------+                                                       : 
1159			;       |  next_free  |                                                       : 
1159			;   +0  +-------------+                                                       : 
1159			;       |             |                                                       : 
1159			;                                                                             : 
1159			;------------------------------------------------------------------------------ 
1159			free: 
1159			      push  BC 
1159			      push  DE 
1159			      push  IX 
1159			 
1159			      ld    A, H                    ; Exit if ptr is null 
1159			      or    L 
1159			      jp    Z, free_early_exit 
1159			 
1159			      ; Set up stack frame 
1159			      ex    DE, HL 
1159			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1159			      add   HL, SP 
1159			      ld    SP, HL 
1159			      ld    IX, 0                   ; Use IX as a frame pointer 
1159			      add   IX, SP 
1159			 
1159			      ; The address in HL points to the start of the useable allocated space, 
1159			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1159			      ; address of the block itself. 
1159			      ex    DE, HL 
1159			      ld    DE, -4 
1159			      add   HL, DE 
1159			 
1159			      ; An allocated block must have a null next block pointer in it 
1159			      ld    A, (HL) 
1159			      inc   HL 
1159			      or    (HL) 
1159			      jp    NZ, free_done 
1159			 
1159			      dec   HL 
1159			 
1159			      ld    B, H                    ; Copy HL to BC 
1159			      ld    C, L 
1159			 
1159			      ; Loop through the free list to find the first block with an address 
1159			      ; higher than the block being freed 
1159			      ld    HL, free_list 
1159			 
1159			free_find_higher_block: 
1159			      ld    E, (HL)                 ; Load next ptr from free block 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      dec   HL 
1159			 
1159			      ld    (IX+0), E               ; Save ptr to next free block 
1159			      ld    (IX+1), D 
1159			      ld    (IX+2), L               ; Save ptr to prev free block 
1159			      ld    (IX+3), H 
1159			 
1159			      ld    A, B                    ; Check if DE is greater than BC 
1159			      cp    D                       ; Compare MSB first 
1159			      jr    Z, $+4                  ; MSB the same, compare LSB 
1159			      jr    NC, free_find_higher_block_skip 
1159			      ld    A, C 
1159			      cp    E                       ; Then compare LSB 
1159			      jr    C, free_found_higher_block 
1159			 
1159			free_find_higher_block_skip: 
1159			      ld    A, D                    ; Reached the end of the free list? 
1159			      or    E 
1159			      jp    Z, free_done 
1159			 
1159			      ex    DE, HL 
1159			 
1159			      jr    free_find_higher_block 
1159			 
1159			free_found_higher_block: 
1159			      ; Insert freed block between prev and next free blocks 
1159			      ld    (HL), C                 ; Point prev free block to freed block 
1159			      inc   HL 
1159			      ld    (HL), B 
1159			 
1159			      ld    H, B                    ; Point freed block at next free block 
1159			      ld    L, C 
1159			      ld    (HL), E 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			      ; Check if the freed block is adjacent to the next free block 
1159			      inc   HL                      ; Load size of freed block into HL 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      ex    DE, HL 
1159			 
1159			      add   HL, BC                  ; Add addr of freed block and its size 
1159			 
1159			      ld    E, (IX+0)               ; Load addr of next free block into DE 
1159			      ld    D, (IX+1) 
1159			 
1159			      or    A                       ; Clear the carry flag 
1159			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1159			      jr    NZ, free_check_adjacent_to_prev 
1159			 
1159			      ; Freed block is adjacent to next, merge into one bigger block 
1159			      ex    DE, HL                  ; Load next ptr from next block into DE 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      push  HL                      ; Save ptr to next block for later 
1159			 
1159			      ld    H, B                    ; Store ptr from next block into freed block 
1159			      ld    L, C 
1159			      ld    (HL), E 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			      pop   HL                      ; Restore ptr to next block 
1159			      inc   HL                      ; Load size of next block into DE 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      push  DE                      ; Save next block size for later 
1159			 
1159			      ld    H, B                    ; Load size of freed block into HL 
1159			      ld    L, C 
1159			      inc   HL 
1159			      inc   HL 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      ex    DE, HL 
1159			 
1159			      pop   DE                      ; Restore size of next block 
1159			      add   HL, DE                  ; Add sizes of both blocks 
1159			      ex    DE, HL 
1159			 
1159			      ld    H, B                    ; Store new bigger size into freed block 
1159			      ld    L, C 
1159			      inc   HL 
1159			      inc   HL 
1159			      ld    (HL), E 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			free_check_adjacent_to_prev: 
1159			      ; Check if the freed block is adjacent to the prev free block 
1159			      ld    L, (IX+2)               ; Prev free block ptr into HL 
1159			      ld    H, (IX+3) 
1159			 
1159			      inc   HL                      ; Size of prev free block into DE 
1159			      inc   HL 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      dec   HL 
1159			      dec   HL 
1159			      dec   HL 
1159			 
1159			      add   HL, DE                  ; Add prev block addr and size 
1159			 
1159			      or    A                       ; Clear the carry flag 
1159			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1159			      jr    NZ, free_done 
1159			 
1159			      ; Freed block is adjacent to prev, merge into one bigger block 
1159			      ld    H, B                    ; Load next ptr from freed block into DE 
1159			      ld    L, C 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      push  HL                      ; Save freed block ptr for later 
1159			 
1159			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1159			      ld    H, (IX+3) 
1159			      ld    (HL), E 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			      pop   HL                      ; Restore freed block ptr 
1159			      inc   HL                      ; Load size of freed block into DE 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			      push  DE                      ; Save freed block size for later 
1159			 
1159			      ld    L, (IX+2)               ; Load size of prev block into DE 
1159			      ld    H, (IX+3) 
1159			      inc   HL 
1159			      inc   HL 
1159			      ld    E, (HL) 
1159			      inc   HL 
1159			      ld    D, (HL) 
1159			 
1159			      pop   HL                      ; Add sizes of both blocks 
1159			      add   HL, DE 
1159			      ex    DE, HL 
1159			 
1159			      ld    L, (IX+2)               ; Store new bigger size into prev block 
1159			      ld    H, (IX+3) 
1159			      inc   HL 
1159			      inc   HL 
1159			      ld    (HL), E 
1159			      inc   HL 
1159			      ld    (HL), D 
1159			 
1159			free_done: 
1159			      ld    HL, 4                   ; Clean up stack frame 
1159			      add   HL, SP 
1159			      ld    SP, HL 
1159			 
1159			free_early_exit: 
1159			      pop   IX 
1159			      pop   DE 
1159			      pop   BC 
1159			 
1159			      ret 
1159			 
1159			 
1159			;      .org 0x8000 
1159			; 
1159			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
1159			 ;                 .dw   0 
1159			 
1159			endif 
1159			 
1159			 
1159			if MALLOC_4 
1159			 
1159			; My memory allocation code. Very very simple.... 
1159			; allocate space under 250 chars 
1159			 
1159			heap_init: 
1159				; init start of heap as zero 
1159				;  
1159			 
1159				ld hl, heap_start 
1159			;	ld a, 0 
1159				ld (hl), 0      ; empty block 
1159				inc hl 
1159			;	ld a, 0 
1159				ld (hl), 0      ; length of block 
1159				; write end of list 
1159				inc hl 
1159				ld a,(hl) 
1159				inc hl 
1159				ld a,(hl) 
1159				 
1159			 
1159				; init some malloc vars 
1159			 
1159				ld hl, 0 
1159				ld (free_list), hl       ; store last malloc location 
1159			 
1159				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
1159			;	ld a, 0 
1159				ld (hl), 0 
1159			 
1159			 
1159				ld hl, heap_start 
1159				;  
1159				  
1159				ret 
1159			 
1159			 
1159			;    free block marker 
1159			;    requested size  
1159			;    pointer to next block 
1159			;    .... 
1159			;    next block marker 
1159			 
1159			 
1159			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
1159			; 
1159			 
1159			 
1159			malloc:  
1159				push de 
1159				push bc 
1159				push af 
1159			 
1159				; hl space required 
1159				 
1159				ld c, l    ; hold space   (TODO only a max of 255) 
1159			 
1159			;	inc c     ; TODO BUG need to fix memory leak on push str 
1159			;	inc c 
1159			;	inc c 
1159			;	inc c 
1159			;	inc c 
1159			;	inc c 
1159			;	inc c 
1159			 
1159			 
1159			 
1159				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
1159			 
1159				ld a, (free_list+3) 
1159			;	cp 0 
1159				or a 
1159				jr z, .contheap 
1159			 
1159				ld hl, (free_list)     ; get last alloc 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "mrs" 
1159						CALLMONITOR 
1159					endif 
1159				jr .startalloc 
1159			 
1159			.contheap: 
1159				ld hl, heap_start 
1159			 
1159			.startalloc: 
1159			 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "mym" 
1159						CALLMONITOR 
1159					endif 
1159			.findblock: 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "mmf" 
1159						CALLMONITOR 
1159					endif 
1159			 
1159				ld a,(hl)  
1159				; if byte is zero then clear to use 
1159			 
1159			;	cp 0 
1159				or a 
1159				jr z, .foundemptyblock 
1159			 
1159				; if byte is not clear 
1159				;     then byte is offset to next block 
1159			 
1159				inc hl 
1159				ld a, (hl) ; get size 
1159			.nextblock:	inc hl 
1159					ld e, (hl) 
1159					inc hl 
1159					ld d, (hl) 
1159					ex de, hl 
1159			;	inc hl  ; move past the store space 
1159			;	inc hl  ; move past zero index  
1159			 
1159				; TODO detect no more space 
1159			 
1159				push hl 
1159				ld de, heap_end 
1159				call cmp16 
1159				pop hl 
1159				jr nc, .nospace 
1159			 
1159				jr .findblock 
1159			 
1159			.nospace: ld hl, 0 
1159				jp .exit 
1159			 
1159			 
1159			.foundemptyblock:	 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "mme" 
1159						CALLMONITOR 
1159					endif 
1159			 
1159			; TODO has block enough space if reusing??? 
1159			 
1159				;  
1159			 
1159			; see if this block has been previously used 
1159				inc hl 
1159				ld a, (hl) 
1159				dec hl 
1159			;	cp 0 
1159				or a 
1159				jr z, .newblock 
1159			 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "meR" 
1159						CALLMONITOR 
1159					endif 
1159			 
1159			; no reusing previously allocated block 
1159			 
1159			; is it smaller than previously used? 
1159				 
1159				inc hl    ; move to size 
1159				ld a, c 
1159				sub (hl)        ; we want c < (hl) 
1159				dec hl    ; move back to marker 
1159			        jr z, .findblock 
1159			 
1159				; update with the new size which should be lower 
1159			 
1159			        ;inc  hl   ; negate next move. move back to size  
1159			 
1159			.newblock: 
1159				; need to be at marker here 
1159			 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "meN" 
1159						CALLMONITOR 
1159					endif 
1159			 
1159			 
1159				ld a, c 
1159			 
1159				ld (free_list+3), a	 ; flag resume from last malloc  
1159				ld (free_list), hl    ; save out last location 
1159			 
1159			 
1159				;inc a     ; space for length byte 
1159				ld (hl), a     ; save block in use marker 
1159			 
1159				inc hl   ; move to space marker 
1159				ld (hl), a    ; save new space 
1159			 
1159				inc hl   ; move to start of allocated area 
1159				 
1159			;	push hl     ; save where we are - 1  
1159			 
1159			;	inc hl  ; move past zero index  
1159				; skip space to set down new marker 
1159			 
1159				; provide some extra space for now 
1159			 
1159				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
1159				inc a 
1159				inc a 
1159			 
1159				push hl   ; save where we are in the node block 
1159			 
1159				call addatohl 
1159			 
1159				; write linked list point 
1159			 
1159				pop de     ; get our node position 
1159				ex de, hl 
1159			 
1159				ld (hl), e 
1159				inc hl 
1159				ld (hl), d 
1159			 
1159				inc hl 
1159			 
1159				; now at start of allocated data so save pointer 
1159			 
1159				push hl 
1159			 
1159				; jump to position of next node and setup empty header in DE 
1159			 
1159				ex de, hl 
1159			 
1159			;	inc hl ; move past end of block 
1159			 
1159			;	ld a, 0 
1159				ld (hl), 0   ; empty marker 
1159				inc hl 
1159				ld (hl), 0   ; size 
1159				inc hl  
1159				ld (hl), 0   ; ptr 
1159				inc hl 
1159				ld (hl), 0   ; ptr 
1159			 
1159			 
1159				pop hl 
1159			 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "mmr" 
1159						CALLMONITOR 
1159					endif 
1159			 
1159			.exit: 
1159				pop af 
1159				pop bc 
1159				pop de  
1159				ret 
1159			 
1159			 
1159			 
1159			 
1159			free:  
1159				push hl 
1159				push af 
1159				; get address in hl 
1159			 
1159					if DEBUG_FORTH_MALLOC_INT 
1159						DMARK "fre" 
1159						CALLMONITOR 
1159					endif 
1159				; data is at hl - move to block count 
1159				dec hl 
1159				dec hl    ; get past pointer 
1159				dec hl 
1159			 
1159				ld a, (hl)    ; need this for a validation check 
1159			 
1159				dec hl    ; move to block marker 
1159			 
1159				; now check that the block count and block marker are the same  
1159			        ; this checks that we are on a malloc node and not random memory 
1159			        ; OK a faint chance this could be a problem but rare - famous last words! 
1159			 
1159				ld c, a 
1159				ld a, (hl)    
1159			 
1159				cp c 
1159				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
1159			 
1159				; yes good chance we are on a malloc node 
1159			 
1159			;	ld a, 0      
1159				ld (hl), 0   ; mark as free 
1159			 
1159				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
1159			 
1159			.freeignore:  
1159			 
1159				pop af 
1159				pop hl 
1159			 
1159				ret 
1159			 
1159			 
1159			 
1159			endif 
