0fb9			BYTERD: 
0fb9 16 00			LD	D,00h		;Set up 
0fbb cd c3 0f			CALL	HEXCON		;Get byte and convert to hex 
0fbe 87				ADD	A,A		;First nibble so 
0fbf 87				ADD	A,A		;multiply by 16 
0fc0 87				ADD	A,A		; 
0fc1 87				ADD	A,A		; 
0fc2 57				LD	D,A		;Save hi nibble in D 
0fc3			HEXCON: 
0fc3 7e				ld a, (hl)		;Get next chr 
0fc4 23				inc hl 
0fc5 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
0fc7 fe 0a			CP	00Ah		;Is it 0-9 ? 
0fc9 38 02			JR	C,NALPHA	;If so miss next bit 
0fcb d6 07			SUB	007h		;Else convert alpha 
0fcd			NALPHA: 
0fcd b2				OR	D		;Add hi nibble back 
0fce c9				RET			; 
