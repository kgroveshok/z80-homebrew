249a 15				db WORD_SYS_CORE+OPCODE_HEAP             
249b b4 24			dw .HEAP            
249d 04				db 3 + 1 
249e .. 00			db "NEW",0              
24a2				endm 
# End of macro CWHEAD
24a2			; | NEW ( -- ) Clears all user words and stack | DONE 
24a2				 
24a2				if MALLOC_4 
24a2					call  heap_init 
24a2				endif 
24a2				; reset uword pointers 
24a2 21 00 80			ld hl, baseram 
24a5 22 dc f3			ld (os_last_new_uword), hl 
24a8 cd ee 22			call user_word_eol 
24ab				; clear stack 
24ab cd 07 23			call forth_warmstart 
24ae				NEXTW 
24ae cd a3 fd			call parse_vector 
24b1 c3 61 23			jp macro_next 
24b4				endm 
# End of macro NEXTW
