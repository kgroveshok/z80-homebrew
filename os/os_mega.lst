4cc9			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4cc9			; | | e.g. 
4cc9			; | | $01 OPEN $01 DO READ . LOOP 
4cc9			; | | 
4cc9			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4cc9			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4cc9			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4cc9			; | | two bytes contain the file id and extent. 
4cc9			; | |  
4cc9			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4cc9			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4cc9			; | | > [!NOTE] 
4cc9			; | | > Compatible with PicoSPINet  
4cc9			 
4cc9					if DEBUG_FORTH_WORDS_KEY 
4cc9						DMARK "REA" 
4cc9				if DEMARK_VERSION = 1  
4cc9 e5					push hl  
4cca 21 d2 4c				ld hl, .dmark  
4ccd 22 9b fd				ld (debug_mark), hl  
4cd0				endif  
