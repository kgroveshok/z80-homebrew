8ddf			if MALLOC_2 
8ddf			; Z80 Malloc and Free Functions 
8ddf			 
8ddf			; Malloc Function: 
8ddf			; Input: 
8ddf			;   HL: Size of block to allocate 
8ddf			; Output: 
8ddf			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8ddf			 
8ddf			malloc: 
8ddf				 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf			call malloc_guard_entry 
8ddf			endif 
8ddf			 
8ddf			 
8ddf			 
8ddf			 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "mal" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			    push af            ; Save AF register 
8ddf			    ld a, l            ; Load low byte of size into A 
8ddf			    or h               ; Check if size is zero 
8ddf			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
8ddf			 
8ddf			    ; Allocate memory 
8ddf			    ld hl, (heap_start) ; Load start of heap into HL 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "ma1" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			    call malloc_internal ; Call internal malloc function 
8ddf			    pop af             ; Restore AF register 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret                ; Return 
8ddf			 
8ddf			; Free Function: 
8ddf			; Input: 
8ddf			;   HL: Pointer to memory block to free 
8ddf			; Output: 
8ddf			;   None 
8ddf			 
8ddf			free: 
8ddf			    push af            ; Save AF register 
8ddf			    ld a, l            ; Load low byte of pointer into A 
8ddf			    or h               ; Check if pointer is NULL 
8ddf			    jp z, free_exit    ; If pointer is NULL, exit 
8ddf			 
8ddf			    ; Free memory 
8ddf			    ld hl, (heap_start) ; Load start of heap into HL 
8ddf			    call free_internal  ; Call internal free function 
8ddf			    pop af             ; Restore AF register 
8ddf			    ret                ; Return 
8ddf			 
8ddf			; Internal Malloc Function: 
8ddf			; Input: 
8ddf			;   HL: Size of block to allocate 
8ddf			; Output: 
8ddf			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8ddf			 
8ddf			malloc_internal: 
8ddf			    ld bc, 2           ; Number of bytes to allocate for management overhead 
8ddf			    add hl, bc         ; Add management overhead to requested size 
8ddf			    ex de, hl          ; Save total size in DE, and keep it in HL 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "ma2" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			 
8ddf			    ; Search for free memory block 
8ddf			    ld de, (heap_end)  ; Load end of heap into DE 
8ddf			    ld bc, 0           ; Initialize counter 
8ddf			 
8ddf					if DEBUG_FORTH_MALLOC 
8ddf						DMARK "ma2" 
8ddf						CALLMONITOR 
8ddf					endif 
8ddf			malloc_search_loop: 
8ddf			    ; Check if current block is free 
8ddf			    ld a, (hl)         ; Load current block's status (free or used) 
8ddf			;    cp 0               ; Compare with zero (free) 
8ddf				or a 
8ddf			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
8ddf			 
8ddf			    ; Check if current block is large enough 
8ddf			    ld a, (hl+1)       ; Load high byte of block size 
8ddf			    cp l               ; Compare with low byte of requested size 
8ddf			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
8ddf			 
8ddf			    ld a, (hl+2)       ; Load low byte of block size 
8ddf			    cp h               ; Compare with high byte of requested size 
8ddf			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
8ddf			 
8ddf			    ; Mark block as used 
8ddf			    ld (hl), 0xFF      ; Set status byte to indicate used block 
8ddf			 
8ddf			    ; Calculate remaining space in block 
8ddf			    ld bc, 0           ; Clear BC 
8ddf			    add hl, bc         ; Increment HL to point to start of data block 
8ddf			    add hl, de         ; HL = HL + DE (total size) 
8ddf			    ld bc, 1           ; Number of bytes to allocate for management overhead 
8ddf			    add hl, bc         ; Add management overhead to start of data block 
8ddf			 
8ddf			    ; Save pointer to allocated block in HL 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf						DMARK "ma5" 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret 
8ddf			 
8ddf			malloc_skip_block_check: 
8ddf			    ; Move to the next block 
8ddf			    ld bc, 3           ; Size of management overhead 
8ddf			    add hl, bc         ; Move to the next block 
8ddf			    inc de             ; Increment counter 
8ddf			 
8ddf			    ; Check if we have reached the end of heap 
8ddf			    ld a, e            ; Load low byte of heap end address 
8ddf			    cp (hl)            ; Compare with low byte of current address 
8ddf			    jr nz, malloc_search_loop  ; If not equal, continue searching 
8ddf			    ld a, d            ; Load high byte of heap end address 
8ddf			;    cp 0               ; Check if it's zero (end of memory) 
8ddf				or a 
8ddf			    jr nz, malloc_search_loop  ; If not zero, continue searching 
8ddf			 
8ddf			    ; If we reached here, allocation failed 
8ddf			    xor a              ; Set result to NULL 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf						DMARK "ma6" 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret 
8ddf			malloc_exit: 
8ddf			if DEBUG_FORTH_MALLOC_HIGH 
8ddf						DMARK "ma7" 
8ddf			call malloc_guard_exit 
8ddf			call malloc_guard_zerolen 
8ddf			endif 
8ddf			    ret 
8ddf			 
8ddf			; Internal Free Function: 
8ddf			; Input: 
8ddf			;   HL: Pointer to memory block to free 
8ddf			; Output: 
8ddf			;   None 
8ddf			 
8ddf			free_internal: 
8ddf			    ld de, (heap_start) ; Load start of heap into DE 
8ddf			    ld bc, 0            ; Initialize counter 
8ddf			 
8ddf			free_search_loop: 
8ddf			    ; Check if current block contains the pointer 
8ddf			    ld a, l             ; Load low byte of pointer 
8ddf			    cp (hl+1)           ; Compare with high byte of current block's address 
8ddf			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8ddf			    ld a, h             ; Load high byte of pointer 
8ddf			    cp (hl+2)           ; Compare with low byte of current block's address 
8ddf			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8ddf			 
8ddf			    ; Mark block as free 
8ddf			    ld (hl), 0          ; Set status byte to indicate free block 
8ddf			    ret                 ; Return 
8ddf			 
8ddf			free_skip_block_check: 
8ddf			    ; Move to the next block 
8ddf			    ld bc, 3            ; Size of management overhead 
8ddf			    add hl, bc          ; Move to the next block 
8ddf			    inc de              ; Increment counter 
8ddf			 
8ddf			    ; Check if we have reached the end of heap 
8ddf			    ld a, e             ; Load low byte of heap end address 
8ddf			    cp (hl)             ; Compare with low byte of current address 
8ddf			    jr nz, free_search_loop  ; If not equal, continue searching 
8ddf			    ld a, d             ; Load high byte of heap end address 
8ddf			;    cp 0                ; Check if it's zero (end of memory) 
8ddf				or a 
8ddf			    jr nz, free_search_loop  ; If not zero, continue searching 
8ddf			 
8ddf			    ; If we reached here, pointer is not found in heap 
8ddf			    ret 
8ddf			 
8ddf			free_exit: 
8ddf			    ret                 ; Return 
8ddf			 
8ddf			; Define heap start and end addresses 
8ddf			;heap_start:    .dw 0xC000   ; Start of heap 
8ddf			;heap_end:      .dw 0xE000   ; End of heap 
8ddf			 
8ddf			endif 
8ddf			 
8ddf			 
8ddf			if MALLOC_1 
8ddf			 
8ddf			 
8ddf			 
8ddf			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
8ddf			 
8ddf			;moved to firmware.asm 
8ddf			;heap_start        .equ  0x9000      ; Starting address of heap 
8ddf			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8ddf			 
8ddf			;      .org 0 
8ddf			;      jp    main 
8ddf			 
8ddf			 
8ddf			;      .org  0x100 
8ddf			;main: 
8ddf			;      ld    HL, 0x8100 
8ddf			;      ld    SP, HL 
8ddf			; 
8ddf			;      call  heap_init 
8ddf			; 
8ddf			;      ; Make some allocations 
8ddf			;      ld    HL, 12 
8ddf			;      call  malloc            ; Allocates 0x9004 
8ddf			; 
8ddf			;      ld    HL, 12 
8ddf			;      call  malloc            ; Allocates 0x9014 
8ddf			; 
8ddf			;      ld    HL, 12 
8ddf			;      call  malloc            ; Allocates 0x9024 
8ddf			; 
8ddf			;      ; Free some allocations 
8ddf			;      ld    HL, 0x9014 
8ddf			;      call  free 
8ddf			; 
8ddf			;      ld    HL, 0x9004 
8ddf			;      call  free 
8ddf			; 
8ddf			;      ld    HL, 0x9024 
8ddf			;      call  free 
8ddf			; 
8ddf			; 
8ddf			;      halt 
8ddf			 
8ddf			 
8ddf			;------------------------------------------------------------------------------ 
8ddf			;     heap_init                                                               : 
8ddf			;                                                                             : 
8ddf			; Description                                                                 : 
8ddf			;     Initialise the heap and make it ready for malloc and free operations.   : 
8ddf			;                                                                             : 
8ddf			;     The heap is maintained as a linked list, starting with an initial       : 
8ddf			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8ddf			;     the first free block in the heap. Each block then points to the next    : 
8ddf			;     free block within the heap, and the free list ends at the first block   : 
8ddf			;     with a null pointer to the next free block.                             : 
8ddf			;                                                                             : 
8ddf			; Parameters                                                                  : 
8ddf			;     Inputs are compile-time only. Two defines which specify the starting    : 
8ddf			;     address of the heap and its size are required, along with a memory      : 
8ddf			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8ddf			;     principally stores a pointer to the first free block in the heap.       : 
8ddf			;                                                                             : 
8ddf			; Returns                                                                     : 
8ddf			;     Nothing                                                                 : 
8ddf			;------------------------------------------------------------------------------ 
8ddf			heap_init: 
8ddf e5			      push  HL 
8de0			 
8de0			      ; Initialise free list struct 
8de0 21 ae d0		      ld    HL, heap_start 
8de3 22 a9 d0		      ld    (free_list), HL 
8de6 21 00 00		      ld    HL, 0 
8de9 22 ab d0		      ld    (free_list+2), HL 
8dec			 
8dec			      ; Insert first free block at bottom of heap, consumes entire heap 
8dec 21 8d e2		      ld    HL, heap_start+heap_size-4 
8def 22 ae d0		      ld    (heap_start), HL        ; Next block (end of free list) 
8df2 21 df 11		      ld    HL, heap_size-4 
8df5 22 b0 d0		      ld    (heap_start+2), HL      ; Block size 
8df8			 
8df8			      ; Insert end of free list block at top of heap - two null words will 
8df8			      ; terminate the free list 
8df8 21 00 00		      ld    HL, 0 
8dfb 22 8f e2		      ld    (heap_start+heap_size-2), HL 
8dfe 22 8d e2		      ld    (heap_start+heap_size-4), HL 
8e01			 
8e01 e1			      pop   HL 
8e02			 
8e02 c9			      ret 
8e03			 
8e03			 
8e03			;------------------------------------------------------------------------------ 
8e03			;     malloc                                                                  : 
8e03			;                                                                             : 
8e03			; Description                                                                 : 
8e03			;     Allocates the wanted space from the heap and returns the address of the : 
8e03			;     first useable byte of the allocation.                                   : 
8e03			;                                                                             : 
8e03			;     Allocations can happen in one of two ways:                              : 
8e03			;                                                                             : 
8e03			;     1. A free block may be found which is the exact size wanted. In this    : 
8e03			;        case the block is removed from the free list and retuedn to the      : 
8e03			;        caller.                                                              : 
8e03			;     2. A free block may be found which is larger than the size wanted. In   : 
8e03			;        this case, the larger block is split into two. The first portion of  : 
8e03			;        this block will become the requested space by the malloc call and    : 
8e03			;        is returned to the caller. The second portion becomes a new free     : 
8e03			;        block, and the free list is adjusted to maintain continuity via this : 
8e03			;        newly created block.                                                 : 
8e03			;                                                                             : 
8e03			;     malloc does not set any initial value in the allocated space, the       : 
8e03			;     caller is required to do this as required.                              : 
8e03			;                                                                             : 
8e03			;     This implementation of malloc uses the stack exclusively, and is        : 
8e03			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8e03			;     advisable to disable interrupts before calling malloc, and recommended  : 
8e03			;     to avoid the use of malloc inside ISRs in general.                      : 
8e03			;                                                                             : 
8e03			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8e03			;                                                                             : 
8e03			; Parameters                                                                  : 
8e03			;     HL  Number of bytes wanted                                              : 
8e03			;                                                                             : 
8e03			; Returns                                                                     : 
8e03			;     HL  Address of the first useable byte of the allocation                 : 
8e03			;                                                                             : 
8e03			; Flags                                                                       : 
8e03			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8e03			;                                                                             : 
8e03			; Stack frame                                                                 : 
8e03			;       |             |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |     BC      |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |     DE      |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |     IX      |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |  prev_free  |                                                       : 
8e03			;   +4  +-------------+                                                       : 
8e03			;       |  this_free  |                                                       : 
8e03			;   +2  +-------------+                                                       : 
8e03			;       |  next_free  |                                                       : 
8e03			;   +0  +-------------+                                                       : 
8e03			;       |             |                                                       : 
8e03			;                                                                             : 
8e03			;------------------------------------------------------------------------------ 
