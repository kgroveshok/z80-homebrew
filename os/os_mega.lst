694e			; **********************************************************************  
694e			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
694e			; **********************************************************************  
694e			;  
694e			; **  Written as a Small Computer Monitor App  
694e			; **  www.scc.me.uk  
694e			;  
694e			; History  
694e			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
694e			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
694e			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
694e			;  
694e			; **********************************************************************  
694e			;  
694e			; This program is an example of one of the methods of interfacing an   
694e			; alphanumeric LCD module.   
694e			;  
694e			; In this example the display is connected to either a Z80 PIO or a   
694e			; simple 8-bit output port.   
694e			;  
694e			; This interfacing method uses 4-bit data mode and uses time delays  
694e			; rather than polling the display's ready status. As a result the   
694e			; interface only requires 6 simple output lines:  
694e			;   Output bit 0 = not used  
694e			;   Output bit 1 = not used  
694e			;   Output bit 2 = RS         High = data, Low = instruction  
694e			;   Output bit 3 = E          Active high  
694e			;   Output bit 4 = DB4  
694e			;   Output bit 5 = DB5  
694e			;   Output bit 6 = DB6  
694e			;   Output bit 7 = DB7  
694e			; Display's R/W is connected to 0v so it is always in write mode  
694e			;  
694e			; This set up should work with any system supporting the RC2014 bus  
694e			  
694e			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
694e			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
694e			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
694e			;  
694e			; **********************************************************************  
694e			  
694e			; Additonal for 4x40. E1 and E2 instead of just E   
694e			; TODO swipe vidout signal on port a to activate E2  
694e			  
694e			; **********************************************************************  
694e			; **  Constants  
694e			; **********************************************************************  
694e			; LCD constants required by LCD support module  
694e			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
694e			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
694e			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
694e			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VICLK  
694e			kLCDBitLED:   EQU 1              ;Port bit for LCD E2 signal            VIDDO  
694e			; TODO Decide which E is being set  
694e			kLCDWidth:  EQU display_cols             ;Width in characters  
694e			  
694e			; **********************************************************************  
694e			; **  Code library usage  
694e			; **********************************************************************  
694e			  
694e			; send character to current cursor position  
694e			; wraps and/or scrolls screen automatically  
694e			  
694e			  
694e			  
