89d5 21 00 00		     ld hl,0         ;10         10 
89d8 29			       add hl,hl     ;11*8       88 
89d9 07			       rlca          ;4*8        32 
89da 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
89dc 19			         add hl,de   ;--         -- 
89dd 10 f9		       djnz $-5      ;13*7+8     99 
89df c9			ret 
