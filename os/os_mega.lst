2319				db WORD_SYS_CORE+opcode             
2319				; internal op code number 
2319				dw nxtword            
2319				; link to next dict word block 
2319				db len + 1 
2319				; literal length of dict word inc zero term 
2319				db lit,0              
2319				; literal dict word 
2319			        ; TODO db opflags        
2319				endm 
