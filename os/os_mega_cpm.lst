0f86				push de 
0f86				push af 
0f86			 
0f86			 	or a      ;clear carry flag 
0f86				push hl 
0f86				ld de, 255 
0f86				sbc hl, de 
0f86				jr c, .lowallocx 
0f86			 
0f86				push de 
0f86					ld hl, display_fb0 
0f86					ld (display_fb_active), hl 
