738a			 
738a			; handle the auto run of code from files in storage 
738a			 
738a			 
738a			include "forth_startup.asm" 
738a			; Which startup method to use? 
738a			; 
738a			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
738a			; followed by loading of a list of scripts in eeprom 
738a			 
738a			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
738a			; from eeprom 
738a			 
738a			; Select with define in main stubs 
738a			 
738a			if STARTUP_V1 
738a				include "forth_startupv1.asm" 
738a			endif 
738a			if STARTUP_V2 
738a				include "forth_startupv2.asm" 
738a			; Version 2 of the startup  
738a			;  
738a			; Auto load any files in bank 1 that start with a '*' 
738a			; If no se storage then revert to using eprom 
738a			 
738a			 
738a			if STORAGE_SE = 0 
738a			 
738a			sprompt1: db "Startup load...",0 
738a			sprompt2: db "Run? 1=No *=End #=All",0 
738a			 
738a			 
738a			 
738a			 
738a			forth_startup: 
738a				ld hl, startcmds 
738a				ld a, 0 
738a				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
738a			 
738a			.start1:	push hl 
738a				call clear_display 
738a				ld de, sprompt1 
738a			        ld a, display_row_1 
738a				call str_at_display 
738a				ld de, sprompt2 
738a			        ld a, display_row_2 
738a				call str_at_display 
738a				pop hl 
738a				push hl 
738a				ld e,(hl) 
738a				inc hl 
738a				ld d,(hl) 
738a			        ld a, display_row_3 
738a				call str_at_display 
738a				call update_display 
738a			 
738a			 
738a				ld a, (os_last_cmd) 
738a			;	cp 0 
738a				or a 
738a				jr z, .startprompt 
738a				call delay250ms 
738a				jr .startdo 
738a				 
738a				 
738a			 
738a			.startprompt: 
738a			 
738a				ld a,display_row_4 + display_cols - 1 
738a			        ld de, endprg 
738a				call str_at_display 
738a				call update_display 
738a				call delay1s 
738a				call cin_wait 
738a						 
738a				cp '*' 
738a				jr z, .startupend1 
738a				cp '#' 
738a				jr nz, .startno 
738a				ld a, 1 
738a				ld (os_last_cmd),a 
738a				jr .startdo 
738a			.startno:	cp '1' 
738a				jr z,.startnxt  
738a			 
738a				; exec startup line 
738a			.startdo:	 
738a				pop hl 
738a				push hl 
738a				 
738a				ld e,(hl) 
738a				inc hl 
738a				ld d,(hl) 
738a				ex de,hl 
738a			 
738a				push hl 
738a			 
738a				ld a, 0 
738a				;ld a, FORTH_END_BUFFER 
738a				call strlent 
738a				inc hl   ; include zero term to copy 
738a				ld b,0 
738a				ld c,l 
738a				pop hl 
738a				ld de, scratch 
738a				ldir 
738a			 
738a			 
738a				ld hl, scratch 
738a				call forthparse 
738a				call forthexec 
738a				call forthexec_cleanup 
738a			 
738a				ld a, display_row_4 
738a				ld de, endprog 
738a			 
738a				call update_display		 
738a			 
738a				ld a, (os_last_cmd) 
738a			;	cp 0 
738a				or a 
738a				jr nz, .startnxt 
738a				call next_page_prompt 
738a			        call clear_display 
738a				call update_display		 
738a			 
738a				; move onto next startup line? 
738a			.startnxt: 
738a			 
738a				call delay250ms 
738a				pop hl 
738a			 
738a				inc hl 
738a				inc hl 
738a			 
738a				push hl 
738a				ld e, (hl) 
738a				inc hl 
738a				ld d, (hl) 
738a				pop hl 
738a				; TODO replace 0 test 
738a			 
738a				ex de, hl 
738a				call ishlzero 
738a			;	ld a,e 
738a			;	add d 
738a			;	cp 0    ; any left to do? 
738a				ex de, hl 
738a				jp nz, .start1 
738a				jr .startupend 
738a			 
738a			.startupend1: pop hl 
738a			.startupend: 
738a			 
738a				call clear_display 
738a				call update_display 
738a				ret 
738a			endif 
738a			 
