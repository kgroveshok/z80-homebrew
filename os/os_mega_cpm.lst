57ca			; stack over and underflow checks 
57ca			 
57ca			; init the words to detect the under/overflow 
57ca			 
57ca			chk_stk_init: 
57ca				; a vague random number to check so we dont get any "lucky" hits 
57ca 3e 2d			ld a, 45 
57cc 6f				ld l, a 
57cd 00				nop 
57ce 3e 17			ld a, 23 
57d0 67				ld h, a 
57d1			 
57d1 22 92 e2			ld (chk_word), hl     ; the word we need to check against 
57d4			 
57d4			;	ld (chk_stund), hl	; stack points.... 
57d4 22 00 ef			ld (chk_stovr), hl 
57d7 22 e1 e9			ld (chk_ret_und), hl 
57da 22 9f e9			ld (chk_ret_ovr), hl 
57dd 22 1d e9			ld (chk_loop_ovr), hl 
57e0 22 1b e8			ld (chk_data_ovr), hl 
57e3 c9				ret 
57e4				 
57e4			check_stacks: 
57e4				; check all stack words 
57e4			 
57e4 e5				push hl 
57e5 d5				push de 
57e6			 
57e6			;	ld de,(chk_word) 
57e6			;	ld hl, (chk_stund)	; stack points.... 
57e6			;	if DEBUG_STK_FAULT 
57e6			;		DMARK "FAa" 
57e6			;		CALLMONITOR 
57e6			;	endif 
57e6			;	call cmp16 
57e6			;	jp z, .chk_faulta 
57e6			; 
57e6			;	ld de, sfaultsu 
57e6			;	jp .chk_fault 
57e6			 
57e6 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
57e9 ed 5b 92 e2		ld de,(chk_word) 
57ed				if DEBUG_STK_FAULT 
57ed					DMARK "FAb" 
57ed					CALLMONITOR 
57ed				endif 
57ed cd fc 0b			call cmp16 
57f0 28 06			jr z, .chk_fault1 
57f2 11 97 58			ld de, sfaultso 
57f5 c3 47 58			jp .chk_fault 
57f8			.chk_fault1:  
57f8 2a e1 e9			ld hl, (chk_ret_und) 
57fb ed 5b 92 e2		ld de,(chk_word) 
57ff				if DEBUG_STK_FAULT 
57ff					DMARK "FAU" 
57ff					CALLMONITOR 
57ff				endif 
57ff cd fc 0b			call cmp16 
5802 ca 0b 58			jp z, .chk_fault2 
5805 11 a7 58			ld de, sfaultru 
5808 c3 47 58			jp .chk_fault 
580b			.chk_fault2:  
580b 2a 9f e9			ld hl, (chk_ret_ovr) 
580e ed 5b 92 e2		ld de,(chk_word) 
5812				if DEBUG_STK_FAULT 
5812					DMARK "FA1" 
5812					CALLMONITOR 
5812				endif 
5812 cd fc 0b			call cmp16 
5815 ca 1e 58			jp z, .chk_fault3 
5818 11 b5 58			ld de, sfaultro 
581b c3 47 58			jp .chk_fault 
581e			.chk_fault3:  
