8d29			; DispA 
8d29			; -------------------------------------------------------------- 
8d29			; Converts a signed integer value to a zero-terminated ASCII 
8d29			; string representative of that value (using radix 10). 
8d29			; -------------------------------------------------------------- 
8d29			; INPUTS: 
8d29			;     HL     Value to convert (two's complement integer). 
8d29			;     DE     Base address of string destination. (pointer). 
8d29			; -------------------------------------------------------------- 
8d29			; OUTPUTS: 
8d29			;     None 
8d29			; -------------------------------------------------------------- 
8d29			; REGISTERS/MEMORY DESTROYED 
8d29			; AF HL 
8d29			; -------------------------------------------------------------- 
8d29			 
8d29			;DispHLToASCII: 
8d29			;   push    de 
8d29			;   push    bc 
8d29			; 
8d29			;; Detect sign of HL. 
8d29			;    bit    7, h 
8d29			;    jr     z, ._DoConvert 
8d29			; 
8d29			;; HL is negative. Output '-' to string and negate HL. 
8d29			;    ld     a, '-' 
8d29			;    ld     (de), a 
8d29			;    inc    de 
8d29			; 
8d29			;; Negate HL (using two's complement) 
8d29			;    xor    a 
8d29			;    sub    l 
8d29			;    ld     l, a 
8d29			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
8d29			;    sbc    a, h 
8d29			;    ld     h, a 
8d29			; 
8d29			;; Convert HL to digit characters 
8d29			;._DoConvert: 
8d29			;    ld     b, 0     ; B will count character length of number 
8d29			;-   ld     a, 10 
8d29			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
8d29			;    push   af 
8d29			;    inc    b 
8d29			;    ld     a, h 
8d29			;    or     l 
8d29			;    jr     nz, - 
8d29			; 
8d29			;; Retrieve digits from stack 
8d29			;-   pop    af 
8d29			;    or     $30 
8d29			;    ld     (de), a 
8d29			;    inc    de 
8d29			;    djnz   - 
8d29			; 
8d29			;; Terminate string with NULL 
8d29			;    xor    a 
8d29			;    ld     (de), a 
8d29			; 
8d29			;    pop    bc 
8d29			;    pop    de 
8d29			;    ret 
8d29			 
8d29			;Comments 
8d29			; 
8d29			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
8d29			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
8d29			;    Note that the output string will not be fixed-width. 
8d29			; 
8d29			;Example Usage 
8d29			; 
8d29			;    ld    hl, -1004 
8d29			;    ld    de, OP1 
8d29			;    call  DispA 
8d29			;    ld    hl, OP1 
8d29			;    syscall  PutS 
