0e99			; Decimal Signed Version 
0e99			 
0e99			; DispA 
0e99			; -------------------------------------------------------------- 
0e99			; Converts a signed integer value to a zero-terminated ASCII 
0e99			; string representative of that value (using radix 10). 
0e99			; -------------------------------------------------------------- 
0e99			; INPUTS: 
0e99			;     HL     Value to convert (two's complement integer). 
0e99			;     DE     Base address of string destination. (pointer). 
0e99			; -------------------------------------------------------------- 
0e99			; OUTPUTS: 
0e99			;     None 
0e99			; -------------------------------------------------------------- 
0e99			; REGISTERS/MEMORY DESTROYED 
0e99			; AF HL 
0e99			; -------------------------------------------------------------- 
0e99			 
0e99			;DispHLToASCII: 
0e99			;   push    de 
0e99			;   push    bc 
0e99			; 
0e99			;; Detect sign of HL. 
0e99			;    bit    7, h 
0e99			;    jr     z, ._DoConvert 
0e99			; 
0e99			;; HL is negative. Output '-' to string and negate HL. 
0e99			;    ld     a, '-' 
0e99			;    ld     (de), a 
0e99			;    inc    de 
0e99			; 
0e99			;; Negate HL (using two's complement) 
0e99			;    xor    a 
0e99			;    sub    l 
0e99			;    ld     l, a 
0e99			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
0e99			;    sbc    a, h 
0e99			;    ld     h, a 
0e99			; 
0e99			;; Convert HL to digit characters 
0e99			;._DoConvert: 
0e99			;    ld     b, 0     ; B will count character length of number 
0e99			;-   ld     a, 10 
0e99			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
0e99			;    push   af 
0e99			;    inc    b 
0e99			;    ld     a, h 
0e99			;    or     l 
0e99			;    jr     nz, - 
0e99			; 
0e99			;; Retrieve digits from stack 
0e99			;-   pop    af 
0e99			;    or     $30 
0e99			;    ld     (de), a 
0e99			;    inc    de 
0e99			;    djnz   - 
0e99			; 
0e99			;; Terminate string with NULL 
0e99			;    xor    a 
0e99			;    ld     (de), a 
0e99			; 
0e99			;    pop    bc 
0e99			;    pop    de 
0e99			;    ret 
0e99			 
0e99			;Comments 
0e99			; 
0e99			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
0e99			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
0e99			;    Note that the output string will not be fixed-width. 
0e99			; 
0e99			;Example Usage 
0e99			; 
0e99			;    ld    hl, -1004 
0e99			;    ld    de, OP1 
0e99			;    call  DispA 
0e99			;    ld    hl, OP1 
0e99			;    syscall  PutS 
