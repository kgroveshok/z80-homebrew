0f52				call bp_on 
0f52			 
0f52				pop de 
0f52				pop hl 
0f52			 
0f52				 
0f52			 
0f52				CALLMONITOR 
0f52				jr .lowdone 
0f52			.lowalloc: 
0f52			 
0f52			 
0f52				pop hl 
0f52			.lowdone:	pop af 
0f52				pop de 
0f52				pop hl 
0f52			ret 
0f52			 
0f52			malloc_guard_exit: 
