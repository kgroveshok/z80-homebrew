6606			; handle the auto run of code from files in storage 
6606			 
6606			 
6606			include "forth_startup.asm" 
6606			; Which startup method to use? 
6606			; 
6606			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6606			; followed by loading of a list of scripts in eeprom 
6606			 
6606			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6606			; from eeprom 
6606			 
6606			; Select with define in main stubs 
6606			 
6606			if STARTUP_V1 
6606				include "forth_startupv1.asm" 
6606			endif 
6606			if STARTUP_V2 
6606				include "forth_startupv2.asm" 
6606			; Version 2 of the startup  
6606			;  
6606			; Auto load any files in bank 1 that start with a '*' 
6606			; If no se storage then revert to using eprom 
6606			 
6606			 
6606			if STORAGE_SE = 0 
6606			 
6606			sprompt1: db "Startup load...",0 
6606			sprompt2: db "Run? 1=No *=End #=All",0 
6606			 
6606			 
6606			 
6606			 
6606			forth_startup: 
6606				ld hl, startcmds 
6606				ld a, 0 
6606				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
6606			 
6606			.start1:	push hl 
6606				call clear_display 
6606				ld de, sprompt1 
6606			        ld a, display_row_1 
6606				call str_at_display 
6606				ld de, sprompt2 
6606			        ld a, display_row_2 
6606				call str_at_display 
6606				pop hl 
6606				push hl 
6606				ld e,(hl) 
6606				inc hl 
6606				ld d,(hl) 
6606			        ld a, display_row_3 
6606				call str_at_display 
6606				call update_display 
6606			 
6606			 
6606				ld a, (os_last_cmd) 
6606			;	cp 0 
6606				or a 
6606				jr z, .startprompt 
6606				call delay250ms 
6606				jr .startdo 
6606				 
6606				 
6606			 
6606			.startprompt: 
6606			 
6606				ld a,display_row_4 + display_cols - 1 
6606			        ld de, endprg 
6606				call str_at_display 
6606				call update_display 
6606				call delay1s 
6606				call cin_wait 
6606						 
6606				cp '*' 
6606				jr z, .startupend1 
6606				cp '#' 
6606				jr nz, .startno 
6606				ld a, 1 
6606				ld (os_last_cmd),a 
6606				jr .startdo 
6606			.startno:	cp '1' 
6606				jr z,.startnxt  
6606			 
6606				; exec startup line 
6606			.startdo:	 
6606				pop hl 
6606				push hl 
6606				 
6606				ld e,(hl) 
6606				inc hl 
6606				ld d,(hl) 
6606				ex de,hl 
6606			 
6606				push hl 
6606			 
6606				ld a, 0 
6606				;ld a, FORTH_END_BUFFER 
6606				call strlent 
6606				inc hl   ; include zero term to copy 
6606				ld b,0 
6606				ld c,l 
6606				pop hl 
6606				ld de, scratch 
6606				ldir 
6606			 
6606			 
6606				ld hl, scratch 
6606				call forthparse 
6606				call forthexec 
6606				call forthexec_cleanup 
6606			 
6606				ld a, display_row_4 
6606				ld de, endprog 
6606			 
6606				call update_display		 
6606			 
6606				ld a, (os_last_cmd) 
6606			;	cp 0 
6606				or a 
6606				jr nz, .startnxt 
6606				call next_page_prompt 
6606			        call clear_display 
6606				call update_display		 
6606			 
6606				; move onto next startup line? 
6606			.startnxt: 
6606			 
6606				call delay250ms 
6606				pop hl 
6606			 
6606				inc hl 
6606				inc hl 
6606			 
6606				push hl 
6606				ld e, (hl) 
6606				inc hl 
6606				ld d, (hl) 
6606				pop hl 
6606				; TODO replace 0 test 
6606			 
6606				ex de, hl 
6606				call ishlzero 
6606			;	ld a,e 
6606			;	add d 
6606			;	cp 0    ; any left to do? 
6606				ex de, hl 
6606				jp nz, .start1 
6606				jr .startupend 
6606			 
6606			.startupend1: pop hl 
6606			.startupend: 
6606			 
6606				call clear_display 
6606				call update_display 
6606				ret 
6606			endif 
