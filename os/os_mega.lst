1213			;     free                                                                    : 
1213			;                                                                             : 
1213			; Description                                                                 : 
1213			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1213			;     returned by malloc, otherwise the behaviour is undefined.               : 
1213			;                                                                             : 
1213			;     Where possible, directly adjacent free blocks will be merged together   : 
1213			;     into larger blocks to help ensure that the heap does not become         : 
1213			;     excessively fragmented.                                                 : 
1213			;                                                                             : 
1213			;     free does not clear or set any other value into the freed space, and    : 
1213			;     therefore its contents may be visible through subsequent malloc's. The  : 
1213			;     caller should clear the freed space as required.                        : 
1213			;                                                                             : 
1213			;     This implementation of free uses the stack exclusively, and is          : 
1213			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1213			;     advisable to disable interrupts before calling free, and recommended    : 
1213			;     to avoid the use of free inside ISRs in general.                        : 
1213			;                                                                             : 
1213			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1213			;                                                                             : 
1213			; Parameters                                                                  : 
1213			;     HL  Pointer to address of first byte of allocation to be freed          : 
1213			;                                                                             : 
1213			; Returns                                                                     : 
1213			;     Nothing                                                                 : 
1213			;                                                                             : 
1213			; Stack frame                                                                 : 
1213			;       |             |                                                       : 
1213			;       +-------------+                                                       : 
1213			;       |     BC      |                                                       : 
1213			;       +-------------+                                                       : 
1213			;       |     DE      |                                                       : 
1213			;       +-------------+                                                       : 
1213			;       |     IX      |                                                       : 
1213			;       +-------------+                                                       : 
1213			;       |  prev_free  |                                                       : 
1213			;   +2  +-------------+                                                       : 
1213			;       |  next_free  |                                                       : 
1213			;   +0  +-------------+                                                       : 
1213			;       |             |                                                       : 
1213			;                                                                             : 
1213			;------------------------------------------------------------------------------ 
1213			free: 
1213 c5			      push  BC 
1214 d5			      push  DE 
1215 dd e5		      push  IX 
1217			 
1217 7c			      ld    A, H                    ; Exit if ptr is null 
1218 b5			      or    L 
1219 ca dd 12		      jp    Z, free_early_exit 
121c			 
121c			      ; Set up stack frame 
121c eb			      ex    DE, HL 
121d 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1220 39			      add   HL, SP 
1221 f9			      ld    SP, HL 
1222 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1226 dd 39		      add   IX, SP 
1228			 
1228			      ; The address in HL points to the start of the useable allocated space, 
1228			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1228			      ; address of the block itself. 
1228 eb			      ex    DE, HL 
1229 11 fc ff		      ld    DE, -4 
122c 19			      add   HL, DE 
122d			 
122d			      ; An allocated block must have a null next block pointer in it 
122d 7e			      ld    A, (HL) 
122e 23			      inc   HL 
122f b6			      or    (HL) 
1230 c2 d8 12		      jp    NZ, free_done 
1233			 
1233 2b			      dec   HL 
1234			 
1234 44			      ld    B, H                    ; Copy HL to BC 
1235 4d			      ld    C, L 
1236			 
1236			      ; Loop through the free list to find the first block with an address 
1236			      ; higher than the block being freed 
1236 21 0a 80		      ld    HL, free_list 
1239			 
1239			free_find_higher_block: 
1239 5e			      ld    E, (HL)                 ; Load next ptr from free block 
123a 23			      inc   HL 
123b 56			      ld    D, (HL) 
123c 2b			      dec   HL 
123d			 
123d dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
1240 dd 72 01		      ld    (IX+1), D 
1243 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1246 dd 74 03		      ld    (IX+3), H 
1249			 
1249 78			      ld    A, B                    ; Check if DE is greater than BC 
124a ba			      cp    D                       ; Compare MSB first 
124b 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
124d 30 04		      jr    NC, free_find_higher_block_skip 
124f 79			      ld    A, C 
1250 bb			      cp    E                       ; Then compare LSB 
1251 38 08		      jr    C, free_found_higher_block 
1253			 
1253			free_find_higher_block_skip: 
1253 7a			      ld    A, D                    ; Reached the end of the free list? 
1254 b3			      or    E 
1255 ca d8 12		      jp    Z, free_done 
1258			 
1258 eb			      ex    DE, HL 
1259			 
1259 18 de		      jr    free_find_higher_block 
125b			 
125b			free_found_higher_block: 
125b			      ; Insert freed block between prev and next free blocks 
125b 71			      ld    (HL), C                 ; Point prev free block to freed block 
125c 23			      inc   HL 
125d 70			      ld    (HL), B 
125e			 
125e 60			      ld    H, B                    ; Point freed block at next free block 
125f 69			      ld    L, C 
1260 73			      ld    (HL), E 
1261 23			      inc   HL 
1262 72			      ld    (HL), D 
1263			 
1263			      ; Check if the freed block is adjacent to the next free block 
1263 23			      inc   HL                      ; Load size of freed block into HL 
1264 5e			      ld    E, (HL) 
1265 23			      inc   HL 
1266 56			      ld    D, (HL) 
1267 eb			      ex    DE, HL 
1268			 
1268 09			      add   HL, BC                  ; Add addr of freed block and its size 
1269			 
1269 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
126c dd 56 01		      ld    D, (IX+1) 
126f			 
126f b7			      or    A                       ; Clear the carry flag 
1270 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1272 20 22		      jr    NZ, free_check_adjacent_to_prev 
1274			 
1274			      ; Freed block is adjacent to next, merge into one bigger block 
1274 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1275 5e			      ld    E, (HL) 
1276 23			      inc   HL 
1277 56			      ld    D, (HL) 
1278 e5			      push  HL                      ; Save ptr to next block for later 
1279			 
1279 60			      ld    H, B                    ; Store ptr from next block into freed block 
127a 69			      ld    L, C 
127b 73			      ld    (HL), E 
127c 23			      inc   HL 
127d 72			      ld    (HL), D 
127e			 
127e e1			      pop   HL                      ; Restore ptr to next block 
127f 23			      inc   HL                      ; Load size of next block into DE 
1280 5e			      ld    E, (HL) 
1281 23			      inc   HL 
1282 56			      ld    D, (HL) 
1283 d5			      push  DE                      ; Save next block size for later 
1284			 
1284 60			      ld    H, B                    ; Load size of freed block into HL 
1285 69			      ld    L, C 
1286 23			      inc   HL 
1287 23			      inc   HL 
1288 5e			      ld    E, (HL) 
1289 23			      inc   HL 
128a 56			      ld    D, (HL) 
128b eb			      ex    DE, HL 
128c			 
128c d1			      pop   DE                      ; Restore size of next block 
128d 19			      add   HL, DE                  ; Add sizes of both blocks 
128e eb			      ex    DE, HL 
128f			 
128f 60			      ld    H, B                    ; Store new bigger size into freed block 
1290 69			      ld    L, C 
1291 23			      inc   HL 
1292 23			      inc   HL 
1293 73			      ld    (HL), E 
1294 23			      inc   HL 
1295 72			      ld    (HL), D 
1296			 
1296			free_check_adjacent_to_prev: 
1296			      ; Check if the freed block is adjacent to the prev free block 
1296 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1299 dd 66 03		      ld    H, (IX+3) 
129c			 
129c 23			      inc   HL                      ; Size of prev free block into DE 
129d 23			      inc   HL 
129e 5e			      ld    E, (HL) 
129f 23			      inc   HL 
12a0 56			      ld    D, (HL) 
12a1 2b			      dec   HL 
12a2 2b			      dec   HL 
12a3 2b			      dec   HL 
12a4			 
12a4 19			      add   HL, DE                  ; Add prev block addr and size 
12a5			 
12a5 b7			      or    A                       ; Clear the carry flag 
12a6 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12a8 20 2e		      jr    NZ, free_done 
12aa			 
12aa			      ; Freed block is adjacent to prev, merge into one bigger block 
12aa 60			      ld    H, B                    ; Load next ptr from freed block into DE 
12ab 69			      ld    L, C 
12ac 5e			      ld    E, (HL) 
12ad 23			      inc   HL 
12ae 56			      ld    D, (HL) 
12af e5			      push  HL                      ; Save freed block ptr for later 
12b0			 
12b0 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12b3 dd 66 03		      ld    H, (IX+3) 
12b6 73			      ld    (HL), E 
12b7 23			      inc   HL 
12b8 72			      ld    (HL), D 
12b9			 
12b9 e1			      pop   HL                      ; Restore freed block ptr 
12ba 23			      inc   HL                      ; Load size of freed block into DE 
12bb 5e			      ld    E, (HL) 
12bc 23			      inc   HL 
12bd 56			      ld    D, (HL) 
12be d5			      push  DE                      ; Save freed block size for later 
12bf			 
12bf dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
12c2 dd 66 03		      ld    H, (IX+3) 
12c5 23			      inc   HL 
12c6 23			      inc   HL 
12c7 5e			      ld    E, (HL) 
12c8 23			      inc   HL 
12c9 56			      ld    D, (HL) 
12ca			 
12ca e1			      pop   HL                      ; Add sizes of both blocks 
12cb 19			      add   HL, DE 
12cc eb			      ex    DE, HL 
12cd			 
12cd dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
12d0 dd 66 03		      ld    H, (IX+3) 
12d3 23			      inc   HL 
12d4 23			      inc   HL 
12d5 73			      ld    (HL), E 
12d6 23			      inc   HL 
12d7 72			      ld    (HL), D 
12d8			 
12d8			free_done: 
12d8 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
12db 39			      add   HL, SP 
12dc f9			      ld    SP, HL 
12dd			 
12dd			free_early_exit: 
12dd dd e1		      pop   IX 
12df d1			      pop   DE 
12e0 c1			      pop   BC 
12e1			 
12e1 c9			      ret 
12e2			 
12e2			; moved to firmware.asm 
12e2			; 
12e2			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12e2			;                  .dw   0 
12e2			 
12e2			 
12e2			endif 
12e2			 
12e2			 
12e2			if MALLOC_3 
12e2			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12e2			;heap_start        .equ  0x9000      ; Starting address of heap 
12e2			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12e2			; 
12e2			 ;     .org 0 
12e2			  ;    jp    main 
12e2			; 
12e2			; 
12e2			 ;     .org  0x100 
12e2			;main: 
12e2			 ;     ld    HL, 0x8100 
12e2			  ;    ld    SP, HL 
12e2			; 
12e2			;      call  heap_init 
12e2			 
12e2			      ; Make some allocations 
12e2			;      ld    HL, 12 
12e2			;      call  malloc            ; Allocates 0x9004 
12e2			; 
12e2			 ;     ld    HL, 12 
12e2			;      call  malloc            ; Allocates 0x9014 
12e2			 
12e2			;      ld    HL, 12 
12e2			;      call  malloc            ; Allocates 0x9024 
12e2			 
12e2			      ; Free some allocations 
12e2			;      ld    HL, 0x9014 
12e2			;      call  free 
12e2			 
12e2			;      ld    HL, 0x9004 
12e2			;      call  free 
12e2			; 
12e2			;      ld    HL, 0x9024 
12e2			;      call  free 
12e2			 
12e2			 
12e2			 ;     halt 
12e2			 
12e2			 
12e2			;------------------------------------------------------------------------------ 
12e2			;     heap_init                                                               : 
12e2			;                                                                             : 
12e2			; Description                                                                 : 
12e2			;     Initialise the heap and make it ready for malloc and free operations.   : 
12e2			;                                                                             : 
12e2			;     The heap is maintained as a linked list, starting with an initial       : 
12e2			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12e2			;     the first free block in the heap. Each block then points to the next    : 
12e2			;     free block within the heap, and the free list ends at the first block   : 
12e2			;     with a null pointer to the next free block.                             : 
12e2			;                                                                             : 
12e2			; Parameters                                                                  : 
12e2			;     Inputs are compile-time only. Two defines which specify the starting    : 
12e2			;     address of the heap and its size are required, along with a memory      : 
12e2			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12e2			;     principally stores a pointer to the first free block in the heap.       : 
12e2			;                                                                             : 
12e2			; Returns                                                                     : 
12e2			;     Nothing                                                                 : 
12e2			;------------------------------------------------------------------------------ 
12e2			heap_init: 
12e2			      push  HL 
12e2			 
12e2			      ; Initialise free list struct 
12e2			      ld    HL, heap_start 
12e2			      ld    (free_list), HL 
12e2			      ld    HL, 0 
12e2			      ld    (free_list+2), HL 
12e2			 
12e2			      ; Insert first free block at bottom of heap, consumes entire heap 
12e2			      ld    HL, heap_start+heap_size-4 
12e2			      ld    (heap_start), HL        ; Next block (end of free list) 
12e2			      ld    HL, heap_size-4 
12e2			      ld    (heap_start+2), HL      ; Block size 
12e2			 
12e2			      ; Insert end of free list block at top of heap - two null words will 
12e2			      ; terminate the free list 
12e2			      ld    HL, 0 
12e2			      ld    (heap_start+heap_size-2), HL 
12e2			      ld    (heap_start+heap_size-4), HL 
12e2			 
12e2			      pop   HL 
12e2			 
12e2			      ret 
12e2			 
12e2			 
12e2			;------------------------------------------------------------------------------ 
12e2			;     malloc                                                                  : 
12e2			;                                                                             : 
12e2			; Description                                                                 : 
12e2			;     Allocates the wanted space from the heap and returns the address of the : 
12e2			;     first useable byte of the allocation.                                   : 
12e2			;                                                                             : 
12e2			;     Allocations can happen in one of two ways:                              : 
12e2			;                                                                             : 
12e2			;     1. A free block may be found which is the exact size wanted. In this    : 
12e2			;        case the block is removed from the free list and retuedn to the      : 
12e2			;        caller.                                                              : 
12e2			;     2. A free block may be found which is larger than the size wanted. In   : 
12e2			;        this case, the larger block is split into two. The first portion of  : 
12e2			;        this block will become the requested space by the malloc call and    : 
12e2			;        is returned to the caller. The second portion becomes a new free     : 
12e2			;        block, and the free list is adjusted to maintain continuity via this : 
12e2			;        newly created block.                                                 : 
12e2			;                                                                             : 
12e2			;     malloc does not set any initial value in the allocated space, the       : 
12e2			;     caller is required to do this as required.                              : 
12e2			;                                                                             : 
12e2			;     This implementation of malloc uses the stack exclusively, and is        : 
12e2			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12e2			;     advisable to disable interrupts before calling malloc, and recommended  : 
12e2			;     to avoid the use of malloc inside ISRs in general.                      : 
12e2			;                                                                             : 
12e2			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12e2			;                                                                             : 
12e2			; Parameters                                                                  : 
12e2			;     HL  Number of bytes wanted                                              : 
12e2			;                                                                             : 
12e2			; Returns                                                                     : 
12e2			;     HL  Address of the first useable byte of the allocation                 : 
12e2			;                                                                             : 
12e2			; Flags                                                                       : 
12e2			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12e2			;                                                                             : 
12e2			; Stack frame                                                                 : 
12e2			;       |             |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |     BC      |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |     DE      |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |     IX      |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |  prev_free  |                                                       : 
12e2			;   +4  +-------------+                                                       : 
12e2			;       |  this_free  |                                                       : 
12e2			;   +2  +-------------+                                                       : 
12e2			;       |  next_free  |                                                       : 
12e2			;   +0  +-------------+                                                       : 
12e2			;       |             |                                                       : 
12e2			;                                                                             : 
12e2			;------------------------------------------------------------------------------ 
12e2			malloc: 
12e2			      push  BC 
12e2			      push  DE 
12e2			      push  IX 
12e2			 
12e2			      ld    A, H                    ; Exit if no space requested 
12e2			      or    L 
12e2			      jp    Z, malloc_early_exit 
12e2			 
12e2			      ; Set up stack frame 
12e2			      ex    DE, HL 
12e2			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12e2			      add   HL, SP 
12e2			      ld    SP, HL 
12e2			      ld    IX, 0                   ; Use IX as a frame pointer 
12e2			      add   IX, SP 
12e2			 
12e2			      ; Setup initial state 
12e2			      ld    HL, 4                   ; want must also include space used by block struct 
12e2			      add   HL, DE 
12e2			 
12e2			      ld    B, H                    ; Move want to BC 
12e2			      ld    C, L 
12e2			 
12e2			      ld    HL, free_list           ; Store prev_free ptr to stack 
12e2			      ld    (IX+4), L 
12e2			      ld    (IX+5), H 
12e2			 
12e2			      ld    E, (HL)                 ; Store this_free ptr to stack 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      ld    (IX+2), E 
12e2			      ld    (IX+3), D 
12e2			      ex    DE, HL                  ; this_free ptr into HL 
12e2			 
12e2			      ; Loop through free block list to find some space 
12e2			malloc_find_space: 
12e2			      ld    E, (HL)                 ; Load next_free ptr into DE 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			 
12e2			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12e2			      or    E 
12e2			      jp    Z, malloc_no_space 
12e2			 
12e2			      ld    (IX+0), E               ; Store next_free ptr to stack 
12e2			      ld    (IX+1), D 
12e2			 
12e2			      ; Does this block have enough space to make the allocation? 
12e2			      inc   HL                      ; Load free block size into DE 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			 
12e2			      ex    DE, HL                  ; Check size of block against want 
12e2			      or    A                       ; Ensure carry flag clear 
12e2			      sbc   HL, BC 
12e2			      push  HL                      ; Store the result for later (new block size) 
12e2			 
12e2			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12e2			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12e2			 
12e2			      ; this_free block is not big enough, setup ptrs to test next free block 
12e2			      pop   HL                      ; Discard previous result 
12e2			 
12e2			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12e2			      ld    H, (IX+3) 
12e2			      ld    (IX+4), L 
12e2			      ld    (IX+5), H 
12e2			 
12e2			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12e2			      ld    H, (IX+1) 
12e2			      ld    (IX+2), L 
12e2			      ld    (IX+3), H 
12e2			 
12e2			      jr    malloc_find_space 
12e2			 
12e2			      ; split a bigger block into two - requested size and remaining size 
12e2			malloc_alloc_split: 
12e2			      ex    DE, HL                  ; Calculate address of new free block 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			      add   HL, BC 
12e2			 
12e2			      ; Create a new block and point it at next_free 
12e2			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12e2			      ld    D, (IX+1) 
12e2			 
12e2			      ld    (HL), E                 ; Store next_free ptr into new block 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			      pop   DE                      ; Store size of new block into new block 
12e2			      inc   HL 
12e2			      ld    (HL), E 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			      ; Update this_free ptr to point to new block 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			 
12e2			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12e2			      ld    D, (IX+3) 
12e2			 
12e2			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12e2			      ld    (IX+3), H 
12e2			 
12e2			      ; Modify this_free block to be allocation 
12e2			      ex    DE, HL 
12e2			      xor   A                       ; Null the next block ptr of allocated block 
12e2			      ld    (HL), A 
12e2			      inc   HL 
12e2			      ld    (HL), A 
12e2			 
12e2			      inc   HL                      ; Store want size into allocated block 
12e2			      ld    (HL), C 
12e2			      inc   HL 
12e2			      ld    (HL), B 
12e2			      inc   HL 
12e2			      push  HL                      ; Address of allocation to return 
12e2			 
12e2			      jr    malloc_update_links 
12e2			 
12e2			malloc_alloc_fit: 
12e2			      pop   HL                      ; Dont need new block size, want is exact fit 
12e2			 
12e2			      ; Modify this_free block to be allocation 
12e2			      ex    DE, HL 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			 
12e2			      xor   A                       ; Null the next block ptr of allocated block 
12e2			      ld    (HL), A 
12e2			      inc   HL 
12e2			      ld    (HL), A 
12e2			 
12e2			      inc   HL                      ; Store address of allocation to return 
12e2			      inc   HL 
12e2			      inc   HL 
12e2			      push  HL 
12e2			 
12e2			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12e2			      ld    L, (IX+0)               ; next_free to HL 
12e2			      ld    H, (IX+1) 
12e2			 
12e2			      ld    (IX+2), L               ; HL to this_free 
12e2			      ld    (IX+3), H 
12e2			 
12e2			 
12e2			malloc_update_links: 
12e2			      ; Update prev_free ptr to point to this_free 
12e2			      ld    L, (IX+4)               ; prev_free ptr to HL 
12e2			      ld    H, (IX+5) 
12e2			 
12e2			      ld    E, (IX+2)               ; this_free ptr to DE 
12e2			      ld    D, (IX+3) 
12e2			 
12e2			      ld    (HL), E                 ; this_free ptr into prev_free 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			      ; Clear the Z flag to indicate successful allocation 
12e2			      ld    A, D 
12e2			      or    E 
12e2			 
12e2			      pop   DE                      ; Address of allocation 
12e2			 
12e2			malloc_no_space: 
12e2			      ld    HL, 6                   ; Clean up stack frame 
12e2			      add   HL, SP 
12e2			      ld    SP, HL 
12e2			 
12e2			      ex    DE, HL                  ; Alloc addr into HL for return 
12e2			 
12e2			malloc_early_exit: 
12e2			      pop   IX 
12e2			      pop   DE 
12e2			      pop   BC 
12e2			 
12e2			      ret 
12e2			 
12e2			 
12e2			;------------------------------------------------------------------------------ 
12e2			;     free                                                                    : 
12e2			;                                                                             : 
12e2			; Description                                                                 : 
12e2			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12e2			;     returned by malloc, otherwise the behaviour is undefined.               : 
12e2			;                                                                             : 
12e2			;     Where possible, directly adjacent free blocks will be merged together   : 
12e2			;     into larger blocks to help ensure that the heap does not become         : 
12e2			;     excessively fragmented.                                                 : 
12e2			;                                                                             : 
12e2			;     free does not clear or set any other value into the freed space, and    : 
12e2			;     therefore its contents may be visible through subsequent malloc's. The  : 
12e2			;     caller should clear the freed space as required.                        : 
12e2			;                                                                             : 
12e2			;     This implementation of free uses the stack exclusively, and is          : 
12e2			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12e2			;     advisable to disable interrupts before calling free, and recommended    : 
12e2			;     to avoid the use of free inside ISRs in general.                        : 
12e2			;                                                                             : 
12e2			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12e2			;                                                                             : 
12e2			; Parameters                                                                  : 
12e2			;     HL  Pointer to address of first byte of allocation to be freed          : 
12e2			;                                                                             : 
12e2			; Returns                                                                     : 
12e2			;     Nothing                                                                 : 
12e2			;                                                                             : 
12e2			; Stack frame                                                                 : 
12e2			;       |             |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |     BC      |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |     DE      |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |     IX      |                                                       : 
12e2			;       +-------------+                                                       : 
12e2			;       |  prev_free  |                                                       : 
12e2			;   +2  +-------------+                                                       : 
12e2			;       |  next_free  |                                                       : 
12e2			;   +0  +-------------+                                                       : 
12e2			;       |             |                                                       : 
12e2			;                                                                             : 
12e2			;------------------------------------------------------------------------------ 
12e2			free: 
12e2			      push  BC 
12e2			      push  DE 
12e2			      push  IX 
12e2			 
12e2			      ld    A, H                    ; Exit if ptr is null 
12e2			      or    L 
12e2			      jp    Z, free_early_exit 
12e2			 
12e2			      ; Set up stack frame 
12e2			      ex    DE, HL 
12e2			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12e2			      add   HL, SP 
12e2			      ld    SP, HL 
12e2			      ld    IX, 0                   ; Use IX as a frame pointer 
12e2			      add   IX, SP 
12e2			 
12e2			      ; The address in HL points to the start of the useable allocated space, 
12e2			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12e2			      ; address of the block itself. 
12e2			      ex    DE, HL 
12e2			      ld    DE, -4 
12e2			      add   HL, DE 
12e2			 
12e2			      ; An allocated block must have a null next block pointer in it 
12e2			      ld    A, (HL) 
12e2			      inc   HL 
12e2			      or    (HL) 
12e2			      jp    NZ, free_done 
12e2			 
12e2			      dec   HL 
12e2			 
12e2			      ld    B, H                    ; Copy HL to BC 
12e2			      ld    C, L 
12e2			 
12e2			      ; Loop through the free list to find the first block with an address 
12e2			      ; higher than the block being freed 
12e2			      ld    HL, free_list 
12e2			 
12e2			free_find_higher_block: 
12e2			      ld    E, (HL)                 ; Load next ptr from free block 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      dec   HL 
12e2			 
12e2			      ld    (IX+0), E               ; Save ptr to next free block 
12e2			      ld    (IX+1), D 
12e2			      ld    (IX+2), L               ; Save ptr to prev free block 
12e2			      ld    (IX+3), H 
12e2			 
12e2			      ld    A, B                    ; Check if DE is greater than BC 
12e2			      cp    D                       ; Compare MSB first 
12e2			      jr    Z, $+4                  ; MSB the same, compare LSB 
12e2			      jr    NC, free_find_higher_block_skip 
12e2			      ld    A, C 
12e2			      cp    E                       ; Then compare LSB 
12e2			      jr    C, free_found_higher_block 
12e2			 
12e2			free_find_higher_block_skip: 
12e2			      ld    A, D                    ; Reached the end of the free list? 
12e2			      or    E 
12e2			      jp    Z, free_done 
12e2			 
12e2			      ex    DE, HL 
12e2			 
12e2			      jr    free_find_higher_block 
12e2			 
12e2			free_found_higher_block: 
12e2			      ; Insert freed block between prev and next free blocks 
12e2			      ld    (HL), C                 ; Point prev free block to freed block 
12e2			      inc   HL 
12e2			      ld    (HL), B 
12e2			 
12e2			      ld    H, B                    ; Point freed block at next free block 
12e2			      ld    L, C 
12e2			      ld    (HL), E 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			      ; Check if the freed block is adjacent to the next free block 
12e2			      inc   HL                      ; Load size of freed block into HL 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      ex    DE, HL 
12e2			 
12e2			      add   HL, BC                  ; Add addr of freed block and its size 
12e2			 
12e2			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12e2			      ld    D, (IX+1) 
12e2			 
12e2			      or    A                       ; Clear the carry flag 
12e2			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12e2			      jr    NZ, free_check_adjacent_to_prev 
12e2			 
12e2			      ; Freed block is adjacent to next, merge into one bigger block 
12e2			      ex    DE, HL                  ; Load next ptr from next block into DE 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      push  HL                      ; Save ptr to next block for later 
12e2			 
12e2			      ld    H, B                    ; Store ptr from next block into freed block 
12e2			      ld    L, C 
12e2			      ld    (HL), E 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			      pop   HL                      ; Restore ptr to next block 
12e2			      inc   HL                      ; Load size of next block into DE 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      push  DE                      ; Save next block size for later 
12e2			 
12e2			      ld    H, B                    ; Load size of freed block into HL 
12e2			      ld    L, C 
12e2			      inc   HL 
12e2			      inc   HL 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      ex    DE, HL 
12e2			 
12e2			      pop   DE                      ; Restore size of next block 
12e2			      add   HL, DE                  ; Add sizes of both blocks 
12e2			      ex    DE, HL 
12e2			 
12e2			      ld    H, B                    ; Store new bigger size into freed block 
12e2			      ld    L, C 
12e2			      inc   HL 
12e2			      inc   HL 
12e2			      ld    (HL), E 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			free_check_adjacent_to_prev: 
12e2			      ; Check if the freed block is adjacent to the prev free block 
12e2			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12e2			      ld    H, (IX+3) 
12e2			 
12e2			      inc   HL                      ; Size of prev free block into DE 
12e2			      inc   HL 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			      dec   HL 
12e2			 
12e2			      add   HL, DE                  ; Add prev block addr and size 
12e2			 
12e2			      or    A                       ; Clear the carry flag 
12e2			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12e2			      jr    NZ, free_done 
12e2			 
12e2			      ; Freed block is adjacent to prev, merge into one bigger block 
12e2			      ld    H, B                    ; Load next ptr from freed block into DE 
12e2			      ld    L, C 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      push  HL                      ; Save freed block ptr for later 
12e2			 
12e2			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12e2			      ld    H, (IX+3) 
12e2			      ld    (HL), E 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			      pop   HL                      ; Restore freed block ptr 
12e2			      inc   HL                      ; Load size of freed block into DE 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			      push  DE                      ; Save freed block size for later 
12e2			 
12e2			      ld    L, (IX+2)               ; Load size of prev block into DE 
12e2			      ld    H, (IX+3) 
12e2			      inc   HL 
12e2			      inc   HL 
12e2			      ld    E, (HL) 
12e2			      inc   HL 
12e2			      ld    D, (HL) 
12e2			 
12e2			      pop   HL                      ; Add sizes of both blocks 
12e2			      add   HL, DE 
12e2			      ex    DE, HL 
12e2			 
12e2			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12e2			      ld    H, (IX+3) 
12e2			      inc   HL 
12e2			      inc   HL 
12e2			      ld    (HL), E 
12e2			      inc   HL 
12e2			      ld    (HL), D 
12e2			 
12e2			free_done: 
12e2			      ld    HL, 4                   ; Clean up stack frame 
12e2			      add   HL, SP 
12e2			      ld    SP, HL 
12e2			 
12e2			free_early_exit: 
12e2			      pop   IX 
12e2			      pop   DE 
12e2			      pop   BC 
12e2			 
12e2			      ret 
12e2			 
12e2			 
12e2			;      .org 0x8000 
12e2			; 
12e2			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12e2			 ;                 .dw   0 
12e2			 
12e2			endif 
12e2			 
12e2			 
12e2			if MALLOC_4 
12e2			 
12e2			; My memory allocation code. Very very simple.... 
12e2			; allocate space under 250 chars 
12e2			 
12e2			heap_init: 
12e2				; init start of heap as zero 
12e2				;  
12e2			 
12e2				ld hl, heap_start 
12e2			;	ld a, 0 
12e2				ld (hl), 0      ; empty block 
12e2				inc hl 
12e2			;	ld a, 0 
12e2				ld (hl), 0      ; length of block 
12e2				; write end of list 
12e2				inc hl 
12e2				ld a,(hl) 
12e2				inc hl 
12e2				ld a,(hl) 
12e2				 
12e2			 
12e2				; init some malloc vars 
12e2			 
12e2				ld hl, 0 
12e2				ld (free_list), hl       ; store last malloc location 
12e2			 
12e2				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12e2			;	ld a, 0 
12e2				ld (hl), 0 
12e2			 
12e2			 
12e2				ld hl, heap_start 
12e2				;  
12e2				  
12e2				ret 
12e2			 
12e2			 
12e2			;    free block marker 
12e2			;    requested size  
12e2			;    pointer to next block 
12e2			;    .... 
12e2			;    next block marker 
12e2			 
12e2			 
12e2			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12e2			; 
12e2			 
12e2			 
12e2			malloc:  
12e2				push de 
12e2				push bc 
12e2				push af 
12e2			 
12e2				; hl space required 
12e2				 
12e2				ld c, l    ; hold space   (TODO only a max of 255) 
12e2			 
12e2			;	inc c     ; TODO BUG need to fix memory leak on push str 
12e2			;	inc c 
12e2			;	inc c 
12e2			;	inc c 
12e2			;	inc c 
12e2			;	inc c 
12e2			;	inc c 
12e2			 
12e2			 
12e2			 
12e2				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12e2			 
12e2				ld a, (free_list+3) 
12e2			;	cp 0 
12e2				or a 
12e2				jr z, .contheap 
12e2			 
12e2				ld hl, (free_list)     ; get last alloc 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "mrs" 
12e2						CALLMONITOR 
12e2					endif 
12e2				jr .startalloc 
12e2			 
12e2			.contheap: 
12e2				ld hl, heap_start 
12e2			 
12e2			.startalloc: 
12e2			 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "mym" 
12e2						CALLMONITOR 
12e2					endif 
12e2			.findblock: 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "mmf" 
12e2						CALLMONITOR 
12e2					endif 
12e2			 
12e2				ld a,(hl)  
12e2				; if byte is zero then clear to use 
12e2			 
12e2			;	cp 0 
12e2				or a 
12e2				jr z, .foundemptyblock 
12e2			 
12e2				; if byte is not clear 
12e2				;     then byte is offset to next block 
12e2			 
12e2				inc hl 
12e2				ld a, (hl) ; get size 
12e2			.nextblock:	inc hl 
12e2					ld e, (hl) 
12e2					inc hl 
12e2					ld d, (hl) 
12e2					ex de, hl 
12e2			;	inc hl  ; move past the store space 
12e2			;	inc hl  ; move past zero index  
12e2			 
12e2				; TODO detect no more space 
12e2			 
12e2				push hl 
12e2				ld de, heap_end 
12e2				call cmp16 
12e2				pop hl 
12e2				jr nc, .nospace 
12e2			 
12e2				jr .findblock 
12e2			 
12e2			.nospace: ld hl, 0 
12e2				jp .exit 
12e2			 
12e2			 
12e2			.foundemptyblock:	 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "mme" 
12e2						CALLMONITOR 
12e2					endif 
12e2			 
12e2			; TODO has block enough space if reusing??? 
12e2			 
12e2				;  
12e2			 
12e2			; see if this block has been previously used 
12e2				inc hl 
12e2				ld a, (hl) 
12e2				dec hl 
12e2			;	cp 0 
12e2				or a 
12e2				jr z, .newblock 
12e2			 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "meR" 
12e2						CALLMONITOR 
12e2					endif 
12e2			 
12e2			; no reusing previously allocated block 
12e2			 
12e2			; is it smaller than previously used? 
12e2				 
12e2				inc hl    ; move to size 
12e2				ld a, c 
12e2				sub (hl)        ; we want c < (hl) 
12e2				dec hl    ; move back to marker 
12e2			        jr z, .findblock 
12e2			 
12e2				; update with the new size which should be lower 
12e2			 
12e2			        ;inc  hl   ; negate next move. move back to size  
12e2			 
12e2			.newblock: 
12e2				; need to be at marker here 
12e2			 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "meN" 
12e2						CALLMONITOR 
12e2					endif 
12e2			 
12e2			 
12e2				ld a, c 
12e2			 
12e2				ld (free_list+3), a	 ; flag resume from last malloc  
12e2				ld (free_list), hl    ; save out last location 
12e2			 
12e2			 
12e2				;inc a     ; space for length byte 
12e2				ld (hl), a     ; save block in use marker 
12e2			 
12e2				inc hl   ; move to space marker 
12e2				ld (hl), a    ; save new space 
12e2			 
12e2				inc hl   ; move to start of allocated area 
12e2				 
12e2			;	push hl     ; save where we are - 1  
12e2			 
12e2			;	inc hl  ; move past zero index  
12e2				; skip space to set down new marker 
12e2			 
12e2				; provide some extra space for now 
12e2			 
12e2				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12e2				inc a 
12e2				inc a 
12e2			 
12e2				push hl   ; save where we are in the node block 
12e2			 
12e2				call addatohl 
12e2			 
12e2				; write linked list point 
12e2			 
12e2				pop de     ; get our node position 
12e2				ex de, hl 
12e2			 
12e2				ld (hl), e 
12e2				inc hl 
12e2				ld (hl), d 
12e2			 
12e2				inc hl 
12e2			 
12e2				; now at start of allocated data so save pointer 
12e2			 
12e2				push hl 
12e2			 
12e2				; jump to position of next node and setup empty header in DE 
12e2			 
12e2				ex de, hl 
12e2			 
12e2			;	inc hl ; move past end of block 
12e2			 
12e2			;	ld a, 0 
12e2				ld (hl), 0   ; empty marker 
12e2				inc hl 
12e2				ld (hl), 0   ; size 
12e2				inc hl  
12e2				ld (hl), 0   ; ptr 
12e2				inc hl 
12e2				ld (hl), 0   ; ptr 
12e2			 
12e2			 
12e2				pop hl 
12e2			 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "mmr" 
12e2						CALLMONITOR 
12e2					endif 
12e2			 
12e2			.exit: 
12e2				pop af 
12e2				pop bc 
12e2				pop de  
12e2				ret 
12e2			 
12e2			 
12e2			 
12e2			 
12e2			free:  
12e2				push hl 
12e2				push af 
12e2				; get address in hl 
12e2			 
12e2					if DEBUG_FORTH_MALLOC_INT 
12e2						DMARK "fre" 
12e2						CALLMONITOR 
12e2					endif 
12e2				; data is at hl - move to block count 
12e2				dec hl 
12e2				dec hl    ; get past pointer 
12e2				dec hl 
12e2			 
12e2				ld a, (hl)    ; need this for a validation check 
12e2			 
12e2				dec hl    ; move to block marker 
12e2			 
12e2				; now check that the block count and block marker are the same  
12e2			        ; this checks that we are on a malloc node and not random memory 
12e2			        ; OK a faint chance this could be a problem but rare - famous last words! 
12e2			 
12e2				ld c, a 
12e2				ld a, (hl)    
12e2			 
12e2				cp c 
12e2				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12e2			 
12e2				; yes good chance we are on a malloc node 
12e2			 
12e2			;	ld a, 0      
12e2				ld (hl), 0   ; mark as free 
12e2			 
12e2				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12e2			 
12e2			.freeignore:  
12e2			 
12e2				pop af 
12e2				pop hl 
12e2			 
12e2				ret 
12e2			 
12e2			 
12e2			 
12e2			endif 
