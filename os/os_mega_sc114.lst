900f			StrictStrCmp: 
900f				; Load next chars of each string 
900f 1a				ld a, (de) 
9010 47				ld b, a 
9011 7e				ld a, (hl) 
9012				; Compare 
9012 b8				cp b 
9013				; Return non-zero if chars don't match 
9013 c0				ret nz 
9014				; Check for end of both strings 
9014 fe 00			cp "\0" 
9016				; Return if strings have ended 
9016 c8				ret z 
9017				; Otherwise, advance to next chars 
9017 23				inc hl 
9018 13				inc de 
9019 18 f4			jr StrictStrCmp 
