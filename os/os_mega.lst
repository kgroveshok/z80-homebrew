694c cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
694e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6950 cb 97		            RES  kLCDBitRS, A  
