22ab 73				ld (hl), e		; next word link ie system dict 
22ac 23				inc hl 
22ad 72				ld (hl), d		; next word link ie system dict 
22ae 23				inc hl	 
22af			 
22af			;	ld (hl), sysdict		; next word link ie system dict 
22af			;	inc hl 
22af			;	inc hl 
22af			 
22af			;	inc hl 
22af			;	inc hl 
22af			 
22af			;	ld a, 2			; word length is 0 
22af 36 02			ld (hl), 2 
22b1 23				inc hl 
22b2			 
22b2			;	ld a, '~'			; word length is 0 
22b2 36 7e			ld (hl), '~' 
22b4 23				inc hl 
22b5			;	ld a, 0			; save empty word 
22b5 36 00			ld (hl), 0 
