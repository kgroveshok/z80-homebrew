0e30			; Get 2 ASCII characters as hex byte from pointer in hl 
0e30			 
0e30			BYTERD: 
0e30 16 00			LD	D,00h		;Set up 
0e32 cd 3a 0e			CALL	HEXCON		;Get byte and convert to hex 
0e35 87				ADD	A,A		;First nibble so 
0e36 87				ADD	A,A		;multiply by 16 
0e37 87				ADD	A,A		; 
0e38 87				ADD	A,A		; 
0e39 57				LD	D,A		;Save hi nibble in D 
0e3a			HEXCON: 
0e3a 7e				ld a, (hl)		;Get next chr 
0e3b 23				inc hl 
