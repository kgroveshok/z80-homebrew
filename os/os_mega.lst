1067			; Decimal Signed Version 
1067			 
1067			; DispA 
1067			; -------------------------------------------------------------- 
1067			; Converts a signed integer value to a zero-terminated ASCII 
1067			; string representative of that value (using radix 10). 
1067			; -------------------------------------------------------------- 
1067			; INPUTS: 
1067			;     HL     Value to convert (two's complement integer). 
1067			;     DE     Base address of string destination. (pointer). 
1067			; -------------------------------------------------------------- 
1067			; OUTPUTS: 
1067			;     None 
1067			; -------------------------------------------------------------- 
1067			; REGISTERS/MEMORY DESTROYED 
1067			; AF HL 
1067			; -------------------------------------------------------------- 
1067			 
1067			;DispHLToASCII: 
1067			;   push    de 
1067			;   push    bc 
1067			; 
1067			;; Detect sign of HL. 
1067			;    bit    7, h 
1067			;    jr     z, ._DoConvert 
1067			; 
1067			;; HL is negative. Output '-' to string and negate HL. 
1067			;    ld     a, '-' 
1067			;    ld     (de), a 
1067			;    inc    de 
1067			; 
1067			;; Negate HL (using two's complement) 
1067			;    xor    a 
1067			;    sub    l 
1067			;    ld     l, a 
1067			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
1067			;    sbc    a, h 
1067			;    ld     h, a 
1067			; 
1067			;; Convert HL to digit characters 
1067			;._DoConvert: 
1067			;    ld     b, 0     ; B will count character length of number 
1067			;-   ld     a, 10 
1067			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
1067			;    push   af 
1067			;    inc    b 
1067			;    ld     a, h 
1067			;    or     l 
1067			;    jr     nz, - 
1067			; 
1067			;; Retrieve digits from stack 
1067			;-   pop    af 
1067			;    or     $30 
1067			;    ld     (de), a 
1067			;    inc    de 
1067			;    djnz   - 
1067			; 
1067			;; Terminate string with NULL 
1067			;    xor    a 
1067			;    ld     (de), a 
1067			; 
1067			;    pop    bc 
1067			;    pop    de 
1067			;    ret 
1067			 
1067			;Comments 
1067			; 
1067			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
1067			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
1067			;    Note that the output string will not be fixed-width. 
1067			; 
1067			;Example Usage 
1067			; 
1067			;    ld    hl, -1004 
1067			;    ld    de, OP1 
1067			;    call  DispA 
1067			;    ld    hl, OP1 
1067			;    syscall  PutS 
1067			 
1067			 
1067			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1067			 
1067			 
1067			;Converts an ASCII string to an unsigned 16-bit integer 
1067			;Quits when it reaches a non-decimal digit 
1067			 
1067			string_to_uint16: 
1067			atoui_16: 
1067			;Input: 
1067			;     DE points to the string 
1067			;Outputs: 
1067			;     HL is the result 
1067			;     A is the 8-bit value of the number 
1067			;     DE points to the byte after the number 
1067			;Destroys: 
1067			;     BC 
1067			;       if the string is non-empty, BC is HL/10 
1067			;Size:  24 bytes 
1067			;Speed: 42+d(104+{0,9}) 
1067			;       d is the number of digits in the number 
1067			;       max is 640 cycles for a 5 digit number 
1067			;Assuming no leading zeros: 
1067			;1 digit:  146cc 
1067			;2 digit:  250cc 
1067			;3 digit:  354cc or 363cc (avg: 354.126cc) 
1067			;4 digit:  458cc or 467cc (avg: 458.27cc) 
1067			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
1067			;avg: 544.81158447265625cc (544+13297/16384) 
1067			;=============================================================== 
1067 21 00 00		  ld hl,0 
106a			.u16a: 
106a 1a			  ld a,(de) 
106b d6 30		  sub 30h 
106d fe 0a		  cp 10 
106f d0			  ret nc 
1070 13			  inc de 
1071 44			  ld b,h 
1072 4d			  ld c,l 
1073 29			  add hl,hl 
1074 29			  add hl,hl 
1075 09			  add hl,bc 
1076 29			  add hl,hl 
1077 85			  add a,l 
1078 6f			  ld l,a 
1079 30 ef		  jr nc,.u16a 
107b 24			  inc h 
107c c3 6a 10		  jp .u16a 
107f			 
107f			 
107f			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
107f			 
107f			;written by Zeda 
107f			;Converts a 16-bit unsigned integer to an ASCII string. 
107f			 
107f			uitoa_16: 
107f			;Input: 
107f			;   DE is the number to convert 
107f			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
107f			;Output: 
107f			;   HL points to the null-terminated ASCII string 
107f			;      NOTE: This isn't necessarily the same as the input HL. 
107f d5			  push de 
1080 c5			  push bc 
1081 f5			  push af 
1082 eb			  ex de,hl 
1083			 
1083 01 f0 d8		  ld bc,-10000 
1086 3e 2f		  ld a,'0'-1 
1088 3c			  inc a 
1089 09			  add hl,bc  
108a 38 fc		   jr c,$-2 
108c 12			  ld (de),a 
108d 13			  inc de 
108e			 
108e 01 e8 03		  ld bc,1000 
1091 3e 3a		  ld a,'9'+1 
1093 3d			  dec a  
1094 09			  add hl,bc  
1095 30 fc		   jr nc,$-2 
1097 12			  ld (de),a 
1098 13			  inc de 
1099			 
1099 01 9c ff		  ld bc,-100 
109c 3e 2f		  ld a,'0'-1 
109e 3c			  inc a  
109f 09			  add hl,bc  
10a0 38 fc		   jr c,$-2 
10a2 12			  ld (de),a 
10a3 13			  inc de 
10a4			 
10a4 7d			  ld a,l 
10a5 26 3a		  ld h,'9'+1 
10a7 25			  dec h  
10a8 c6 0a		  add a,10  
10aa 30 fb		   jr nc,$-3 
10ac c6 30		  add a,'0' 
10ae eb			  ex de,hl 
10af 72			  ld (hl),d 
10b0 23			  inc hl 
10b1 77			  ld (hl),a 
10b2 23			  inc hl 
10b3 36 00		  ld (hl),0 
10b5			 
10b5			;Now strip the leading zeros 
10b5 0e fa		  ld c,-6 
10b7 09			  add hl,bc 
10b8 3e 30		  ld a,'0' 
10ba 23			  inc hl  
10bb be			  cp (hl)  
10bc 28 fc		  jr z,$-2 
10be			 
10be			;Make sure that the string is non-empty! 
10be 7e			  ld a,(hl) 
10bf b7			  or a 
10c0 20 01		  jr nz,.atoub 
10c2 2b			  dec hl 
10c3			.atoub: 
10c3			 
10c3 f1			  pop af 
10c4 c1			  pop bc 
10c5 d1			  pop de 
10c6 c9			  ret 
10c7			 
10c7			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
10c7			 
10c7			toUpper: 
10c7			;A is the char. 
10c7			;If A is a lowercase letter, this sets it to the matching uppercase 
10c7			;18cc or 30cc or 41cc 
10c7			;avg: 26.75cc 
10c7 fe 61		  cp 'a' 
10c9 d8			  ret c 
10ca fe 7b		  cp 'z'+1 
10cc d0			  ret nc 
10cd d6 20		  sub 'a'-'A' 
10cf c9			  ret 
