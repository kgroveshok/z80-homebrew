1c25			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
1c25			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
1c25			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
1c25			WORD_SYS_END: equ 0   ; Opcode for all user words 
1c25			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
1c25			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
1c25			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
1c25			 
1c25			; Core word preamble macro 
1c25			 
1c25			CWHEAD:   macro nxtword opcode lit len opflags 
1c25				db WORD_SYS_CORE+opcode             
