647b			; stack over and underflow checks 
647b			 
647b			; init the words to detect the under/overflow 
647b			 
647b			chk_stk_init: 
647b				; a vague random number to check so we dont get any "lucky" hits 
647b 3e 2d			ld a, 45 
647d 6f				ld l, a 
647e 00				nop 
647f 3e 17			ld a, 23 
6481 67				ld h, a 
6482			 
6482 22 bc f0			ld (chk_word), hl     ; the word we need to check against 
6485			 
6485			;	ld (chk_stund), hl	; stack points.... 
6485 22 3b fe			ld (chk_stovr), hl 
6488 22 0b f9			ld (chk_ret_und), hl 
648b 22 c9 f8			ld (chk_ret_ovr), hl 
648e 22 47 f8			ld (chk_loop_ovr), hl 
6491 22 45 f6			ld (chk_data_ovr), hl 
6494 c9				ret 
6495				 
6495			check_stacks: 
6495				; check all stack words 
6495			 
6495 e5				push hl 
6496 d5				push de 
6497			 
6497			;	ld de,(chk_word) 
6497			;	ld hl, (chk_stund)	; stack points.... 
6497			;	if DEBUG_STK_FAULT 
6497			;		DMARK "FAa" 
6497			;		CALLMONITOR 
6497			;	endif 
6497			;	call cmp16 
6497			;	jp z, .chk_faulta 
6497			; 
6497			;	ld de, sfaultsu 
6497			;	jp .chk_fault 
6497			 
6497 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
649a ed 5b bc f0		ld de,(chk_word) 
649e				if DEBUG_STK_FAULT 
649e					DMARK "FAb" 
649e					CALLMONITOR 
649e				endif 
649e cd 7d 0d			call cmp16 
64a1 28 06			jr z, .chk_fault1 
64a3 11 48 65			ld de, sfaultso 
64a6 c3 f8 64			jp .chk_fault 
64a9			.chk_fault1:  
64a9 2a 0b f9			ld hl, (chk_ret_und) 
64ac ed 5b bc f0		ld de,(chk_word) 
64b0				if DEBUG_STK_FAULT 
64b0					DMARK "FAU" 
64b0					CALLMONITOR 
64b0				endif 
64b0 cd 7d 0d			call cmp16 
64b3 ca bc 64			jp z, .chk_fault2 
64b6 11 58 65			ld de, sfaultru 
64b9 c3 f8 64			jp .chk_fault 
64bc			.chk_fault2:  
64bc 2a c9 f8			ld hl, (chk_ret_ovr) 
64bf ed 5b bc f0		ld de,(chk_word) 
64c3				if DEBUG_STK_FAULT 
64c3					DMARK "FA1" 
64c3					CALLMONITOR 
64c3				endif 
64c3 cd 7d 0d			call cmp16 
64c6 ca cf 64			jp z, .chk_fault3 
64c9 11 66 65			ld de, sfaultro 
64cc c3 f8 64			jp .chk_fault 
64cf			.chk_fault3:  
64cf 2a 47 f8			ld hl, (chk_loop_ovr) 
64d2 ed 5b bc f0		ld de,(chk_word) 
64d6				if DEBUG_STK_FAULT 
64d6					DMARK "FA2" 
64d6					CALLMONITOR 
64d6				endif 
64d6 cd 7d 0d			call cmp16 
64d9 ca e2 64			jp z, .chk_fault4 
64dc 11 80 65			ld de, sfaultlo 
64df c3 f8 64			jp .chk_fault 
64e2			.chk_fault4:  
64e2 2a 45 f6			ld hl, (chk_data_ovr) 
64e5 ed 5b bc f0		ld de,(chk_word) 
64e9				if DEBUG_STK_FAULT 
64e9					DMARK "FA3" 
64e9					CALLMONITOR 
64e9				endif 
64e9 cd 7d 0d			call cmp16 
64ec ca f5 64			jp z, .chk_fault5 
64ef 11 9a 65			ld de, sfaultdo 
64f2 c3 f8 64			jp .chk_fault 
64f5			 
64f5			 
