0cd8			;;;; int maths 
0cd8			 
0cd8			; https://map.grauw.nl/articles/mult_div_shifts.php 
0cd8			; Divide 16-bit values (with 16-bit result) 
0cd8			; In: Divide BC by divider DE 
0cd8			; Out: BC = result, HL = rest 
0cd8			; 
0cd8			Div16: 
0cd8 21 00 00		    ld hl,0 
0cdb 78			    ld a,b 
0cdc 06 08		    ld b,8 
0cde			Div16_Loop1: 
0cde 17			    rla 
0cdf ed 6a		    adc hl,hl 
0ce1 ed 52		    sbc hl,de 
0ce3 30 01		    jr nc,Div16_NoAdd1 
0ce5 19			    add hl,de 
0ce6			Div16_NoAdd1: 
0ce6 10 f6		    djnz Div16_Loop1 
0ce8 17			    rla 
0ce9 2f			    cpl 
0cea 47			    ld b,a 
0ceb 79			    ld a,c 
0cec 48			    ld c,b 
0ced 06 08		    ld b,8 
0cef			Div16_Loop2: 
0cef 17			    rla 
0cf0 ed 6a		    adc hl,hl 
0cf2 ed 52		    sbc hl,de 
0cf4 30 01		    jr nc,Div16_NoAdd2 
0cf6 19			    add hl,de 
0cf7			Div16_NoAdd2: 
0cf7 10 f6		    djnz Div16_Loop2 
0cf9 17			    rla 
0cfa 2f			    cpl 
0cfb 41			    ld b,c 
0cfc 4f			    ld c,a 
0cfd c9			ret 
0cfe			 
0cfe			 
0cfe			;http://z80-heaven.wikidot.com/math 
0cfe			; 
0cfe			;Inputs: 
0cfe			;     DE and A are factors 
0cfe			;Outputs: 
0cfe			;     A is not changed 
0cfe			;     B is 0 
0cfe			;     C is not changed 
0cfe			;     DE is not changed 
0cfe			;     HL is the product 
0cfe			;Time: 
0cfe			;     342+6x 
0cfe			; 
0cfe			Mult16: 
0cfe			 
0cfe 06 08		     ld b,8          ;7           7 
0d00 21 00 00		     ld hl,0         ;10         10 
0d03 29			       add hl,hl     ;11*8       88 
0d04 07			       rlca          ;4*8        32 
0d05 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0d07 19			         add hl,de   ;--         -- 
0d08 10 f9		       djnz $-5      ;13*7+8     99 
0d0a c9			ret 
0d0b			 
0d0b			; 
0d0b			; Square root of 16-bit value 
0d0b			; In:  HL = value 
0d0b			; Out:  D = result (rounded down) 
0d0b			; 
0d0b			;Sqr16: 
0d0b			;    ld de,#0040 
0d0b			;    ld a,l 
0d0b			;    ld l,h 
0d0b			;    ld h,d 
0d0b			;    or a 
0d0b			;    ld b,8 
0d0b			;Sqr16_Loop: 
0d0b			;    sbc hl,de 
0d0b			;    jr nc,Sqr16_Skip 
0d0b			;    add hl,de 
0d0b			;Sqr16_Skip: 
0d0b			;    ccf 
0d0b			;    rl d 
0d0b			;    add a,a 
0d0b			;    adc hl,hl 
0d0b			;    add a,a 
0d0b			;    adc hl,hl 
0d0b			;    djnz Sqr16_Loop 
0d0b			;    ret 
0d0b			; 
0d0b			; 
0d0b			; Divide 8-bit values 
0d0b			; In: Divide E by divider C 
0d0b			; Out: A = result, B = rest 
0d0b			; 
0d0b			Div8: 
0d0b af			    xor a 
0d0c 06 08		    ld b,8 
0d0e			Div8_Loop: 
0d0e cb 13		    rl e 
0d10 17			    rla 
0d11 91			    sub c 
0d12 30 01		    jr nc,Div8_NoAdd 
0d14 81			    add a,c 
0d15			Div8_NoAdd: 
0d15 10 f7		    djnz Div8_Loop 
0d17 47			    ld b,a 
0d18 7b			    ld a,e 
0d19 17			    rla 
0d1a 2f			    cpl 
0d1b c9			    ret 
0d1c			 
0d1c			; 
0d1c			; Multiply 8-bit value with a 16-bit value (unrolled) 
0d1c			; In: Multiply A with DE 
0d1c			; Out: HL = result 
0d1c			; 
0d1c			Mult12U: 
0d1c 2e 00		    ld l,0 
0d1e 87			    add a,a 
0d1f 30 01		    jr nc,Mult12U_NoAdd0 
0d21 19			    add hl,de 
0d22			Mult12U_NoAdd0: 
0d22 29			    add hl,hl 
0d23 87			    add a,a 
0d24 30 01		    jr nc,Mult12U_NoAdd1 
0d26 19			    add hl,de 
0d27			Mult12U_NoAdd1: 
0d27 29			    add hl,hl 
0d28 87			    add a,a 
0d29 30 01		    jr nc,Mult12U_NoAdd2 
0d2b 19			    add hl,de 
0d2c			Mult12U_NoAdd2: 
0d2c 29			    add hl,hl 
0d2d 87			    add a,a 
0d2e 30 01		    jr nc,Mult12U_NoAdd3 
0d30 19			    add hl,de 
0d31			Mult12U_NoAdd3: 
0d31 29			    add hl,hl 
0d32 87			    add a,a 
0d33 30 01		    jr nc,Mult12U_NoAdd4 
0d35 19			    add hl,de 
0d36			Mult12U_NoAdd4: 
0d36 29			    add hl,hl 
0d37 87			    add a,a 
0d38 30 01		    jr nc,Mult12U_NoAdd5 
0d3a 19			    add hl,de 
0d3b			Mult12U_NoAdd5: 
0d3b 29			    add hl,hl 
0d3c 87			    add a,a 
0d3d 30 01		    jr nc,Mult12U_NoAdd6 
0d3f 19			    add hl,de 
0d40			Mult12U_NoAdd6: 
0d40 29			    add hl,hl 
0d41 87			    add a,a 
0d42 d0			    ret nc 
0d43 19			    add hl,de 
0d44 c9			    ret 
