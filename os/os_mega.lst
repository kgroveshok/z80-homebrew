12e0			 
12e0				; if byte is not clear 
12e0				;     then byte is offset to next block 
12e0			 
12e0				inc hl 
12e0				ld a, (hl) ; get size 
12e0			.nextblock:	inc hl 
12e0					ld e, (hl) 
12e0					inc hl 
12e0					ld d, (hl) 
12e0					ex de, hl 
12e0			;	inc hl  ; move past the store space 
12e0			;	inc hl  ; move past zero index  
12e0			 
12e0				; TODO detect no more space 
12e0			 
