9daf			.HEAP: 
9daf			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9daf 15				db WORD_SYS_CORE+OPCODE_HEAP             
9db0 dd 9d			dw .EXEC            
9db2 05				db 4 + 1 
9db3 .. 00			db "HEAP",0              
9db8				endm 
# End of macro CWHEAD
9db8			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9db8			; | | u1 - Current number of bytes in the heap 
9db8			; | | u2 - Remaining bytes left on the heap 
9db8			; | |  
9db8			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9db8			 
9db8			 
9db8				if DEBUG_FORTH_WORDS_KEY 
9db8					DMARK "HEP" 
9db8				if DEMARK_VERSION = 1  
9db8 e5					push hl  
9db9 21 c1 9d				ld hl, .dmark  
9dbc 22 60 ee				ld (debug_mark), hl  
9dbf				endif  
9dbf				if DEMARK_VERSION = 0  
9dbf					push af  
9dbf					ld a, (.dmark)  
9dbf					ld (debug_mark),a  
9dbf					ld a, (.dmark+1)  
9dbf					ld (debug_mark+1),a  
9dbf					ld a, (.dmark+2)  
9dbf					ld (debug_mark+2),a  
9dbf				endif  
9dbf 18 04			jr .pastdmark  
9dc1 ..			.dmark: db "HEP"  
9dc4				if DEMARK_VERSION = 1  
9dc4 00					db 0  
9dc5				endif  
9dc5				if DEMARK_VERSION = 1  
9dc5 e1			.pastdmark: pop hl  
9dc6				endif  
9dc6				if DEMARK_VERSION = 0  
9dc6			.pastdmark: pop af  
9dc6				endif  
9dc6			endm  
# End of macro DMARK
9dc6					CALLMONITOR 
9dc6				if BASE_CPM=1  
9dc6					call debug_vector  
9dc6				endif  
9dc6				if BASE_KEV=1  
9dc6					rst 8  
9dc6				endif  
9dc6				endm  
# End of macro CALLMONITOR
9dc6				endif 
