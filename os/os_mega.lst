4cc3			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4cc3			; | | e.g. 
4cc3			; | | $01 OPEN $01 DO READ . LOOP 
4cc3			; | | 
4cc3			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4cc3			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4cc3			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4cc3			; | | two bytes contain the file id and extent. 
4cc3			; | |  
4cc3			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4cc3			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4cc3			; | | > [!NOTE] 
4cc3			; | | > Compatible with PicoSPINet  
4cc3			 
4cc3					if DEBUG_FORTH_WORDS_KEY 
4cc3						DMARK "REA" 
4cc3				if DEMARK_VERSION = 1  
4cc3 e5					push hl  
4cc4 21 cc 4c				ld hl, .dmark  
4cc7 22 9b fd				ld (debug_mark), hl  
4cca				endif  
4cca				if DEMARK_VERSION = 0  
4cca					push af  
4cca					ld a, (.dmark)  
4cca					ld (debug_mark),a  
4cca					ld a, (.dmark+1)  
4cca					ld (debug_mark+1),a  
4cca					ld a, (.dmark+2)  
4cca					ld (debug_mark+2),a  
4cca				endif  
4cca 18 04			jr .pastdmark  
4ccc ..			.dmark: db "REA"  
4ccf				if DEMARK_VERSION = 1  
4ccf 00					db 0  
4cd0				endif  
4cd0				if DEMARK_VERSION = 1  
4cd0 e1			.pastdmark: pop hl  
4cd1				endif  
4cd1				if DEMARK_VERSION = 0  
4cd1			.pastdmark: pop af  
4cd1				endif  
4cd1			endm  
# End of macro DMARK
4cd1						CALLMONITOR 
4cd1				if BASE_CPM=1  
4cd1					call debug_vector  
4cd1				endif  
4cd1				if BASE_KEV=1  
