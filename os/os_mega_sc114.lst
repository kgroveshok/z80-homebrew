d4d9			; Which startup method to use? 
d4d9			; 
d4d9			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
d4d9			; followed by loading of a list of scripts in eeprom 
d4d9			 
d4d9			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
d4d9			; from eeprom 
d4d9			 
d4d9			; Select with define in main stubs 
d4d9			 
d4d9			if STARTUP_V1 
d4d9				include "forth_startupv1.asm" 
d4d9			; Startup script loading version 1 
d4d9			 
d4d9			; If SE storage is available first stage is to use the selected file 
d4d9			; then go through the eeprom list 
d4d9			 
d4d9 .. 00		sprompt1: db "Startup load...",0 
d4e9 .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
