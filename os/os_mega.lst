6a36			  
6a36			; **********************************************************************  
6a36			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6a36			; **********************************************************************  
6a36			;  
6a36			; **  Written as a Small Computer Monitor App   
6a36			; **  Version 0.1 SCC 2018-05-16  
6a36			; **  www.scc.me.uk  
6a36			;  
6a36			; **********************************************************************  
6a36			;  
6a36			; This module provides support for alphanumeric LCD modules using with  
6a36			; *  HD44780 (or compatible) controller  
6a36			; *  5 x 7 pixel fonts  
6a36			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6a36			; *  Interface via six digital outputs to the display (see below)  
6a36			;  
6a36			; LCD module pinout:  
6a36			;   1  Vss   0v supply  
6a36			;   2  Vdd   5v supply  
6a36			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6a36			;   4  RS    High = data, Low = instruction  
6a36			;   5  R/W   High = Read, Low = Write  
6a36			;   6  E     Enable signal (active high)  
6a36			;   7  DB0   Data bit 0  
6a36			;   8  DB1   Data bit 1  
6a36			;   9  DB2   Data bit 2  
6a36			;  10  DB3   Data bit 3  
6a36			;  11  DB4   Data bit 4  
6a36			;  12  DB5   Data bit 5  
6a36			;  13  DB6   Data bit 6  
6a36			;  14  DB7   Data bit 7  
6a36			;  15  A     Backlight anode (+)  
6a36			;  16  K     Backlight cathode (-)  
6a36			;  
6a36			; This interfacing method uses 4-bit data mode and uses time delays  
6a36			; rather than polling the display's ready status. As a result the   
6a36			; interface only requires 6 simple output lines:  
6a36			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6a36			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6a36			;   LCD DB4 = Microcomputer output port bit 4  
6a36			;   LCD DB5 = Microcomputer output port bit 5  
6a36			;   LCD DB6 = Microcomputer output port bit 6  
6a36			;   LCD DB7 = Microcomputer output port bit 7  
6a36			; Display's R/W is connected to 0v so it is always in write mode  
6a36			; All 6 connections must be on the same port address <kLCDPrt>  
6a36			; This method also allows a decent length of cable from micro to LCD  
6a36			;  
6a36			; **********************************************************************  
6a36			;  
6a36			; To include the code for any given function provided by this module,   
6a36			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6a36			; the parent source file.  
6a36			; For example:  #REQUIRES   uHexPrefix  
6a36			;  
6a36			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6a36			; in the parent source file.  
6a36			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6a36			;  
6a36			; These are the function names provided by this module:  
6a36			; fLCD_Init                     ;Initialise LCD  
6a36			; fLCD_Inst                     ;Send instruction to LCD  
6a36			; fLCD_Data                     ;Send data byte to LCD  
6a36			; fLCD_Pos                      ;Position cursor  
6a36			; fLCD_Str                      ;Display string  
6a36			; fLCD_Def                      ;Define custom character  
6a36			;  
6a36			; **********************************************************************  
6a36			;  
6a36			; Requires SCMonAPI.asm to also be included in the project  
6a36			;  
6a36			  
6a36			  
6a36			; **********************************************************************  
6a36			; **  Constants  
6a36			; **********************************************************************  
6a36			  
6a36			; Constants that must be defined externally  
6a36			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6a36			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6a36			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6a36			;kLCDWidth: EQU 20             ;Width in characters  
6a36			  
6a36			; general line offsets in any frame buffer  
6a36			  
6a36			  
6a36			display_row_1: equ 0  
6a36			display_row_2: equ display_row_1+display_cols  
6a36			display_row_3: equ display_row_2 + display_cols  
6a36			display_row_4: equ display_row_3 + display_cols  
6a36			;display_row_4_eol:   
6a36			  
6a36			  
6a36			; Cursor position values for the start of each line  
6a36			  
6a36			; E  
6a36			kLCD_Line1: EQU 0x00   
6a36			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6a36			; E1  
6a36			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6a36			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6a36			  
6a36			; Instructions to send as A register to fLCD_Inst  
6a36			kLCD_Clear: EQU 00000001b     ;LCD clear  
6a36			kLCD_Off:   EQU 00001000b     ;LCD off  
6a36			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6a36			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6a36			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6a36			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6a36			  
6a36			; Constants used by this code module  
6a36			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6a36			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6a36			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6a36			  
6a36			  
6a36			  
6a36			; **********************************************************************  
6a36			; **  LCD support functions  
6a36			; **********************************************************************  
6a36			  
6a36			; Initialise alphanumeric LCD module  
6a36			; LCD control register codes:  
6a36			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6a36			;   N    0 = 1-line mode       1 = 2-line mode  
6a36			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6a36			;   D    0 = Display off       1 = Display on  
6a36			;   C    0 = Cursor off        1 = Cursor on  
6a36			;   B    0 = Blinking off      1 = Blinking on  
6a36			;   ID   0 = Decrement mode    1 = Increment mode  
6a36			;   SH   0 = Entire shift off  1 = Entire shift on  
6a36 3e 28		fLCD_Init:  LD   A, 40  
6a38 cd 5d 6b		            CALL LCDDelay       ;Delay 40ms after power up  
6a3b			; For reliable reset set 8-bit mode - 3 times  
6a3b cd 2d 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a3e cd 2d 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a41 cd 2d 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a44			; Set 4-bit mode  
6a44 cd 29 6b		            CALL WrFn4bit       ;Function = 4-bit mode  
6a47 cd 5b 6b		            CALL LCDDelay1      ;Delay 37 us or more  
6a4a			; Function set  
6a4a 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6a4c cd 5f 6a		            CALL fLCD_Inst      ;2 line, display on  
6a4f			; Display On/Off control  
6a4f 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6a51 cd 5f 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6a54			; Display Clear  
6a54 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6a56 cd 5f 6a		            CALL fLCD_Inst      ;Clear display  
6a59			; Entry mode  
6a59 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6a5b cd 5f 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
6a5e			; Display module now initialised  
6a5e c9			            RET  
6a5f			; ok to here  
6a5f			  
6a5f			; Write instruction to LCD  
6a5f			;   On entry: A = Instruction byte to be written  
6a5f			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a5f f5			fLCD_Inst:  PUSH AF  
6a60 f5			            PUSH AF  
6a61 cd 73 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a64 f1			            POP  AF  
6a65 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a66 17			            RLA  
6a67 17			            RLA  
6a68 17			            RLA  
6a69 cd 73 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6a6c 3e 02		            LD   A, 2  
6a6e cd 5d 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6a71 f1			            POP  AF  
6a72 c9			            RET  
6a73			Wr4bits:   
6a73 f5					push af  
6a74 3a fb fa				ld a, (display_lcde1e2)  
6a77 fe 00				cp 0     ; e  
6a79 20 10				jr nz, .wea2	  
6a7b f1					pop af  
6a7c e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a7e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a80 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6a82 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6a84 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a86 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6a88 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a8a c9			            RET  
6a8b f1			.wea2:		pop af  
6a8c e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a8e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a90 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6a92 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6a94 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a96 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6a98 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a9a c9			            RET  
6a9b			  
6a9b			  
6a9b			; Write data to LCD  
6a9b			;   On entry: A = Data byte to be written  
6a9b			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a9b f5			fLCD_Data:  PUSH AF  
6a9c f5			            PUSH AF  
6a9d cd af 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6aa0 f1			            POP  AF  
6aa1 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6aa2 17			            RLA  
6aa3 17			            RLA  
6aa4 17			            RLA  
6aa5 cd af 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6aa8 3e 96		            LD   A, 150  
6aaa 3d			Wait:      DEC  A              ;Wait a while to allow data   
6aab 20 fd		            JR   NZ, Wait      ;  write to complete  
6aad f1			            POP  AF  
6aae c9			            RET  
6aaf			Wr4bitsa:     
6aaf f5					push af  
6ab0 3a fb fa				ld a, (display_lcde1e2)  
6ab3 fe 00				cp 0     ; e1  
6ab5 20 16				jr nz, .we2	  
6ab7 f1					pop af  
6ab8 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6aba cb d7		            SET  kLCDBitRS, A  
6abc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6abe cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6ac0 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6ac2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6ac4 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6ac6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6ac8 cb 97		            RES  kLCDBitRS, A  
6aca d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6acc c9			            RET  
6acd f1			.we2:		pop af  
6ace e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6ad0 cb d7		            SET  kLCDBitRS, A  
6ad2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6ad4 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6ad6 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6ad8 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6ada cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6adc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6ade cb 97		            RES  kLCDBitRS, A  
6ae0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6ae2 c9			            RET  
6ae3			  
6ae3			  
6ae3			; Position cursor to specified location  
6ae3			;   On entry: A = Cursor position  
6ae3			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ae3 f5			fLCD_Pos:   PUSH AF  
6ae4					; at this point set the E1 or E2 flag depending on position  
6ae4			  
6ae4 c5					push bc  
6ae5			;		push af  
6ae5 06 00				ld b, 0  
6ae7 4f					ld c, a  
6ae8 3e 4f				ld a, kLCD_Line3-1  
6aea b7			 		or a      ;clear carry flag  
6aeb 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6aec 38 04				jr c, .pe1  
6aee			  
6aee					; E selection  
6aee cb 80				res 0, b         ; bit 0 unset e  
6af0			;		pop af    ; before line 3 so recover orig pos  
6af0			;		ld c, a    ; save for poking back  
6af0 18 06				jr .peset	          
6af2			.pe1:          	; E2 selection  
6af2 cb c0				set 0, b         ; bit 0 set e1  
6af4 79					ld a, c  
6af5 de 4f				sbc a, kLCD_Line3-1  
6af7 4f					ld c, a	         ; save caculated offset  
6af8			;		pop af     ; bin this original value now we have calculated form  
6af8			  
6af8			.peset:		; set bit  
6af8 78					ld a, b  
6af9 32 fb fa				ld (display_lcde1e2), a 	  
6afc 79					ld a, c  
6afd c1					pop bc  
6afe			  
6afe f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6b00 cd 5f 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6b03 f1			            POP  AF  
6b04 c9			            RET  
6b05			  
6b05			  
6b05			; Output text string to LCD  
6b05			;   On entry: DE = Pointer to null terminated text string  
6b05			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6b05 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6b06 b7			            OR   A              ;Null terminator?  
6b07 c8			            RET  Z              ;Yes, so finished  
6b08 cd 9b 6a		            CALL fLCD_Data      ;Write character to display  
6b0b 13			            INC  DE             ;Point to next character  
6b0c 18 f7		            JR   fLCD_Str       ;Repeat  
6b0e c9					ret  
6b0f			  
6b0f			; Define custom character  
6b0f			;   On entry: A = Character number (0 to 7)  
6b0f			;             DE = Pointer to character bitmap data  
6b0f			;   On exit:  A = Next character number  
6b0f			;             DE = Next location following bitmap  
6b0f			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6b0f			; Character is   
6b0f c5			fLCD_Def:   PUSH BC  
6b10 f5			            PUSH AF  
6b11 07			            RLCA                ;Calculate location  
6b12 07			            RLCA                ;  for bitmap data  
6b13 07			            RLCA                ;  = 8 x CharacterNumber  
6b14 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6b16 cd 5f 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6b19 06 00		            LD   B, 0  
6b1b 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6b1c cd 9b 6a		            CALL fLCD_Data      ;Write byte to display  
6b1f 13			            INC  DE             ;Point to next byte  
6b20 04			            INC  B              ;Count bytes  
6b21 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6b23 28 f6		            JR   Z, Loop       ;No, so repeat  
6b25 f1			            POP  AF  
6b26 3c			            INC  A              ;Increment character number  
6b27 c1			            POP  BC  
6b28 c9			            RET  
