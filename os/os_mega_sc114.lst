bf24					NEXTW 
bf24			 
bf24			 
bf24			 
bf24			.SESEL: 
bf24				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bf24			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bf24			; | | Zero is disabled storage. 
bf24					if DEBUG_FORTH_WORDS_KEY 
bf24						DMARK "BN?" 
bf24						CALLMONITOR 
bf24					endif 
bf24					ld a, (spi_device_id) 
bf24					sub '0' 
bf24					ld h, 0 
bf24					ld l, a 
bf24					FORTH_PUSH_VALUEHL 
bf24					;call forth_push_numhl 
bf24					NEXTW 
bf24			.SESELS: 
bf24				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bf24			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bf24			; | | Set to zero to disable storage. 
bf24					if DEBUG_FORTH_WORDS_KEY 
bf24						DMARK "BNK" 
bf24						CALLMONITOR 
bf24					endif 
bf24			 
bf24					ld a, 255 
bf24					ld (spi_cartdev), a 
bf24			 
bf24					; get bank 
bf24			 
bf24					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf24			 
bf24			;		push hl 
bf24			 
bf24					; destroy value TOS 
bf24			 
bf24					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf24			 
bf24					; one value on hl get other one back 
bf24			 
bf24			;		pop hl 
bf24			 
bf24			 
bf24					ld c, SPI_CE_HIGH 
bf24					ld b, '0'    ; human readable bank number 
bf24			 
bf24					ld a, l 
bf24			 
bf24					if DEBUG_FORTH_WORDS 
bf24						DMARK "BNK" 
bf24						CALLMONITOR 
bf24					endif 
bf24			 
bf24					; active low 
bf24			 
bf24			;		cp 0 
bf24					or a 
bf24					jr z, .bset 
bf24					cp 1 
bf24					jr nz, .b2 
bf24					res 0, c 
bf24					ld b, '1'    ; human readable bank number 
bf24			.b2:		cp 2 
bf24					jr nz, .b3 
bf24					res 1, c 
bf24					ld b, '2'    ; human readable bank number 
bf24			.b3:		cp 3 
bf24					jr nz, .b4 
bf24					res 2, c 
bf24					ld b, '3'    ; human readable bank number 
bf24			.b4:		cp 4 
bf24					jr nz, .b5 
bf24					res 3, c 
bf24					ld b, '4'    ; human readable bank number 
bf24			.b5:		cp 5 
bf24					jr nz, .bset 
bf24					res 4, c 
bf24					ld b, '5'    ; human readable bank number 
bf24			 
bf24			.bset: 
bf24					ld a, c 
bf24					ld (spi_device),a 
bf24					ld a, b 
bf24					ld (spi_device_id),a 
bf24					if DEBUG_FORTH_WORDS 
bf24						DMARK "BN2" 
bf24						CALLMONITOR 
bf24					endif 
bf24			 
bf24					; set default SPI clk pulse time as disabled for BANK use 
bf24			 
bf24					ld a, 0 
bf24					ld (spi_clktime), a 
bf24			 
bf24					NEXTW 
bf24			 
bf24			.CARTDEV: 
bf24				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bf24			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bf24			; | | Set to zero to disable devices. 
bf24					if DEBUG_FORTH_WORDS_KEY 
bf24						DMARK "CDV" 
bf24						CALLMONITOR 
bf24					endif 
bf24			 
bf24					; disable se storage bank selection 
bf24			 
bf24					ld a, SPI_CE_HIGH		; ce high 
bf24					ld (spi_device), a 
bf24			 
bf24					; get bank 
bf24			 
bf24					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf24			 
bf24			;		push hl 
bf24			 
bf24					; destroy value TOS 
bf24			 
bf24					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf24			 
bf24					; one value on hl get other one back 
bf24			 
bf24			;		pop hl 
bf24			 
bf24					; active low 
bf24			 
bf24					ld c, 255 
bf24			 
bf24					ld a, l 
bf24					if DEBUG_FORTH_WORDS 
bf24						DMARK "CDV" 
bf24						CALLMONITOR 
bf24					endif 
bf24			;		cp 0 
bf24					or a 
bf24					jr z, .cset 
bf24					cp 1 
bf24					jr nz, .c2 
bf24					res 0, c 
bf24			.c2:		cp 2 
bf24					jr nz, .c3 
bf24					res 1, c 
bf24			.c3:		cp 3 
bf24					jr nz, .c4 
bf24					res 2, c 
bf24			.c4:		cp 4 
bf24					jr nz, .c5 
bf24					res 3, c 
bf24			.c5:		cp 5 
bf24					jr nz, .c6 
bf24					res 4, c 
bf24			.c6:		cp 6 
bf24					jr nz, .c7 
bf24					res 5, c 
bf24			.c7:		cp 7 
bf24					jr nz, .c8 
bf24					res 6, c 
bf24			.c8:		cp 8 
bf24					jr nz, .cset 
bf24					res 7, c 
bf24			.cset:		ld a, c 
bf24					ld (spi_cartdev),a 
bf24			 
bf24					if DEBUG_FORTH_WORDS 
bf24						DMARK "CD2" 
bf24						CALLMONITOR 
bf24					endif 
bf24			 
bf24					; set default SPI clk pulse time as 10ms for CARTDEV use 
bf24			 
bf24					ld a, $0a 
bf24					ld (spi_clktime), a 
bf24					NEXTW 
bf24			endif 
bf24			 
bf24			.ENDDEVICE: 
bf24			; eof 
bf24			 
# End of file forth_words_device.asm
