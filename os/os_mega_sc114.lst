8d86			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
8d86			 
8d86			toUpper: 
8d86			;A is the char. 
8d86			;If A is a lowercase letter, this sets it to the matching uppercase 
8d86			;18cc or 30cc or 41cc 
8d86			;avg: 26.75cc 
8d86 fe 61		  cp 'a' 
8d88 d8			  ret c 
8d89 fe 7b		  cp 'z'+1 
8d8b d0			  ret nc 
8d8c d6 20		  sub 'a'-'A' 
8d8e c9			  ret 
