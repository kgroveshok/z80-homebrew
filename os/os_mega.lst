68ac 32 fb fa				ld (display_lcde1e2), a  
68af cd 30 69		            CALL fLCD_Init      ;Initialise LCD module  
68b2 3e 01				ld a, 1  
68b4 32 fb fa				ld (display_lcde1e2), a  
68b7 cd 30 69		            CALL fLCD_Init      ;Initialise LCD module  
68ba			  
68ba c9				ret  
