0d39 87			    add a,a 
0d3a 30 01		    jr nc,Mult12U_NoAdd6 
0d3c 19			    add hl,de 
0d3d			Mult12U_NoAdd6: 
0d3d 29			    add hl,hl 
0d3e 87			    add a,a 
0d3f d0			    ret nc 
0d40 19			    add hl,de 
0d41 c9			    ret 
