668b			; Which startup method to use? 
668b			; 
668b			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
668b			; followed by loading of a list of scripts in eeprom 
668b			 
668b			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
668b			; from eeprom 
668b			 
668b			; Select with define in main stubs 
668b			 
668b			if STARTUP_V1 
668b				include "forth_startupv1.asm" 
668b			endif 
668b			if STARTUP_V2 
668b				include "forth_startupv2.asm" 
668b			; Version 2 of the startup  
668b			;  
668b			; Auto load any files in bank 1 that start with a '*' 
668b			; If no se storage then revert to using eprom 
668b			 
668b			 
668b			if STORAGE_SE = 0 
668b			 
668b			sprompt1: db "Startup load...",0 
668b			sprompt2: db "Run? 1=No *=End #=All",0 
668b			 
668b			 
668b			 
668b			 
668b			forth_startup: 
668b				ld hl, startcmds 
668b				ld a, 0 
668b				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
668b			 
668b			.start1:	push hl 
668b				call clear_display 
668b				ld de, sprompt1 
668b			        ld a, display_row_1 
668b				call str_at_display 
668b				ld de, sprompt2 
668b			        ld a, display_row_2 
668b				call str_at_display 
668b				pop hl 
668b				push hl 
668b				ld e,(hl) 
668b				inc hl 
668b				ld d,(hl) 
668b			        ld a, display_row_3 
668b				call str_at_display 
668b				call update_display 
668b			 
668b			 
668b				ld a, (os_last_cmd) 
668b			;	cp 0 
668b				or a 
668b				jr z, .startprompt 
668b				call delay250ms 
668b				jr .startdo 
668b				 
668b				 
668b			 
668b			.startprompt: 
668b			 
668b				ld a,display_row_4 + display_cols - 1 
668b			        ld de, endprg 
668b				call str_at_display 
668b				call update_display 
668b				call delay1s 
668b				call cin_wait 
668b						 
668b				cp '*' 
668b				jr z, .startupend1 
668b				cp '#' 
668b				jr nz, .startno 
668b				ld a, 1 
668b				ld (os_last_cmd),a 
668b				jr .startdo 
668b			.startno:	cp '1' 
668b				jr z,.startnxt  
668b			 
668b				; exec startup line 
668b			.startdo:	 
668b				pop hl 
668b				push hl 
668b				 
668b				ld e,(hl) 
668b				inc hl 
668b				ld d,(hl) 
668b				ex de,hl 
668b			 
668b				push hl 
668b			 
668b				ld a, 0 
668b				;ld a, FORTH_END_BUFFER 
668b				call strlent 
668b				inc hl   ; include zero term to copy 
668b				ld b,0 
668b				ld c,l 
668b				pop hl 
668b				ld de, scratch 
668b				ldir 
668b			 
668b			 
668b				ld hl, scratch 
668b				call forthparse 
668b				call forthexec 
668b				call forthexec_cleanup 
668b			 
668b				ld a, display_row_4 
668b				ld de, endprog 
668b			 
668b				call update_display		 
668b			 
668b				ld a, (os_last_cmd) 
668b			;	cp 0 
668b				or a 
668b				jr nz, .startnxt 
668b				call next_page_prompt 
668b			        call clear_display 
668b				call update_display		 
668b			 
668b				; move onto next startup line? 
668b			.startnxt: 
668b			 
668b				call delay250ms 
668b				pop hl 
668b			 
668b				inc hl 
668b				inc hl 
668b			 
668b				push hl 
668b				ld e, (hl) 
668b				inc hl 
668b				ld d, (hl) 
668b				pop hl 
668b				; TODO replace 0 test 
668b			 
668b				ex de, hl 
668b				call ishlzero 
668b			;	ld a,e 
668b			;	add d 
668b			;	cp 0    ; any left to do? 
668b				ex de, hl 
668b				jp nz, .start1 
668b				jr .startupend 
668b			 
668b			.startupend1: pop hl 
668b			.startupend: 
668b			 
668b				call clear_display 
668b				call update_display 
668b				ret 
668b			endif 
