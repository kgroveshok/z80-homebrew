10b0			free_find_higher_block: 
10b0 5e			      ld    E, (HL)                 ; Load next ptr from free block 
10b1 23			      inc   HL 
10b2 56			      ld    D, (HL) 
10b3 2b			      dec   HL 
10b4			 
10b4 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
10b7 dd 72 01		      ld    (IX+1), D 
10ba dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
10bd dd 74 03		      ld    (IX+3), H 
10c0			 
10c0 78			      ld    A, B                    ; Check if DE is greater than BC 
