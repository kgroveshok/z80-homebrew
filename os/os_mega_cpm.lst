11a8			config_fdir: 
11a8				; using the scratch dir go through and release the memory allocated for each string 
11a8				 
11a8				ld hl, scratch 
11a8			.cfdir:	ld e,(hl) 
11a8				inc hl 
11a8				ld d,(hl) 
11a8				inc hl 
11a8			 
11a8				ex de, hl 
11a8				call ishlzero 
11a8				ret z     ; return on null pointer 
11a8				call free 
11a8				ex de, hl 
11a8				jr .cfdir 
11a8			 
11a8			 
11a8				ret 
11a8			 
11a8			 
11a8			config_dir: 
11a8			 
11a8				; for the config menus that need to build a directory of storage call this routine 
11a8				; it will construct a menu in scratch to pass to menu 
11a8			 
11a8				; open storage device 
11a8			 
11a8				; execute DIR to build a list of files and their ids into scratch in menu format 
11a8				; once the menu has finished then will need to call config_fdir to release the strings 
11a8				 
11a8				; c = number items 
11a8			 
11a8				 
11a8				call storage_get_block_0 
11a8			 
11a8				ld hl, store_page     ; get current id count 
11a8				ld b, (hl) 
11a8				ld c, 0    ; count of files   
11a8			 
11a8			 
11a8				ld hl, scratch 
11a8				ld (store_tmp2), hl    ; location to poke strings 
11a8			 
11a8				; check for empty drive 
11a8			 
11a8				ld a, 0 
11a8				cp b 
11a8				jp z, .dirdone 
11a8			 
11a8				 
11a8					if DEBUG_FORTH_WORDS 
11a8						DMARK "Cdc" 
11a8						CALLMONITOR 
11a8					endif 
11a8			 
11a8			 
11a8			.diritem:	 
11a8				push bc 
11a8				; for each of the current ids do a search for them and if found push to stack 
11a8			 
11a8					ld hl, STORE_BLOCK_PHY 
11a8					ld d, 0		 ; look for extent 0 of block id as this contains file name 
11a8					ld e,b 
11a8			 
11a8					call storage_findnextid 
11a8			 
11a8			 
11a8					; if found hl will be non zero 
11a8			 
11a8					call ishlzero 
11a8					jr z, .dirnotfound 
11a8			 
11a8					; increase count 
11a8			 
11a8					pop bc	 
11a8					inc c 
11a8					push bc 
11a8					 
11a8			 
11a8					; get file header and push the file name 
11a8			 
11a8					ld de, store_page 
11a8					call storage_read_block 
11a8			 
11a8					; push file id to stack 
11a8				 
11a8					ld a, (store_page) 
11a8					ld h, 0 
11a8					ld l, a 
11a8			 
11a8					;call forth_push_numhl 
11a8					; TODO store id 
11a8			 
11a8					push hl 
11a8			 
11a8					; push extent count to stack  
11a8				 
11a8					ld hl, store_page+3 
11a8			 
11a8					; get file name length 
11a8			 
11a8					call strlenz   
11a8			 
11a8					inc hl   ; cover zero term 
11a8					inc hl  ; stick the id at the end of the area 
11a8			 
11a8					push hl 
11a8					pop bc    ; move length to bc 
11a8			 
11a8					call malloc 
11a8			 
11a8					; TODO save malloc area to scratch 
11a8			 
11a8					ex de, hl 
11a8					ld hl, (store_tmp2) 
11a8					ld (hl), e 
11a8					inc hl 
11a8					ld (hl), d 
11a8					inc hl 
11a8					ld (store_tmp2), hl 
11a8			 
11a8					 
11a8			 
11a8					;pop hl   ; get source 
11a8			;		ex de, hl    ; swap aronund	 
11a8			 
11a8					ld hl, store_page+3 
11a8					if DEBUG_FORTH_WORDS 
11a8						DMARK "CFd" 
11a8						CALLMONITOR 
11a8					endif 
11a8					ldir 
11a8			 
11a8					; de is past string, move back one and store id 
11a8					 
11a8					dec de 
11a8			 
11a8					; store file id 
11a8			 
11a8					pop hl 
11a8					ex de,hl 
11a8					ld (hl), e 
11a8			 
11a8					if DEBUG_FORTH_WORDS 
11a8						DMARK "Cdi" 
11a8						CALLMONITOR 
11a8					endif 
11a8					 
11a8			.dirnotfound: 
11a8					pop bc     
11a8					djnz .diritem 
11a8				 
11a8			.dirdone:	 
11a8			 
11a8			;		ld a, 0 
11a8					ld hl, (store_tmp2) 
11a8					ld (hl), 0 
11a8					inc hl 
11a8					ld (hl), 0 
11a8					inc hl 
11a8					; push a count of the dir items found 
11a8			 
11a8			;		ld h, 0 
11a8			;		ld l, c 
11a8			 
11a8				ret 
11a8			 
11a8			endif 
