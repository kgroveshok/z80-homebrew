69dc			; **********************************************************************  
69dc			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
69dc			; **********************************************************************  
69dc			;  
69dc			; **  Written as a Small Computer Monitor App   
69dc			; **  Version 0.1 SCC 2018-05-16  
69dc			; **  www.scc.me.uk  
69dc			;  
69dc			; **********************************************************************  
69dc			;  
69dc			; This module provides support for alphanumeric LCD modules using with  
69dc			; *  HD44780 (or compatible) controller  
69dc			; *  5 x 7 pixel fonts  
69dc			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
69dc			; *  Interface via six digital outputs to the display (see below)  
69dc			;  
69dc			; LCD module pinout:  
69dc			;   1  Vss   0v supply  
69dc			;   2  Vdd   5v supply  
69dc			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
69dc			;   4  RS    High = data, Low = instruction  
69dc			;   5  R/W   High = Read, Low = Write  
69dc			;   6  E     Enable signal (active high)  
69dc			;   7  DB0   Data bit 0  
69dc			;   8  DB1   Data bit 1  
69dc			;   9  DB2   Data bit 2  
69dc			;  10  DB3   Data bit 3  
69dc			;  11  DB4   Data bit 4  
69dc			;  12  DB5   Data bit 5  
69dc			;  13  DB6   Data bit 6  
69dc			;  14  DB7   Data bit 7  
69dc			;  15  A     Backlight anode (+)  
69dc			;  16  K     Backlight cathode (-)  
69dc			;  
69dc			; This interfacing method uses 4-bit data mode and uses time delays  
69dc			; rather than polling the display's ready status. As a result the   
69dc			; interface only requires 6 simple output lines:  
69dc			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
69dc			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
69dc			;   LCD DB4 = Microcomputer output port bit 4  
69dc			;   LCD DB5 = Microcomputer output port bit 5  
69dc			;   LCD DB6 = Microcomputer output port bit 6  
69dc			;   LCD DB7 = Microcomputer output port bit 7  
69dc			; Display's R/W is connected to 0v so it is always in write mode  
69dc			; All 6 connections must be on the same port address <kLCDPrt>  
69dc			; This method also allows a decent length of cable from micro to LCD  
69dc			;  
69dc			; **********************************************************************  
69dc			;  
69dc			; To include the code for any given function provided by this module,   
69dc			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
69dc			; the parent source file.  
69dc			; For example:  #REQUIRES   uHexPrefix  
69dc			;  
69dc			; Also #INCLUDE this file at some point after the #REQUIRES statements  
69dc			; in the parent source file.  
69dc			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
69dc			;  
69dc			; These are the function names provided by this module:  
69dc			; fLCD_Init                     ;Initialise LCD  
69dc			; fLCD_Inst                     ;Send instruction to LCD  
69dc			; fLCD_Data                     ;Send data byte to LCD  
69dc			; fLCD_Pos                      ;Position cursor  
69dc			; fLCD_Str                      ;Display string  
69dc			; fLCD_Def                      ;Define custom character  
69dc			;  
69dc			; **********************************************************************  
69dc			;  
69dc			; Requires SCMonAPI.asm to also be included in the project  
69dc			;  
69dc			  
69dc			  
69dc			; **********************************************************************  
69dc			; **  Constants  
69dc			; **********************************************************************  
69dc			  
69dc			; Constants that must be defined externally  
69dc			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
69dc			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
69dc			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
69dc			;kLCDWidth: EQU 20             ;Width in characters  
69dc			  
69dc			; general line offsets in any frame buffer  
69dc			  
69dc			  
69dc			display_row_1: equ 0  
69dc			display_row_2: equ display_row_1+display_cols  
69dc			display_row_3: equ display_row_2 + display_cols  
69dc			display_row_4: equ display_row_3 + display_cols  
69dc			;display_row_4_eol:   
69dc			  
69dc			  
69dc			; Cursor position values for the start of each line  
69dc			  
69dc			; E  
69dc			kLCD_Line1: EQU 0x00   
69dc			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
69dc			; E1  
69dc			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
69dc			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
69dc			  
69dc			; Instructions to send as A register to fLCD_Inst  
69dc			kLCD_Clear: EQU 00000001b     ;LCD clear  
69dc			kLCD_Off:   EQU 00001000b     ;LCD off  
69dc			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
69dc			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
69dc			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
69dc			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
69dc			  
69dc			; Constants used by this code module  
69dc			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
69dc			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
69dc			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
