1319			StrictStrCmp: 
1319				; Load next chars of each string 
1319 1a				ld a, (de) 
131a 47				ld b, a 
131b 7e				ld a, (hl) 
131c				; Compare 
131c b8				cp b 
131d				; Return non-zero if chars don't match 
131d c0				ret nz 
131e				; Check for end of both strings 
131e fe 00			cp "\0" 
1320				; Return if strings have ended 
1320 c8				ret z 
1321				; Otherwise, advance to next chars 
1321 23				inc hl 
1322 13				inc de 
1323 18 f4			jr StrictStrCmp 
