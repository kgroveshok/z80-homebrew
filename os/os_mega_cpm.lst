4428				CWHEAD .SOUT 31 "IN" 2 WORD_FLAG_CODE 
4428 33				db WORD_SYS_CORE+31             
4429 55 44			dw .SOUT            
442b 03				db 2 + 1 
442c .. 00			db "IN",0              
442f				endm 
# End of macro CWHEAD
442f			; | IN ( u1 -- u )    Perform Z80 IN with u1 being the port number. Push result to TOS | DONE 
442f					if DEBUG_FORTH_WORDS_KEY 
442f						DMARK "IN." 
442f				if DEMARK_VERSION = 1  
442f e5					push hl  
4430 21 38 44				ld hl, .dmark  
4433 22 60 ee				ld (debug_mark), hl  
4436				endif  
4436				if DEMARK_VERSION = 0  
4436					push af  
4436					ld a, (.dmark)  
4436					ld (debug_mark),a  
4436					ld a, (.dmark+1)  
4436					ld (debug_mark+1),a  
4436					ld a, (.dmark+2)  
4436					ld (debug_mark+2),a  
4436				endif  
4436 18 04			jr .pastdmark  
4438 ..			.dmark: db "IN."  
443b				if DEMARK_VERSION = 1  
443b 00					db 0  
443c				endif  
443c				if DEMARK_VERSION = 1  
443c e1			.pastdmark: pop hl  
443d				endif  
443d				if DEMARK_VERSION = 0  
443d			.pastdmark: pop af  
443d				endif  
443d			endm  
# End of macro DMARK
443d						CALLMONITOR 
443d				if BASE_CPM=1  
443d cd 6b ee				call debug_vector  
4440				endif  
4440				if BASE_KEV=1  
4440					rst 8  
4440				endif  
4440				endm  
# End of macro CALLMONITOR
4440					endif 
4440					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4440				if BASE_CPM=1 
4440 cd 91 1a			call macro_dsp_valuehl 
4443				endif 
4443				if BASE_KEV=1 
4443					rst $18 
4443				endif 
4443				endm 
# End of macro FORTH_DSP_VALUEHL
4443			 
4443 e5					push hl 
4444			 
4444					; destroy value TOS 
4444			 
4444					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4444				if BASE_CPM=1 
4444 cd 28 1b			call macro_forth_dsp_pop 
4447				endif 
4447				if BASE_KEV=1 
4447					rst $10 
4447				endif 
4447				endm 
# End of macro FORTH_DSP_POP
4447			 
4447					; one value on hl get other one back 
4447			 
4447 c1					pop bc 
4448			 
4448					; do the sub 
4448			;		ex de, hl 
4448			 
4448 ed 68				in l,(c) 
444a			 
444a					; save it 
444a			 
444a 26 00				ld h,0 
444c			 
444c					; TODO push value back onto stack for another op etc 
444c			 
444c					;call forth_push_numhl 
444c			 
444c					FORTH_PUSH_VALUEHL 
444c				if BASE_CPM=1 
444c cd 03 19				call forth_push_numhl 
444f				endif 
444f				if BASE_KEV=1 
444f					rst $20 
444f				endif 
444f				endm 
# End of macro FORTH_PUSH_VALUEHL
444f					NEXTW 
444f cd 68 ee			call parse_vector 
4452 c3 41 1c			jp macro_next 
4455				endm 
# End of macro NEXTW
4455			.SOUT: 
4455				CWHEAD .SPIO 32 "OUT" 3 WORD_FLAG_CODE 
4455 34				db WORD_SYS_CORE+32             
4456 95 44			dw .SPIO            
4458 04				db 3 + 1 
4459 .. 00			db "OUT",0              
445d				endm 
# End of macro CWHEAD
445d			; | OUT ( u1 u2 -- ) Perform Z80 OUT to port u2 sending byte u1 | DONE 
445d					if DEBUG_FORTH_WORDS_KEY 
445d						DMARK "OUT" 
445d				if DEMARK_VERSION = 1  
445d e5					push hl  
445e 21 66 44				ld hl, .dmark  
4461 22 60 ee				ld (debug_mark), hl  
4464				endif  
4464				if DEMARK_VERSION = 0  
4464					push af  
4464					ld a, (.dmark)  
4464					ld (debug_mark),a  
4464					ld a, (.dmark+1)  
4464					ld (debug_mark+1),a  
4464					ld a, (.dmark+2)  
4464					ld (debug_mark+2),a  
4464				endif  
4464 18 04			jr .pastdmark  
4466 ..			.dmark: db "OUT"  
4469				if DEMARK_VERSION = 1  
4469 00					db 0  
446a				endif  
446a				if DEMARK_VERSION = 1  
446a e1			.pastdmark: pop hl  
446b				endif  
446b				if DEMARK_VERSION = 0  
446b			.pastdmark: pop af  
446b				endif  
446b			endm  
# End of macro DMARK
446b						CALLMONITOR 
446b				if BASE_CPM=1  
446b cd 6b ee				call debug_vector  
446e				endif  
446e				if BASE_KEV=1  
446e					rst 8  
446e				endif  
446e				endm  
# End of macro CALLMONITOR
446e					endif 
446e			 
446e					; get port 
446e			 
446e					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
446e				if BASE_CPM=1 
446e cd 91 1a			call macro_dsp_valuehl 
4471				endif 
4471				if BASE_KEV=1 
4471					rst $18 
4471				endif 
4471				endm 
# End of macro FORTH_DSP_VALUEHL
4471			 
4471 e5					push hl 
4472			 
4472					; destroy value TOS 
4472			 
4472					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4472				if BASE_CPM=1 
4472 cd 28 1b			call macro_forth_dsp_pop 
4475				endif 
4475				if BASE_KEV=1 
4475					rst $10 
4475				endif 
4475				endm 
# End of macro FORTH_DSP_POP
4475			 
4475					; get byte to send 
4475			 
4475					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4475				if BASE_CPM=1 
4475 cd 91 1a			call macro_dsp_valuehl 
4478				endif 
4478				if BASE_KEV=1 
4478					rst $18 
4478				endif 
4478				endm 
# End of macro FORTH_DSP_VALUEHL
4478			 
4478			;		push hl 
4478			 
4478					; destroy value TOS 
4478			 
4478					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4478				if BASE_CPM=1 
4478 cd 28 1b			call macro_forth_dsp_pop 
447b				endif 
447b				if BASE_KEV=1 
447b					rst $10 
447b				endif 
447b				endm 
# End of macro FORTH_DSP_POP
447b			 
447b					; one value on hl get other one back 
447b			 
447b			;		pop hl 
447b			 
447b c1					pop bc 
447c			 
447c					if DEBUG_FORTH_WORDS 
447c						DMARK "OUT" 
447c				if DEMARK_VERSION = 1  
447c e5					push hl  
447d 21 85 44				ld hl, .dmark  
4480 22 60 ee				ld (debug_mark), hl  
4483				endif  
4483				if DEMARK_VERSION = 0  
4483					push af  
4483					ld a, (.dmark)  
4483					ld (debug_mark),a  
4483					ld a, (.dmark+1)  
4483					ld (debug_mark+1),a  
4483					ld a, (.dmark+2)  
4483					ld (debug_mark+2),a  
4483				endif  
4483 18 04			jr .pastdmark  
4485 ..			.dmark: db "OUT"  
4488				if DEMARK_VERSION = 1  
4488 00					db 0  
4489				endif  
4489				if DEMARK_VERSION = 1  
4489 e1			.pastdmark: pop hl  
448a				endif  
448a				if DEMARK_VERSION = 0  
448a			.pastdmark: pop af  
448a				endif  
448a			endm  
# End of macro DMARK
448a						CALLMONITOR 
448a				if BASE_CPM=1  
448a cd 6b ee				call debug_vector  
448d				endif  
448d				if BASE_KEV=1  
448d					rst 8  
448d				endif  
448d				endm  
# End of macro CALLMONITOR
448d					endif 
448d			 
448d ed 69				out (c), l 
448f			 
448f					NEXTW 
