2ace			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2ace			; | | At start the current various registers will be displayed with contents. 
2ace			; | | Top right corner will show the most recent debug marker seen. 
2ace			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2ace			; | | and the return stack pointer (RSP). 
2ace			; | | Pressing: 
2ace			; | |  
2ace			; | |    1 - Initial screen 
2ace			; | |  
2ace			; | |    2 - Display a data dump of HL 
2ace			; | |  
2ace			; | |    3 - Display a data dump of DE 
2ace			; | |  
2ace			; | |    4 - Display a data dump of BC 
2ace			; | |  
2ace			; | |    5 - Display a data dump of HL 
2ace			; | |  
2ace			; | |    6 - Display a data dump of DSP 
2ace			; | |  
2ace			; | |    7 - Display a data dump of RSP 
2ace			; | |  
2ace			; | |    8 - Display a data dump of what is at DSP 
2ace			; | |  
2ace			; | |    9 - Display a data dump of what is at RSP 
2ace			; | |  
2ace			; | |    0 - Exit monitor and continue running. This will also enable break points 
2ace			; | |  
2ace			; | |    * - Disable break points 
2ace			; | |  
2ace			; | |    # - Enter traditional monitor mode 
2ace			; | |  
2ace			; | | 
2ace			; | | Monitor Mode 
2ace			; | | ------------ 
2ace			; | | A prompt of '>' will be shown for various commands: 
2ace			; | |  
2ace			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2ace			; | |  
2ace			; | |    C - Continue display a data dump from the last set address 
2ace			; | |  
2ace			; | |    M xxxx - Set start of memory edit at address xx 
2ace			; | |  
2ace			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2ace			; | |  
2ace			; | |    G xxxx - Exec code at specific address 
2ace			; | |  
2ace			; | |    Q - Return to previous 
2ace				if DEBUG_FORTH_WORDS_KEY 
2ace					DMARK "MON" 
2ace				if DEMARK_VERSION = 1  
2ace e5					push hl  
2acf 21 d7 2a				ld hl, .dmark  
2ad2 22 9b fd				ld (debug_mark), hl  
2ad5				endif  
