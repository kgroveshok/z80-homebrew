920e			config_dir: 
920e			 
920e				; for the config menus that need to build a directory of storage call this routine 
920e				; it will construct a menu in scratch to pass to menu 
920e			 
920e				; open storage device 
920e			 
920e				; execute DIR to build a list of files and their ids into scratch in menu format 
920e				; once the menu has finished then will need to call config_fdir to release the strings 
920e				 
920e				; c = number items 
920e			 
920e				 
920e				call storage_get_block_0 
920e			 
920e				ld hl, store_page     ; get current id count 
920e				ld b, (hl) 
920e				ld c, 0    ; count of files   
920e			 
920e			 
920e				ld hl, scratch 
920e				ld (store_tmp2), hl    ; location to poke strings 
920e			 
920e				; check for empty drive 
920e			 
