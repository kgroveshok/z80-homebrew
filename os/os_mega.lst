5323				endm 
# End of macro CWHEAD
5323			; | SPITIME ( -- u1 )   Pushes address of the SPI pulse counter/delay to stack | DONE 
5323			; 
5323			; | | If using BANK devices then leave as is. 
5323			; | | Only really useful for the CARTDEV where other devices may be far too slow. In particular 
5323			; | | the multiplexing of the PicoSPINet addon which might not be running fast enough for all of the nodes 
5323			 
5323 21 92 f9				ld hl, spi_clktime  
5326 cd d6 1f				call forth_push_numhl 
