1bd5 23				inc hl 
1bd6			 
1bd6 11 7f 1d			ld de, sysdict 
1bd9 73				ld (hl), e		; next word link ie system dict 
1bda 23				inc hl 
1bdb 72				ld (hl), d		; next word link ie system dict 
1bdc 23				inc hl	 
1bdd			 
1bdd			;	ld (hl), sysdict		; next word link ie system dict 
