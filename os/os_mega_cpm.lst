0eb1			;      NOTE: This isn't necessarily the same as the input HL. 
0eb1 d5			  push de 
0eb2 c5			  push bc 
0eb3 f5			  push af 
0eb4 eb			  ex de,hl 
0eb5			 
0eb5 01 f0 d8		  ld bc,-10000 
0eb8 3e 2f		  ld a,'0'-1 
0eba 3c			  inc a 
0ebb 09			  add hl,bc  
0ebc 38 fc		   jr c,$-2 
0ebe 12			  ld (de),a 
0ebf 13			  inc de 
0ec0			 
0ec0 01 e8 03		  ld bc,1000 
0ec3 3e 3a		  ld a,'9'+1 
0ec5 3d			  dec a  
0ec6 09			  add hl,bc  
0ec7 30 fc		   jr nc,$-2 
0ec9 12			  ld (de),a 
0eca 13			  inc de 
0ecb			 
0ecb 01 9c ff		  ld bc,-100 
0ece 3e 2f		  ld a,'0'-1 
0ed0 3c			  inc a  
0ed1 09			  add hl,bc  
0ed2 38 fc		   jr c,$-2 
0ed4 12			  ld (de),a 
0ed5 13			  inc de 
0ed6			 
0ed6 7d			  ld a,l 
0ed7 26 3a		  ld h,'9'+1 
0ed9 25			  dec h  
0eda c6 0a		  add a,10  
0edc 30 fb		   jr nc,$-3 
0ede c6 30		  add a,'0' 
0ee0 eb			  ex de,hl 
0ee1 72			  ld (hl),d 
0ee2 23			  inc hl 
0ee3 77			  ld (hl),a 
0ee4 23			  inc hl 
0ee5 36 00		  ld (hl),0 
0ee7			 
0ee7			;Now strip the leading zeros 
0ee7 0e fa		  ld c,-6 
0ee9 09			  add hl,bc 
0eea 3e 30		  ld a,'0' 
0eec 23			  inc hl  
0eed be			  cp (hl)  
0eee 28 fc		  jr z,$-2 
0ef0			 
0ef0			;Make sure that the string is non-empty! 
