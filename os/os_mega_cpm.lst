13ba				ld a, $fe      ; bit 0 clear 
13ba				ld (spi_device), a 
13ba			 
13ba				call storage_get_block_0 
13ba			 
13ba				pop bc 
13ba				ld a,c 
13ba				ld (store_page+STORE_0_BANKRUN), a 
13ba				ld a,b 
13ba				ld (store_page+STORE_0_BANKRUNN), a 
13ba					ld hl, 0 
13ba					ld de, store_page 
13ba				call storage_write_block 
13ba			 
