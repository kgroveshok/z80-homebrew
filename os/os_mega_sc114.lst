# End of macro CWHEAD
a693			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a693			; | | At start the current various registers will be displayed with contents. 
a693			; | | Top right corner will show the most recent debug marker seen. 
a693			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a693			; | | and the return stack pointer (RSP). 
a693			; | | Pressing: 
a693			; | |  
a693			; | |    1 - Initial screen 
a693			; | |  
a693			; | |    2 - Display a data dump of HL 
a693			; | |  
a693			; | |    3 - Display a data dump of DE 
a693			; | |  
a693			; | |    4 - Display a data dump of BC 
a693			; | |  
a693			; | |    5 - Display a data dump of HL 
a693			; | |  
a693			; | |    6 - Display a data dump of DSP 
a693			; | |  
a693			; | |    7 - Display a data dump of RSP 
a693			; | |  
a693			; | |    8 - Display a data dump of what is at DSP 
a693			; | |  
a693			; | |    9 - Display a data dump of what is at RSP 
a693			; | |  
a693			; | |    0 - Exit monitor and continue running. This will also enable break points 
a693			; | |  
a693			; | |    * - Disable break points 
a693			; | |  
a693			; | |    # - Enter traditional monitor mode 
a693			; | |  
a693			; | | 
a693			; | | Monitor Mode 
a693			; | | ------------ 
a693			; | | A prompt of '>' will be shown for various commands: 
a693			; | |  
a693			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a693			; | |  
a693			; | |    C - Continue display a data dump from the last set address 
a693			; | |  
a693			; | |    M xxxx - Set start of memory edit at address xx 
a693			; | |  
a693			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a693			; | |  
a693			; | |    G xxxx - Exec code at specific address 
a693			; | |  
a693			; | |    Q - Return to previous 
a693				if DEBUG_FORTH_WORDS_KEY 
a693					DMARK "MON" 
a693 f5				push af  
a694 3a a8 a6			ld a, (.dmark)  
a697 32 5e ee			ld (debug_mark),a  
a69a 3a a9 a6			ld a, (.dmark+1)  
a69d 32 5f ee			ld (debug_mark+1),a  
a6a0 3a aa a6			ld a, (.dmark+2)  
a6a3 32 60 ee			ld (debug_mark+2),a  
a6a6 18 03			jr .pastdmark  
a6a8 ..			.dmark: db "MON"  
a6ab f1			.pastdmark: pop af  
a6ac			endm  
# End of macro DMARK
a6ac					CALLMONITOR 
a6ac				if BASE_CPM=1  
a6ac					call debug_vector  
a6ac				endif  
a6ac				if BASE_KEV=1  
a6ac					rst 8  
a6ac				endif  
a6ac				endm  
# End of macro CALLMONITOR
a6ac				endif 
a6ac			;		ld a, 0 
a6ac			;		ld (os_view_disable), a 
a6ac cd e3 92			call bp_on 
