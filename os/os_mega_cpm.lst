11aa			; only care about direct match or not 
11aa			; hl and de strings 
11aa			; zero set if the same 
11aa			 
11aa			strcmp: 
11aa 1a				ld a, (de) 
11ab be				cp (hl) 
11ac 28 02			jr z, .ssame 
11ae b7				or a 
11af c9				ret 
11b0			 
11b0			.ssame:  
11b0			;	cp 0 
11b0 b7				or a 
11b1 c8				ret z 
11b2			 
11b2 23				inc hl 
11b3 13				inc de 
11b4 18 f4			jr strcmp 
