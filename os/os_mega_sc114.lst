9da5			; the core word dictionary v4 
9da5			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
9da5			 
9da5			; this is a linked list for each of the system words used 
9da5			; user defined words will follow the same format but will be in ram 
9da5			 
9da5			 
9da5			; 
9da5			; 
9da5			; define linked list: 
9da5			; 
9da5			; 1. compiled byte op code 
9da5			; 2. len of text word 
9da5			; 3. text word 
9da5			; 4. ptr to next dictionary word 
9da5			; 5. asm, calls etc for the word 
9da5			; 
9da5			;  if 1 == 0 then last word in dict  
9da5			;   
9da5			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
9da5			;  
9da5			;  
9da5			; create basic standard set of words 
9da5			; 
9da5			;  
9da5			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
9da5			; 2DUP 2DROP 2SWAP  
9da5			; @ C@ - get byte  
9da5			; ! C! - store byte 
9da5			; 0< true if less than zero 
9da5			; 0= true if zero 
9da5			; < >  
9da5			; = true if same 
9da5			; variables 
9da5			 
9da5			 
