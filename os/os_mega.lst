1137 eb			      ex    DE, HL 
1138 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
113b 39			      add   HL, SP 
113c f9			      ld    SP, HL 
113d dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1141 dd 39		      add   IX, SP 
1143			 
1143			      ; Setup initial state 
1143 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
1146 19			      add   HL, DE 
1147			 
1147 44			      ld    B, H                    ; Move want to BC 
1148 4d			      ld    C, L 
1149			 
1149 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
114c dd 75 04		      ld    (IX+4), L 
114f dd 74 05		      ld    (IX+5), H 
1152			 
1152 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
1153 23			      inc   HL 
1154 56			      ld    D, (HL) 
1155 dd 73 02		      ld    (IX+2), E 
1158 dd 72 03		      ld    (IX+3), D 
115b eb			      ex    DE, HL                  ; this_free ptr into HL 
115c			 
115c					if DEBUG_FORTH_MALLOC 
115c						DMARK "maB" 
115c						CALLMONITOR 
115c					endif 
115c			      ; Loop through free block list to find some space 
115c			malloc_find_space: 
115c 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
115d 23			      inc   HL 
115e 56			      ld    D, (HL) 
115f			 
115f 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1160 b3			      or    E 
1161 ca ed 11		      jp    Z, malloc_no_space 
1164			 
1164 dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1167 dd 72 01		      ld    (IX+1), D 
116a			 
116a			      ; Does this block have enough space to make the allocation? 
116a 23			      inc   HL                      ; Load free block size into DE 
116b 5e			      ld    E, (HL) 
116c 23			      inc   HL 
116d 56			      ld    D, (HL) 
116e			 
116e eb			      ex    DE, HL                  ; Check size of block against want 
116f b7			      or    A                       ; Ensure carry flag clear 
1170 ed 42		      sbc   HL, BC 
1172 e5			      push  HL                      ; Store the result for later (new block size) 
1173			 
1173 ca c2 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1176 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1178			 
1178			      ; this_free block is not big enough, setup ptrs to test next free block 
1178 e1			      pop   HL                      ; Discard previous result 
1179			 
1179 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
117c dd 66 03		      ld    H, (IX+3) 
117f dd 75 04		      ld    (IX+4), L 
1182 dd 74 05		      ld    (IX+5), H 
1185			 
1185 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1188 dd 66 01		      ld    H, (IX+1) 
118b dd 75 02		      ld    (IX+2), L 
118e dd 74 03		      ld    (IX+3), H 
1191			 
1191					if DEBUG_FORTH_MALLOC 
1191						DMARK "MA>" 
1191						CALLMONITOR 
1191					endif 
1191 18 c9		      jr    malloc_find_space 
1193			 
