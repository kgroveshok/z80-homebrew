1109			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1109			 
1109			 
1109			;Converts an ASCII string to an unsigned 16-bit integer 
1109			;Quits when it reaches a non-decimal digit 
1109			 
1109			string_to_uint16: 
1109			atoui_16: 
1109			;Input: 
1109			;     DE points to the string 
1109			;Outputs: 
1109			;     HL is the result 
1109			;     A is the 8-bit value of the number 
1109			;     DE points to the byte after the number 
1109			;Destroys: 
1109			;     BC 
1109			;       if the string is non-empty, BC is HL/10 
1109			;Size:  24 bytes 
1109			;Speed: 42+d(104+{0,9}) 
1109			;       d is the number of digits in the number 
1109			;       max is 640 cycles for a 5 digit number 
1109			;Assuming no leading zeros: 
1109			;1 digit:  146cc 
1109			;2 digit:  250cc 
1109			;3 digit:  354cc or 363cc (avg: 354.126cc) 
1109			;4 digit:  458cc or 467cc (avg: 458.27cc) 
1109			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
1109			;avg: 544.81158447265625cc (544+13297/16384) 
1109			;=============================================================== 
1109 21 00 00		  ld hl,0 
110c			.u16a: 
110c 1a			  ld a,(de) 
110d d6 30		  sub 30h 
110f fe 0a		  cp 10 
1111 d0			  ret nc 
1112 13			  inc de 
1113 44			  ld b,h 
1114 4d			  ld c,l 
1115 29			  add hl,hl 
1116 29			  add hl,hl 
1117 09			  add hl,bc 
1118 29			  add hl,hl 
1119 85			  add a,l 
111a 6f			  ld l,a 
111b 30 ef		  jr nc,.u16a 
111d 24			  inc h 
111e c3 0c 11		  jp .u16a 
