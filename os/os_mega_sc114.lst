8997			;;;; int maths 
8997			 
8997			; https://map.grauw.nl/articles/mult_div_shifts.php 
8997			; Divide 16-bit values (with 16-bit result) 
8997			; In: Divide BC by divider DE 
8997			; Out: BC = result, HL = rest 
8997			; 
8997			Div16: 
8997 21 00 00		    ld hl,0 
899a 78			    ld a,b 
899b 06 08		    ld b,8 
899d			Div16_Loop1: 
899d 17			    rla 
899e ed 6a		    adc hl,hl 
89a0 ed 52		    sbc hl,de 
89a2 30 01		    jr nc,Div16_NoAdd1 
89a4 19			    add hl,de 
89a5			Div16_NoAdd1: 
89a5 10 f6		    djnz Div16_Loop1 
89a7 17			    rla 
89a8 2f			    cpl 
89a9 47			    ld b,a 
89aa 79			    ld a,c 
89ab 48			    ld c,b 
89ac 06 08		    ld b,8 
89ae			Div16_Loop2: 
89ae 17			    rla 
89af ed 6a		    adc hl,hl 
89b1 ed 52		    sbc hl,de 
89b3 30 01		    jr nc,Div16_NoAdd2 
89b5 19			    add hl,de 
89b6			Div16_NoAdd2: 
89b6 10 f6		    djnz Div16_Loop2 
89b8 17			    rla 
89b9 2f			    cpl 
89ba 41			    ld b,c 
89bb 4f			    ld c,a 
89bc c9			ret 
89bd			 
89bd			 
89bd			;http://z80-heaven.wikidot.com/math 
89bd			; 
89bd			;Inputs: 
89bd			;     DE and A are factors 
89bd			;Outputs: 
89bd			;     A is not changed 
89bd			;     B is 0 
89bd			;     C is not changed 
89bd			;     DE is not changed 
89bd			;     HL is the product 
89bd			;Time: 
89bd			;     342+6x 
89bd			; 
89bd			Mult16: 
89bd			 
89bd 06 08		     ld b,8          ;7           7 
89bf 21 00 00		     ld hl,0         ;10         10 
89c2 29			       add hl,hl     ;11*8       88 
89c3 07			       rlca          ;4*8        32 
89c4 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
89c6 19			         add hl,de   ;--         -- 
89c7 10 f9		       djnz $-5      ;13*7+8     99 
89c9 c9			ret 
89ca			 
89ca			; 
89ca			; Square root of 16-bit value 
89ca			; In:  HL = value 
89ca			; Out:  D = result (rounded down) 
89ca			; 
89ca			;Sqr16: 
89ca			;    ld de,#0040 
89ca			;    ld a,l 
89ca			;    ld l,h 
89ca			;    ld h,d 
89ca			;    or a 
89ca			;    ld b,8 
89ca			;Sqr16_Loop: 
89ca			;    sbc hl,de 
89ca			;    jr nc,Sqr16_Skip 
89ca			;    add hl,de 
89ca			;Sqr16_Skip: 
89ca			;    ccf 
89ca			;    rl d 
89ca			;    add a,a 
89ca			;    adc hl,hl 
89ca			;    add a,a 
89ca			;    adc hl,hl 
89ca			;    djnz Sqr16_Loop 
89ca			;    ret 
89ca			; 
89ca			; 
89ca			; Divide 8-bit values 
89ca			; In: Divide E by divider C 
89ca			; Out: A = result, B = rest 
89ca			; 
89ca			Div8: 
89ca af			    xor a 
89cb 06 08		    ld b,8 
89cd			Div8_Loop: 
89cd cb 13		    rl e 
89cf 17			    rla 
89d0 91			    sub c 
89d1 30 01		    jr nc,Div8_NoAdd 
89d3 81			    add a,c 
89d4			Div8_NoAdd: 
89d4 10 f7		    djnz Div8_Loop 
89d6 47			    ld b,a 
89d7 7b			    ld a,e 
89d8 17			    rla 
89d9 2f			    cpl 
89da c9			    ret 
89db			 
89db			; 
89db			; Multiply 8-bit value with a 16-bit value (unrolled) 
89db			; In: Multiply A with DE 
89db			; Out: HL = result 
89db			; 
89db			Mult12U: 
89db 2e 00		    ld l,0 
89dd 87			    add a,a 
89de 30 01		    jr nc,Mult12U_NoAdd0 
89e0 19			    add hl,de 
89e1			Mult12U_NoAdd0: 
89e1 29			    add hl,hl 
89e2 87			    add a,a 
89e3 30 01		    jr nc,Mult12U_NoAdd1 
89e5 19			    add hl,de 
89e6			Mult12U_NoAdd1: 
89e6 29			    add hl,hl 
89e7 87			    add a,a 
89e8 30 01		    jr nc,Mult12U_NoAdd2 
89ea 19			    add hl,de 
89eb			Mult12U_NoAdd2: 
89eb 29			    add hl,hl 
89ec 87			    add a,a 
89ed 30 01		    jr nc,Mult12U_NoAdd3 
89ef 19			    add hl,de 
89f0			Mult12U_NoAdd3: 
89f0 29			    add hl,hl 
89f1 87			    add a,a 
89f2 30 01		    jr nc,Mult12U_NoAdd4 
89f4 19			    add hl,de 
89f5			Mult12U_NoAdd4: 
89f5 29			    add hl,hl 
89f6 87			    add a,a 
89f7 30 01		    jr nc,Mult12U_NoAdd5 
89f9 19			    add hl,de 
89fa			Mult12U_NoAdd5: 
89fa 29			    add hl,hl 
89fb 87			    add a,a 
89fc 30 01		    jr nc,Mult12U_NoAdd6 
89fe 19			    add hl,de 
89ff			Mult12U_NoAdd6: 
89ff 29			    add hl,hl 
8a00 87			    add a,a 
8a01 d0			    ret nc 
8a02 19			    add hl,de 
8a03 c9			    ret 
8a04			 
8a04			; 
8a04			; Multiply 8-bit value with a 16-bit value (right rotating) 
8a04			; In: Multiply A with DE 
8a04			;      Put lowest value in A for most efficient calculation 
8a04			; Out: HL = result 
8a04			; 
8a04			Mult12R: 
8a04 21 00 00		    ld hl,0 
8a07			Mult12R_Loop: 
8a07 cb 3f		    srl a 
8a09 30 01		    jr nc,Mult12R_NoAdd 
8a0b 19			    add hl,de 
8a0c			Mult12R_NoAdd: 
8a0c cb 23		    sla e 
8a0e cb 12		    rl d 
8a10 b7			    or a 
8a11 c2 07 8a		    jp nz,Mult12R_Loop 
8a14 c9			    ret 
8a15			 
8a15			; 
8a15			; Multiply 16-bit values (with 32-bit result) 
8a15			; In: Multiply BC with DE 
8a15			; Out: BCHL = result 
8a15			; 
8a15			Mult32: 
8a15 79			    ld a,c 
8a16 48			    ld c,b 
8a17 21 00 00		    ld hl,0 
8a1a 06 10		    ld b,16 
8a1c			Mult32_Loop: 
8a1c 29			    add hl,hl 
8a1d 17			    rla 
8a1e cb 11		    rl c 
8a20 30 07		    jr nc,Mult32_NoAdd 
8a22 19			    add hl,de 
8a23 ce 00		    adc a,0 
8a25 d2 29 8a		    jp nc,Mult32_NoAdd 
8a28 0c			    inc c 
8a29			Mult32_NoAdd: 
8a29 10 f1		    djnz Mult32_Loop 
8a2b 41			    ld b,c 
8a2c 4f			    ld c,a 
8a2d c9			    ret 
8a2e			 
8a2e			 
8a2e			 
8a2e			; 
8a2e			; Multiply 8-bit values 
8a2e			; In:  Multiply H with E 
8a2e			; Out: HL = result 
8a2e			; 
8a2e			Mult8: 
8a2e 16 00		    ld d,0 
8a30 6a			    ld l,d 
8a31 06 08		    ld b,8 
8a33			Mult8_Loop: 
8a33 29			    add hl,hl 
8a34 30 01		    jr nc,Mult8_NoAdd 
8a36 19			    add hl,de 
8a37			Mult8_NoAdd: 
8a37 10 fa		    djnz Mult8_Loop 
8a39 c9			    ret 
