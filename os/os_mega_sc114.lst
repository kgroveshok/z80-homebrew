8f9f			; Tape support 
8f9f			 
8f9f			; setup default tape params 
8f9f			tape_init:     
8f9f 3e 00			ld a, Device_A 
8fa1 32 53 ea			ld (tape_port), a 
8fa4 21 96 00			ld hl, 150 
8fa7 22 47 ea			ld (tape_tm_gap), hl 
8faa 21 46 00			ld hl, 70 
8fad 22 45 ea			ld (tape_tm_high), hl 
8fb0 21 14 00			ld hl, 20 
8fb3 22 43 ea			ld (tape_tm_low), hl 
8fb6 c9				ret 
8fb7			 
8fb7			; support routinues for tape 
8fb7			 
8fb7			 
8fb7			; Tape Output 
8fb7			 
8fb7			; osciallate the pin for the required duration 
8fb7			 
8fb7			tape_osc:  
8fb7				; hl has the number of iterations 
8fb7				; c = port number 
8fb7				; d = bus data 
8fb7				 
8fb7 ed 51			out (c), d 
8fb9 3e 01			ld a, 1 
8fbb cd 34 87			call aDelayInMS 
8fbe				 
8fbe 2b				dec hl 
8fbf 7d				ld a, l 
8fc0 84				add h 
8fc1 fe 00			cp 0 
8fc3 20 f2			jr nz, tape_osc 
8fc5				 
8fc5 c9				ret 
8fc6			 
8fc6			; output a gap period 
8fc6			tape_gap:  
8fc6 2a 47 ea			ld hl, (tape_tm_gap) 
8fc9 7d				ld a, l 
8fca cd 34 87			call aDelayInMS 
8fcd c9				ret 
8fce			 
8fce			; output a high period 
8fce			 
8fce			tape_high: 
8fce 3a 53 ea			ld a, (tape_port) 
8fd1 4f				ld c, a 
8fd2 16 ff			ld d, 255 
8fd4 2a 45 ea			ld hl, (tape_tm_high) 
8fd7 cd b7 8f			call tape_osc 
8fda c9				 ret 
8fdb			 
8fdb			; output a low period 
8fdb			 
8fdb			tape_low:  
8fdb			 
8fdb 3a 53 ea			ld a, (tape_port) 
8fde 4f				ld c, a 
8fdf 16 ff			ld d, 255 
8fe1 2a 43 ea			ld hl, (tape_tm_low) 
8fe4 cd b7 8f			call tape_osc 
8fe7 c9				 ret 
8fe8			 
8fe8			; end of save marker 
8fe8			 
8fe8			tape_end: 
8fe8 3e ff			ld a, 255 
8fea cd 01 90			call tape_byte_out 
8fed cd c6 8f			call tape_gap 
8ff0 3e ff			ld a, 255 
8ff2 cd 01 90			call tape_byte_out 
8ff5 cd c6 8f			call tape_gap 
8ff8 3e ff			ld a, 255 
8ffa cd 01 90			call tape_byte_out 
8ffd cd c6 8f			call tape_gap 
9000 c9				 ret 
9001			 
9001			; output an encoded byte 
9001			 
9001			tape_byte_out: 
9001				; a = byte to output 
9001 06 08			ld b, 8 
9003 4f				ld c, a 
9004			.tbo:    
9004 c5				push bc 
9005 cb 79			bit 7, c 
9007 28 05			jr z, .tbol 
9009 cd ce 8f			call tape_high 
900c 18 03			jr .tbn 
900e			.tbol: 
900e cd db 8f			call tape_low 
9011			.tbn: 
9011 cd c6 8f			call tape_gap 
9014 c1				pop bc 
9015 cb 21			sla c 
9017 10 eb			djnz .tbo 
9019			 
9019			 
9019 c9				 ret 
901a			 
