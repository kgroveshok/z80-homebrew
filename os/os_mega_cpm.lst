0acc			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
0acc			; random number generators 
0acc			 
0acc			 
0acc			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0acc			 
0acc			 
0acc			;-----> Generate a random number 
0acc			; output a=answer 0<=a<=255 
0acc			; all registers are preserved except: af 
0acc			random: 
0acc e5			        push    hl 
0acd d5			        push    de 
0ace 2a a0 eb		        ld      hl,(randData) 
0ad1 ed 5f		        ld      a,r 
0ad3 57			        ld      d,a 
0ad4 5e			        ld      e,(hl) 
0ad5 19			        add     hl,de 
0ad6 85			        add     a,l 
0ad7 ac			        xor     h 
0ad8 22 a0 eb		        ld      (randData),hl 
0adb d1			        pop     de 
0adc e1			        pop     hl 
0add c9			        ret 
0ade			 
0ade			 
0ade			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0ade			 
0ade			 
0ade			 
0ade			;------LFSR------ 
0ade			;James Montelongo 
0ade			;optimized by Spencer Putt 
0ade			;out: 
0ade			; a = 8 bit random number 
0ade			RandLFSR: 
0ade 21 a6 eb		        ld hl,LFSRSeed+4 
0ae1 5e			        ld e,(hl) 
0ae2 23			        inc hl 
0ae3 56			        ld d,(hl) 
0ae4 23			        inc hl 
0ae5 4e			        ld c,(hl) 
0ae6 23			        inc hl 
0ae7 7e			        ld a,(hl) 
0ae8 47			        ld b,a 
0ae9 cb 13		        rl e  
0aeb cb 12			rl d 
0aed cb 11		        rl c  
0aef 17				rla 
0af0 cb 13		        rl e  
0af2 cb 12			rl d 
0af4 cb 11		        rl c  
0af6 17				rla 
0af7 cb 13		        rl e  
0af9 cb 12			rl d 
0afb cb 11		        rl c  
0afd 17				rla 
0afe 67			        ld h,a 
0aff cb 13		        rl e  
0b01 cb 12			rl d 
0b03 cb 11		        rl c  
0b05 17				rla 
0b06 a8			        xor b 
0b07 cb 13		        rl e  
0b09 cb 12			rl d 
0b0b ac			        xor h 
0b0c a9			        xor c 
0b0d aa			        xor d 
0b0e 21 a8 eb		        ld hl,LFSRSeed+6 
0b11 11 a9 eb		        ld de,LFSRSeed+7 
0b14 01 07 00		        ld bc,7 
0b17 ed b8		        lddr 
0b19 12			        ld (de),a 
0b1a c9			        ret 
0b1b			 
0b1b			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0b1b			 
0b1b			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0b1b			 
0b1b			 
0b1b			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0b1b			 
0b1b			prng16: 
0b1b			;Inputs: 
0b1b			;   (seed1) contains a 16-bit seed value 
0b1b			;   (seed2) contains a NON-ZERO 16-bit seed value 
0b1b			;Outputs: 
0b1b			;   HL is the result 
0b1b			;   BC is the result of the LCG, so not that great of quality 
0b1b			;   DE is preserved 
0b1b			;Destroys: 
0b1b			;   AF 
0b1b			;cycle: 4,294,901,760 (almost 4.3 billion) 
0b1b			;160cc 
0b1b			;26 bytes 
0b1b 2a 9a eb		    ld hl,(seed1) 
0b1e 44			    ld b,h 
0b1f 4d			    ld c,l 
0b20 29			    add hl,hl 
0b21 29			    add hl,hl 
0b22 2c			    inc l 
0b23 09			    add hl,bc 
