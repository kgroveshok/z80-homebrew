0bde 85			    add   a, l    ; A = A+L 
0bdf 6f			    ld    l, a    ; L = A+L 
0be0 8c			    adc   a, h    ; A = A+L+H+carry 
0be1 95			    sub   l       ; A = H+carry 
0be2 67			    ld    h, a    ; H = H+carry 
0be3 c9			ret 
