69e3			; **********************************************************************  
69e3			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
69e3			; **********************************************************************  
69e3			;  
69e3			; **  Written as a Small Computer Monitor App   
69e3			; **  Version 0.1 SCC 2018-05-16  
69e3			; **  www.scc.me.uk  
69e3			;  
69e3			; **********************************************************************  
69e3			;  
69e3			; This module provides support for alphanumeric LCD modules using with  
69e3			; *  HD44780 (or compatible) controller  
69e3			; *  5 x 7 pixel fonts  
69e3			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
69e3			; *  Interface via six digital outputs to the display (see below)  
69e3			;  
69e3			; LCD module pinout:  
69e3			;   1  Vss   0v supply  
69e3			;   2  Vdd   5v supply  
69e3			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
69e3			;   4  RS    High = data, Low = instruction  
69e3			;   5  R/W   High = Read, Low = Write  
69e3			;   6  E     Enable signal (active high)  
69e3			;   7  DB0   Data bit 0  
69e3			;   8  DB1   Data bit 1  
69e3			;   9  DB2   Data bit 2  
69e3			;  10  DB3   Data bit 3  
69e3			;  11  DB4   Data bit 4  
69e3			;  12  DB5   Data bit 5  
69e3			;  13  DB6   Data bit 6  
69e3			;  14  DB7   Data bit 7  
69e3			;  15  A     Backlight anode (+)  
69e3			;  16  K     Backlight cathode (-)  
69e3			;  
69e3			; This interfacing method uses 4-bit data mode and uses time delays  
69e3			; rather than polling the display's ready status. As a result the   
69e3			; interface only requires 6 simple output lines:  
69e3			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
69e3			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
69e3			;   LCD DB4 = Microcomputer output port bit 4  
69e3			;   LCD DB5 = Microcomputer output port bit 5  
69e3			;   LCD DB6 = Microcomputer output port bit 6  
69e3			;   LCD DB7 = Microcomputer output port bit 7  
69e3			; Display's R/W is connected to 0v so it is always in write mode  
69e3			; All 6 connections must be on the same port address <kLCDPrt>  
69e3			; This method also allows a decent length of cable from micro to LCD  
69e3			;  
69e3			; **********************************************************************  
69e3			;  
69e3			; To include the code for any given function provided by this module,   
69e3			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
69e3			; the parent source file.  
69e3			; For example:  #REQUIRES   uHexPrefix  
69e3			;  
69e3			; Also #INCLUDE this file at some point after the #REQUIRES statements  
69e3			; in the parent source file.  
69e3			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
69e3			;  
69e3			; These are the function names provided by this module:  
69e3			; fLCD_Init                     ;Initialise LCD  
69e3			; fLCD_Inst                     ;Send instruction to LCD  
69e3			; fLCD_Data                     ;Send data byte to LCD  
69e3			; fLCD_Pos                      ;Position cursor  
69e3			; fLCD_Str                      ;Display string  
69e3			; fLCD_Def                      ;Define custom character  
69e3			;  
69e3			; **********************************************************************  
69e3			;  
69e3			; Requires SCMonAPI.asm to also be included in the project  
69e3			;  
69e3			  
69e3			  
69e3			; **********************************************************************  
69e3			; **  Constants  
69e3			; **********************************************************************  
69e3			  
69e3			; Constants that must be defined externally  
69e3			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
69e3			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
69e3			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
69e3			;kLCDWidth: EQU 20             ;Width in characters  
69e3			  
69e3			; general line offsets in any frame buffer  
69e3			  
69e3			  
69e3			display_row_1: equ 0  
69e3			display_row_2: equ display_row_1+display_cols  
69e3			display_row_3: equ display_row_2 + display_cols  
69e3			display_row_4: equ display_row_3 + display_cols  
69e3			;display_row_4_eol:   
69e3			  
69e3			  
69e3			; Cursor position values for the start of each line  
69e3			  
69e3			; E  
69e3			kLCD_Line1: EQU 0x00   
69e3			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
69e3			; E1  
69e3			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
69e3			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
69e3			  
69e3			; Instructions to send as A register to fLCD_Inst  
69e3			kLCD_Clear: EQU 00000001b     ;LCD clear  
69e3			kLCD_Off:   EQU 00001000b     ;LCD off  
69e3			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
69e3			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
69e3			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
69e3			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
69e3			  
69e3			; Constants used by this code module  
69e3			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
69e3			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
69e3			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
69e3			  
69e3			  
69e3			  
69e3			; **********************************************************************  
69e3			; **  LCD support functions  
69e3			; **********************************************************************  
69e3			  
69e3			; Initialise alphanumeric LCD module  
69e3			; LCD control register codes:  
69e3			;   DL   0 = 4-bit mode        1 = 8-bit mode  
69e3			;   N    0 = 1-line mode       1 = 2-line mode  
69e3			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
69e3			;   D    0 = Display off       1 = Display on  
69e3			;   C    0 = Cursor off        1 = Cursor on  
69e3			;   B    0 = Blinking off      1 = Blinking on  
69e3			;   ID   0 = Decrement mode    1 = Increment mode  
69e3			;   SH   0 = Entire shift off  1 = Entire shift on  
69e3 3e 28		fLCD_Init:  LD   A, 40  
69e5 cd 0a 6b		            CALL LCDDelay       ;Delay 40ms after power up  
69e8			; For reliable reset set 8-bit mode - 3 times  
69e8 cd da 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69eb cd da 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69ee cd da 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69f1			; Set 4-bit mode  
69f1 cd d6 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
69f4 cd 08 6b		            CALL LCDDelay1      ;Delay 37 us or more  
69f7			; Function set  
69f7 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
69f9 cd 0c 6a		            CALL fLCD_Inst      ;2 line, display on  
69fc			; Display On/Off control  
69fc 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
69fe cd 0c 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6a01			; Display Clear  
6a01 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6a03 cd 0c 6a		            CALL fLCD_Inst      ;Clear display  
6a06			; Entry mode  
6a06 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6a08 cd 0c 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
6a0b			; Display module now initialised  
6a0b c9			            RET  
6a0c			; ok to here  
6a0c			  
6a0c			; Write instruction to LCD  
6a0c			;   On entry: A = Instruction byte to be written  
6a0c			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a0c f5			fLCD_Inst:  PUSH AF  
6a0d f5			            PUSH AF  
6a0e cd 20 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a11 f1			            POP  AF  
6a12 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a13 17			            RLA  
6a14 17			            RLA  
6a15 17			            RLA  
6a16 cd 20 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6a19 3e 02		            LD   A, 2  
6a1b cd 0a 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6a1e f1			            POP  AF  
6a1f c9			            RET  
6a20			Wr4bits:   
6a20 f5					push af  
6a21 3a fb fa				ld a, (display_lcde1e2)  
6a24 fe 00				cp 0     ; e  
6a26 20 10				jr nz, .wea2	  
6a28 f1					pop af  
6a29 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a2b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a2d cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6a2f cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6a31 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a33 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6a35 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a37 c9			            RET  
6a38 f1			.wea2:		pop af  
6a39 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a3b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a3d cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6a3f cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6a41 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a43 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6a45 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a47 c9			            RET  
6a48			  
6a48			  
6a48			; Write data to LCD  
6a48			;   On entry: A = Data byte to be written  
6a48			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a48 f5			fLCD_Data:  PUSH AF  
6a49 f5			            PUSH AF  
6a4a cd 5c 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6a4d f1			            POP  AF  
6a4e 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a4f 17			            RLA  
6a50 17			            RLA  
6a51 17			            RLA  
6a52 cd 5c 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6a55 3e 96		            LD   A, 150  
6a57 3d			Wait:      DEC  A              ;Wait a while to allow data   
6a58 20 fd		            JR   NZ, Wait      ;  write to complete  
6a5a f1			            POP  AF  
6a5b c9			            RET  
6a5c			Wr4bitsa:     
6a5c f5					push af  
6a5d 3a fb fa				ld a, (display_lcde1e2)  
6a60 fe 00				cp 0     ; e1  
6a62 20 16				jr nz, .we2	  
6a64 f1					pop af  
6a65 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a67 cb d7		            SET  kLCDBitRS, A  
6a69 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a6b cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6a6d cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6a6f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a71 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6a73 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a75 cb 97		            RES  kLCDBitRS, A  
6a77 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a79 c9			            RET  
6a7a f1			.we2:		pop af  
6a7b e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a7d cb d7		            SET  kLCDBitRS, A  
6a7f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a81 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6a83 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6a85 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a87 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6a89 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a8b cb 97		            RES  kLCDBitRS, A  
6a8d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a8f c9			            RET  
6a90			  
6a90			  
6a90			; Position cursor to specified location  
6a90			;   On entry: A = Cursor position  
6a90			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a90 f5			fLCD_Pos:   PUSH AF  
6a91					; at this point set the E1 or E2 flag depending on position  
6a91			  
6a91 c5					push bc  
6a92			;		push af  
6a92 06 00				ld b, 0  
6a94 4f					ld c, a  
6a95 3e 4f				ld a, kLCD_Line3-1  
6a97 b7			 		or a      ;clear carry flag  
6a98 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6a99 38 04				jr c, .pe1  
6a9b			  
6a9b					; E selection  
6a9b cb 80				res 0, b         ; bit 0 unset e  
6a9d			;		pop af    ; before line 3 so recover orig pos  
6a9d			;		ld c, a    ; save for poking back  
6a9d 18 06				jr .peset	          
6a9f			.pe1:          	; E2 selection  
6a9f cb c0				set 0, b         ; bit 0 set e1  
6aa1 79					ld a, c  
6aa2 de 4f				sbc a, kLCD_Line3-1  
6aa4 4f					ld c, a	         ; save caculated offset  
6aa5			;		pop af     ; bin this original value now we have calculated form  
6aa5			  
6aa5			.peset:		; set bit  
6aa5 78					ld a, b  
6aa6 32 fb fa				ld (display_lcde1e2), a 	  
6aa9 79					ld a, c  
6aaa c1					pop bc  
6aab			  
6aab f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6aad cd 0c 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ab0 f1			            POP  AF  
6ab1 c9			            RET  
6ab2			  
6ab2			  
6ab2			; Output text string to LCD  
6ab2			;   On entry: DE = Pointer to null terminated text string  
6ab2			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6ab2 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6ab3 b7			            OR   A              ;Null terminator?  
6ab4 c8			            RET  Z              ;Yes, so finished  
6ab5 cd 48 6a		            CALL fLCD_Data      ;Write character to display  
6ab8 13			            INC  DE             ;Point to next character  
6ab9 18 f7		            JR   fLCD_Str       ;Repeat  
6abb c9					ret  
6abc			  
6abc			; Define custom character  
6abc			;   On entry: A = Character number (0 to 7)  
6abc			;             DE = Pointer to character bitmap data  
6abc			;   On exit:  A = Next character number  
6abc			;             DE = Next location following bitmap  
6abc			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6abc			; Character is   
6abc c5			fLCD_Def:   PUSH BC  
6abd f5			            PUSH AF  
6abe 07			            RLCA                ;Calculate location  
6abf 07			            RLCA                ;  for bitmap data  
6ac0 07			            RLCA                ;  = 8 x CharacterNumber  
6ac1 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6ac3 cd 0c 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ac6 06 00		            LD   B, 0  
6ac8 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6ac9 cd 48 6a		            CALL fLCD_Data      ;Write byte to display  
6acc 13			            INC  DE             ;Point to next byte  
6acd 04			            INC  B              ;Count bytes  
6ace cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6ad0 28 f6		            JR   Z, Loop       ;No, so repeat  
6ad2 f1			            POP  AF  
6ad3 3c			            INC  A              ;Increment character number  
6ad4 c1			            POP  BC  
6ad5 c9			            RET  
6ad6			  
6ad6			  
6ad6			; **********************************************************************  
6ad6			; **  Private functions  
6ad6			; **********************************************************************  
6ad6			  
6ad6			; Write function to LCD  
6ad6			;   On entry: A = Function byte to be written  
6ad6			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ad6 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6ad8 18 02		            JR   WrFunc  
6ada 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6adc f5			WrFunc:     PUSH AF  
6add f5					push af  
6ade 3a fb fa				ld a, (display_lcde1e2)  
6ae1 fe 00				cp 0     ; e1  
6ae3 20 0f				jr nz, .wfea2	  
6ae5 f1					pop af  
6ae6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6ae8 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6aea cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6aec d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6aee cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6af0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6af2 18 0d			jr .wfskip  
6af4 f1			.wfea2:		pop af  
6af5 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6af7 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6af9 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6afb d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6afd cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6aff d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b01 3e 05		.wfskip:            LD  A, 5  
6b03 cd 0a 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b06 f1			            POP  AF  
6b07 c9			            RET  
6b08			  
6b08			  
6b08			; Delay in milliseconds  
6b08			;   On entry: A = Number of milliseconds delay  
6b08			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6b08 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
6b0a d5			LCDDelay:   PUSH DE  
6b0b 5f			            LD   E, A           ;Delay by 'A' ms  
6b0c 16 00		            LD   D, 0  
6b0e cd 56 0a		            CALL aDelayInMS  
6b11 d1			            POP  DE  
6b12 c9			            RET  
