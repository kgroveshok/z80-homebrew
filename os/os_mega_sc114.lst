9caf			user_word_eol:  
9caf				; hl contains the pointer to where to create a linked list item from the end 
9caf				; of the user dict to continue on at the system word dict 
9caf				 
9caf				; poke the stub of the word list linked list to repoint to rom words 
9caf			 
9caf				; stub format 
9caf				; db   word id 
9caf				; dw    link to next word 
9caf			        ; db char length of token 
9caf				; db string + 0 term 
9caf				; db exec code....  
9caf			 
9caf			;	ld a, WORD_SYS_ROOT     ; root word 
9caf 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9cb1 23				inc hl 
9cb2			 
9cb2 11 5b 9e			ld de, sysdict 
9cb5 73				ld (hl), e		; next word link ie system dict 
9cb6 23				inc hl 
9cb7 72				ld (hl), d		; next word link ie system dict 
9cb8 23				inc hl	 
9cb9			 
9cb9			;	ld (hl), sysdict		; next word link ie system dict 
9cb9			;	inc hl 
9cb9			;	inc hl 
9cb9			 
9cb9			;	inc hl 
9cb9			;	inc hl 
9cb9			 
9cb9			;	ld a, 2			; word length is 0 
9cb9 36 02			ld (hl), 2 
9cbb 23				inc hl 
9cbc			 
9cbc			;	ld a, '~'			; word length is 0 
9cbc 36 7e			ld (hl), '~' 
9cbe 23				inc hl 
9cbf			;	ld a, 0			; save empty word 
9cbf 36 00			ld (hl), 0 
