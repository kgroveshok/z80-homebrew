d303			; stack over and underflow checks 
d303			 
d303			; init the words to detect the under/overflow 
d303			 
d303			chk_stk_init: 
d303				; a vague random number to check so we dont get any "lucky" hits 
d303 3e 2d			ld a, 45 
d305 6f				ld l, a 
d306 00				nop 
d307 3e 17			ld a, 23 
d309 67				ld h, a 
d30a			 
d30a 22 7e e2			ld (chk_word), hl     ; the word we need to check against 
d30d			 
d30d			;	ld (chk_stund), hl	; stack points.... 
d30d 22 00 ef			ld (chk_stovr), hl 
d310 22 cd e9			ld (chk_ret_und), hl 
d313 22 8b e9			ld (chk_ret_ovr), hl 
d316 22 09 e9			ld (chk_loop_ovr), hl 
d319 22 07 e8			ld (chk_data_ovr), hl 
d31c c9				ret 
d31d				 
d31d			check_stacks: 
d31d				; check all stack words 
d31d			 
d31d e5				push hl 
d31e d5				push de 
d31f			 
d31f			;	ld de,(chk_word) 
d31f			;	ld hl, (chk_stund)	; stack points.... 
d31f			;	if DEBUG_STK_FAULT 
d31f			;		DMARK "FAa" 
d31f			;		CALLMONITOR 
d31f			;	endif 
d31f			;	call cmp16 
d31f			;	jp z, .chk_faulta 
d31f			; 
d31f			;	ld de, sfaultsu 
d31f			;	jp .chk_fault 
d31f			 
d31f 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
d322 ed 5b 7e e2		ld de,(chk_word) 
d326				if DEBUG_STK_FAULT 
d326					DMARK "FAb" 
d326					CALLMONITOR 
d326				endif 
d326 cd 58 8a			call cmp16 
d329 28 06			jr z, .chk_fault1 
d32b 11 d0 d3			ld de, sfaultso 
d32e c3 80 d3			jp .chk_fault 
d331			.chk_fault1:  
d331 2a cd e9			ld hl, (chk_ret_und) 
d334 ed 5b 7e e2		ld de,(chk_word) 
d338				if DEBUG_STK_FAULT 
d338					DMARK "FAU" 
d338					CALLMONITOR 
d338				endif 
d338 cd 58 8a			call cmp16 
