668a			; handle the auto run of code from files in storage 
668a			 
668a			 
668a			include "forth_startup.asm" 
668a			; Which startup method to use? 
668a			; 
668a			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
668a			; followed by loading of a list of scripts in eeprom 
668a			 
668a			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
668a			; from eeprom 
668a			 
668a			; Select with define in main stubs 
668a			 
668a			if STARTUP_V1 
668a				include "forth_startupv1.asm" 
668a			endif 
668a			if STARTUP_V2 
668a				include "forth_startupv2.asm" 
668a			; Version 2 of the startup  
668a			;  
668a			; Auto load any files in bank 1 that start with a '*' 
668a			; If no se storage then revert to using eprom 
