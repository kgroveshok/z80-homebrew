1199			; Select storage bank 
1199			 
1199			.selbank: 
1199			 
1199			if STARTUP_V2 
1199			;	if STORAGE_SE 
1199			;	else 
1199			 
1199				ld hl, prom_banks 
1199				call menu 
1199				cp 0 
1199				ret z 
1199				 
1199				; set the bank number from the result 
1199			 
1199				 
1199					ld c, SPI_CE_HIGH 
1199					ld b, '0'    ; human readable bank number 
1199			 
1199			 
1199					; active low 
1199			 
1199			;		cp 0 
1199					or a 
1199					jr z, .bset 
1199					cp 1 
1199					jr nz, .b2 
1199					res 0, c 
1199					ld b, '1'    ; human readable bank number 
1199			.b2:		cp 2 
1199					jr nz, .b3 
1199					res 1, c 
1199					ld b, '2'    ; human readable bank number 
1199			.b3:		cp 3 
1199					jr nz, .b4 
1199					res 2, c 
1199					ld b, '3'    ; human readable bank number 
1199			.b4:		cp 4 
1199					jr nz, .b5 
1199					res 3, c 
1199					ld b, '4'    ; human readable bank number 
1199			.b5:		cp 5 
1199					jr nz, .bset 
1199					res 4, c 
1199					ld b, '5'    ; human readable bank number 
1199			 
1199			.bset: 
1199			 
1199					ld a, c 
1199			;		ld (spi_device),a 
1199					ld a, b 
1199			;		ld (spi_device_id),a 
1199					push bc 
1199			 
1199					; select bank 1 and load block 0  
