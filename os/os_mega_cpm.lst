0f95			StrictStrCmp: 
0f95				; Load next chars of each string 
0f95 1a				ld a, (de) 
0f96 47				ld b, a 
0f97 7e				ld a, (hl) 
0f98				; Compare 
0f98 b8				cp b 
0f99				; Return non-zero if chars don't match 
0f99 c0				ret nz 
0f9a				; Check for end of both strings 
0f9a fe 00			cp "\0" 
0f9c				; Return if strings have ended 
0f9c c8				ret z 
0f9d				; Otherwise, advance to next chars 
0f9d 23				inc hl 
0f9e 13				inc de 
0f9f 18 f4			jr StrictStrCmp 
