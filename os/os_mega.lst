4cd0					ld a, (.dmark+1)  
4cd0					ld (debug_mark+1),a  
4cd0					ld a, (.dmark+2)  
4cd0					ld (debug_mark+2),a  
4cd0				endif  
4cd0 18 04			jr .pastdmark  
4cd2 ..			.dmark: db "REA"  
4cd5				if DEMARK_VERSION = 1  
4cd5 00					db 0  
4cd6				endif  
4cd6				if DEMARK_VERSION = 1  
4cd6 e1			.pastdmark: pop hl  
4cd7				endif  
4cd7				if DEMARK_VERSION = 0  
4cd7			.pastdmark: pop af  
4cd7				endif  
4cd7			endm  
# End of macro DMARK
