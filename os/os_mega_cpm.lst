1040			;------------------------------------------------------------------------------ 
1040			;     free                                                                    : 
1040			;                                                                             : 
1040			; Description                                                                 : 
1040			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1040			;     returned by malloc, otherwise the behaviour is undefined.               : 
1040			;                                                                             : 
1040			;     Where possible, directly adjacent free blocks will be merged together   : 
1040			;     into larger blocks to help ensure that the heap does not become         : 
1040			;     excessively fragmented.                                                 : 
1040			;                                                                             : 
1040			;     free does not clear or set any other value into the freed space, and    : 
1040			;     therefore its contents may be visible through subsequent malloc's. The  : 
1040			;     caller should clear the freed space as required.                        : 
1040			;                                                                             : 
1040			;     This implementation of free uses the stack exclusively, and is          : 
1040			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1040			;     advisable to disable interrupts before calling free, and recommended    : 
1040			;     to avoid the use of free inside ISRs in general.                        : 
1040			;                                                                             : 
1040			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1040			;                                                                             : 
1040			; Parameters                                                                  : 
1040			;     HL  Pointer to address of first byte of allocation to be freed          : 
1040			;                                                                             : 
1040			; Returns                                                                     : 
1040			;     Nothing                                                                 : 
1040			;                                                                             : 
1040			; Stack frame                                                                 : 
1040			;       |             |                                                       : 
1040			;       +-------------+                                                       : 
1040			;       |     BC      |                                                       : 
1040			;       +-------------+                                                       : 
1040			;       |     DE      |                                                       : 
1040			;       +-------------+                                                       : 
1040			;       |     IX      |                                                       : 
1040			;       +-------------+                                                       : 
1040			;       |  prev_free  |                                                       : 
1040			;   +2  +-------------+                                                       : 
1040			;       |  next_free  |                                                       : 
1040			;   +0  +-------------+                                                       : 
1040			;       |             |                                                       : 
1040			;                                                                             : 
1040			;------------------------------------------------------------------------------ 
1040			free: 
1040 c5			      push  BC 
1041 d5			      push  DE 
1042 dd e5		      push  IX 
1044			 
1044 7c			      ld    A, H                    ; Exit if ptr is null 
1045 b5			      or    L 
1046 ca 0a 11		      jp    Z, free_early_exit 
1049			 
1049			      ; Set up stack frame 
1049 eb			      ex    DE, HL 
104a 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
104d 39			      add   HL, SP 
104e f9			      ld    SP, HL 
104f dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1053 dd 39		      add   IX, SP 
1055			 
1055			      ; The address in HL points to the start of the useable allocated space, 
1055			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1055			      ; address of the block itself. 
1055 eb			      ex    DE, HL 
1056 11 fc ff		      ld    DE, -4 
1059 19			      add   HL, DE 
105a			 
105a			      ; An allocated block must have a null next block pointer in it 
105a 7e			      ld    A, (HL) 
105b 23			      inc   HL 
105c b6			      or    (HL) 
105d c2 05 11		      jp    NZ, free_done 
1060			 
1060 2b			      dec   HL 
1061			 
1061 44			      ld    B, H                    ; Copy HL to BC 
1062 4d			      ld    C, L 
1063			 
1063			      ; Loop through the free list to find the first block with an address 
1063			      ; higher than the block being freed 
1063 21 f6 57		      ld    HL, free_list 
1066			 
