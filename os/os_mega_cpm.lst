4479			.SPII: 
4479				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
4479			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
4479					if DEBUG_FORTH_WORDS_KEY 
4479						DMARK "SPi" 
4479						CALLMONITOR 
4479					endif 
4479			 
4479					; TODO Get SPI byte 
4479			 
4479					call spi_read_byte 
4479			 
4479					if DEBUG_FORTH_WORDS 
4479						DMARK "Si2" 
4479						CALLMONITOR 
4479					endif 
