6955			include "firmware_lcd_4x40.asm" 
6955			; **********************************************************************  
6955			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
6955			; **********************************************************************  
6955			;  
6955			; **  Written as a Small Computer Monitor App  
6955			; **  www.scc.me.uk  
6955			;  
6955			; History  
6955			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
6955			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
6955			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
6955			;  
6955			; **********************************************************************  
6955			;  
6955			; This program is an example of one of the methods of interfacing an   
6955			; alphanumeric LCD module.   
6955			;  
6955			; In this example the display is connected to either a Z80 PIO or a   
6955			; simple 8-bit output port.   
6955			;  
6955			; This interfacing method uses 4-bit data mode and uses time delays  
6955			; rather than polling the display's ready status. As a result the   
6955			; interface only requires 6 simple output lines:  
6955			;   Output bit 0 = not used  
6955			;   Output bit 1 = not used  
6955			;   Output bit 2 = RS         High = data, Low = instruction  
6955			;   Output bit 3 = E          Active high  
6955			;   Output bit 4 = DB4  
6955			;   Output bit 5 = DB5  
6955			;   Output bit 6 = DB6  
6955			;   Output bit 7 = DB7  
6955			; Display's R/W is connected to 0v so it is always in write mode  
6955			;  
6955			; This set up should work with any system supporting the RC2014 bus  
6955			  
6955			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
6955			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
6955			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
6955			;  
6955			; **********************************************************************  
6955			  
6955			; Additonal for 4x40. E1 and E2 instead of just E   
6955			; TODO swipe vidout signal on port a to activate E2  
6955			  
6955			; **********************************************************************  
6955			; **  Constants  
6955			; **********************************************************************  
6955			; LCD constants required by LCD support module  
6955			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
6955			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
6955			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
6955			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
6955			; TODO Decide which E is being set  
6955			kLCDWidth:  EQU display_cols             ;Width in characters  
6955			  
6955			; **********************************************************************  
6955			; **  Code library usage  
6955			; **********************************************************************  
6955			  
6955			; send character to current cursor position  
6955			; wraps and/or scrolls screen automatically  
6955			  
6955			  
6955			  
