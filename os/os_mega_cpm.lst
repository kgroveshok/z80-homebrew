1d48			; op codes for forth keywords 
1d48			 
1d48			; Changing use of opcodes to flag is the word exists in compiled form or not.  
1d48			; This provides a means to compile uwords if required for higher performance 
1d48			; by avoiding the use of the keyword parser and just jumping directly to the code 
1d48			; Actually there is already a flag for if the code exists as binary thinking about it... 
1d48			 
1d48			 
1d48			 
1d48			 
1d48			 
1d48			; free to use code 0  
1d48				OPCODE_HEAP: equ  1 
1d48				OPCODE_EXEC: equ 2 
1d48				OPCODE_DUP: equ 3 
1d48				OPCODE_SWAP: equ 4 
1d48				OPCODE_COLN: equ 5 
