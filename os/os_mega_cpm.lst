0b7c			;http://z80-heaven.wikidot.com/math 
0b7c			; 
0b7c			;Inputs: 
0b7c			;     DE and A are factors 
0b7c			;Outputs: 
0b7c			;     A is not changed 
0b7c			;     B is 0 
0b7c			;     C is not changed 
0b7c			;     DE is not changed 
0b7c			;     HL is the product 
0b7c			;Time: 
0b7c			;     342+6x 
0b7c			; 
0b7c			Mult16: 
0b7c			 
0b7c 06 08		     ld b,8          ;7           7 
0b7e 21 00 00		     ld hl,0         ;10         10 
0b81 29			       add hl,hl     ;11*8       88 
0b82 07			       rlca          ;4*8        32 
0b83 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0b85 19			         add hl,de   ;--         -- 
0b86 10 f9		       djnz $-5      ;13*7+8     99 
0b88 c9			ret 
