8d44			; Decimal Signed Version 
8d44			 
8d44			; DispA 
8d44			; -------------------------------------------------------------- 
8d44			; Converts a signed integer value to a zero-terminated ASCII 
8d44			; string representative of that value (using radix 10). 
8d44			; -------------------------------------------------------------- 
8d44			; INPUTS: 
8d44			;     HL     Value to convert (two's complement integer). 
8d44			;     DE     Base address of string destination. (pointer). 
8d44			; -------------------------------------------------------------- 
8d44			; OUTPUTS: 
8d44			;     None 
8d44			; -------------------------------------------------------------- 
8d44			; REGISTERS/MEMORY DESTROYED 
8d44			; AF HL 
8d44			; -------------------------------------------------------------- 
8d44			 
8d44			;DispHLToASCII: 
8d44			;   push    de 
8d44			;   push    bc 
8d44			; 
8d44			;; Detect sign of HL. 
8d44			;    bit    7, h 
8d44			;    jr     z, ._DoConvert 
8d44			; 
8d44			;; HL is negative. Output '-' to string and negate HL. 
8d44			;    ld     a, '-' 
8d44			;    ld     (de), a 
8d44			;    inc    de 
8d44			; 
8d44			;; Negate HL (using two's complement) 
8d44			;    xor    a 
8d44			;    sub    l 
8d44			;    ld     l, a 
8d44			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
8d44			;    sbc    a, h 
8d44			;    ld     h, a 
8d44			; 
8d44			;; Convert HL to digit characters 
8d44			;._DoConvert: 
8d44			;    ld     b, 0     ; B will count character length of number 
8d44			;-   ld     a, 10 
8d44			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
8d44			;    push   af 
8d44			;    inc    b 
8d44			;    ld     a, h 
8d44			;    or     l 
8d44			;    jr     nz, - 
8d44			; 
8d44			;; Retrieve digits from stack 
8d44			;-   pop    af 
8d44			;    or     $30 
8d44			;    ld     (de), a 
8d44			;    inc    de 
8d44			;    djnz   - 
8d44			; 
8d44			;; Terminate string with NULL 
8d44			;    xor    a 
8d44			;    ld     (de), a 
8d44			; 
8d44			;    pop    bc 
8d44			;    pop    de 
8d44			;    ret 
8d44			 
8d44			;Comments 
8d44			; 
8d44			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
8d44			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
8d44			;    Note that the output string will not be fixed-width. 
8d44			; 
8d44			;Example Usage 
8d44			; 
8d44			;    ld    hl, -1004 
8d44			;    ld    de, OP1 
8d44			;    call  DispA 
8d44			;    ld    hl, OP1 
8d44			;    syscall  PutS 
