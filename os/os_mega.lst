4c9b			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4c9b			; | | e.g. 
4c9b			; | | $01 OPEN $01 DO READ . LOOP 
4c9b			; | | 
4c9b			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4c9b			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4c9b			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4c9b			; | | two bytes contain the file id and extent. 
4c9b			; | |  
4c9b			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4c9b			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4c9b			; | | > [!NOTE] 
4c9b			; | | > Compatible with PicoSPINet  
4c9b			 
4c9b					if DEBUG_FORTH_WORDS_KEY 
4c9b						DMARK "REA" 
4c9b				if DEMARK_VERSION = 1  
4c9b e5					push hl  
4c9c 21 a4 4c				ld hl, .dmark  
4c9f 22 9b fd				ld (debug_mark), hl  
4ca2				endif  
