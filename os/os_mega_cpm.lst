0153			  
0153			; macro to detect for stack imbalances  
0153			  
0153			include "stackimbal.asm"  
0153			; Macro and code to detect stock imbalances 
0153			 
0153			SPPUSH: equ 0 
0153			 
0153			; Add a stack frame which can be checked before return 
0153			 
0153			STACKFRAME: macro onoff frame1 frame2 
0153			 
0153				if DEBUG_STACK_IMB 
0153					if onoff 
0153						; save current SP 
0153						exx 
0153			 
0153						ld de, frame1 
0153						ld a, d 
0153						ld hl, curframe 
0153						call hexout 
0153						ld a, e 
0153						ld hl, curframe+2 
0153						call hexout 
0153			  
0153						ld hl, frame1 
0153						push hl 
0153						ld hl, frame2 
0153						push hl 
0153						exx 
0153					endif 
0153					 
0153				endif 
0153			endm 
0153			 
0153			STACKFRAMECHK: macro onoff frame1 frame2 
0153			 
0153					 
0153				if DEBUG_STACK_IMB 
0153					if onoff 
0153						exx 
0153						; check stack frame SP 
0153			 
0153						ld hl, frame2 
0153						pop de   ; frame2 
0153			 
0153						call cmp16 
0153						jr nz, .spnosame 
0153						 
0153			 
0153						ld hl, frame1 
0153						pop de   ; frame1 
0153			 
0153						call cmp16 
0153						jr z, .spfrsame 
0153			 
0153						.spnosame: call showsperror 
0153			 
0153						.spfrsame: nop 
0153			 
0153						exx 
0153					endif 
0153					 
0153				endif 
0153			 
0153			 
0153			endm 
0153			 
0153			 
0153			; for a sub routine, wrap SP collection and comparisons 
0153			 
0153			; Usage: 
0153			; 
0153			; SAVESP ON/OFF 0-STACK_IMB_STORE/4 
0153			; CHECKSP ON/OFF 0-STACK_IMB_STORE/4 
0153			 
0153			SAVESP: macro onoff storeword 
0153			 
0153				if DEBUG_STACK_IMB 
0153					if onoff 
0153						; save current SP 
0153			 
0153						ld (store_sp+(storeword*4)), sp 
0153			 
0153					endif 
0153					 
0153				endif 
0153			 
0153			endm 
0153			 
0153			CHECKSP: macro onoff storeword 
0153			 
0153				if DEBUG_STACK_IMB 
0153					if onoff 
0153			 
0153						; save SP after last save 
0153				 
0153						ld (store_sp+(storeword*4)+2), sp 
0153			 
0153						push hl 
0153						ld hl, store_sp+(storeword*4) 
0153						call check_stack_sp  
0153						pop hl 
0153			 
0153			 
0153					endif 
0153					 
0153				endif 
0153			 
0153			endm 
0153			 
0153			if DEBUG_STACK_IMB 
0153			 
0153			check_stack_sp: 
0153					push de 
0153			 
0153					ld e, (hl) 
0153					inc hl 
0153					ld d, (hl) 
0153					inc hl 
0153			 
0153					push de 
0153			 
0153			 
0153					ld e, (hl) 
0153					inc hl 
0153					ld d, (hl) 
0153					inc hl 
0153			 
0153					pop hl 
0153			 
0153			 
0153					; check to see if the same 
0153			 
0153					call cmp16 
0153					jr z, .spsame 
0153			 
0153					; not same 
0153			 
0153					call showsperror 
0153			.spsame: 
0153			 
0153					pop de 
0153			 
0153					ret 
0153			 
0153			.sperr:  db "Stack imbalance",0 
0153			 
0153			 
0153			showsperror: 
0153			 
0153			 
0153				push hl 
0153				push af 
0153				push de 
0153				call clear_display 
0153				ld de, .sperr 
0153				ld a,0 
0153			;	ld de,os_word_scratch 
0153				call str_at_display 
0153				ld a, display_row_1+17 
0153				ld de, debug_mark 
0153				call str_at_display 
0153				ld a, 0 
0153				ld (curframe+4),a 
0153				ld hl, curframe 
0153				ld de, os_word_scratch 
0153				ld a, display_row_4 
0153				call str_at_display 
0153				call update_display 
0153				;call break_point_state 
0153				call cin_wait 
0153			 
0153			;	ld a, ' ' 
0153			;	ld (os_view_disable), a 
0153				call bp_on 
0153				pop de	 
0153				pop af 
0153				pop hl 
0153				CALLMONITOR 
0153				ret 
0153			 
0153			endif 
0153			 
0153			 
0153			 
0153			; eof 
# End of file stackimbal.asm
