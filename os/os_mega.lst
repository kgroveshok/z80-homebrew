12c4			 
12c4			; encoding 
12c4			;  
12c4			; pulse marks  of stream 
12c4			; proportial 
12c4			 
12c4			 
12c4			; setup default tape params 
12c4			tape_init:     
12c4 3e 00			ld a, Device_A 
12c6 32 8e f9			ld (tape_port), a 
12c9			 
12c9 3e fa			ld a, 250 
12cb 32 8b f9			ld (tape_tm_gap), a 
12ce			 
12ce 3e 06			ld a, 6 
12d0 32 8d f9			ld (tape_pulse_high), a 
12d3			 
12d3 3e 02			ld a, 2 
12d5 32 8c f9			ld (tape_pulse_low), a 
12d8			 
12d8 21 32 00			ld hl, 50 
12db 22 89 f9			ld (tape_tm_high), hl 
12de			 
12de 21 32 00			ld hl, 50 
12e1 22 87 f9			ld (tape_tm_low), hl 
12e4 c9				ret 
12e5			 
12e5			; support routinues for tape 
12e5			 
12e5			 
12e5			; Tape Output 
12e5			 
12e5			; osciallate the pin for the required duration 
12e5			 
12e5			tape_osc:  
12e5				; hl has the number of iterations 
12e5				; c = port number 
12e5				; d = bus data 
12e5				 
12e5 ed 51			out (c), d 
12e7			 
12e7 2b				dec hl 
12e8 cd 88 0d			call ishlzero 
12eb 20 f8			jr nz, tape_osc 
12ed				 
12ed c9				ret 
12ee			 
12ee			; output a gap period 
12ee			tape_gap:  
12ee 3a 8b f9			ld a, (tape_tm_gap) 
12f1 cd 53 0a			call aDelayInMS 
12f4 c9				ret 
12f5			 
12f5			tape_byte_gap: 
12f5 cd ee 12			call tape_gap 
12f8 cd ee 12			call tape_gap 
12fb cd ee 12			call tape_gap 
12fe cd ee 12			call tape_gap 
1301 c9				ret 
1302			 
1302			; output a high period 
1302			 
1302			tape_high: 
1302 3a 8e f9			ld a, (tape_port) 
1305 4f				ld c, a 
1306 16 ff			ld d, 255 
1308 3a 8d f9			ld a, (tape_pulse_high) 
130b 47				ld b, a 
130c 2a 89 f9		.th:	ld hl, (tape_tm_high) 
130f cd e5 12			call tape_osc 
1312 cd ee 12			call tape_gap 
1315 10 f5			djnz .th 
1317 c9				 ret 
1318			 
1318			; output a low period 
1318			 
1318			tape_low:  
1318			 
1318 3a 8e f9			ld a, (tape_port) 
131b 4f				ld c, a 
131c 16 ff			ld d, 255 
131e 3a 8c f9			ld a, (tape_pulse_low) 
1321 47				ld b, a 
1322 2a 87 f9		.tl:	ld hl, (tape_tm_low) 
1325 cd e5 12			call tape_osc 
1328 cd ee 12			call tape_gap 
132b 10 f5			djnz .tl 
132d c9				 ret 
132e			 
132e			; end of save marker 
132e			 
132e			tape_end: 
132e 3e ff			ld a, 255 
1330 cd 47 13			call tape_byte_out 
1333 cd f5 12			call tape_byte_gap 
1336			 
1336 3e ff			ld a, 255 
1338 cd 47 13			call tape_byte_out 
133b cd f5 12			call tape_byte_gap 
133e 3e ff			ld a, 255 
1340 cd 47 13			call tape_byte_out 
1343 cd f5 12			call tape_byte_gap 
1346 c9				 ret 
1347			 
1347			; output an encoded byte 
1347			 
1347			tape_byte_out: 
1347				; a = byte to output 
1347 06 08			ld b, 8 
1349 4f				ld c, a 
134a			.tbo:    
134a c5				push bc 
134b cb 79			bit 7, c 
134d 28 05			jr z, .tbol 
134f cd 02 13			call tape_high 
1352 18 03			jr .tbn 
1354			.tbol: 
1354 cd 18 13			call tape_low 
1357			.tbn: 
1357 cd ee 12			call tape_gap 
135a c1				pop bc 
135b cb 21			sla c 
135d 10 eb			djnz .tbo 
135f cd f5 12			call tape_byte_gap 
1362			 
1362 c9				 ret 
1363			 
1363			; output a string 
1363			 
1363			; hl - pointer to string 
