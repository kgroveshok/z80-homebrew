d50b 32 72 ee		        ld (hardware_word+1),a 
d50e f1				pop af 
d50f c9				ret 
d510			 
d510			nmi: 
d510 e5				push hl 
d511 d5				push de 
d512 c5				push bc 
d513 f5				push af 
