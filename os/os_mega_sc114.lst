8e21			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8e21			;                                                                             : 
8e21			; Parameters                                                                  : 
8e21			;     HL  Number of bytes wanted                                              : 
8e21			;                                                                             : 
8e21			; Returns                                                                     : 
8e21			;     HL  Address of the first useable byte of the allocation                 : 
8e21			;                                                                             : 
8e21			; Flags                                                                       : 
8e21			;     Z   Set if the allocation did not succeed, clear otherwise              : 
