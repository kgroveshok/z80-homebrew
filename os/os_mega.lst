2c0d			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2c0d			; | | At start the current various registers will be displayed with contents. 
2c0d			; | | Top right corner will show the most recent debug marker seen. 
2c0d			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2c0d			; | | and the return stack pointer (RSP). 
2c0d			; | | Pressing: 
2c0d			; | |  
2c0d			; | |    1 - Initial screen 
2c0d			; | |  
2c0d			; | |    2 - Display a data dump of HL 
2c0d			; | |  
2c0d			; | |    3 - Display a data dump of DE 
2c0d			; | |  
2c0d			; | |    4 - Display a data dump of BC 
2c0d			; | |  
2c0d			; | |    5 - Display a data dump of HL 
2c0d			; | |  
2c0d			; | |    6 - Display a data dump of DSP 
2c0d			; | |  
2c0d			; | |    7 - Display a data dump of RSP 
2c0d			; | |  
2c0d			; | |    8 - Display a data dump of what is at DSP 
2c0d			; | |  
2c0d			; | |    9 - Display a data dump of what is at RSP 
2c0d			; | |  
2c0d			; | |    0 - Exit monitor and continue running. This will also enable break points 
2c0d			; | |  
2c0d			; | |    * - Disable break points 
2c0d			; | |  
2c0d			; | |    # - Enter traditional monitor mode 
2c0d			; | |  
2c0d			; | | 
2c0d			; | | Monitor Mode 
2c0d			; | | ------------ 
2c0d			; | | A prompt of '>' will be shown for various commands: 
2c0d			; | |  
2c0d			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2c0d			; | |  
2c0d			; | |    C - Continue display a data dump from the last set address 
2c0d			; | |  
2c0d			; | |    M xxxx - Set start of memory edit at address xx 
2c0d			; | |  
2c0d			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2c0d			; | |  
2c0d			; | |    G xxxx - Exec code at specific address 
2c0d			; | |  
2c0d			; | |    Q - Return to previous 
2c0d				if DEBUG_FORTH_WORDS_KEY 
2c0d					DMARK "MON" 
2c0d				if DEMARK_VERSION = 1  
2c0d e5					push hl  
2c0e 21 16 2c				ld hl, .dmark  
2c11 22 9b fd				ld (debug_mark), hl  
2c14				endif  
2c14				if DEMARK_VERSION = 0  
2c14					push af  
2c14					ld a, (.dmark)  
2c14					ld (debug_mark),a  
2c14					ld a, (.dmark+1)  
2c14					ld (debug_mark+1),a  
2c14					ld a, (.dmark+2)  
2c14					ld (debug_mark+2),a  
2c14				endif  
2c14 18 04			jr .pastdmark  
2c16 ..			.dmark: db "MON"  
2c19				if DEMARK_VERSION = 1  
2c19 00					db 0  
2c1a				endif  
2c1a				if DEMARK_VERSION = 1  
2c1a e1			.pastdmark: pop hl  
2c1b				endif  
2c1b				if DEMARK_VERSION = 0  
2c1b			.pastdmark: pop af  
2c1b				endif  
2c1b			endm  
# End of macro DMARK
