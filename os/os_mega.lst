0c93			 
0c93			;-----> Generate a random number 
0c93			; output a=answer 0<=a<=255 
0c93			; all registers are preserved except: af 
0c93			random: 
0c93 e5			        push    hl 
0c94 d5			        push    de 
0c95 2a db fa		        ld      hl,(randData) 
0c98 ed 5f		        ld      a,r 
0c9a 57			        ld      d,a 
0c9b 5e			        ld      e,(hl) 
0c9c 19			        add     hl,de 
0c9d 85			        add     a,l 
0c9e ac			        xor     h 
0c9f 22 db fa		        ld      (randData),hl 
0ca2 d1			        pop     de 
0ca3 e1			        pop     hl 
0ca4 c9			        ret 
0ca5			 
0ca5			 
0ca5			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0ca5			 
0ca5			 
0ca5			 
0ca5			;------LFSR------ 
0ca5			;James Montelongo 
0ca5			;optimized by Spencer Putt 
0ca5			;out: 
0ca5			; a = 8 bit random number 
0ca5			RandLFSR: 
0ca5 21 e1 fa		        ld hl,LFSRSeed+4 
0ca8 5e			        ld e,(hl) 
0ca9 23			        inc hl 
0caa 56			        ld d,(hl) 
0cab 23			        inc hl 
0cac 4e			        ld c,(hl) 
0cad 23			        inc hl 
0cae 7e			        ld a,(hl) 
0caf 47			        ld b,a 
0cb0 cb 13		        rl e  
0cb2 cb 12			rl d 
0cb4 cb 11		        rl c  
0cb6 17				rla 
0cb7 cb 13		        rl e  
0cb9 cb 12			rl d 
0cbb cb 11		        rl c  
0cbd 17				rla 
0cbe cb 13		        rl e  
0cc0 cb 12			rl d 
0cc2 cb 11		        rl c  
0cc4 17				rla 
0cc5 67			        ld h,a 
0cc6 cb 13		        rl e  
0cc8 cb 12			rl d 
0cca cb 11		        rl c  
0ccc 17				rla 
0ccd a8			        xor b 
0cce cb 13		        rl e  
0cd0 cb 12			rl d 
0cd2 ac			        xor h 
0cd3 a9			        xor c 
0cd4 aa			        xor d 
0cd5 21 e3 fa		        ld hl,LFSRSeed+6 
0cd8 11 e4 fa		        ld de,LFSRSeed+7 
0cdb 01 07 00		        ld bc,7 
0cde ed b8		        lddr 
0ce0 12			        ld (de),a 
0ce1 c9			        ret 
0ce2			 
0ce2			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0ce2			 
0ce2			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0ce2			 
0ce2			 
0ce2			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0ce2			 
0ce2			prng16: 
0ce2			;Inputs: 
0ce2			;   (seed1) contains a 16-bit seed value 
0ce2			;   (seed2) contains a NON-ZERO 16-bit seed value 
0ce2			;Outputs: 
0ce2			;   HL is the result 
0ce2			;   BC is the result of the LCG, so not that great of quality 
0ce2			;   DE is preserved 
0ce2			;Destroys: 
0ce2			;   AF 
0ce2			;cycle: 4,294,901,760 (almost 4.3 billion) 
0ce2			;160cc 
0ce2			;26 bytes 
0ce2 2a d5 fa		    ld hl,(seed1) 
0ce5 44			    ld b,h 
0ce6 4d			    ld c,l 
0ce7 29			    add hl,hl 
0ce8 29			    add hl,hl 
0ce9 2c			    inc l 
0cea 09			    add hl,bc 
0ceb 22 d5 fa		    ld (seed1),hl 
0cee 2a d3 fa		    ld hl,(seed2) 
0cf1 29			    add hl,hl 
0cf2 9f			    sbc a,a 
0cf3 e6 2d		    and %00101101 
0cf5 ad			    xor l 
0cf6 6f			    ld l,a 
0cf7 22 d3 fa		    ld (seed2),hl 
0cfa 09			    add hl,bc 
0cfb c9			    ret 
0cfc			 
0cfc			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0cfc			 
0cfc			rand32: 
0cfc			;Inputs: 
0cfc			;   (seed1_0) holds the lower 16 bits of the first seed 
0cfc			;   (seed1_1) holds the upper 16 bits of the first seed 
0cfc			;   (seed2_0) holds the lower 16 bits of the second seed 
0cfc			;   (seed2_1) holds the upper 16 bits of the second seed 
0cfc			;   **NOTE: seed2 must be non-zero 
0cfc			;Outputs: 
0cfc			;   HL is the result 
0cfc			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0cfc			;Destroys: 
0cfc			;   AF 
0cfc			;Tested and passes all CAcert tests 
0cfc			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0cfc			;it has a period of 18,446,744,069,414,584,320 
0cfc			;roughly 18.4 quintillion. 
0cfc			;LFSR taps: 0,2,6,7  = 11000101 
0cfc			;291cc 
0cfc			;seed1_0=$+1 
0cfc			;    ld hl,12345 
0cfc			;seed1_1=$+1 
0cfc			;    ld de,6789 
0cfc			;    ld b,h 
0cfc			;    ld c,l 
0cfc			;    add hl,hl \ rl e \ rl d 
0cfc			;    add hl,hl \ rl e \ rl d 
0cfc			;    inc l 
0cfc			;    add hl,bc 
0cfc			;    ld (seed1_0),hl 
0cfc			;    ld hl,(seed1_1) 
0cfc			;    adc hl,de 
0cfc			;    ld (seed1_1),hl 
0cfc			;    ex de,hl 
0cfc			;seed2_0=$+1 
0cfc			;    ld hl,9876 
0cfc			;seed2_1=$+1 
0cfc			;    ld bc,54321 
0cfc			;    add hl,hl \ rl c \ rl b 
0cfc			;    ld (seed2_1),bc 
0cfc			;    sbc a,a 
0cfc			;    and %11000101 
0cfc			;    xor l 
0cfc			;    ld l,a 
0cfc			;    ld (seed2_0),hl 
0cfc			;    ex de,hl 
0cfc			;    add hl,bc 
0cfc			;    ret 
0cfc			; 
0cfc			 
0cfc			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0cfc			; 20 bytes, 86 cycles (excluding ret) 
0cfc			 
0cfc			; returns   hl = pseudorandom number 
0cfc			; corrupts   a 
0cfc			 
0cfc			; generates 16-bit pseudorandom numbers with a period of 65535 
0cfc			; using the xorshift method: 
0cfc			 
0cfc			; hl ^= hl << 7 
0cfc			; hl ^= hl >> 9 
0cfc			; hl ^= hl << 8 
0cfc			 
0cfc			; some alternative shift triplets which also perform well are: 
0cfc			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0cfc			 
0cfc			;  org 32768 
0cfc			 
0cfc			xrnd: 
0cfc 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0cff 3e 00		  ld a,0 
0d01 bd			  cp l 
0d02 20 02		  jr nz, .xrnd1 
0d04 2e 01		  ld l, 1 
0d06			.xrnd1: 
0d06			 
0d06 7c			  ld a,h 
0d07 1f			  rra 
0d08 7d			  ld a,l 
0d09 1f			  rra 
0d0a ac			  xor h 
0d0b 67			  ld h,a 
0d0c 7d			  ld a,l 
0d0d 1f			  rra 
0d0e 7c			  ld a,h 
0d0f 1f			  rra 
0d10 ad			  xor l 
0d11 6f			  ld l,a 
0d12 ac			  xor h 
0d13 67			  ld h,a 
0d14			 
0d14 22 d9 fa		  ld (xrandc),hl 
0d17			 
0d17 c9			  ret 
