8993			; 
8993			; Divide 8-bit values 
8993			; In: Divide E by divider C 
8993			; Out: A = result, B = rest 
8993			; 
8993			Div8: 
8993 af			    xor a 
8994 06 08		    ld b,8 
8996			Div8_Loop: 
8996 cb 13		    rl e 
8998 17			    rla 
8999 91			    sub c 
899a 30 01		    jr nc,Div8_NoAdd 
899c 81			    add a,c 
899d			Div8_NoAdd: 
899d 10 f7		    djnz Div8_Loop 
899f 47			    ld b,a 
89a0 7b			    ld a,e 
89a1 17			    rla 
89a2 2f			    cpl 
89a3 c9			    ret 
