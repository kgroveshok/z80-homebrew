8f8d dd 66 03		      ld    H, (IX+3) 
8f90 23			      inc   HL 
8f91 23			      inc   HL 
8f92 73			      ld    (HL), E 
8f93 23			      inc   HL 
8f94 72			      ld    (HL), D 
8f95			 
8f95			free_done: 
8f95 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
8f98 39			      add   HL, SP 
8f99 f9			      ld    SP, HL 
8f9a			 
8f9a			free_early_exit: 
8f9a dd e1		      pop   IX 
8f9c d1			      pop   DE 
8f9d c1			      pop   BC 
8f9e			 
8f9e c9			      ret 
8f9f			 
8f9f			; moved to firmware.asm 
8f9f			; 
8f9f			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8f9f			;                  .dw   0 
8f9f			 
8f9f			 
8f9f			endif 
8f9f			 
8f9f			 
8f9f			if MALLOC_3 
8f9f			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
8f9f			;heap_start        .equ  0x9000      ; Starting address of heap 
8f9f			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8f9f			; 
8f9f			 ;     .org 0 
8f9f			  ;    jp    main 
8f9f			; 
8f9f			; 
8f9f			 ;     .org  0x100 
8f9f			;main: 
8f9f			 ;     ld    HL, 0x8100 
8f9f			  ;    ld    SP, HL 
8f9f			; 
8f9f			;      call  heap_init 
8f9f			 
8f9f			      ; Make some allocations 
8f9f			;      ld    HL, 12 
8f9f			;      call  malloc            ; Allocates 0x9004 
8f9f			; 
8f9f			 ;     ld    HL, 12 
8f9f			;      call  malloc            ; Allocates 0x9014 
8f9f			 
8f9f			;      ld    HL, 12 
8f9f			;      call  malloc            ; Allocates 0x9024 
8f9f			 
8f9f			      ; Free some allocations 
8f9f			;      ld    HL, 0x9014 
8f9f			;      call  free 
8f9f			 
8f9f			;      ld    HL, 0x9004 
8f9f			;      call  free 
8f9f			; 
8f9f			;      ld    HL, 0x9024 
8f9f			;      call  free 
8f9f			 
8f9f			 
8f9f			 ;     halt 
8f9f			 
8f9f			 
8f9f			;------------------------------------------------------------------------------ 
8f9f			;     heap_init                                                               : 
8f9f			;                                                                             : 
8f9f			; Description                                                                 : 
8f9f			;     Initialise the heap and make it ready for malloc and free operations.   : 
8f9f			;                                                                             : 
8f9f			;     The heap is maintained as a linked list, starting with an initial       : 
8f9f			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8f9f			;     the first free block in the heap. Each block then points to the next    : 
8f9f			;     free block within the heap, and the free list ends at the first block   : 
8f9f			;     with a null pointer to the next free block.                             : 
8f9f			;                                                                             : 
8f9f			; Parameters                                                                  : 
8f9f			;     Inputs are compile-time only. Two defines which specify the starting    : 
8f9f			;     address of the heap and its size are required, along with a memory      : 
8f9f			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8f9f			;     principally stores a pointer to the first free block in the heap.       : 
8f9f			;                                                                             : 
8f9f			; Returns                                                                     : 
8f9f			;     Nothing                                                                 : 
8f9f			;------------------------------------------------------------------------------ 
8f9f			heap_init: 
8f9f			      push  HL 
8f9f			 
8f9f			      ; Initialise free list struct 
8f9f			      ld    HL, heap_start 
8f9f			      ld    (free_list), HL 
8f9f			      ld    HL, 0 
8f9f			      ld    (free_list+2), HL 
8f9f			 
8f9f			      ; Insert first free block at bottom of heap, consumes entire heap 
8f9f			      ld    HL, heap_start+heap_size-4 
8f9f			      ld    (heap_start), HL        ; Next block (end of free list) 
8f9f			      ld    HL, heap_size-4 
8f9f			      ld    (heap_start+2), HL      ; Block size 
8f9f			 
8f9f			      ; Insert end of free list block at top of heap - two null words will 
8f9f			      ; terminate the free list 
8f9f			      ld    HL, 0 
8f9f			      ld    (heap_start+heap_size-2), HL 
8f9f			      ld    (heap_start+heap_size-4), HL 
8f9f			 
8f9f			      pop   HL 
8f9f			 
8f9f			      ret 
8f9f			 
8f9f			 
8f9f			;------------------------------------------------------------------------------ 
8f9f			;     malloc                                                                  : 
8f9f			;                                                                             : 
8f9f			; Description                                                                 : 
8f9f			;     Allocates the wanted space from the heap and returns the address of the : 
8f9f			;     first useable byte of the allocation.                                   : 
8f9f			;                                                                             : 
8f9f			;     Allocations can happen in one of two ways:                              : 
8f9f			;                                                                             : 
8f9f			;     1. A free block may be found which is the exact size wanted. In this    : 
8f9f			;        case the block is removed from the free list and retuedn to the      : 
8f9f			;        caller.                                                              : 
8f9f			;     2. A free block may be found which is larger than the size wanted. In   : 
8f9f			;        this case, the larger block is split into two. The first portion of  : 
8f9f			;        this block will become the requested space by the malloc call and    : 
8f9f			;        is returned to the caller. The second portion becomes a new free     : 
8f9f			;        block, and the free list is adjusted to maintain continuity via this : 
8f9f			;        newly created block.                                                 : 
8f9f			;                                                                             : 
8f9f			;     malloc does not set any initial value in the allocated space, the       : 
8f9f			;     caller is required to do this as required.                              : 
8f9f			;                                                                             : 
8f9f			;     This implementation of malloc uses the stack exclusively, and is        : 
8f9f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8f9f			;     advisable to disable interrupts before calling malloc, and recommended  : 
8f9f			;     to avoid the use of malloc inside ISRs in general.                      : 
8f9f			;                                                                             : 
8f9f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8f9f			;                                                                             : 
8f9f			; Parameters                                                                  : 
8f9f			;     HL  Number of bytes wanted                                              : 
8f9f			;                                                                             : 
8f9f			; Returns                                                                     : 
8f9f			;     HL  Address of the first useable byte of the allocation                 : 
8f9f			;                                                                             : 
8f9f			; Flags                                                                       : 
8f9f			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8f9f			;                                                                             : 
8f9f			; Stack frame                                                                 : 
8f9f			;       |             |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |     BC      |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |     DE      |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |     IX      |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |  prev_free  |                                                       : 
8f9f			;   +4  +-------------+                                                       : 
8f9f			;       |  this_free  |                                                       : 
8f9f			;   +2  +-------------+                                                       : 
8f9f			;       |  next_free  |                                                       : 
8f9f			;   +0  +-------------+                                                       : 
8f9f			;       |             |                                                       : 
8f9f			;                                                                             : 
8f9f			;------------------------------------------------------------------------------ 
8f9f			malloc: 
8f9f			      push  BC 
8f9f			      push  DE 
8f9f			      push  IX 
8f9f			 
8f9f			      ld    A, H                    ; Exit if no space requested 
8f9f			      or    L 
8f9f			      jp    Z, malloc_early_exit 
8f9f			 
8f9f			      ; Set up stack frame 
8f9f			      ex    DE, HL 
8f9f			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8f9f			      add   HL, SP 
8f9f			      ld    SP, HL 
8f9f			      ld    IX, 0                   ; Use IX as a frame pointer 
8f9f			      add   IX, SP 
8f9f			 
8f9f			      ; Setup initial state 
8f9f			      ld    HL, 4                   ; want must also include space used by block struct 
8f9f			      add   HL, DE 
8f9f			 
8f9f			      ld    B, H                    ; Move want to BC 
8f9f			      ld    C, L 
8f9f			 
8f9f			      ld    HL, free_list           ; Store prev_free ptr to stack 
8f9f			      ld    (IX+4), L 
8f9f			      ld    (IX+5), H 
8f9f			 
8f9f			      ld    E, (HL)                 ; Store this_free ptr to stack 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      ld    (IX+2), E 
8f9f			      ld    (IX+3), D 
8f9f			      ex    DE, HL                  ; this_free ptr into HL 
8f9f			 
8f9f			      ; Loop through free block list to find some space 
8f9f			malloc_find_space: 
8f9f			      ld    E, (HL)                 ; Load next_free ptr into DE 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			 
8f9f			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8f9f			      or    E 
8f9f			      jp    Z, malloc_no_space 
8f9f			 
8f9f			      ld    (IX+0), E               ; Store next_free ptr to stack 
8f9f			      ld    (IX+1), D 
8f9f			 
8f9f			      ; Does this block have enough space to make the allocation? 
8f9f			      inc   HL                      ; Load free block size into DE 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			 
8f9f			      ex    DE, HL                  ; Check size of block against want 
8f9f			      or    A                       ; Ensure carry flag clear 
8f9f			      sbc   HL, BC 
8f9f			      push  HL                      ; Store the result for later (new block size) 
8f9f			 
8f9f			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8f9f			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8f9f			 
8f9f			      ; this_free block is not big enough, setup ptrs to test next free block 
8f9f			      pop   HL                      ; Discard previous result 
8f9f			 
8f9f			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8f9f			      ld    H, (IX+3) 
8f9f			      ld    (IX+4), L 
8f9f			      ld    (IX+5), H 
8f9f			 
8f9f			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8f9f			      ld    H, (IX+1) 
8f9f			      ld    (IX+2), L 
8f9f			      ld    (IX+3), H 
8f9f			 
8f9f			      jr    malloc_find_space 
8f9f			 
8f9f			      ; split a bigger block into two - requested size and remaining size 
8f9f			malloc_alloc_split: 
8f9f			      ex    DE, HL                  ; Calculate address of new free block 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			      add   HL, BC 
8f9f			 
8f9f			      ; Create a new block and point it at next_free 
8f9f			      ld    E, (IX+0)               ; Load next_free ptr into DE 
8f9f			      ld    D, (IX+1) 
8f9f			 
8f9f			      ld    (HL), E                 ; Store next_free ptr into new block 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			      pop   DE                      ; Store size of new block into new block 
8f9f			      inc   HL 
8f9f			      ld    (HL), E 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			      ; Update this_free ptr to point to new block 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			 
8f9f			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8f9f			      ld    D, (IX+3) 
8f9f			 
8f9f			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8f9f			      ld    (IX+3), H 
8f9f			 
8f9f			      ; Modify this_free block to be allocation 
8f9f			      ex    DE, HL 
8f9f			      xor   A                       ; Null the next block ptr of allocated block 
8f9f			      ld    (HL), A 
8f9f			      inc   HL 
8f9f			      ld    (HL), A 
8f9f			 
8f9f			      inc   HL                      ; Store want size into allocated block 
8f9f			      ld    (HL), C 
8f9f			      inc   HL 
8f9f			      ld    (HL), B 
8f9f			      inc   HL 
8f9f			      push  HL                      ; Address of allocation to return 
8f9f			 
8f9f			      jr    malloc_update_links 
8f9f			 
8f9f			malloc_alloc_fit: 
8f9f			      pop   HL                      ; Dont need new block size, want is exact fit 
8f9f			 
8f9f			      ; Modify this_free block to be allocation 
8f9f			      ex    DE, HL 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			 
8f9f			      xor   A                       ; Null the next block ptr of allocated block 
8f9f			      ld    (HL), A 
8f9f			      inc   HL 
8f9f			      ld    (HL), A 
8f9f			 
8f9f			      inc   HL                      ; Store address of allocation to return 
8f9f			      inc   HL 
8f9f			      inc   HL 
8f9f			      push  HL 
8f9f			 
8f9f			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8f9f			      ld    L, (IX+0)               ; next_free to HL 
8f9f			      ld    H, (IX+1) 
8f9f			 
8f9f			      ld    (IX+2), L               ; HL to this_free 
8f9f			      ld    (IX+3), H 
8f9f			 
8f9f			 
8f9f			malloc_update_links: 
8f9f			      ; Update prev_free ptr to point to this_free 
8f9f			      ld    L, (IX+4)               ; prev_free ptr to HL 
8f9f			      ld    H, (IX+5) 
8f9f			 
8f9f			      ld    E, (IX+2)               ; this_free ptr to DE 
8f9f			      ld    D, (IX+3) 
8f9f			 
8f9f			      ld    (HL), E                 ; this_free ptr into prev_free 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			      ; Clear the Z flag to indicate successful allocation 
8f9f			      ld    A, D 
8f9f			      or    E 
8f9f			 
8f9f			      pop   DE                      ; Address of allocation 
8f9f			 
8f9f			malloc_no_space: 
8f9f			      ld    HL, 6                   ; Clean up stack frame 
8f9f			      add   HL, SP 
8f9f			      ld    SP, HL 
8f9f			 
8f9f			      ex    DE, HL                  ; Alloc addr into HL for return 
8f9f			 
8f9f			malloc_early_exit: 
8f9f			      pop   IX 
8f9f			      pop   DE 
8f9f			      pop   BC 
8f9f			 
8f9f			      ret 
8f9f			 
8f9f			 
8f9f			;------------------------------------------------------------------------------ 
8f9f			;     free                                                                    : 
8f9f			;                                                                             : 
8f9f			; Description                                                                 : 
8f9f			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8f9f			;     returned by malloc, otherwise the behaviour is undefined.               : 
8f9f			;                                                                             : 
8f9f			;     Where possible, directly adjacent free blocks will be merged together   : 
8f9f			;     into larger blocks to help ensure that the heap does not become         : 
8f9f			;     excessively fragmented.                                                 : 
8f9f			;                                                                             : 
8f9f			;     free does not clear or set any other value into the freed space, and    : 
8f9f			;     therefore its contents may be visible through subsequent malloc's. The  : 
8f9f			;     caller should clear the freed space as required.                        : 
8f9f			;                                                                             : 
8f9f			;     This implementation of free uses the stack exclusively, and is          : 
8f9f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8f9f			;     advisable to disable interrupts before calling free, and recommended    : 
8f9f			;     to avoid the use of free inside ISRs in general.                        : 
8f9f			;                                                                             : 
8f9f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8f9f			;                                                                             : 
8f9f			; Parameters                                                                  : 
8f9f			;     HL  Pointer to address of first byte of allocation to be freed          : 
8f9f			;                                                                             : 
8f9f			; Returns                                                                     : 
8f9f			;     Nothing                                                                 : 
8f9f			;                                                                             : 
8f9f			; Stack frame                                                                 : 
8f9f			;       |             |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |     BC      |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |     DE      |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |     IX      |                                                       : 
8f9f			;       +-------------+                                                       : 
8f9f			;       |  prev_free  |                                                       : 
8f9f			;   +2  +-------------+                                                       : 
8f9f			;       |  next_free  |                                                       : 
8f9f			;   +0  +-------------+                                                       : 
8f9f			;       |             |                                                       : 
8f9f			;                                                                             : 
8f9f			;------------------------------------------------------------------------------ 
8f9f			free: 
8f9f			      push  BC 
8f9f			      push  DE 
8f9f			      push  IX 
8f9f			 
8f9f			      ld    A, H                    ; Exit if ptr is null 
8f9f			      or    L 
8f9f			      jp    Z, free_early_exit 
8f9f			 
8f9f			      ; Set up stack frame 
8f9f			      ex    DE, HL 
8f9f			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8f9f			      add   HL, SP 
8f9f			      ld    SP, HL 
8f9f			      ld    IX, 0                   ; Use IX as a frame pointer 
8f9f			      add   IX, SP 
8f9f			 
8f9f			      ; The address in HL points to the start of the useable allocated space, 
8f9f			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8f9f			      ; address of the block itself. 
8f9f			      ex    DE, HL 
8f9f			      ld    DE, -4 
8f9f			      add   HL, DE 
8f9f			 
8f9f			      ; An allocated block must have a null next block pointer in it 
8f9f			      ld    A, (HL) 
8f9f			      inc   HL 
8f9f			      or    (HL) 
8f9f			      jp    NZ, free_done 
8f9f			 
8f9f			      dec   HL 
8f9f			 
8f9f			      ld    B, H                    ; Copy HL to BC 
8f9f			      ld    C, L 
8f9f			 
8f9f			      ; Loop through the free list to find the first block with an address 
8f9f			      ; higher than the block being freed 
8f9f			      ld    HL, free_list 
8f9f			 
8f9f			free_find_higher_block: 
8f9f			      ld    E, (HL)                 ; Load next ptr from free block 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      dec   HL 
8f9f			 
8f9f			      ld    (IX+0), E               ; Save ptr to next free block 
8f9f			      ld    (IX+1), D 
8f9f			      ld    (IX+2), L               ; Save ptr to prev free block 
8f9f			      ld    (IX+3), H 
8f9f			 
8f9f			      ld    A, B                    ; Check if DE is greater than BC 
8f9f			      cp    D                       ; Compare MSB first 
8f9f			      jr    Z, $+4                  ; MSB the same, compare LSB 
8f9f			      jr    NC, free_find_higher_block_skip 
8f9f			      ld    A, C 
8f9f			      cp    E                       ; Then compare LSB 
8f9f			      jr    C, free_found_higher_block 
8f9f			 
8f9f			free_find_higher_block_skip: 
8f9f			      ld    A, D                    ; Reached the end of the free list? 
8f9f			      or    E 
8f9f			      jp    Z, free_done 
8f9f			 
8f9f			      ex    DE, HL 
8f9f			 
8f9f			      jr    free_find_higher_block 
8f9f			 
8f9f			free_found_higher_block: 
8f9f			      ; Insert freed block between prev and next free blocks 
8f9f			      ld    (HL), C                 ; Point prev free block to freed block 
8f9f			      inc   HL 
8f9f			      ld    (HL), B 
8f9f			 
8f9f			      ld    H, B                    ; Point freed block at next free block 
8f9f			      ld    L, C 
8f9f			      ld    (HL), E 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			      ; Check if the freed block is adjacent to the next free block 
8f9f			      inc   HL                      ; Load size of freed block into HL 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      ex    DE, HL 
8f9f			 
8f9f			      add   HL, BC                  ; Add addr of freed block and its size 
8f9f			 
8f9f			      ld    E, (IX+0)               ; Load addr of next free block into DE 
8f9f			      ld    D, (IX+1) 
8f9f			 
8f9f			      or    A                       ; Clear the carry flag 
8f9f			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8f9f			      jr    NZ, free_check_adjacent_to_prev 
8f9f			 
8f9f			      ; Freed block is adjacent to next, merge into one bigger block 
8f9f			      ex    DE, HL                  ; Load next ptr from next block into DE 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      push  HL                      ; Save ptr to next block for later 
8f9f			 
8f9f			      ld    H, B                    ; Store ptr from next block into freed block 
8f9f			      ld    L, C 
8f9f			      ld    (HL), E 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			      pop   HL                      ; Restore ptr to next block 
8f9f			      inc   HL                      ; Load size of next block into DE 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      push  DE                      ; Save next block size for later 
8f9f			 
8f9f			      ld    H, B                    ; Load size of freed block into HL 
8f9f			      ld    L, C 
8f9f			      inc   HL 
8f9f			      inc   HL 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      ex    DE, HL 
8f9f			 
8f9f			      pop   DE                      ; Restore size of next block 
8f9f			      add   HL, DE                  ; Add sizes of both blocks 
8f9f			      ex    DE, HL 
8f9f			 
8f9f			      ld    H, B                    ; Store new bigger size into freed block 
8f9f			      ld    L, C 
8f9f			      inc   HL 
8f9f			      inc   HL 
8f9f			      ld    (HL), E 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			free_check_adjacent_to_prev: 
8f9f			      ; Check if the freed block is adjacent to the prev free block 
8f9f			      ld    L, (IX+2)               ; Prev free block ptr into HL 
8f9f			      ld    H, (IX+3) 
8f9f			 
8f9f			      inc   HL                      ; Size of prev free block into DE 
8f9f			      inc   HL 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			      dec   HL 
8f9f			 
8f9f			      add   HL, DE                  ; Add prev block addr and size 
8f9f			 
8f9f			      or    A                       ; Clear the carry flag 
8f9f			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8f9f			      jr    NZ, free_done 
8f9f			 
8f9f			      ; Freed block is adjacent to prev, merge into one bigger block 
8f9f			      ld    H, B                    ; Load next ptr from freed block into DE 
8f9f			      ld    L, C 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      push  HL                      ; Save freed block ptr for later 
8f9f			 
8f9f			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8f9f			      ld    H, (IX+3) 
8f9f			      ld    (HL), E 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			      pop   HL                      ; Restore freed block ptr 
8f9f			      inc   HL                      ; Load size of freed block into DE 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			      push  DE                      ; Save freed block size for later 
8f9f			 
8f9f			      ld    L, (IX+2)               ; Load size of prev block into DE 
8f9f			      ld    H, (IX+3) 
8f9f			      inc   HL 
8f9f			      inc   HL 
8f9f			      ld    E, (HL) 
8f9f			      inc   HL 
8f9f			      ld    D, (HL) 
8f9f			 
8f9f			      pop   HL                      ; Add sizes of both blocks 
8f9f			      add   HL, DE 
8f9f			      ex    DE, HL 
8f9f			 
8f9f			      ld    L, (IX+2)               ; Store new bigger size into prev block 
8f9f			      ld    H, (IX+3) 
8f9f			      inc   HL 
8f9f			      inc   HL 
8f9f			      ld    (HL), E 
8f9f			      inc   HL 
8f9f			      ld    (HL), D 
8f9f			 
8f9f			free_done: 
8f9f			      ld    HL, 4                   ; Clean up stack frame 
8f9f			      add   HL, SP 
8f9f			      ld    SP, HL 
8f9f			 
8f9f			free_early_exit: 
8f9f			      pop   IX 
8f9f			      pop   DE 
8f9f			      pop   BC 
8f9f			 
8f9f			      ret 
8f9f			 
8f9f			 
8f9f			;      .org 0x8000 
8f9f			; 
8f9f			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8f9f			 ;                 .dw   0 
8f9f			 
8f9f			endif 
