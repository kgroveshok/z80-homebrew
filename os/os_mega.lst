4ca2					ld a, (.dmark+2)  
4ca2					ld (debug_mark+2),a  
4ca2				endif  
4ca2 18 04			jr .pastdmark  
4ca4 ..			.dmark: db "REA"  
4ca7				if DEMARK_VERSION = 1  
4ca7 00					db 0  
4ca8				endif  
