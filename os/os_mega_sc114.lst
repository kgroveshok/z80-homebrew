8fbd				 
8fbd			;	cp 0 
8fbd			;	jr z, .fski 
8fbd			;	ld a, 1 
8fbd			;	call aDelayInMS 
8fbd			 
8fbd				; do a brief pause 
8fbd			;	push bc 
8fbd			;.flo:	 
8fbd			;    and     255  	; 7 
8fbd			;    dec     bc      	; 6 
