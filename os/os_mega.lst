00fc cd 6b 0a			call delay1s  
00ff			if display_cols == 20	  
00ff			            LD   A, display_row_3+2  
00ff			else  
00ff 3e 5c		            LD   A, display_row_3+12  
0101			endif  
0101 11 88 18			ld de, prom_bootmsg1  
0104 cd 3e 0b			call str_at_display  
0107			; display debug level  
