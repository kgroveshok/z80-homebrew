678e			; handle the auto run of code from files in storage 
678e			 
678e			 
678e			include "forth_startup.asm" 
678e			; Which startup method to use? 
678e			; 
678e			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
678e			; followed by loading of a list of scripts in eeprom 
678e			 
678e			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
678e			; from eeprom 
678e			 
678e			; Select with define in main stubs 
678e			 
678e			if STARTUP_V1 
678e				include "forth_startupv1.asm" 
678e			endif 
678e			if STARTUP_V2 
678e				include "forth_startupv2.asm" 
678e			; Version 2 of the startup  
678e			;  
678e			; Auto load any files in bank 1 that start with a '*' 
678e			; If no se storage then revert to using eprom 
678e			 
678e			 
678e			if STORAGE_SE = 0 
678e			 
678e			sprompt1: db "Startup load...",0 
678e			sprompt2: db "Run? 1=No *=End #=All",0 
678e			 
678e			 
678e			 
678e			 
678e			forth_startup: 
678e				ld hl, startcmds 
678e				ld a, 0 
678e				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
678e			 
678e			.start1:	push hl 
678e				call clear_display 
678e				ld de, sprompt1 
678e			        ld a, display_row_1 
678e				call str_at_display 
678e				ld de, sprompt2 
678e			        ld a, display_row_2 
678e				call str_at_display 
678e				pop hl 
678e				push hl 
678e				ld e,(hl) 
678e				inc hl 
678e				ld d,(hl) 
678e			        ld a, display_row_3 
678e				call str_at_display 
678e				call update_display 
678e			 
678e			 
678e				ld a, (os_last_cmd) 
678e			;	cp 0 
678e				or a 
678e				jr z, .startprompt 
678e				call delay250ms 
678e				jr .startdo 
678e				 
678e				 
678e			 
678e			.startprompt: 
678e			 
678e				ld a,display_row_4 + display_cols - 1 
678e			        ld de, endprg 
678e				call str_at_display 
678e				call update_display 
678e				call delay1s 
678e				call cin_wait 
678e						 
678e				cp '*' 
678e				jr z, .startupend1 
678e				cp '#' 
678e				jr nz, .startno 
678e				ld a, 1 
678e				ld (os_last_cmd),a 
678e				jr .startdo 
678e			.startno:	cp '1' 
678e				jr z,.startnxt  
678e			 
678e				; exec startup line 
678e			.startdo:	 
678e				pop hl 
678e				push hl 
678e				 
678e				ld e,(hl) 
678e				inc hl 
678e				ld d,(hl) 
678e				ex de,hl 
678e			 
678e				push hl 
678e			 
678e				ld a, 0 
678e				;ld a, FORTH_END_BUFFER 
678e				call strlent 
678e				inc hl   ; include zero term to copy 
678e				ld b,0 
678e				ld c,l 
678e				pop hl 
678e				ld de, scratch 
678e				ldir 
678e			 
678e			 
678e				ld hl, scratch 
678e				call forthparse 
678e				call forthexec 
678e				call forthexec_cleanup 
678e			 
678e				ld a, display_row_4 
678e				ld de, endprog 
678e			 
678e				call update_display		 
678e			 
678e				ld a, (os_last_cmd) 
678e			;	cp 0 
678e				or a 
678e				jr nz, .startnxt 
678e				call next_page_prompt 
678e			        call clear_display 
678e				call update_display		 
678e			 
678e				; move onto next startup line? 
678e			.startnxt: 
678e			 
678e				call delay250ms 
678e				pop hl 
678e			 
678e				inc hl 
678e				inc hl 
678e			 
678e				push hl 
678e				ld e, (hl) 
678e				inc hl 
678e				ld d, (hl) 
678e				pop hl 
678e				; TODO replace 0 test 
678e			 
678e				ex de, hl 
678e				call ishlzero 
678e			;	ld a,e 
678e			;	add d 
678e			;	cp 0    ; any left to do? 
678e				ex de, hl 
678e				jp nz, .start1 
678e				jr .startupend 
678e			 
678e			.startupend1: pop hl 
678e			.startupend: 
678e			 
678e				call clear_display 
678e				call update_display 
678e				ret 
678e			endif 
