89a4			; Multiply 8-bit value with a 16-bit value (unrolled) 
89a4			; In: Multiply A with DE 
89a4			; Out: HL = result 
89a4			; 
89a4			Mult12U: 
89a4 2e 00		    ld l,0 
89a6 87			    add a,a 
89a7 30 01		    jr nc,Mult12U_NoAdd0 
89a9 19			    add hl,de 
89aa			Mult12U_NoAdd0: 
89aa 29			    add hl,hl 
89ab 87			    add a,a 
89ac 30 01		    jr nc,Mult12U_NoAdd1 
89ae 19			    add hl,de 
89af			Mult12U_NoAdd1: 
89af 29			    add hl,hl 
89b0 87			    add a,a 
89b1 30 01		    jr nc,Mult12U_NoAdd2 
89b3 19			    add hl,de 
89b4			Mult12U_NoAdd2: 
89b4 29			    add hl,hl 
89b5 87			    add a,a 
89b6 30 01		    jr nc,Mult12U_NoAdd3 
89b8 19			    add hl,de 
89b9			Mult12U_NoAdd3: 
89b9 29			    add hl,hl 
89ba 87			    add a,a 
89bb 30 01		    jr nc,Mult12U_NoAdd4 
89bd 19			    add hl,de 
89be			Mult12U_NoAdd4: 
89be 29			    add hl,hl 
89bf 87			    add a,a 
89c0 30 01		    jr nc,Mult12U_NoAdd5 
89c2 19			    add hl,de 
89c3			Mult12U_NoAdd5: 
89c3 29			    add hl,hl 
89c4 87			    add a,a 
89c5 30 01		    jr nc,Mult12U_NoAdd6 
89c7 19			    add hl,de 
89c8			Mult12U_NoAdd6: 
89c8 29			    add hl,hl 
89c9 87			    add a,a 
89ca d0			    ret nc 
89cb 19			    add hl,de 
89cc c9			    ret 
89cd			 
89cd			; 
89cd			; Multiply 8-bit value with a 16-bit value (right rotating) 
89cd			; In: Multiply A with DE 
89cd			;      Put lowest value in A for most efficient calculation 
89cd			; Out: HL = result 
89cd			; 
89cd			Mult12R: 
89cd 21 00 00		    ld hl,0 
89d0			Mult12R_Loop: 
89d0 cb 3f		    srl a 
89d2 30 01		    jr nc,Mult12R_NoAdd 
89d4 19			    add hl,de 
89d5			Mult12R_NoAdd: 
89d5 cb 23		    sla e 
89d7 cb 12		    rl d 
89d9 b7			    or a 
89da c2 d0 89		    jp nz,Mult12R_Loop 
89dd c9			    ret 
