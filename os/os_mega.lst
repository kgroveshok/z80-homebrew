1123			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
1123			 
1123			;moved to firmware.asm 
1123			;heap_start        .equ  0x9000      ; Starting address of heap 
1123			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
1123			 
1123			;      .org 0 
1123			;      jp    main 
1123			 
1123			 
1123			;      .org  0x100 
1123			;main: 
1123			;      ld    HL, 0x8100 
1123			;      ld    SP, HL 
1123			; 
1123			;      call  heap_init 
1123			; 
1123			;      ; Make some allocations 
1123			;      ld    HL, 12 
1123			;      call  malloc            ; Allocates 0x9004 
1123			; 
1123			;      ld    HL, 12 
1123			;      call  malloc            ; Allocates 0x9014 
1123			; 
1123			;      ld    HL, 12 
1123			;      call  malloc            ; Allocates 0x9024 
1123			; 
1123			;      ; Free some allocations 
1123			;      ld    HL, 0x9014 
1123			;      call  free 
1123			; 
1123			;      ld    HL, 0x9004 
1123			;      call  free 
1123			; 
1123			;      ld    HL, 0x9024 
1123			;      call  free 
1123			; 
1123			; 
1123			;      halt 
