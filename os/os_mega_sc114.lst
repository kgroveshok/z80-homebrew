8053			STORE_DEVICE_MAXBLOCKS:  equ  255*2 ; how many blocks are there on this storage device  
8053			;endif  
8053			  
8053			; Block 0 at offset $3b is a flag to decide to offer auto start up - 0 = prompt 1-auto run no prompt 2 - dont run  
8053			  
8053			STORE_0_AUTORUN: equ $20  
8053			  
8053			; Block 0 at offset $20+ holds the file number to run at system startup after the display  
8053			  
8053			STORE_0_AUTOFILE: equ $21  
8053			STORE_0_BANKRUN: equ $23  
8053			STORE_0_FILERUN: equ $24  
8053			STORE_0_BANKRUNN: equ $25   ; human readable bank id  
8053			  
8053			; Block 0 offsets for settings  
8053			  
8053			; if set then skip prompt for start up and accept all  
8053			  
8053			STORE_0_QUICKSTART: equ $25  
