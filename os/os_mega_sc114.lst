8ee5			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8ee5			      ; address of the block itself. 
8ee5 eb			      ex    DE, HL 
8ee6 11 fc ff		      ld    DE, -4 
8ee9 19			      add   HL, DE 
