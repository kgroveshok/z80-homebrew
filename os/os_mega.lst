4b82					push af  
4b82					ld a, (.dmark)  
4b82					ld (debug_mark),a  
4b82					ld a, (.dmark+1)  
4b82					ld (debug_mark+1),a  
4b82					ld a, (.dmark+2)  
4b82					ld (debug_mark+2),a  
4b82				endif  
4b82 18 04			jr .pastdmark  
4b84 ..			.dmark: db "REA"  
4b87				if DEMARK_VERSION = 1  
4b87 00					db 0  
4b88				endif  
4b88				if DEMARK_VERSION = 1  
