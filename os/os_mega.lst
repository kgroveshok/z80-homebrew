6930			; **********************************************************************  
6930			; **  LCD support functions  
6930			; **********************************************************************  
6930			  
6930			; Initialise alphanumeric LCD module  
6930			; LCD control register codes:  
6930			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6930			;   N    0 = 1-line mode       1 = 2-line mode  
6930			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6930			;   D    0 = Display off       1 = Display on  
6930			;   C    0 = Cursor off        1 = Cursor on  
6930			;   B    0 = Blinking off      1 = Blinking on  
6930			;   ID   0 = Decrement mode    1 = Increment mode  
6930			;   SH   0 = Entire shift off  1 = Entire shift on  
6930 3e 28		fLCD_Init:  LD   A, 40  
6932 cd 57 6a		            CALL LCDDelay       ;Delay 40ms after power up  
6935			; For reliable reset set 8-bit mode - 3 times  
6935 cd 27 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
6938 cd 27 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
693b cd 27 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
693e			; Set 4-bit mode  
693e cd 23 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
6941 cd 55 6a		            CALL LCDDelay1      ;Delay 37 us or more  
6944			; Function set  
6944 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6946 cd 59 69		            CALL fLCD_Inst      ;2 line, display on  
6949			; Display On/Off control  
6949 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
694b cd 59 69		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
694e			; Display Clear  
694e 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6950 cd 59 69		            CALL fLCD_Inst      ;Clear display  
6953			; Entry mode  
6953 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6955 cd 59 69		            CALL fLCD_Inst      ;Increment mode, shift off  
6958			; Display module now initialised  
6958 c9			            RET  
6959			; ok to here  
6959			  
6959			; Write instruction to LCD  
6959			;   On entry: A = Instruction byte to be written  
6959			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6959 f5			fLCD_Inst:  PUSH AF  
695a f5			            PUSH AF  
695b cd 6d 69		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
695e f1			            POP  AF  
695f 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6960 17			            RLA  
6961 17			            RLA  
6962 17			            RLA  
6963 cd 6d 69		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6966 3e 02		            LD   A, 2  
6968 cd 57 6a		            CALL LCDDelay       ;Delay 2 ms to complete   
696b f1			            POP  AF  
696c c9			            RET  
696d			Wr4bits:   
696d f5					push af  
696e 3a fb fa				ld a, (display_lcde1e2)  
6971 fe 00				cp 0     ; e  
6973 20 10				jr nz, .wea2	  
6975 f1					pop af  
6976 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6978 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
697a cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
697c cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
697e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6980 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6982 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6984 c9			            RET  
6985 f1			.wea2:		pop af  
6986 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6988 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
698a cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
698c cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
698e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6990 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6992 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6994 c9			            RET  
6995			  
6995			  
6995			; Write data to LCD  
6995			;   On entry: A = Data byte to be written  
6995			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6995 f5			fLCD_Data:  PUSH AF  
6996 f5			            PUSH AF  
6997 cd a9 69		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
699a f1			            POP  AF  
699b 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
699c 17			            RLA  
699d 17			            RLA  
699e 17			            RLA  
699f cd a9 69		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
69a2 3e 96		            LD   A, 150  
69a4 3d			Wait:      DEC  A              ;Wait a while to allow data   
69a5 20 fd		            JR   NZ, Wait      ;  write to complete  
69a7 f1			            POP  AF  
69a8 c9			            RET  
69a9			Wr4bitsa:     
69a9 f5					push af  
69aa 3a fb fa				ld a, (display_lcde1e2)  
69ad fe 00				cp 0     ; e1  
69af 20 16				jr nz, .we2	  
69b1 f1					pop af  
69b2 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
69b4 cb d7		            SET  kLCDBitRS, A  
69b6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
69b8 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
69ba cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
69bc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
69be cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
69c0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
69c2 cb 97		            RES  kLCDBitRS, A  
69c4 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69c6 c9			            RET  
69c7 f1			.we2:		pop af  
69c8 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
69ca cb d7		            SET  kLCDBitRS, A  
69cc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
69ce cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
69d0 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
69d2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
69d4 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
69d6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
69d8 cb 97		            RES  kLCDBitRS, A  
69da d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69dc c9			            RET  
69dd			  
69dd			  
69dd			; Position cursor to specified location  
69dd			;   On entry: A = Cursor position  
69dd			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
69dd f5			fLCD_Pos:   PUSH AF  
69de					; at this point set the E1 or E2 flag depending on position  
69de			  
69de c5					push bc  
69df			;		push af  
69df 06 00				ld b, 0  
69e1 4f					ld c, a  
69e2 3e 4f				ld a, kLCD_Line3-1  
69e4 b7			 		or a      ;clear carry flag  
69e5 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
69e6 38 04				jr c, .pe1  
69e8			  
69e8					; E selection  
69e8 cb 80				res 0, b         ; bit 0 unset e  
69ea			;		pop af    ; before line 3 so recover orig pos  
69ea			;		ld c, a    ; save for poking back  
69ea 18 06				jr .peset	          
69ec			.pe1:          	; E2 selection  
69ec cb c0				set 0, b         ; bit 0 set e1  
69ee 79					ld a, c  
69ef de 4f				sbc a, kLCD_Line3-1  
69f1 4f					ld c, a	         ; save caculated offset  
69f2			;		pop af     ; bin this original value now we have calculated form  
69f2			  
69f2			.peset:		; set bit  
69f2 78					ld a, b  
69f3 32 fb fa				ld (display_lcde1e2), a 	  
69f6 79					ld a, c  
69f7 c1					pop bc  
69f8			  
69f8 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
69fa cd 59 69		            CALL fLCD_Inst      ;Write instruction to LCD  
69fd f1			            POP  AF  
69fe c9			            RET  
69ff			  
69ff			  
69ff			; Output text string to LCD  
69ff			;   On entry: DE = Pointer to null terminated text string  
69ff			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
69ff 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6a00 b7			            OR   A              ;Null terminator?  
6a01 c8			            RET  Z              ;Yes, so finished  
6a02 cd 95 69		            CALL fLCD_Data      ;Write character to display  
6a05 13			            INC  DE             ;Point to next character  
6a06 18 f7		            JR   fLCD_Str       ;Repeat  
6a08 c9					ret  
6a09			  
6a09			; Define custom character  
6a09			;   On entry: A = Character number (0 to 7)  
6a09			;             DE = Pointer to character bitmap data  
6a09			;   On exit:  A = Next character number  
6a09			;             DE = Next location following bitmap  
6a09			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6a09			; Character is   
6a09 c5			fLCD_Def:   PUSH BC  
6a0a f5			            PUSH AF  
6a0b 07			            RLCA                ;Calculate location  
6a0c 07			            RLCA                ;  for bitmap data  
6a0d 07			            RLCA                ;  = 8 x CharacterNumber  
6a0e f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6a10 cd 59 69		            CALL fLCD_Inst      ;Write instruction to LCD  
6a13 06 00		            LD   B, 0  
6a15 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6a16 cd 95 69		            CALL fLCD_Data      ;Write byte to display  
6a19 13			            INC  DE             ;Point to next byte  
6a1a 04			            INC  B              ;Count bytes  
6a1b cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6a1d 28 f6		            JR   Z, Loop       ;No, so repeat  
6a1f f1			            POP  AF  
6a20 3c			            INC  A              ;Increment character number  
6a21 c1			            POP  BC  
6a22 c9			            RET  
