00cc			  
00cc				if MALLOC_1  
00cc cd 63 11				call  heap_init  
00cf				endif  
00cf				if MALLOC_4  
00cf					call  heap_init  
00cf				endif  
00cf			  
00cf				; init sound hardware if present  
00cf			  
00cf				if SOUND_ENABLE  
00cf cd e9 15				call sound_init  
00d2				endif  
00d2			  
00d2				; lcd test sequence  
00d2					  
00d2 cd ad 0b			call update_display  
00d5 cd b4 0a			call delay1s  
00d8 3e 2b			ld a,'+'  
00da cd 7a 0b			call fill_display  
00dd cd ad 0b			call update_display  
00e0 cd b4 0a			call delay1s  
00e3 3e 2a			ld a,'*'  
00e5 cd 7a 0b			call fill_display  
00e8 cd ad 0b			call update_display  
00eb cd b4 0a			call delay1s  
00ee 3e 2d			ld a,'-'  
00f0 cd 7a 0b			call fill_display  
00f3 cd ad 0b			call update_display  
00f6 cd b4 0a			call delay1s  
00f9			  
00f9			; boot splash screen  
00f9			if display_cols == 20	  
00f9			        ld a, display_row_1    
00f9			else  
00f9 3e 0a		        ld a, display_row_1 +10   
00fb			endif  
00fb 11 ee 1b			ld de, prom_bootmsg  
00fe cd 87 0b			call str_at_display  
0101 cd ad 0b			call update_display  
0104			  
0104			  
0104 cd b4 0a			call delay1s  
0107 cd b4 0a			call delay1s  
010a			if display_cols == 20	  
010a			            LD   A, display_row_3+2  
010a			else  
010a 3e 5c		            LD   A, display_row_3+12  
010c			endif  
010c 11 03 1c			ld de, prom_bootmsg1  
010f cd 87 0b			call str_at_display  
0112			; display debug level  
0112 3e 78		            LD   A, display_row_4  
0114 11 03 00			ld de, debuglevel  
0117 cd 87 0b			call str_at_display  
011a			  
011a cd ad 0b			call update_display  
011d cd b4 0a			call delay1s  
0120 cd b4 0a			call delay1s  
0123			  
0123			;	ld a, display_row_4+3  
