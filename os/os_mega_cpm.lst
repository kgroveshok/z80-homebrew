0da3 07			       rlca          ;4*8        32 
0da4 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0da6 19			         add hl,de   ;--         -- 
0da7 10 f9		       djnz $-5      ;13*7+8     99 
0da9 c9			ret 
