0fa1			malloc_guard_zerolen: 
0fa1				push hl 
0fa1				push de 
0fa1				push af 
0fa1			 
0fa1				ld de, 0 
0fa1			        call cmp16 
0fa1				jr nz, .lowalloz 
0fa1			 
0fa1				push hl 
0fa1				push de 
0fa1					ld hl, display_fb0 
0fa1					ld (display_fb_active), hl 
0fa1				call clear_display 
0fa1				ld a, 0 
0fa1				ld de, .malloczero 
0fa1				call str_at_display 
0fa1				call update_display 
0fa1				call delay1s 
0fa1				call delay1s 
0fa1				call bp_on 
0fa1			;	ld a, 0 
0fa1			;	ld (os_view_disable), a 
0fa1			 
0fa1				pop de 
0fa1				pop hl 
0fa1			 
0fa1				 
0fa1			 
0fa1				CALLMONITOR 
0fa1			.lowalloz: 
0fa1			 
0fa1			 
0fa1				pop af 
0fa1				pop de 
0fa1				pop hl 
0fa1			ret 
0fa1			 
0fa1			malloc_guard_entry: 
0fa1				push hl 
0fa1				push de 
0fa1				push af 
0fa1			 
0fa1			 	or a      ;clear carry flag 
0fa1				push hl 
0fa1				ld de, 255 
0fa1				sbc hl, de 
0fa1				jr c, .lowalloc 
0fa1			 
0fa1				push de 
0fa1					ld hl, display_fb0 
0fa1					ld (display_fb_active), hl 
0fa1				call clear_display 
0fa1				ld a, 0 
0fa1				ld de, .mallocsize 
0fa1				call str_at_display 
0fa1				call update_display 
0fa1				call delay1s 
0fa1				call delay1s 
0fa1			;	ld a, 0 
0fa1			;	ld (os_view_disable), a 
0fa1				call bp_on 
0fa1			 
0fa1				pop de 
0fa1				pop hl 
0fa1			 
0fa1				 
0fa1			 
0fa1				CALLMONITOR 
0fa1				jr .lowdone 
0fa1			.lowalloc: 
0fa1			 
0fa1			 
0fa1				pop hl 
0fa1			.lowdone:	pop af 
0fa1				pop de 
0fa1				pop hl 
0fa1			ret 
0fa1			 
0fa1			malloc_guard_exit: 
0fa1				push hl 
0fa1				push de 
0fa1				push af 
0fa1			 
0fa1			 	or a      ;clear carry flag 
0fa1				push hl 
0fa1				ld de, 255 
0fa1				sbc hl, de 
0fa1				jr c, .lowallocx 
0fa1			 
0fa1				push de 
0fa1					ld hl, display_fb0 
0fa1					ld (display_fb_active), hl 
0fa1				call clear_display 
0fa1				ld a, 0 
0fa1				ld de, .mallocasize 
0fa1				call str_at_display 
0fa1				call update_display 
0fa1				call delay1s 
0fa1				call delay1s 
0fa1			;	ld a, 0 
0fa1			;	ld (os_view_disable), a 
0fa1				call bp_on 
0fa1				pop de 
0fa1				pop hl 
0fa1			 
0fa1				CALLMONITOR 
0fa1				jr .lowdonex 
0fa1			.lowallocx: 
0fa1			 
