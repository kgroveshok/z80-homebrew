5ac0				call str_at_display 
5ac0				ld a, display_row_3+15 
5ac0				ld de, sprompt4 
5ac0				call str_at_display 
5ac0			 
5ac0				call update_display 
5ac0			 
5ac0				call cin_wait 
5ac0				cp 'n' 
5ac0				ret z 
5ac0				cp 'N' 
5ac0				ret z 
5ac0			 
5ac0				call delay1s 
5ac0			 
5ac0				ld a, (store_page+2) 
5ac0				ld (store_openmaxext), a    ; save count of ext 
5ac0				ld a, 1  
5ac0				ld (store_openext), a    ; save count of ext 
5ac0			 
5ac0			.autof:  
