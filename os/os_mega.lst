224d			user_word_eol:  
224d				; hl contains the pointer to where to create a linked list item from the end 
224d				; of the user dict to continue on at the system word dict 
224d				 
224d				; poke the stub of the word list linked list to repoint to rom words 
224d			 
224d				; stub format 
224d				; db   word id 
224d				; dw    link to next word 
224d			        ; db char length of token 
224d				; db string + 0 term 
224d				; db exec code....  
224d			 
224d			;	ld a, WORD_SYS_ROOT     ; root word 
224d 36 00			ld (hl), WORD_SYS_ROOT		; word id 
224f 23				inc hl 
2250			 
2250 11 f9 23			ld de, sysdict 
2253 73				ld (hl), e		; next word link ie system dict 
2254 23				inc hl 
2255 72				ld (hl), d		; next word link ie system dict 
2256 23				inc hl	 
2257			 
2257			;	ld (hl), sysdict		; next word link ie system dict 
2257			;	inc hl 
2257			;	inc hl 
2257			 
2257			;	inc hl 
2257			;	inc hl 
2257			 
2257			;	ld a, 2			; word length is 0 
2257 36 02			ld (hl), 2 
2259 23				inc hl 
225a			 
225a			;	ld a, '~'			; word length is 0 
225a 36 7e			ld (hl), '~' 
225c 23				inc hl 
225d			;	ld a, 0			; save empty word 
225d 36 00			ld (hl), 0 
225f			 
225f c9				ret 
