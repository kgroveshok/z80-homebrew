10fe			StrictStrCmp: 
10fe				; Load next chars of each string 
10fe 1a				ld a, (de) 
10ff 47				ld b, a 
1100 7e				ld a, (hl) 
1101				; Compare 
1101 b8				cp b 
1102				; Return non-zero if chars don't match 
1102 c0				ret nz 
1103				; Check for end of both strings 
1103 fe 00			cp "\0" 
1105				; Return if strings have ended 
1105 c8				ret z 
1106				; Otherwise, advance to next chars 
1106 23				inc hl 
1107 13				inc de 
1108 18 f4			jr StrictStrCmp 
110a			 
