d60c			 
d60c			kLCDWidth:  EQU display_cols             ;Width in characters 
d60c			kLCD_Line1: EQU 0x00  
d60c			kLCD_Line2: EQU kLCD_Line1+kLCDWidth 
d60c			; E1 
d60c			kLCD_Line3: EQU kLCD_Line2+kLCDWidth 
d60c			kLCD_Line4: EQU kLCD_Line3+kLCDWidth  
