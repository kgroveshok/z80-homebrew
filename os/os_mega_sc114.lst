990b cd 82 dd				call check_stacks 
990e				endif 
990e e5				push hl 
990f d5				push de 
9910 eb				ex de,hl 
9911 2a e5 e9			ld hl,(cli_ret_sp) 
9914 23				inc hl 
9915 23				inc hl 
9916 22 e5 e9			ld (cli_ret_sp),hl 
9919 73				ld (hl), e 
991a 23				inc hl 
991b 72				ld (hl), d 
991c d1				pop de 
991d e1				pop hl 
991e				if DEBUG_FORTH_STACK_GUARD 
991e cd 82 dd				call check_stacks 
9921				endif 
9921 c9				ret 
9922			 
9922			; get current ret stack pointer and save to hl  
9922				 
9922			FORTH_RSP_TOS: macro 
9922				call macro_forth_rsp_tos 
9922				endm 
9922			 
9922			macro_forth_rsp_tos: 
9922				;push de 
9922 2a e5 e9			ld hl,(cli_ret_sp) 
9925 cd 5a 99			call loadhlptrtohl 
9928				;ld e, (hl) 
9928				;inc hl 
9928				;ld d, (hl) 
9928				;ex de, hl 
9928					if DEBUG_FORTH_WORDS 
9928			;			DMARK "RST" 
9928						CALLMONITOR 
9928				if BASE_CPM=1  
9928					call debug_vector  
