bfe0					ld a, (.dmark+2)  
bfe0					ld (debug_mark+2),a  
bfe0				endif  
bfe0 18 04			jr .pastdmark  
bfe2 ..			.dmark: db "VAR"  
bfe5				if DEMARK_VERSION = 1  
bfe5 00					db 0  
bfe6				endif  
bfe6				if DEMARK_VERSION = 1  
bfe6 e1			.pastdmark: pop hl  
bfe7				endif  
