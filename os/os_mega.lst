6872 3e 28			ld a, kLCD_Line2  
6874 cd 66 69		            CALL fLCD_Pos       ;Position cursor to location in A  
6877 06 28			ld b, display_cols  
6879 ed 5b f9 fa		ld de, (display_write_tmp)  
687d cd b1 68			call write_len_string  
