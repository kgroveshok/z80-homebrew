4d4e					ld a, (.dmark+2)  
4d4e					ld (debug_mark+2),a  
4d4e				endif  
4d4e 18 04			jr .pastdmark  
4d50 ..			.dmark: db "VAR"  
4d53				if DEMARK_VERSION = 1  
