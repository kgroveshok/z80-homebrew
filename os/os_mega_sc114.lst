8d26			; Decimal Signed Version 
8d26			 
8d26			; DispA 
8d26			; -------------------------------------------------------------- 
8d26			; Converts a signed integer value to a zero-terminated ASCII 
8d26			; string representative of that value (using radix 10). 
8d26			; -------------------------------------------------------------- 
8d26			; INPUTS: 
8d26			;     HL     Value to convert (two's complement integer). 
8d26			;     DE     Base address of string destination. (pointer). 
8d26			; -------------------------------------------------------------- 
8d26			; OUTPUTS: 
8d26			;     None 
8d26			; -------------------------------------------------------------- 
8d26			; REGISTERS/MEMORY DESTROYED 
8d26			; AF HL 
8d26			; -------------------------------------------------------------- 
8d26			 
8d26			;DispHLToASCII: 
8d26			;   push    de 
8d26			;   push    bc 
8d26			; 
8d26			;; Detect sign of HL. 
8d26			;    bit    7, h 
8d26			;    jr     z, ._DoConvert 
8d26			; 
8d26			;; HL is negative. Output '-' to string and negate HL. 
8d26			;    ld     a, '-' 
8d26			;    ld     (de), a 
8d26			;    inc    de 
8d26			; 
8d26			;; Negate HL (using two's complement) 
8d26			;    xor    a 
8d26			;    sub    l 
8d26			;    ld     l, a 
8d26			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
8d26			;    sbc    a, h 
8d26			;    ld     h, a 
8d26			; 
8d26			;; Convert HL to digit characters 
8d26			;._DoConvert: 
8d26			;    ld     b, 0     ; B will count character length of number 
8d26			;-   ld     a, 10 
8d26			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
8d26			;    push   af 
8d26			;    inc    b 
8d26			;    ld     a, h 
8d26			;    or     l 
8d26			;    jr     nz, - 
8d26			; 
8d26			;; Retrieve digits from stack 
8d26			;-   pop    af 
8d26			;    or     $30 
8d26			;    ld     (de), a 
8d26			;    inc    de 
8d26			;    djnz   - 
8d26			; 
8d26			;; Terminate string with NULL 
8d26			;    xor    a 
8d26			;    ld     (de), a 
8d26			; 
8d26			;    pop    bc 
8d26			;    pop    de 
8d26			;    ret 
8d26			 
8d26			;Comments 
8d26			; 
8d26			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
8d26			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
8d26			;    Note that the output string will not be fixed-width. 
8d26			; 
8d26			;Example Usage 
8d26			; 
8d26			;    ld    hl, -1004 
8d26			;    ld    de, OP1 
8d26			;    call  DispA 
8d26			;    ld    hl, OP1 
8d26			;    syscall  PutS 
8d26			 
