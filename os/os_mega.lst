658d 3e 00			ld a, kLCD_Line1  
658f cd 99 66		            CALL fLCD_Pos       ;Position cursor to location in A  
6592 06 28			ld b, display_cols  
6594 ed 5b f9 fa		ld de, (display_write_tmp)  
6598 cd e4 65			call write_len_string  
659b				  
659b				  
659b 2a f9 fa			ld hl, (display_write_tmp)  
659e 11 28 00			ld de, display_cols  
65a1 19				add hl,de  
65a2 22 f9 fa			ld (display_write_tmp),hl  
65a5			  
65a5				  
65a5 3e 28			ld a, kLCD_Line2  
65a7 cd 99 66		            CALL fLCD_Pos       ;Position cursor to location in A  
65aa 06 28			ld b, display_cols  
65ac ed 5b f9 fa		ld de, (display_write_tmp)  
65b0 cd e4 65			call write_len_string  
65b3				  
65b3 2a f9 fa			ld hl, (display_write_tmp)  
65b6 11 28 00			ld de, display_cols  
65b9 19				add hl,de  
65ba 22 f9 fa			ld (display_write_tmp),hl  
65bd			  
65bd				  
65bd 3e 50			ld a, kLCD_Line3  
65bf cd 99 66		            CALL fLCD_Pos       ;Position cursor to location in A  
65c2 06 28			ld b, display_cols  
65c4 ed 5b f9 fa		ld de, (display_write_tmp)  
65c8 cd e4 65			call write_len_string  
65cb				  
65cb 2a f9 fa			ld hl, (display_write_tmp)  
65ce 11 28 00			ld de, display_cols  
65d1 19				add hl,de  
65d2 22 f9 fa			ld (display_write_tmp),hl  
65d5			  
65d5				  
65d5 3e 78			ld a, kLCD_Line4  
65d7 cd 99 66		            CALL fLCD_Pos       ;Position cursor to location in A  
65da 06 28			ld b, display_cols  
65dc ed 5b f9 fa		ld de, (display_write_tmp)  
65e0 cd e4 65			call write_len_string  
65e3 c9					ret  
65e4				  
65e4				; write out a fixed length string given in b from de  
65e4			  
65e4 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
65e5 cd 51 66		            CALL fLCD_Data      ;Write character to display  
65e8 13				inc de  
65e9 10 f9			djnz write_len_string  
65eb c9				ret  
