8c6b			;                jr      nc, is_hex_2    ; No, continue 
8c6b			;                ccf                     ; Yes - clear carry and return 
8c6b			;                ret 
8c6b			;is_hex_2        scf                     ; Set carry 
8c6b			;                ret 
8c6b			; 
8c6b			; Convert a single character contained in A to upper case: 
8c6b			; 
8c6b fe 61		to_upper:        cp      'a'             ; Nothing to do if not lower case 
8c6d d8			                ret     c 
8c6e fe 7b		                cp      'z' + 1         ; > 'z'? 
8c70 d0			                ret     nc              ; Nothing to do, either 
8c71 e6 5f		                and     $5f             ; Convert to upper case 
8c73 c9			                ret 
