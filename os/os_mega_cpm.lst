14d4			include "firmware_595shiftreg.asm"  
14d4			; common code for handling a 595 shift reg out on whatever output port 
14d4			 
14d4			; port in c 
14d4			; byte in a 
14d4			 
14d4			 
14d4			shift_bit_data: equ 0 
14d4			shift_bit_clk: equ 1 
14d4			shift_bit_latch: equ 2 
14d4			 
14d4			 
14d4			; shift out a byte to the sound chip 
14d4			 
14d4			; A contains byte to send 
14d4			 
14d4			shift_byte: 
14d4			 
14d4 06 08			ld b, 8   ; 8 bits to shift 
14d6			 
14d6 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
14d8			 
14d8				; set data bit state 
14d8			 
14d8 cb 7f			bit 7, a 
14da				; high bit is set 
14da 28 02			jr z, .nb2 
14dc cb c2			set shift_bit_data, d 
14de			 
14de				; set latches state  
14de cb ca		.nb2:	set shift_bit_clk, d 
14e0 cb 92			res shift_bit_latch, d    ; latch is inverted 
14e2 ed 51			out (c), d 
14e4				 
14e4				; clock the bit out 
14e4 cb 8a			res shift_bit_clk, d 
14e6 ed 51			out (c), d 
14e8			 
14e8				; shift a left one bit and repeat 
14e8 17				rla 
14e9			 
14e9 10 eb			djnz .nb1 
14eb			 
14eb				; latch 
14eb cb d2			set shift_bit_latch, d 
14ed ed 51			out (c), d 
14ef					 
14ef			 
14ef				; set  
14ef c9				ret 
# End of file firmware_595shiftreg.asm
