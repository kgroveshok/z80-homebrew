9e5b			.NEW: 
9e5b			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
9e5b 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e5c 75 9e			dw .HEAP            
9e5e 04				db 3 + 1 
9e5f .. 00			db "NEW",0              
9e63				endm 
# End of macro CWHEAD
9e63			; | NEW ( -- ) Clears all user words and stack | DONE 
9e63				 
9e63				if MALLOC_4 
9e63					call  heap_init 
9e63				endif 
9e63				; reset uword pointers 
9e63 21 e6 d5			ld hl, baseram 
9e66 22 9a e5			ld (os_last_new_uword), hl 
9e69 cd af 9c			call user_word_eol 
9e6c				; clear stack 
9e6c cd c8 9c			call forth_warmstart 
9e6f				NEXTW 
9e6f cd 68 ee			call parse_vector 
9e72 c3 22 9d			jp macro_next 
9e75				endm 
# End of macro NEXTW
9e75			 
9e75			.HEAP: 
9e75			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9e75 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e76 a3 9e			dw .EXEC            
9e78 05				db 4 + 1 
9e79 .. 00			db "HEAP",0              
9e7e				endm 
# End of macro CWHEAD
9e7e			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9e7e			; | | u1 - Current number of bytes in the heap 
9e7e			; | | u2 - Remaining bytes left on the heap 
9e7e			; | |  
9e7e			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9e7e			 
9e7e			 
9e7e				if DEBUG_FORTH_WORDS_KEY 
9e7e					DMARK "HEP" 
9e7e				if DEMARK_VERSION = 1  
9e7e e5					push hl  
9e7f 21 87 9e				ld hl, .dmark  
9e82 22 60 ee				ld (debug_mark), hl  
9e85				endif  
9e85				if DEMARK_VERSION = 0  
9e85					push af  
9e85					ld a, (.dmark)  
9e85					ld (debug_mark),a  
9e85					ld a, (.dmark+1)  
9e85					ld (debug_mark+1),a  
9e85					ld a, (.dmark+2)  
9e85					ld (debug_mark+2),a  
9e85				endif  
9e85 18 04			jr .pastdmark  
9e87 ..			.dmark: db "HEP"  
9e8a				if DEMARK_VERSION = 1  
9e8a 00					db 0  
9e8b				endif  
9e8b				if DEMARK_VERSION = 1  
9e8b e1			.pastdmark: pop hl  
9e8c				endif  
9e8c				if DEMARK_VERSION = 0  
9e8c			.pastdmark: pop af  
9e8c				endif  
9e8c			endm  
# End of macro DMARK
9e8c					CALLMONITOR 
9e8c				if BASE_CPM=1  
9e8c					call debug_vector  
9e8c				endif  
9e8c				if BASE_KEV=1  
9e8c					rst 8  
9e8c				endif  
9e8c				endm  
# End of macro CALLMONITOR
9e8c				endif 
9e8c 2a f0 d5			ld hl, (free_list )      
9e8f 11 f5 d5			ld de, heap_start 
