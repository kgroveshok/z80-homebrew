126c			; Decimal Signed Version 
126c			 
126c			; DispA 
126c			; -------------------------------------------------------------- 
126c			; Converts a signed integer value to a zero-terminated ASCII 
126c			; string representative of that value (using radix 10). 
126c			; -------------------------------------------------------------- 
126c			; INPUTS: 
126c			;     HL     Value to convert (two's complement integer). 
126c			;     DE     Base address of string destination. (pointer). 
126c			; -------------------------------------------------------------- 
126c			; OUTPUTS: 
126c			;     None 
126c			; -------------------------------------------------------------- 
126c			; REGISTERS/MEMORY DESTROYED 
126c			; AF HL 
126c			; -------------------------------------------------------------- 
126c			 
126c			;DispHLToASCII: 
126c			;   push    de 
126c			;   push    bc 
126c			; 
126c			;; Detect sign of HL. 
126c			;    bit    7, h 
126c			;    jr     z, ._DoConvert 
126c			; 
126c			;; HL is negative. Output '-' to string and negate HL. 
126c			;    ld     a, '-' 
126c			;    ld     (de), a 
126c			;    inc    de 
126c			; 
126c			;; Negate HL (using two's complement) 
126c			;    xor    a 
126c			;    sub    l 
126c			;    ld     l, a 
126c			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
126c			;    sbc    a, h 
126c			;    ld     h, a 
126c			; 
126c			;; Convert HL to digit characters 
126c			;._DoConvert: 
126c			;    ld     b, 0     ; B will count character length of number 
126c			;-   ld     a, 10 
126c			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
126c			;    push   af 
126c			;    inc    b 
126c			;    ld     a, h 
126c			;    or     l 
126c			;    jr     nz, - 
126c			; 
126c			;; Retrieve digits from stack 
126c			;-   pop    af 
126c			;    or     $30 
126c			;    ld     (de), a 
126c			;    inc    de 
126c			;    djnz   - 
126c			; 
126c			;; Terminate string with NULL 
126c			;    xor    a 
126c			;    ld     (de), a 
126c			; 
126c			;    pop    bc 
126c			;    pop    de 
126c			;    ret 
126c			 
126c			;Comments 
126c			; 
126c			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
126c			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
126c			;    Note that the output string will not be fixed-width. 
126c			; 
126c			;Example Usage 
126c			; 
126c			;    ld    hl, -1004 
126c			;    ld    de, OP1 
126c			;    call  DispA 
126c			;    ld    hl, OP1 
126c			;    syscall  PutS 
126c			 
126c			 
126c			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
126c			 
126c			 
126c			;Converts an ASCII string to an unsigned 16-bit integer 
126c			;Quits when it reaches a non-decimal digit 
126c			 
126c			string_to_uint16: 
126c			atoui_16: 
126c			;Input: 
126c			;     DE points to the string 
126c			;Outputs: 
126c			;     HL is the result 
126c			;     A is the 8-bit value of the number 
126c			;     DE points to the byte after the number 
126c			;Destroys: 
126c			;     BC 
126c			;       if the string is non-empty, BC is HL/10 
126c			;Size:  24 bytes 
126c			;Speed: 42+d(104+{0,9}) 
126c			;       d is the number of digits in the number 
126c			;       max is 640 cycles for a 5 digit number 
126c			;Assuming no leading zeros: 
126c			;1 digit:  146cc 
126c			;2 digit:  250cc 
126c			;3 digit:  354cc or 363cc (avg: 354.126cc) 
126c			;4 digit:  458cc or 467cc (avg: 458.27cc) 
126c			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
126c			;avg: 544.81158447265625cc (544+13297/16384) 
126c			;=============================================================== 
126c 21 00 00		  ld hl,0 
126f			.u16a: 
126f 1a			  ld a,(de) 
1270 d6 30		  sub 30h 
1272 fe 0a		  cp 10 
1274 d0			  ret nc 
1275 13			  inc de 
1276 44			  ld b,h 
1277 4d			  ld c,l 
1278 29			  add hl,hl 
1279 29			  add hl,hl 
127a 09			  add hl,bc 
127b 29			  add hl,hl 
127c 85			  add a,l 
127d 6f			  ld l,a 
127e 30 ef		  jr nc,.u16a 
1280 24			  inc h 
1281 c3 6f 12		  jp .u16a 
