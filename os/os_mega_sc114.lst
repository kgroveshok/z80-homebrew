a7ba			; | SCRATCH ( u -- addr ) Pushes address of offset u to stack | DONE 
a7ba			; | | The scratch area provides 32 word array. Can be used as single byte or as a word by passing the offset on stack. Pushes the resulting address to stack.  
a7ba			; | | When used with the direct storage writing/malloc and the !@ or word versions it is possible to construct an expanded and flexible variable system 
a7ba			; | |  
a7ba			; | | e.g.    : score $00 scratch ; 
a7ba			; | |  
a7ba			; | | $00 score ! 
a7ba			; | | $01 score +! 
a7ba			; | |  
a7ba			; | | e.g.   : varword $0a scratch ;  
a7ba			; | | 
a7ba			; | | $8000 varword ! 
a7ba					if DEBUG_FORTH_WORDS_KEY 
a7ba						DMARK "SCR" 
a7ba				if DEMARK_VERSION = 1  
a7ba e5					push hl  
a7bb 21 c3 a7				ld hl, .dmark  
a7be 22 60 ee				ld (debug_mark), hl  
a7c1				endif  
a7c1				if DEMARK_VERSION = 0  
a7c1					push af  
a7c1					ld a, (.dmark)  
a7c1					ld (debug_mark),a  
a7c1					ld a, (.dmark+1)  
a7c1					ld (debug_mark+1),a  
a7c1					ld a, (.dmark+2)  
a7c1					ld (debug_mark+2),a  
a7c1				endif  
a7c1 18 04			jr .pastdmark  
a7c3 ..			.dmark: db "SCR"  
a7c6				if DEMARK_VERSION = 1  
a7c6 00					db 0  
a7c7				endif  
a7c7				if DEMARK_VERSION = 1  
a7c7 e1			.pastdmark: pop hl  
a7c8				endif  
a7c8				if DEMARK_VERSION = 0  
a7c8			.pastdmark: pop af  
a7c8				endif  
a7c8			endm  
# End of macro DMARK
a7c8						CALLMONITOR 
a7c8				if BASE_CPM=1  
a7c8					call debug_vector  
a7c8				endif  
a7c8				if BASE_KEV=1  
