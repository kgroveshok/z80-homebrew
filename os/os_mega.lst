7188				; check all stack words 
7188			 
7188 e5				push hl 
7189 d5				push de 
718a			 
718a			;	ld de,(chk_word) 
718a			;	ld hl, (chk_stund)	; stack points.... 
718a			;	if DEBUG_STK_FAULT 
718a			;		DMARK "FAa" 
718a			;		CALLMONITOR 
718a			;	endif 
718a			;	call cmp16 
718a			;	jp z, .chk_faulta 
718a			; 
718a			;	ld de, sfaultsu 
718a			;	jp .chk_fault 
718a			 
718a 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
718d ed 5b cb f0		ld de,(chk_word) 
7191				if DEBUG_STK_FAULT 
7191					DMARK "FAb" 
7191					CALLMONITOR 
7191				endif 
7191 cd 9b 0f			call cmp16 
7194 28 06			jr z, .chk_fault1 
7196 11 3a 72			ld de, sfaultso 
7199 c3 eb 71			jp .chk_fault 
719c			.chk_fault1:  
719c 2a 1a f9			ld hl, (chk_ret_und) 
719f ed 5b cb f0		ld de,(chk_word) 
71a3				if DEBUG_STK_FAULT 
71a3					DMARK "FAU" 
71a3					CALLMONITOR 
71a3				endif 
71a3 cd 9b 0f			call cmp16 
71a6 ca af 71			jp z, .chk_fault2 
71a9 11 4a 72			ld de, sfaultru 
71ac c3 eb 71			jp .chk_fault 
71af			.chk_fault2:  
71af 2a d8 f8			ld hl, (chk_ret_ovr) 
71b2 ed 5b cb f0		ld de,(chk_word) 
71b6				if DEBUG_STK_FAULT 
