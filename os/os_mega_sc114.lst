9da5			; op codes for forth keywords 
9da5			 
9da5			; Changing use of opcodes to flag is the word exists in compiled form or not.  
9da5			; This provides a means to compile uwords if required for higher performance 
9da5			; by avoiding the use of the keyword parser and just jumping directly to the code 
9da5			; Actually there is already a flag for if the code exists as binary thinking about it... 
9da5			 
9da5			 
9da5			 
9da5			 
9da5			 
9da5			; free to use code 0  
9da5				OPCODE_HEAP: equ  1 
9da5				OPCODE_EXEC: equ 2 
9da5				OPCODE_DUP: equ 3 
9da5				OPCODE_SWAP: equ 4 
9da5				OPCODE_COLN: equ 5 
9da5				OPCODE_SCOLN: equ 6 
9da5				OPCODE_DROP: equ 7 
