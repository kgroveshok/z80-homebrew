9c78			user_word_eol:  
9c78				; hl contains the pointer to where to create a linked list item from the end 
9c78				; of the user dict to continue on at the system word dict 
9c78				 
9c78				; poke the stub of the word list linked list to repoint to rom words 
9c78			 
9c78				; stub format 
9c78				; db   word id 
9c78				; dw    link to next word 
9c78			        ; db char length of token 
9c78				; db string + 0 term 
9c78				; db exec code....  
9c78			 
9c78			;	ld a, WORD_SYS_ROOT     ; root word 
9c78 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9c7a 23				inc hl 
9c7b			 
9c7b 11 24 9e			ld de, sysdict 
9c7e 73				ld (hl), e		; next word link ie system dict 
9c7f 23				inc hl 
9c80 72				ld (hl), d		; next word link ie system dict 
9c81 23				inc hl	 
9c82			 
9c82			;	ld (hl), sysdict		; next word link ie system dict 
9c82			;	inc hl 
9c82			;	inc hl 
9c82			 
9c82			;	inc hl 
9c82			;	inc hl 
9c82			 
9c82			;	ld a, 2			; word length is 0 
9c82 36 02			ld (hl), 2 
9c84 23				inc hl 
9c85			 
9c85			;	ld a, '~'			; word length is 0 
9c85 36 7e			ld (hl), '~' 
9c87 23				inc hl 
9c88			;	ld a, 0			; save empty word 
9c88 36 00			ld (hl), 0 
