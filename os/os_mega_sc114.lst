80e2			 
80e2			; persisent storage hardware abstraction layer  
80e2			 
80e2			 
80e2			 
80e2			; Block 0 on storage is a config state 
80e2			 
80e2			 
80e2			 
80e2			; TODO add read phy block and write phy block functions 
80e2			; TODO add presence check (i.e. read write byte 0 of block 0 for eeprom) 
80e2			 
80e2			; Abstraction layer  
80e2			 
80e2			; Logocial block size is same size as physical size - using tape concept 
80e2			 
80e2			;STORE_BLOCK_PHY2LOG: equ (STORE_BLOCK_LOG/STORE_BLOCK_PHY)       ; How many physical blocks make up a logical block 
80e2			;STORE_BLOCK_MAX: equ (STORE_BLOCK_PHY*STORE_DEVICE_MAXBLOCKS)/255    ; Max number of logical blocks on the device 
80e2			 
80e2			 
80e2			 
80e2			; Filesystem layout (Logical layout) 
80e2			; 
80e2			; Block 0 - Bank config  
80e2			; 
80e2			;      Byte - 0 file id counter 
80e2			;      Byte - 1-2 formated: Byte pattern: 0x80 x27 
80e2			;      Byte - 3-20 zero terminated bank label 
80e2			; 
80e2			; Block 1 > File storage 
80e2			; 
80e2			;      Byte 0 file id    - block 0 file details 
80e2			;      Byte 1 block id - block 0 is file  
80e2			;            Byte 2-15 - File name 
80e2			; 
80e2			;       - to end of block data 
80e2			; 
80e2			 
80e2			; Get ID for the file named in pointer held HL 
80e2			; Returns ID in HL = 255 if no file found 
80e2			 
80e2			storage_getid: 
80e2			 
80e2 22 66 ea			ld (store_tmp1), hl 
80e5			 
80e5				if DEBUG_STORESE 
80e5					DMARK "SGI" 
80e5				if DEMARK_VERSION = 1  
80e5 e5					push hl  
80e6 21 ee 80				ld hl, .dmark  
80e9 22 5e ee				ld (debug_mark), hl  
80ec				endif  
