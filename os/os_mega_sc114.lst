d573 11 49 d5			ld de, sprompt2 
d576 3e 28		        ld a, display_row_2 
d578 cd 22 88			call str_at_display 
d57b e1				pop hl 
d57c e5				push hl 
d57d 5e				ld e,(hl) 
d57e 23				inc hl 
d57f 56				ld d,(hl) 
d580 3e 50		        ld a, display_row_3 
d582 cd 22 88			call str_at_display 
d585 cd 48 88			call update_display 
d588			 
d588			 
d588 3a c8 e6			ld a, (os_last_cmd) 
d58b fe 00			cp 0 
