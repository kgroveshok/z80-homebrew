de3a			; Which startup method to use? 
de3a			; 
de3a			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
de3a			; followed by loading of a list of scripts in eeprom 
de3a			 
de3a			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
de3a			; from eeprom 
de3a			 
de3a			; Select with define in main stubs 
de3a			 
de3a			if STARTUP_V1 
de3a				include "forth_startupv1.asm" 
de3a			; Startup script loading version 1 
