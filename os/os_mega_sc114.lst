d5c5			key_init: 
d5c5				; init keyboard macro pointers 
d5c5 21 00 00			ld hl, 0 
d5c8 22 fe ee			ld (key_macroroot), hl 
d5cb 22 fc ee			ld (key_macrolast), hl 
d5ce				; no init as handled by the SCM bios 
