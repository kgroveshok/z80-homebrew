75f8				; write out a fixed length string given in b from de  
75f8			  
75f8 1a			write_len_string:   LD   A, (DE)        ;Get character from string  
75f9 cd 65 76		            CALL fLCD_Data      ;Write character to display  
75fc 13				inc de  
75fd 10 f9			djnz write_len_string  
75ff c9				ret  
