1dbb				if BASE_CPM=1 
1dbb cd 08 19				call forth_push_numhl 
1dbe				endif 
1dbe				if BASE_KEV=1 
1dbe					rst $20 
1dbe				endif 
1dbe				endm 
# End of macro FORTH_PUSH_VALUEHL
