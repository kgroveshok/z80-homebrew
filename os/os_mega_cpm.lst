1876			FORTH_CHK_DSP_UNDER: macro 
1876				push hl 
1876				push de 
1876				ld hl,(cli_data_sp) 
1876				ld de, cli_data_stack 
1876				call cmp16 
1876				jp c, fault_dsp_under 
1876				pop de 
1876				pop hl 
1876				endm 
1876			 
1876			 
1876			FORTH_CHK_RSP_UNDER: macro 
1876				push hl 
1876				push de 
1876				ld hl,(cli_ret_sp) 
1876				ld de, cli_ret_stack 
1876				call cmp16 
1876				jp c, fault_rsp_under 
1876				pop de 
1876				pop hl 
1876				endm 
1876			 
1876			FORTH_CHK_LOOP_UNDER: macro 
1876				push hl 
1876				push de 
1876				ld hl,(cli_loop_sp) 
1876				ld de, cli_loop_stack 
1876				call cmp16 
1876				jp c, fault_loop_under 
1876				pop de 
1876				pop hl 
1876				endm 
