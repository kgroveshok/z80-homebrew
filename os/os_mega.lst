655d			; stack over and underflow checks 
655d			 
655d			; init the words to detect the under/overflow 
655d			 
655d			chk_stk_init: 
655d				; a vague random number to check so we dont get any "lucky" hits 
655d 3e 2d			ld a, 45 
655f 6f				ld l, a 
6560 00				nop 
6561 3e 17			ld a, 23 
6563 67				ld h, a 
6564			 
6564 22 b4 f0			ld (chk_word), hl     ; the word we need to check against 
6567			 
6567			;	ld (chk_stund), hl	; stack points.... 
6567 22 3b fe			ld (chk_stovr), hl 
656a 22 03 f9			ld (chk_ret_und), hl 
