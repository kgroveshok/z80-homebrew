8dd3			StrictStrCmp: 
8dd3				; Load next chars of each string 
8dd3 1a				ld a, (de) 
8dd4 47				ld b, a 
8dd5 7e				ld a, (hl) 
8dd6				; Compare 
8dd6 b8				cp b 
8dd7				; Return non-zero if chars don't match 
8dd7 c0				ret nz 
8dd8				; Check for end of both strings 
8dd8 fe 00			cp "\0" 
8dda				; Return if strings have ended 
8dda c8				ret z 
8ddb				; Otherwise, advance to next chars 
8ddb 23				inc hl 
8ddc 13				inc de 
8ddd 18 f4			jr StrictStrCmp 
8ddf			 
8ddf			;end 
8ddf			; eof 
8ddf			 
