0ecd			 
0ecd			;Converts an ASCII string to an unsigned 16-bit integer 
0ecd			;Quits when it reaches a non-decimal digit 
0ecd			 
0ecd			string_to_uint16: 
0ecd			atoui_16: 
0ecd			;Input: 
0ecd			;     DE points to the string 
0ecd			;Outputs: 
0ecd			;     HL is the result 
0ecd			;     A is the 8-bit value of the number 
0ecd			;     DE points to the byte after the number 
0ecd			;Destroys: 
0ecd			;     BC 
0ecd			;       if the string is non-empty, BC is HL/10 
0ecd			;Size:  24 bytes 
0ecd			;Speed: 42+d(104+{0,9}) 
0ecd			;       d is the number of digits in the number 
0ecd			;       max is 640 cycles for a 5 digit number 
0ecd			;Assuming no leading zeros: 
0ecd			;1 digit:  146cc 
0ecd			;2 digit:  250cc 
0ecd			;3 digit:  354cc or 363cc (avg: 354.126cc) 
0ecd			;4 digit:  458cc or 467cc (avg: 458.27cc) 
0ecd			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
0ecd			;avg: 544.81158447265625cc (544+13297/16384) 
0ecd			;=============================================================== 
0ecd 21 00 00		  ld hl,0 
