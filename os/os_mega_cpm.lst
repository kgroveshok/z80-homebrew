4296				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
4296			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
4296			 
4296					if DEBUG_FORTH_WORDS_KEY 
4296						DMARK "SPo" 
4296						CALLMONITOR 
4296					endif 
4296					; get port 
4296			 
4296			 
4296					; get byte to send 
4296			 
4296					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4296			 
4296			;		push hl    ; u1  
4296			 
4296					; destroy value TOS 
4296			 
