9e53			; the core word dictionary v4 
9e53			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
9e53			 
9e53			; this is a linked list for each of the system words used 
9e53			; user defined words will follow the same format but will be in ram 
9e53			 
9e53			 
9e53			; 
9e53			; 
9e53			; define linked list: 
9e53			; 
9e53			; 1. compiled byte op code 
9e53			; 2. len of text word 
9e53			; 3. text word 
9e53			; 4. ptr to next dictionary word 
9e53			; 5. asm, calls etc for the word 
9e53			; 
9e53			;  if 1 == 0 then last word in dict  
9e53			;   
9e53			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
9e53			;  
9e53			;  
9e53			; create basic standard set of words 
9e53			; 
9e53			;  
9e53			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
9e53			; 2DUP 2DROP 2SWAP  
9e53			; @ C@ - get byte  
9e53			; ! C! - store byte 
9e53			; 0< true if less than zero 
9e53			; 0= true if zero 
9e53			; < >  
9e53			; = true if same 
9e53			; variables 
9e53			 
9e53			 
