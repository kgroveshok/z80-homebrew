7435 3e 78			ld a, kLCD_Line4  
7437 cd f9 74		            CALL fLCD_Pos       ;Position cursor to location in A  
743a 06 28			ld b, display_cols  
743c ed 5b f7 fa		ld de, (display_write_tmp)  
7440 cd 44 74			call write_len_string  
7443 c9					ret  
