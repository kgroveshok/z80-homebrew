9e24 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e25 3e 9e			dw .HEAP            
9e27 04				db 3 + 1 
9e28 .. 00			db "NEW",0              
9e2c				endm 
# End of macro CWHEAD
9e2c			; | NEW ( -- ) Clears all user words and stack | DONE 
9e2c				 
9e2c				if MALLOC_4 
9e2c					call  heap_init 
9e2c				endif 
9e2c				; reset uword pointers 
9e2c 21 cd d6			ld hl, baseram 
9e2f 22 9f e5			ld (os_last_new_uword), hl 
9e32 cd 78 9c			call user_word_eol 
9e35				; clear stack 
9e35 cd 91 9c			call forth_warmstart 
9e38				NEXTW 
9e38 cd 68 ee			call parse_vector 
9e3b c3 eb 9c			jp macro_next 
9e3e				endm 
# End of macro NEXTW
9e3e			 
9e3e			.HEAP: 
9e3e			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9e3e 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e3f 6c 9e			dw .EXEC            
9e41 05				db 4 + 1 
9e42 .. 00			db "HEAP",0              
9e47				endm 
# End of macro CWHEAD
9e47			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9e47			; | | u1 - Current number of bytes in the heap 
9e47			; | | u2 - Remaining bytes left on the heap 
9e47			; | |  
9e47			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9e47			 
9e47			 
9e47				if DEBUG_FORTH_WORDS_KEY 
9e47					DMARK "HEP" 
9e47				if DEMARK_VERSION = 1  
9e47 e5					push hl  
9e48 21 50 9e				ld hl, .dmark  
9e4b 22 60 ee				ld (debug_mark), hl  
9e4e				endif  
9e4e				if DEMARK_VERSION = 0  
9e4e					push af  
9e4e					ld a, (.dmark)  
9e4e					ld (debug_mark),a  
9e4e					ld a, (.dmark+1)  
9e4e					ld (debug_mark+1),a  
9e4e					ld a, (.dmark+2)  
9e4e					ld (debug_mark+2),a  
9e4e				endif  
9e4e 18 04			jr .pastdmark  
9e50 ..			.dmark: db "HEP"  
9e53				if DEMARK_VERSION = 1  
9e53 00					db 0  
9e54				endif  
9e54				if DEMARK_VERSION = 1  
9e54 e1			.pastdmark: pop hl  
9e55				endif  
9e55				if DEMARK_VERSION = 0  
9e55			.pastdmark: pop af  
9e55				endif  
9e55			endm  
# End of macro DMARK
