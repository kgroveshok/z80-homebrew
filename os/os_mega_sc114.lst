9a38			 
9a38			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
9a38			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
9a38			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
9a38			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
9a38			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
9a38			WORD_SYS_END: equ 0   ; Opcode for all user words 
9a38			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
9a38			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
9a38			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
9a38			 
9a38			; Core word preamble macro 
9a38			 
9a38			CWHEAD:   macro nxtword opcode lit len opflags 
9a38				db WORD_SYS_CORE+opcode             
9a38				; internal op code number 
9a38				dw nxtword            
9a38				; link to next dict word block 
9a38				db len + 1 
9a38				; literal length of dict word inc zero term 
9a38				db lit,0              
9a38				; literal dict word 
9a38			        ; TODO db opflags        
9a38				endm 
