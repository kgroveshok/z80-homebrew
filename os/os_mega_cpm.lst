0153			; Macro to make adding debug marks easier  
0153			  
0153			  
0153			  
0153			DMARK: macro str  
0153			  
0153				if DEMARK_VERSION = 1  
0153					push hl  
0153					ld hl, .dmark  
0153					ld (debug_mark), hl  
0153				endif  
0153			  
0153			  
0153				if DEMARK_VERSION = 0  
0153					push af  
0153					ld a, (.dmark)  
0153					ld (debug_mark),a  
0153					ld a, (.dmark+1)  
0153					ld (debug_mark+1),a  
0153					ld a, (.dmark+2)  
0153					ld (debug_mark+2),a  
0153			  
0153				endif  
0153			  
0153				jr .pastdmark  
0153			.dmark: db str  
0153			  
0153				if DEMARK_VERSION = 1  
0153					; add a terminator as this is printed direct  
0153					; other version stuffs into a buffer  
0153					db 0  
0153				endif  
0153			  
0153			; skip string  
0153			  
0153				if DEMARK_VERSION = 1  
0153			.pastdmark: pop hl  
0153				endif  
0153			  
0153				if DEMARK_VERSION = 0  
0153			.pastdmark: pop af  
0153				endif  
0153			  
0153			endm  
