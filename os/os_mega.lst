21d4			; | ## Core Words 
21d4			 
21d4			;if MALLOC_4 
21d4			 
21d4			.HEAP: 
21d4			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
21d4 15				db WORD_SYS_CORE+OPCODE_HEAP             
21d5 05 22			dw .EXEC            
21d7 05				db 4 + 1 
21d8 .. 00			db "HEAP",0              
21dd				endm 
# End of macro CWHEAD
21dd			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
21dd			; | | u1 - Current number of bytes in the heap 
21dd			; | | u2 - Remaining bytes left on the heap 
21dd			; | |  
21dd			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
21dd			 
21dd			 
21dd				if DEBUG_FORTH_WORDS_KEY 
21dd					DMARK "HEP" 
21dd				if DEMARK_VERSION = 1  
21dd e5					push hl  
21de 21 e6 21				ld hl, .dmark  
21e1 22 9b fd				ld (debug_mark), hl  
21e4				endif  
21e4				if DEMARK_VERSION = 0  
21e4					push af  
21e4					ld a, (.dmark)  
21e4					ld (debug_mark),a  
21e4					ld a, (.dmark+1)  
21e4					ld (debug_mark+1),a  
21e4					ld a, (.dmark+2)  
21e4					ld (debug_mark+2),a  
21e4				endif  
21e4 18 04			jr .pastdmark  
21e6 ..			.dmark: db "HEP"  
21e9				if DEMARK_VERSION = 1  
21e9 00					db 0  
21ea				endif  
21ea				if DEMARK_VERSION = 1  
21ea e1			.pastdmark: pop hl  
21eb				endif  
21eb				if DEMARK_VERSION = 0  
21eb			.pastdmark: pop af  
21eb				endif  
21eb			endm  
# End of macro DMARK
21eb					CALLMONITOR 
21eb				if BASE_CPM=1  
21eb					call debug_vector  
21eb				endif  
21eb				if BASE_KEV=1  
21eb cf					rst 8  
21ec				endif  
21ec				endm  
# End of macro CALLMONITOR
21ec				endif 
