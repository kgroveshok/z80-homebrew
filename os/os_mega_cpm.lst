10b0			free_find_higher_block: 
10b0 5e			      ld    E, (HL)                 ; Load next ptr from free block 
10b1 23			      inc   HL 
10b2 56			      ld    D, (HL) 
10b3 2b			      dec   HL 
10b4			 
10b4 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
10b7 dd 72 01		      ld    (IX+1), D 
10ba dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
10bd dd 74 03		      ld    (IX+3), H 
10c0			 
10c0 78			      ld    A, B                    ; Check if DE is greater than BC 
10c1 ba			      cp    D                       ; Compare MSB first 
10c2 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
10c4 30 04		      jr    NC, free_find_higher_block_skip 
10c6 79			      ld    A, C 
10c7 bb			      cp    E                       ; Then compare LSB 
10c8 38 08		      jr    C, free_found_higher_block 
10ca			 
10ca			free_find_higher_block_skip: 
10ca 7a			      ld    A, D                    ; Reached the end of the free list? 
10cb b3			      or    E 
10cc ca 4f 11		      jp    Z, free_done 
