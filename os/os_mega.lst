1030			; Decimal Signed Version 
1030			 
1030			; DispA 
1030			; -------------------------------------------------------------- 
1030			; Converts a signed integer value to a zero-terminated ASCII 
1030			; string representative of that value (using radix 10). 
1030			; -------------------------------------------------------------- 
1030			; INPUTS: 
1030			;     HL     Value to convert (two's complement integer). 
1030			;     DE     Base address of string destination. (pointer). 
1030			; -------------------------------------------------------------- 
1030			; OUTPUTS: 
1030			;     None 
1030			; -------------------------------------------------------------- 
1030			; REGISTERS/MEMORY DESTROYED 
1030			; AF HL 
1030			; -------------------------------------------------------------- 
1030			 
1030			;DispHLToASCII: 
1030			;   push    de 
1030			;   push    bc 
1030			; 
1030			;; Detect sign of HL. 
1030			;    bit    7, h 
1030			;    jr     z, ._DoConvert 
1030			; 
1030			;; HL is negative. Output '-' to string and negate HL. 
1030			;    ld     a, '-' 
1030			;    ld     (de), a 
1030			;    inc    de 
1030			; 
1030			;; Negate HL (using two's complement) 
1030			;    xor    a 
1030			;    sub    l 
1030			;    ld     l, a 
1030			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
1030			;    sbc    a, h 
1030			;    ld     h, a 
1030			; 
1030			;; Convert HL to digit characters 
1030			;._DoConvert: 
1030			;    ld     b, 0     ; B will count character length of number 
1030			;-   ld     a, 10 
1030			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
1030			;    push   af 
1030			;    inc    b 
1030			;    ld     a, h 
1030			;    or     l 
1030			;    jr     nz, - 
1030			; 
1030			;; Retrieve digits from stack 
1030			;-   pop    af 
1030			;    or     $30 
1030			;    ld     (de), a 
1030			;    inc    de 
1030			;    djnz   - 
1030			; 
1030			;; Terminate string with NULL 
1030			;    xor    a 
1030			;    ld     (de), a 
1030			; 
1030			;    pop    bc 
1030			;    pop    de 
1030			;    ret 
1030			 
1030			;Comments 
1030			; 
1030			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
1030			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
1030			;    Note that the output string will not be fixed-width. 
1030			; 
1030			;Example Usage 
1030			; 
1030			;    ld    hl, -1004 
1030			;    ld    de, OP1 
1030			;    call  DispA 
1030			;    ld    hl, OP1 
1030			;    syscall  PutS 
