bbce			    NEXTW 
bbce			 
bbce			.SPICEH: 
bbce				CWHEAD .SPIOb 61 "SPICEH" 6 WORD_FLAG_CODE 
bbce			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
bbce			 
bbce					call spi_ce_high 
bbce			    NEXTW 
bbce			 
bbce			 
bbce			.SPIOb: 
bbce			 
bbce				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
bbce			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
bbce			 
bbce					if DEBUG_FORTH_WORDS_KEY 
bbce						DMARK "SPo" 
bbce						CALLMONITOR 
bbce					endif 
bbce					; get port 
bbce			 
bbce			 
bbce					; get byte to send 
bbce			 
bbce					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bbce			 
bbce			;		push hl    ; u1  
bbce			 
bbce					; destroy value TOS 
bbce			 
bbce					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bbce			 
bbce					; one value on hl get other one back 
bbce			 
bbce			;		pop hl   ; u2 - addr 
bbce			 
bbce					; TODO Send SPI byte 
bbce			 
bbce			;		push hl 
bbce			;		call spi_ce_low 
bbce			;		pop hl 
bbce					ld a, l 
bbce					call spi_send_byte 
bbce			;		call spi_ce_high 
bbce			 
bbce					NEXTW 
bbce			 
bbce			.SPII: 
bbce				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bbce			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bbce					if DEBUG_FORTH_WORDS_KEY 
bbce						DMARK "SPi" 
bbce						CALLMONITOR 
bbce					endif 
bbce			 
bbce					; TODO Get SPI byte 
bbce			 
bbce					call spi_read_byte 
bbce			 
bbce					if DEBUG_FORTH_WORDS 
bbce						DMARK "Si2" 
bbce						CALLMONITOR 
bbce					endif 
bbce					ld h, 0 
bbce					ld l, a 
bbce					if DEBUG_FORTH_WORDS 
bbce						DMARK "Si3" 
bbce						CALLMONITOR 
bbce					endif 
bbce					;call forth_push_numhl 
bbce					FORTH_PUSH_VALUEHL 
bbce			 
bbce					NEXTW 
bbce			 
bbce			 
bbce			 
bbce			.SESEL: 
bbce				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bbce			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bbce			; | | Zero is disabled storage. 
bbce					if DEBUG_FORTH_WORDS_KEY 
bbce						DMARK "BN?" 
bbce						CALLMONITOR 
bbce					endif 
bbce					ld a, (spi_device_id) 
bbce					sub '0' 
bbce					ld h, 0 
bbce					ld l, a 
bbce					FORTH_PUSH_VALUEHL 
bbce					;call forth_push_numhl 
bbce					NEXTW 
bbce			.SESELS: 
bbce				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bbce			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bbce			; | | Set to zero to disable storage. 
bbce					if DEBUG_FORTH_WORDS_KEY 
bbce						DMARK "BNK" 
bbce						CALLMONITOR 
bbce					endif 
bbce			 
bbce					ld a, 255 
bbce					ld (spi_cartdev), a 
bbce			 
bbce					; get bank 
bbce			 
bbce					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bbce			 
bbce			;		push hl 
bbce			 
bbce					; destroy value TOS 
bbce			 
bbce					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bbce			 
bbce					; one value on hl get other one back 
bbce			 
bbce			;		pop hl 
bbce			 
bbce			 
bbce					ld c, SPI_CE_HIGH 
bbce					ld b, '0'    ; human readable bank number 
bbce			 
bbce					ld a, l 
bbce			 
bbce					if DEBUG_FORTH_WORDS 
bbce						DMARK "BNK" 
bbce						CALLMONITOR 
bbce					endif 
bbce			 
bbce					; active low 
bbce			 
bbce			;		cp 0 
bbce					or a 
bbce					jr z, .bset 
bbce					cp 1 
bbce					jr nz, .b2 
bbce					res 0, c 
bbce					ld b, '1'    ; human readable bank number 
bbce			.b2:		cp 2 
bbce					jr nz, .b3 
bbce					res 1, c 
bbce					ld b, '2'    ; human readable bank number 
bbce			.b3:		cp 3 
bbce					jr nz, .b4 
bbce					res 2, c 
bbce					ld b, '3'    ; human readable bank number 
bbce			.b4:		cp 4 
bbce					jr nz, .b5 
bbce					res 3, c 
bbce					ld b, '4'    ; human readable bank number 
bbce			.b5:		cp 5 
bbce					jr nz, .bset 
bbce					res 4, c 
bbce					ld b, '5'    ; human readable bank number 
bbce			 
bbce			.bset: 
bbce					ld a, c 
bbce					ld (spi_device),a 
bbce					ld a, b 
bbce					ld (spi_device_id),a 
bbce					if DEBUG_FORTH_WORDS 
bbce						DMARK "BN2" 
bbce						CALLMONITOR 
bbce					endif 
bbce			 
bbce					; set default SPI clk pulse time as disabled for BANK use 
bbce			 
bbce					ld a, 0 
bbce					ld (spi_clktime), a 
bbce			 
bbce					NEXTW 
bbce			 
bbce			.CARTDEV: 
bbce				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bbce			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bbce			; | | Set to zero to disable devices. 
bbce					if DEBUG_FORTH_WORDS_KEY 
bbce						DMARK "CDV" 
bbce						CALLMONITOR 
bbce					endif 
bbce			 
bbce					; disable se storage bank selection 
bbce			 
bbce					ld a, SPI_CE_HIGH		; ce high 
bbce					ld (spi_device), a 
bbce			 
bbce					; get bank 
bbce			 
bbce					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bbce			 
bbce			;		push hl 
bbce			 
bbce					; destroy value TOS 
bbce			 
bbce					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bbce			 
bbce					; one value on hl get other one back 
bbce			 
bbce			;		pop hl 
bbce			 
bbce					; active low 
bbce			 
bbce					ld c, 255 
bbce			 
bbce					ld a, l 
bbce					if DEBUG_FORTH_WORDS 
bbce						DMARK "CDV" 
bbce						CALLMONITOR 
bbce					endif 
bbce			;		cp 0 
bbce					or a 
bbce					jr z, .cset 
bbce					cp 1 
bbce					jr nz, .c2 
bbce					res 0, c 
bbce			.c2:		cp 2 
bbce					jr nz, .c3 
bbce					res 1, c 
bbce			.c3:		cp 3 
bbce					jr nz, .c4 
bbce					res 2, c 
bbce			.c4:		cp 4 
bbce					jr nz, .c5 
bbce					res 3, c 
bbce			.c5:		cp 5 
bbce					jr nz, .c6 
bbce					res 4, c 
bbce			.c6:		cp 6 
bbce					jr nz, .c7 
bbce					res 5, c 
bbce			.c7:		cp 7 
bbce					jr nz, .c8 
bbce					res 6, c 
bbce			.c8:		cp 8 
bbce					jr nz, .cset 
bbce					res 7, c 
bbce			.cset:		ld a, c 
bbce					ld (spi_cartdev),a 
bbce			 
bbce					if DEBUG_FORTH_WORDS 
bbce						DMARK "CD2" 
bbce						CALLMONITOR 
bbce					endif 
bbce			 
bbce					; set default SPI clk pulse time as 10ms for CARTDEV use 
bbce			 
bbce					ld a, $0a 
bbce					ld (spi_clktime), a 
bbce					NEXTW 
bbce			endif 
bbce			 
bbce			.ENDDEVICE: 
bbce			; eof 
bbce			 
