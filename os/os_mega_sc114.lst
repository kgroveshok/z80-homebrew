d461 11 37 d4			ld de, sprompt2 
d464 3e 28		        ld a, display_row_2 
d466 cd 22 88			call str_at_display 
d469 e1				pop hl 
d46a e5				push hl 
d46b 5e				ld e,(hl) 
d46c 23				inc hl 
d46d 56				ld d,(hl) 
d46e 3e 50		        ld a, display_row_3 
d470 cd 22 88			call str_at_display 
d473 cd 48 88			call update_display 
