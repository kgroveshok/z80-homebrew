8bf6			;http://z80-heaven.wikidot.com/math 
8bf6			; 
8bf6			;Inputs: 
8bf6			;     DE and A are factors 
8bf6			;Outputs: 
8bf6			;     A is not changed 
8bf6			;     B is 0 
8bf6			;     C is not changed 
8bf6			;     DE is not changed 
8bf6			;     HL is the product 
8bf6			;Time: 
8bf6			;     342+6x 
8bf6			; 
8bf6			Mult16: 
8bf6			 
8bf6 06 08		     ld b,8          ;7           7 
8bf8 21 00 00		     ld hl,0         ;10         10 
8bfb 29			       add hl,hl     ;11*8       88 
8bfc 07			       rlca          ;4*8        32 
8bfd 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
8bff 19			         add hl,de   ;--         -- 
8c00 10 f9		       djnz $-5      ;13*7+8     99 
8c02 c9			ret 
