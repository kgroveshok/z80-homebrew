746c			include "firmware_lcd_4x40.asm" 
746c			; **********************************************************************  
746c			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
746c			; **********************************************************************  
746c			;  
746c			; **  Written as a Small Computer Monitor App  
746c			; **  www.scc.me.uk  
746c			;  
746c			; History  
746c			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
746c			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
746c			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
746c			;  
746c			; **********************************************************************  
746c			;  
746c			; This program is an example of one of the methods of interfacing an   
746c			; alphanumeric LCD module.   
746c			;  
746c			; In this example the display is connected to either a Z80 PIO or a   
746c			; simple 8-bit output port.   
746c			;  
746c			; This interfacing method uses 4-bit data mode and uses time delays  
746c			; rather than polling the display's ready status. As a result the   
746c			; interface only requires 6 simple output lines:  
746c			;   Output bit 0 = not used  
746c			;   Output bit 1 = not used  
746c			;   Output bit 2 = RS         High = data, Low = instruction  
746c			;   Output bit 3 = E          Active high  
746c			;   Output bit 4 = DB4  
746c			;   Output bit 5 = DB5  
746c			;   Output bit 6 = DB6  
746c			;   Output bit 7 = DB7  
746c			; Display's R/W is connected to 0v so it is always in write mode  
746c			;  
746c			; This set up should work with any system supporting the RC2014 bus  
746c			  
746c			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
746c			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
746c			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
746c			;  
746c			; **********************************************************************  
746c			  
746c			; Additonal for 4x40. E1 and E2 instead of just E   
746c			; TODO swipe vidout signal on port a to activate E2  
746c			  
746c			; **********************************************************************  
746c			; **  Constants  
746c			; **********************************************************************  
746c			; LCD constants required by LCD support module  
746c			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
746c			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
746c			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
746c			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
746c			; TODO Decide which E is being set  
746c			kLCDWidth:  EQU display_cols             ;Width in characters  
746c			  
746c			; **********************************************************************  
746c			; **  Code library usage  
746c			; **********************************************************************  
746c			  
746c			; send character to current cursor position  
746c			; wraps and/or scrolls screen automatically  
746c			  
746c			  
746c			  
746c			lcd_init:  
746c			  
746c			; SCMonAPI functions used  
746c			  
746c			; Alphanumeric LCD functions used  
746c			; no need to specify specific functions for this module  
746c			  
746c 3e cf		            LD   A, 11001111b  
746e d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
7470 3e 00		            LD   A, 00000000b  
7472 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
7474			  
7474			; Initialise alphanumeric LCD module  
7474 3e 00				ld a, 0  
7476 32 f9 fa				ld (display_lcde1e2), a  
7479 cd fa 74		            CALL fLCD_Init      ;Initialise LCD module  
747c 3e 01				ld a, 1  
747e 32 f9 fa				ld (display_lcde1e2), a  
7481 cd fa 74		            CALL fLCD_Init      ;Initialise LCD module  
7484			  
7484 c9				ret  
7485			  
7485			;  
7485			;;  
7485			; lcd functions  
7485			;  
7485			;  
