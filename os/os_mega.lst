4886			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4886			; | | e.g. 
4886			; | | $01 OPEN $01 DO READ . LOOP 
4886			; | | 
4886			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4886			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4886			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4886			; | | two bytes contain the file id and extent. 
4886			; | |  
4886			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4886			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4886			; | | > [!NOTE] 
4886			; | | > Compatible with PicoSPINet  
4886			 
4886					if DEBUG_FORTH_WORDS_KEY 
4886						DMARK "REA" 
4886				if DEMARK_VERSION = 1  
4886 e5					push hl  
4887 21 8f 48				ld hl, .dmark  
488a 22 9b fd				ld (debug_mark), hl  
488d				endif  
488d				if DEMARK_VERSION = 0  
488d					push af  
488d					ld a, (.dmark)  
488d					ld (debug_mark),a  
488d					ld a, (.dmark+1)  
488d					ld (debug_mark+1),a  
488d					ld a, (.dmark+2)  
488d					ld (debug_mark+2),a  
488d				endif  
488d 18 04			jr .pastdmark  
488f ..			.dmark: db "REA"  
4892				if DEMARK_VERSION = 1  
4892 00					db 0  
4893				endif  
4893				if DEMARK_VERSION = 1  
4893 e1			.pastdmark: pop hl  
4894				endif  
4894				if DEMARK_VERSION = 0  
4894			.pastdmark: pop af  
4894				endif  
4894			endm  
# End of macro DMARK
4894						CALLMONITOR 
4894				if BASE_CPM=1  
4894					call debug_vector  
4894				endif  
4894				if BASE_KEV=1  
4894 cf					rst 8  
4895				endif  
4895				endm  
# End of macro CALLMONITOR
4895					endif 
