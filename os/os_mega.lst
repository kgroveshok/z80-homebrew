10fb			StrictStrCmp: 
10fb				; Load next chars of each string 
10fb 1a				ld a, (de) 
10fc 47				ld b, a 
10fd 7e				ld a, (hl) 
10fe				; Compare 
10fe b8				cp b 
10ff				; Return non-zero if chars don't match 
10ff c0				ret nz 
1100				; Check for end of both strings 
1100 fe 00			cp "\0" 
1102				; Return if strings have ended 
1102 c8				ret z 
1103				; Otherwise, advance to next chars 
1103 23				inc hl 
1104 13				inc de 
1105 18 f4			jr StrictStrCmp 
