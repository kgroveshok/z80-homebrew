8f68			 
8f68			if MALLOC_3 
8f68			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
8f68			;heap_start        .equ  0x9000      ; Starting address of heap 
8f68			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8f68			; 
8f68			 ;     .org 0 
8f68			  ;    jp    main 
8f68			; 
8f68			; 
8f68			 ;     .org  0x100 
8f68			;main: 
8f68			 ;     ld    HL, 0x8100 
8f68			  ;    ld    SP, HL 
8f68			; 
8f68			;      call  heap_init 
8f68			 
8f68			      ; Make some allocations 
8f68			;      ld    HL, 12 
8f68			;      call  malloc            ; Allocates 0x9004 
8f68			; 
8f68			 ;     ld    HL, 12 
8f68			;      call  malloc            ; Allocates 0x9014 
8f68			 
8f68			;      ld    HL, 12 
8f68			;      call  malloc            ; Allocates 0x9024 
8f68			 
8f68			      ; Free some allocations 
8f68			;      ld    HL, 0x9014 
8f68			;      call  free 
8f68			 
8f68			;      ld    HL, 0x9004 
8f68			;      call  free 
8f68			; 
8f68			;      ld    HL, 0x9024 
8f68			;      call  free 
8f68			 
8f68			 
8f68			 ;     halt 
8f68			 
8f68			 
8f68			;------------------------------------------------------------------------------ 
8f68			;     heap_init                                                               : 
8f68			;                                                                             : 
8f68			; Description                                                                 : 
8f68			;     Initialise the heap and make it ready for malloc and free operations.   : 
8f68			;                                                                             : 
8f68			;     The heap is maintained as a linked list, starting with an initial       : 
8f68			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8f68			;     the first free block in the heap. Each block then points to the next    : 
8f68			;     free block within the heap, and the free list ends at the first block   : 
8f68			;     with a null pointer to the next free block.                             : 
8f68			;                                                                             : 
8f68			; Parameters                                                                  : 
8f68			;     Inputs are compile-time only. Two defines which specify the starting    : 
8f68			;     address of the heap and its size are required, along with a memory      : 
8f68			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8f68			;     principally stores a pointer to the first free block in the heap.       : 
8f68			;                                                                             : 
8f68			; Returns                                                                     : 
8f68			;     Nothing                                                                 : 
8f68			;------------------------------------------------------------------------------ 
8f68			heap_init: 
8f68			      push  HL 
8f68			 
8f68			      ; Initialise free list struct 
8f68			      ld    HL, heap_start 
8f68			      ld    (free_list), HL 
8f68			      ld    HL, 0 
8f68			      ld    (free_list+2), HL 
8f68			 
8f68			      ; Insert first free block at bottom of heap, consumes entire heap 
8f68			      ld    HL, heap_start+heap_size-4 
8f68			      ld    (heap_start), HL        ; Next block (end of free list) 
8f68			      ld    HL, heap_size-4 
8f68			      ld    (heap_start+2), HL      ; Block size 
8f68			 
8f68			      ; Insert end of free list block at top of heap - two null words will 
8f68			      ; terminate the free list 
8f68			      ld    HL, 0 
8f68			      ld    (heap_start+heap_size-2), HL 
8f68			      ld    (heap_start+heap_size-4), HL 
8f68			 
8f68			      pop   HL 
8f68			 
8f68			      ret 
8f68			 
8f68			 
8f68			;------------------------------------------------------------------------------ 
8f68			;     malloc                                                                  : 
8f68			;                                                                             : 
8f68			; Description                                                                 : 
8f68			;     Allocates the wanted space from the heap and returns the address of the : 
8f68			;     first useable byte of the allocation.                                   : 
8f68			;                                                                             : 
8f68			;     Allocations can happen in one of two ways:                              : 
8f68			;                                                                             : 
8f68			;     1. A free block may be found which is the exact size wanted. In this    : 
8f68			;        case the block is removed from the free list and retuedn to the      : 
8f68			;        caller.                                                              : 
8f68			;     2. A free block may be found which is larger than the size wanted. In   : 
8f68			;        this case, the larger block is split into two. The first portion of  : 
8f68			;        this block will become the requested space by the malloc call and    : 
8f68			;        is returned to the caller. The second portion becomes a new free     : 
8f68			;        block, and the free list is adjusted to maintain continuity via this : 
8f68			;        newly created block.                                                 : 
8f68			;                                                                             : 
8f68			;     malloc does not set any initial value in the allocated space, the       : 
8f68			;     caller is required to do this as required.                              : 
8f68			;                                                                             : 
8f68			;     This implementation of malloc uses the stack exclusively, and is        : 
8f68			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8f68			;     advisable to disable interrupts before calling malloc, and recommended  : 
8f68			;     to avoid the use of malloc inside ISRs in general.                      : 
8f68			;                                                                             : 
8f68			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8f68			;                                                                             : 
8f68			; Parameters                                                                  : 
8f68			;     HL  Number of bytes wanted                                              : 
8f68			;                                                                             : 
8f68			; Returns                                                                     : 
8f68			;     HL  Address of the first useable byte of the allocation                 : 
8f68			;                                                                             : 
8f68			; Flags                                                                       : 
8f68			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8f68			;                                                                             : 
8f68			; Stack frame                                                                 : 
8f68			;       |             |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |     BC      |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |     DE      |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |     IX      |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |  prev_free  |                                                       : 
8f68			;   +4  +-------------+                                                       : 
8f68			;       |  this_free  |                                                       : 
8f68			;   +2  +-------------+                                                       : 
8f68			;       |  next_free  |                                                       : 
8f68			;   +0  +-------------+                                                       : 
8f68			;       |             |                                                       : 
8f68			;                                                                             : 
8f68			;------------------------------------------------------------------------------ 
8f68			malloc: 
8f68			      push  BC 
8f68			      push  DE 
8f68			      push  IX 
8f68			 
8f68			      ld    A, H                    ; Exit if no space requested 
8f68			      or    L 
8f68			      jp    Z, malloc_early_exit 
8f68			 
8f68			      ; Set up stack frame 
8f68			      ex    DE, HL 
8f68			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8f68			      add   HL, SP 
8f68			      ld    SP, HL 
8f68			      ld    IX, 0                   ; Use IX as a frame pointer 
8f68			      add   IX, SP 
8f68			 
8f68			      ; Setup initial state 
8f68			      ld    HL, 4                   ; want must also include space used by block struct 
8f68			      add   HL, DE 
8f68			 
8f68			      ld    B, H                    ; Move want to BC 
8f68			      ld    C, L 
8f68			 
8f68			      ld    HL, free_list           ; Store prev_free ptr to stack 
8f68			      ld    (IX+4), L 
8f68			      ld    (IX+5), H 
8f68			 
8f68			      ld    E, (HL)                 ; Store this_free ptr to stack 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      ld    (IX+2), E 
8f68			      ld    (IX+3), D 
8f68			      ex    DE, HL                  ; this_free ptr into HL 
8f68			 
8f68			      ; Loop through free block list to find some space 
8f68			malloc_find_space: 
8f68			      ld    E, (HL)                 ; Load next_free ptr into DE 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			 
8f68			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8f68			      or    E 
8f68			      jp    Z, malloc_no_space 
8f68			 
8f68			      ld    (IX+0), E               ; Store next_free ptr to stack 
8f68			      ld    (IX+1), D 
8f68			 
8f68			      ; Does this block have enough space to make the allocation? 
8f68			      inc   HL                      ; Load free block size into DE 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			 
8f68			      ex    DE, HL                  ; Check size of block against want 
8f68			      or    A                       ; Ensure carry flag clear 
8f68			      sbc   HL, BC 
8f68			      push  HL                      ; Store the result for later (new block size) 
8f68			 
8f68			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8f68			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8f68			 
8f68			      ; this_free block is not big enough, setup ptrs to test next free block 
8f68			      pop   HL                      ; Discard previous result 
8f68			 
8f68			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8f68			      ld    H, (IX+3) 
8f68			      ld    (IX+4), L 
8f68			      ld    (IX+5), H 
8f68			 
8f68			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8f68			      ld    H, (IX+1) 
8f68			      ld    (IX+2), L 
8f68			      ld    (IX+3), H 
8f68			 
8f68			      jr    malloc_find_space 
8f68			 
8f68			      ; split a bigger block into two - requested size and remaining size 
8f68			malloc_alloc_split: 
8f68			      ex    DE, HL                  ; Calculate address of new free block 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			      add   HL, BC 
8f68			 
8f68			      ; Create a new block and point it at next_free 
8f68			      ld    E, (IX+0)               ; Load next_free ptr into DE 
8f68			      ld    D, (IX+1) 
8f68			 
8f68			      ld    (HL), E                 ; Store next_free ptr into new block 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			      pop   DE                      ; Store size of new block into new block 
8f68			      inc   HL 
8f68			      ld    (HL), E 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			      ; Update this_free ptr to point to new block 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			 
8f68			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8f68			      ld    D, (IX+3) 
8f68			 
8f68			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8f68			      ld    (IX+3), H 
8f68			 
8f68			      ; Modify this_free block to be allocation 
8f68			      ex    DE, HL 
8f68			      xor   A                       ; Null the next block ptr of allocated block 
8f68			      ld    (HL), A 
8f68			      inc   HL 
8f68			      ld    (HL), A 
8f68			 
8f68			      inc   HL                      ; Store want size into allocated block 
8f68			      ld    (HL), C 
8f68			      inc   HL 
8f68			      ld    (HL), B 
8f68			      inc   HL 
8f68			      push  HL                      ; Address of allocation to return 
8f68			 
8f68			      jr    malloc_update_links 
8f68			 
8f68			malloc_alloc_fit: 
8f68			      pop   HL                      ; Dont need new block size, want is exact fit 
8f68			 
8f68			      ; Modify this_free block to be allocation 
8f68			      ex    DE, HL 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			 
8f68			      xor   A                       ; Null the next block ptr of allocated block 
8f68			      ld    (HL), A 
8f68			      inc   HL 
8f68			      ld    (HL), A 
8f68			 
8f68			      inc   HL                      ; Store address of allocation to return 
8f68			      inc   HL 
8f68			      inc   HL 
8f68			      push  HL 
8f68			 
8f68			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8f68			      ld    L, (IX+0)               ; next_free to HL 
8f68			      ld    H, (IX+1) 
8f68			 
8f68			      ld    (IX+2), L               ; HL to this_free 
8f68			      ld    (IX+3), H 
8f68			 
8f68			 
8f68			malloc_update_links: 
8f68			      ; Update prev_free ptr to point to this_free 
8f68			      ld    L, (IX+4)               ; prev_free ptr to HL 
8f68			      ld    H, (IX+5) 
8f68			 
8f68			      ld    E, (IX+2)               ; this_free ptr to DE 
8f68			      ld    D, (IX+3) 
8f68			 
8f68			      ld    (HL), E                 ; this_free ptr into prev_free 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			      ; Clear the Z flag to indicate successful allocation 
8f68			      ld    A, D 
8f68			      or    E 
8f68			 
8f68			      pop   DE                      ; Address of allocation 
8f68			 
8f68			malloc_no_space: 
8f68			      ld    HL, 6                   ; Clean up stack frame 
8f68			      add   HL, SP 
8f68			      ld    SP, HL 
8f68			 
8f68			      ex    DE, HL                  ; Alloc addr into HL for return 
8f68			 
8f68			malloc_early_exit: 
8f68			      pop   IX 
8f68			      pop   DE 
8f68			      pop   BC 
8f68			 
8f68			      ret 
8f68			 
8f68			 
8f68			;------------------------------------------------------------------------------ 
8f68			;     free                                                                    : 
8f68			;                                                                             : 
8f68			; Description                                                                 : 
8f68			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8f68			;     returned by malloc, otherwise the behaviour is undefined.               : 
8f68			;                                                                             : 
8f68			;     Where possible, directly adjacent free blocks will be merged together   : 
8f68			;     into larger blocks to help ensure that the heap does not become         : 
8f68			;     excessively fragmented.                                                 : 
8f68			;                                                                             : 
8f68			;     free does not clear or set any other value into the freed space, and    : 
8f68			;     therefore its contents may be visible through subsequent malloc's. The  : 
8f68			;     caller should clear the freed space as required.                        : 
8f68			;                                                                             : 
8f68			;     This implementation of free uses the stack exclusively, and is          : 
8f68			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8f68			;     advisable to disable interrupts before calling free, and recommended    : 
8f68			;     to avoid the use of free inside ISRs in general.                        : 
8f68			;                                                                             : 
8f68			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8f68			;                                                                             : 
8f68			; Parameters                                                                  : 
8f68			;     HL  Pointer to address of first byte of allocation to be freed          : 
8f68			;                                                                             : 
8f68			; Returns                                                                     : 
8f68			;     Nothing                                                                 : 
8f68			;                                                                             : 
8f68			; Stack frame                                                                 : 
8f68			;       |             |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |     BC      |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |     DE      |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |     IX      |                                                       : 
8f68			;       +-------------+                                                       : 
8f68			;       |  prev_free  |                                                       : 
8f68			;   +2  +-------------+                                                       : 
8f68			;       |  next_free  |                                                       : 
8f68			;   +0  +-------------+                                                       : 
8f68			;       |             |                                                       : 
8f68			;                                                                             : 
8f68			;------------------------------------------------------------------------------ 
8f68			free: 
8f68			      push  BC 
8f68			      push  DE 
8f68			      push  IX 
8f68			 
8f68			      ld    A, H                    ; Exit if ptr is null 
8f68			      or    L 
8f68			      jp    Z, free_early_exit 
8f68			 
8f68			      ; Set up stack frame 
8f68			      ex    DE, HL 
8f68			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8f68			      add   HL, SP 
8f68			      ld    SP, HL 
8f68			      ld    IX, 0                   ; Use IX as a frame pointer 
8f68			      add   IX, SP 
8f68			 
8f68			      ; The address in HL points to the start of the useable allocated space, 
8f68			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8f68			      ; address of the block itself. 
8f68			      ex    DE, HL 
8f68			      ld    DE, -4 
8f68			      add   HL, DE 
8f68			 
8f68			      ; An allocated block must have a null next block pointer in it 
8f68			      ld    A, (HL) 
8f68			      inc   HL 
8f68			      or    (HL) 
8f68			      jp    NZ, free_done 
8f68			 
8f68			      dec   HL 
8f68			 
8f68			      ld    B, H                    ; Copy HL to BC 
8f68			      ld    C, L 
8f68			 
8f68			      ; Loop through the free list to find the first block with an address 
8f68			      ; higher than the block being freed 
8f68			      ld    HL, free_list 
8f68			 
8f68			free_find_higher_block: 
8f68			      ld    E, (HL)                 ; Load next ptr from free block 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      dec   HL 
8f68			 
8f68			      ld    (IX+0), E               ; Save ptr to next free block 
8f68			      ld    (IX+1), D 
8f68			      ld    (IX+2), L               ; Save ptr to prev free block 
8f68			      ld    (IX+3), H 
8f68			 
8f68			      ld    A, B                    ; Check if DE is greater than BC 
8f68			      cp    D                       ; Compare MSB first 
8f68			      jr    Z, $+4                  ; MSB the same, compare LSB 
8f68			      jr    NC, free_find_higher_block_skip 
8f68			      ld    A, C 
8f68			      cp    E                       ; Then compare LSB 
8f68			      jr    C, free_found_higher_block 
8f68			 
8f68			free_find_higher_block_skip: 
8f68			      ld    A, D                    ; Reached the end of the free list? 
8f68			      or    E 
8f68			      jp    Z, free_done 
8f68			 
8f68			      ex    DE, HL 
8f68			 
8f68			      jr    free_find_higher_block 
8f68			 
8f68			free_found_higher_block: 
8f68			      ; Insert freed block between prev and next free blocks 
8f68			      ld    (HL), C                 ; Point prev free block to freed block 
8f68			      inc   HL 
8f68			      ld    (HL), B 
8f68			 
8f68			      ld    H, B                    ; Point freed block at next free block 
8f68			      ld    L, C 
8f68			      ld    (HL), E 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			      ; Check if the freed block is adjacent to the next free block 
8f68			      inc   HL                      ; Load size of freed block into HL 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      ex    DE, HL 
8f68			 
8f68			      add   HL, BC                  ; Add addr of freed block and its size 
8f68			 
8f68			      ld    E, (IX+0)               ; Load addr of next free block into DE 
8f68			      ld    D, (IX+1) 
8f68			 
8f68			      or    A                       ; Clear the carry flag 
8f68			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8f68			      jr    NZ, free_check_adjacent_to_prev 
8f68			 
8f68			      ; Freed block is adjacent to next, merge into one bigger block 
8f68			      ex    DE, HL                  ; Load next ptr from next block into DE 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      push  HL                      ; Save ptr to next block for later 
8f68			 
8f68			      ld    H, B                    ; Store ptr from next block into freed block 
8f68			      ld    L, C 
8f68			      ld    (HL), E 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			      pop   HL                      ; Restore ptr to next block 
8f68			      inc   HL                      ; Load size of next block into DE 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      push  DE                      ; Save next block size for later 
8f68			 
8f68			      ld    H, B                    ; Load size of freed block into HL 
8f68			      ld    L, C 
8f68			      inc   HL 
8f68			      inc   HL 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      ex    DE, HL 
8f68			 
8f68			      pop   DE                      ; Restore size of next block 
8f68			      add   HL, DE                  ; Add sizes of both blocks 
8f68			      ex    DE, HL 
8f68			 
8f68			      ld    H, B                    ; Store new bigger size into freed block 
8f68			      ld    L, C 
8f68			      inc   HL 
8f68			      inc   HL 
8f68			      ld    (HL), E 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			free_check_adjacent_to_prev: 
8f68			      ; Check if the freed block is adjacent to the prev free block 
8f68			      ld    L, (IX+2)               ; Prev free block ptr into HL 
8f68			      ld    H, (IX+3) 
8f68			 
8f68			      inc   HL                      ; Size of prev free block into DE 
8f68			      inc   HL 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			      dec   HL 
8f68			 
8f68			      add   HL, DE                  ; Add prev block addr and size 
8f68			 
8f68			      or    A                       ; Clear the carry flag 
8f68			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8f68			      jr    NZ, free_done 
8f68			 
8f68			      ; Freed block is adjacent to prev, merge into one bigger block 
8f68			      ld    H, B                    ; Load next ptr from freed block into DE 
8f68			      ld    L, C 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      push  HL                      ; Save freed block ptr for later 
8f68			 
8f68			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8f68			      ld    H, (IX+3) 
8f68			      ld    (HL), E 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			      pop   HL                      ; Restore freed block ptr 
8f68			      inc   HL                      ; Load size of freed block into DE 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			      push  DE                      ; Save freed block size for later 
8f68			 
8f68			      ld    L, (IX+2)               ; Load size of prev block into DE 
8f68			      ld    H, (IX+3) 
8f68			      inc   HL 
8f68			      inc   HL 
8f68			      ld    E, (HL) 
8f68			      inc   HL 
8f68			      ld    D, (HL) 
8f68			 
8f68			      pop   HL                      ; Add sizes of both blocks 
8f68			      add   HL, DE 
8f68			      ex    DE, HL 
8f68			 
8f68			      ld    L, (IX+2)               ; Store new bigger size into prev block 
8f68			      ld    H, (IX+3) 
8f68			      inc   HL 
8f68			      inc   HL 
8f68			      ld    (HL), E 
8f68			      inc   HL 
8f68			      ld    (HL), D 
8f68			 
8f68			free_done: 
8f68			      ld    HL, 4                   ; Clean up stack frame 
8f68			      add   HL, SP 
8f68			      ld    SP, HL 
8f68			 
8f68			free_early_exit: 
8f68			      pop   IX 
8f68			      pop   DE 
8f68			      pop   BC 
8f68			 
8f68			      ret 
8f68			 
8f68			 
8f68			;      .org 0x8000 
8f68			; 
8f68			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8f68			 ;                 .dw   0 
8f68			 
8f68			endif 
8f68			 
8f68			 
8f68			if MALLOC_4 
8f68			 
8f68			; My memory allocation code. Very very simple.... 
8f68			; allocate space under 250 chars 
8f68			 
8f68			heap_init: 
8f68				; init start of heap as zero 
8f68				;  
8f68			 
8f68				ld hl, heap_start 
8f68			;	ld a, 0 
8f68				ld (hl), 0      ; empty block 
8f68				inc hl 
8f68			;	ld a, 0 
8f68				ld (hl), 0      ; length of block 
8f68				; write end of list 
8f68				inc hl 
8f68				ld a,(hl) 
8f68				inc hl 
8f68				ld a,(hl) 
8f68				 
8f68			 
8f68				; init some malloc vars 
8f68			 
8f68				ld hl, 0 
8f68				ld (free_list), hl       ; store last malloc location 
8f68			 
8f68				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
8f68			;	ld a, 0 
8f68				ld (hl), 0 
8f68			 
8f68			 
8f68				ld hl, heap_start 
8f68				;  
8f68				  
8f68				ret 
8f68			 
8f68			 
8f68			;    free block marker 
8f68			;    requested size  
8f68			;    pointer to next block 
8f68			;    .... 
8f68			;    next block marker 
8f68			 
8f68			 
8f68			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
8f68			; 
8f68			 
8f68			 
8f68			malloc:  
8f68				push de 
8f68				push bc 
8f68				push af 
8f68			 
8f68				; hl space required 
8f68				 
8f68				ld c, l    ; hold space   (TODO only a max of 255) 
8f68			 
8f68			;	inc c     ; TODO BUG need to fix memory leak on push str 
8f68			;	inc c 
8f68			;	inc c 
8f68			;	inc c 
8f68			;	inc c 
8f68			;	inc c 
8f68			;	inc c 
8f68			 
8f68			 
8f68			 
8f68				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
8f68			 
8f68				ld a, (free_list+3) 
8f68			;	cp 0 
8f68				or a 
8f68				jr z, .contheap 
8f68			 
8f68				ld hl, (free_list)     ; get last alloc 
8f68					if DEBUG_FORTH_MALLOC_INT 
8f68						DMARK "mrs" 
8f68						CALLMONITOR 
8f68					endif 
8f68				jr .startalloc 
8f68			 
8f68			.contheap: 
8f68				ld hl, heap_start 
8f68			 
8f68			.startalloc: 
8f68			 
8f68					if DEBUG_FORTH_MALLOC_INT 
8f68						DMARK "mym" 
8f68						CALLMONITOR 
8f68					endif 
8f68			.findblock: 
8f68					if DEBUG_FORTH_MALLOC_INT 
8f68						DMARK "mmf" 
8f68						CALLMONITOR 
8f68					endif 
8f68			 
8f68				ld a,(hl)  
8f68				; if byte is zero then clear to use 
8f68			 
8f68			;	cp 0 
8f68				or a 
8f68				jr z, .foundemptyblock 
8f68			 
8f68				; if byte is not clear 
8f68				;     then byte is offset to next block 
8f68			 
8f68				inc hl 
8f68				ld a, (hl) ; get size 
8f68			.nextblock:	inc hl 
8f68					ld e, (hl) 
8f68					inc hl 
8f68					ld d, (hl) 
8f68					ex de, hl 
8f68			;	inc hl  ; move past the store space 
8f68			;	inc hl  ; move past zero index  
8f68			 
8f68				; TODO detect no more space 
