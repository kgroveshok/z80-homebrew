2dd5			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2dd5			; | | At start the current various registers will be displayed with contents. 
2dd5			; | | Top right corner will show the most recent debug marker seen. 
2dd5			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2dd5			; | | and the return stack pointer (RSP). 
2dd5			; | | Pressing: 
2dd5			; | |  
2dd5			; | |    1 - Initial screen 
2dd5			; | |  
2dd5			; | |    2 - Display a data dump of HL 
2dd5			; | |  
2dd5			; | |    3 - Display a data dump of DE 
2dd5			; | |  
2dd5			; | |    4 - Display a data dump of BC 
2dd5			; | |  
2dd5			; | |    5 - Display a data dump of HL 
2dd5			; | |  
2dd5			; | |    6 - Display a data dump of DSP 
2dd5			; | |  
2dd5			; | |    7 - Display a data dump of RSP 
2dd5			; | |  
2dd5			; | |    8 - Display a data dump of what is at DSP 
2dd5			; | |  
2dd5			; | |    9 - Display a data dump of what is at RSP 
2dd5			; | |  
2dd5			; | |    0 - Exit monitor and continue running. This will also enable break points 
2dd5			; | |  
2dd5			; | |    * - Disable break points 
2dd5			; | |  
2dd5			; | |    # - Enter traditional monitor mode 
2dd5			; | |  
2dd5			; | | 
2dd5			; | | Monitor Mode 
2dd5			; | | ------------ 
2dd5			; | | A prompt of '>' will be shown for various commands: 
2dd5			; | |  
2dd5			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2dd5			; | |  
2dd5			; | |    C - Continue display a data dump from the last set address 
2dd5			; | |  
2dd5			; | |    M xxxx - Set start of memory edit at address xx 
2dd5			; | |  
2dd5			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2dd5			; | |  
2dd5			; | |    G xxxx - Exec code at specific address 
2dd5			; | |  
2dd5			; | |    Q - Return to previous 
2dd5				if DEBUG_FORTH_WORDS_KEY 
2dd5					DMARK "MON" 
2dd5 f5				push af  
2dd6 3a ea 2d			ld a, (.dmark)  
2dd9 32 99 fd			ld (debug_mark),a  
2ddc 3a eb 2d			ld a, (.dmark+1)  
2ddf 32 9a fd			ld (debug_mark+1),a  
2de2 3a ec 2d			ld a, (.dmark+2)  
2de5 32 9b fd			ld (debug_mark+2),a  
2de8 18 03			jr .pastdmark  
2dea ..			.dmark: db "MON"  
2ded f1			.pastdmark: pop af  
2dee			endm  
# End of macro DMARK
2dee					CALLMONITOR 
2dee				if BASE_CPM=1  
2dee					call debug_vector  
2dee				endif  
2dee				if BASE_KEV=1  
2dee cf					rst 8  
2def				endif  
2def				endm  
# End of macro CALLMONITOR
2def				endif 
