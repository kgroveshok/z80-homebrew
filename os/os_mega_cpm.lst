0b27 2a 98 eb		    ld hl,(seed2) 
0b2a 29			    add hl,hl 
0b2b 9f			    sbc a,a 
0b2c e6 2d		    and %00101101 
0b2e ad			    xor l 
0b2f 6f			    ld l,a 
0b30 22 98 eb		    ld (seed2),hl 
0b33 09			    add hl,bc 
0b34 c9			    ret 
0b35			 
0b35			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0b35			 
0b35			rand32: 
0b35			;Inputs: 
0b35			;   (seed1_0) holds the lower 16 bits of the first seed 
0b35			;   (seed1_1) holds the upper 16 bits of the first seed 
0b35			;   (seed2_0) holds the lower 16 bits of the second seed 
0b35			;   (seed2_1) holds the upper 16 bits of the second seed 
0b35			;   **NOTE: seed2 must be non-zero 
0b35			;Outputs: 
0b35			;   HL is the result 
0b35			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0b35			;Destroys: 
0b35			;   AF 
0b35			;Tested and passes all CAcert tests 
0b35			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0b35			;it has a period of 18,446,744,069,414,584,320 
0b35			;roughly 18.4 quintillion. 
0b35			;LFSR taps: 0,2,6,7  = 11000101 
0b35			;291cc 
0b35			;seed1_0=$+1 
0b35			;    ld hl,12345 
0b35			;seed1_1=$+1 
0b35			;    ld de,6789 
0b35			;    ld b,h 
0b35			;    ld c,l 
0b35			;    add hl,hl \ rl e \ rl d 
0b35			;    add hl,hl \ rl e \ rl d 
0b35			;    inc l 
0b35			;    add hl,bc 
0b35			;    ld (seed1_0),hl 
0b35			;    ld hl,(seed1_1) 
0b35			;    adc hl,de 
0b35			;    ld (seed1_1),hl 
0b35			;    ex de,hl 
0b35			;seed2_0=$+1 
0b35			;    ld hl,9876 
0b35			;seed2_1=$+1 
0b35			;    ld bc,54321 
0b35			;    add hl,hl \ rl c \ rl b 
0b35			;    ld (seed2_1),bc 
0b35			;    sbc a,a 
0b35			;    and %11000101 
0b35			;    xor l 
0b35			;    ld l,a 
0b35			;    ld (seed2_0),hl 
0b35			;    ex de,hl 
0b35			;    add hl,bc 
0b35			;    ret 
0b35			; 
0b35			 
0b35			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0b35			; 20 bytes, 86 cycles (excluding ret) 
0b35			 
0b35			; returns   hl = pseudorandom number 
0b35			; corrupts   a 
0b35			 
0b35			; generates 16-bit pseudorandom numbers with a period of 65535 
0b35			; using the xorshift method: 
0b35			 
0b35			; hl ^= hl << 7 
0b35			; hl ^= hl >> 9 
0b35			; hl ^= hl << 8 
0b35			 
0b35			; some alternative shift triplets which also perform well are: 
0b35			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0b35			 
0b35			;  org 32768 
0b35			 
0b35			xrnd: 
0b35 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
0b38 3e 00		  ld a,0 
0b3a bd			  cp l 
0b3b 20 02		  jr nz, .xrnd1 
0b3d 2e 01		  ld l, 1 
0b3f			.xrnd1: 
0b3f			 
0b3f 7c			  ld a,h 
0b40 1f			  rra 
0b41 7d			  ld a,l 
0b42 1f			  rra 
0b43 ac			  xor h 
0b44 67			  ld h,a 
0b45 7d			  ld a,l 
0b46 1f			  rra 
0b47 7c			  ld a,h 
0b48 1f			  rra 
0b49 ad			  xor l 
0b4a 6f			  ld l,a 
0b4b ac			  xor h 
0b4c 67			  ld h,a 
0b4d			 
0b4d 22 9e eb		  ld (xrandc),hl 
0b50			 
0b50 c9			  ret 
