5538			check_stacks: 
5538				; check all stack words 
5538			 
5538 e5				push hl 
5539 d5				push de 
553a			 
553a			;	ld de,(chk_word) 
553a			;	ld hl, (chk_stund)	; stack points.... 
553a			;	if DEBUG_STK_FAULT 
553a			;		DMARK "FAa" 
553a			;		CALLMONITOR 
553a			;	endif 
553a			;	call cmp16 
553a			;	jp z, .chk_faulta 
553a			; 
553a			;	ld de, sfaultsu 
553a			;	jp .chk_fault 
553a			 
553a 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
553d ed 5b 92 e2		ld de,(chk_word) 
5541				if DEBUG_STK_FAULT 
5541					DMARK "FAb" 
5541					CALLMONITOR 
5541				endif 
5541 cd fc 0b			call cmp16 
5544 28 06			jr z, .chk_fault1 
5546 11 eb 55			ld de, sfaultso 
5549 c3 9b 55			jp .chk_fault 
554c			.chk_fault1:  
554c 2a e1 e9			ld hl, (chk_ret_und) 
554f ed 5b 92 e2		ld de,(chk_word) 
5553				if DEBUG_STK_FAULT 
5553					DMARK "FAU" 
5553					CALLMONITOR 
5553				endif 
5553 cd fc 0b			call cmp16 
5556 ca 5f 55			jp z, .chk_fault2 
5559 11 fb 55			ld de, sfaultru 
555c c3 9b 55			jp .chk_fault 
555f			.chk_fault2:  
