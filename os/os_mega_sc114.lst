8053			; Macro to make adding debug marks easier  
8053			  
8053			  
8053			  
8053			DMARK: macro str  
8053			  
8053				if DEMARK_VERSION = 1  
8053					push hl  
8053					ld hl, .dmark  
8053					ld (debug_mark), hl  
8053				endif  
8053			  
8053			  
8053				if DEMARK_VERSION = 0  
8053					push af  
8053					ld a, (.dmark)  
8053					ld (debug_mark),a  
8053					ld a, (.dmark+1)  
8053					ld (debug_mark+1),a  
8053					ld a, (.dmark+2)  
8053					ld (debug_mark+2),a  
8053			  
8053				endif  
8053			  
8053				jr .pastdmark  
8053			.dmark: db str  
8053			  
8053				if DEMARK_VERSION = 1  
8053					; add a terminator as this is printed direct  
8053					; other version stuffs into a buffer  
8053					db 0  
8053				endif  
8053			  
8053			; skip string  
8053			  
8053				if DEMARK_VERSION = 1  
8053			.pastdmark: pop hl  
8053				endif  
8053			  
8053				if DEMARK_VERSION = 0  
8053			.pastdmark: pop af  
8053				endif  
8053			  
8053			endm  
8053			  
8053			  
8053			; macro to detect for stack imbalances  
8053			  
8053			include "stackimbal.asm"  
8053			; Macro and code to detect stock imbalances 
8053			 
8053			SPPUSH: equ 0 
8053			 
8053			; Add a stack frame which can be checked before return 
8053			 
8053			STACKFRAME: macro onoff frame1 frame2 
8053			 
8053				if DEBUG_STACK_IMB 
8053					if onoff 
8053						; save current SP 
8053						exx 
8053			 
8053						ld de, frame1 
8053						ld a, d 
8053						ld hl, curframe 
8053						call hexout 
8053						ld a, e 
8053						ld hl, curframe+2 
8053						call hexout 
8053			  
8053						ld hl, frame1 
8053						push hl 
8053						ld hl, frame2 
8053						push hl 
8053						exx 
8053					endif 
8053					 
8053				endif 
8053			endm 
8053			 
8053			STACKFRAMECHK: macro onoff frame1 frame2 
8053			 
8053					 
8053				if DEBUG_STACK_IMB 
8053					if onoff 
8053						exx 
8053						; check stack frame SP 
8053			 
8053						ld hl, frame2 
8053						pop de   ; frame2 
8053			 
8053						call cmp16 
8053						jr nz, .spnosame 
8053						 
8053			 
8053						ld hl, frame1 
8053						pop de   ; frame1 
8053			 
8053						call cmp16 
8053						jr z, .spfrsame 
8053			 
8053						.spnosame: call showsperror 
8053			 
8053						.spfrsame: nop 
8053			 
8053						exx 
8053					endif 
8053					 
8053				endif 
8053			 
8053			 
8053			endm 
8053			 
8053			 
8053			; for a sub routine, wrap SP collection and comparisons 
8053			 
8053			; Usage: 
8053			; 
8053			; SAVESP ON/OFF 0-STACK_IMB_STORE/4 
8053			; CHECKSP ON/OFF 0-STACK_IMB_STORE/4 
8053			 
8053			SAVESP: macro onoff storeword 
8053			 
8053				if DEBUG_STACK_IMB 
8053					if onoff 
8053						; save current SP 
8053			 
8053						ld (store_sp+(storeword*4)), sp 
8053			 
8053					endif 
8053					 
8053				endif 
8053			 
8053			endm 
8053			 
8053			CHECKSP: macro onoff storeword 
8053			 
8053				if DEBUG_STACK_IMB 
8053					if onoff 
8053			 
8053						; save SP after last save 
8053				 
8053						ld (store_sp+(storeword*4)+2), sp 
8053			 
8053						push hl 
8053						ld hl, store_sp+(storeword*4) 
8053						call check_stack_sp  
8053						pop hl 
8053			 
8053			 
8053					endif 
8053					 
8053				endif 
8053			 
8053			endm 
8053			 
8053			if DEBUG_STACK_IMB 
8053			 
8053			check_stack_sp: 
8053					push de 
8053			 
8053					ld e, (hl) 
8053					inc hl 
8053					ld d, (hl) 
8053					inc hl 
8053			 
8053					push de 
8053			 
8053			 
8053					ld e, (hl) 
8053					inc hl 
8053					ld d, (hl) 
8053					inc hl 
8053			 
8053					pop hl 
8053			 
8053			 
8053					; check to see if the same 
8053			 
8053					call cmp16 
8053					jr z, .spsame 
8053			 
8053					; not same 
8053			 
8053					call showsperror 
8053			.spsame: 
8053			 
8053					pop de 
8053			 
8053					ret 
8053			 
8053			.sperr:  db "Stack imbalance",0 
8053			 
8053			 
8053			showsperror: 
8053			 
8053			 
8053				push hl 
8053				push af 
8053				push de 
8053				call clear_display 
8053				ld de, .sperr 
8053				ld a,0 
8053			;	ld de,os_word_scratch 
8053				call str_at_display 
8053				ld a, display_row_1+17 
8053				ld de, debug_mark 
8053				call str_at_display 
8053				ld a, 0 
8053				ld (curframe+4),a 
8053				ld hl, curframe 
8053				ld de, os_word_scratch 
8053				ld a, display_row_4 
8053				call str_at_display 
8053				call update_display 
8053				;call break_point_state 
8053				call cin_wait 
8053			 
8053			;	ld a, ' ' 
8053			;	ld (os_view_disable), a 
8053				call bp_on 
8053				pop de	 
8053				pop af 
8053				pop hl 
8053				CALLMONITOR 
8053				ret 
8053			 
8053			endif 
8053			 
8053			 
8053			 
8053			; eof 
# End of file stackimbal.asm
