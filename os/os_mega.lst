20ee			;	FORTH_END_BUFFER: equ 0 
20ee			;else 
20ee			FORTH_END_BUFFER: equ 127 
20ee			;endif 
20ee			 
20ee			FORTH_TRUE: equ 1 
20ee			FORTH_FALSE: equ 0 
