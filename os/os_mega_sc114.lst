98dd			; Stack operations for v5 parser on wards 
98dd			; * DATA stack 
98dd			; * LOOP stack 
98dd			; * RETURN stack 
98dd			 
98dd			 
98dd			 
98dd			FORTH_CHK_DSP_UNDER: macro 
98dd				push hl 
98dd				push de 
98dd				ld hl,(cli_data_sp) 
98dd				ld de, cli_data_stack 
98dd				call cmp16 
98dd				jp c, fault_dsp_under 
98dd				pop de 
98dd				pop hl 
98dd				endm 
98dd			 
98dd			 
98dd			FORTH_CHK_RSP_UNDER: macro 
98dd				push hl 
98dd				push de 
98dd				ld hl,(cli_ret_sp) 
98dd				ld de, cli_ret_stack 
98dd				call cmp16 
98dd				jp c, fault_rsp_under 
98dd				pop de 
98dd				pop hl 
98dd				endm 
98dd			 
98dd			FORTH_CHK_LOOP_UNDER: macro 
98dd				push hl 
98dd				push de 
98dd				ld hl,(cli_loop_sp) 
98dd				ld de, cli_loop_stack 
98dd				call cmp16 
98dd				jp c, fault_loop_under 
98dd				pop de 
98dd				pop hl 
98dd				endm 
98dd			 
98dd			FORTH_ERR_TOS_NOTSTR: macro 
98dd				; TOSO might need more for checks when used 
98dd				push af 
98dd				ld a,(hl) 
98dd				cp DS_TYPE_STR 
98dd				jp nz, type_faultn   
98dd				pop af 
98dd				endm 
98dd			 
98dd			FORTH_ERR_TOS_NOTNUM: macro 
98dd				push af 
98dd				ld a,(hl) 
98dd				cp DS_TYPE_INUM 
98dd				jp nz, type_faultn   
98dd				pop af 
98dd				endm 
98dd			 
98dd			 
98dd			; increase data stack pointer and save hl to it 
98dd				 
98dd			FORTH_DSP_NEXT: macro 
98dd				call macro_forth_dsp_next 
98dd				endm 
98dd			 
98dd			 
98dd			macro_forth_dsp_next: 
98dd				if DEBUG_FORTH_STACK_GUARD 
98dd cd 87 d2				call check_stacks 
98e0				endif 
98e0 e5				push hl 
98e1 d5				push de 
98e2 eb				ex de,hl 
98e3 2a d2 e9			ld hl,(cli_data_sp) 
98e6 23				inc hl 
98e7 23				inc hl 
98e8			 
98e8			; PARSEV5 
98e8 23				inc hl 
98e9 22 d2 e9			ld (cli_data_sp),hl 
98ec 73				ld (hl), e 
98ed 23				inc hl 
98ee 72				ld (hl), d 
98ef d1				pop de 
98f0 e1				pop hl 
98f1				if DEBUG_FORTH_STACK_GUARD 
98f1 cd 87 d2				call check_stacks 
98f4				endif 
98f4 c9				ret 
