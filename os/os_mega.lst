12c4			if TAPE_SUPPORT   
12c4				include "firmware_tape.asm"    ; Tape support on Device A by default  
12c4			; Tape support 
12c4			 
12c4			; setup default tape params 
12c4			tape_init:     
12c4 3e 00			ld a, Device_A 
12c6 32 8e f9			ld (tape_port), a 
12c9 21 96 00			ld hl, 150 
12cc 22 82 f9			ld (tape_tm_gap), hl 
12cf 21 46 00			ld hl, 70 
12d2 22 80 f9			ld (tape_tm_high), hl 
12d5 21 14 00			ld hl, 20 
12d8 22 7e f9			ld (tape_tm_low), hl 
12db c9				ret 
12dc			 
12dc			; support routinues for tape 
12dc			 
12dc			 
12dc			; Tape Output 
12dc			 
12dc			; osciallate the pin for the required duration 
12dc			 
12dc			tape_osc:  
12dc				; hl has the number of iterations 
12dc				; c = port number 
12dc				; d = bus data 
12dc				 
12dc ed 51			out (c), d 
12de 3e 01			ld a, 1 
12e0 cd 53 0a			call aDelayInMS 
12e3				 
12e3 2b				dec hl 
12e4 7d				ld a, l 
12e5 84				add h 
12e6 fe 00			cp 0 
12e8 20 f2			jr nz, tape_osc 
12ea				 
12ea c9				ret 
12eb			 
12eb			; output a gap period 
12eb			tape_gap:  
12eb 2a 82 f9			ld hl, (tape_tm_gap) 
12ee 7d				ld a, l 
12ef cd 53 0a			call aDelayInMS 
12f2 c9				ret 
12f3			 
12f3			; output a high period 
12f3			 
12f3			tape_high: 
12f3 3a 8e f9			ld a, (tape_port) 
12f6 4f				ld c, a 
12f7 16 ff			ld d, 255 
12f9 2a 80 f9			ld hl, (tape_tm_high) 
12fc cd dc 12			call tape_osc 
12ff c9				 ret 
1300			 
1300			; output a low period 
1300			 
1300			tape_low:  
1300			 
1300 3a 8e f9			ld a, (tape_port) 
1303 4f				ld c, a 
1304 16 ff			ld d, 255 
1306 2a 7e f9			ld hl, (tape_tm_low) 
1309 cd dc 12			call tape_osc 
130c c9				 ret 
130d			 
130d			; end of save marker 
130d			 
130d			tape_end: 
130d 3e ff			ld a, 255 
130f cd 26 13			call tape_byte_out 
1312 cd eb 12			call tape_gap 
1315 3e ff			ld a, 255 
1317 cd 26 13			call tape_byte_out 
131a cd eb 12			call tape_gap 
131d 3e ff			ld a, 255 
131f cd 26 13			call tape_byte_out 
1322 cd eb 12			call tape_gap 
1325 c9				 ret 
1326			 
1326			; output an encoded byte 
1326			 
1326			tape_byte_out: 
1326				; a = byte to output 
1326 06 08			ld b, 8 
1328 4f				ld c, a 
1329			.tbo:    
1329 c5				push bc 
132a cb 79			bit 7, c 
132c 28 05			jr z, .tbol 
132e cd f3 12			call tape_high 
1331 18 03			jr .tbn 
1333			.tbol: 
1333 cd 00 13			call tape_low 
1336			.tbn: 
1336 cd eb 12			call tape_gap 
1339 c1				pop bc 
133a cb 21			sla c 
133c 10 eb			djnz .tbo 
133e			 
133e			 
133e c9				 ret 
133f			 
133f			; output a string 
133f			 
133f			; hl - pointer to string 
133f			 
133f			tape_strz_out:  
133f 7e				ld a, (hl) 
1340 e5				push hl 
1341 cd 26 13			call tape_byte_out 
1344			 
1344 cd eb 12			call tape_gap 
1347 cd eb 12			call tape_gap 
134a			 
134a cd 87 0a			call active 
134d eb				ex de, hl 
134e 3e 00			ld a, 0 
1350 cd 41 0b			call  str_at_display 
1353 cd 51 0b			call update_display 
1356			 
1356 e1				pop hl 
1357 7e				ld a, (hl) 
1358 fe 00			cp 0 
135a c8				ret z 
135b 23				inc hl 
135c 18 e1			jr tape_strz_out 
135e			 
135e			; prompt the user to ready the tape to record 
135e			 
135e			tape_ready_rec:  
135e			 
135e 21 72 13			ld hl, trr1 
1361 11 96 13			ld de, trr2 
1364 cd c1 0a			call info_panel 
1367 c9				ret 
