1107			;------------------------------------------------------------------------------ 
1107			;     heap_init                                                               : 
1107			;                                                                             : 
1107			; Description                                                                 : 
1107			;     Initialise the heap and make it ready for malloc and free operations.   : 
1107			;                                                                             : 
1107			;     The heap is maintained as a linked list, starting with an initial       : 
1107			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1107			;     the first free block in the heap. Each block then points to the next    : 
1107			;     free block within the heap, and the free list ends at the first block   : 
1107			;     with a null pointer to the next free block.                             : 
1107			;                                                                             : 
1107			; Parameters                                                                  : 
1107			;     Inputs are compile-time only. Two defines which specify the starting    : 
1107			;     address of the heap and its size are required, along with a memory      : 
1107			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1107			;     principally stores a pointer to the first free block in the heap.       : 
1107			;                                                                             : 
1107			; Returns                                                                     : 
1107			;     Nothing                                                                 : 
1107			;------------------------------------------------------------------------------ 
1107			heap_init: 
1107 e5			      push  HL 
1108			 
1108			      ; Initialise free list struct 
1108 21 0e 80		      ld    HL, heap_start 
110b 22 0a 80		      ld    (free_list), HL 
110e 21 00 00		      ld    HL, 0 
1111 22 0c 80		      ld    (free_list+2), HL 
1114			 
1114			      ; Insert first free block at bottom of heap, consumes entire heap 
1114 21 b7 f0		      ld    HL, heap_start+heap_size-4 
1117 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
111a 21 a9 70		      ld    HL, heap_size-4 
111d 22 10 80		      ld    (heap_start+2), HL      ; Block size 
1120			 
1120			      ; Insert end of free list block at top of heap - two null words will 
1120			      ; terminate the free list 
1120 21 00 00		      ld    HL, 0 
1123 22 b9 f0		      ld    (heap_start+heap_size-2), HL 
1126 22 b7 f0		      ld    (heap_start+heap_size-4), HL 
1129			 
1129 e1			      pop   HL 
112a			 
112a c9			      ret 
112b			 
112b			 
112b			;------------------------------------------------------------------------------ 
112b			;     malloc                                                                  : 
112b			;                                                                             : 
112b			; Description                                                                 : 
112b			;     Allocates the wanted space from the heap and returns the address of the : 
112b			;     first useable byte of the allocation.                                   : 
112b			;                                                                             : 
112b			;     Allocations can happen in one of two ways:                              : 
112b			;                                                                             : 
112b			;     1. A free block may be found which is the exact size wanted. In this    : 
112b			;        case the block is removed from the free list and retuedn to the      : 
112b			;        caller.                                                              : 
112b			;     2. A free block may be found which is larger than the size wanted. In   : 
112b			;        this case, the larger block is split into two. The first portion of  : 
112b			;        this block will become the requested space by the malloc call and    : 
112b			;        is returned to the caller. The second portion becomes a new free     : 
112b			;        block, and the free list is adjusted to maintain continuity via this : 
112b			;        newly created block.                                                 : 
112b			;                                                                             : 
112b			;     malloc does not set any initial value in the allocated space, the       : 
112b			;     caller is required to do this as required.                              : 
112b			;                                                                             : 
112b			;     This implementation of malloc uses the stack exclusively, and is        : 
112b			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
112b			;     advisable to disable interrupts before calling malloc, and recommended  : 
112b			;     to avoid the use of malloc inside ISRs in general.                      : 
112b			;                                                                             : 
112b			;     NOTE: heap_init must be called before malloc and free can be used.      : 
112b			;                                                                             : 
112b			; Parameters                                                                  : 
112b			;     HL  Number of bytes wanted                                              : 
112b			;                                                                             : 
112b			; Returns                                                                     : 
112b			;     HL  Address of the first useable byte of the allocation                 : 
112b			;                                                                             : 
112b			; Flags                                                                       : 
112b			;     Z   Set if the allocation did not succeed, clear otherwise              : 
112b			;                                                                             : 
112b			; Stack frame                                                                 : 
112b			;       |             |                                                       : 
112b			;       +-------------+                                                       : 
112b			;       |     BC      |                                                       : 
112b			;       +-------------+                                                       : 
112b			;       |     DE      |                                                       : 
112b			;       +-------------+                                                       : 
112b			;       |     IX      |                                                       : 
112b			;       +-------------+                                                       : 
112b			;       |  prev_free  |                                                       : 
112b			;   +4  +-------------+                                                       : 
112b			;       |  this_free  |                                                       : 
112b			;   +2  +-------------+                                                       : 
112b			;       |  next_free  |                                                       : 
112b			;   +0  +-------------+                                                       : 
112b			;       |             |                                                       : 
112b			;                                                                             : 
112b			;------------------------------------------------------------------------------ 
112b			 
112b			 
112b			;malloc: 
112b			; 
112b			;	SAVESP ON 1 
112b			; 
112b			;	call malloc_code 
112b			; 
112b			;	CHECKSP ON 1 
112b			;	ret 
112b			 
112b			 
112b			malloc: 
112b c5			      push  BC 
112c d5			      push  DE 
112d dd e5		      push  IX 
112f			if DEBUG_FORTH_MALLOC_HIGH 
112f			call malloc_guard_entry 
112f			endif 
112f			 
112f					if DEBUG_FORTH_MALLOC 
112f						DMARK "mal" 
112f						CALLMONITOR 
112f					endif 
112f 7c			      ld    A, H                    ; Exit if no space requested 
1130 b5			      or    L 
1131 ca f0 11		      jp    Z, malloc_early_exit 
1134			 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			; 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			;inc hl 
1134			 
1134			 
1134			 
1134			 
1134					if DEBUG_FORTH_MALLOC 
1134						DMARK "maA" 
1134						CALLMONITOR 
1134					endif 
1134			      ; Set up stack frame 
1134 eb			      ex    DE, HL 
1135 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1138 39			      add   HL, SP 
1139 f9			      ld    SP, HL 
113a dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
113e dd 39		      add   IX, SP 
1140			 
1140			      ; Setup initial state 
1140 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
1143 19			      add   HL, DE 
1144			 
1144 44			      ld    B, H                    ; Move want to BC 
1145 4d			      ld    C, L 
1146			 
1146 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
1149 dd 75 04		      ld    (IX+4), L 
114c dd 74 05		      ld    (IX+5), H 
114f			 
114f 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
1150 23			      inc   HL 
1151 56			      ld    D, (HL) 
1152 dd 73 02		      ld    (IX+2), E 
1155 dd 72 03		      ld    (IX+3), D 
1158 eb			      ex    DE, HL                  ; this_free ptr into HL 
1159			 
1159					if DEBUG_FORTH_MALLOC 
1159						DMARK "maB" 
1159						CALLMONITOR 
1159					endif 
1159			      ; Loop through free block list to find some space 
1159			malloc_find_space: 
1159 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
115a 23			      inc   HL 
115b 56			      ld    D, (HL) 
115c			 
115c 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
115d b3			      or    E 
115e ca ea 11		      jp    Z, malloc_no_space 
1161			 
1161 dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1164 dd 72 01		      ld    (IX+1), D 
1167			 
1167			      ; Does this block have enough space to make the allocation? 
1167 23			      inc   HL                      ; Load free block size into DE 
1168 5e			      ld    E, (HL) 
1169 23			      inc   HL 
116a 56			      ld    D, (HL) 
116b			 
116b eb			      ex    DE, HL                  ; Check size of block against want 
116c b7			      or    A                       ; Ensure carry flag clear 
116d ed 42		      sbc   HL, BC 
116f e5			      push  HL                      ; Store the result for later (new block size) 
1170			 
1170 ca bf 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1173 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1175			 
1175			      ; this_free block is not big enough, setup ptrs to test next free block 
1175 e1			      pop   HL                      ; Discard previous result 
1176			 
1176 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1179 dd 66 03		      ld    H, (IX+3) 
117c dd 75 04		      ld    (IX+4), L 
117f dd 74 05		      ld    (IX+5), H 
1182			 
1182 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1185 dd 66 01		      ld    H, (IX+1) 
1188 dd 75 02		      ld    (IX+2), L 
118b dd 74 03		      ld    (IX+3), H 
118e			 
118e					if DEBUG_FORTH_MALLOC 
118e						DMARK "MA>" 
118e						CALLMONITOR 
118e					endif 
118e 18 c9		      jr    malloc_find_space 
1190			 
1190			      ; split a bigger block into two - requested size and remaining size 
1190			malloc_alloc_split: 
1190					if DEBUG_FORTH_MALLOC 
1190						DMARK "MAs" 
1190						CALLMONITOR 
1190					endif 
1190 eb			      ex    DE, HL                  ; Calculate address of new free block 
1191 2b			      dec   HL 
1192 2b			      dec   HL 
1193 2b			      dec   HL 
1194 09			      add   HL, BC 
1195			 
1195			      ; Create a new block and point it at next_free 
1195 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
1198 dd 56 01		      ld    D, (IX+1) 
119b			 
119b 73			      ld    (HL), E                 ; Store next_free ptr into new block 
119c 23			      inc   HL 
119d 72			      ld    (HL), D 
119e			 
119e d1			      pop   DE                      ; Store size of new block into new block 
119f 23			      inc   HL 
11a0 73			      ld    (HL), E 
11a1 23			      inc   HL 
11a2 72			      ld    (HL), D 
11a3			 
11a3			      ; Update this_free ptr to point to new block 
11a3 2b			      dec   HL 
11a4 2b			      dec   HL 
11a5 2b			      dec   HL 
11a6			 
11a6 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
11a9 dd 56 03		      ld    D, (IX+3) 
11ac			 
11ac dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
11af dd 74 03		      ld    (IX+3), H 
11b2			 
11b2			      ; Modify this_free block to be allocation 
11b2 eb			      ex    DE, HL 
11b3 af			      xor   A                       ; Null the next block ptr of allocated block 
11b4 77			      ld    (HL), A 
11b5 23			      inc   HL 
11b6 77			      ld    (HL), A 
11b7			 
11b7 23			      inc   HL                      ; Store want size into allocated block 
11b8 71			      ld    (HL), C 
11b9 23			      inc   HL 
11ba 70			      ld    (HL), B 
11bb 23			      inc   HL 
11bc e5			      push  HL                      ; Address of allocation to return 
11bd			 
11bd 18 19		      jr    malloc_update_links 
11bf			 
11bf			malloc_alloc_fit: 
11bf e1			      pop   HL                      ; Dont need new block size, want is exact fit 
11c0			 
11c0					if DEBUG_FORTH_MALLOC 
11c0						DMARK "MAf" 
11c0						CALLMONITOR 
11c0					endif 
11c0			      ; Modify this_free block to be allocation 
11c0 eb			      ex    DE, HL 
11c1 2b			      dec   HL 
11c2 2b			      dec   HL 
11c3 2b			      dec   HL 
11c4			 
11c4 af			      xor   A                       ; Null the next block ptr of allocated block 
11c5 77			      ld    (HL), A 
11c6 23			      inc   HL 
11c7 77			      ld    (HL), A 
11c8			 
11c8 23			      inc   HL                      ; Store address of allocation to return 
11c9 23			      inc   HL 
11ca 23			      inc   HL 
11cb e5			      push  HL 
11cc			 
11cc			      ; Copy next_free ptr to this_free, remove allocated block from free list 
11cc dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11cf dd 66 01		      ld    H, (IX+1) 
11d2			 
11d2 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11d5 dd 74 03		      ld    (IX+3), H 
11d8			 
11d8			 
11d8			malloc_update_links: 
11d8			      ; Update prev_free ptr to point to this_free 
11d8 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
11db dd 66 05		      ld    H, (IX+5) 
11de			 
11de dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
11e1 dd 56 03		      ld    D, (IX+3) 
11e4			 
11e4 73			      ld    (HL), E                 ; this_free ptr into prev_free 
11e5 23			      inc   HL 
11e6 72			      ld    (HL), D 
11e7			 
11e7					if DEBUG_FORTH_MALLOC 
11e7						DMARK "Mul" 
11e7						CALLMONITOR 
11e7					endif 
11e7			      ; Clear the Z flag to indicate successful allocation 
11e7 7a			      ld    A, D 
11e8 b3			      or    E 
11e9			 
11e9 d1			      pop   DE                      ; Address of allocation 
11ea					if DEBUG_FORTH_MALLOC 
11ea						DMARK "MAu" 
11ea						CALLMONITOR 
11ea					endif 
11ea			 
11ea			malloc_no_space: 
11ea 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
11ed 39			      add   HL, SP 
11ee f9			      ld    SP, HL 
11ef			 
11ef eb			      ex    DE, HL                  ; Alloc addr into HL for return 
11f0					if DEBUG_FORTH_MALLOC 
11f0						DMARK "MAN" 
11f0						CALLMONITOR 
11f0					endif 
11f0			 
11f0			malloc_early_exit: 
11f0					if DEBUG_FORTH_MALLOC 
11f0						DMARK "MAx" 
11f0						CALLMONITOR 
11f0					endif 
11f0 dd e1		      pop   IX 
11f2 d1			      pop   DE 
11f3 c1			      pop   BC 
11f4			 
