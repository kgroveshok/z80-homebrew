8f7f dd 66 03		      ld    H, (IX+3) 
8f82 23			      inc   HL 
8f83 23			      inc   HL 
8f84 5e			      ld    E, (HL) 
8f85 23			      inc   HL 
8f86 56			      ld    D, (HL) 
