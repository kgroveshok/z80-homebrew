# End of macro CWHEAD
a6f6			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a6f6			; | | At start the current various registers will be displayed with contents. 
a6f6			; | | Top right corner will show the most recent debug marker seen. 
a6f6			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a6f6			; | | and the return stack pointer (RSP). 
a6f6			; | | Pressing: 
a6f6			; | |  
a6f6			; | |    1 - Initial screen 
a6f6			; | |  
a6f6			; | |    2 - Display a data dump of HL 
a6f6			; | |  
a6f6			; | |    3 - Display a data dump of DE 
a6f6			; | |  
a6f6			; | |    4 - Display a data dump of BC 
a6f6			; | |  
a6f6			; | |    5 - Display a data dump of HL 
a6f6			; | |  
a6f6			; | |    6 - Display a data dump of DSP 
a6f6			; | |  
a6f6			; | |    7 - Display a data dump of RSP 
a6f6			; | |  
a6f6			; | |    8 - Display a data dump of what is at DSP 
a6f6			; | |  
a6f6			; | |    9 - Display a data dump of what is at RSP 
a6f6			; | |  
a6f6			; | |    0 - Exit monitor and continue running. This will also enable break points 
a6f6			; | |  
a6f6			; | |    * - Disable break points 
a6f6			; | |  
a6f6			; | |    # - Enter traditional monitor mode 
a6f6			; | |  
a6f6			; | | 
a6f6			; | | Monitor Mode 
a6f6			; | | ------------ 
a6f6			; | | A prompt of '>' will be shown for various commands: 
a6f6			; | |  
a6f6			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a6f6			; | |  
a6f6			; | |    C - Continue display a data dump from the last set address 
a6f6			; | |  
a6f6			; | |    M xxxx - Set start of memory edit at address xx 
a6f6			; | |  
a6f6			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a6f6			; | |  
a6f6			; | |    G xxxx - Exec code at specific address 
a6f6			; | |  
a6f6			; | |    Q - Return to previous 
a6f6				if DEBUG_FORTH_WORDS_KEY 
a6f6					DMARK "MON" 
a6f6 f5				push af  
a6f7 3a 0b a7			ld a, (.dmark)  
a6fa 32 5e ee			ld (debug_mark),a  
a6fd 3a 0c a7			ld a, (.dmark+1)  
a700 32 5f ee			ld (debug_mark+1),a  
a703 3a 0d a7			ld a, (.dmark+2)  
a706 32 60 ee			ld (debug_mark+2),a  
a709 18 03			jr .pastdmark  
a70b ..			.dmark: db "MON"  
a70e f1			.pastdmark: pop af  
a70f			endm  
# End of macro DMARK
a70f					CALLMONITOR 
a70f				if BASE_CPM=1  
a70f					call debug_vector  
a70f				endif  
a70f				if BASE_KEV=1  
a70f					rst 8  
a70f				endif  
a70f				endm  
# End of macro CALLMONITOR
a70f				endif 
a70f			;		ld a, 0 
a70f			;		ld (os_view_disable), a 
a70f cd e3 92			call bp_on 
a712			 
a712				CALLMONITOR 
a712				if BASE_CPM=1  
