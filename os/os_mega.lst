12e0			;.to: 
12e0 ed 51			out (c), d 
12e2				 
12e2			;	cp 0 
12e2			;	jr z, .fski 
12e2			;	ld a, 1 
12e2			;	call aDelayInMS 
12e2			 
12e2				; do a brief pause 
12e2			;	push bc 
12e2			;.flo:	 
12e2			;    and     255  	; 7 
