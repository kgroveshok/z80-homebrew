6409					CALLMONITOR 
6409				endif 
6409 cd 7d 0d			call cmp16 
640c 28 06			jr z, .chk_fault1 
640e 11 b3 64			ld de, sfaultso 
6411 c3 63 64			jp .chk_fault 
