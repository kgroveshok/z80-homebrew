1211			;------------------------------------------------------------------------------ 
1211			;     free                                                                    : 
1211			;                                                                             : 
1211			; Description                                                                 : 
1211			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1211			;     returned by malloc, otherwise the behaviour is undefined.               : 
1211			;                                                                             : 
1211			;     Where possible, directly adjacent free blocks will be merged together   : 
1211			;     into larger blocks to help ensure that the heap does not become         : 
1211			;     excessively fragmented.                                                 : 
1211			;                                                                             : 
1211			;     free does not clear or set any other value into the freed space, and    : 
1211			;     therefore its contents may be visible through subsequent malloc's. The  : 
1211			;     caller should clear the freed space as required.                        : 
1211			;                                                                             : 
1211			;     This implementation of free uses the stack exclusively, and is          : 
1211			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1211			;     advisable to disable interrupts before calling free, and recommended    : 
1211			;     to avoid the use of free inside ISRs in general.                        : 
1211			;                                                                             : 
1211			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1211			;                                                                             : 
1211			; Parameters                                                                  : 
1211			;     HL  Pointer to address of first byte of allocation to be freed          : 
1211			;                                                                             : 
1211			; Returns                                                                     : 
1211			;     Nothing                                                                 : 
1211			;                                                                             : 
1211			; Stack frame                                                                 : 
1211			;       |             |                                                       : 
1211			;       +-------------+                                                       : 
1211			;       |     BC      |                                                       : 
1211			;       +-------------+                                                       : 
1211			;       |     DE      |                                                       : 
1211			;       +-------------+                                                       : 
1211			;       |     IX      |                                                       : 
1211			;       +-------------+                                                       : 
1211			;       |  prev_free  |                                                       : 
1211			;   +2  +-------------+                                                       : 
1211			;       |  next_free  |                                                       : 
1211			;   +0  +-------------+                                                       : 
1211			;       |             |                                                       : 
1211			;                                                                             : 
1211			;------------------------------------------------------------------------------ 
1211			free: 
1211 c5			      push  BC 
1212 d5			      push  DE 
1213 dd e5		      push  IX 
1215			 
1215 7c			      ld    A, H                    ; Exit if ptr is null 
1216 b5			      or    L 
1217 ca db 12		      jp    Z, free_early_exit 
121a			 
121a			      ; Set up stack frame 
121a eb			      ex    DE, HL 
121b 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
121e 39			      add   HL, SP 
121f f9			      ld    SP, HL 
1220 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1224 dd 39		      add   IX, SP 
1226			 
1226			      ; The address in HL points to the start of the useable allocated space, 
1226			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1226			      ; address of the block itself. 
1226 eb			      ex    DE, HL 
1227 11 fc ff		      ld    DE, -4 
122a 19			      add   HL, DE 
122b			 
122b			      ; An allocated block must have a null next block pointer in it 
122b 7e			      ld    A, (HL) 
122c 23			      inc   HL 
122d b6			      or    (HL) 
122e c2 d6 12		      jp    NZ, free_done 
1231			 
1231 2b			      dec   HL 
1232			 
1232 44			      ld    B, H                    ; Copy HL to BC 
1233 4d			      ld    C, L 
1234			 
1234			      ; Loop through the free list to find the first block with an address 
1234			      ; higher than the block being freed 
1234 21 0a 80		      ld    HL, free_list 
1237			 
1237			free_find_higher_block: 
1237 5e			      ld    E, (HL)                 ; Load next ptr from free block 
1238 23			      inc   HL 
1239 56			      ld    D, (HL) 
123a 2b			      dec   HL 
123b			 
123b dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
123e dd 72 01		      ld    (IX+1), D 
1241 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1244 dd 74 03		      ld    (IX+3), H 
1247			 
1247 78			      ld    A, B                    ; Check if DE is greater than BC 
1248 ba			      cp    D                       ; Compare MSB first 
1249 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
124b 30 04		      jr    NC, free_find_higher_block_skip 
124d 79			      ld    A, C 
124e bb			      cp    E                       ; Then compare LSB 
124f 38 08		      jr    C, free_found_higher_block 
1251			 
1251			free_find_higher_block_skip: 
1251 7a			      ld    A, D                    ; Reached the end of the free list? 
1252 b3			      or    E 
1253 ca d6 12		      jp    Z, free_done 
1256			 
1256 eb			      ex    DE, HL 
1257			 
1257 18 de		      jr    free_find_higher_block 
1259			 
1259			free_found_higher_block: 
1259			      ; Insert freed block between prev and next free blocks 
1259 71			      ld    (HL), C                 ; Point prev free block to freed block 
125a 23			      inc   HL 
125b 70			      ld    (HL), B 
125c			 
125c 60			      ld    H, B                    ; Point freed block at next free block 
125d 69			      ld    L, C 
125e 73			      ld    (HL), E 
125f 23			      inc   HL 
1260 72			      ld    (HL), D 
1261			 
1261			      ; Check if the freed block is adjacent to the next free block 
1261 23			      inc   HL                      ; Load size of freed block into HL 
1262 5e			      ld    E, (HL) 
1263 23			      inc   HL 
1264 56			      ld    D, (HL) 
1265 eb			      ex    DE, HL 
1266			 
1266 09			      add   HL, BC                  ; Add addr of freed block and its size 
1267			 
1267 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
126a dd 56 01		      ld    D, (IX+1) 
126d			 
126d b7			      or    A                       ; Clear the carry flag 
126e ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1270 20 22		      jr    NZ, free_check_adjacent_to_prev 
1272			 
1272			      ; Freed block is adjacent to next, merge into one bigger block 
1272 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1273 5e			      ld    E, (HL) 
1274 23			      inc   HL 
1275 56			      ld    D, (HL) 
1276 e5			      push  HL                      ; Save ptr to next block for later 
1277			 
1277 60			      ld    H, B                    ; Store ptr from next block into freed block 
1278 69			      ld    L, C 
1279 73			      ld    (HL), E 
127a 23			      inc   HL 
127b 72			      ld    (HL), D 
127c			 
127c e1			      pop   HL                      ; Restore ptr to next block 
127d 23			      inc   HL                      ; Load size of next block into DE 
127e 5e			      ld    E, (HL) 
127f 23			      inc   HL 
1280 56			      ld    D, (HL) 
1281 d5			      push  DE                      ; Save next block size for later 
1282			 
1282 60			      ld    H, B                    ; Load size of freed block into HL 
1283 69			      ld    L, C 
1284 23			      inc   HL 
1285 23			      inc   HL 
1286 5e			      ld    E, (HL) 
1287 23			      inc   HL 
1288 56			      ld    D, (HL) 
1289 eb			      ex    DE, HL 
128a			 
128a d1			      pop   DE                      ; Restore size of next block 
128b 19			      add   HL, DE                  ; Add sizes of both blocks 
128c eb			      ex    DE, HL 
128d			 
128d 60			      ld    H, B                    ; Store new bigger size into freed block 
128e 69			      ld    L, C 
128f 23			      inc   HL 
1290 23			      inc   HL 
1291 73			      ld    (HL), E 
1292 23			      inc   HL 
1293 72			      ld    (HL), D 
1294			 
1294			free_check_adjacent_to_prev: 
1294			      ; Check if the freed block is adjacent to the prev free block 
1294 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1297 dd 66 03		      ld    H, (IX+3) 
129a			 
129a 23			      inc   HL                      ; Size of prev free block into DE 
129b 23			      inc   HL 
129c 5e			      ld    E, (HL) 
129d 23			      inc   HL 
129e 56			      ld    D, (HL) 
129f 2b			      dec   HL 
12a0 2b			      dec   HL 
12a1 2b			      dec   HL 
12a2			 
12a2 19			      add   HL, DE                  ; Add prev block addr and size 
12a3			 
12a3 b7			      or    A                       ; Clear the carry flag 
12a4 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12a6 20 2e		      jr    NZ, free_done 
12a8			 
12a8			      ; Freed block is adjacent to prev, merge into one bigger block 
12a8 60			      ld    H, B                    ; Load next ptr from freed block into DE 
12a9 69			      ld    L, C 
12aa 5e			      ld    E, (HL) 
12ab 23			      inc   HL 
12ac 56			      ld    D, (HL) 
12ad e5			      push  HL                      ; Save freed block ptr for later 
12ae			 
12ae dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12b1 dd 66 03		      ld    H, (IX+3) 
12b4 73			      ld    (HL), E 
12b5 23			      inc   HL 
12b6 72			      ld    (HL), D 
12b7			 
12b7 e1			      pop   HL                      ; Restore freed block ptr 
12b8 23			      inc   HL                      ; Load size of freed block into DE 
12b9 5e			      ld    E, (HL) 
12ba 23			      inc   HL 
12bb 56			      ld    D, (HL) 
12bc d5			      push  DE                      ; Save freed block size for later 
12bd			 
12bd dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
12c0 dd 66 03		      ld    H, (IX+3) 
12c3 23			      inc   HL 
12c4 23			      inc   HL 
12c5 5e			      ld    E, (HL) 
12c6 23			      inc   HL 
12c7 56			      ld    D, (HL) 
12c8			 
12c8 e1			      pop   HL                      ; Add sizes of both blocks 
12c9 19			      add   HL, DE 
12ca eb			      ex    DE, HL 
12cb			 
12cb dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
12ce dd 66 03		      ld    H, (IX+3) 
12d1 23			      inc   HL 
12d2 23			      inc   HL 
12d3 73			      ld    (HL), E 
12d4 23			      inc   HL 
12d5 72			      ld    (HL), D 
12d6			 
12d6			free_done: 
12d6 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
12d9 39			      add   HL, SP 
12da f9			      ld    SP, HL 
12db			 
12db			free_early_exit: 
12db dd e1		      pop   IX 
12dd d1			      pop   DE 
12de c1			      pop   BC 
12df			 
12df c9			      ret 
12e0			 
