6810			;	ld a,e 
6810			;	add d 
6810			;	cp 0    ; any left to do? 
6810				ex de, hl 
6810				jp nz, .start1 
6810				jr .startupend 
6810			 
6810			.startupend1: pop hl 
6810			.startupend: 
6810			 
6810				call clear_display 
6810				call update_display 
6810				ret 
