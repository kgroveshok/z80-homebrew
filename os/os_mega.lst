2070			; My forth kernel 
2070			include "forth_kernel.asm" 
2070			; 
2070			; kernel to the forth OS 
2070			 
2070			DS_TYPE_STR: equ 1     ; string type 
2070			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
2070			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
2070			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
2070			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
2070			 
2070			FORTH_PARSEV1: equ 0 
2070			FORTH_PARSEV2: equ 0 
2070			FORTH_PARSEV3: equ 0 
2070			FORTH_PARSEV4: equ 0 
2070			FORTH_PARSEV5: equ 0 
2070			FORTH_PARSEV6: equ 1 
2070			 
2070			;if FORTH_PARSEV5 
2070			;	FORTH_END_BUFFER: equ 0 
2070			;else 
2070			FORTH_END_BUFFER: equ 127 
2070			;endif 
2070			 
2070			FORTH_TRUE: equ 1 
2070			FORTH_FALSE: equ 0 
2070			 
2070			if FORTH_PARSEV4 
2070			include "forth_stackops.asm" 
2070			endif 
2070			 
