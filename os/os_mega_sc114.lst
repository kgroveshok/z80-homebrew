bff2			    NEXTW 
bff2			 
bff2			.SPIBOb: 
bff2			 
bff2				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
bff2			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
bff2			 
bff2					if DEBUG_FORTH_WORDS_KEY 
bff2						DMARK "SPo" 
bff2						CALLMONITOR 
bff2					endif 
bff2					; get port 
bff2			 
bff2			 
bff2					; get byte to send 
bff2			 
