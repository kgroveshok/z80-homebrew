8fbb				 
8fbb			;	ld a, (tape_tm_freq) 
8fbb			;	ld b, a 
8fbb			;.to: 
8fbb ed 51			out (c), d 
8fbd				 
8fbd			;	cp 0 
8fbd			;	jr z, .fski 
8fbd			;	ld a, 1 
8fbd			;	call aDelayInMS 
8fbd			 
8fbd				; do a brief pause 
8fbd			;	push bc 
8fbd			;.flo:	 
8fbd			;    and     255  	; 7 
8fbd			;    dec     bc      	; 6 
8fbd			;    ld      a,c     	; 4 
8fbd			;    or      b     	; 4 
8fbd			;	djnz .flo 
8fbd			;	pop bc 
8fbd			 
8fbd 2b				dec hl 
8fbe cd 63 8a			call ishlzero 
8fc1 20 f8			jr nz, tape_osc 
8fc3				 
8fc3 c9				ret 
8fc4			 
8fc4			; output a gap period 
8fc4			tape_gap:  
