8fe4			 
8fe4			;Comparing Strings 
8fe4			 
8fe4			;IN    HL     Address of string1. 
8fe4			;      DE     Address of string2. 
8fe4			 
8fe4			; doc given but wrong??? 
8fe4			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
8fe4			;      carry  Set if string1 > string2, reset if string1 <= string2. 
8fe4			; tested 
8fe4			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
8fe4			 
8fe4			strcmp_old: 
8fe4 e5			    PUSH   HL 
8fe5 d5			    PUSH   DE 
8fe6			 
8fe6 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
8fe7 be			    CP     (HL)            ; (want to minimize work). 
8fe8 38 01		    JR     C, Str1IsBigger 
8fea 7e			    LD     A, (HL) 
8feb			 
8feb			Str1IsBigger: 
8feb 4f			    LD     C, A             ; Put length in BC 
8fec 06 00		    LD     B, 0 
8fee 13			    INC    DE              ; Increment pointers to meat of string. 
8fef 23			    INC    HL 
8ff0			 
8ff0			CmpLoop: 
8ff0 1a			    LD     A, (DE)          ; Compare bytes. 
8ff1 ed a1		    CPI 
8ff3 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
8ff5 13			    INC    DE              ; Update pointer. 
8ff6 ea f0 8f		    JP     PE, CmpLoop 
8ff9			 
8ff9 d1			    POP    DE 
8ffa e1			    POP    HL 
8ffb 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
8ffc be			    CP     (HL) 
8ffd c9			    RET 
8ffe			 
8ffe			NoMatch: 
8ffe 2b			    DEC    HL 
8fff be			    CP     (HL)            ; Compare again to affect carry. 
9000 d1			    POP    DE 
9001 e1			    POP    HL 
9002 c9			    RET 
