11f8			;------------------------------------------------------------------------------ 
11f8			;     free                                                                    : 
11f8			;                                                                             : 
11f8			; Description                                                                 : 
11f8			;     Return the space pointed to by HL to the heap. HL must be an address as : 
11f8			;     returned by malloc, otherwise the behaviour is undefined.               : 
11f8			;                                                                             : 
11f8			;     Where possible, directly adjacent free blocks will be merged together   : 
11f8			;     into larger blocks to help ensure that the heap does not become         : 
11f8			;     excessively fragmented.                                                 : 
11f8			;                                                                             : 
11f8			;     free does not clear or set any other value into the freed space, and    : 
11f8			;     therefore its contents may be visible through subsequent malloc's. The  : 
11f8			;     caller should clear the freed space as required.                        : 
11f8			;                                                                             : 
11f8			;     This implementation of free uses the stack exclusively, and is          : 
11f8			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
11f8			;     advisable to disable interrupts before calling free, and recommended    : 
11f8			;     to avoid the use of free inside ISRs in general.                        : 
11f8			;                                                                             : 
11f8			;     NOTE: heap_init must be called before malloc and free can be used.      : 
11f8			;                                                                             : 
11f8			; Parameters                                                                  : 
11f8			;     HL  Pointer to address of first byte of allocation to be freed          : 
11f8			;                                                                             : 
11f8			; Returns                                                                     : 
11f8			;     Nothing                                                                 : 
11f8			;                                                                             : 
11f8			; Stack frame                                                                 : 
11f8			;       |             |                                                       : 
11f8			;       +-------------+                                                       : 
11f8			;       |     BC      |                                                       : 
11f8			;       +-------------+                                                       : 
11f8			;       |     DE      |                                                       : 
11f8			;       +-------------+                                                       : 
11f8			;       |     IX      |                                                       : 
11f8			;       +-------------+                                                       : 
11f8			;       |  prev_free  |                                                       : 
11f8			;   +2  +-------------+                                                       : 
11f8			;       |  next_free  |                                                       : 
11f8			;   +0  +-------------+                                                       : 
11f8			;       |             |                                                       : 
11f8			;                                                                             : 
11f8			;------------------------------------------------------------------------------ 
11f8			free: 
11f8 c5			      push  BC 
11f9 d5			      push  DE 
11fa dd e5		      push  IX 
11fc			 
11fc 7c			      ld    A, H                    ; Exit if ptr is null 
11fd b5			      or    L 
11fe ca c2 12		      jp    Z, free_early_exit 
1201			 
1201			      ; Set up stack frame 
1201 eb			      ex    DE, HL 
1202 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1205 39			      add   HL, SP 
1206 f9			      ld    SP, HL 
1207 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
120b dd 39		      add   IX, SP 
120d			 
120d			      ; The address in HL points to the start of the useable allocated space, 
120d			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
120d			      ; address of the block itself. 
120d eb			      ex    DE, HL 
120e 11 fc ff		      ld    DE, -4 
1211 19			      add   HL, DE 
1212			 
1212			      ; An allocated block must have a null next block pointer in it 
1212 7e			      ld    A, (HL) 
1213 23			      inc   HL 
1214 b6			      or    (HL) 
1215 c2 bd 12		      jp    NZ, free_done 
1218			 
1218 2b			      dec   HL 
1219			 
1219 44			      ld    B, H                    ; Copy HL to BC 
121a 4d			      ld    C, L 
121b			 
121b			      ; Loop through the free list to find the first block with an address 
121b			      ; higher than the block being freed 
121b 21 0a 80		      ld    HL, free_list 
121e			 
121e			free_find_higher_block: 
121e 5e			      ld    E, (HL)                 ; Load next ptr from free block 
121f 23			      inc   HL 
1220 56			      ld    D, (HL) 
1221 2b			      dec   HL 
1222			 
1222 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
1225 dd 72 01		      ld    (IX+1), D 
1228 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
122b dd 74 03		      ld    (IX+3), H 
122e			 
122e 78			      ld    A, B                    ; Check if DE is greater than BC 
122f ba			      cp    D                       ; Compare MSB first 
1230 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
1232 30 04		      jr    NC, free_find_higher_block_skip 
1234 79			      ld    A, C 
1235 bb			      cp    E                       ; Then compare LSB 
1236 38 08		      jr    C, free_found_higher_block 
1238			 
1238			free_find_higher_block_skip: 
1238 7a			      ld    A, D                    ; Reached the end of the free list? 
1239 b3			      or    E 
123a ca bd 12		      jp    Z, free_done 
123d			 
123d eb			      ex    DE, HL 
123e			 
123e 18 de		      jr    free_find_higher_block 
1240			 
1240			free_found_higher_block: 
1240			      ; Insert freed block between prev and next free blocks 
1240 71			      ld    (HL), C                 ; Point prev free block to freed block 
1241 23			      inc   HL 
1242 70			      ld    (HL), B 
1243			 
1243 60			      ld    H, B                    ; Point freed block at next free block 
1244 69			      ld    L, C 
1245 73			      ld    (HL), E 
1246 23			      inc   HL 
1247 72			      ld    (HL), D 
1248			 
1248			      ; Check if the freed block is adjacent to the next free block 
1248 23			      inc   HL                      ; Load size of freed block into HL 
1249 5e			      ld    E, (HL) 
124a 23			      inc   HL 
124b 56			      ld    D, (HL) 
124c eb			      ex    DE, HL 
124d			 
124d 09			      add   HL, BC                  ; Add addr of freed block and its size 
124e			 
124e dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
1251 dd 56 01		      ld    D, (IX+1) 
1254			 
1254 b7			      or    A                       ; Clear the carry flag 
1255 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1257 20 22		      jr    NZ, free_check_adjacent_to_prev 
1259			 
1259			      ; Freed block is adjacent to next, merge into one bigger block 
1259 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
125a 5e			      ld    E, (HL) 
125b 23			      inc   HL 
125c 56			      ld    D, (HL) 
125d e5			      push  HL                      ; Save ptr to next block for later 
125e			 
125e 60			      ld    H, B                    ; Store ptr from next block into freed block 
125f 69			      ld    L, C 
1260 73			      ld    (HL), E 
1261 23			      inc   HL 
1262 72			      ld    (HL), D 
1263			 
1263 e1			      pop   HL                      ; Restore ptr to next block 
1264 23			      inc   HL                      ; Load size of next block into DE 
1265 5e			      ld    E, (HL) 
1266 23			      inc   HL 
1267 56			      ld    D, (HL) 
1268 d5			      push  DE                      ; Save next block size for later 
1269			 
1269 60			      ld    H, B                    ; Load size of freed block into HL 
126a 69			      ld    L, C 
126b 23			      inc   HL 
126c 23			      inc   HL 
126d 5e			      ld    E, (HL) 
126e 23			      inc   HL 
126f 56			      ld    D, (HL) 
1270 eb			      ex    DE, HL 
1271			 
1271 d1			      pop   DE                      ; Restore size of next block 
1272 19			      add   HL, DE                  ; Add sizes of both blocks 
1273 eb			      ex    DE, HL 
1274			 
1274 60			      ld    H, B                    ; Store new bigger size into freed block 
1275 69			      ld    L, C 
1276 23			      inc   HL 
1277 23			      inc   HL 
1278 73			      ld    (HL), E 
1279 23			      inc   HL 
127a 72			      ld    (HL), D 
127b			 
127b			free_check_adjacent_to_prev: 
127b			      ; Check if the freed block is adjacent to the prev free block 
127b dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
127e dd 66 03		      ld    H, (IX+3) 
1281			 
1281 23			      inc   HL                      ; Size of prev free block into DE 
1282 23			      inc   HL 
1283 5e			      ld    E, (HL) 
1284 23			      inc   HL 
1285 56			      ld    D, (HL) 
1286 2b			      dec   HL 
1287 2b			      dec   HL 
1288 2b			      dec   HL 
1289			 
1289 19			      add   HL, DE                  ; Add prev block addr and size 
128a			 
128a b7			      or    A                       ; Clear the carry flag 
128b ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
128d 20 2e		      jr    NZ, free_done 
128f			 
128f			      ; Freed block is adjacent to prev, merge into one bigger block 
128f 60			      ld    H, B                    ; Load next ptr from freed block into DE 
1290 69			      ld    L, C 
1291 5e			      ld    E, (HL) 
1292 23			      inc   HL 
1293 56			      ld    D, (HL) 
1294 e5			      push  HL                      ; Save freed block ptr for later 
1295			 
1295 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1298 dd 66 03		      ld    H, (IX+3) 
129b 73			      ld    (HL), E 
129c 23			      inc   HL 
129d 72			      ld    (HL), D 
129e			 
129e e1			      pop   HL                      ; Restore freed block ptr 
129f 23			      inc   HL                      ; Load size of freed block into DE 
12a0 5e			      ld    E, (HL) 
12a1 23			      inc   HL 
12a2 56			      ld    D, (HL) 
12a3 d5			      push  DE                      ; Save freed block size for later 
12a4			 
12a4 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
12a7 dd 66 03		      ld    H, (IX+3) 
12aa 23			      inc   HL 
12ab 23			      inc   HL 
12ac 5e			      ld    E, (HL) 
12ad 23			      inc   HL 
12ae 56			      ld    D, (HL) 
12af			 
12af e1			      pop   HL                      ; Add sizes of both blocks 
12b0 19			      add   HL, DE 
12b1 eb			      ex    DE, HL 
12b2			 
12b2 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
12b5 dd 66 03		      ld    H, (IX+3) 
12b8 23			      inc   HL 
12b9 23			      inc   HL 
12ba 73			      ld    (HL), E 
12bb 23			      inc   HL 
12bc 72			      ld    (HL), D 
12bd			 
12bd			free_done: 
12bd 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
12c0 39			      add   HL, SP 
12c1 f9			      ld    SP, HL 
12c2			 
12c2			free_early_exit: 
12c2 dd e1		      pop   IX 
12c4 d1			      pop   DE 
12c5 c1			      pop   BC 
12c6			 
12c6 c9			      ret 
