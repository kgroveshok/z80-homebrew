0d8a			subafromhl: 
0d8a			   ; If A=0 do nothing 
0d8a			    ; Otherwise flip A's sign. Since 
0d8a			    ; the upper byte becomes -1, also 
0d8a			    ; substract 1 from H. 
0d8a ed 44		    neg 
0d8c ca 95 0d		    jp    z, Skip 
0d8f 25			    dec   h 
0d90			     
0d90			    ; Now add the low byte as usual 
0d90			    ; Two's complement takes care of 
0d90			    ; ensuring the result is correct 
0d90 85			    add   a, l 
0d91 6f			    ld    l, a 
0d92 8c			    adc   a, h 
0d93 95			    sub   l 
0d94 67			    ld    h, a 
0d95			Skip: 
0d95 c9				ret 
