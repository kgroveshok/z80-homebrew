d539			 
d539			include "forth_startup.asm" 
d539			; Which startup method to use? 
d539			; 
d539			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
d539			; followed by loading of a list of scripts in eeprom 
d539			 
d539			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
d539			; from eeprom 
d539			 
d539			; Select with define in main stubs 
d539			 
d539			if STARTUP_V1 
d539				include "forth_startupv1.asm" 
d539			; Startup script loading version 1 
d539			 
d539			; If SE storage is available first stage is to use the selected file 
d539			; then go through the eeprom list 
d539			 
d539 .. 00		sprompt1: db "Startup load...",0 
d549 .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
d55f			 
d55f			 
d55f			 
d55f			 
d55f			forth_startup: 
d55f 21 ac c2			ld hl, startcmds 
d562 3e 00			ld a, 0 
d564 32 c8 e6			ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
d567			 
d567 e5			.start1:	push hl 
d568 cd 10 88			call clear_display 
d56b 11 39 d5			ld de, sprompt1 
