8d9f			StrictStrCmp: 
8d9f				; Load next chars of each string 
8d9f 1a				ld a, (de) 
8da0 47				ld b, a 
8da1 7e				ld a, (hl) 
8da2				; Compare 
8da2 b8				cp b 
8da3				; Return non-zero if chars don't match 
8da3 c0				ret nz 
8da4				; Check for end of both strings 
8da4 fe 00			cp "\0" 
8da6				; Return if strings have ended 
8da6 c8				ret z 
8da7				; Otherwise, advance to next chars 
8da7 23				inc hl 
8da8 13				inc de 
8da9 18 f4			jr StrictStrCmp 
