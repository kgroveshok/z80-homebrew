1125			; Z80 Malloc and Free Functions 
1125			 
1125			; Malloc Function: 
1125			; Input: 
1125			;   HL: Size of block to allocate 
1125			; Output: 
1125			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1125			 
1125			malloc: 
1125				 
1125			if DEBUG_FORTH_MALLOC_HIGH 
1125			call malloc_guard_entry 
1125			endif 
1125			 
1125			 
1125			 
1125			 
1125					if DEBUG_FORTH_MALLOC 
1125						DMARK "mal" 
1125						CALLMONITOR 
1125					endif 
1125			    push af            ; Save AF register 
1125			    ld a, l            ; Load low byte of size into A 
1125			    or h               ; Check if size is zero 
1125			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1125			 
1125			    ; Allocate memory 
1125			    ld hl, (heap_start) ; Load start of heap into HL 
1125					if DEBUG_FORTH_MALLOC 
1125						DMARK "ma1" 
1125						CALLMONITOR 
1125					endif 
1125			    call malloc_internal ; Call internal malloc function 
1125			    pop af             ; Restore AF register 
1125			if DEBUG_FORTH_MALLOC_HIGH 
1125			call malloc_guard_exit 
1125			call malloc_guard_zerolen 
1125			endif 
1125			    ret                ; Return 
1125			 
1125			; Free Function: 
1125			; Input: 
1125			;   HL: Pointer to memory block to free 
1125			; Output: 
1125			;   None 
1125			 
1125			free: 
1125			    push af            ; Save AF register 
1125			    ld a, l            ; Load low byte of pointer into A 
1125			    or h               ; Check if pointer is NULL 
1125			    jp z, free_exit    ; If pointer is NULL, exit 
1125			 
1125			    ; Free memory 
1125			    ld hl, (heap_start) ; Load start of heap into HL 
1125			    call free_internal  ; Call internal free function 
1125			    pop af             ; Restore AF register 
1125			    ret                ; Return 
1125			 
1125			; Internal Malloc Function: 
1125			; Input: 
1125			;   HL: Size of block to allocate 
1125			; Output: 
1125			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1125			 
1125			malloc_internal: 
1125			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1125			    add hl, bc         ; Add management overhead to requested size 
1125			    ex de, hl          ; Save total size in DE, and keep it in HL 
1125					if DEBUG_FORTH_MALLOC 
1125						DMARK "ma2" 
1125						CALLMONITOR 
1125					endif 
1125			 
1125			    ; Search for free memory block 
1125			    ld de, (heap_end)  ; Load end of heap into DE 
1125			    ld bc, 0           ; Initialize counter 
1125			 
1125					if DEBUG_FORTH_MALLOC 
1125						DMARK "ma2" 
1125						CALLMONITOR 
1125					endif 
1125			malloc_search_loop: 
1125			    ; Check if current block is free 
1125			    ld a, (hl)         ; Load current block's status (free or used) 
1125			;    cp 0               ; Compare with zero (free) 
1125				or a 
1125			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1125			 
1125			    ; Check if current block is large enough 
1125			    ld a, (hl+1)       ; Load high byte of block size 
1125			    cp l               ; Compare with low byte of requested size 
1125			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1125			 
1125			    ld a, (hl+2)       ; Load low byte of block size 
1125			    cp h               ; Compare with high byte of requested size 
1125			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1125			 
1125			    ; Mark block as used 
1125			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1125			 
1125			    ; Calculate remaining space in block 
1125			    ld bc, 0           ; Clear BC 
1125			    add hl, bc         ; Increment HL to point to start of data block 
1125			    add hl, de         ; HL = HL + DE (total size) 
1125			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1125			    add hl, bc         ; Add management overhead to start of data block 
1125			 
1125			    ; Save pointer to allocated block in HL 
1125			if DEBUG_FORTH_MALLOC_HIGH 
1125						DMARK "ma5" 
1125			call malloc_guard_exit 
1125			call malloc_guard_zerolen 
1125			endif 
1125			    ret 
1125			 
1125			malloc_skip_block_check: 
1125			    ; Move to the next block 
1125			    ld bc, 3           ; Size of management overhead 
1125			    add hl, bc         ; Move to the next block 
1125			    inc de             ; Increment counter 
1125			 
1125			    ; Check if we have reached the end of heap 
1125			    ld a, e            ; Load low byte of heap end address 
1125			    cp (hl)            ; Compare with low byte of current address 
1125			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1125			    ld a, d            ; Load high byte of heap end address 
1125			;    cp 0               ; Check if it's zero (end of memory) 
1125				or a 
1125			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1125			 
1125			    ; If we reached here, allocation failed 
1125			    xor a              ; Set result to NULL 
1125			if DEBUG_FORTH_MALLOC_HIGH 
1125						DMARK "ma6" 
1125			call malloc_guard_exit 
1125			call malloc_guard_zerolen 
1125			endif 
1125			    ret 
1125			malloc_exit: 
1125			if DEBUG_FORTH_MALLOC_HIGH 
1125						DMARK "ma7" 
1125			call malloc_guard_exit 
1125			call malloc_guard_zerolen 
1125			endif 
1125			    ret 
1125			 
1125			; Internal Free Function: 
1125			; Input: 
1125			;   HL: Pointer to memory block to free 
1125			; Output: 
1125			;   None 
1125			 
1125			free_internal: 
1125			    ld de, (heap_start) ; Load start of heap into DE 
1125			    ld bc, 0            ; Initialize counter 
1125			 
1125			free_search_loop: 
1125			    ; Check if current block contains the pointer 
1125			    ld a, l             ; Load low byte of pointer 
1125			    cp (hl+1)           ; Compare with high byte of current block's address 
1125			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1125			    ld a, h             ; Load high byte of pointer 
1125			    cp (hl+2)           ; Compare with low byte of current block's address 
1125			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1125			 
1125			    ; Mark block as free 
1125			    ld (hl), 0          ; Set status byte to indicate free block 
1125			    ret                 ; Return 
1125			 
1125			free_skip_block_check: 
1125			    ; Move to the next block 
1125			    ld bc, 3            ; Size of management overhead 
1125			    add hl, bc          ; Move to the next block 
1125			    inc de              ; Increment counter 
1125			 
1125			    ; Check if we have reached the end of heap 
1125			    ld a, e             ; Load low byte of heap end address 
1125			    cp (hl)             ; Compare with low byte of current address 
1125			    jr nz, free_search_loop  ; If not equal, continue searching 
1125			    ld a, d             ; Load high byte of heap end address 
1125			;    cp 0                ; Check if it's zero (end of memory) 
1125				or a 
1125			    jr nz, free_search_loop  ; If not zero, continue searching 
1125			 
1125			    ; If we reached here, pointer is not found in heap 
1125			    ret 
1125			 
1125			free_exit: 
1125			    ret                 ; Return 
1125			 
1125			; Define heap start and end addresses 
1125			;heap_start:    .dw 0xC000   ; Start of heap 
1125			;heap_end:      .dw 0xE000   ; End of heap 
1125			 
1125			endif 
