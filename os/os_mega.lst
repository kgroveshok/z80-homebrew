0276				include "firmware_seeprom.asm"  
0276			; 
0276			; persisent storage interface via microchip serial eeprom 
0276			 
0276			; port a pio 2 
0276			; pa 7 - si 
0276			; pa 6 - sclk  
0276			; pa 5 - so 
0276			; pa 4 - cs 
0276			; pa 3 - cs 
0276			; pa 2 - cs 
0276			; pa 1 - cs 
0276			; pa 0 - cs 
0276			; 
0276			; TODO get block 
0276			; TODO save block 
0276			; TODO load file 
0276			; TODO save file 
0276			; TODO get dir  
0276			 
0276			;  
0276			storage_adata: equ Device_C    ; device c port a - onboard storage 
0276			storage_actl: equ Device_C+2     ; device c port a 
0276			storage_bdata: equ Device_C+1    ; device c port b - ext storage cart 
0276			storage_bctl: equ Device_C+3     ; device c port b 
0276			 
0276			 
0276			; TODO move these to hardware driver file 
0276			 
0276			;STORE_BLOCK_PHY:   equ 64    ; physical block size on storage   64byte on 256k eeprom 
0276			;STORE_DEVICE_MAXBLOCKS:  equ  512 ; how many blocks are there on this storage device 
0276			; storage bank file system format 
0276			; 
0276			; first page of bank: 
0276			; 	addr 0 - status check 
0276			;       addr 1 - write protect flag 
0276			;       addr 2 - zero if all data is held on this device. >0 - next device number (not used right now) 
0276			;       addr 3 - last file id (to save on scanning for spare file id). or could have bit mask of file ids in use????  
0276			;         TODO see if scanning whole of for available next file id is fast enough 
0276			;	addr 4 > zero term string of bank label 
0276			; 
0276			;        
0276			;  
0276			; first page of any file: 
0276			;      byte 0 - file id  
0276			;      byte 1-17 - fixed file name  
0276			;      byte 18-end of page - extra meta data tba (date? description? keywords?) 
0276			; 
0276			; other pages of any file: 
0276			;      byte 0 - file id 
0276			;      byte 1> - file data 
0276			; 
0276			; TODO depending on how long it takes to load a file in if scanning the whole bank for the file id, could speed it up by having last file page flag??? high bit? that would max 127 files 
0276			;  
0276			; TODO need a bank format which places a 0 in each of the first byte of every page and updates the meta in page 0 
0276			 
0276			 
0276			;storage_so_bit: 5 
0276			;storage_si_bit: 7 
0276			;storage_sclk_bit: 6 
