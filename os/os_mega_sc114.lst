8eeb			;------------------------------------------------------------------------------ 
8eeb			;     free                                                                    : 
8eeb			;                                                                             : 
8eeb			; Description                                                                 : 
8eeb			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8eeb			;     returned by malloc, otherwise the behaviour is undefined.               : 
8eeb			;                                                                             : 
8eeb			;     Where possible, directly adjacent free blocks will be merged together   : 
8eeb			;     into larger blocks to help ensure that the heap does not become         : 
8eeb			;     excessively fragmented.                                                 : 
8eeb			;                                                                             : 
8eeb			;     free does not clear or set any other value into the freed space, and    : 
8eeb			;     therefore its contents may be visible through subsequent malloc's. The  : 
8eeb			;     caller should clear the freed space as required.                        : 
8eeb			;                                                                             : 
8eeb			;     This implementation of free uses the stack exclusively, and is          : 
8eeb			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8eeb			;     advisable to disable interrupts before calling free, and recommended    : 
8eeb			;     to avoid the use of free inside ISRs in general.                        : 
8eeb			;                                                                             : 
8eeb			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8eeb			;                                                                             : 
8eeb			; Parameters                                                                  : 
8eeb			;     HL  Pointer to address of first byte of allocation to be freed          : 
8eeb			;                                                                             : 
8eeb			; Returns                                                                     : 
8eeb			;     Nothing                                                                 : 
8eeb			;                                                                             : 
8eeb			; Stack frame                                                                 : 
8eeb			;       |             |                                                       : 
8eeb			;       +-------------+                                                       : 
8eeb			;       |     BC      |                                                       : 
8eeb			;       +-------------+                                                       : 
8eeb			;       |     DE      |                                                       : 
8eeb			;       +-------------+                                                       : 
8eeb			;       |     IX      |                                                       : 
8eeb			;       +-------------+                                                       : 
8eeb			;       |  prev_free  |                                                       : 
8eeb			;   +2  +-------------+                                                       : 
8eeb			;       |  next_free  |                                                       : 
8eeb			;   +0  +-------------+                                                       : 
8eeb			;       |             |                                                       : 
8eeb			;                                                                             : 
8eeb			;------------------------------------------------------------------------------ 
8eeb			free: 
8eeb c5			      push  BC 
8eec d5			      push  DE 
8eed dd e5		      push  IX 
