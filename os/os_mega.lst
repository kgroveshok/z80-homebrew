534e			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
534e			; | 
534e			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
534e			; | |  
534e			; | | e.g. 
534e			; | |         #30 a var ! 
534e			; | |         a var @ . 
534e			; | |   
534e			; | |     Displays the number 30 
534e			; | | 
534e			; | | Each variable pointer is a word so can use for any words that use that:  
534e			; | |  
534e			; | | e.g. 
534e			; | |  
534e			; | |         #30 a var 2! 
534e			; | |         a var 2@ . 
534e			; | |   
534e			; | |     Displays the number 30 
534e			; | |  
534e			; | | > [!NOTE]  
534e			; ! | > If a full string is passed then only the first char is looked at 
534e			; | | > Any other char could exceed bounds checks!  
534e			; | | > 
534e			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
534e			 
534e					if DEBUG_FORTH_WORDS_KEY 
534e						DMARK "VAR" 
534e				if DEMARK_VERSION = 1  
