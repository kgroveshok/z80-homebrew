0b56			; Out: BC = result, HL = rest 
0b56			; 
0b56			Div16: 
0b56 21 00 00		    ld hl,0 
0b59 78			    ld a,b 
0b5a 06 08		    ld b,8 
0b5c			Div16_Loop1: 
0b5c 17			    rla 
0b5d ed 6a		    adc hl,hl 
0b5f ed 52		    sbc hl,de 
0b61 30 01		    jr nc,Div16_NoAdd1 
0b63 19			    add hl,de 
0b64			Div16_NoAdd1: 
0b64 10 f6		    djnz Div16_Loop1 
0b66 17			    rla 
0b67 2f			    cpl 
0b68 47			    ld b,a 
0b69 79			    ld a,c 
0b6a 48			    ld c,b 
0b6b 06 08		    ld b,8 
0b6d			Div16_Loop2: 
0b6d 17			    rla 
0b6e ed 6a		    adc hl,hl 
0b70 ed 52		    sbc hl,de 
0b72 30 01		    jr nc,Div16_NoAdd2 
0b74 19			    add hl,de 
0b75			Div16_NoAdd2: 
