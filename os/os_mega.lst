10ec			 
10ec			;Comparing Strings 
10ec			 
10ec			;IN    HL     Address of string1. 
10ec			;      DE     Address of string2. 
10ec			 
10ec			; doc given but wrong??? 
10ec			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10ec			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10ec			; tested 
10ec			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10ec			 
10ec			strcmp_old: 
10ec e5			    PUSH   HL 
10ed d5			    PUSH   DE 
10ee			 
10ee 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10ef be			    CP     (HL)            ; (want to minimize work). 
10f0 38 01		    JR     C, Str1IsBigger 
10f2 7e			    LD     A, (HL) 
10f3			 
10f3			Str1IsBigger: 
10f3 4f			    LD     C, A             ; Put length in BC 
10f4 06 00		    LD     B, 0 
10f6 13			    INC    DE              ; Increment pointers to meat of string. 
10f7 23			    INC    HL 
10f8			 
10f8			CmpLoop: 
10f8 1a			    LD     A, (DE)          ; Compare bytes. 
10f9 ed a1		    CPI 
10fb 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10fd 13			    INC    DE              ; Update pointer. 
10fe ea f8 10		    JP     PE, CmpLoop 
1101			 
1101 d1			    POP    DE 
1102 e1			    POP    HL 
1103 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
1104 be			    CP     (HL) 
1105 c9			    RET 
1106			 
1106			NoMatch: 
1106 2b			    DEC    HL 
1107 be			    CP     (HL)            ; Compare again to affect carry. 
1108 d1			    POP    DE 
1109 e1			    POP    HL 
110a c9			    RET 
