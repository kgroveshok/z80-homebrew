247c					ld (debug_mark+1),a  
247c					ld a, (.dmark+2)  
247c					ld (debug_mark+2),a  
247c				endif  
247c 18 04			jr .pastdmark  
247e ..			.dmark: db "HEP"  
2481				if DEMARK_VERSION = 1  
