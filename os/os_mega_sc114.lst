91d8			 
91d8			.foundemptyblock:	 
91d8					if DEBUG_FORTH_MALLOC_INT 
91d8						DMARK "mme" 
91d8						CALLMONITOR 
91d8					endif 
91d8			 
91d8			; TODO has block enough space if reusing??? 
91d8			 
91d8				;  
91d8			 
91d8			; see if this block has been previously used 
91d8				inc hl 
91d8				ld a, (hl) 
91d8				dec hl 
91d8			;	cp 0 
91d8				or a 
91d8				jr z, .newblock 
91d8			 
91d8					if DEBUG_FORTH_MALLOC_INT 
91d8						DMARK "meR" 
91d8						CALLMONITOR 
91d8					endif 
91d8			 
91d8			; no reusing previously allocated block 
91d8			 
91d8			; is it smaller than previously used? 
91d8				 
91d8				inc hl    ; move to size 
91d8				ld a, c 
91d8				sub (hl)        ; we want c < (hl) 
91d8				dec hl    ; move back to marker 
91d8			        jr z, .findblock 
91d8			 
91d8				; update with the new size which should be lower 
91d8			 
91d8			        ;inc  hl   ; negate next move. move back to size  
91d8			 
91d8			.newblock: 
91d8				; need to be at marker here 
91d8			 
91d8					if DEBUG_FORTH_MALLOC_INT 
91d8						DMARK "meN" 
91d8						CALLMONITOR 
91d8					endif 
91d8			 
91d8			 
91d8				ld a, c 
91d8			 
91d8				ld (free_list+3), a	 ; flag resume from last malloc  
91d8				ld (free_list), hl    ; save out last location 
91d8			 
91d8			 
91d8				;inc a     ; space for length byte 
91d8				ld (hl), a     ; save block in use marker 
91d8			 
91d8				inc hl   ; move to space marker 
91d8				ld (hl), a    ; save new space 
91d8			 
91d8				inc hl   ; move to start of allocated area 
91d8				 
91d8			;	push hl     ; save where we are - 1  
91d8			 
91d8			;	inc hl  ; move past zero index  
91d8				; skip space to set down new marker 
91d8			 
91d8				; provide some extra space for now 
91d8			 
91d8				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
91d8				inc a 
91d8				inc a 
91d8			 
91d8				push hl   ; save where we are in the node block 
91d8			 
91d8				call addatohl 
91d8			 
91d8				; write linked list point 
91d8			 
91d8				pop de     ; get our node position 
91d8				ex de, hl 
91d8			 
91d8				ld (hl), e 
91d8				inc hl 
91d8				ld (hl), d 
91d8			 
91d8				inc hl 
91d8			 
91d8				; now at start of allocated data so save pointer 
91d8			 
91d8				push hl 
91d8			 
91d8				; jump to position of next node and setup empty header in DE 
91d8			 
91d8				ex de, hl 
91d8			 
91d8			;	inc hl ; move past end of block 
91d8			 
91d8			;	ld a, 0 
91d8				ld (hl), 0   ; empty marker 
91d8				inc hl 
91d8				ld (hl), 0   ; size 
91d8				inc hl  
91d8				ld (hl), 0   ; ptr 
91d8				inc hl 
91d8				ld (hl), 0   ; ptr 
91d8			 
91d8			 
91d8				pop hl 
91d8			 
91d8					if DEBUG_FORTH_MALLOC_INT 
91d8						DMARK "mmr" 
91d8						CALLMONITOR 
91d8					endif 
