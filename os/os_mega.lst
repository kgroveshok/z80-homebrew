74fa			;            DB  10001b  
74fa			;            DB  11111b  
74fa			;            DB  11111b  
74fa			;            DB  11111b  
74fa			;            DB  11111b  
74fa			;; Character 0x01 = Bluetooth icon  
74fa			;            DB  01100b  
74fa			;            DB  01010b  
74fa			;            DB  11100b  
74fa			;            DB  01000b  
74fa			;            DB  11100b  
74fa			;            DB  01010b  
74fa			;            DB  01100b  
