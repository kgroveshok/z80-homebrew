8de2			malloc_guard_zerolen: 
8de2				push hl 
8de2				push de 
8de2				push af 
8de2			 
8de2				ld de, 0 
8de2			        call cmp16 
8de2				jr nz, .lowalloz 
8de2			 
8de2				push hl 
8de2				push de 
8de2					ld hl, display_fb0 
8de2					ld (display_fb_active), hl 
8de2				call clear_display 
8de2				ld a, 0 
8de2				ld de, .malloczero 
8de2				call str_at_display 
8de2				call update_display 
8de2				call delay1s 
8de2				call delay1s 
8de2				call bp_on 
8de2			;	ld a, 0 
8de2			;	ld (os_view_disable), a 
8de2			 
8de2				pop de 
8de2				pop hl 
8de2			 
8de2				 
8de2			 
8de2				CALLMONITOR 
8de2			.lowalloz: 
8de2			 
8de2			 
8de2				pop af 
8de2				pop de 
8de2				pop hl 
8de2			ret 
8de2			 
8de2			malloc_guard_entry: 
8de2				push hl 
8de2				push de 
8de2				push af 
8de2			 
8de2			 	or a      ;clear carry flag 
8de2				push hl 
8de2				ld de, 255 
8de2				sbc hl, de 
8de2				jr c, .lowalloc 
8de2			 
8de2				push de 
8de2					ld hl, display_fb0 
8de2					ld (display_fb_active), hl 
8de2				call clear_display 
8de2				ld a, 0 
8de2				ld de, .mallocsize 
8de2				call str_at_display 
8de2				call update_display 
8de2				call delay1s 
8de2				call delay1s 
8de2			;	ld a, 0 
8de2			;	ld (os_view_disable), a 
8de2				call bp_on 
8de2			 
8de2				pop de 
8de2				pop hl 
8de2			 
8de2				 
8de2			 
8de2				CALLMONITOR 
8de2				jr .lowdone 
8de2			.lowalloc: 
8de2			 
8de2			 
8de2				pop hl 
8de2			.lowdone:	pop af 
8de2				pop de 
8de2				pop hl 
8de2			ret 
8de2			 
8de2			malloc_guard_exit: 
8de2				push hl 
8de2				push de 
8de2				push af 
8de2			 
8de2			 	or a      ;clear carry flag 
8de2				push hl 
8de2				ld de, 255 
8de2				sbc hl, de 
8de2				jr c, .lowallocx 
8de2			 
8de2				push de 
8de2					ld hl, display_fb0 
8de2					ld (display_fb_active), hl 
8de2				call clear_display 
8de2				ld a, 0 
8de2				ld de, .mallocasize 
8de2				call str_at_display 
8de2				call update_display 
8de2				call delay1s 
8de2				call delay1s 
8de2			;	ld a, 0 
8de2			;	ld (os_view_disable), a 
8de2				call bp_on 
8de2				pop de 
8de2				pop hl 
8de2			 
8de2				CALLMONITOR 
8de2				jr .lowdonex 
8de2			.lowallocx: 
8de2			 
8de2				pop hl 
8de2			.lowdonex:	pop af 
8de2				pop de 
8de2				pop hl 
8de2			ret 
