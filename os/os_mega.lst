1f9a			FORTH_CHK_DSP_UNDER: macro 
1f9a				push hl 
1f9a				push de 
1f9a				ld hl,(cli_data_sp) 
1f9a				ld de, cli_data_stack 
1f9a				call cmp16 
1f9a				jp c, fault_dsp_under 
1f9a				pop de 
1f9a				pop hl 
1f9a				endm 
1f9a			 
1f9a			 
1f9a			FORTH_CHK_RSP_UNDER: macro 
