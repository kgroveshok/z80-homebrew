bc0d			 
bc0d					ld a, l 
bc0d					if DEBUG_FORTH_WORDS 
bc0d						DMARK "CDV" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d			;		cp 0 
bc0d					or a 
bc0d					jr z, .cset 
bc0d					cp 1 
bc0d					jr nz, .c2 
bc0d					res 0, c 
bc0d			.c2:		cp 2 
bc0d					jr nz, .c3 
bc0d					res 1, c 
bc0d			.c3:		cp 3 
bc0d					jr nz, .c4 
bc0d					res 2, c 
bc0d			.c4:		cp 4 
bc0d					jr nz, .c5 
bc0d					res 3, c 
bc0d			.c5:		cp 5 
bc0d					jr nz, .c6 
bc0d					res 4, c 
bc0d			.c6:		cp 6 
bc0d					jr nz, .c7 
bc0d					res 5, c 
bc0d			.c7:		cp 7 
bc0d					jr nz, .c8 
bc0d					res 6, c 
bc0d			.c8:		cp 8 
bc0d					jr nz, .cset 
bc0d					res 7, c 
bc0d			.cset:		ld a, c 
bc0d					ld (spi_cartdev),a 
bc0d			 
bc0d					if DEBUG_FORTH_WORDS 
bc0d						DMARK "CD2" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d			 
bc0d					; set default SPI clk pulse time as 10ms for CARTDEV use 
bc0d			 
bc0d					ld a, $0a 
bc0d					ld (spi_clktime), a 
bc0d					NEXTW 
bc0d			endif 
