10f8			StrictStrCmp: 
10f8				; Load next chars of each string 
10f8 1a				ld a, (de) 
10f9 47				ld b, a 
10fa 7e				ld a, (hl) 
10fb				; Compare 
10fb b8				cp b 
10fc				; Return non-zero if chars don't match 
10fc c0				ret nz 
10fd				; Check for end of both strings 
10fd fe 00			cp "\0" 
10ff				; Return if strings have ended 
10ff c8				ret z 
1100				; Otherwise, advance to next chars 
1100 23				inc hl 
1101 13				inc de 
1102 18 f4			jr StrictStrCmp 
1104			 
