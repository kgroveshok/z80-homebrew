232a			user_word_eol:  
232a				; hl contains the pointer to where to create a linked list item from the end 
232a				; of the user dict to continue on at the system word dict 
232a				 
232a				; poke the stub of the word list linked list to repoint to rom words 
232a			 
232a				; stub format 
232a				; db   word id 
232a				; dw    link to next word 
232a			        ; db char length of token 
232a				; db string + 0 term 
232a				; db exec code....  
232a			 
232a			;	ld a, WORD_SYS_ROOT     ; root word 
232a 36 00			ld (hl), WORD_SYS_ROOT		; word id 
232c 23				inc hl 
232d			 
232d 11 d6 24			ld de, sysdict 
2330 73				ld (hl), e		; next word link ie system dict 
2331 23				inc hl 
2332 72				ld (hl), d		; next word link ie system dict 
2333 23				inc hl	 
2334			 
2334			;	ld (hl), sysdict		; next word link ie system dict 
2334			;	inc hl 
2334			;	inc hl 
2334			 
2334			;	inc hl 
2334			;	inc hl 
2334			 
2334			;	ld a, 2			; word length is 0 
2334 36 02			ld (hl), 2 
2336 23				inc hl 
2337			 
2337			;	ld a, '~'			; word length is 0 
2337 36 7e			ld (hl), '~' 
2339 23				inc hl 
233a			;	ld a, 0			; save empty word 
233a 36 00			ld (hl), 0 
233c			 
233c c9				ret 
