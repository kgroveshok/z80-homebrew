8f51			 
8f51 60			      ld    H, B                    ; Store ptr from next block into freed block 
8f52 69			      ld    L, C 
8f53 73			      ld    (HL), E 
8f54 23			      inc   HL 
8f55 72			      ld    (HL), D 
