8de2			if MALLOC_2 
8de2			; Z80 Malloc and Free Functions 
8de2			 
8de2			; Malloc Function: 
8de2			; Input: 
8de2			;   HL: Size of block to allocate 
8de2			; Output: 
8de2			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8de2			 
8de2			malloc: 
8de2				 
8de2			if DEBUG_FORTH_MALLOC_HIGH 
8de2			call malloc_guard_entry 
8de2			endif 
8de2			 
8de2			 
8de2			 
8de2			 
8de2					if DEBUG_FORTH_MALLOC 
8de2						DMARK "mal" 
8de2						CALLMONITOR 
8de2					endif 
8de2			    push af            ; Save AF register 
8de2			    ld a, l            ; Load low byte of size into A 
8de2			    or h               ; Check if size is zero 
8de2			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
8de2			 
8de2			    ; Allocate memory 
8de2			    ld hl, (heap_start) ; Load start of heap into HL 
8de2					if DEBUG_FORTH_MALLOC 
8de2						DMARK "ma1" 
8de2						CALLMONITOR 
8de2					endif 
8de2			    call malloc_internal ; Call internal malloc function 
8de2			    pop af             ; Restore AF register 
8de2			if DEBUG_FORTH_MALLOC_HIGH 
8de2			call malloc_guard_exit 
8de2			call malloc_guard_zerolen 
8de2			endif 
8de2			    ret                ; Return 
8de2			 
8de2			; Free Function: 
8de2			; Input: 
8de2			;   HL: Pointer to memory block to free 
8de2			; Output: 
8de2			;   None 
8de2			 
8de2			free: 
8de2			    push af            ; Save AF register 
8de2			    ld a, l            ; Load low byte of pointer into A 
8de2			    or h               ; Check if pointer is NULL 
8de2			    jp z, free_exit    ; If pointer is NULL, exit 
8de2			 
8de2			    ; Free memory 
8de2			    ld hl, (heap_start) ; Load start of heap into HL 
8de2			    call free_internal  ; Call internal free function 
8de2			    pop af             ; Restore AF register 
8de2			    ret                ; Return 
8de2			 
8de2			; Internal Malloc Function: 
8de2			; Input: 
8de2			;   HL: Size of block to allocate 
8de2			; Output: 
8de2			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
8de2			 
8de2			malloc_internal: 
8de2			    ld bc, 2           ; Number of bytes to allocate for management overhead 
8de2			    add hl, bc         ; Add management overhead to requested size 
8de2			    ex de, hl          ; Save total size in DE, and keep it in HL 
8de2					if DEBUG_FORTH_MALLOC 
8de2						DMARK "ma2" 
8de2						CALLMONITOR 
8de2					endif 
8de2			 
8de2			    ; Search for free memory block 
8de2			    ld de, (heap_end)  ; Load end of heap into DE 
8de2			    ld bc, 0           ; Initialize counter 
8de2			 
8de2					if DEBUG_FORTH_MALLOC 
8de2						DMARK "ma2" 
8de2						CALLMONITOR 
8de2					endif 
8de2			malloc_search_loop: 
8de2			    ; Check if current block is free 
8de2			    ld a, (hl)         ; Load current block's status (free or used) 
8de2			;    cp 0               ; Compare with zero (free) 
8de2				or a 
8de2			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
8de2			 
8de2			    ; Check if current block is large enough 
8de2			    ld a, (hl+1)       ; Load high byte of block size 
8de2			    cp l               ; Compare with low byte of requested size 
8de2			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
8de2			 
8de2			    ld a, (hl+2)       ; Load low byte of block size 
8de2			    cp h               ; Compare with high byte of requested size 
8de2			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
8de2			 
8de2			    ; Mark block as used 
8de2			    ld (hl), 0xFF      ; Set status byte to indicate used block 
8de2			 
8de2			    ; Calculate remaining space in block 
8de2			    ld bc, 0           ; Clear BC 
8de2			    add hl, bc         ; Increment HL to point to start of data block 
8de2			    add hl, de         ; HL = HL + DE (total size) 
8de2			    ld bc, 1           ; Number of bytes to allocate for management overhead 
8de2			    add hl, bc         ; Add management overhead to start of data block 
8de2			 
8de2			    ; Save pointer to allocated block in HL 
8de2			if DEBUG_FORTH_MALLOC_HIGH 
8de2						DMARK "ma5" 
8de2			call malloc_guard_exit 
8de2			call malloc_guard_zerolen 
8de2			endif 
8de2			    ret 
8de2			 
8de2			malloc_skip_block_check: 
8de2			    ; Move to the next block 
8de2			    ld bc, 3           ; Size of management overhead 
8de2			    add hl, bc         ; Move to the next block 
8de2			    inc de             ; Increment counter 
8de2			 
8de2			    ; Check if we have reached the end of heap 
8de2			    ld a, e            ; Load low byte of heap end address 
8de2			    cp (hl)            ; Compare with low byte of current address 
8de2			    jr nz, malloc_search_loop  ; If not equal, continue searching 
8de2			    ld a, d            ; Load high byte of heap end address 
8de2			;    cp 0               ; Check if it's zero (end of memory) 
8de2				or a 
8de2			    jr nz, malloc_search_loop  ; If not zero, continue searching 
8de2			 
8de2			    ; If we reached here, allocation failed 
8de2			    xor a              ; Set result to NULL 
8de2			if DEBUG_FORTH_MALLOC_HIGH 
8de2						DMARK "ma6" 
8de2			call malloc_guard_exit 
8de2			call malloc_guard_zerolen 
8de2			endif 
8de2			    ret 
8de2			malloc_exit: 
8de2			if DEBUG_FORTH_MALLOC_HIGH 
8de2						DMARK "ma7" 
8de2			call malloc_guard_exit 
8de2			call malloc_guard_zerolen 
8de2			endif 
8de2			    ret 
8de2			 
8de2			; Internal Free Function: 
8de2			; Input: 
8de2			;   HL: Pointer to memory block to free 
8de2			; Output: 
8de2			;   None 
8de2			 
8de2			free_internal: 
8de2			    ld de, (heap_start) ; Load start of heap into DE 
8de2			    ld bc, 0            ; Initialize counter 
8de2			 
8de2			free_search_loop: 
8de2			    ; Check if current block contains the pointer 
8de2			    ld a, l             ; Load low byte of pointer 
8de2			    cp (hl+1)           ; Compare with high byte of current block's address 
8de2			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8de2			    ld a, h             ; Load high byte of pointer 
8de2			    cp (hl+2)           ; Compare with low byte of current block's address 
8de2			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
8de2			 
8de2			    ; Mark block as free 
8de2			    ld (hl), 0          ; Set status byte to indicate free block 
8de2			    ret                 ; Return 
8de2			 
8de2			free_skip_block_check: 
8de2			    ; Move to the next block 
8de2			    ld bc, 3            ; Size of management overhead 
8de2			    add hl, bc          ; Move to the next block 
8de2			    inc de              ; Increment counter 
8de2			 
8de2			    ; Check if we have reached the end of heap 
8de2			    ld a, e             ; Load low byte of heap end address 
8de2			    cp (hl)             ; Compare with low byte of current address 
8de2			    jr nz, free_search_loop  ; If not equal, continue searching 
8de2			    ld a, d             ; Load high byte of heap end address 
8de2			;    cp 0                ; Check if it's zero (end of memory) 
8de2				or a 
8de2			    jr nz, free_search_loop  ; If not zero, continue searching 
8de2			 
8de2			    ; If we reached here, pointer is not found in heap 
8de2			    ret 
8de2			 
8de2			free_exit: 
8de2			    ret                 ; Return 
8de2			 
