249a			; the core word dictionary v4 
249a			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
249a			 
249a			; this is a linked list for each of the system words used 
249a			; user defined words will follow the same format but will be in ram 
249a			 
249a			 
249a			; 
249a			; 
249a			; define linked list: 
249a			; 
249a			; 1. compiled byte op code 
249a			; 2. len of text word 
249a			; 3. text word 
249a			; 4. ptr to next dictionary word 
249a			; 5. asm, calls etc for the word 
249a			; 
249a			;  if 1 == 0 then last word in dict  
249a			;   
249a			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
249a			;  
249a			;  
249a			; create basic standard set of words 
249a			; 
249a			;  
249a			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
249a			; 2DUP 2DROP 2SWAP  
249a			; @ C@ - get byte  
249a			; ! C! - store byte 
249a			; 0< true if less than zero 
249a			; 0= true if zero 
249a			; < >  
249a			; = true if same 
249a			; variables 
249a			 
249a			 
249a			; Hardware specific words I may need 
249a			; 
249a			; IN OUT  
249a			; calls to key util functions 
249a			; calls to hardward abstraction stuff 
249a			; easy control of frame buffers and lcd i/o 
249a			; keyboard  
249a			 
249a			 
