8c80 4f			    ld    c, a    ; L = A+L 
8c81 88			    adc   a, b    ; A = A+L+H+carry 
8c82 91			    sub   c       ; A = H+carry 
8c83 47			    ld    b, a    ; H = H+carry 
8c84 c9			ret 
