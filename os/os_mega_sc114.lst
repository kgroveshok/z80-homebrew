bf33					ld a, (.dmark+2)  
bf33					ld (debug_mark+2),a  
bf33				endif  
bf33 18 04			jr .pastdmark  
bf35 ..			.dmark: db "VAR"  
bf38				if DEMARK_VERSION = 1  
bf38 00					db 0  
bf39				endif  
bf39				if DEMARK_VERSION = 1  
bf39 e1			.pastdmark: pop hl  
bf3a				endif  
