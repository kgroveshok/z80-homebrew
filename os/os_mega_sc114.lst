a456			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a456			; | | At start the current various registers will be displayed with contents. 
a456			; | | Top right corner will show the most recent debug marker seen. 
a456			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a456			; | | and the return stack pointer (RSP). 
a456			; | | Pressing: 
a456			; | |  
a456			; | |    1 - Initial screen 
a456			; | |  
a456			; | |    2 - Display a data dump of HL 
a456			; | |  
a456			; | |    3 - Display a data dump of DE 
a456			; | |  
a456			; | |    4 - Display a data dump of BC 
a456			; | |  
a456			; | |    5 - Display a data dump of HL 
a456			; | |  
a456			; | |    6 - Display a data dump of DSP 
a456			; | |  
a456			; | |    7 - Display a data dump of RSP 
a456			; | |  
a456			; | |    8 - Display a data dump of what is at DSP 
a456			; | |  
a456			; | |    9 - Display a data dump of what is at RSP 
a456			; | |  
a456			; | |    0 - Exit monitor and continue running. This will also enable break points 
a456			; | |  
a456			; | |    * - Disable break points 
a456			; | |  
a456			; | |    # - Enter traditional monitor mode 
a456			; | |  
a456			; | | 
a456			; | | Monitor Mode 
a456			; | | ------------ 
a456			; | | A prompt of '>' will be shown for various commands: 
a456			; | |  
a456			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a456			; | |  
a456			; | |    C - Continue display a data dump from the last set address 
a456			; | |  
a456			; | |    M xxxx - Set start of memory edit at address xx 
a456			; | |  
a456			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a456			; | |  
a456			; | |    G xxxx - Exec code at specific address 
a456			; | |  
a456			; | |    Q - Return to previous 
a456				if DEBUG_FORTH_WORDS_KEY 
a456					DMARK "MON" 
a456				if DEMARK_VERSION = 1  
a456 e5					push hl  
a457 21 5f a4				ld hl, .dmark  
a45a 22 60 ee				ld (debug_mark), hl  
a45d				endif  
a45d				if DEMARK_VERSION = 0  
a45d					push af  
a45d					ld a, (.dmark)  
a45d					ld (debug_mark),a  
a45d					ld a, (.dmark+1)  
a45d					ld (debug_mark+1),a  
a45d					ld a, (.dmark+2)  
a45d					ld (debug_mark+2),a  
a45d				endif  
a45d 18 04			jr .pastdmark  
a45f ..			.dmark: db "MON"  
a462				if DEMARK_VERSION = 1  
a462 00					db 0  
a463				endif  
a463				if DEMARK_VERSION = 1  
a463 e1			.pastdmark: pop hl  
a464				endif  
a464				if DEMARK_VERSION = 0  
a464			.pastdmark: pop af  
a464				endif  
a464			endm  
# End of macro DMARK
a464					CALLMONITOR 
a464				if BASE_CPM=1  
a464					call debug_vector  
a464				endif  
a464				if BASE_KEV=1  
a464					rst 8  
a464				endif  
a464				endm  
# End of macro CALLMONITOR
a464				endif 
