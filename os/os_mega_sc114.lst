8d57			uitoa_16: 
8d57			;Input: 
8d57			;   DE is the number to convert 
8d57			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
8d57			;Output: 
8d57			;   HL points to the null-terminated ASCII string 
8d57			;      NOTE: This isn't necessarily the same as the input HL. 
8d57 d5			  push de 
8d58 c5			  push bc 
8d59 f5			  push af 
8d5a eb			  ex de,hl 
8d5b			 
8d5b 01 f0 d8		  ld bc,-10000 
8d5e 3e 2f		  ld a,'0'-1 
8d60 3c			  inc a 
8d61 09			  add hl,bc  
8d62 38 fc		   jr c,$-2 
8d64 12			  ld (de),a 
8d65 13			  inc de 
8d66			 
8d66 01 e8 03		  ld bc,1000 
8d69 3e 3a		  ld a,'9'+1 
8d6b 3d			  dec a  
8d6c 09			  add hl,bc  
8d6d 30 fc		   jr nc,$-2 
8d6f 12			  ld (de),a 
8d70 13			  inc de 
8d71			 
8d71 01 9c ff		  ld bc,-100 
8d74 3e 2f		  ld a,'0'-1 
8d76 3c			  inc a  
8d77 09			  add hl,bc  
8d78 38 fc		   jr c,$-2 
8d7a 12			  ld (de),a 
8d7b 13			  inc de 
8d7c			 
8d7c 7d			  ld a,l 
8d7d 26 3a		  ld h,'9'+1 
8d7f 25			  dec h  
8d80 c6 0a		  add a,10  
8d82 30 fb		   jr nc,$-3 
8d84 c6 30		  add a,'0' 
8d86 eb			  ex de,hl 
8d87 72			  ld (hl),d 
8d88 23			  inc hl 
8d89 77			  ld (hl),a 
8d8a 23			  inc hl 
8d8b 36 00		  ld (hl),0 
8d8d			 
8d8d			;Now strip the leading zeros 
8d8d 0e fa		  ld c,-6 
8d8f 09			  add hl,bc 
8d90 3e 30		  ld a,'0' 
8d92 23			  inc hl  
8d93 be			  cp (hl)  
8d94 28 fc		  jr z,$-2 
8d96			 
8d96			;Make sure that the string is non-empty! 
8d96 7e			  ld a,(hl) 
8d97 b7			  or a 
8d98 20 01		  jr nz,.atoub 
8d9a 2b			  dec hl 
8d9b			.atoub: 
