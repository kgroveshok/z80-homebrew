10f2			 
10f2			; only care about direct match or not 
10f2			; hl and de strings 
10f2			; zero set if the same 
10f2			 
10f2			strcmp: 
10f2 1a				ld a, (de) 
10f3 be				cp (hl) 
10f4 28 02			jr z, .ssame 
10f6 b7				or a 
10f7 c9				ret 
10f8			 
10f8			.ssame:  
10f8			;	cp 0 
10f8 b7				or a 
10f9 c8				ret z 
10fa			 
10fa 23				inc hl 
10fb 13				inc de 
10fc 18 f4			jr strcmp 
