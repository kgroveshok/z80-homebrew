5ac0				call ishlzero 
5ac0				ret z 
5ac0			;	jr z, .autoend 
5ac0			 
5ac0					if DEBUG_FORTH_WORDS 
5ac0						DMARK "ASc" 
5ac0						CALLMONITOR 
5ac0					endif 
5ac0				ld de, store_page+2 
5ac0				ld a, display_row_4 
5ac0				call str_at_display 
5ac0			 
5ac0				call update_display 
5ac0				call delay250ms 
5ac0			 
5ac0			 
5ac0			 
5ac0				ld hl, store_page+2 
5ac0				call forthparse 
5ac0				call forthexec 
5ac0				call forthexec_cleanup 
5ac0			 
5ac0				 
