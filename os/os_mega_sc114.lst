89c7			;    ld a,l 
89c7			;    ld l,h 
89c7			;    ld h,d 
89c7			;    or a 
89c7			;    ld b,8 
89c7			;Sqr16_Loop: 
89c7			;    sbc hl,de 
89c7			;    jr nc,Sqr16_Skip 
89c7			;    add hl,de 
89c7			;Sqr16_Skip: 
89c7			;    ccf 
89c7			;    rl d 
89c7			;    add a,a 
89c7			;    adc hl,hl 
89c7			;    add a,a 
89c7			;    adc hl,hl 
89c7			;    djnz Sqr16_Loop 
89c7			;    ret 
