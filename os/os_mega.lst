1034			;Output: a=0,value of a in the screen 
1034			;destroys af,bc (don't know about hl and de) 
1034			DispAToASCII: 
1034 0e 9c			ld	c,-100 
1036 cd 40 10			call	.Na1 
1039 0e f6			ld	c,-10 
103b cd 40 10			call	.Na1 
103e 0e ff			ld	c,-1 
1040 06 2f		.Na1:	ld	b,'0'-1 
1042 04			.Na2:	inc	b 
1043 81				add	a,c 
1044 38 fc			jr	c,.Na2 
1046 91				sub	c		;works as add 100/10/1 
1047 f5				push af		;safer than ld c,a 
1048 78				ld	a,b		;char is in b 
1049			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
1049 f1				pop af		;safer than ld a,c 
104a c9				ret 
104b			 
104b			; Decimal Signed Version 
104b			 
104b			; DispA 
104b			; -------------------------------------------------------------- 
104b			; Converts a signed integer value to a zero-terminated ASCII 
104b			; string representative of that value (using radix 10). 
104b			; -------------------------------------------------------------- 
104b			; INPUTS: 
104b			;     HL     Value to convert (two's complement integer). 
104b			;     DE     Base address of string destination. (pointer). 
104b			; -------------------------------------------------------------- 
104b			; OUTPUTS: 
104b			;     None 
104b			; -------------------------------------------------------------- 
104b			; REGISTERS/MEMORY DESTROYED 
104b			; AF HL 
104b			; -------------------------------------------------------------- 
104b			 
104b			;DispHLToASCII: 
104b			;   push    de 
104b			;   push    bc 
104b			; 
104b			;; Detect sign of HL. 
104b			;    bit    7, h 
104b			;    jr     z, ._DoConvert 
104b			; 
104b			;; HL is negative. Output '-' to string and negate HL. 
104b			;    ld     a, '-' 
104b			;    ld     (de), a 
104b			;    inc    de 
104b			; 
104b			;; Negate HL (using two's complement) 
104b			;    xor    a 
104b			;    sub    l 
104b			;    ld     l, a 
104b			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
104b			;    sbc    a, h 
104b			;    ld     h, a 
104b			; 
104b			;; Convert HL to digit characters 
104b			;._DoConvert: 
104b			;    ld     b, 0     ; B will count character length of number 
104b			;-   ld     a, 10 
104b			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
104b			;    push   af 
104b			;    inc    b 
104b			;    ld     a, h 
104b			;    or     l 
104b			;    jr     nz, - 
104b			; 
104b			;; Retrieve digits from stack 
104b			;-   pop    af 
104b			;    or     $30 
104b			;    ld     (de), a 
104b			;    inc    de 
104b			;    djnz   - 
104b			; 
104b			;; Terminate string with NULL 
104b			;    xor    a 
104b			;    ld     (de), a 
104b			; 
104b			;    pop    bc 
104b			;    pop    de 
104b			;    ret 
104b			 
104b			;Comments 
104b			; 
104b			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
104b			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
104b			;    Note that the output string will not be fixed-width. 
104b			; 
104b			;Example Usage 
104b			; 
104b			;    ld    hl, -1004 
104b			;    ld    de, OP1 
104b			;    call  DispA 
104b			;    ld    hl, OP1 
104b			;    syscall  PutS 
104b			 
104b			 
104b			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
104b			 
104b			 
104b			;Converts an ASCII string to an unsigned 16-bit integer 
104b			;Quits when it reaches a non-decimal digit 
104b			 
104b			string_to_uint16: 
104b			atoui_16: 
104b			;Input: 
104b			;     DE points to the string 
104b			;Outputs: 
104b			;     HL is the result 
104b			;     A is the 8-bit value of the number 
104b			;     DE points to the byte after the number 
104b			;Destroys: 
104b			;     BC 
104b			;       if the string is non-empty, BC is HL/10 
104b			;Size:  24 bytes 
104b			;Speed: 42+d(104+{0,9}) 
104b			;       d is the number of digits in the number 
104b			;       max is 640 cycles for a 5 digit number 
104b			;Assuming no leading zeros: 
104b			;1 digit:  146cc 
104b			;2 digit:  250cc 
104b			;3 digit:  354cc or 363cc (avg: 354.126cc) 
104b			;4 digit:  458cc or 467cc (avg: 458.27cc) 
104b			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
104b			;avg: 544.81158447265625cc (544+13297/16384) 
104b			;=============================================================== 
104b 21 00 00		  ld hl,0 
104e			.u16a: 
104e 1a			  ld a,(de) 
104f d6 30		  sub 30h 
1051 fe 0a		  cp 10 
1053 d0			  ret nc 
1054 13			  inc de 
1055 44			  ld b,h 
1056 4d			  ld c,l 
1057 29			  add hl,hl 
1058 29			  add hl,hl 
1059 09			  add hl,bc 
105a 29			  add hl,hl 
105b 85			  add a,l 
105c 6f			  ld l,a 
105d 30 ef		  jr nc,.u16a 
105f 24			  inc h 
1060 c3 4e 10		  jp .u16a 
1063			 
1063			 
1063			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1063			 
1063			;written by Zeda 
1063			;Converts a 16-bit unsigned integer to an ASCII string. 
1063			 
1063			uitoa_16: 
1063			;Input: 
1063			;   DE is the number to convert 
1063			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1063			;Output: 
1063			;   HL points to the null-terminated ASCII string 
1063			;      NOTE: This isn't necessarily the same as the input HL. 
1063 d5			  push de 
1064 c5			  push bc 
1065 f5			  push af 
1066 eb			  ex de,hl 
1067			 
1067 01 f0 d8		  ld bc,-10000 
106a 3e 2f		  ld a,'0'-1 
106c 3c			  inc a 
106d 09			  add hl,bc  
106e 38 fc		   jr c,$-2 
1070 12			  ld (de),a 
1071 13			  inc de 
1072			 
1072 01 e8 03		  ld bc,1000 
1075 3e 3a		  ld a,'9'+1 
1077 3d			  dec a  
1078 09			  add hl,bc  
1079 30 fc		   jr nc,$-2 
107b 12			  ld (de),a 
107c 13			  inc de 
107d			 
107d 01 9c ff		  ld bc,-100 
1080 3e 2f		  ld a,'0'-1 
1082 3c			  inc a  
1083 09			  add hl,bc  
1084 38 fc		   jr c,$-2 
1086 12			  ld (de),a 
1087 13			  inc de 
1088			 
1088 7d			  ld a,l 
1089 26 3a		  ld h,'9'+1 
108b 25			  dec h  
108c c6 0a		  add a,10  
108e 30 fb		   jr nc,$-3 
1090 c6 30		  add a,'0' 
1092 eb			  ex de,hl 
1093 72			  ld (hl),d 
1094 23			  inc hl 
1095 77			  ld (hl),a 
1096 23			  inc hl 
1097 36 00		  ld (hl),0 
1099			 
1099			;Now strip the leading zeros 
1099 0e fa		  ld c,-6 
109b 09			  add hl,bc 
109c 3e 30		  ld a,'0' 
109e 23			  inc hl  
109f be			  cp (hl)  
10a0 28 fc		  jr z,$-2 
10a2			 
10a2			;Make sure that the string is non-empty! 
10a2 7e			  ld a,(hl) 
10a3 b7			  or a 
10a4 20 01		  jr nz,.atoub 
10a6 2b			  dec hl 
10a7			.atoub: 
10a7			 
10a7 f1			  pop af 
10a8 c1			  pop bc 
10a9 d1			  pop de 
10aa c9			  ret 
10ab			 
10ab			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
10ab			 
10ab			toUpper: 
10ab			;A is the char. 
10ab			;If A is a lowercase letter, this sets it to the matching uppercase 
10ab			;18cc or 30cc or 41cc 
10ab			;avg: 26.75cc 
10ab fe 61		  cp 'a' 
10ad d8			  ret c 
10ae fe 7b		  cp 'z'+1 
10b0 d0			  ret nc 
10b1 d6 20		  sub 'a'-'A' 
10b3 c9			  ret 
10b4			 
10b4			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
10b4			 
10b4			; String Length 
10b4			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
10b4			 
10b4			; Get the length of the null-terminated string starting at $8000 hl 
10b4			;    LD     HL, $8000 
10b4			 
10b4			strlenz: 
10b4			 
10b4 af			    XOR    A               ; Zero is the value we are looking for. 
10b5 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
10b6 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
10b7			                           ; 65, 536 bytes (the entire addressable memory space). 
10b7 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10b9			 
10b9			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10b9 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
10ba 6f			    LD     L, A             ; number of bytes 
10bb ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10bd 2b			    DEC    HL              ; Compensate for null. 
10be c9				ret 
10bf			 
10bf			; Get the length of the A terminated string starting at $8000 hl 
10bf			;    LD     HL, $8000 
10bf			 
10bf			strlent: 
10bf			 
10bf			                  ; A is the value we are looking for. 
10bf 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10c1 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10c3			                           ; 65, 536 bytes (the entire addressable memory space). 
10c3 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10c5			 
10c5			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10c5 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10c7 2e 00		    LD     L, 0             ; number of bytes 
10c9 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10cb 2b			    DEC    HL              ; Compensate for null. 
10cc c9				ret 
10cd			 
10cd			 
10cd			;Comparing Strings 
10cd			 
10cd			;IN    HL     Address of string1. 
10cd			;      DE     Address of string2. 
10cd			 
10cd			; doc given but wrong??? 
10cd			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10cd			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10cd			; tested 
10cd			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10cd			 
10cd			strcmp_old: 
10cd e5			    PUSH   HL 
10ce d5			    PUSH   DE 
10cf			 
10cf 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10d0 be			    CP     (HL)            ; (want to minimize work). 
10d1 38 01		    JR     C, Str1IsBigger 
10d3 7e			    LD     A, (HL) 
10d4			 
10d4			Str1IsBigger: 
10d4 4f			    LD     C, A             ; Put length in BC 
10d5 06 00		    LD     B, 0 
10d7 13			    INC    DE              ; Increment pointers to meat of string. 
10d8 23			    INC    HL 
10d9			 
10d9			CmpLoop: 
10d9 1a			    LD     A, (DE)          ; Compare bytes. 
10da ed a1		    CPI 
10dc 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10de 13			    INC    DE              ; Update pointer. 
10df ea d9 10		    JP     PE, CmpLoop 
10e2			 
10e2 d1			    POP    DE 
10e3 e1			    POP    HL 
10e4 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
10e5 be			    CP     (HL) 
10e6 c9			    RET 
10e7			 
10e7			NoMatch: 
10e7 2b			    DEC    HL 
10e8 be			    CP     (HL)            ; Compare again to affect carry. 
10e9 d1			    POP    DE 
10ea e1			    POP    HL 
10eb c9			    RET 
