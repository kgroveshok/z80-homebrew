4463			.SESEL: 
4463				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
4463			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
4463			; | | Zero is disabled storage. 
4463					if DEBUG_FORTH_WORDS_KEY 
4463						DMARK "BN?" 
4463						CALLMONITOR 
4463					endif 
4463					ld a, (spi_device_id) 
4463					sub '0' 
4463					ld h, 0 
4463					ld l, a 
4463					FORTH_PUSH_VALUEHL 
4463					;call forth_push_numhl 
4463					NEXTW 
4463			.SESELS: 
4463				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
4463			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
4463			; | | Set to zero to disable storage. 
4463					if DEBUG_FORTH_WORDS_KEY 
4463						DMARK "BNK" 
4463						CALLMONITOR 
4463					endif 
4463			 
4463					ld a, 255 
4463					ld (spi_cartdev), a 
4463			 
4463					; get bank 
4463			 
4463					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4463			 
4463			;		push hl 
4463			 
4463					; destroy value TOS 
4463			 
4463					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4463			 
4463					; one value on hl get other one back 
4463			 
4463			;		pop hl 
4463			 
4463			 
4463					ld c, SPI_CE_HIGH 
4463					ld b, '0'    ; human readable bank number 
4463			 
4463					ld a, l 
4463			 
4463					if DEBUG_FORTH_WORDS 
4463						DMARK "BNK" 
4463						CALLMONITOR 
4463					endif 
4463			 
4463					; active low 
4463			 
4463			;		cp 0 
4463					or a 
4463					jr z, .bset 
4463					cp 1 
4463					jr nz, .b2 
4463					res 0, c 
4463					ld b, '1'    ; human readable bank number 
4463			.b2:		cp 2 
4463					jr nz, .b3 
4463					res 1, c 
4463					ld b, '2'    ; human readable bank number 
4463			.b3:		cp 3 
4463					jr nz, .b4 
4463					res 2, c 
4463					ld b, '3'    ; human readable bank number 
4463			.b4:		cp 4 
4463					jr nz, .b5 
4463					res 3, c 
4463					ld b, '4'    ; human readable bank number 
4463			.b5:		cp 5 
4463					jr nz, .bset 
4463					res 4, c 
4463					ld b, '5'    ; human readable bank number 
4463			 
4463			.bset: 
4463					ld a, c 
4463					ld (spi_device),a 
4463					ld a, b 
4463					ld (spi_device_id),a 
4463					if DEBUG_FORTH_WORDS 
4463						DMARK "BN2" 
4463						CALLMONITOR 
4463					endif 
4463			 
4463					; set default SPI clk pulse time as disabled for BANK use 
4463			 
4463					ld a, 0 
4463					ld (spi_clktime), a 
4463			 
4463					NEXTW 
4463			 
4463			.CARTDEV: 
4463				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
4463			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
4463			; | | Set to zero to disable devices. 
4463					if DEBUG_FORTH_WORDS_KEY 
4463						DMARK "CDV" 
4463						CALLMONITOR 
4463					endif 
4463			 
4463					; disable se storage bank selection 
4463			 
4463					ld a, SPI_CE_HIGH		; ce high 
4463					ld (spi_device), a 
4463			 
4463					; get bank 
4463			 
4463					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4463			 
4463			;		push hl 
4463			 
4463					; destroy value TOS 
4463			 
4463					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4463			 
4463					; one value on hl get other one back 
4463			 
4463			;		pop hl 
4463			 
4463					; active low 
4463			 
4463					ld c, 255 
4463			 
4463					ld a, l 
4463					if DEBUG_FORTH_WORDS 
4463						DMARK "CDV" 
4463						CALLMONITOR 
4463					endif 
4463			;		cp 0 
4463					or a 
4463					jr z, .cset 
4463					cp 1 
4463					jr nz, .c2 
4463					res 0, c 
4463			.c2:		cp 2 
4463					jr nz, .c3 
4463					res 1, c 
4463			.c3:		cp 3 
4463					jr nz, .c4 
4463					res 2, c 
4463			.c4:		cp 4 
4463					jr nz, .c5 
4463					res 3, c 
4463			.c5:		cp 5 
4463					jr nz, .c6 
4463					res 4, c 
4463			.c6:		cp 6 
4463					jr nz, .c7 
4463					res 5, c 
4463			.c7:		cp 7 
4463					jr nz, .c8 
4463					res 6, c 
4463			.c8:		cp 8 
4463					jr nz, .cset 
4463					res 7, c 
4463			.cset:		ld a, c 
4463					ld (spi_cartdev),a 
4463			 
4463					if DEBUG_FORTH_WORDS 
4463						DMARK "CD2" 
4463						CALLMONITOR 
4463					endif 
4463			 
4463					; set default SPI clk pulse time as 10ms for CARTDEV use 
4463			 
4463					ld a, $0a 
4463					ld (spi_clktime), a 
4463					NEXTW 
4463			endif 
4463			 
