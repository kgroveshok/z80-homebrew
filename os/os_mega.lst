1019			; Decimal Unsigned Version 
1019			 
1019			;Number in a to decimal ASCII 
1019			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
1019			;Example: display a=56 as "056" 
1019			;input: a = number 
1019			;Output: a=0,value of a in the screen 
1019			;destroys af,bc (don't know about hl and de) 
1019			DispAToASCII: 
1019 0e 9c			ld	c,-100 
101b cd 25 10			call	.Na1 
101e 0e f6			ld	c,-10 
1020 cd 25 10			call	.Na1 
1023 0e ff			ld	c,-1 
1025 06 2f		.Na1:	ld	b,'0'-1 
1027 04			.Na2:	inc	b 
1028 81				add	a,c 
1029 38 fc			jr	c,.Na2 
102b 91				sub	c		;works as add 100/10/1 
102c f5				push af		;safer than ld c,a 
102d 78				ld	a,b		;char is in b 
102e			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
102e f1				pop af		;safer than ld a,c 
102f c9				ret 
