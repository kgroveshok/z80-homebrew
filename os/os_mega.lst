0eda			;;;; int maths 
0eda			 
0eda			; https://map.grauw.nl/articles/mult_div_shifts.php 
0eda			; Divide 16-bit values (with 16-bit result) 
0eda			; In: Divide BC by divider DE 
0eda			; Out: BC = result, HL = rest 
0eda			; 
0eda			Div16: 
0eda 21 00 00		    ld hl,0 
0edd 78			    ld a,b 
0ede 06 08		    ld b,8 
0ee0			Div16_Loop1: 
0ee0 17			    rla 
0ee1 ed 6a		    adc hl,hl 
0ee3 ed 52		    sbc hl,de 
0ee5 30 01		    jr nc,Div16_NoAdd1 
0ee7 19			    add hl,de 
0ee8			Div16_NoAdd1: 
0ee8 10 f6		    djnz Div16_Loop1 
0eea 17			    rla 
0eeb 2f			    cpl 
0eec 47			    ld b,a 
0eed 79			    ld a,c 
0eee 48			    ld c,b 
0eef 06 08		    ld b,8 
0ef1			Div16_Loop2: 
0ef1 17			    rla 
0ef2 ed 6a		    adc hl,hl 
0ef4 ed 52		    sbc hl,de 
0ef6 30 01		    jr nc,Div16_NoAdd2 
0ef8 19			    add hl,de 
0ef9			Div16_NoAdd2: 
0ef9 10 f6		    djnz Div16_Loop2 
0efb 17			    rla 
0efc 2f			    cpl 
0efd 41			    ld b,c 
0efe 4f			    ld c,a 
0eff c9			ret 
