0c34			 
0c34			;-----> Generate a random number 
0c34			; output a=answer 0<=a<=255 
0c34			; all registers are preserved except: af 
0c34			random: 
0c34 e5			        push    hl 
0c35 d5			        push    de 
0c36 2a db fa		        ld      hl,(randData) 
0c39 ed 5f		        ld      a,r 
0c3b 57			        ld      d,a 
0c3c 5e			        ld      e,(hl) 
0c3d 19			        add     hl,de 
0c3e 85			        add     a,l 
0c3f ac			        xor     h 
0c40 22 db fa		        ld      (randData),hl 
0c43 d1			        pop     de 
0c44 e1			        pop     hl 
0c45 c9			        ret 
0c46			 
0c46			 
0c46			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0c46			 
0c46			 
0c46			 
0c46			;------LFSR------ 
0c46			;James Montelongo 
0c46			;optimized by Spencer Putt 
0c46			;out: 
0c46			; a = 8 bit random number 
0c46			RandLFSR: 
0c46 21 e1 fa		        ld hl,LFSRSeed+4 
0c49 5e			        ld e,(hl) 
0c4a 23			        inc hl 
0c4b 56			        ld d,(hl) 
0c4c 23			        inc hl 
0c4d 4e			        ld c,(hl) 
0c4e 23			        inc hl 
0c4f 7e			        ld a,(hl) 
0c50 47			        ld b,a 
0c51 cb 13		        rl e  
0c53 cb 12			rl d 
0c55 cb 11		        rl c  
0c57 17				rla 
0c58 cb 13		        rl e  
0c5a cb 12			rl d 
0c5c cb 11		        rl c  
0c5e 17				rla 
0c5f cb 13		        rl e  
0c61 cb 12			rl d 
0c63 cb 11		        rl c  
0c65 17				rla 
0c66 67			        ld h,a 
0c67 cb 13		        rl e  
0c69 cb 12			rl d 
0c6b cb 11		        rl c  
0c6d 17				rla 
0c6e a8			        xor b 
0c6f cb 13		        rl e  
0c71 cb 12			rl d 
0c73 ac			        xor h 
0c74 a9			        xor c 
0c75 aa			        xor d 
0c76 21 e3 fa		        ld hl,LFSRSeed+6 
0c79 11 e4 fa		        ld de,LFSRSeed+7 
0c7c 01 07 00		        ld bc,7 
0c7f ed b8		        lddr 
0c81 12			        ld (de),a 
0c82 c9			        ret 
0c83			 
0c83			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0c83			 
0c83			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0c83			 
0c83			 
0c83			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0c83			 
0c83			prng16: 
0c83			;Inputs: 
0c83			;   (seed1) contains a 16-bit seed value 
0c83			;   (seed2) contains a NON-ZERO 16-bit seed value 
0c83			;Outputs: 
0c83			;   HL is the result 
0c83			;   BC is the result of the LCG, so not that great of quality 
0c83			;   DE is preserved 
0c83			;Destroys: 
0c83			;   AF 
0c83			;cycle: 4,294,901,760 (almost 4.3 billion) 
0c83			;160cc 
0c83			;26 bytes 
0c83 2a d5 fa		    ld hl,(seed1) 
0c86 44			    ld b,h 
0c87 4d			    ld c,l 
0c88 29			    add hl,hl 
0c89 29			    add hl,hl 
0c8a 2c			    inc l 
0c8b 09			    add hl,bc 
0c8c 22 d5 fa		    ld (seed1),hl 
0c8f 2a d3 fa		    ld hl,(seed2) 
0c92 29			    add hl,hl 
0c93 9f			    sbc a,a 
0c94 e6 2d		    and %00101101 
0c96 ad			    xor l 
0c97 6f			    ld l,a 
0c98 22 d3 fa		    ld (seed2),hl 
0c9b 09			    add hl,bc 
0c9c c9			    ret 
0c9d			 
0c9d			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0c9d			 
0c9d			rand32: 
0c9d			;Inputs: 
0c9d			;   (seed1_0) holds the lower 16 bits of the first seed 
0c9d			;   (seed1_1) holds the upper 16 bits of the first seed 
0c9d			;   (seed2_0) holds the lower 16 bits of the second seed 
0c9d			;   (seed2_1) holds the upper 16 bits of the second seed 
0c9d			;   **NOTE: seed2 must be non-zero 
0c9d			;Outputs: 
0c9d			;   HL is the result 
0c9d			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0c9d			;Destroys: 
0c9d			;   AF 
0c9d			;Tested and passes all CAcert tests 
0c9d			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0c9d			;it has a period of 18,446,744,069,414,584,320 
0c9d			;roughly 18.4 quintillion. 
0c9d			;LFSR taps: 0,2,6,7  = 11000101 
0c9d			;291cc 
0c9d			;seed1_0=$+1 
0c9d			;    ld hl,12345 
0c9d			;seed1_1=$+1 
0c9d			;    ld de,6789 
0c9d			;    ld b,h 
0c9d			;    ld c,l 
0c9d			;    add hl,hl \ rl e \ rl d 
0c9d			;    add hl,hl \ rl e \ rl d 
0c9d			;    inc l 
0c9d			;    add hl,bc 
0c9d			;    ld (seed1_0),hl 
0c9d			;    ld hl,(seed1_1) 
0c9d			;    adc hl,de 
0c9d			;    ld (seed1_1),hl 
0c9d			;    ex de,hl 
0c9d			;seed2_0=$+1 
0c9d			;    ld hl,9876 
0c9d			;seed2_1=$+1 
0c9d			;    ld bc,54321 
0c9d			;    add hl,hl \ rl c \ rl b 
0c9d			;    ld (seed2_1),bc 
0c9d			;    sbc a,a 
0c9d			;    and %11000101 
0c9d			;    xor l 
0c9d			;    ld l,a 
0c9d			;    ld (seed2_0),hl 
0c9d			;    ex de,hl 
0c9d			;    add hl,bc 
0c9d			;    ret 
0c9d			; 
0c9d			 
0c9d			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0c9d			; 20 bytes, 86 cycles (excluding ret) 
0c9d			 
0c9d			; returns   hl = pseudorandom number 
0c9d			; corrupts   a 
0c9d			 
0c9d			; generates 16-bit pseudorandom numbers with a period of 65535 
0c9d			; using the xorshift method: 
0c9d			 
0c9d			; hl ^= hl << 7 
0c9d			; hl ^= hl >> 9 
0c9d			; hl ^= hl << 8 
0c9d			 
0c9d			; some alternative shift triplets which also perform well are: 
0c9d			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0c9d			 
0c9d			;  org 32768 
0c9d			 
0c9d			xrnd: 
0c9d 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0ca0 3e 00		  ld a,0 
0ca2 bd			  cp l 
0ca3 20 02		  jr nz, .xrnd1 
0ca5 2e 01		  ld l, 1 
0ca7			.xrnd1: 
0ca7			 
0ca7 7c			  ld a,h 
0ca8 1f			  rra 
0ca9 7d			  ld a,l 
0caa 1f			  rra 
0cab ac			  xor h 
0cac 67			  ld h,a 
0cad 7d			  ld a,l 
0cae 1f			  rra 
0caf 7c			  ld a,h 
0cb0 1f			  rra 
0cb1 ad			  xor l 
0cb2 6f			  ld l,a 
0cb3 ac			  xor h 
0cb4 67			  ld h,a 
0cb5			 
0cb5 22 d9 fa		  ld (xrandc),hl 
0cb8			 
0cb8 c9			  ret 
0cb9			;  
0cb9			 
