ca26				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
ca26			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
ca26			 
ca26					if DEBUG_FORTH_WORDS_KEY 
ca26						DMARK "SPo" 
ca26						CALLMONITOR 
ca26					endif 
ca26					; get port 
