914e			;	ld de, 10000 
914e			.td2: 
914e 2a 49 ea			ld hl, (tape_sync) 
9151 34					inc (hl) 
9152			.td3:  
9152 3e 01			ld a, 1 
9154 cd 34 87			call aDelayInMS 
9157			; wait for next pulse 
9157 db 00			in a,(0) 
9159 fe 00			cp 0 
915b 20 09			jr nz, .td4 
915d 2a 4a ea			ld hl, (tape_sync+1) 
9160 34				inc (hl) 
9161 7e				ld a,(hl) 
9162 fe 05			cp 5 
9164 18 e8			jr .td2 
9166			 
9166			.td4: 
9166				 ; in gap 
9166			; wait for rising edge 
9166			; on edge  
9166			; count pulse 
9166			; count no pulse 
9166			; if no pulse for 5ms then must be gap 
9166			; save pulse size for each gap found 
9166			; once gap count is 6 then exit and report counts 
9166			 
9166 c9					ret 
