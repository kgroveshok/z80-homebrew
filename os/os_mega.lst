2479			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
2479			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
2479			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
2479			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
2479			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
2479			WORD_SYS_END: equ 0   ; Opcode for all user words 
2479			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
2479			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
2479			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
2479			 
2479			; Core word preamble macro 
2479			 
2479			CWHEAD:   macro nxtword opcode lit len opflags 
2479				db WORD_SYS_CORE+opcode             
2479				; internal op code number 
2479				dw nxtword            
2479				; link to next dict word block 
2479				db len + 1 
2479				; literal length of dict word inc zero term 
2479				db lit,0              
2479				; literal dict word 
2479			        ; TODO db opflags        
2479				endm 
