0d78			addatohl: 
0d78 85			    add   a, l    ; A = A+L 
0d79 6f			    ld    l, a    ; L = A+L 
0d7a 8c			    adc   a, h    ; A = A+L+H+carry 
0d7b 95			    sub   l       ; A = H+carry 
0d7c 67			    ld    h, a    ; H = H+carry 
0d7d c9			ret 
