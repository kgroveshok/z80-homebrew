695b cd dc 69		            CALL fLCD_Init      ;Initialise LCD module  
695e 3e 01				ld a, 1  
6960 32 fb fa				ld (display_lcde1e2), a  
6963 cd dc 69		            CALL fLCD_Init      ;Initialise LCD module  
6966			  
6966 c9				ret  
