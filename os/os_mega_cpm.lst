24dc					ld (debug_mark+1),a  
24dc					ld a, (.dmark+2)  
24dc					ld (debug_mark+2),a  
24dc				endif  
24dc 18 04			jr .pastdmark  
24de ..			.dmark: db "MON"  
24e1				if DEMARK_VERSION = 1  
24e1 00					db 0  
24e2				endif  
24e2				if DEMARK_VERSION = 1  
24e2 e1			.pastdmark: pop hl  
24e3				endif  
