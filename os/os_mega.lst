10e9			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
10e9			 
10e9			;      .org 0 
10e9			;      jp    main 
10e9			 
10e9			 
10e9			;      .org  0x100 
10e9			;main: 
10e9			;      ld    HL, 0x8100 
10e9			;      ld    SP, HL 
10e9			; 
10e9			;      call  heap_init 
10e9			; 
10e9			;      ; Make some allocations 
10e9			;      ld    HL, 12 
10e9			;      call  malloc            ; Allocates 0x9004 
10e9			; 
10e9			;      ld    HL, 12 
10e9			;      call  malloc            ; Allocates 0x9014 
10e9			; 
10e9			;      ld    HL, 12 
10e9			;      call  malloc            ; Allocates 0x9024 
10e9			; 
10e9			;      ; Free some allocations 
10e9			;      ld    HL, 0x9014 
10e9			;      call  free 
10e9			; 
10e9			;      ld    HL, 0x9004 
10e9			;      call  free 
10e9			; 
10e9			;      ld    HL, 0x9024 
10e9			;      call  free 
10e9			; 
10e9			; 
10e9			;      halt 
