0e12 fe 61		to_upper:        cp      'a'             ; Nothing to do if not lower case 
0e14 d8			                ret     c 
0e15 fe 7b		                cp      'z' + 1         ; > 'z'? 
0e17 d0			                ret     nc              ; Nothing to do, either 
0e18 e6 5f		                and     $5f             ; Convert to upper case 
