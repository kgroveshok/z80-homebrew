24eb			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
24eb			; | | At start the current various registers will be displayed with contents. 
24eb			; | | Top right corner will show the most recent debug marker seen. 
24eb			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
24eb			; | | and the return stack pointer (RSP). 
24eb			; | | Pressing: 
24eb			; | |  
24eb			; | |    1 - Initial screen 
24eb			; | |  
24eb			; | |    2 - Display a data dump of HL 
24eb			; | |  
24eb			; | |    3 - Display a data dump of DE 
24eb			; | |  
24eb			; | |    4 - Display a data dump of BC 
24eb			; | |  
24eb			; | |    5 - Display a data dump of HL 
24eb			; | |  
24eb			; | |    6 - Display a data dump of DSP 
24eb			; | |  
24eb			; | |    7 - Display a data dump of RSP 
24eb			; | |  
24eb			; | |    8 - Display a data dump of what is at DSP 
24eb			; | |  
24eb			; | |    9 - Display a data dump of what is at RSP 
24eb			; | |  
24eb			; | |    0 - Exit monitor and continue running. This will also enable break points 
24eb			; | |  
24eb			; | |    * - Disable break points 
24eb			; | |  
24eb			; | |    # - Enter traditional monitor mode 
24eb			; | |  
24eb			; | | 
24eb			; | | Monitor Mode 
24eb			; | | ------------ 
24eb			; | | A prompt of '>' will be shown for various commands: 
24eb			; | |  
24eb			; | |    D xxxx - Display a data dump starting from hex address xxxx 
24eb			; | |  
24eb			; | |    C - Continue display a data dump from the last set address 
24eb			; | |  
24eb			; | |    M xxxx - Set start of memory edit at address xx 
24eb			; | |  
24eb			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
24eb			; | |  
24eb			; | |    G xxxx - Exec code at specific address 
24eb			; | |  
24eb			; | |    Q - Return to previous 
24eb				if DEBUG_FORTH_WORDS_KEY 
24eb					DMARK "MON" 
24eb				if DEMARK_VERSION = 1  
24eb e5					push hl  
24ec 21 f4 24				ld hl, .dmark  
24ef 22 60 ee				ld (debug_mark), hl  
24f2				endif  
24f2				if DEMARK_VERSION = 0  
24f2					push af  
