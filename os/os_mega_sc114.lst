99c5			user_word_eol:  
99c5				; hl contains the pointer to where to create a linked list item from the end 
99c5				; of the user dict to continue on at the system word dict 
99c5				 
99c5				; poke the stub of the word list linked list to repoint to rom words 
99c5			 
99c5				; stub format 
99c5				; db   word id 
99c5				; dw    link to next word 
99c5			        ; db char length of token 
99c5				; db string + 0 term 
99c5				; db exec code....  
99c5			 
99c5			;	ld a, WORD_SYS_ROOT     ; root word 
99c5 36 00			ld (hl), WORD_SYS_ROOT		; word id 
99c7 23				inc hl 
99c8			 
99c8 11 71 9b			ld de, sysdict 
99cb 73				ld (hl), e		; next word link ie system dict 
99cc 23				inc hl 
99cd 72				ld (hl), d		; next word link ie system dict 
99ce 23				inc hl	 
99cf			 
99cf			;	ld (hl), sysdict		; next word link ie system dict 
99cf			;	inc hl 
99cf			;	inc hl 
99cf			 
99cf			;	inc hl 
99cf			;	inc hl 
99cf			 
99cf			;	ld a, 2			; word length is 0 
99cf 36 02			ld (hl), 2 
99d1 23				inc hl 
99d2			 
99d2			;	ld a, '~'			; word length is 0 
99d2 36 7e			ld (hl), '~' 
99d4 23				inc hl 
99d5			;	ld a, 0			; save empty word 
99d5 36 00			ld (hl), 0 
99d7			 
99d7 c9				ret 
