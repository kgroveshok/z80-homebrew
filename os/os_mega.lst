25b2			.NEW: 
25b2			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
25b2 15				db WORD_SYS_CORE+OPCODE_HEAP             
25b3 cc 25			dw .HEAP            
25b5 04				db 3 + 1 
25b6 .. 00			db "NEW",0              
25ba				endm 
# End of macro CWHEAD
25ba			; | NEW ( -- ) Clears all user words and stack | DONE 
25ba				 
25ba				if MALLOC_4 
25ba					call  heap_init 
25ba				endif 
25ba				; reset uword pointers 
25ba 21 00 80			ld hl, baseram 
25bd 22 da f3			ld (os_last_new_uword), hl 
25c0 cd 06 24			call user_word_eol 
25c3				; clear stack 
25c3 cd 1f 24			call forth_warmstart 
25c6				NEXTW 
25c6 cd a3 fd			call parse_vector 
25c9 c3 79 24			jp macro_next 
25cc				endm 
# End of macro NEXTW
25cc			 
25cc			.HEAP: 
25cc			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
25cc 15				db WORD_SYS_CORE+OPCODE_HEAP             
25cd fd 25			dw .EXEC            
25cf 05				db 4 + 1 
25d0 .. 00			db "HEAP",0              
25d5				endm 
# End of macro CWHEAD
25d5			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
25d5			; | | u1 - Current number of bytes in the heap 
25d5			; | | u2 - Remaining bytes left on the heap 
25d5			; | |  
25d5			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
25d5			 
25d5			 
25d5				if DEBUG_FORTH_WORDS_KEY 
25d5					DMARK "HEP" 
25d5				if DEMARK_VERSION = 1  
25d5 e5					push hl  
25d6 21 de 25				ld hl, .dmark  
25d9 22 9b fd				ld (debug_mark), hl  
25dc				endif  
25dc				if DEMARK_VERSION = 0  
25dc					push af  
25dc					ld a, (.dmark)  
25dc					ld (debug_mark),a  
25dc					ld a, (.dmark+1)  
25dc					ld (debug_mark+1),a  
25dc					ld a, (.dmark+2)  
25dc					ld (debug_mark+2),a  
25dc				endif  
25dc 18 04			jr .pastdmark  
25de ..			.dmark: db "HEP"  
25e1				if DEMARK_VERSION = 1  
25e1 00					db 0  
25e2				endif  
25e2				if DEMARK_VERSION = 1  
25e2 e1			.pastdmark: pop hl  
25e3				endif  
25e3				if DEMARK_VERSION = 0  
25e3			.pastdmark: pop af  
25e3				endif  
25e3			endm  
# End of macro DMARK
25e3					CALLMONITOR 
25e3				if BASE_CPM=1  
25e3					call debug_vector  
25e3				endif  
25e3				if BASE_KEV=1  
25e3 cf					rst 8  
25e4				endif  
25e4				endm  
# End of macro CALLMONITOR
25e4				endif 
25e4 2a 0a 80			ld hl, (free_list )      
25e7 11 0e 80			ld de, heap_start 
