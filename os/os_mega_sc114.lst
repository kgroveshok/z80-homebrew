8f7a			uitoa_16: 
8f7a			;Input: 
8f7a			;   DE is the number to convert 
8f7a			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
8f7a			;Output: 
8f7a			;   HL points to the null-terminated ASCII string 
8f7a			;      NOTE: This isn't necessarily the same as the input HL. 
8f7a d5			  push de 
8f7b c5			  push bc 
8f7c f5			  push af 
8f7d eb			  ex de,hl 
8f7e			 
8f7e 01 f0 d8		  ld bc,-10000 
8f81 3e 2f		  ld a,'0'-1 
8f83 3c			  inc a 
8f84 09			  add hl,bc  
8f85 38 fc		   jr c,$-2 
8f87 12			  ld (de),a 
8f88 13			  inc de 
8f89			 
8f89 01 e8 03		  ld bc,1000 
8f8c 3e 3a		  ld a,'9'+1 
8f8e 3d			  dec a  
8f8f 09			  add hl,bc  
8f90 30 fc		   jr nc,$-2 
8f92 12			  ld (de),a 
8f93 13			  inc de 
8f94			 
8f94 01 9c ff		  ld bc,-100 
8f97 3e 2f		  ld a,'0'-1 
8f99 3c			  inc a  
8f9a 09			  add hl,bc  
8f9b 38 fc		   jr c,$-2 
8f9d 12			  ld (de),a 
8f9e 13			  inc de 
8f9f			 
8f9f 7d			  ld a,l 
8fa0 26 3a		  ld h,'9'+1 
8fa2 25			  dec h  
8fa3 c6 0a		  add a,10  
8fa5 30 fb		   jr nc,$-3 
8fa7 c6 30		  add a,'0' 
8fa9 eb			  ex de,hl 
8faa 72			  ld (hl),d 
8fab 23			  inc hl 
8fac 77			  ld (hl),a 
8fad 23			  inc hl 
8fae 36 00		  ld (hl),0 
8fb0			 
8fb0			;Now strip the leading zeros 
8fb0 0e fa		  ld c,-6 
8fb2 09			  add hl,bc 
8fb3 3e 30		  ld a,'0' 
8fb5 23			  inc hl  
8fb6 be			  cp (hl)  
8fb7 28 fc		  jr z,$-2 
8fb9			 
8fb9			;Make sure that the string is non-empty! 
8fb9 7e			  ld a,(hl) 
8fba b7			  or a 
8fbb 20 01		  jr nz,.atoub 
8fbd 2b			  dec hl 
