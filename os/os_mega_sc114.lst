918f dd 66 03		      ld    H, (IX+3) 
9192			 
9192 23			      inc   HL                      ; Size of prev free block into DE 
9193 23			      inc   HL 
9194 5e			      ld    E, (HL) 
9195 23			      inc   HL 
9196 56			      ld    D, (HL) 
9197 2b			      dec   HL 
9198 2b			      dec   HL 
9199 2b			      dec   HL 
919a			 
919a 19			      add   HL, DE                  ; Add prev block addr and size 
919b			 
919b b7			      or    A                       ; Clear the carry flag 
919c ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
919e 20 2e		      jr    NZ, free_done 
91a0			 
91a0			      ; Freed block is adjacent to prev, merge into one bigger block 
91a0 60			      ld    H, B                    ; Load next ptr from freed block into DE 
91a1 69			      ld    L, C 
91a2 5e			      ld    E, (HL) 
91a3 23			      inc   HL 
91a4 56			      ld    D, (HL) 
91a5 e5			      push  HL                      ; Save freed block ptr for later 
91a6			 
91a6 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
91a9 dd 66 03		      ld    H, (IX+3) 
91ac 73			      ld    (HL), E 
91ad 23			      inc   HL 
91ae 72			      ld    (HL), D 
91af			 
91af e1			      pop   HL                      ; Restore freed block ptr 
91b0 23			      inc   HL                      ; Load size of freed block into DE 
91b1 5e			      ld    E, (HL) 
91b2 23			      inc   HL 
91b3 56			      ld    D, (HL) 
91b4 d5			      push  DE                      ; Save freed block size for later 
91b5			 
