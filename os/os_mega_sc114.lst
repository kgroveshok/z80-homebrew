8a37			;HL_Div_C: 
8a37			;Inputs: 
8a37			;     HL is the numerator 
8a37			;     C is the denominator 
8a37			;Outputs: 
8a37			;     A is the remainder 
8a37			;     B is 0 
8a37			;     C is not changed 
8a37			;     DE is not changed 
8a37			;     HL is the quotient 
8a37			; 
8a37			;       ld b,16 
8a37			;       xor a 
8a37			;         add hl,hl 
8a37			;         rla 
8a37			;         cp c 
8a37			;         jr c,$+4 
8a37			;           inc l 
8a37			;           sub c 
8a37			;         djnz $-7 
