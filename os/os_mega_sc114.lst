9da5			.NEW: 
9da5			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
9da5 15				db WORD_SYS_CORE+OPCODE_HEAP             
9da6 bf 9d			dw .HEAP            
9da8 04				db 3 + 1 
9da9 .. 00			db "NEW",0              
9dad				endm 
# End of macro CWHEAD
9dad			; | NEW ( -- ) Clears all user words and stack | DONE 
9dad				 
9dad				if MALLOC_4 
9dad					call  heap_init 
9dad				endif 
9dad				; reset uword pointers 
9dad 21 47 d6			ld hl, baseram 
9db0 22 a2 e5			ld (os_last_new_uword), hl 
9db3 cd f9 9b			call user_word_eol 
9db6				; clear stack 
9db6 cd 12 9c			call forth_warmstart 
9db9				NEXTW 
9db9 cd 68 ee			call parse_vector 
9dbc c3 6c 9c			jp macro_next 
9dbf				endm 
# End of macro NEXTW
9dbf			 
9dbf			.HEAP: 
9dbf			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9dbf 15				db WORD_SYS_CORE+OPCODE_HEAP             
9dc0 ed 9d			dw .EXEC            
9dc2 05				db 4 + 1 
9dc3 .. 00			db "HEAP",0              
9dc8				endm 
# End of macro CWHEAD
9dc8			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9dc8			; | | u1 - Current number of bytes in the heap 
9dc8			; | | u2 - Remaining bytes left on the heap 
9dc8			; | |  
9dc8			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9dc8			 
9dc8			 
9dc8				if DEBUG_FORTH_WORDS_KEY 
9dc8					DMARK "HEP" 
9dc8				if DEMARK_VERSION = 1  
9dc8 e5					push hl  
9dc9 21 d1 9d				ld hl, .dmark  
9dcc 22 60 ee				ld (debug_mark), hl  
9dcf				endif  
9dcf				if DEMARK_VERSION = 0  
9dcf					push af  
9dcf					ld a, (.dmark)  
9dcf					ld (debug_mark),a  
9dcf					ld a, (.dmark+1)  
9dcf					ld (debug_mark+1),a  
9dcf					ld a, (.dmark+2)  
9dcf					ld (debug_mark+2),a  
9dcf				endif  
9dcf 18 04			jr .pastdmark  
9dd1 ..			.dmark: db "HEP"  
9dd4				if DEMARK_VERSION = 1  
9dd4 00					db 0  
9dd5				endif  
9dd5				if DEMARK_VERSION = 1  
9dd5 e1			.pastdmark: pop hl  
9dd6				endif  
9dd6				if DEMARK_VERSION = 0  
9dd6			.pastdmark: pop af  
9dd6				endif  
9dd6			endm  
# End of macro DMARK
9dd6					CALLMONITOR 
9dd6				if BASE_CPM=1  
9dd6					call debug_vector  
9dd6				endif  
9dd6				if BASE_KEV=1  
9dd6					rst 8  
9dd6				endif  
9dd6				endm  
# End of macro CALLMONITOR
9dd6				endif 
9dd6 2a 51 d6			ld hl, (free_list )      
9dd9 11 56 d6			ld de, heap_start 
9ddc			 
9ddc ed 52			sbc hl, de  
9dde			 
9dde			;	call forth_push_numhl 
9dde					FORTH_PUSH_VALUEHL 
9dde				if BASE_CPM=1 
9dde					call forth_push_numhl 
9dde				endif 
9dde				if BASE_KEV=1 
9dde					rst $20 
9dde				endif 
9dde				endm 
# End of macro FORTH_PUSH_VALUEHL
9dde			 
9dde			 
