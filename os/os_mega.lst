6778			; handle the auto run of code from files in storage 
6778			 
6778			 
6778			include "forth_startup.asm" 
6778			; Which startup method to use? 
6778			; 
6778			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6778			; followed by loading of a list of scripts in eeprom 
6778			 
6778			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6778			; from eeprom 
6778			 
6778			; Select with define in main stubs 
6778			 
6778			if STARTUP_V1 
6778				include "forth_startupv1.asm" 
6778			endif 
6778			if STARTUP_V2 
6778				include "forth_startupv2.asm" 
6778			; Version 2 of the startup  
6778			;  
6778			; Auto load any files in bank 1 that start with a '*' 
6778			; If no se storage then revert to using eprom 
6778			 
6778			 
6778			if STORAGE_SE = 0 
6778			 
6778			sprompt1: db "Startup load...",0 
6778			sprompt2: db "Run? 1=No *=End #=All",0 
6778			 
6778			 
6778			 
6778			 
6778			forth_startup: 
6778				ld hl, startcmds 
6778				ld a, 0 
6778				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
6778			 
6778			.start1:	push hl 
6778				call clear_display 
6778				ld de, sprompt1 
6778			        ld a, display_row_1 
6778				call str_at_display 
6778				ld de, sprompt2 
6778			        ld a, display_row_2 
6778				call str_at_display 
6778				pop hl 
6778				push hl 
6778				ld e,(hl) 
6778				inc hl 
6778				ld d,(hl) 
6778			        ld a, display_row_3 
6778				call str_at_display 
6778				call update_display 
6778			 
6778			 
6778				ld a, (os_last_cmd) 
6778			;	cp 0 
6778				or a 
6778				jr z, .startprompt 
6778				call delay250ms 
6778				jr .startdo 
6778				 
6778				 
6778			 
6778			.startprompt: 
6778			 
6778				ld a,display_row_4 + display_cols - 1 
6778			        ld de, endprg 
6778				call str_at_display 
6778				call update_display 
6778				call delay1s 
6778				call cin_wait 
6778						 
6778				cp '*' 
6778				jr z, .startupend1 
6778				cp '#' 
6778				jr nz, .startno 
6778				ld a, 1 
6778				ld (os_last_cmd),a 
6778				jr .startdo 
6778			.startno:	cp '1' 
6778				jr z,.startnxt  
6778			 
6778				; exec startup line 
6778			.startdo:	 
6778				pop hl 
6778				push hl 
6778				 
6778				ld e,(hl) 
6778				inc hl 
6778				ld d,(hl) 
6778				ex de,hl 
6778			 
6778				push hl 
6778			 
6778				ld a, 0 
6778				;ld a, FORTH_END_BUFFER 
6778				call strlent 
6778				inc hl   ; include zero term to copy 
6778				ld b,0 
6778				ld c,l 
6778				pop hl 
6778				ld de, scratch 
6778				ldir 
6778			 
6778			 
6778				ld hl, scratch 
6778				call forthparse 
6778				call forthexec 
6778				call forthexec_cleanup 
6778			 
6778				ld a, display_row_4 
6778				ld de, endprog 
6778			 
6778				call update_display		 
6778			 
6778				ld a, (os_last_cmd) 
6778			;	cp 0 
6778				or a 
6778				jr nz, .startnxt 
6778				call next_page_prompt 
6778			        call clear_display 
6778				call update_display		 
6778			 
6778				; move onto next startup line? 
6778			.startnxt: 
6778			 
6778				call delay250ms 
6778				pop hl 
6778			 
6778				inc hl 
6778				inc hl 
6778			 
6778				push hl 
6778				ld e, (hl) 
6778				inc hl 
6778				ld d, (hl) 
6778				pop hl 
6778				; TODO replace 0 test 
6778			 
6778				ex de, hl 
6778				call ishlzero 
6778			;	ld a,e 
6778			;	add d 
6778			;	cp 0    ; any left to do? 
6778				ex de, hl 
6778				jp nz, .start1 
6778				jr .startupend 
6778			 
6778			.startupend1: pop hl 
6778			.startupend: 
6778			 
6778				call clear_display 
6778				call update_display 
6778				ret 
6778			endif 
