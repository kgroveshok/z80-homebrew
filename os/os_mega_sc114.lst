8997			; https://map.grauw.nl/articles/mult_div_shifts.php 
8997			; Divide 16-bit values (with 16-bit result) 
8997			; In: Divide BC by divider DE 
8997			; Out: BC = result, HL = rest 
8997			; 
8997			Div16: 
8997 21 00 00		    ld hl,0 
899a 78			    ld a,b 
899b 06 08		    ld b,8 
899d			Div16_Loop1: 
899d 17			    rla 
899e ed 6a		    adc hl,hl 
89a0 ed 52		    sbc hl,de 
89a2 30 01		    jr nc,Div16_NoAdd1 
89a4 19			    add hl,de 
89a5			Div16_NoAdd1: 
89a5 10 f6		    djnz Div16_Loop1 
89a7 17			    rla 
89a8 2f			    cpl 
89a9 47			    ld b,a 
89aa 79			    ld a,c 
89ab 48			    ld c,b 
89ac 06 08		    ld b,8 
89ae			Div16_Loop2: 
89ae 17			    rla 
89af ed 6a		    adc hl,hl 
89b1 ed 52		    sbc hl,de 
89b3 30 01		    jr nc,Div16_NoAdd2 
89b5 19			    add hl,de 
89b6			Div16_NoAdd2: 
89b6 10 f6		    djnz Div16_Loop2 
89b8 17			    rla 
89b9 2f			    cpl 
89ba 41			    ld b,c 
89bb 4f			    ld c,a 
89bc c9			ret 
89bd			 
89bd			 
89bd			;http://z80-heaven.wikidot.com/math 
89bd			; 
89bd			;Inputs: 
89bd			;     DE and A are factors 
89bd			;Outputs: 
89bd			;     A is not changed 
89bd			;     B is 0 
89bd			;     C is not changed 
89bd			;     DE is not changed 
89bd			;     HL is the product 
89bd			;Time: 
89bd			;     342+6x 
89bd			; 
89bd			Mult16: 
89bd			 
89bd 06 08		     ld b,8          ;7           7 
89bf 21 00 00		     ld hl,0         ;10         10 
89c2 29			       add hl,hl     ;11*8       88 
89c3 07			       rlca          ;4*8        32 
89c4 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
89c6 19			         add hl,de   ;--         -- 
89c7 10 f9		       djnz $-5      ;13*7+8     99 
89c9 c9			ret 
89ca			 
89ca			; 
89ca			; Square root of 16-bit value 
89ca			; In:  HL = value 
89ca			; Out:  D = result (rounded down) 
89ca			; 
89ca			;Sqr16: 
89ca			;    ld de,#0040 
89ca			;    ld a,l 
89ca			;    ld l,h 
89ca			;    ld h,d 
89ca			;    or a 
89ca			;    ld b,8 
89ca			;Sqr16_Loop: 
89ca			;    sbc hl,de 
89ca			;    jr nc,Sqr16_Skip 
89ca			;    add hl,de 
89ca			;Sqr16_Skip: 
89ca			;    ccf 
89ca			;    rl d 
89ca			;    add a,a 
89ca			;    adc hl,hl 
89ca			;    add a,a 
89ca			;    adc hl,hl 
89ca			;    djnz Sqr16_Loop 
89ca			;    ret 
89ca			; 
89ca			; 
89ca			; Divide 8-bit values 
89ca			; In: Divide E by divider C 
89ca			; Out: A = result, B = rest 
89ca			; 
89ca			Div8: 
89ca af			    xor a 
89cb 06 08		    ld b,8 
89cd			Div8_Loop: 
89cd cb 13		    rl e 
89cf 17			    rla 
89d0 91			    sub c 
89d1 30 01		    jr nc,Div8_NoAdd 
89d3 81			    add a,c 
89d4			Div8_NoAdd: 
89d4 10 f7		    djnz Div8_Loop 
89d6 47			    ld b,a 
89d7 7b			    ld a,e 
89d8 17			    rla 
89d9 2f			    cpl 
89da c9			    ret 
