8d3f			; Decimal Signed Version 
8d3f			 
8d3f			; DispA 
8d3f			; -------------------------------------------------------------- 
8d3f			; Converts a signed integer value to a zero-terminated ASCII 
8d3f			; string representative of that value (using radix 10). 
8d3f			; -------------------------------------------------------------- 
8d3f			; INPUTS: 
8d3f			;     HL     Value to convert (two's complement integer). 
8d3f			;     DE     Base address of string destination. (pointer). 
8d3f			; -------------------------------------------------------------- 
8d3f			; OUTPUTS: 
8d3f			;     None 
8d3f			; -------------------------------------------------------------- 
8d3f			; REGISTERS/MEMORY DESTROYED 
8d3f			; AF HL 
8d3f			; -------------------------------------------------------------- 
8d3f			 
8d3f			;DispHLToASCII: 
8d3f			;   push    de 
8d3f			;   push    bc 
8d3f			; 
8d3f			;; Detect sign of HL. 
8d3f			;    bit    7, h 
8d3f			;    jr     z, ._DoConvert 
8d3f			; 
8d3f			;; HL is negative. Output '-' to string and negate HL. 
8d3f			;    ld     a, '-' 
8d3f			;    ld     (de), a 
8d3f			;    inc    de 
8d3f			; 
8d3f			;; Negate HL (using two's complement) 
8d3f			;    xor    a 
8d3f			;    sub    l 
8d3f			;    ld     l, a 
8d3f			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
8d3f			;    sbc    a, h 
8d3f			;    ld     h, a 
8d3f			; 
8d3f			;; Convert HL to digit characters 
8d3f			;._DoConvert: 
8d3f			;    ld     b, 0     ; B will count character length of number 
8d3f			;-   ld     a, 10 
8d3f			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
8d3f			;    push   af 
8d3f			;    inc    b 
8d3f			;    ld     a, h 
8d3f			;    or     l 
8d3f			;    jr     nz, - 
8d3f			; 
8d3f			;; Retrieve digits from stack 
8d3f			;-   pop    af 
8d3f			;    or     $30 
8d3f			;    ld     (de), a 
8d3f			;    inc    de 
8d3f			;    djnz   - 
8d3f			; 
8d3f			;; Terminate string with NULL 
8d3f			;    xor    a 
8d3f			;    ld     (de), a 
8d3f			; 
8d3f			;    pop    bc 
8d3f			;    pop    de 
8d3f			;    ret 
8d3f			 
8d3f			;Comments 
8d3f			; 
8d3f			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
8d3f			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
8d3f			;    Note that the output string will not be fixed-width. 
8d3f			; 
8d3f			;Example Usage 
8d3f			; 
8d3f			;    ld    hl, -1004 
8d3f			;    ld    de, OP1 
8d3f			;    call  DispA 
8d3f			;    ld    hl, OP1 
8d3f			;    syscall  PutS 
8d3f			 
