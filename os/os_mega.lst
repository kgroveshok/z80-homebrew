6834 c5				push bc  
6835 21 e1 fc			ld hl, display_fb0  
6838			cpr:	  
6838				; loop for cursor whole row  
6838 0e 28			ld c, display_cols  
683a 23			cpr1:	inc hl  
683b 0d				dec c  
683c 20 fc			jr nz, cpr1  
683e 05				dec b  
683f 20 f7			jr nz, cpr  
6841			  
6841				; add col	  
6841			  
6841 23			cpr2:	inc hl  
6842 1d				dec e  
6843 20 fc			jr nz, cpr2  
6845			  
6845 c1				pop bc  
6846 c9				ret  
