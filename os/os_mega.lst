12c4			if MALLOC_3 
12c4			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12c4			;heap_start        .equ  0x9000      ; Starting address of heap 
12c4			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12c4			; 
12c4			 ;     .org 0 
12c4			  ;    jp    main 
12c4			; 
12c4			; 
12c4			 ;     .org  0x100 
12c4			;main: 
12c4			 ;     ld    HL, 0x8100 
12c4			  ;    ld    SP, HL 
12c4			; 
12c4			;      call  heap_init 
12c4			 
12c4			      ; Make some allocations 
12c4			;      ld    HL, 12 
12c4			;      call  malloc            ; Allocates 0x9004 
12c4			; 
12c4			 ;     ld    HL, 12 
12c4			;      call  malloc            ; Allocates 0x9014 
12c4			 
12c4			;      ld    HL, 12 
12c4			;      call  malloc            ; Allocates 0x9024 
12c4			 
12c4			      ; Free some allocations 
12c4			;      ld    HL, 0x9014 
12c4			;      call  free 
12c4			 
12c4			;      ld    HL, 0x9004 
12c4			;      call  free 
12c4			; 
12c4			;      ld    HL, 0x9024 
12c4			;      call  free 
12c4			 
12c4			 
12c4			 ;     halt 
12c4			 
12c4			 
12c4			;------------------------------------------------------------------------------ 
12c4			;     heap_init                                                               : 
12c4			;                                                                             : 
12c4			; Description                                                                 : 
12c4			;     Initialise the heap and make it ready for malloc and free operations.   : 
12c4			;                                                                             : 
12c4			;     The heap is maintained as a linked list, starting with an initial       : 
12c4			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12c4			;     the first free block in the heap. Each block then points to the next    : 
12c4			;     free block within the heap, and the free list ends at the first block   : 
12c4			;     with a null pointer to the next free block.                             : 
12c4			;                                                                             : 
12c4			; Parameters                                                                  : 
12c4			;     Inputs are compile-time only. Two defines which specify the starting    : 
12c4			;     address of the heap and its size are required, along with a memory      : 
12c4			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12c4			;     principally stores a pointer to the first free block in the heap.       : 
12c4			;                                                                             : 
12c4			; Returns                                                                     : 
12c4			;     Nothing                                                                 : 
12c4			;------------------------------------------------------------------------------ 
12c4			heap_init: 
12c4			      push  HL 
12c4			 
12c4			      ; Initialise free list struct 
12c4			      ld    HL, heap_start 
12c4			      ld    (free_list), HL 
12c4			      ld    HL, 0 
12c4			      ld    (free_list+2), HL 
12c4			 
12c4			      ; Insert first free block at bottom of heap, consumes entire heap 
12c4			      ld    HL, heap_start+heap_size-4 
12c4			      ld    (heap_start), HL        ; Next block (end of free list) 
12c4			      ld    HL, heap_size-4 
12c4			      ld    (heap_start+2), HL      ; Block size 
12c4			 
12c4			      ; Insert end of free list block at top of heap - two null words will 
12c4			      ; terminate the free list 
12c4			      ld    HL, 0 
12c4			      ld    (heap_start+heap_size-2), HL 
12c4			      ld    (heap_start+heap_size-4), HL 
12c4			 
12c4			      pop   HL 
12c4			 
12c4			      ret 
12c4			 
12c4			 
12c4			;------------------------------------------------------------------------------ 
12c4			;     malloc                                                                  : 
12c4			;                                                                             : 
12c4			; Description                                                                 : 
12c4			;     Allocates the wanted space from the heap and returns the address of the : 
12c4			;     first useable byte of the allocation.                                   : 
12c4			;                                                                             : 
12c4			;     Allocations can happen in one of two ways:                              : 
12c4			;                                                                             : 
12c4			;     1. A free block may be found which is the exact size wanted. In this    : 
12c4			;        case the block is removed from the free list and retuedn to the      : 
12c4			;        caller.                                                              : 
12c4			;     2. A free block may be found which is larger than the size wanted. In   : 
12c4			;        this case, the larger block is split into two. The first portion of  : 
12c4			;        this block will become the requested space by the malloc call and    : 
12c4			;        is returned to the caller. The second portion becomes a new free     : 
12c4			;        block, and the free list is adjusted to maintain continuity via this : 
12c4			;        newly created block.                                                 : 
12c4			;                                                                             : 
12c4			;     malloc does not set any initial value in the allocated space, the       : 
12c4			;     caller is required to do this as required.                              : 
12c4			;                                                                             : 
12c4			;     This implementation of malloc uses the stack exclusively, and is        : 
12c4			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12c4			;     advisable to disable interrupts before calling malloc, and recommended  : 
12c4			;     to avoid the use of malloc inside ISRs in general.                      : 
12c4			;                                                                             : 
12c4			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12c4			;                                                                             : 
12c4			; Parameters                                                                  : 
12c4			;     HL  Number of bytes wanted                                              : 
12c4			;                                                                             : 
12c4			; Returns                                                                     : 
12c4			;     HL  Address of the first useable byte of the allocation                 : 
12c4			;                                                                             : 
12c4			; Flags                                                                       : 
12c4			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12c4			;                                                                             : 
12c4			; Stack frame                                                                 : 
12c4			;       |             |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |     BC      |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |     DE      |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |     IX      |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |  prev_free  |                                                       : 
12c4			;   +4  +-------------+                                                       : 
12c4			;       |  this_free  |                                                       : 
12c4			;   +2  +-------------+                                                       : 
12c4			;       |  next_free  |                                                       : 
12c4			;   +0  +-------------+                                                       : 
12c4			;       |             |                                                       : 
12c4			;                                                                             : 
12c4			;------------------------------------------------------------------------------ 
12c4			malloc: 
12c4			      push  BC 
12c4			      push  DE 
12c4			      push  IX 
12c4			 
12c4			      ld    A, H                    ; Exit if no space requested 
12c4			      or    L 
12c4			      jp    Z, malloc_early_exit 
12c4			 
12c4			      ; Set up stack frame 
12c4			      ex    DE, HL 
12c4			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12c4			      add   HL, SP 
12c4			      ld    SP, HL 
12c4			      ld    IX, 0                   ; Use IX as a frame pointer 
12c4			      add   IX, SP 
12c4			 
12c4			      ; Setup initial state 
12c4			      ld    HL, 4                   ; want must also include space used by block struct 
12c4			      add   HL, DE 
12c4			 
12c4			      ld    B, H                    ; Move want to BC 
12c4			      ld    C, L 
12c4			 
12c4			      ld    HL, free_list           ; Store prev_free ptr to stack 
12c4			      ld    (IX+4), L 
12c4			      ld    (IX+5), H 
12c4			 
12c4			      ld    E, (HL)                 ; Store this_free ptr to stack 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      ld    (IX+2), E 
12c4			      ld    (IX+3), D 
12c4			      ex    DE, HL                  ; this_free ptr into HL 
12c4			 
12c4			      ; Loop through free block list to find some space 
12c4			malloc_find_space: 
12c4			      ld    E, (HL)                 ; Load next_free ptr into DE 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			 
12c4			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12c4			      or    E 
12c4			      jp    Z, malloc_no_space 
12c4			 
12c4			      ld    (IX+0), E               ; Store next_free ptr to stack 
12c4			      ld    (IX+1), D 
12c4			 
12c4			      ; Does this block have enough space to make the allocation? 
12c4			      inc   HL                      ; Load free block size into DE 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			 
12c4			      ex    DE, HL                  ; Check size of block against want 
12c4			      or    A                       ; Ensure carry flag clear 
12c4			      sbc   HL, BC 
12c4			      push  HL                      ; Store the result for later (new block size) 
12c4			 
12c4			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12c4			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12c4			 
12c4			      ; this_free block is not big enough, setup ptrs to test next free block 
12c4			      pop   HL                      ; Discard previous result 
12c4			 
12c4			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12c4			      ld    H, (IX+3) 
12c4			      ld    (IX+4), L 
12c4			      ld    (IX+5), H 
12c4			 
12c4			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12c4			      ld    H, (IX+1) 
12c4			      ld    (IX+2), L 
12c4			      ld    (IX+3), H 
12c4			 
12c4			      jr    malloc_find_space 
12c4			 
12c4			      ; split a bigger block into two - requested size and remaining size 
12c4			malloc_alloc_split: 
12c4			      ex    DE, HL                  ; Calculate address of new free block 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			      add   HL, BC 
12c4			 
12c4			      ; Create a new block and point it at next_free 
12c4			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12c4			      ld    D, (IX+1) 
12c4			 
12c4			      ld    (HL), E                 ; Store next_free ptr into new block 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			      pop   DE                      ; Store size of new block into new block 
12c4			      inc   HL 
12c4			      ld    (HL), E 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			      ; Update this_free ptr to point to new block 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			 
12c4			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12c4			      ld    D, (IX+3) 
12c4			 
12c4			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12c4			      ld    (IX+3), H 
12c4			 
12c4			      ; Modify this_free block to be allocation 
12c4			      ex    DE, HL 
12c4			      xor   A                       ; Null the next block ptr of allocated block 
12c4			      ld    (HL), A 
12c4			      inc   HL 
12c4			      ld    (HL), A 
12c4			 
12c4			      inc   HL                      ; Store want size into allocated block 
12c4			      ld    (HL), C 
12c4			      inc   HL 
12c4			      ld    (HL), B 
12c4			      inc   HL 
12c4			      push  HL                      ; Address of allocation to return 
12c4			 
12c4			      jr    malloc_update_links 
12c4			 
12c4			malloc_alloc_fit: 
12c4			      pop   HL                      ; Dont need new block size, want is exact fit 
12c4			 
12c4			      ; Modify this_free block to be allocation 
12c4			      ex    DE, HL 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			 
12c4			      xor   A                       ; Null the next block ptr of allocated block 
12c4			      ld    (HL), A 
12c4			      inc   HL 
12c4			      ld    (HL), A 
12c4			 
12c4			      inc   HL                      ; Store address of allocation to return 
12c4			      inc   HL 
12c4			      inc   HL 
12c4			      push  HL 
12c4			 
12c4			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12c4			      ld    L, (IX+0)               ; next_free to HL 
12c4			      ld    H, (IX+1) 
12c4			 
12c4			      ld    (IX+2), L               ; HL to this_free 
12c4			      ld    (IX+3), H 
12c4			 
12c4			 
12c4			malloc_update_links: 
12c4			      ; Update prev_free ptr to point to this_free 
12c4			      ld    L, (IX+4)               ; prev_free ptr to HL 
12c4			      ld    H, (IX+5) 
12c4			 
12c4			      ld    E, (IX+2)               ; this_free ptr to DE 
12c4			      ld    D, (IX+3) 
12c4			 
12c4			      ld    (HL), E                 ; this_free ptr into prev_free 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			      ; Clear the Z flag to indicate successful allocation 
12c4			      ld    A, D 
12c4			      or    E 
12c4			 
12c4			      pop   DE                      ; Address of allocation 
12c4			 
12c4			malloc_no_space: 
12c4			      ld    HL, 6                   ; Clean up stack frame 
12c4			      add   HL, SP 
12c4			      ld    SP, HL 
12c4			 
12c4			      ex    DE, HL                  ; Alloc addr into HL for return 
12c4			 
12c4			malloc_early_exit: 
12c4			      pop   IX 
12c4			      pop   DE 
12c4			      pop   BC 
12c4			 
12c4			      ret 
12c4			 
12c4			 
12c4			;------------------------------------------------------------------------------ 
12c4			;     free                                                                    : 
12c4			;                                                                             : 
12c4			; Description                                                                 : 
12c4			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12c4			;     returned by malloc, otherwise the behaviour is undefined.               : 
12c4			;                                                                             : 
12c4			;     Where possible, directly adjacent free blocks will be merged together   : 
12c4			;     into larger blocks to help ensure that the heap does not become         : 
12c4			;     excessively fragmented.                                                 : 
12c4			;                                                                             : 
12c4			;     free does not clear or set any other value into the freed space, and    : 
12c4			;     therefore its contents may be visible through subsequent malloc's. The  : 
12c4			;     caller should clear the freed space as required.                        : 
12c4			;                                                                             : 
12c4			;     This implementation of free uses the stack exclusively, and is          : 
12c4			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12c4			;     advisable to disable interrupts before calling free, and recommended    : 
12c4			;     to avoid the use of free inside ISRs in general.                        : 
12c4			;                                                                             : 
12c4			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12c4			;                                                                             : 
12c4			; Parameters                                                                  : 
12c4			;     HL  Pointer to address of first byte of allocation to be freed          : 
12c4			;                                                                             : 
12c4			; Returns                                                                     : 
12c4			;     Nothing                                                                 : 
12c4			;                                                                             : 
12c4			; Stack frame                                                                 : 
12c4			;       |             |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |     BC      |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |     DE      |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |     IX      |                                                       : 
12c4			;       +-------------+                                                       : 
12c4			;       |  prev_free  |                                                       : 
12c4			;   +2  +-------------+                                                       : 
12c4			;       |  next_free  |                                                       : 
12c4			;   +0  +-------------+                                                       : 
12c4			;       |             |                                                       : 
12c4			;                                                                             : 
12c4			;------------------------------------------------------------------------------ 
12c4			free: 
12c4			      push  BC 
12c4			      push  DE 
12c4			      push  IX 
12c4			 
12c4			      ld    A, H                    ; Exit if ptr is null 
12c4			      or    L 
12c4			      jp    Z, free_early_exit 
12c4			 
12c4			      ; Set up stack frame 
12c4			      ex    DE, HL 
12c4			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12c4			      add   HL, SP 
12c4			      ld    SP, HL 
12c4			      ld    IX, 0                   ; Use IX as a frame pointer 
12c4			      add   IX, SP 
12c4			 
12c4			      ; The address in HL points to the start of the useable allocated space, 
12c4			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12c4			      ; address of the block itself. 
12c4			      ex    DE, HL 
12c4			      ld    DE, -4 
12c4			      add   HL, DE 
12c4			 
12c4			      ; An allocated block must have a null next block pointer in it 
12c4			      ld    A, (HL) 
12c4			      inc   HL 
12c4			      or    (HL) 
12c4			      jp    NZ, free_done 
12c4			 
12c4			      dec   HL 
12c4			 
12c4			      ld    B, H                    ; Copy HL to BC 
12c4			      ld    C, L 
12c4			 
12c4			      ; Loop through the free list to find the first block with an address 
12c4			      ; higher than the block being freed 
12c4			      ld    HL, free_list 
12c4			 
12c4			free_find_higher_block: 
12c4			      ld    E, (HL)                 ; Load next ptr from free block 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      dec   HL 
12c4			 
12c4			      ld    (IX+0), E               ; Save ptr to next free block 
12c4			      ld    (IX+1), D 
12c4			      ld    (IX+2), L               ; Save ptr to prev free block 
12c4			      ld    (IX+3), H 
12c4			 
12c4			      ld    A, B                    ; Check if DE is greater than BC 
12c4			      cp    D                       ; Compare MSB first 
12c4			      jr    Z, $+4                  ; MSB the same, compare LSB 
12c4			      jr    NC, free_find_higher_block_skip 
12c4			      ld    A, C 
12c4			      cp    E                       ; Then compare LSB 
12c4			      jr    C, free_found_higher_block 
12c4			 
12c4			free_find_higher_block_skip: 
12c4			      ld    A, D                    ; Reached the end of the free list? 
12c4			      or    E 
12c4			      jp    Z, free_done 
12c4			 
12c4			      ex    DE, HL 
12c4			 
12c4			      jr    free_find_higher_block 
12c4			 
12c4			free_found_higher_block: 
12c4			      ; Insert freed block between prev and next free blocks 
12c4			      ld    (HL), C                 ; Point prev free block to freed block 
12c4			      inc   HL 
12c4			      ld    (HL), B 
12c4			 
12c4			      ld    H, B                    ; Point freed block at next free block 
12c4			      ld    L, C 
12c4			      ld    (HL), E 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			      ; Check if the freed block is adjacent to the next free block 
12c4			      inc   HL                      ; Load size of freed block into HL 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      ex    DE, HL 
12c4			 
12c4			      add   HL, BC                  ; Add addr of freed block and its size 
12c4			 
12c4			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12c4			      ld    D, (IX+1) 
12c4			 
12c4			      or    A                       ; Clear the carry flag 
12c4			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12c4			      jr    NZ, free_check_adjacent_to_prev 
12c4			 
12c4			      ; Freed block is adjacent to next, merge into one bigger block 
12c4			      ex    DE, HL                  ; Load next ptr from next block into DE 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      push  HL                      ; Save ptr to next block for later 
12c4			 
12c4			      ld    H, B                    ; Store ptr from next block into freed block 
12c4			      ld    L, C 
12c4			      ld    (HL), E 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			      pop   HL                      ; Restore ptr to next block 
12c4			      inc   HL                      ; Load size of next block into DE 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      push  DE                      ; Save next block size for later 
12c4			 
12c4			      ld    H, B                    ; Load size of freed block into HL 
12c4			      ld    L, C 
12c4			      inc   HL 
12c4			      inc   HL 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      ex    DE, HL 
12c4			 
12c4			      pop   DE                      ; Restore size of next block 
12c4			      add   HL, DE                  ; Add sizes of both blocks 
12c4			      ex    DE, HL 
12c4			 
12c4			      ld    H, B                    ; Store new bigger size into freed block 
12c4			      ld    L, C 
12c4			      inc   HL 
12c4			      inc   HL 
12c4			      ld    (HL), E 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			free_check_adjacent_to_prev: 
12c4			      ; Check if the freed block is adjacent to the prev free block 
12c4			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12c4			      ld    H, (IX+3) 
12c4			 
12c4			      inc   HL                      ; Size of prev free block into DE 
12c4			      inc   HL 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			      dec   HL 
12c4			 
12c4			      add   HL, DE                  ; Add prev block addr and size 
12c4			 
12c4			      or    A                       ; Clear the carry flag 
12c4			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12c4			      jr    NZ, free_done 
12c4			 
12c4			      ; Freed block is adjacent to prev, merge into one bigger block 
12c4			      ld    H, B                    ; Load next ptr from freed block into DE 
12c4			      ld    L, C 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      push  HL                      ; Save freed block ptr for later 
12c4			 
12c4			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12c4			      ld    H, (IX+3) 
12c4			      ld    (HL), E 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			      pop   HL                      ; Restore freed block ptr 
12c4			      inc   HL                      ; Load size of freed block into DE 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			      push  DE                      ; Save freed block size for later 
12c4			 
12c4			      ld    L, (IX+2)               ; Load size of prev block into DE 
12c4			      ld    H, (IX+3) 
12c4			      inc   HL 
12c4			      inc   HL 
12c4			      ld    E, (HL) 
12c4			      inc   HL 
12c4			      ld    D, (HL) 
12c4			 
12c4			      pop   HL                      ; Add sizes of both blocks 
12c4			      add   HL, DE 
12c4			      ex    DE, HL 
12c4			 
12c4			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12c4			      ld    H, (IX+3) 
12c4			      inc   HL 
12c4			      inc   HL 
12c4			      ld    (HL), E 
12c4			      inc   HL 
12c4			      ld    (HL), D 
12c4			 
12c4			free_done: 
12c4			      ld    HL, 4                   ; Clean up stack frame 
12c4			      add   HL, SP 
12c4			      ld    SP, HL 
12c4			 
12c4			free_early_exit: 
12c4			      pop   IX 
12c4			      pop   DE 
12c4			      pop   BC 
12c4			 
12c4			      ret 
12c4			 
12c4			 
12c4			;      .org 0x8000 
12c4			; 
12c4			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12c4			 ;                 .dw   0 
12c4			 
12c4			endif 
12c4			 
12c4			 
12c4			if MALLOC_4 
12c4			 
12c4			; My memory allocation code. Very very simple.... 
12c4			; allocate space under 250 chars 
12c4			 
12c4			heap_init: 
12c4				; init start of heap as zero 
12c4				;  
12c4			 
12c4				ld hl, heap_start 
12c4			;	ld a, 0 
12c4				ld (hl), 0      ; empty block 
12c4				inc hl 
12c4			;	ld a, 0 
12c4				ld (hl), 0      ; length of block 
12c4				; write end of list 
12c4				inc hl 
12c4				ld a,(hl) 
12c4				inc hl 
12c4				ld a,(hl) 
12c4				 
12c4			 
12c4				; init some malloc vars 
12c4			 
12c4				ld hl, 0 
12c4				ld (free_list), hl       ; store last malloc location 
12c4			 
12c4				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12c4			;	ld a, 0 
12c4				ld (hl), 0 
12c4			 
12c4			 
12c4				ld hl, heap_start 
12c4				;  
12c4				  
12c4				ret 
12c4			 
12c4			 
12c4			;    free block marker 
12c4			;    requested size  
12c4			;    pointer to next block 
12c4			;    .... 
12c4			;    next block marker 
12c4			 
12c4			 
12c4			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12c4			; 
12c4			 
12c4			 
12c4			malloc:  
12c4				push de 
12c4				push bc 
12c4				push af 
12c4			 
12c4				; hl space required 
12c4				 
12c4				ld c, l    ; hold space   (TODO only a max of 255) 
12c4			 
12c4			;	inc c     ; TODO BUG need to fix memory leak on push str 
12c4			;	inc c 
12c4			;	inc c 
12c4			;	inc c 
12c4			;	inc c 
12c4			;	inc c 
12c4			;	inc c 
12c4			 
12c4			 
12c4			 
12c4				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12c4			 
12c4				ld a, (free_list+3) 
12c4			;	cp 0 
12c4				or a 
12c4				jr z, .contheap 
12c4			 
12c4				ld hl, (free_list)     ; get last alloc 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "mrs" 
12c4						CALLMONITOR 
12c4					endif 
12c4				jr .startalloc 
12c4			 
12c4			.contheap: 
12c4				ld hl, heap_start 
12c4			 
12c4			.startalloc: 
12c4			 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "mym" 
12c4						CALLMONITOR 
12c4					endif 
12c4			.findblock: 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "mmf" 
12c4						CALLMONITOR 
12c4					endif 
12c4			 
12c4				ld a,(hl)  
12c4				; if byte is zero then clear to use 
12c4			 
12c4			;	cp 0 
12c4				or a 
12c4				jr z, .foundemptyblock 
12c4			 
12c4				; if byte is not clear 
12c4				;     then byte is offset to next block 
12c4			 
12c4				inc hl 
12c4				ld a, (hl) ; get size 
12c4			.nextblock:	inc hl 
12c4					ld e, (hl) 
12c4					inc hl 
12c4					ld d, (hl) 
12c4					ex de, hl 
12c4			;	inc hl  ; move past the store space 
12c4			;	inc hl  ; move past zero index  
12c4			 
12c4				; TODO detect no more space 
12c4			 
12c4				push hl 
12c4				ld de, heap_end 
12c4				call cmp16 
12c4				pop hl 
12c4				jr nc, .nospace 
12c4			 
12c4				jr .findblock 
12c4			 
12c4			.nospace: ld hl, 0 
12c4				jp .exit 
12c4			 
12c4			 
12c4			.foundemptyblock:	 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "mme" 
12c4						CALLMONITOR 
12c4					endif 
12c4			 
12c4			; TODO has block enough space if reusing??? 
12c4			 
12c4				;  
12c4			 
12c4			; see if this block has been previously used 
12c4				inc hl 
12c4				ld a, (hl) 
12c4				dec hl 
12c4			;	cp 0 
12c4				or a 
12c4				jr z, .newblock 
12c4			 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "meR" 
12c4						CALLMONITOR 
12c4					endif 
12c4			 
12c4			; no reusing previously allocated block 
12c4			 
12c4			; is it smaller than previously used? 
12c4				 
12c4				inc hl    ; move to size 
12c4				ld a, c 
12c4				sub (hl)        ; we want c < (hl) 
12c4				dec hl    ; move back to marker 
12c4			        jr z, .findblock 
12c4			 
12c4				; update with the new size which should be lower 
12c4			 
12c4			        ;inc  hl   ; negate next move. move back to size  
12c4			 
12c4			.newblock: 
12c4				; need to be at marker here 
12c4			 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "meN" 
12c4						CALLMONITOR 
12c4					endif 
12c4			 
12c4			 
12c4				ld a, c 
12c4			 
12c4				ld (free_list+3), a	 ; flag resume from last malloc  
12c4				ld (free_list), hl    ; save out last location 
12c4			 
12c4			 
12c4				;inc a     ; space for length byte 
12c4				ld (hl), a     ; save block in use marker 
12c4			 
12c4				inc hl   ; move to space marker 
12c4				ld (hl), a    ; save new space 
12c4			 
12c4				inc hl   ; move to start of allocated area 
12c4				 
12c4			;	push hl     ; save where we are - 1  
12c4			 
12c4			;	inc hl  ; move past zero index  
12c4				; skip space to set down new marker 
12c4			 
12c4				; provide some extra space for now 
12c4			 
12c4				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12c4				inc a 
12c4				inc a 
12c4			 
12c4				push hl   ; save where we are in the node block 
12c4			 
12c4				call addatohl 
12c4			 
12c4				; write linked list point 
12c4			 
12c4				pop de     ; get our node position 
12c4				ex de, hl 
12c4			 
12c4				ld (hl), e 
12c4				inc hl 
12c4				ld (hl), d 
12c4			 
12c4				inc hl 
12c4			 
12c4				; now at start of allocated data so save pointer 
12c4			 
12c4				push hl 
12c4			 
12c4				; jump to position of next node and setup empty header in DE 
12c4			 
12c4				ex de, hl 
12c4			 
12c4			;	inc hl ; move past end of block 
12c4			 
12c4			;	ld a, 0 
12c4				ld (hl), 0   ; empty marker 
12c4				inc hl 
12c4				ld (hl), 0   ; size 
12c4				inc hl  
12c4				ld (hl), 0   ; ptr 
12c4				inc hl 
12c4				ld (hl), 0   ; ptr 
12c4			 
12c4			 
12c4				pop hl 
12c4			 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "mmr" 
12c4						CALLMONITOR 
12c4					endif 
12c4			 
12c4			.exit: 
12c4				pop af 
12c4				pop bc 
12c4				pop de  
12c4				ret 
12c4			 
12c4			 
12c4			 
12c4			 
12c4			free:  
12c4				push hl 
12c4				push af 
12c4				; get address in hl 
12c4			 
12c4					if DEBUG_FORTH_MALLOC_INT 
12c4						DMARK "fre" 
12c4						CALLMONITOR 
12c4					endif 
12c4				; data is at hl - move to block count 
12c4				dec hl 
12c4				dec hl    ; get past pointer 
12c4				dec hl 
12c4			 
12c4				ld a, (hl)    ; need this for a validation check 
12c4			 
12c4				dec hl    ; move to block marker 
12c4			 
12c4				; now check that the block count and block marker are the same  
12c4			        ; this checks that we are on a malloc node and not random memory 
12c4			        ; OK a faint chance this could be a problem but rare - famous last words! 
12c4			 
12c4				ld c, a 
12c4				ld a, (hl)    
12c4			 
12c4				cp c 
12c4				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12c4			 
12c4				; yes good chance we are on a malloc node 
12c4			 
12c4			;	ld a, 0      
12c4				ld (hl), 0   ; mark as free 
12c4			 
12c4				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12c4			 
12c4			.freeignore:  
12c4			 
12c4				pop af 
12c4				pop hl 
12c4			 
12c4				ret 
12c4			 
12c4			 
12c4			 
12c4			endif 
