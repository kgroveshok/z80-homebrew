1d66			 
1d66			 
1d66			FORTH_CHK_DSP_UNDER: macro 
1d66				push hl 
1d66				push de 
1d66				ld hl,(cli_data_sp) 
1d66				ld de, cli_data_stack 
1d66				call cmp16 
1d66				jp c, fault_dsp_under 
1d66				pop de 
1d66				pop hl 
1d66				endm 
1d66			 
1d66			 
1d66			FORTH_CHK_RSP_UNDER: macro 
1d66				push hl 
1d66				push de 
1d66				ld hl,(cli_ret_sp) 
1d66				ld de, cli_ret_stack 
1d66				call cmp16 
1d66				jp c, fault_rsp_under 
1d66				pop de 
1d66				pop hl 
1d66				endm 
1d66			 
1d66			FORTH_CHK_LOOP_UNDER: macro 
1d66				push hl 
1d66				push de 
1d66				ld hl,(cli_loop_sp) 
1d66				ld de, cli_loop_stack 
1d66				call cmp16 
1d66				jp c, fault_loop_under 
1d66				pop de 
1d66				pop hl 
1d66				endm 
1d66			 
