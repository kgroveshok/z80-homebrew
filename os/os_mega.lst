6869			; **********************************************************************  
6869			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
6869			; **********************************************************************  
6869			;  
6869			; **  Written as a Small Computer Monitor App  
6869			; **  www.scc.me.uk  
6869			;  
6869			; History  
6869			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
6869			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
6869			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
6869			;  
6869			; **********************************************************************  
6869			;  
6869			; This program is an example of one of the methods of interfacing an   
6869			; alphanumeric LCD module.   
6869			;  
6869			; In this example the display is connected to either a Z80 PIO or a   
6869			; simple 8-bit output port.   
6869			;  
6869			; This interfacing method uses 4-bit data mode and uses time delays  
6869			; rather than polling the display's ready status. As a result the   
6869			; interface only requires 6 simple output lines:  
6869			;   Output bit 0 = not used  
6869			;   Output bit 1 = not used  
6869			;   Output bit 2 = RS         High = data, Low = instruction  
6869			;   Output bit 3 = E          Active high  
6869			;   Output bit 4 = DB4  
6869			;   Output bit 5 = DB5  
6869			;   Output bit 6 = DB6  
6869			;   Output bit 7 = DB7  
6869			; Display's R/W is connected to 0v so it is always in write mode  
6869			;  
6869			; This set up should work with any system supporting the RC2014 bus  
6869			  
6869			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
6869			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
6869			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
6869			;  
6869			; **********************************************************************  
6869			  
6869			; Additonal for 4x40. E1 and E2 instead of just E   
6869			; TODO swipe vidout signal on port a to activate E2  
6869			  
6869			; **********************************************************************  
6869			; **  Constants  
6869			; **********************************************************************  
6869			; LCD constants required by LCD support module  
6869			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
6869			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
6869			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
6869			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
6869			; TODO Decide which E is being set  
6869			kLCDWidth:  EQU display_cols             ;Width in characters  
6869			  
6869			; **********************************************************************  
6869			; **  Code library usage  
6869			; **********************************************************************  
6869			  
6869			; send character to current cursor position  
6869			; wraps and/or scrolls screen automatically  
6869			  
6869			  
6869			  
6869			lcd_init:  
6869			  
6869			; SCMonAPI functions used  
6869			  
6869			; Alphanumeric LCD functions used  
6869			; no need to specify specific functions for this module  
6869			  
6869 3e cf		            LD   A, 11001111b  
686b d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
686d 3e 00		            LD   A, 00000000b  
686f d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6871			  
6871			; Initialise alphanumeric LCD module  
6871 3e 00				ld a, 0  
6873 32 fb fa				ld (display_lcde1e2), a  
6876 cd f7 68		            CALL fLCD_Init      ;Initialise LCD module  
6879 3e 01				ld a, 1  
687b 32 fb fa				ld (display_lcde1e2), a  
687e cd f7 68		            CALL fLCD_Init      ;Initialise LCD module  
6881			  
6881 c9				ret  
