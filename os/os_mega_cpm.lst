24d5			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
24d5			; | | At start the current various registers will be displayed with contents. 
24d5			; | | Top right corner will show the most recent debug marker seen. 
24d5			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
24d5			; | | and the return stack pointer (RSP). 
24d5			; | | Pressing: 
24d5			; | |  
24d5			; | |    1 - Initial screen 
24d5			; | |  
24d5			; | |    2 - Display a data dump of HL 
24d5			; | |  
24d5			; | |    3 - Display a data dump of DE 
24d5			; | |  
24d5			; | |    4 - Display a data dump of BC 
24d5			; | |  
24d5			; | |    5 - Display a data dump of HL 
24d5			; | |  
24d5			; | |    6 - Display a data dump of DSP 
24d5			; | |  
24d5			; | |    7 - Display a data dump of RSP 
24d5			; | |  
24d5			; | |    8 - Display a data dump of what is at DSP 
24d5			; | |  
24d5			; | |    9 - Display a data dump of what is at RSP 
24d5			; | |  
24d5			; | |    0 - Exit monitor and continue running. This will also enable break points 
24d5			; | |  
24d5			; | |    * - Disable break points 
24d5			; | |  
24d5			; | |    # - Enter traditional monitor mode 
24d5			; | |  
24d5			; | | 
24d5			; | | Monitor Mode 
24d5			; | | ------------ 
24d5			; | | A prompt of '>' will be shown for various commands: 
24d5			; | |  
24d5			; | |    D xxxx - Display a data dump starting from hex address xxxx 
24d5			; | |  
24d5			; | |    C - Continue display a data dump from the last set address 
24d5			; | |  
24d5			; | |    M xxxx - Set start of memory edit at address xx 
24d5			; | |  
24d5			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
24d5			; | |  
24d5			; | |    G xxxx - Exec code at specific address 
24d5			; | |  
24d5			; | |    Q - Return to previous 
24d5				if DEBUG_FORTH_WORDS_KEY 
24d5					DMARK "MON" 
24d5				if DEMARK_VERSION = 1  
24d5 e5					push hl  
24d6 21 de 24				ld hl, .dmark  
24d9 22 60 ee				ld (debug_mark), hl  
24dc				endif  
