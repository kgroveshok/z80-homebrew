60f8			; **********************************************************************  
60f8			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
60f8			; **********************************************************************  
60f8			;  
60f8			; **  Written as a Small Computer Monitor App   
60f8			; **  Version 0.1 SCC 2018-05-16  
60f8			; **  www.scc.me.uk  
60f8			;  
60f8			; **********************************************************************  
60f8			;  
60f8			; This module provides support for alphanumeric LCD modules using with  
60f8			; *  HD44780 (or compatible) controller  
60f8			; *  5 x 7 pixel fonts  
60f8			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
60f8			; *  Interface via six digital outputs to the display (see below)  
60f8			;  
60f8			; LCD module pinout:  
60f8			;   1  Vss   0v supply  
60f8			;   2  Vdd   5v supply  
60f8			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
60f8			;   4  RS    High = data, Low = instruction  
60f8			;   5  R/W   High = Read, Low = Write  
60f8			;   6  E     Enable signal (active high)  
60f8			;   7  DB0   Data bit 0  
60f8			;   8  DB1   Data bit 1  
60f8			;   9  DB2   Data bit 2  
60f8			;  10  DB3   Data bit 3  
60f8			;  11  DB4   Data bit 4  
60f8			;  12  DB5   Data bit 5  
60f8			;  13  DB6   Data bit 6  
60f8			;  14  DB7   Data bit 7  
60f8			;  15  A     Backlight anode (+)  
60f8			;  16  K     Backlight cathode (-)  
60f8			;  
60f8			; This interfacing method uses 4-bit data mode and uses time delays  
60f8			; rather than polling the display's ready status. As a result the   
60f8			; interface only requires 6 simple output lines:  
60f8			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
60f8			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
60f8			;   LCD DB4 = Microcomputer output port bit 4  
60f8			;   LCD DB5 = Microcomputer output port bit 5  
60f8			;   LCD DB6 = Microcomputer output port bit 6  
60f8			;   LCD DB7 = Microcomputer output port bit 7  
60f8			; Display's R/W is connected to 0v so it is always in write mode  
60f8			; All 6 connections must be on the same port address <kLCDPrt>  
60f8			; This method also allows a decent length of cable from micro to LCD  
60f8			;  
60f8			; **********************************************************************  
60f8			;  
60f8			; To include the code for any given function provided by this module,   
60f8			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
60f8			; the parent source file.  
60f8			; For example:  #REQUIRES   uHexPrefix  
60f8			;  
60f8			; Also #INCLUDE this file at some point after the #REQUIRES statements  
60f8			; in the parent source file.  
60f8			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
60f8			;  
60f8			; These are the function names provided by this module:  
60f8			; fLCD_Init                     ;Initialise LCD  
60f8			; fLCD_Inst                     ;Send instruction to LCD  
60f8			; fLCD_Data                     ;Send data byte to LCD  
60f8			; fLCD_Pos                      ;Position cursor  
60f8			; fLCD_Str                      ;Display string  
60f8			; fLCD_Def                      ;Define custom character  
60f8			;  
60f8			; **********************************************************************  
60f8			;  
60f8			; Requires SCMonAPI.asm to also be included in the project  
60f8			;  
60f8			  
60f8			  
60f8			; **********************************************************************  
60f8			; **  Constants  
60f8			; **********************************************************************  
60f8			  
60f8			; Constants that must be defined externally  
60f8			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
60f8			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
60f8			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
60f8			;kLCDWidth: EQU 20             ;Width in characters  
60f8			  
60f8			; general line offsets in any frame buffer  
60f8			  
60f8			  
60f8			display_row_1: equ 0  
60f8			display_row_2: equ display_row_1+display_cols  
60f8			display_row_3: equ display_row_2 + display_cols  
60f8			display_row_4: equ display_row_3 + display_cols  
60f8			;display_row_4_eol:   
60f8			  
60f8			  
60f8			; Cursor position values for the start of each line  
60f8			  
60f8			; E  
60f8			kLCD_Line1: EQU 0x00   
60f8			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
60f8			; E1  
60f8			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
60f8			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
60f8			  
60f8			; Instructions to send as A register to fLCD_Inst  
60f8			kLCD_Clear: EQU 00000001b     ;LCD clear  
60f8			kLCD_Off:   EQU 00001000b     ;LCD off  
60f8			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
60f8			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
60f8			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
60f8			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
60f8			  
60f8			; Constants used by this code module  
60f8			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
60f8			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
60f8			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
60f8			  
60f8			  
60f8			  
60f8			; **********************************************************************  
60f8			; **  LCD support functions  
60f8			; **********************************************************************  
60f8			  
60f8			; Initialise alphanumeric LCD module  
60f8			; LCD control register codes:  
60f8			;   DL   0 = 4-bit mode        1 = 8-bit mode  
60f8			;   N    0 = 1-line mode       1 = 2-line mode  
60f8			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
60f8			;   D    0 = Display off       1 = Display on  
60f8			;   C    0 = Cursor off        1 = Cursor on  
60f8			;   B    0 = Blinking off      1 = Blinking on  
60f8			;   ID   0 = Decrement mode    1 = Increment mode  
60f8			;   SH   0 = Entire shift off  1 = Entire shift on  
60f8 3e 28		fLCD_Init:  LD   A, 40  
60fa cd 1f 62		            CALL LCDDelay       ;Delay 40ms after power up  
60fd			; For reliable reset set 8-bit mode - 3 times  
60fd cd ef 61		            CALL WrFn8bit       ;Function = 8-bit mode  
6100 cd ef 61		            CALL WrFn8bit       ;Function = 8-bit mode  
6103 cd ef 61		            CALL WrFn8bit       ;Function = 8-bit mode  
6106			; Set 4-bit mode  
6106 cd eb 61		            CALL WrFn4bit       ;Function = 4-bit mode  
6109 cd 1d 62		            CALL LCDDelay1      ;Delay 37 us or more  
610c			; Function set  
610c 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
610e cd 21 61		            CALL fLCD_Inst      ;2 line, display on  
6111			; Display On/Off control  
6111 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6113 cd 21 61		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6116			; Display Clear  
6116 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6118 cd 21 61		            CALL fLCD_Inst      ;Clear display  
611b			; Entry mode  
611b 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
611d cd 21 61		            CALL fLCD_Inst      ;Increment mode, shift off  
6120			; Display module now initialised  
6120 c9			            RET  
6121			; ok to here  
6121			  
6121			; Write instruction to LCD  
6121			;   On entry: A = Instruction byte to be written  
6121			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6121 f5			fLCD_Inst:  PUSH AF  
6122 f5			            PUSH AF  
6123 cd 35 61		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6126 f1			            POP  AF  
6127 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6128 17			            RLA  
6129 17			            RLA  
612a 17			            RLA  
612b cd 35 61		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
612e 3e 02		            LD   A, 2  
6130 cd 1f 62		            CALL LCDDelay       ;Delay 2 ms to complete   
6133 f1			            POP  AF  
6134 c9			            RET  
6135			Wr4bits:   
6135 f5					push af  
6136 3a f9 fa				ld a, (display_lcde1e2)  
6139 fe 00				cp 0     ; e  
613b 20 10				jr nz, .wea2	  
613d f1					pop af  
613e e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6140 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6142 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6144 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6146 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6148 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
614a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
614c c9			            RET  
614d f1			.wea2:		pop af  
614e e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6150 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6152 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6154 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6156 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6158 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
615a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
615c c9			            RET  
615d			  
615d			  
615d			; Write data to LCD  
615d			;   On entry: A = Data byte to be written  
615d			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
615d f5			fLCD_Data:  PUSH AF  
615e f5			            PUSH AF  
615f cd 71 61		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6162 f1			            POP  AF  
6163 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6164 17			            RLA  
6165 17			            RLA  
6166 17			            RLA  
6167 cd 71 61		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
616a 3e 96		            LD   A, 150  
616c 3d			Wait:      DEC  A              ;Wait a while to allow data   
616d 20 fd		            JR   NZ, Wait      ;  write to complete  
616f f1			            POP  AF  
6170 c9			            RET  
6171			Wr4bitsa:     
6171 f5					push af  
6172 3a f9 fa				ld a, (display_lcde1e2)  
6175 fe 00				cp 0     ; e1  
6177 20 16				jr nz, .we2	  
6179 f1					pop af  
617a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
617c cb d7		            SET  kLCDBitRS, A  
617e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6180 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6182 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6184 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6186 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6188 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
618a cb 97		            RES  kLCDBitRS, A  
618c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
618e c9			            RET  
618f f1			.we2:		pop af  
6190 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6192 cb d7		            SET  kLCDBitRS, A  
6194 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6196 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6198 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
619a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
619c cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
619e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
61a0 cb 97		            RES  kLCDBitRS, A  
61a2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
61a4 c9			            RET  
61a5			  
61a5			  
61a5			; Position cursor to specified location  
61a5			;   On entry: A = Cursor position  
61a5			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
61a5 f5			fLCD_Pos:   PUSH AF  
61a6					; at this point set the E1 or E2 flag depending on position  
61a6			  
61a6 c5					push bc  
61a7			;		push af  
61a7 06 00				ld b, 0  
61a9 4f					ld c, a  
61aa 3e 4f				ld a, kLCD_Line3-1  
61ac b7			 		or a      ;clear carry flag  
61ad 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
61ae 38 04				jr c, .pe1  
61b0			  
61b0					; E selection  
61b0 cb 80				res 0, b         ; bit 0 unset e  
61b2			;		pop af    ; before line 3 so recover orig pos  
61b2			;		ld c, a    ; save for poking back  
61b2 18 06				jr .peset	          
61b4			.pe1:          	; E2 selection  
61b4 cb c0				set 0, b         ; bit 0 set e1  
61b6 79					ld a, c  
61b7 de 4f				sbc a, kLCD_Line3-1  
61b9 4f					ld c, a	         ; save caculated offset  
61ba			;		pop af     ; bin this original value now we have calculated form  
61ba			  
61ba			.peset:		; set bit  
61ba 78					ld a, b  
61bb 32 f9 fa				ld (display_lcde1e2), a 	  
61be 79					ld a, c  
61bf c1					pop bc  
61c0			  
61c0 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
61c2 cd 21 61		            CALL fLCD_Inst      ;Write instruction to LCD  
61c5 f1			            POP  AF  
61c6 c9			            RET  
61c7			  
61c7			  
61c7			; Output text string to LCD  
61c7			;   On entry: DE = Pointer to null terminated text string  
61c7			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
61c7 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
61c8 b7			            OR   A              ;Null terminator?  
61c9 c8			            RET  Z              ;Yes, so finished  
61ca cd 5d 61		            CALL fLCD_Data      ;Write character to display  
61cd 13			            INC  DE             ;Point to next character  
61ce 18 f7		            JR   fLCD_Str       ;Repeat  
61d0 c9					ret  
61d1			  
61d1			; Define custom character  
61d1			;   On entry: A = Character number (0 to 7)  
61d1			;             DE = Pointer to character bitmap data  
61d1			;   On exit:  A = Next character number  
61d1			;             DE = Next location following bitmap  
61d1			;             BC HL IX IY I AF' BC' DE' HL' preserved  
61d1			; Character is   
61d1 c5			fLCD_Def:   PUSH BC  
61d2 f5			            PUSH AF  
61d3 07			            RLCA                ;Calculate location  
61d4 07			            RLCA                ;  for bitmap data  
61d5 07			            RLCA                ;  = 8 x CharacterNumber  
61d6 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
61d8 cd 21 61		            CALL fLCD_Inst      ;Write instruction to LCD  
61db 06 00		            LD   B, 0  
61dd 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
61de cd 5d 61		            CALL fLCD_Data      ;Write byte to display  
61e1 13			            INC  DE             ;Point to next byte  
61e2 04			            INC  B              ;Count bytes  
61e3 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
61e5 28 f6		            JR   Z, Loop       ;No, so repeat  
61e7 f1			            POP  AF  
61e8 3c			            INC  A              ;Increment character number  
61e9 c1			            POP  BC  
61ea c9			            RET  
61eb			  
61eb			  
61eb			; **********************************************************************  
61eb			; **  Private functions  
61eb			; **********************************************************************  
61eb			  
61eb			; Write function to LCD  
61eb			;   On entry: A = Function byte to be written  
61eb			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
61eb 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
61ed 18 02		            JR   WrFunc  
61ef 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
61f1 f5			WrFunc:     PUSH AF  
61f2 f5					push af  
61f3 3a f9 fa				ld a, (display_lcde1e2)  
61f6 fe 00				cp 0     ; e1  
61f8 20 0f				jr nz, .wfea2	  
61fa f1					pop af  
61fb d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
61fd cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
61ff cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6201 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6203 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6205 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6207 18 0d			jr .wfskip  
6209 f1			.wfea2:		pop af  
620a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
620c cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
620e cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6210 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6212 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6214 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6216 3e 05		.wfskip:            LD  A, 5  
6218 cd 1f 62		            CALL LCDDelay       ;Delay 5 ms to complete  
621b f1			            POP  AF  
621c c9			            RET  
621d			  
621d			  
621d			; Delay in milliseconds  
621d			;   On entry: A = Number of milliseconds delay  
621d			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
621d 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
621f d5			LCDDelay:   PUSH DE  
6220 5f			            LD   E, A           ;Delay by 'A' ms  
6221 16 00		            LD   D, 0  
6223 cd 01 0a		            CALL aDelayInMS  
6226 d1			            POP  DE  
6227 c9			            RET  
