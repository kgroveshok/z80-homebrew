9d17			; A better parser without using malloc and string copies all over the place.  
9d17			; Exec in situ should be faster 
9d17			 
9d17			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
9d17			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
9d17			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
9d17			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
9d17			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
9d17			WORD_SYS_END: equ 0   ; Opcode for all user words 
9d17			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
9d17			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
9d17			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
9d17			 
9d17			; Core word preamble macro 
9d17			 
9d17			CWHEAD:   macro nxtword opcode lit len opflags 
9d17				db WORD_SYS_CORE+opcode             
9d17				; internal op code number 
9d17				dw nxtword            
9d17				; link to next dict word block 
9d17				db len + 1 
9d17				; literal length of dict word inc zero term 
9d17				db lit,0              
9d17				; literal dict word 
9d17			        ; TODO db opflags        
9d17				endm 
9d17			 
