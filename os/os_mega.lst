1d66				push af 
1d66				ld a,(hl) 
1d66				cp DS_TYPE_STR 
1d66				jp nz, type_faultn   
1d66				pop af 
1d66				endm 
1d66			 
1d66			FORTH_ERR_TOS_NOTNUM: macro 
