1157			StrictStrCmp: 
1157				; Load next chars of each string 
1157 1a				ld a, (de) 
1158 47				ld b, a 
1159 7e				ld a, (hl) 
115a				; Compare 
115a b8				cp b 
115b				; Return non-zero if chars don't match 
115b c0				ret nz 
115c				; Check for end of both strings 
115c fe 00			cp "\0" 
115e				; Return if strings have ended 
115e c8				ret z 
115f				; Otherwise, advance to next chars 
115f 23				inc hl 
1160 13				inc de 
1161 18 f4			jr StrictStrCmp 
