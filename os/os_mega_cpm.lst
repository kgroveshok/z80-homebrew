11c2			 
11c2			 
11c2			;      .org  0x100 
11c2			;main: 
11c2			;      ld    HL, 0x8100 
11c2			;      ld    SP, HL 
11c2			; 
11c2			;      call  heap_init 
11c2			; 
11c2			;      ; Make some allocations 
11c2			;      ld    HL, 12 
11c2			;      call  malloc            ; Allocates 0x9004 
11c2			; 
11c2			;      ld    HL, 12 
11c2			;      call  malloc            ; Allocates 0x9014 
11c2			; 
11c2			;      ld    HL, 12 
11c2			;      call  malloc            ; Allocates 0x9024 
11c2			; 
11c2			;      ; Free some allocations 
11c2			;      ld    HL, 0x9014 
11c2			;      call  free 
11c2			; 
11c2			;      ld    HL, 0x9004 
11c2			;      call  free 
11c2			; 
11c2			;      ld    HL, 0x9024 
11c2			;      call  free 
11c2			; 
11c2			; 
11c2			;      halt 
11c2			 
11c2			 
11c2			;------------------------------------------------------------------------------ 
11c2			;     heap_init                                                               : 
11c2			;                                                                             : 
11c2			; Description                                                                 : 
11c2			;     Initialise the heap and make it ready for malloc and free operations.   : 
11c2			;                                                                             : 
11c2			;     The heap is maintained as a linked list, starting with an initial       : 
11c2			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
11c2			;     the first free block in the heap. Each block then points to the next    : 
11c2			;     free block within the heap, and the free list ends at the first block   : 
11c2			;     with a null pointer to the next free block.                             : 
11c2			;                                                                             : 
11c2			; Parameters                                                                  : 
11c2			;     Inputs are compile-time only. Two defines which specify the starting    : 
11c2			;     address of the heap and its size are required, along with a memory      : 
11c2			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
11c2			;     principally stores a pointer to the first free block in the heap.       : 
11c2			;                                                                             : 
11c2			; Returns                                                                     : 
11c2			;     Nothing                                                                 : 
11c2			;------------------------------------------------------------------------------ 
11c2			heap_init: 
11c2 e5			      push  HL 
11c3			 
11c3			      ; Initialise free list struct 
11c3 21 e3 67		      ld    HL, heap_start 
11c6 22 de 67		      ld    (free_list), HL 
11c9 21 00 00		      ld    HL, 0 
11cc 22 e0 67		      ld    (free_list+2), HL 
11cf			 
11cf			      ; Insert first free block at bottom of heap, consumes entire heap 
11cf 21 8b e2		      ld    HL, heap_start+heap_size-4 
11d2 22 e3 67		      ld    (heap_start), HL        ; Next block (end of free list) 
11d5 21 a8 7a		      ld    HL, heap_size-4 
11d8 22 e5 67		      ld    (heap_start+2), HL      ; Block size 
11db			 
11db			      ; Insert end of free list block at top of heap - two null words will 
11db			      ; terminate the free list 
11db 21 00 00		      ld    HL, 0 
11de 22 8d e2		      ld    (heap_start+heap_size-2), HL 
11e1 22 8b e2		      ld    (heap_start+heap_size-4), HL 
11e4			 
11e4 e1			      pop   HL 
11e5			 
11e5 c9			      ret 
11e6			 
11e6			 
11e6			;------------------------------------------------------------------------------ 
11e6			;     malloc                                                                  : 
11e6			;                                                                             : 
11e6			; Description                                                                 : 
11e6			;     Allocates the wanted space from the heap and returns the address of the : 
11e6			;     first useable byte of the allocation.                                   : 
11e6			;                                                                             : 
11e6			;     Allocations can happen in one of two ways:                              : 
11e6			;                                                                             : 
11e6			;     1. A free block may be found which is the exact size wanted. In this    : 
11e6			;        case the block is removed from the free list and retuedn to the      : 
11e6			;        caller.                                                              : 
11e6			;     2. A free block may be found which is larger than the size wanted. In   : 
11e6			;        this case, the larger block is split into two. The first portion of  : 
11e6			;        this block will become the requested space by the malloc call and    : 
11e6			;        is returned to the caller. The second portion becomes a new free     : 
11e6			;        block, and the free list is adjusted to maintain continuity via this : 
11e6			;        newly created block.                                                 : 
11e6			;                                                                             : 
11e6			;     malloc does not set any initial value in the allocated space, the       : 
11e6			;     caller is required to do this as required.                              : 
11e6			;                                                                             : 
11e6			;     This implementation of malloc uses the stack exclusively, and is        : 
11e6			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
11e6			;     advisable to disable interrupts before calling malloc, and recommended  : 
11e6			;     to avoid the use of malloc inside ISRs in general.                      : 
11e6			;                                                                             : 
11e6			;     NOTE: heap_init must be called before malloc and free can be used.      : 
11e6			;                                                                             : 
11e6			; Parameters                                                                  : 
11e6			;     HL  Number of bytes wanted                                              : 
11e6			;                                                                             : 
11e6			; Returns                                                                     : 
11e6			;     HL  Address of the first useable byte of the allocation                 : 
11e6			;                                                                             : 
11e6			; Flags                                                                       : 
11e6			;     Z   Set if the allocation did not succeed, clear otherwise              : 
11e6			;                                                                             : 
11e6			; Stack frame                                                                 : 
11e6			;       |             |                                                       : 
11e6			;       +-------------+                                                       : 
11e6			;       |     BC      |                                                       : 
11e6			;       +-------------+                                                       : 
11e6			;       |     DE      |                                                       : 
11e6			;       +-------------+                                                       : 
11e6			;       |     IX      |                                                       : 
11e6			;       +-------------+                                                       : 
11e6			;       |  prev_free  |                                                       : 
11e6			;   +4  +-------------+                                                       : 
11e6			;       |  this_free  |                                                       : 
11e6			;   +2  +-------------+                                                       : 
11e6			;       |  next_free  |                                                       : 
11e6			;   +0  +-------------+                                                       : 
11e6			;       |             |                                                       : 
11e6			;                                                                             : 
11e6			;------------------------------------------------------------------------------ 
11e6			 
11e6			 
11e6			;malloc: 
11e6			; 
11e6			;	SAVESP ON 1 
11e6			; 
11e6			;	call malloc_code 
11e6			; 
11e6			;	CHECKSP ON 1 
11e6			;	ret 
11e6			 
11e6			 
11e6			malloc: 
11e6 c5			      push  BC 
11e7 d5			      push  DE 
11e8 dd e5		      push  IX 
11ea			if DEBUG_FORTH_MALLOC_HIGH 
11ea			call malloc_guard_entry 
11ea			endif 
11ea			 
11ea					if DEBUG_FORTH_MALLOC 
11ea						DMARK "mal" 
11ea						CALLMONITOR 
11ea					endif 
11ea 7c			      ld    A, H                    ; Exit if no space requested 
11eb b5			      or    L 
11ec ca ab 12		      jp    Z, malloc_early_exit 
11ef			 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			; 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			;inc hl 
11ef			 
11ef			 
11ef			 
11ef			 
11ef					if DEBUG_FORTH_MALLOC 
11ef						DMARK "maA" 
11ef						CALLMONITOR 
11ef					endif 
11ef			      ; Set up stack frame 
11ef eb			      ex    DE, HL 
11f0 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
11f3 39			      add   HL, SP 
11f4 f9			      ld    SP, HL 
11f5 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
11f9 dd 39		      add   IX, SP 
11fb			 
11fb			      ; Setup initial state 
11fb 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
11fe 19			      add   HL, DE 
11ff			 
11ff 44			      ld    B, H                    ; Move want to BC 
1200 4d			      ld    C, L 
1201			 
1201 21 de 67		      ld    HL, free_list           ; Store prev_free ptr to stack 
1204 dd 75 04		      ld    (IX+4), L 
1207 dd 74 05		      ld    (IX+5), H 
120a			 
120a 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
120b 23			      inc   HL 
120c 56			      ld    D, (HL) 
120d dd 73 02		      ld    (IX+2), E 
1210 dd 72 03		      ld    (IX+3), D 
1213 eb			      ex    DE, HL                  ; this_free ptr into HL 
1214			 
1214					if DEBUG_FORTH_MALLOC 
1214						DMARK "maB" 
1214						CALLMONITOR 
1214					endif 
1214			      ; Loop through free block list to find some space 
1214			malloc_find_space: 
1214 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
1215 23			      inc   HL 
1216 56			      ld    D, (HL) 
1217			 
1217 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
1218 b3			      or    E 
1219 ca a5 12		      jp    Z, malloc_no_space 
121c			 
121c dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
121f dd 72 01		      ld    (IX+1), D 
1222			 
1222			      ; Does this block have enough space to make the allocation? 
1222 23			      inc   HL                      ; Load free block size into DE 
1223 5e			      ld    E, (HL) 
1224 23			      inc   HL 
1225 56			      ld    D, (HL) 
1226			 
1226 eb			      ex    DE, HL                  ; Check size of block against want 
1227 b7			      or    A                       ; Ensure carry flag clear 
1228 ed 42		      sbc   HL, BC 
122a e5			      push  HL                      ; Store the result for later (new block size) 
122b			 
122b ca 7a 12		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
122e 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1230			 
1230			      ; this_free block is not big enough, setup ptrs to test next free block 
1230 e1			      pop   HL                      ; Discard previous result 
1231			 
1231 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1234 dd 66 03		      ld    H, (IX+3) 
1237 dd 75 04		      ld    (IX+4), L 
123a dd 74 05		      ld    (IX+5), H 
123d			 
123d dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1240 dd 66 01		      ld    H, (IX+1) 
1243 dd 75 02		      ld    (IX+2), L 
1246 dd 74 03		      ld    (IX+3), H 
1249			 
1249					if DEBUG_FORTH_MALLOC 
1249						DMARK "MA>" 
1249						CALLMONITOR 
1249					endif 
1249 18 c9		      jr    malloc_find_space 
124b			 
124b			      ; split a bigger block into two - requested size and remaining size 
124b			malloc_alloc_split: 
124b					if DEBUG_FORTH_MALLOC 
124b						DMARK "MAs" 
124b						CALLMONITOR 
124b					endif 
124b eb			      ex    DE, HL                  ; Calculate address of new free block 
124c 2b			      dec   HL 
124d 2b			      dec   HL 
124e 2b			      dec   HL 
124f 09			      add   HL, BC 
1250			 
1250			      ; Create a new block and point it at next_free 
1250 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
1253 dd 56 01		      ld    D, (IX+1) 
1256			 
1256 73			      ld    (HL), E                 ; Store next_free ptr into new block 
1257 23			      inc   HL 
1258 72			      ld    (HL), D 
1259			 
1259 d1			      pop   DE                      ; Store size of new block into new block 
125a 23			      inc   HL 
125b 73			      ld    (HL), E 
125c 23			      inc   HL 
125d 72			      ld    (HL), D 
125e			 
125e			      ; Update this_free ptr to point to new block 
125e 2b			      dec   HL 
125f 2b			      dec   HL 
1260 2b			      dec   HL 
1261			 
1261 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1264 dd 56 03		      ld    D, (IX+3) 
1267			 
1267 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
126a dd 74 03		      ld    (IX+3), H 
126d			 
126d			      ; Modify this_free block to be allocation 
126d eb			      ex    DE, HL 
126e af			      xor   A                       ; Null the next block ptr of allocated block 
126f 77			      ld    (HL), A 
1270 23			      inc   HL 
1271 77			      ld    (HL), A 
1272			 
1272 23			      inc   HL                      ; Store want size into allocated block 
1273 71			      ld    (HL), C 
1274 23			      inc   HL 
1275 70			      ld    (HL), B 
1276 23			      inc   HL 
1277 e5			      push  HL                      ; Address of allocation to return 
1278			 
1278 18 19		      jr    malloc_update_links 
127a			 
127a			malloc_alloc_fit: 
127a e1			      pop   HL                      ; Dont need new block size, want is exact fit 
127b			 
127b					if DEBUG_FORTH_MALLOC 
127b						DMARK "MAf" 
127b						CALLMONITOR 
127b					endif 
127b			      ; Modify this_free block to be allocation 
127b eb			      ex    DE, HL 
127c 2b			      dec   HL 
127d 2b			      dec   HL 
127e 2b			      dec   HL 
127f			 
127f af			      xor   A                       ; Null the next block ptr of allocated block 
1280 77			      ld    (HL), A 
1281 23			      inc   HL 
1282 77			      ld    (HL), A 
1283			 
1283 23			      inc   HL                      ; Store address of allocation to return 
1284 23			      inc   HL 
1285 23			      inc   HL 
1286 e5			      push  HL 
1287			 
1287			      ; Copy next_free ptr to this_free, remove allocated block from free list 
1287 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
128a dd 66 01		      ld    H, (IX+1) 
128d			 
128d dd 75 02		      ld    (IX+2), L               ; HL to this_free 
1290 dd 74 03		      ld    (IX+3), H 
1293			 
1293			 
1293			malloc_update_links: 
1293			      ; Update prev_free ptr to point to this_free 
1293 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
1296 dd 66 05		      ld    H, (IX+5) 
1299			 
1299 dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
129c dd 56 03		      ld    D, (IX+3) 
129f			 
129f 73			      ld    (HL), E                 ; this_free ptr into prev_free 
12a0 23			      inc   HL 
12a1 72			      ld    (HL), D 
12a2			 
12a2					if DEBUG_FORTH_MALLOC 
12a2						DMARK "Mul" 
12a2						CALLMONITOR 
12a2					endif 
12a2			      ; Clear the Z flag to indicate successful allocation 
12a2 7a			      ld    A, D 
12a3 b3			      or    E 
12a4			 
12a4 d1			      pop   DE                      ; Address of allocation 
12a5					if DEBUG_FORTH_MALLOC 
12a5						DMARK "MAu" 
12a5						CALLMONITOR 
12a5					endif 
12a5			 
12a5			malloc_no_space: 
12a5 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
12a8 39			      add   HL, SP 
12a9 f9			      ld    SP, HL 
12aa			 
12aa eb			      ex    DE, HL                  ; Alloc addr into HL for return 
12ab					if DEBUG_FORTH_MALLOC 
12ab						DMARK "MAN" 
12ab						CALLMONITOR 
12ab					endif 
12ab			 
12ab			malloc_early_exit: 
12ab					if DEBUG_FORTH_MALLOC 
12ab						DMARK "MAx" 
12ab						CALLMONITOR 
12ab					endif 
12ab dd e1		      pop   IX 
12ad d1			      pop   DE 
12ae c1			      pop   BC 
12af			 
12af			if DEBUG_FORTH_MALLOC_HIGH 
12af			call malloc_guard_exit 
12af			call malloc_guard_zerolen 
12af			endif 
12af c9			      ret 
