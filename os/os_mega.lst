68e4			; **********************************************************************  
68e4			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
68e4			; **********************************************************************  
68e4			;  
68e4			; **  Written as a Small Computer Monitor App  
68e4			; **  www.scc.me.uk  
68e4			;  
68e4			; History  
68e4			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
68e4			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
68e4			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
68e4			;  
68e4			; **********************************************************************  
68e4			;  
68e4			; This program is an example of one of the methods of interfacing an   
68e4			; alphanumeric LCD module.   
68e4			;  
68e4			; In this example the display is connected to either a Z80 PIO or a   
68e4			; simple 8-bit output port.   
68e4			;  
68e4			; This interfacing method uses 4-bit data mode and uses time delays  
68e4			; rather than polling the display's ready status. As a result the   
68e4			; interface only requires 6 simple output lines:  
68e4			;   Output bit 0 = not used  
68e4			;   Output bit 1 = not used  
68e4			;   Output bit 2 = RS         High = data, Low = instruction  
68e4			;   Output bit 3 = E          Active high  
68e4			;   Output bit 4 = DB4  
68e4			;   Output bit 5 = DB5  
68e4			;   Output bit 6 = DB6  
68e4			;   Output bit 7 = DB7  
68e4			; Display's R/W is connected to 0v so it is always in write mode  
68e4			;  
68e4			; This set up should work with any system supporting the RC2014 bus  
68e4			  
68e4			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
68e4			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
68e4			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
68e4			;  
68e4			; **********************************************************************  
68e4			  
68e4			; Additonal for 4x40. E1 and E2 instead of just E   
68e4			; TODO swipe vidout signal on port a to activate E2  
68e4			  
68e4			; **********************************************************************  
68e4			; **  Constants  
68e4			; **********************************************************************  
68e4			; LCD constants required by LCD support module  
68e4			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
68e4			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
68e4			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
68e4			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VICLK  
68e4			kLCDBitLED:   EQU 1              ;Port bit for LCD E2 signal            VIDDO  
68e4			; TODO Decide which E is being set  
68e4			kLCDWidth:  EQU display_cols             ;Width in characters  
68e4			  
68e4			; **********************************************************************  
68e4			; **  Code library usage  
68e4			; **********************************************************************  
68e4			  
68e4			; send character to current cursor position  
68e4			; wraps and/or scrolls screen automatically  
68e4			  
68e4			  
