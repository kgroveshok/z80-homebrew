6a0a 2a f9 fa			ld hl, (display_write_tmp)  
6a0d 11 28 00			ld de, display_cols  
6a10 19				add hl,de  
6a11 22 f9 fa			ld (display_write_tmp),hl  
6a14			  
6a14				  
6a14 3e 28			ld a, kLCD_Line2  
6a16 cd 24 6b		            CALL fLCD_Pos       ;Position cursor to location in A  
6a19 06 28			ld b, display_cols  
6a1b ed 5b f9 fa		ld de, (display_write_tmp)  
6a1f cd 53 6a			call write_len_string  
6a22				  
6a22 2a f9 fa			ld hl, (display_write_tmp)  
6a25 11 28 00			ld de, display_cols  
6a28 19				add hl,de  
