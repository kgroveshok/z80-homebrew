12e0			if MALLOC_4 
12e0			 
12e0			; My memory allocation code. Very very simple.... 
12e0			; allocate space under 250 chars 
12e0			 
12e0			heap_init: 
12e0				; init start of heap as zero 
12e0				;  
12e0			 
12e0				ld hl, heap_start 
12e0			;	ld a, 0 
12e0				ld (hl), 0      ; empty block 
12e0				inc hl 
12e0			;	ld a, 0 
12e0				ld (hl), 0      ; length of block 
12e0				; write end of list 
12e0				inc hl 
12e0				ld a,(hl) 
12e0				inc hl 
12e0				ld a,(hl) 
12e0				 
12e0			 
12e0				; init some malloc vars 
12e0			 
12e0				ld hl, 0 
12e0				ld (free_list), hl       ; store last malloc location 
12e0			 
12e0				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12e0			;	ld a, 0 
12e0				ld (hl), 0 
12e0			 
12e0			 
12e0				ld hl, heap_start 
12e0				;  
12e0				  
12e0				ret 
12e0			 
12e0			 
12e0			;    free block marker 
12e0			;    requested size  
12e0			;    pointer to next block 
12e0			;    .... 
12e0			;    next block marker 
12e0			 
12e0			 
12e0			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12e0			; 
12e0			 
12e0			 
12e0			malloc:  
12e0				push de 
12e0				push bc 
12e0				push af 
12e0			 
12e0				; hl space required 
12e0				 
12e0				ld c, l    ; hold space   (TODO only a max of 255) 
12e0			 
12e0			;	inc c     ; TODO BUG need to fix memory leak on push str 
12e0			;	inc c 
12e0			;	inc c 
12e0			;	inc c 
12e0			;	inc c 
12e0			;	inc c 
12e0			;	inc c 
12e0			 
12e0			 
12e0			 
12e0				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12e0			 
12e0				ld a, (free_list+3) 
12e0			;	cp 0 
12e0				or a 
12e0				jr z, .contheap 
12e0			 
12e0				ld hl, (free_list)     ; get last alloc 
12e0					if DEBUG_FORTH_MALLOC_INT 
