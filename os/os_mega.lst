2b76					ld a, (.dmark+1)  
2b76					ld (debug_mark+1),a  
2b76					ld a, (.dmark+2)  
2b76					ld (debug_mark+2),a  
2b76				endif  
2b76 18 04			jr .pastdmark  
2b78 ..			.dmark: db "MON"  
2b7b				if DEMARK_VERSION = 1  
2b7b 00					db 0  
2b7c				endif  
