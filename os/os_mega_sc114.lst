bf71					if DEBUG_FORTH_WORDS 
bf71						DMARK "Si3" 
bf71						CALLMONITOR 
bf71					endif 
bf71					;call forth_push_numhl 
bf71					FORTH_PUSH_VALUEHL 
bf71			 
bf71					NEXTW 
bf71			 
bf71			 
bf71			 
bf71			.SESEL: 
bf71				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bf71			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bf71			; | | Zero is disabled storage. 
bf71					if DEBUG_FORTH_WORDS_KEY 
bf71						DMARK "BN?" 
bf71						CALLMONITOR 
bf71					endif 
bf71					ld a, (spi_device_id) 
bf71					sub '0' 
bf71					ld h, 0 
bf71					ld l, a 
bf71					FORTH_PUSH_VALUEHL 
bf71					;call forth_push_numhl 
bf71					NEXTW 
bf71			.SESELS: 
bf71				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bf71			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bf71			; | | Set to zero to disable storage. 
bf71					if DEBUG_FORTH_WORDS_KEY 
bf71						DMARK "BNK" 
bf71						CALLMONITOR 
bf71					endif 
bf71			 
bf71					ld a, 255 
bf71					ld (spi_cartdev), a 
bf71			 
bf71					; get bank 
bf71			 
bf71					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf71			 
bf71			;		push hl 
bf71			 
bf71					; destroy value TOS 
bf71			 
bf71					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf71			 
bf71					; one value on hl get other one back 
bf71			 
bf71			;		pop hl 
bf71			 
bf71			 
bf71					ld c, SPI_CE_HIGH 
bf71					ld b, '0'    ; human readable bank number 
bf71			 
bf71					ld a, l 
bf71			 
bf71					if DEBUG_FORTH_WORDS 
bf71						DMARK "BNK" 
bf71						CALLMONITOR 
bf71					endif 
bf71			 
bf71					; active low 
bf71			 
bf71			;		cp 0 
bf71					or a 
bf71					jr z, .bset 
bf71					cp 1 
bf71					jr nz, .b2 
bf71					res 0, c 
bf71					ld b, '1'    ; human readable bank number 
bf71			.b2:		cp 2 
bf71					jr nz, .b3 
bf71					res 1, c 
bf71					ld b, '2'    ; human readable bank number 
bf71			.b3:		cp 3 
bf71					jr nz, .b4 
bf71					res 2, c 
bf71					ld b, '3'    ; human readable bank number 
bf71			.b4:		cp 4 
bf71					jr nz, .b5 
bf71					res 3, c 
bf71					ld b, '4'    ; human readable bank number 
bf71			.b5:		cp 5 
bf71					jr nz, .bset 
bf71					res 4, c 
bf71					ld b, '5'    ; human readable bank number 
bf71			 
bf71			.bset: 
bf71					ld a, c 
bf71					ld (spi_device),a 
bf71					ld a, b 
bf71					ld (spi_device_id),a 
bf71					if DEBUG_FORTH_WORDS 
bf71						DMARK "BN2" 
bf71						CALLMONITOR 
bf71					endif 
bf71			 
bf71					; set default SPI clk pulse time as disabled for BANK use 
bf71			 
bf71					ld a, 0 
bf71					ld (spi_clktime), a 
bf71			 
bf71					NEXTW 
bf71			 
bf71			.CARTDEV: 
bf71				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bf71			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bf71			; | | Set to zero to disable devices. 
bf71					if DEBUG_FORTH_WORDS_KEY 
bf71						DMARK "CDV" 
bf71						CALLMONITOR 
bf71					endif 
bf71			 
bf71					; disable se storage bank selection 
bf71			 
bf71					ld a, SPI_CE_HIGH		; ce high 
bf71					ld (spi_device), a 
bf71			 
bf71					; get bank 
bf71			 
bf71					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bf71			 
bf71			;		push hl 
bf71			 
bf71					; destroy value TOS 
bf71			 
bf71					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bf71			 
bf71					; one value on hl get other one back 
bf71			 
bf71			;		pop hl 
bf71			 
bf71					; active low 
bf71			 
bf71					ld c, 255 
bf71			 
bf71					ld a, l 
bf71					if DEBUG_FORTH_WORDS 
bf71						DMARK "CDV" 
bf71						CALLMONITOR 
bf71					endif 
bf71			;		cp 0 
bf71					or a 
bf71					jr z, .cset 
bf71					cp 1 
bf71					jr nz, .c2 
bf71					res 0, c 
bf71			.c2:		cp 2 
bf71					jr nz, .c3 
bf71					res 1, c 
bf71			.c3:		cp 3 
bf71					jr nz, .c4 
bf71					res 2, c 
bf71			.c4:		cp 4 
bf71					jr nz, .c5 
bf71					res 3, c 
bf71			.c5:		cp 5 
bf71					jr nz, .c6 
bf71					res 4, c 
bf71			.c6:		cp 6 
bf71					jr nz, .c7 
bf71					res 5, c 
bf71			.c7:		cp 7 
bf71					jr nz, .c8 
bf71					res 6, c 
bf71			.c8:		cp 8 
bf71					jr nz, .cset 
bf71					res 7, c 
bf71			.cset:		ld a, c 
bf71					ld (spi_cartdev),a 
bf71			 
bf71					if DEBUG_FORTH_WORDS 
bf71						DMARK "CD2" 
bf71						CALLMONITOR 
bf71					endif 
bf71			 
bf71					; set default SPI clk pulse time as 10ms for CARTDEV use 
bf71			 
bf71					ld a, $0a 
bf71					ld (spi_clktime), a 
bf71					NEXTW 
bf71			endif 
bf71			 
bf71			.ENDDEVICE: 
bf71			; eof 
bf71			 
# End of file forth_words_device.asm
