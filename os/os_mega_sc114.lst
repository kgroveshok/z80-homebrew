bea3					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bea3			 
bea3			;		push hl    ; u1  
bea3			 
bea3					; destroy value TOS 
bea3			 
bea3					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bea3			 
bea3					; one value on hl get other one back 
