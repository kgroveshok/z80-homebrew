8a4c			subafromhl: 
8a4c			   ; If A=0 do nothing 
8a4c			    ; Otherwise flip A's sign. Since 
8a4c			    ; the upper byte becomes -1, also 
8a4c			    ; substract 1 from H. 
8a4c ed 44		    neg 
8a4e ca 57 8a		    jp    z, Skip 
8a51 25			    dec   h 
8a52			     
8a52			    ; Now add the low byte as usual 
8a52			    ; Two's complement takes care of 
8a52			    ; ensuring the result is correct 
8a52 85			    add   a, l 
8a53 6f			    ld    l, a 
8a54 8c			    adc   a, h 
8a55 95			    sub   l 
8a56 67			    ld    h, a 
8a57			Skip: 
8a57 c9				ret 
