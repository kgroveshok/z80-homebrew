0143				 ; set DI high, CE high , SCLK low 
0143				;ld a, SPI_DI | SPI_CE0 
0143 3e 07			ld a, SPI_DI  
0145 cd 57 02			call spi_ce_high 
0148 d3 80			 out (storage_adata),a 
014a 32 8c f9			ld (spi_portbyte),a 
014d			 
