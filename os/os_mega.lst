0faf			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0faf			;;    subtract $30, if result > 9 then subtract $7 more 
0faf			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0faf			atohex: 
0faf d6 30				SUB $30 
0fb1 fe 0a				CP 10 
0fb3 f8					RET M		; If result negative it was 0-9 so we're done 
0fb4 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0fb6 c9					RET		 
