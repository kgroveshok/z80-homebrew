11f2			 
11f2			;------------------------------------------------------------------------------ 
11f2			;     free                                                                    : 
11f2			;                                                                             : 
11f2			; Description                                                                 : 
11f2			;     Return the space pointed to by HL to the heap. HL must be an address as : 
11f2			;     returned by malloc, otherwise the behaviour is undefined.               : 
11f2			;                                                                             : 
11f2			;     Where possible, directly adjacent free blocks will be merged together   : 
11f2			;     into larger blocks to help ensure that the heap does not become         : 
11f2			;     excessively fragmented.                                                 : 
11f2			;                                                                             : 
11f2			;     free does not clear or set any other value into the freed space, and    : 
11f2			;     therefore its contents may be visible through subsequent malloc's. The  : 
11f2			;     caller should clear the freed space as required.                        : 
11f2			;                                                                             : 
11f2			;     This implementation of free uses the stack exclusively, and is          : 
11f2			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
11f2			;     advisable to disable interrupts before calling free, and recommended    : 
11f2			;     to avoid the use of free inside ISRs in general.                        : 
11f2			;                                                                             : 
11f2			;     NOTE: heap_init must be called before malloc and free can be used.      : 
11f2			;                                                                             : 
11f2			; Parameters                                                                  : 
11f2			;     HL  Pointer to address of first byte of allocation to be freed          : 
11f2			;                                                                             : 
11f2			; Returns                                                                     : 
11f2			;     Nothing                                                                 : 
11f2			;                                                                             : 
11f2			; Stack frame                                                                 : 
11f2			;       |             |                                                       : 
11f2			;       +-------------+                                                       : 
11f2			;       |     BC      |                                                       : 
11f2			;       +-------------+                                                       : 
11f2			;       |     DE      |                                                       : 
11f2			;       +-------------+                                                       : 
11f2			;       |     IX      |                                                       : 
11f2			;       +-------------+                                                       : 
11f2			;       |  prev_free  |                                                       : 
11f2			;   +2  +-------------+                                                       : 
11f2			;       |  next_free  |                                                       : 
11f2			;   +0  +-------------+                                                       : 
11f2			;       |             |                                                       : 
11f2			;                                                                             : 
11f2			;------------------------------------------------------------------------------ 
11f2			free: 
11f2 c5			      push  BC 
11f3 d5			      push  DE 
11f4 dd e5		      push  IX 
11f6			 
11f6 7c			      ld    A, H                    ; Exit if ptr is null 
11f7 b5			      or    L 
11f8 ca bc 12		      jp    Z, free_early_exit 
11fb			 
11fb			      ; Set up stack frame 
11fb eb			      ex    DE, HL 
11fc 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
11ff 39			      add   HL, SP 
1200 f9			      ld    SP, HL 
1201 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1205 dd 39		      add   IX, SP 
1207			 
1207			      ; The address in HL points to the start of the useable allocated space, 
1207			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1207			      ; address of the block itself. 
1207 eb			      ex    DE, HL 
1208 11 fc ff		      ld    DE, -4 
120b 19			      add   HL, DE 
120c			 
120c			      ; An allocated block must have a null next block pointer in it 
120c 7e			      ld    A, (HL) 
120d 23			      inc   HL 
120e b6			      or    (HL) 
120f c2 b7 12		      jp    NZ, free_done 
1212			 
1212 2b			      dec   HL 
1213			 
1213 44			      ld    B, H                    ; Copy HL to BC 
1214 4d			      ld    C, L 
1215			 
1215			      ; Loop through the free list to find the first block with an address 
1215			      ; higher than the block being freed 
1215 21 0a 80		      ld    HL, free_list 
1218			 
1218			free_find_higher_block: 
1218 5e			      ld    E, (HL)                 ; Load next ptr from free block 
1219 23			      inc   HL 
121a 56			      ld    D, (HL) 
121b 2b			      dec   HL 
121c			 
121c dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
121f dd 72 01		      ld    (IX+1), D 
1222 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1225 dd 74 03		      ld    (IX+3), H 
1228			 
1228 78			      ld    A, B                    ; Check if DE is greater than BC 
1229 ba			      cp    D                       ; Compare MSB first 
122a 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
122c 30 04		      jr    NC, free_find_higher_block_skip 
122e 79			      ld    A, C 
122f bb			      cp    E                       ; Then compare LSB 
1230 38 08		      jr    C, free_found_higher_block 
1232			 
1232			free_find_higher_block_skip: 
1232 7a			      ld    A, D                    ; Reached the end of the free list? 
1233 b3			      or    E 
1234 ca b7 12		      jp    Z, free_done 
1237			 
1237 eb			      ex    DE, HL 
1238			 
1238 18 de		      jr    free_find_higher_block 
123a			 
123a			free_found_higher_block: 
123a			      ; Insert freed block between prev and next free blocks 
123a 71			      ld    (HL), C                 ; Point prev free block to freed block 
123b 23			      inc   HL 
123c 70			      ld    (HL), B 
123d			 
123d 60			      ld    H, B                    ; Point freed block at next free block 
123e 69			      ld    L, C 
123f 73			      ld    (HL), E 
1240 23			      inc   HL 
1241 72			      ld    (HL), D 
1242			 
1242			      ; Check if the freed block is adjacent to the next free block 
1242 23			      inc   HL                      ; Load size of freed block into HL 
1243 5e			      ld    E, (HL) 
1244 23			      inc   HL 
1245 56			      ld    D, (HL) 
1246 eb			      ex    DE, HL 
1247			 
1247 09			      add   HL, BC                  ; Add addr of freed block and its size 
1248			 
1248 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
124b dd 56 01		      ld    D, (IX+1) 
124e			 
124e b7			      or    A                       ; Clear the carry flag 
124f ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1251 20 22		      jr    NZ, free_check_adjacent_to_prev 
1253			 
1253			      ; Freed block is adjacent to next, merge into one bigger block 
1253 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1254 5e			      ld    E, (HL) 
1255 23			      inc   HL 
1256 56			      ld    D, (HL) 
1257 e5			      push  HL                      ; Save ptr to next block for later 
1258			 
1258 60			      ld    H, B                    ; Store ptr from next block into freed block 
1259 69			      ld    L, C 
125a 73			      ld    (HL), E 
125b 23			      inc   HL 
125c 72			      ld    (HL), D 
125d			 
125d e1			      pop   HL                      ; Restore ptr to next block 
125e 23			      inc   HL                      ; Load size of next block into DE 
125f 5e			      ld    E, (HL) 
1260 23			      inc   HL 
1261 56			      ld    D, (HL) 
1262 d5			      push  DE                      ; Save next block size for later 
1263			 
1263 60			      ld    H, B                    ; Load size of freed block into HL 
1264 69			      ld    L, C 
1265 23			      inc   HL 
1266 23			      inc   HL 
1267 5e			      ld    E, (HL) 
1268 23			      inc   HL 
1269 56			      ld    D, (HL) 
126a eb			      ex    DE, HL 
126b			 
126b d1			      pop   DE                      ; Restore size of next block 
126c 19			      add   HL, DE                  ; Add sizes of both blocks 
126d eb			      ex    DE, HL 
126e			 
126e 60			      ld    H, B                    ; Store new bigger size into freed block 
126f 69			      ld    L, C 
1270 23			      inc   HL 
1271 23			      inc   HL 
1272 73			      ld    (HL), E 
1273 23			      inc   HL 
1274 72			      ld    (HL), D 
1275			 
1275			free_check_adjacent_to_prev: 
1275			      ; Check if the freed block is adjacent to the prev free block 
1275 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1278 dd 66 03		      ld    H, (IX+3) 
127b			 
127b 23			      inc   HL                      ; Size of prev free block into DE 
127c 23			      inc   HL 
127d 5e			      ld    E, (HL) 
127e 23			      inc   HL 
127f 56			      ld    D, (HL) 
1280 2b			      dec   HL 
1281 2b			      dec   HL 
1282 2b			      dec   HL 
1283			 
1283 19			      add   HL, DE                  ; Add prev block addr and size 
1284			 
1284 b7			      or    A                       ; Clear the carry flag 
1285 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1287 20 2e		      jr    NZ, free_done 
1289			 
1289			      ; Freed block is adjacent to prev, merge into one bigger block 
1289 60			      ld    H, B                    ; Load next ptr from freed block into DE 
128a 69			      ld    L, C 
128b 5e			      ld    E, (HL) 
128c 23			      inc   HL 
128d 56			      ld    D, (HL) 
128e e5			      push  HL                      ; Save freed block ptr for later 
128f			 
128f dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
1292 dd 66 03		      ld    H, (IX+3) 
1295 73			      ld    (HL), E 
1296 23			      inc   HL 
1297 72			      ld    (HL), D 
1298			 
1298 e1			      pop   HL                      ; Restore freed block ptr 
1299 23			      inc   HL                      ; Load size of freed block into DE 
129a 5e			      ld    E, (HL) 
129b 23			      inc   HL 
129c 56			      ld    D, (HL) 
129d d5			      push  DE                      ; Save freed block size for later 
129e			 
129e dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
12a1 dd 66 03		      ld    H, (IX+3) 
12a4 23			      inc   HL 
12a5 23			      inc   HL 
12a6 5e			      ld    E, (HL) 
12a7 23			      inc   HL 
12a8 56			      ld    D, (HL) 
12a9			 
12a9 e1			      pop   HL                      ; Add sizes of both blocks 
12aa 19			      add   HL, DE 
12ab eb			      ex    DE, HL 
12ac			 
12ac dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
12af dd 66 03		      ld    H, (IX+3) 
12b2 23			      inc   HL 
12b3 23			      inc   HL 
12b4 73			      ld    (HL), E 
12b5 23			      inc   HL 
12b6 72			      ld    (HL), D 
12b7			 
12b7			free_done: 
12b7 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
12ba 39			      add   HL, SP 
12bb f9			      ld    SP, HL 
12bc			 
12bc			free_early_exit: 
12bc dd e1		      pop   IX 
12be d1			      pop   DE 
12bf c1			      pop   BC 
12c0			 
12c0 c9			      ret 
12c1			 
12c1			; moved to firmware.asm 
12c1			; 
12c1			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12c1			;                  .dw   0 
12c1			 
12c1			 
12c1			endif 
12c1			 
12c1			 
12c1			if MALLOC_3 
12c1			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12c1			;heap_start        .equ  0x9000      ; Starting address of heap 
12c1			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12c1			; 
12c1			 ;     .org 0 
12c1			  ;    jp    main 
12c1			; 
12c1			; 
12c1			 ;     .org  0x100 
12c1			;main: 
12c1			 ;     ld    HL, 0x8100 
12c1			  ;    ld    SP, HL 
12c1			; 
12c1			;      call  heap_init 
12c1			 
12c1			      ; Make some allocations 
12c1			;      ld    HL, 12 
12c1			;      call  malloc            ; Allocates 0x9004 
12c1			; 
12c1			 ;     ld    HL, 12 
12c1			;      call  malloc            ; Allocates 0x9014 
12c1			 
12c1			;      ld    HL, 12 
12c1			;      call  malloc            ; Allocates 0x9024 
12c1			 
12c1			      ; Free some allocations 
12c1			;      ld    HL, 0x9014 
12c1			;      call  free 
12c1			 
12c1			;      ld    HL, 0x9004 
12c1			;      call  free 
12c1			; 
12c1			;      ld    HL, 0x9024 
12c1			;      call  free 
12c1			 
12c1			 
12c1			 ;     halt 
12c1			 
12c1			 
12c1			;------------------------------------------------------------------------------ 
12c1			;     heap_init                                                               : 
12c1			;                                                                             : 
12c1			; Description                                                                 : 
12c1			;     Initialise the heap and make it ready for malloc and free operations.   : 
12c1			;                                                                             : 
12c1			;     The heap is maintained as a linked list, starting with an initial       : 
12c1			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12c1			;     the first free block in the heap. Each block then points to the next    : 
12c1			;     free block within the heap, and the free list ends at the first block   : 
12c1			;     with a null pointer to the next free block.                             : 
12c1			;                                                                             : 
12c1			; Parameters                                                                  : 
12c1			;     Inputs are compile-time only. Two defines which specify the starting    : 
12c1			;     address of the heap and its size are required, along with a memory      : 
12c1			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12c1			;     principally stores a pointer to the first free block in the heap.       : 
12c1			;                                                                             : 
12c1			; Returns                                                                     : 
12c1			;     Nothing                                                                 : 
12c1			;------------------------------------------------------------------------------ 
12c1			heap_init: 
12c1			      push  HL 
12c1			 
12c1			      ; Initialise free list struct 
12c1			      ld    HL, heap_start 
12c1			      ld    (free_list), HL 
12c1			      ld    HL, 0 
12c1			      ld    (free_list+2), HL 
12c1			 
12c1			      ; Insert first free block at bottom of heap, consumes entire heap 
12c1			      ld    HL, heap_start+heap_size-4 
12c1			      ld    (heap_start), HL        ; Next block (end of free list) 
12c1			      ld    HL, heap_size-4 
12c1			      ld    (heap_start+2), HL      ; Block size 
12c1			 
12c1			      ; Insert end of free list block at top of heap - two null words will 
12c1			      ; terminate the free list 
12c1			      ld    HL, 0 
12c1			      ld    (heap_start+heap_size-2), HL 
12c1			      ld    (heap_start+heap_size-4), HL 
12c1			 
12c1			      pop   HL 
12c1			 
12c1			      ret 
12c1			 
12c1			 
12c1			;------------------------------------------------------------------------------ 
12c1			;     malloc                                                                  : 
12c1			;                                                                             : 
12c1			; Description                                                                 : 
12c1			;     Allocates the wanted space from the heap and returns the address of the : 
12c1			;     first useable byte of the allocation.                                   : 
12c1			;                                                                             : 
12c1			;     Allocations can happen in one of two ways:                              : 
12c1			;                                                                             : 
12c1			;     1. A free block may be found which is the exact size wanted. In this    : 
12c1			;        case the block is removed from the free list and retuedn to the      : 
12c1			;        caller.                                                              : 
12c1			;     2. A free block may be found which is larger than the size wanted. In   : 
12c1			;        this case, the larger block is split into two. The first portion of  : 
12c1			;        this block will become the requested space by the malloc call and    : 
12c1			;        is returned to the caller. The second portion becomes a new free     : 
12c1			;        block, and the free list is adjusted to maintain continuity via this : 
12c1			;        newly created block.                                                 : 
12c1			;                                                                             : 
12c1			;     malloc does not set any initial value in the allocated space, the       : 
12c1			;     caller is required to do this as required.                              : 
12c1			;                                                                             : 
12c1			;     This implementation of malloc uses the stack exclusively, and is        : 
12c1			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12c1			;     advisable to disable interrupts before calling malloc, and recommended  : 
12c1			;     to avoid the use of malloc inside ISRs in general.                      : 
12c1			;                                                                             : 
12c1			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12c1			;                                                                             : 
12c1			; Parameters                                                                  : 
12c1			;     HL  Number of bytes wanted                                              : 
12c1			;                                                                             : 
12c1			; Returns                                                                     : 
12c1			;     HL  Address of the first useable byte of the allocation                 : 
12c1			;                                                                             : 
12c1			; Flags                                                                       : 
12c1			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12c1			;                                                                             : 
12c1			; Stack frame                                                                 : 
12c1			;       |             |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |     BC      |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |     DE      |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |     IX      |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |  prev_free  |                                                       : 
12c1			;   +4  +-------------+                                                       : 
12c1			;       |  this_free  |                                                       : 
12c1			;   +2  +-------------+                                                       : 
12c1			;       |  next_free  |                                                       : 
12c1			;   +0  +-------------+                                                       : 
12c1			;       |             |                                                       : 
12c1			;                                                                             : 
12c1			;------------------------------------------------------------------------------ 
12c1			malloc: 
12c1			      push  BC 
12c1			      push  DE 
12c1			      push  IX 
12c1			 
12c1			      ld    A, H                    ; Exit if no space requested 
12c1			      or    L 
12c1			      jp    Z, malloc_early_exit 
12c1			 
12c1			      ; Set up stack frame 
12c1			      ex    DE, HL 
12c1			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12c1			      add   HL, SP 
12c1			      ld    SP, HL 
12c1			      ld    IX, 0                   ; Use IX as a frame pointer 
12c1			      add   IX, SP 
12c1			 
12c1			      ; Setup initial state 
12c1			      ld    HL, 4                   ; want must also include space used by block struct 
12c1			      add   HL, DE 
12c1			 
12c1			      ld    B, H                    ; Move want to BC 
12c1			      ld    C, L 
12c1			 
12c1			      ld    HL, free_list           ; Store prev_free ptr to stack 
12c1			      ld    (IX+4), L 
12c1			      ld    (IX+5), H 
12c1			 
12c1			      ld    E, (HL)                 ; Store this_free ptr to stack 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      ld    (IX+2), E 
12c1			      ld    (IX+3), D 
12c1			      ex    DE, HL                  ; this_free ptr into HL 
12c1			 
12c1			      ; Loop through free block list to find some space 
12c1			malloc_find_space: 
12c1			      ld    E, (HL)                 ; Load next_free ptr into DE 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			 
12c1			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12c1			      or    E 
12c1			      jp    Z, malloc_no_space 
12c1			 
12c1			      ld    (IX+0), E               ; Store next_free ptr to stack 
12c1			      ld    (IX+1), D 
12c1			 
12c1			      ; Does this block have enough space to make the allocation? 
12c1			      inc   HL                      ; Load free block size into DE 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			 
12c1			      ex    DE, HL                  ; Check size of block against want 
12c1			      or    A                       ; Ensure carry flag clear 
12c1			      sbc   HL, BC 
12c1			      push  HL                      ; Store the result for later (new block size) 
12c1			 
12c1			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12c1			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12c1			 
12c1			      ; this_free block is not big enough, setup ptrs to test next free block 
12c1			      pop   HL                      ; Discard previous result 
12c1			 
12c1			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12c1			      ld    H, (IX+3) 
12c1			      ld    (IX+4), L 
12c1			      ld    (IX+5), H 
12c1			 
12c1			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12c1			      ld    H, (IX+1) 
12c1			      ld    (IX+2), L 
12c1			      ld    (IX+3), H 
12c1			 
12c1			      jr    malloc_find_space 
12c1			 
12c1			      ; split a bigger block into two - requested size and remaining size 
12c1			malloc_alloc_split: 
12c1			      ex    DE, HL                  ; Calculate address of new free block 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			      add   HL, BC 
12c1			 
12c1			      ; Create a new block and point it at next_free 
12c1			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12c1			      ld    D, (IX+1) 
12c1			 
12c1			      ld    (HL), E                 ; Store next_free ptr into new block 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			      pop   DE                      ; Store size of new block into new block 
12c1			      inc   HL 
12c1			      ld    (HL), E 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			      ; Update this_free ptr to point to new block 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			 
12c1			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12c1			      ld    D, (IX+3) 
12c1			 
12c1			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12c1			      ld    (IX+3), H 
12c1			 
12c1			      ; Modify this_free block to be allocation 
12c1			      ex    DE, HL 
12c1			      xor   A                       ; Null the next block ptr of allocated block 
12c1			      ld    (HL), A 
12c1			      inc   HL 
12c1			      ld    (HL), A 
12c1			 
12c1			      inc   HL                      ; Store want size into allocated block 
12c1			      ld    (HL), C 
12c1			      inc   HL 
12c1			      ld    (HL), B 
12c1			      inc   HL 
12c1			      push  HL                      ; Address of allocation to return 
12c1			 
12c1			      jr    malloc_update_links 
12c1			 
12c1			malloc_alloc_fit: 
12c1			      pop   HL                      ; Dont need new block size, want is exact fit 
12c1			 
12c1			      ; Modify this_free block to be allocation 
12c1			      ex    DE, HL 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			 
12c1			      xor   A                       ; Null the next block ptr of allocated block 
12c1			      ld    (HL), A 
12c1			      inc   HL 
12c1			      ld    (HL), A 
12c1			 
12c1			      inc   HL                      ; Store address of allocation to return 
12c1			      inc   HL 
12c1			      inc   HL 
12c1			      push  HL 
12c1			 
12c1			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12c1			      ld    L, (IX+0)               ; next_free to HL 
12c1			      ld    H, (IX+1) 
12c1			 
12c1			      ld    (IX+2), L               ; HL to this_free 
12c1			      ld    (IX+3), H 
12c1			 
12c1			 
12c1			malloc_update_links: 
12c1			      ; Update prev_free ptr to point to this_free 
12c1			      ld    L, (IX+4)               ; prev_free ptr to HL 
12c1			      ld    H, (IX+5) 
12c1			 
12c1			      ld    E, (IX+2)               ; this_free ptr to DE 
12c1			      ld    D, (IX+3) 
12c1			 
12c1			      ld    (HL), E                 ; this_free ptr into prev_free 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			      ; Clear the Z flag to indicate successful allocation 
12c1			      ld    A, D 
12c1			      or    E 
12c1			 
12c1			      pop   DE                      ; Address of allocation 
12c1			 
12c1			malloc_no_space: 
12c1			      ld    HL, 6                   ; Clean up stack frame 
12c1			      add   HL, SP 
12c1			      ld    SP, HL 
12c1			 
12c1			      ex    DE, HL                  ; Alloc addr into HL for return 
12c1			 
12c1			malloc_early_exit: 
12c1			      pop   IX 
12c1			      pop   DE 
12c1			      pop   BC 
12c1			 
12c1			      ret 
12c1			 
12c1			 
12c1			;------------------------------------------------------------------------------ 
12c1			;     free                                                                    : 
12c1			;                                                                             : 
12c1			; Description                                                                 : 
12c1			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12c1			;     returned by malloc, otherwise the behaviour is undefined.               : 
12c1			;                                                                             : 
12c1			;     Where possible, directly adjacent free blocks will be merged together   : 
12c1			;     into larger blocks to help ensure that the heap does not become         : 
12c1			;     excessively fragmented.                                                 : 
12c1			;                                                                             : 
12c1			;     free does not clear or set any other value into the freed space, and    : 
12c1			;     therefore its contents may be visible through subsequent malloc's. The  : 
12c1			;     caller should clear the freed space as required.                        : 
12c1			;                                                                             : 
12c1			;     This implementation of free uses the stack exclusively, and is          : 
12c1			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12c1			;     advisable to disable interrupts before calling free, and recommended    : 
12c1			;     to avoid the use of free inside ISRs in general.                        : 
12c1			;                                                                             : 
12c1			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12c1			;                                                                             : 
12c1			; Parameters                                                                  : 
12c1			;     HL  Pointer to address of first byte of allocation to be freed          : 
12c1			;                                                                             : 
12c1			; Returns                                                                     : 
12c1			;     Nothing                                                                 : 
12c1			;                                                                             : 
12c1			; Stack frame                                                                 : 
12c1			;       |             |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |     BC      |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |     DE      |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |     IX      |                                                       : 
12c1			;       +-------------+                                                       : 
12c1			;       |  prev_free  |                                                       : 
12c1			;   +2  +-------------+                                                       : 
12c1			;       |  next_free  |                                                       : 
12c1			;   +0  +-------------+                                                       : 
12c1			;       |             |                                                       : 
12c1			;                                                                             : 
12c1			;------------------------------------------------------------------------------ 
12c1			free: 
12c1			      push  BC 
12c1			      push  DE 
12c1			      push  IX 
12c1			 
12c1			      ld    A, H                    ; Exit if ptr is null 
12c1			      or    L 
12c1			      jp    Z, free_early_exit 
12c1			 
12c1			      ; Set up stack frame 
12c1			      ex    DE, HL 
12c1			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12c1			      add   HL, SP 
12c1			      ld    SP, HL 
12c1			      ld    IX, 0                   ; Use IX as a frame pointer 
12c1			      add   IX, SP 
12c1			 
12c1			      ; The address in HL points to the start of the useable allocated space, 
12c1			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12c1			      ; address of the block itself. 
12c1			      ex    DE, HL 
12c1			      ld    DE, -4 
12c1			      add   HL, DE 
12c1			 
12c1			      ; An allocated block must have a null next block pointer in it 
12c1			      ld    A, (HL) 
12c1			      inc   HL 
12c1			      or    (HL) 
12c1			      jp    NZ, free_done 
12c1			 
12c1			      dec   HL 
12c1			 
12c1			      ld    B, H                    ; Copy HL to BC 
12c1			      ld    C, L 
12c1			 
12c1			      ; Loop through the free list to find the first block with an address 
12c1			      ; higher than the block being freed 
12c1			      ld    HL, free_list 
12c1			 
12c1			free_find_higher_block: 
12c1			      ld    E, (HL)                 ; Load next ptr from free block 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      dec   HL 
12c1			 
12c1			      ld    (IX+0), E               ; Save ptr to next free block 
12c1			      ld    (IX+1), D 
12c1			      ld    (IX+2), L               ; Save ptr to prev free block 
12c1			      ld    (IX+3), H 
12c1			 
12c1			      ld    A, B                    ; Check if DE is greater than BC 
12c1			      cp    D                       ; Compare MSB first 
12c1			      jr    Z, $+4                  ; MSB the same, compare LSB 
12c1			      jr    NC, free_find_higher_block_skip 
12c1			      ld    A, C 
12c1			      cp    E                       ; Then compare LSB 
12c1			      jr    C, free_found_higher_block 
12c1			 
12c1			free_find_higher_block_skip: 
12c1			      ld    A, D                    ; Reached the end of the free list? 
12c1			      or    E 
12c1			      jp    Z, free_done 
12c1			 
12c1			      ex    DE, HL 
12c1			 
12c1			      jr    free_find_higher_block 
12c1			 
12c1			free_found_higher_block: 
12c1			      ; Insert freed block between prev and next free blocks 
12c1			      ld    (HL), C                 ; Point prev free block to freed block 
12c1			      inc   HL 
12c1			      ld    (HL), B 
12c1			 
12c1			      ld    H, B                    ; Point freed block at next free block 
12c1			      ld    L, C 
12c1			      ld    (HL), E 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			      ; Check if the freed block is adjacent to the next free block 
12c1			      inc   HL                      ; Load size of freed block into HL 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      ex    DE, HL 
12c1			 
12c1			      add   HL, BC                  ; Add addr of freed block and its size 
12c1			 
12c1			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12c1			      ld    D, (IX+1) 
12c1			 
12c1			      or    A                       ; Clear the carry flag 
12c1			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12c1			      jr    NZ, free_check_adjacent_to_prev 
12c1			 
12c1			      ; Freed block is adjacent to next, merge into one bigger block 
12c1			      ex    DE, HL                  ; Load next ptr from next block into DE 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      push  HL                      ; Save ptr to next block for later 
12c1			 
12c1			      ld    H, B                    ; Store ptr from next block into freed block 
12c1			      ld    L, C 
12c1			      ld    (HL), E 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			      pop   HL                      ; Restore ptr to next block 
12c1			      inc   HL                      ; Load size of next block into DE 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      push  DE                      ; Save next block size for later 
12c1			 
12c1			      ld    H, B                    ; Load size of freed block into HL 
12c1			      ld    L, C 
12c1			      inc   HL 
12c1			      inc   HL 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      ex    DE, HL 
12c1			 
12c1			      pop   DE                      ; Restore size of next block 
12c1			      add   HL, DE                  ; Add sizes of both blocks 
12c1			      ex    DE, HL 
12c1			 
12c1			      ld    H, B                    ; Store new bigger size into freed block 
12c1			      ld    L, C 
12c1			      inc   HL 
12c1			      inc   HL 
12c1			      ld    (HL), E 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			free_check_adjacent_to_prev: 
12c1			      ; Check if the freed block is adjacent to the prev free block 
12c1			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12c1			      ld    H, (IX+3) 
12c1			 
12c1			      inc   HL                      ; Size of prev free block into DE 
12c1			      inc   HL 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			      dec   HL 
12c1			 
12c1			      add   HL, DE                  ; Add prev block addr and size 
12c1			 
12c1			      or    A                       ; Clear the carry flag 
12c1			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12c1			      jr    NZ, free_done 
12c1			 
12c1			      ; Freed block is adjacent to prev, merge into one bigger block 
12c1			      ld    H, B                    ; Load next ptr from freed block into DE 
12c1			      ld    L, C 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      push  HL                      ; Save freed block ptr for later 
12c1			 
12c1			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12c1			      ld    H, (IX+3) 
12c1			      ld    (HL), E 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			      pop   HL                      ; Restore freed block ptr 
12c1			      inc   HL                      ; Load size of freed block into DE 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			      push  DE                      ; Save freed block size for later 
12c1			 
12c1			      ld    L, (IX+2)               ; Load size of prev block into DE 
12c1			      ld    H, (IX+3) 
12c1			      inc   HL 
12c1			      inc   HL 
12c1			      ld    E, (HL) 
12c1			      inc   HL 
12c1			      ld    D, (HL) 
12c1			 
12c1			      pop   HL                      ; Add sizes of both blocks 
12c1			      add   HL, DE 
12c1			      ex    DE, HL 
12c1			 
12c1			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12c1			      ld    H, (IX+3) 
12c1			      inc   HL 
12c1			      inc   HL 
12c1			      ld    (HL), E 
12c1			      inc   HL 
12c1			      ld    (HL), D 
12c1			 
12c1			free_done: 
12c1			      ld    HL, 4                   ; Clean up stack frame 
12c1			      add   HL, SP 
12c1			      ld    SP, HL 
12c1			 
12c1			free_early_exit: 
12c1			      pop   IX 
12c1			      pop   DE 
12c1			      pop   BC 
12c1			 
12c1			      ret 
12c1			 
12c1			 
12c1			;      .org 0x8000 
12c1			; 
12c1			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12c1			 ;                 .dw   0 
12c1			 
12c1			endif 
12c1			 
12c1			 
12c1			if MALLOC_4 
12c1			 
12c1			; My memory allocation code. Very very simple.... 
12c1			; allocate space under 250 chars 
12c1			 
12c1			heap_init: 
12c1				; init start of heap as zero 
12c1				;  
12c1			 
12c1				ld hl, heap_start 
12c1			;	ld a, 0 
12c1				ld (hl), 0      ; empty block 
12c1				inc hl 
12c1			;	ld a, 0 
12c1				ld (hl), 0      ; length of block 
12c1				; write end of list 
12c1				inc hl 
12c1				ld a,(hl) 
12c1				inc hl 
12c1				ld a,(hl) 
12c1				 
12c1			 
12c1				; init some malloc vars 
12c1			 
12c1				ld hl, 0 
12c1				ld (free_list), hl       ; store last malloc location 
12c1			 
12c1				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12c1			;	ld a, 0 
12c1				ld (hl), 0 
12c1			 
12c1			 
12c1				ld hl, heap_start 
12c1				;  
12c1				  
12c1				ret 
12c1			 
12c1			 
12c1			;    free block marker 
12c1			;    requested size  
12c1			;    pointer to next block 
12c1			;    .... 
12c1			;    next block marker 
12c1			 
12c1			 
12c1			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12c1			; 
12c1			 
12c1			 
12c1			malloc:  
12c1				push de 
12c1				push bc 
12c1				push af 
12c1			 
12c1				; hl space required 
12c1				 
12c1				ld c, l    ; hold space   (TODO only a max of 255) 
12c1			 
12c1			;	inc c     ; TODO BUG need to fix memory leak on push str 
12c1			;	inc c 
12c1			;	inc c 
12c1			;	inc c 
12c1			;	inc c 
12c1			;	inc c 
12c1			;	inc c 
12c1			 
12c1			 
12c1			 
12c1				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12c1			 
12c1				ld a, (free_list+3) 
12c1			;	cp 0 
12c1				or a 
12c1				jr z, .contheap 
12c1			 
12c1				ld hl, (free_list)     ; get last alloc 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "mrs" 
12c1						CALLMONITOR 
12c1					endif 
12c1				jr .startalloc 
12c1			 
12c1			.contheap: 
12c1				ld hl, heap_start 
12c1			 
12c1			.startalloc: 
12c1			 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "mym" 
12c1						CALLMONITOR 
12c1					endif 
12c1			.findblock: 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "mmf" 
12c1						CALLMONITOR 
12c1					endif 
12c1			 
12c1				ld a,(hl)  
12c1				; if byte is zero then clear to use 
12c1			 
12c1			;	cp 0 
12c1				or a 
12c1				jr z, .foundemptyblock 
12c1			 
12c1				; if byte is not clear 
12c1				;     then byte is offset to next block 
12c1			 
12c1				inc hl 
12c1				ld a, (hl) ; get size 
12c1			.nextblock:	inc hl 
12c1					ld e, (hl) 
12c1					inc hl 
12c1					ld d, (hl) 
12c1					ex de, hl 
12c1			;	inc hl  ; move past the store space 
12c1			;	inc hl  ; move past zero index  
12c1			 
12c1				; TODO detect no more space 
12c1			 
12c1				push hl 
12c1				ld de, heap_end 
12c1				call cmp16 
12c1				pop hl 
12c1				jr nc, .nospace 
12c1			 
12c1				jr .findblock 
12c1			 
12c1			.nospace: ld hl, 0 
12c1				jp .exit 
12c1			 
12c1			 
12c1			.foundemptyblock:	 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "mme" 
12c1						CALLMONITOR 
12c1					endif 
12c1			 
12c1			; TODO has block enough space if reusing??? 
12c1			 
12c1				;  
12c1			 
12c1			; see if this block has been previously used 
12c1				inc hl 
12c1				ld a, (hl) 
12c1				dec hl 
12c1			;	cp 0 
12c1				or a 
12c1				jr z, .newblock 
12c1			 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "meR" 
12c1						CALLMONITOR 
12c1					endif 
12c1			 
12c1			; no reusing previously allocated block 
12c1			 
12c1			; is it smaller than previously used? 
12c1				 
12c1				inc hl    ; move to size 
12c1				ld a, c 
12c1				sub (hl)        ; we want c < (hl) 
12c1				dec hl    ; move back to marker 
12c1			        jr z, .findblock 
12c1			 
12c1				; update with the new size which should be lower 
12c1			 
12c1			        ;inc  hl   ; negate next move. move back to size  
12c1			 
12c1			.newblock: 
12c1				; need to be at marker here 
12c1			 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "meN" 
12c1						CALLMONITOR 
12c1					endif 
12c1			 
12c1			 
12c1				ld a, c 
12c1			 
12c1				ld (free_list+3), a	 ; flag resume from last malloc  
12c1				ld (free_list), hl    ; save out last location 
12c1			 
12c1			 
12c1				;inc a     ; space for length byte 
12c1				ld (hl), a     ; save block in use marker 
12c1			 
12c1				inc hl   ; move to space marker 
12c1				ld (hl), a    ; save new space 
12c1			 
12c1				inc hl   ; move to start of allocated area 
12c1				 
12c1			;	push hl     ; save where we are - 1  
12c1			 
12c1			;	inc hl  ; move past zero index  
12c1				; skip space to set down new marker 
12c1			 
12c1				; provide some extra space for now 
12c1			 
12c1				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12c1				inc a 
12c1				inc a 
12c1			 
12c1				push hl   ; save where we are in the node block 
12c1			 
12c1				call addatohl 
12c1			 
12c1				; write linked list point 
12c1			 
12c1				pop de     ; get our node position 
12c1				ex de, hl 
12c1			 
12c1				ld (hl), e 
12c1				inc hl 
12c1				ld (hl), d 
12c1			 
12c1				inc hl 
12c1			 
12c1				; now at start of allocated data so save pointer 
12c1			 
12c1				push hl 
12c1			 
12c1				; jump to position of next node and setup empty header in DE 
12c1			 
12c1				ex de, hl 
12c1			 
12c1			;	inc hl ; move past end of block 
12c1			 
12c1			;	ld a, 0 
12c1				ld (hl), 0   ; empty marker 
12c1				inc hl 
12c1				ld (hl), 0   ; size 
12c1				inc hl  
12c1				ld (hl), 0   ; ptr 
12c1				inc hl 
12c1				ld (hl), 0   ; ptr 
12c1			 
12c1			 
12c1				pop hl 
12c1			 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "mmr" 
12c1						CALLMONITOR 
12c1					endif 
12c1			 
12c1			.exit: 
12c1				pop af 
12c1				pop bc 
12c1				pop de  
12c1				ret 
12c1			 
12c1			 
12c1			 
12c1			 
12c1			free:  
12c1				push hl 
12c1				push af 
12c1				; get address in hl 
12c1			 
12c1					if DEBUG_FORTH_MALLOC_INT 
12c1						DMARK "fre" 
12c1						CALLMONITOR 
12c1					endif 
12c1				; data is at hl - move to block count 
12c1				dec hl 
12c1				dec hl    ; get past pointer 
12c1				dec hl 
12c1			 
12c1				ld a, (hl)    ; need this for a validation check 
12c1			 
12c1				dec hl    ; move to block marker 
12c1			 
12c1				; now check that the block count and block marker are the same  
12c1			        ; this checks that we are on a malloc node and not random memory 
12c1			        ; OK a faint chance this could be a problem but rare - famous last words! 
12c1			 
12c1				ld c, a 
12c1				ld a, (hl)    
12c1			 
12c1				cp c 
12c1				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12c1			 
12c1				; yes good chance we are on a malloc node 
12c1			 
12c1			;	ld a, 0      
12c1				ld (hl), 0   ; mark as free 
12c1			 
12c1				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12c1			 
12c1			.freeignore:  
12c1			 
12c1				pop af 
12c1				pop hl 
12c1			 
12c1				ret 
12c1			 
12c1			 
12c1			 
12c1			endif 
12c1			 
