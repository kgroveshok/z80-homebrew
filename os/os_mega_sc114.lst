8feb			 
8feb			; hl - points to file name 
8feb			; de - points to strings to add to file 
8feb			 
8feb			.genfile: 
8feb				push hl 
8feb				push de 
8feb			 
8feb				call clear_display 
8feb				ld a, display_row_1 
8feb				ld de, .genfiletxt 
8feb				call str_at_display 
8feb				call update_display 
8feb			 
8feb				pop de 
8feb				pop hl 
8feb			 
8feb			 
8feb				push de 
8feb				call storage_create 
8feb				; id in hl 
8feb				pop de   ; table of strings to add 
8feb			 
8feb			.genloop: 
8feb			 
8feb				push hl ; save id for next time around 
8feb				push de ; save de for next time around 
8feb			 
8feb				ex de, hl 
8feb				call loadwordinhl 
8feb				ex de, hl 
8feb			 
8feb				; need hl to be the id 
8feb				; need de to be the string ptr 
8feb				 
8feb				call storage_append 
8feb			 
8feb				pop de 
8feb				pop hl 
8feb			 
8feb				inc de 
8feb				inc de 
8feb			 
8feb				ld a,(de) 
8feb				cp 0 
8feb				jr nz, .genloop 
8feb				inc de 
8feb				ld a, (de) 
8feb				dec de 
8feb				cp 0 
8feb				jr nz, .genloop	 
8feb			 
8feb				ret 
8feb			 
8feb			.genfiletxt:  db "Creating file...",0 
