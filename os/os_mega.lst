5ee2			; handle the auto run of code from files in storage 
5ee2			 
5ee2			 
5ee2			include "forth_startup.asm" 
5ee2			; Which startup method to use? 
5ee2			; 
5ee2			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
5ee2			; followed by loading of a list of scripts in eeprom 
5ee2			 
5ee2			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
5ee2			; from eeprom 
5ee2			 
5ee2			; Select with define in main stubs 
5ee2			 
5ee2			if STARTUP_V1 
5ee2				include "forth_startupv1.asm" 
5ee2			endif 
5ee2			if STARTUP_V2 
5ee2				include "forth_startupv2.asm" 
5ee2			; Version 2 of the startup  
5ee2			;  
5ee2			; Auto load any files in bank 1 that start with a '*' 
5ee2			; If no se storage then revert to using eprom 
5ee2			 
5ee2			 
5ee2			if STORAGE_SE = 0 
5ee2			 
5ee2			sprompt1: db "Startup load...",0 
5ee2			sprompt2: db "Run? 1=No *=End #=All",0 
5ee2			 
5ee2			 
5ee2			 
5ee2			 
5ee2			forth_startup: 
5ee2				ld hl, startcmds 
5ee2				ld a, 0 
5ee2				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
5ee2			 
5ee2			.start1:	push hl 
5ee2				call clear_display 
5ee2				ld de, sprompt1 
5ee2			        ld a, display_row_1 
5ee2				call str_at_display 
5ee2				ld de, sprompt2 
5ee2			        ld a, display_row_2 
5ee2				call str_at_display 
5ee2				pop hl 
5ee2				push hl 
5ee2				ld e,(hl) 
5ee2				inc hl 
5ee2				ld d,(hl) 
5ee2			        ld a, display_row_3 
5ee2				call str_at_display 
5ee2				call update_display 
5ee2			 
5ee2			 
5ee2				ld a, (os_last_cmd) 
5ee2			;	cp 0 
5ee2				or a 
5ee2				jr z, .startprompt 
5ee2				call delay250ms 
5ee2				jr .startdo 
5ee2				 
5ee2				 
5ee2			 
5ee2			.startprompt: 
5ee2			 
5ee2				ld a,display_row_4 + display_cols - 1 
5ee2			        ld de, endprg 
5ee2				call str_at_display 
5ee2				call update_display 
5ee2				call delay1s 
5ee2				call cin_wait 
5ee2						 
5ee2				cp '*' 
5ee2				jr z, .startupend1 
5ee2				cp '#' 
5ee2				jr nz, .startno 
5ee2				ld a, 1 
5ee2				ld (os_last_cmd),a 
5ee2				jr .startdo 
5ee2			.startno:	cp '1' 
5ee2				jr z,.startnxt  
5ee2			 
5ee2				; exec startup line 
5ee2			.startdo:	 
5ee2				pop hl 
5ee2				push hl 
5ee2				 
5ee2				ld e,(hl) 
5ee2				inc hl 
5ee2				ld d,(hl) 
5ee2				ex de,hl 
5ee2			 
5ee2				push hl 
5ee2			 
5ee2				ld a, 0 
5ee2				;ld a, FORTH_END_BUFFER 
5ee2				call strlent 
5ee2				inc hl   ; include zero term to copy 
5ee2				ld b,0 
5ee2				ld c,l 
5ee2				pop hl 
5ee2				ld de, scratch 
5ee2				ldir 
5ee2			 
5ee2			 
5ee2				ld hl, scratch 
5ee2				call forthparse 
5ee2				call forthexec 
5ee2				call forthexec_cleanup 
5ee2			 
5ee2				ld a, display_row_4 
5ee2				ld de, endprog 
5ee2			 
5ee2				call update_display		 
5ee2			 
5ee2				ld a, (os_last_cmd) 
5ee2			;	cp 0 
5ee2				or a 
5ee2				jr nz, .startnxt 
5ee2				call next_page_prompt 
5ee2			        call clear_display 
5ee2				call update_display		 
5ee2			 
5ee2				; move onto next startup line? 
5ee2			.startnxt: 
5ee2			 
5ee2				call delay250ms 
5ee2				pop hl 
5ee2			 
5ee2				inc hl 
5ee2				inc hl 
5ee2			 
5ee2				push hl 
5ee2				ld e, (hl) 
5ee2				inc hl 
5ee2				ld d, (hl) 
5ee2				pop hl 
5ee2				; TODO replace 0 test 
5ee2			 
5ee2				ex de, hl 
5ee2				call ishlzero 
5ee2			;	ld a,e 
5ee2			;	add d 
5ee2			;	cp 0    ; any left to do? 
5ee2				ex de, hl 
5ee2				jp nz, .start1 
5ee2				jr .startupend 
5ee2			 
5ee2			.startupend1: pop hl 
5ee2			.startupend: 
5ee2			 
5ee2				call clear_display 
5ee2				call update_display 
5ee2				ret 
5ee2			endif 
