2db5			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2db5			; | | At start the current various registers will be displayed with contents. 
2db5			; | | Top right corner will show the most recent debug marker seen. 
2db5			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2db5			; | | and the return stack pointer (RSP). 
2db5			; | | Pressing: 
2db5			; | |  
2db5			; | |    1 - Initial screen 
2db5			; | |  
2db5			; | |    2 - Display a data dump of HL 
2db5			; | |  
2db5			; | |    3 - Display a data dump of DE 
2db5			; | |  
2db5			; | |    4 - Display a data dump of BC 
2db5			; | |  
2db5			; | |    5 - Display a data dump of HL 
2db5			; | |  
2db5			; | |    6 - Display a data dump of DSP 
2db5			; | |  
2db5			; | |    7 - Display a data dump of RSP 
2db5			; | |  
2db5			; | |    8 - Display a data dump of what is at DSP 
2db5			; | |  
2db5			; | |    9 - Display a data dump of what is at RSP 
2db5			; | |  
2db5			; | |    0 - Exit monitor and continue running. This will also enable break points 
2db5			; | |  
2db5			; | |    * - Disable break points 
2db5			; | |  
2db5			; | |    # - Enter traditional monitor mode 
2db5			; | |  
2db5			; | | 
2db5			; | | Monitor Mode 
2db5			; | | ------------ 
2db5			; | | A prompt of '>' will be shown for various commands: 
2db5			; | |  
2db5			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2db5			; | |  
2db5			; | |    C - Continue display a data dump from the last set address 
2db5			; | |  
2db5			; | |    M xxxx - Set start of memory edit at address xx 
2db5			; | |  
2db5			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2db5			; | |  
2db5			; | |    G xxxx - Exec code at specific address 
2db5			; | |  
2db5			; | |    Q - Return to previous 
2db5				if DEBUG_FORTH_WORDS_KEY 
2db5					DMARK "MON" 
2db5 f5				push af  
2db6 3a ca 2d			ld a, (.dmark)  
2db9 32 99 fd			ld (debug_mark),a  
2dbc 3a cb 2d			ld a, (.dmark+1)  
