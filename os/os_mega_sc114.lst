d40b			include "forth_startup.asm" 
d40b			; Which startup method to use? 
d40b			; 
d40b			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
d40b			; followed by loading of a list of scripts in eeprom 
d40b			 
d40b			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
d40b			; from eeprom 
d40b			 
d40b			; Select with define in main stubs 
d40b			 
d40b			if STARTUP_V1 
d40b				include "forth_startupv1.asm" 
d40b			; Startup script loading version 1 
d40b			 
d40b			; If SE storage is available first stage is to use the selected file 
d40b			; then go through the eeprom list 
d40b			 
d40b .. 00		sprompt1: db "Startup load...",0 
d41b .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
