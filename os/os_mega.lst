668a				ex de, hl 
668a				call ishlzero 
668a			;	ld a,e 
668a			;	add d 
668a			;	cp 0    ; any left to do? 
668a				ex de, hl 
668a				jp nz, .start1 
668a				jr .startupend 
668a			 
668a			.startupend1: pop hl 
668a			.startupend: 
668a			 
668a				call clear_display 
668a				call update_display 
668a				ret 
