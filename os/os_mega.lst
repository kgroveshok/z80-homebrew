12d8			; Tape support 
12d8			 
12d8			 
12d8			; encoding 
12d8			;  
12d8			; pulse marks  of stream 
12d8			; proportial 
12d8			 
12d8			 
12d8			; setup default tape params 
12d8			tape_init:     
12d8 3e 00			ld a, Device_A 
12da 32 8e f9			ld (tape_port), a 
12dd			 
12dd 3e fa			ld a, 250 
12df 32 89 f9			ld (tape_tm_gap), a 
12e2			 
12e2 21 40 1f			ld hl, 8000 
12e5 22 8a f9			ld (tape_samples), hl 
12e8			 
12e8 3e 06			ld a, 6 
12ea 32 8d f9			ld (tape_pulse_high), a 
12ed			 
12ed 3e 02			ld a, 2 
12ef 32 8c f9			ld (tape_pulse_low), a 
12f2			 
12f2 21 32 00			ld hl, 50 
12f5 22 87 f9			ld (tape_tm_high), hl 
12f8			 
12f8 21 32 00			ld hl, 50 
12fb 22 85 f9			ld (tape_tm_low), hl 
12fe c9				ret 
12ff			 
12ff			; support routinues for tape 
12ff			 
12ff			 
12ff			; Tape Output 
12ff			 
12ff			; osciallate the pin for the required duration 
12ff			 
12ff			tape_osc:  
12ff				; hl has the number of iterations 
12ff				; c = port number 
12ff				; d = bus data 
12ff				 
12ff ed 51			out (c), d 
1301			 
1301 2b				dec hl 
1302 cd 8b 0d			call ishlzero 
1305 20 f8			jr nz, tape_osc 
1307				 
1307 c9				ret 
1308			 
1308			; output a gap period 
1308			tape_gap:  
1308 3a 89 f9			ld a, (tape_tm_gap) 
130b cd 56 0a			call aDelayInMS 
130e c9				ret 
130f			 
130f			tape_byte_gap: 
130f cd 08 13			call tape_gap 
1312 cd 08 13			call tape_gap 
1315 cd 08 13			call tape_gap 
1318 cd 08 13			call tape_gap 
131b c9				ret 
131c			 
131c			; output a high period 
131c			 
131c			tape_high: 
131c 3a 8e f9			ld a, (tape_port) 
131f 4f				ld c, a 
1320 16 ff			ld d, 255 
1322 3a 8d f9			ld a, (tape_pulse_high) 
1325 47				ld b, a 
1326 2a 87 f9		.th:	ld hl, (tape_tm_high) 
1329 cd ff 12			call tape_osc 
132c 10 f8			djnz .th 
132e c9				 ret 
132f			 
132f			; output a low period 
132f			 
132f			tape_low:  
132f			 
132f 3a 8e f9			ld a, (tape_port) 
1332 4f				ld c, a 
1333 16 ff			ld d, 255 
1335 3a 8c f9			ld a, (tape_pulse_low) 
1338 47				ld b, a 
1339 2a 87 f9		.tl:	ld hl, (tape_tm_high) 
133c			; keep the same pulse size and instead use count of pulse rather than length of pulse 
133c			;	ld hl, (tape_tm_low) 
133c cd ff 12			call tape_osc 
133f 10 f8			djnz .tl 
1341 c9				 ret 
1342			 
1342			; end of save marker 
1342			 
1342			tape_end: 
1342 3e ff			ld a, 255 
1344 cd 5b 13			call tape_byte_out 
1347 cd 0f 13			call tape_byte_gap 
134a			 
134a 3e ff			ld a, 255 
134c cd 5b 13			call tape_byte_out 
134f cd 0f 13			call tape_byte_gap 
1352 3e ff			ld a, 255 
1354 cd 5b 13			call tape_byte_out 
1357 cd 0f 13			call tape_byte_gap 
135a c9				 ret 
135b			 
135b			; output an encoded byte 
135b			 
135b			tape_byte_out: 
135b				; a = byte to output 
135b 06 08			ld b, 8 
135d 4f				ld c, a 
135e			.tbo:    
135e c5				push bc 
135f cb 79			bit 7, c 
1361 28 05			jr z, .tbol 
1363 cd 1c 13			call tape_high 
1366 18 03			jr .tbn 
1368			.tbol: 
1368 cd 2f 13			call tape_low 
136b			.tbn: 
136b cd 08 13			call tape_gap 
136e c1				pop bc 
136f cb 21			sla c 
1371 10 eb			djnz .tbo 
1373 cd 0f 13			call tape_byte_gap 
1376			 
1376 c9				 ret 
