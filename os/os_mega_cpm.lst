114a			 
114a			 
114a					; active low 
114a			 
114a			;		cp 0 
114a					or a 
114a					jr z, .bset 
114a					cp 1 
114a					jr nz, .b2 
114a					res 0, c 
114a					ld b, '1'    ; human readable bank number 
114a			.b2:		cp 2 
114a					jr nz, .b3 
114a					res 1, c 
114a					ld b, '2'    ; human readable bank number 
114a			.b3:		cp 3 
