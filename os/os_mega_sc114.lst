8fba			 
8fba			if MALLOC_4 
8fba			 
8fba			; My memory allocation code. Very very simple.... 
8fba			; allocate space under 250 chars 
8fba			 
8fba			heap_init: 
8fba				; init start of heap as zero 
8fba				;  
8fba			 
8fba				ld hl, heap_start 
8fba			;	ld a, 0 
8fba				ld (hl), 0      ; empty block 
8fba				inc hl 
8fba			;	ld a, 0 
8fba				ld (hl), 0      ; length of block 
8fba				; write end of list 
8fba				inc hl 
8fba				ld a,(hl) 
8fba				inc hl 
8fba				ld a,(hl) 
8fba				 
8fba			 
8fba				; init some malloc vars 
8fba			 
8fba				ld hl, 0 
8fba				ld (free_list), hl       ; store last malloc location 
8fba			 
8fba				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
8fba			;	ld a, 0 
8fba				ld (hl), 0 
8fba			 
8fba			 
8fba				ld hl, heap_start 
8fba				;  
8fba				  
8fba				ret 
8fba			 
8fba			 
8fba			;    free block marker 
8fba			;    requested size  
8fba			;    pointer to next block 
8fba			;    .... 
8fba			;    next block marker 
8fba			 
8fba			 
8fba			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
8fba			; 
8fba			 
8fba			 
8fba			malloc:  
8fba				push de 
8fba				push bc 
8fba				push af 
8fba			 
8fba				; hl space required 
8fba				 
8fba				ld c, l    ; hold space   (TODO only a max of 255) 
8fba			 
8fba			;	inc c     ; TODO BUG need to fix memory leak on push str 
8fba			;	inc c 
8fba			;	inc c 
8fba			;	inc c 
8fba			;	inc c 
8fba			;	inc c 
8fba			;	inc c 
8fba			 
8fba			 
8fba			 
8fba				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
8fba			 
8fba				ld a, (free_list+3) 
8fba			;	cp 0 
8fba				or a 
8fba				jr z, .contheap 
8fba			 
8fba				ld hl, (free_list)     ; get last alloc 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "mrs" 
8fba						CALLMONITOR 
8fba					endif 
8fba				jr .startalloc 
8fba			 
8fba			.contheap: 
8fba				ld hl, heap_start 
8fba			 
8fba			.startalloc: 
8fba			 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "mym" 
8fba						CALLMONITOR 
8fba					endif 
8fba			.findblock: 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "mmf" 
8fba						CALLMONITOR 
8fba					endif 
8fba			 
8fba				ld a,(hl)  
8fba				; if byte is zero then clear to use 
8fba			 
8fba			;	cp 0 
8fba				or a 
8fba				jr z, .foundemptyblock 
8fba			 
8fba				; if byte is not clear 
8fba				;     then byte is offset to next block 
8fba			 
8fba				inc hl 
8fba				ld a, (hl) ; get size 
8fba			.nextblock:	inc hl 
8fba					ld e, (hl) 
8fba					inc hl 
8fba					ld d, (hl) 
8fba					ex de, hl 
8fba			;	inc hl  ; move past the store space 
8fba			;	inc hl  ; move past zero index  
8fba			 
8fba				; TODO detect no more space 
8fba			 
8fba				push hl 
8fba				ld de, heap_end 
8fba				call cmp16 
8fba				pop hl 
8fba				jr nc, .nospace 
8fba			 
8fba				jr .findblock 
8fba			 
8fba			.nospace: ld hl, 0 
8fba				jp .exit 
8fba			 
8fba			 
8fba			.foundemptyblock:	 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "mme" 
8fba						CALLMONITOR 
8fba					endif 
8fba			 
8fba			; TODO has block enough space if reusing??? 
8fba			 
8fba				;  
8fba			 
8fba			; see if this block has been previously used 
8fba				inc hl 
8fba				ld a, (hl) 
8fba				dec hl 
8fba			;	cp 0 
8fba				or a 
8fba				jr z, .newblock 
8fba			 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "meR" 
8fba						CALLMONITOR 
8fba					endif 
8fba			 
8fba			; no reusing previously allocated block 
8fba			 
8fba			; is it smaller than previously used? 
8fba				 
8fba				inc hl    ; move to size 
8fba				ld a, c 
8fba				sub (hl)        ; we want c < (hl) 
8fba				dec hl    ; move back to marker 
8fba			        jr z, .findblock 
8fba			 
8fba				; update with the new size which should be lower 
8fba			 
8fba			        ;inc  hl   ; negate next move. move back to size  
8fba			 
8fba			.newblock: 
8fba				; need to be at marker here 
8fba			 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "meN" 
8fba						CALLMONITOR 
8fba					endif 
8fba			 
8fba			 
8fba				ld a, c 
8fba			 
8fba				ld (free_list+3), a	 ; flag resume from last malloc  
8fba				ld (free_list), hl    ; save out last location 
8fba			 
8fba			 
8fba				;inc a     ; space for length byte 
8fba				ld (hl), a     ; save block in use marker 
8fba			 
8fba				inc hl   ; move to space marker 
8fba				ld (hl), a    ; save new space 
8fba			 
8fba				inc hl   ; move to start of allocated area 
8fba				 
8fba			;	push hl     ; save where we are - 1  
8fba			 
8fba			;	inc hl  ; move past zero index  
8fba				; skip space to set down new marker 
8fba			 
8fba				; provide some extra space for now 
8fba			 
8fba				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
8fba				inc a 
8fba				inc a 
8fba			 
8fba				push hl   ; save where we are in the node block 
8fba			 
8fba				call addatohl 
8fba			 
8fba				; write linked list point 
8fba			 
8fba				pop de     ; get our node position 
8fba				ex de, hl 
8fba			 
8fba				ld (hl), e 
8fba				inc hl 
8fba				ld (hl), d 
8fba			 
8fba				inc hl 
8fba			 
8fba				; now at start of allocated data so save pointer 
8fba			 
8fba				push hl 
8fba			 
8fba				; jump to position of next node and setup empty header in DE 
8fba			 
8fba				ex de, hl 
8fba			 
8fba			;	inc hl ; move past end of block 
8fba			 
8fba			;	ld a, 0 
8fba				ld (hl), 0   ; empty marker 
8fba				inc hl 
8fba				ld (hl), 0   ; size 
8fba				inc hl  
8fba				ld (hl), 0   ; ptr 
8fba				inc hl 
8fba				ld (hl), 0   ; ptr 
8fba			 
8fba			 
8fba				pop hl 
8fba			 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "mmr" 
8fba						CALLMONITOR 
8fba					endif 
8fba			 
8fba			.exit: 
8fba				pop af 
8fba				pop bc 
8fba				pop de  
8fba				ret 
8fba			 
8fba			 
8fba			 
8fba			 
8fba			free:  
8fba				push hl 
8fba				push af 
8fba				; get address in hl 
8fba			 
8fba					if DEBUG_FORTH_MALLOC_INT 
8fba						DMARK "fre" 
8fba						CALLMONITOR 
8fba					endif 
8fba				; data is at hl - move to block count 
8fba				dec hl 
8fba				dec hl    ; get past pointer 
8fba				dec hl 
8fba			 
8fba				ld a, (hl)    ; need this for a validation check 
8fba			 
8fba				dec hl    ; move to block marker 
8fba			 
8fba				; now check that the block count and block marker are the same  
8fba			        ; this checks that we are on a malloc node and not random memory 
8fba			        ; OK a faint chance this could be a problem but rare - famous last words! 
8fba			 
8fba				ld c, a 
8fba				ld a, (hl)    
8fba			 
8fba				cp c 
8fba				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
8fba			 
8fba				; yes good chance we are on a malloc node 
8fba			 
8fba			;	ld a, 0      
8fba				ld (hl), 0   ; mark as free 
8fba			 
8fba				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
8fba			 
8fba			.freeignore:  
8fba			 
8fba				pop af 
8fba				pop hl 
8fba			 
8fba				ret 
8fba			 
8fba			 
8fba			 
8fba			endif 
