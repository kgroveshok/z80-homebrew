0d84 5f			    ld    e, a    ; L = A+L 
0d85 8a			    adc   a, d    ; A = A+L+H+carry 
0d86 93			    sub   e       ; A = H+carry 
0d87 57			    ld    d, a    ; H = H+carry 
0d88 c9			ret 
