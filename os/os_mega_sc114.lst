d4fd						CALLMONITOR 
d4fd					endif 
d4fd			 
d4fd					call ishlzero 
d4fd					ret z             ; file not found 
d4fd			 
d4fd					ld a, display_row_2 + 10 
d4fd					ld de, store_page+3 
d4fd					call str_at_display 
d4fd				 
d4fd			; 
