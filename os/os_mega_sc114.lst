9e3a 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e3b 54 9e			dw .HEAP            
9e3d 04				db 3 + 1 
9e3e .. 00			db "NEW",0              
9e42				endm 
# End of macro CWHEAD
9e42			; | NEW ( -- ) Clears all user words and stack | DONE 
9e42				 
9e42				if MALLOC_4 
9e42					call  heap_init 
9e42				endif 
9e42				; reset uword pointers 
9e42 21 e3 d6			ld hl, baseram 
9e45 22 9f e5			ld (os_last_new_uword), hl 
9e48 cd 8e 9c			call user_word_eol 
9e4b				; clear stack 
9e4b cd a7 9c			call forth_warmstart 
9e4e				NEXTW 
9e4e cd 68 ee			call parse_vector 
9e51 c3 01 9d			jp macro_next 
9e54				endm 
# End of macro NEXTW
9e54			 
9e54			.HEAP: 
9e54			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
9e54 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e55 82 9e			dw .EXEC            
9e57 05				db 4 + 1 
9e58 .. 00			db "HEAP",0              
9e5d				endm 
# End of macro CWHEAD
9e5d			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
9e5d			; | | u1 - Current number of bytes in the heap 
9e5d			; | | u2 - Remaining bytes left on the heap 
9e5d			; | |  
9e5d			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
9e5d			 
9e5d			 
9e5d				if DEBUG_FORTH_WORDS_KEY 
9e5d					DMARK "HEP" 
9e5d				if DEMARK_VERSION = 1  
9e5d e5					push hl  
9e5e 21 66 9e				ld hl, .dmark  
9e61 22 60 ee				ld (debug_mark), hl  
9e64				endif  
9e64				if DEMARK_VERSION = 0  
9e64					push af  
9e64					ld a, (.dmark)  
9e64					ld (debug_mark),a  
9e64					ld a, (.dmark+1)  
9e64					ld (debug_mark+1),a  
9e64					ld a, (.dmark+2)  
9e64					ld (debug_mark+2),a  
9e64				endif  
9e64 18 04			jr .pastdmark  
9e66 ..			.dmark: db "HEP"  
9e69				if DEMARK_VERSION = 1  
9e69 00					db 0  
9e6a				endif  
9e6a				if DEMARK_VERSION = 1  
9e6a e1			.pastdmark: pop hl  
9e6b				endif  
9e6b				if DEMARK_VERSION = 0  
9e6b			.pastdmark: pop af  
9e6b				endif  
9e6b			endm  
# End of macro DMARK
9e6b					CALLMONITOR 
9e6b				if BASE_CPM=1  
9e6b					call debug_vector  
9e6b				endif  
9e6b				if BASE_KEV=1  
9e6b					rst 8  
9e6b				endif  
9e6b				endm  
# End of macro CALLMONITOR
9e6b				endif 
9e6b 2a ed d6			ld hl, (free_list )      
9e6e 11 f2 d6			ld de, heap_start 
