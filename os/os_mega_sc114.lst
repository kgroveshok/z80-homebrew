9ddd 15				db WORD_SYS_CORE+OPCODE_HEAP             
9dde f7 9d			dw .HEAP            
9de0 04				db 3 + 1 
9de1 .. 00			db "NEW",0              
9de5				endm 
# End of macro CWHEAD
9de5			; | NEW ( -- ) Clears all user words and stack | DONE 
9de5				 
9de5				if MALLOC_4 
