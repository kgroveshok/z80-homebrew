110a			if MALLOC_2 
110a			; Z80 Malloc and Free Functions 
110a			 
110a			; Malloc Function: 
110a			; Input: 
110a			;   HL: Size of block to allocate 
110a			; Output: 
110a			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
110a			 
110a			malloc: 
110a				 
110a			if DEBUG_FORTH_MALLOC_HIGH 
110a			call malloc_guard_entry 
110a			endif 
110a			 
110a			 
110a			 
110a			 
110a					if DEBUG_FORTH_MALLOC 
110a						DMARK "mal" 
110a						CALLMONITOR 
110a					endif 
110a			    push af            ; Save AF register 
110a			    ld a, l            ; Load low byte of size into A 
110a			    or h               ; Check if size is zero 
110a			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
110a			 
110a			    ; Allocate memory 
110a			    ld hl, (heap_start) ; Load start of heap into HL 
110a					if DEBUG_FORTH_MALLOC 
110a						DMARK "ma1" 
110a						CALLMONITOR 
110a					endif 
110a			    call malloc_internal ; Call internal malloc function 
110a			    pop af             ; Restore AF register 
110a			if DEBUG_FORTH_MALLOC_HIGH 
110a			call malloc_guard_exit 
110a			call malloc_guard_zerolen 
110a			endif 
110a			    ret                ; Return 
110a			 
110a			; Free Function: 
110a			; Input: 
110a			;   HL: Pointer to memory block to free 
110a			; Output: 
110a			;   None 
110a			 
110a			free: 
110a			    push af            ; Save AF register 
110a			    ld a, l            ; Load low byte of pointer into A 
110a			    or h               ; Check if pointer is NULL 
110a			    jp z, free_exit    ; If pointer is NULL, exit 
110a			 
110a			    ; Free memory 
110a			    ld hl, (heap_start) ; Load start of heap into HL 
110a			    call free_internal  ; Call internal free function 
110a			    pop af             ; Restore AF register 
110a			    ret                ; Return 
110a			 
110a			; Internal Malloc Function: 
110a			; Input: 
110a			;   HL: Size of block to allocate 
110a			; Output: 
110a			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
110a			 
110a			malloc_internal: 
110a			    ld bc, 2           ; Number of bytes to allocate for management overhead 
110a			    add hl, bc         ; Add management overhead to requested size 
110a			    ex de, hl          ; Save total size in DE, and keep it in HL 
110a					if DEBUG_FORTH_MALLOC 
110a						DMARK "ma2" 
110a						CALLMONITOR 
110a					endif 
110a			 
110a			    ; Search for free memory block 
110a			    ld de, (heap_end)  ; Load end of heap into DE 
110a			    ld bc, 0           ; Initialize counter 
110a			 
110a					if DEBUG_FORTH_MALLOC 
110a						DMARK "ma2" 
110a						CALLMONITOR 
110a					endif 
110a			malloc_search_loop: 
110a			    ; Check if current block is free 
110a			    ld a, (hl)         ; Load current block's status (free or used) 
110a			;    cp 0               ; Compare with zero (free) 
110a				or a 
110a			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
110a			 
110a			    ; Check if current block is large enough 
110a			    ld a, (hl+1)       ; Load high byte of block size 
110a			    cp l               ; Compare with low byte of requested size 
110a			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
110a			 
110a			    ld a, (hl+2)       ; Load low byte of block size 
110a			    cp h               ; Compare with high byte of requested size 
110a			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
110a			 
110a			    ; Mark block as used 
110a			    ld (hl), 0xFF      ; Set status byte to indicate used block 
110a			 
110a			    ; Calculate remaining space in block 
110a			    ld bc, 0           ; Clear BC 
110a			    add hl, bc         ; Increment HL to point to start of data block 
110a			    add hl, de         ; HL = HL + DE (total size) 
110a			    ld bc, 1           ; Number of bytes to allocate for management overhead 
110a			    add hl, bc         ; Add management overhead to start of data block 
110a			 
110a			    ; Save pointer to allocated block in HL 
110a			if DEBUG_FORTH_MALLOC_HIGH 
110a						DMARK "ma5" 
110a			call malloc_guard_exit 
110a			call malloc_guard_zerolen 
110a			endif 
110a			    ret 
110a			 
110a			malloc_skip_block_check: 
110a			    ; Move to the next block 
110a			    ld bc, 3           ; Size of management overhead 
110a			    add hl, bc         ; Move to the next block 
110a			    inc de             ; Increment counter 
110a			 
110a			    ; Check if we have reached the end of heap 
110a			    ld a, e            ; Load low byte of heap end address 
110a			    cp (hl)            ; Compare with low byte of current address 
110a			    jr nz, malloc_search_loop  ; If not equal, continue searching 
110a			    ld a, d            ; Load high byte of heap end address 
110a			;    cp 0               ; Check if it's zero (end of memory) 
110a				or a 
110a			    jr nz, malloc_search_loop  ; If not zero, continue searching 
110a			 
110a			    ; If we reached here, allocation failed 
110a			    xor a              ; Set result to NULL 
110a			if DEBUG_FORTH_MALLOC_HIGH 
110a						DMARK "ma6" 
110a			call malloc_guard_exit 
110a			call malloc_guard_zerolen 
110a			endif 
110a			    ret 
110a			malloc_exit: 
110a			if DEBUG_FORTH_MALLOC_HIGH 
110a						DMARK "ma7" 
110a			call malloc_guard_exit 
110a			call malloc_guard_zerolen 
110a			endif 
110a			    ret 
110a			 
110a			; Internal Free Function: 
110a			; Input: 
110a			;   HL: Pointer to memory block to free 
110a			; Output: 
110a			;   None 
110a			 
110a			free_internal: 
110a			    ld de, (heap_start) ; Load start of heap into DE 
110a			    ld bc, 0            ; Initialize counter 
110a			 
110a			free_search_loop: 
110a			    ; Check if current block contains the pointer 
110a			    ld a, l             ; Load low byte of pointer 
110a			    cp (hl+1)           ; Compare with high byte of current block's address 
110a			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
110a			    ld a, h             ; Load high byte of pointer 
110a			    cp (hl+2)           ; Compare with low byte of current block's address 
110a			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
110a			 
110a			    ; Mark block as free 
110a			    ld (hl), 0          ; Set status byte to indicate free block 
110a			    ret                 ; Return 
110a			 
110a			free_skip_block_check: 
110a			    ; Move to the next block 
110a			    ld bc, 3            ; Size of management overhead 
110a			    add hl, bc          ; Move to the next block 
110a			    inc de              ; Increment counter 
110a			 
110a			    ; Check if we have reached the end of heap 
110a			    ld a, e             ; Load low byte of heap end address 
110a			    cp (hl)             ; Compare with low byte of current address 
110a			    jr nz, free_search_loop  ; If not equal, continue searching 
110a			    ld a, d             ; Load high byte of heap end address 
110a			;    cp 0                ; Check if it's zero (end of memory) 
110a				or a 
110a			    jr nz, free_search_loop  ; If not zero, continue searching 
110a			 
110a			    ; If we reached here, pointer is not found in heap 
110a			    ret 
110a			 
110a			free_exit: 
110a			    ret                 ; Return 
110a			 
110a			; Define heap start and end addresses 
110a			;heap_start:    .dw 0xC000   ; Start of heap 
110a			;heap_end:      .dw 0xE000   ; End of heap 
110a			 
110a			endif 
