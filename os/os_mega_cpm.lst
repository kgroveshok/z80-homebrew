4296			; var handler 
4296			 
4296			 
4296			.VARS: 
4296				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
4296 77				db WORD_SYS_CORE+99             
4297 0e 43			dw .V0            
4299 04				db 3 + 1 
429a .. 00			db "VAR",0              
429e				endm 
# End of macro CWHEAD
429e			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
429e			; | 
429e			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
429e			; | |  
429e			; | | e.g. 
429e			; | |         #30 a var ! 
429e			; | |         a var @ . 
429e			; | |   
429e			; | |     Displays the number 30 
429e			; | | 
429e			; | | Each variable pointer is a word so can use for any words that use that:  
429e			; | |  
429e			; | | e.g. 
429e			; | |  
429e			; | |         #30 a var 2! 
429e			; | |         a var 2@ . 
429e			; | |   
429e			; | |     Displays the number 30 
429e			; | |  
429e			; | | > [!NOTE]  
429e			; ! | > If a full string is passed then only the first char is looked at 
429e			; | | > Any other char could exceed bounds checks!  
429e			; | | > 
429e			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
429e			 
429e					if DEBUG_FORTH_WORDS_KEY 
429e						DMARK "VAR" 
429e				if DEMARK_VERSION = 1  
429e e5					push hl  
429f 21 a7 42				ld hl, .dmark  
42a2 22 5e ee				ld (debug_mark), hl  
42a5				endif  
42a5				if DEMARK_VERSION = 0  
42a5					push af  
42a5					ld a, (.dmark)  
42a5					ld (debug_mark),a  
42a5					ld a, (.dmark+1)  
42a5					ld (debug_mark+1),a  
42a5					ld a, (.dmark+2)  
42a5					ld (debug_mark+2),a  
42a5				endif  
42a5 18 03			jr .pastdmark  
42a7 ..			.dmark: db "VAR"  
42aa				if DEMARK_VERSION = 1  
42aa e1			.pastdmark: pop hl  
42ab				endif  
42ab				if DEMARK_VERSION = 0  
42ab			.pastdmark: pop af  
42ab				endif  
42ab			endm  
# End of macro DMARK
42ab						CALLMONITOR 
42ab				if BASE_CPM=1  
42ab cd 6b ee				call debug_vector  
42ae				endif  
42ae				if BASE_KEV=1  
42ae					rst 8  
42ae				endif  
42ae				endm  
# End of macro CALLMONITOR
42ae					endif 
42ae			 
42ae					FORTH_DSP_VALUEHL 
42ae				if BASE_CPM=1 
42ae cd 21 1a			call macro_dsp_valuehl 
42b1				endif 
42b1				if BASE_KEV=1 
42b1					rst $18 
42b1				endif 
42b1				endm 
# End of macro FORTH_DSP_VALUEHL
