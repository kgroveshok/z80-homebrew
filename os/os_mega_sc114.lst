8fb7				pop de 
8fb7				pop hl 
8fb7			 
8fb7			 
8fb7				push de 
8fb7				call storage_create 
8fb7				; id in hl 
8fb7				pop de   ; table of strings to add 
8fb7			 
8fb7			.genloop: 
8fb7			 
8fb7				push hl ; save id for next time around 
8fb7				push de ; save de for next time around 
8fb7			 
8fb7				ex de, hl 
8fb7				call loadwordinhl 
8fb7				ex de, hl 
8fb7			 
8fb7				; need hl to be the id 
8fb7				; need de to be the string ptr 
8fb7				 
8fb7				call storage_append 
8fb7			 
8fb7				pop de 
8fb7				pop hl 
8fb7			 
8fb7				inc de 
8fb7				inc de 
8fb7			 
8fb7				ld a,(de) 
8fb7				cp 0 
8fb7				jr nz, .genloop 
8fb7				inc de 
8fb7				ld a, (de) 
8fb7				dec de 
8fb7				cp 0 
8fb7				jr nz, .genloop	 
8fb7			 
8fb7				ret 
