d543 f7				rst $30 
d544			 
d544			 
d544 0e 02			ld c, 2 
d546				;ld de, .cls 
d546 3e 5b			ld a, '[' 
d548 f7				rst $30 
d549 0e 02			ld c, 2 
d54b				;ld de, .cls 
d54b 3e 32			ld a, '2' 
d54d f7				rst $30 
d54e 0e 02			ld c, 2 
d550				;ld de, .cls 
d550 3e 4a			ld a, 'J' 
d552 f7				rst $30 
d553 d1				pop de 
d554 c1				pop bc 
d555 e1				pop hl 
d556			 
d556			 
d556 22 be eb		        ld (display_write_tmp), hl 	  
d559 3e 00			ld a, kLCD_Line1 
d55b			        ;    CALL fLCD_Pos       ;Position cursor to location in A 
d55b 06 28			ld b, display_cols 
d55d ed 5b be eb		ld de, (display_write_tmp) 
d561 cd bf d5			call write_len_string 
d564				 
