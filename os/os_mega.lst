10b7			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
10b7			 
10b7			; String Length 
10b7			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
10b7			 
10b7			; Get the length of the null-terminated string starting at $8000 hl 
10b7			;    LD     HL, $8000 
10b7			 
10b7			strlenz: 
10b7			 
10b7 af			    XOR    A               ; Zero is the value we are looking for. 
10b8 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
10b9 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
10ba			                           ; 65, 536 bytes (the entire addressable memory space). 
10ba ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10bc			 
10bc			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10bc 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
10bd 6f			    LD     L, A             ; number of bytes 
10be ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10c0 2b			    DEC    HL              ; Compensate for null. 
10c1 c9				ret 
10c2			 
10c2			; Get the length of the A terminated string starting at $8000 hl 
10c2			;    LD     HL, $8000 
10c2			 
10c2			strlent: 
10c2			 
10c2			                  ; A is the value we are looking for. 
10c2 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10c4 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10c6			                           ; 65, 536 bytes (the entire addressable memory space). 
10c6 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10c8			 
10c8			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10c8 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10ca 2e 00		    LD     L, 0             ; number of bytes 
10cc ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10ce 2b			    DEC    HL              ; Compensate for null. 
10cf c9				ret 
10d0			 
10d0			 
10d0			;Comparing Strings 
10d0			 
10d0			;IN    HL     Address of string1. 
10d0			;      DE     Address of string2. 
10d0			 
10d0			; doc given but wrong??? 
10d0			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
10d0			;      carry  Set if string1 > string2, reset if string1 <= string2. 
10d0			; tested 
10d0			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
10d0			 
10d0			strcmp_old: 
10d0 e5			    PUSH   HL 
10d1 d5			    PUSH   DE 
10d2			 
10d2 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
10d3 be			    CP     (HL)            ; (want to minimize work). 
10d4 38 01		    JR     C, Str1IsBigger 
10d6 7e			    LD     A, (HL) 
10d7			 
10d7			Str1IsBigger: 
10d7 4f			    LD     C, A             ; Put length in BC 
10d8 06 00		    LD     B, 0 
10da 13			    INC    DE              ; Increment pointers to meat of string. 
10db 23			    INC    HL 
10dc			 
10dc			CmpLoop: 
10dc 1a			    LD     A, (DE)          ; Compare bytes. 
10dd ed a1		    CPI 
10df 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
10e1 13			    INC    DE              ; Update pointer. 
10e2 ea dc 10		    JP     PE, CmpLoop 
10e5			 
10e5 d1			    POP    DE 
10e6 e1			    POP    HL 
10e7 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
10e8 be			    CP     (HL) 
10e9 c9			    RET 
10ea			 
10ea			NoMatch: 
10ea 2b			    DEC    HL 
10eb be			    CP     (HL)            ; Compare again to affect carry. 
10ec d1			    POP    DE 
10ed e1			    POP    HL 
10ee c9			    RET 
