0ab6			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
0ab6			; random number generators 
0ab6			 
0ab6			 
0ab6			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0ab6			 
0ab6			 
0ab6			;-----> Generate a random number 
0ab6			; output a=answer 0<=a<=255 
0ab6			; all registers are preserved except: af 
0ab6			random: 
0ab6 e5			        push    hl 
0ab7 d5			        push    de 
0ab8 2a a0 eb		        ld      hl,(randData) 
0abb ed 5f		        ld      a,r 
0abd 57			        ld      d,a 
0abe 5e			        ld      e,(hl) 
0abf 19			        add     hl,de 
0ac0 85			        add     a,l 
0ac1 ac			        xor     h 
0ac2 22 a0 eb		        ld      (randData),hl 
0ac5 d1			        pop     de 
0ac6 e1			        pop     hl 
0ac7 c9			        ret 
0ac8			 
0ac8			 
0ac8			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0ac8			 
0ac8			 
0ac8			 
0ac8			;------LFSR------ 
0ac8			;James Montelongo 
0ac8			;optimized by Spencer Putt 
0ac8			;out: 
0ac8			; a = 8 bit random number 
0ac8			RandLFSR: 
0ac8 21 a6 eb		        ld hl,LFSRSeed+4 
0acb 5e			        ld e,(hl) 
0acc 23			        inc hl 
0acd 56			        ld d,(hl) 
0ace 23			        inc hl 
0acf 4e			        ld c,(hl) 
0ad0 23			        inc hl 
0ad1 7e			        ld a,(hl) 
0ad2 47			        ld b,a 
0ad3 cb 13		        rl e  
0ad5 cb 12			rl d 
0ad7 cb 11		        rl c  
0ad9 17				rla 
0ada cb 13		        rl e  
0adc cb 12			rl d 
0ade cb 11		        rl c  
0ae0 17				rla 
0ae1 cb 13		        rl e  
0ae3 cb 12			rl d 
0ae5 cb 11		        rl c  
0ae7 17				rla 
0ae8 67			        ld h,a 
0ae9 cb 13		        rl e  
0aeb cb 12			rl d 
0aed cb 11		        rl c  
0aef 17				rla 
0af0 a8			        xor b 
0af1 cb 13		        rl e  
0af3 cb 12			rl d 
0af5 ac			        xor h 
0af6 a9			        xor c 
0af7 aa			        xor d 
0af8 21 a8 eb		        ld hl,LFSRSeed+6 
0afb 11 a9 eb		        ld de,LFSRSeed+7 
0afe 01 07 00		        ld bc,7 
0b01 ed b8		        lddr 
0b03 12			        ld (de),a 
0b04 c9			        ret 
0b05			 
0b05			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0b05			 
0b05			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0b05			 
0b05			 
0b05			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0b05			 
0b05			prng16: 
0b05			;Inputs: 
0b05			;   (seed1) contains a 16-bit seed value 
0b05			;   (seed2) contains a NON-ZERO 16-bit seed value 
0b05			;Outputs: 
0b05			;   HL is the result 
0b05			;   BC is the result of the LCG, so not that great of quality 
0b05			;   DE is preserved 
0b05			;Destroys: 
0b05			;   AF 
0b05			;cycle: 4,294,901,760 (almost 4.3 billion) 
0b05			;160cc 
0b05			;26 bytes 
0b05 2a 9a eb		    ld hl,(seed1) 
0b08 44			    ld b,h 
0b09 4d			    ld c,l 
0b0a 29			    add hl,hl 
0b0b 29			    add hl,hl 
0b0c 2c			    inc l 
0b0d 09			    add hl,bc 
0b0e 22 9a eb		    ld (seed1),hl 
0b11 2a 98 eb		    ld hl,(seed2) 
0b14 29			    add hl,hl 
0b15 9f			    sbc a,a 
0b16 e6 2d		    and %00101101 
0b18 ad			    xor l 
0b19 6f			    ld l,a 
0b1a 22 98 eb		    ld (seed2),hl 
0b1d 09			    add hl,bc 
0b1e c9			    ret 
0b1f			 
0b1f			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0b1f			 
0b1f			rand32: 
0b1f			;Inputs: 
0b1f			;   (seed1_0) holds the lower 16 bits of the first seed 
0b1f			;   (seed1_1) holds the upper 16 bits of the first seed 
0b1f			;   (seed2_0) holds the lower 16 bits of the second seed 
0b1f			;   (seed2_1) holds the upper 16 bits of the second seed 
0b1f			;   **NOTE: seed2 must be non-zero 
0b1f			;Outputs: 
0b1f			;   HL is the result 
0b1f			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0b1f			;Destroys: 
0b1f			;   AF 
0b1f			;Tested and passes all CAcert tests 
0b1f			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0b1f			;it has a period of 18,446,744,069,414,584,320 
0b1f			;roughly 18.4 quintillion. 
0b1f			;LFSR taps: 0,2,6,7  = 11000101 
0b1f			;291cc 
0b1f			;seed1_0=$+1 
0b1f			;    ld hl,12345 
0b1f			;seed1_1=$+1 
0b1f			;    ld de,6789 
0b1f			;    ld b,h 
0b1f			;    ld c,l 
0b1f			;    add hl,hl \ rl e \ rl d 
0b1f			;    add hl,hl \ rl e \ rl d 
0b1f			;    inc l 
0b1f			;    add hl,bc 
0b1f			;    ld (seed1_0),hl 
0b1f			;    ld hl,(seed1_1) 
0b1f			;    adc hl,de 
0b1f			;    ld (seed1_1),hl 
0b1f			;    ex de,hl 
0b1f			;seed2_0=$+1 
0b1f			;    ld hl,9876 
0b1f			;seed2_1=$+1 
0b1f			;    ld bc,54321 
0b1f			;    add hl,hl \ rl c \ rl b 
0b1f			;    ld (seed2_1),bc 
0b1f			;    sbc a,a 
0b1f			;    and %11000101 
0b1f			;    xor l 
0b1f			;    ld l,a 
0b1f			;    ld (seed2_0),hl 
0b1f			;    ex de,hl 
0b1f			;    add hl,bc 
0b1f			;    ret 
0b1f			; 
0b1f			 
0b1f			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0b1f			; 20 bytes, 86 cycles (excluding ret) 
0b1f			 
0b1f			; returns   hl = pseudorandom number 
0b1f			; corrupts   a 
0b1f			 
0b1f			; generates 16-bit pseudorandom numbers with a period of 65535 
0b1f			; using the xorshift method: 
0b1f			 
0b1f			; hl ^= hl << 7 
0b1f			; hl ^= hl >> 9 
0b1f			; hl ^= hl << 8 
0b1f			 
0b1f			; some alternative shift triplets which also perform well are: 
0b1f			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0b1f			 
0b1f			;  org 32768 
0b1f			 
0b1f			xrnd: 
0b1f 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
0b22 3e 00		  ld a,0 
0b24 bd			  cp l 
0b25 20 02		  jr nz, .xrnd1 
0b27 2e 01		  ld l, 1 
0b29			.xrnd1: 
0b29			 
0b29 7c			  ld a,h 
0b2a 1f			  rra 
0b2b 7d			  ld a,l 
0b2c 1f			  rra 
0b2d ac			  xor h 
0b2e 67			  ld h,a 
0b2f 7d			  ld a,l 
0b30 1f			  rra 
0b31 7c			  ld a,h 
0b32 1f			  rra 
0b33 ad			  xor l 
0b34 6f			  ld l,a 
0b35 ac			  xor h 
0b36 67			  ld h,a 
0b37			 
0b37 22 9e eb		  ld (xrandc),hl 
0b3a			 
0b3a c9			  ret 
