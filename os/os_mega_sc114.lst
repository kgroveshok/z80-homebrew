89de			; 
89de			; Multiply 16-bit values (with 32-bit result) 
89de			; In: Multiply BC with DE 
89de			; Out: BCHL = result 
89de			; 
89de			Mult32: 
89de 79			    ld a,c 
89df 48			    ld c,b 
89e0 21 00 00		    ld hl,0 
89e3 06 10		    ld b,16 
89e5			Mult32_Loop: 
89e5 29			    add hl,hl 
89e6 17			    rla 
89e7 cb 11		    rl c 
89e9 30 07		    jr nc,Mult32_NoAdd 
89eb 19			    add hl,de 
89ec ce 00		    adc a,0 
89ee d2 f2 89		    jp nc,Mult32_NoAdd 
89f1 0c			    inc c 
89f2			Mult32_NoAdd: 
89f2 10 f1		    djnz Mult32_Loop 
89f4 41			    ld b,c 
89f5 4f			    ld c,a 
89f6 c9			    ret 
