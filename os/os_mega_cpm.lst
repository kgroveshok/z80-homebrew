0f9c			;      halt 
0f9c			 
0f9c			 
0f9c			;------------------------------------------------------------------------------ 
0f9c			;     heap_init                                                               : 
0f9c			;                                                                             : 
0f9c			; Description                                                                 : 
0f9c			;     Initialise the heap and make it ready for malloc and free operations.   : 
0f9c			;                                                                             : 
0f9c			;     The heap is maintained as a linked list, starting with an initial       : 
0f9c			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
0f9c			;     the first free block in the heap. Each block then points to the next    : 
0f9c			;     free block within the heap, and the free list ends at the first block   : 
0f9c			;     with a null pointer to the next free block.                             : 
0f9c			;                                                                             : 
0f9c			; Parameters                                                                  : 
0f9c			;     Inputs are compile-time only. Two defines which specify the starting    : 
0f9c			;     address of the heap and its size are required, along with a memory      : 
0f9c			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
0f9c			;     principally stores a pointer to the first free block in the heap.       : 
0f9c			;                                                                             : 
0f9c			; Returns                                                                     : 
0f9c			;     Nothing                                                                 : 
0f9c			;------------------------------------------------------------------------------ 
0f9c			heap_init: 
0f9c e5			      push  HL 
0f9d			 
0f9d			      ; Initialise free list struct 
0f9d 21 25 5c		      ld    HL, heap_start 
0fa0 22 20 5c		      ld    (free_list), HL 
0fa3 21 00 00		      ld    HL, 0 
0fa6 22 22 5c		      ld    (free_list+2), HL 
0fa9			 
0fa9			      ; Insert first free block at bottom of heap, consumes entire heap 
0fa9 21 79 e2		      ld    HL, heap_start+heap_size-4 
0fac 22 25 5c		      ld    (heap_start), HL        ; Next block (end of free list) 
0faf 21 54 86		      ld    HL, heap_size-4 
0fb2 22 27 5c		      ld    (heap_start+2), HL      ; Block size 
0fb5			 
0fb5			      ; Insert end of free list block at top of heap - two null words will 
0fb5			      ; terminate the free list 
0fb5 21 00 00		      ld    HL, 0 
0fb8 22 7b e2		      ld    (heap_start+heap_size-2), HL 
0fbb 22 79 e2		      ld    (heap_start+heap_size-4), HL 
0fbe			 
0fbe e1			      pop   HL 
0fbf			 
0fbf c9			      ret 
