a731					ld (debug_mark+1),a  
a731					ld a, (.dmark+2)  
a731					ld (debug_mark+2),a  
a731				endif  
a731 18 04			jr .pastdmark  
a733 ..			.dmark: db "SCR"  
a736				if DEMARK_VERSION = 1  
