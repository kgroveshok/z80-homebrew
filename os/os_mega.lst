1014			;      NOTE: This isn't necessarily the same as the input HL. 
1014 d5			  push de 
1015 c5			  push bc 
1016 f5			  push af 
1017 eb			  ex de,hl 
1018			 
1018 01 f0 d8		  ld bc,-10000 
101b 3e 2f		  ld a,'0'-1 
101d 3c			  inc a 
101e 09			  add hl,bc  
101f 38 fc		   jr c,$-2 
1021 12			  ld (de),a 
1022 13			  inc de 
1023			 
1023 01 e8 03		  ld bc,1000 
1026 3e 3a		  ld a,'9'+1 
1028 3d			  dec a  
1029 09			  add hl,bc  
102a 30 fc		   jr nc,$-2 
102c 12			  ld (de),a 
102d 13			  inc de 
102e			 
102e 01 9c ff		  ld bc,-100 
1031 3e 2f		  ld a,'0'-1 
1033 3c			  inc a  
1034 09			  add hl,bc  
1035 38 fc		   jr c,$-2 
1037 12			  ld (de),a 
1038 13			  inc de 
1039			 
1039 7d			  ld a,l 
103a 26 3a		  ld h,'9'+1 
103c 25			  dec h  
103d c6 0a		  add a,10  
103f 30 fb		   jr nc,$-3 
1041 c6 30		  add a,'0' 
1043 eb			  ex de,hl 
1044 72			  ld (hl),d 
1045 23			  inc hl 
1046 77			  ld (hl),a 
1047 23			  inc hl 
1048 36 00		  ld (hl),0 
104a			 
104a			;Now strip the leading zeros 
104a 0e fa		  ld c,-6 
104c 09			  add hl,bc 
104d 3e 30		  ld a,'0' 
104f 23			  inc hl  
1050 be			  cp (hl)  
1051 28 fc		  jr z,$-2 
1053			 
1053			;Make sure that the string is non-empty! 
1053 7e			  ld a,(hl) 
1054 b7			  or a 
1055 20 01		  jr nz,.atoub 
1057 2b			  dec hl 
1058			.atoub: 
1058			 
