00d2				endif  
00d2			  
00d2				; lcd test sequence  
00d2					  
00d2 cd 6f 0b			call update_display  
00d5 cd 76 0a			call delay1s  
00d8 3e 2b			ld a,'+'  
00da cd 3c 0b			call fill_display  
00dd cd 6f 0b			call update_display  
00e0 cd 76 0a			call delay1s  
00e3 3e 2a			ld a,'*'  
00e5 cd 3c 0b			call fill_display  
00e8 cd 6f 0b			call update_display  
00eb cd 76 0a			call delay1s  
00ee 3e 2d			ld a,'-'  
00f0 cd 3c 0b			call fill_display  
00f3 cd 6f 0b			call update_display  
00f6 cd 76 0a			call delay1s  
00f9			  
00f9			; boot splash screen  
00f9			if display_cols == 20	  
00f9			        ld a, display_row_1    
00f9			else  
00f9 3e 0a		        ld a, display_row_1 +10   
00fb			endif  
00fb 11 b0 1b			ld de, prom_bootmsg  
00fe cd 49 0b			call str_at_display  
0101 cd 6f 0b			call update_display  
0104			  
0104			  
0104 cd 76 0a			call delay1s  
0107 cd 76 0a			call delay1s  
010a			if display_cols == 20	  
