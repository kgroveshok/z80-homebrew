0dc1			addatode: 
0dc1 83			    add   a, e    ; A = A+L 
0dc2 5f			    ld    e, a    ; L = A+L 
0dc3 8a			    adc   a, d    ; A = A+L+H+carry 
0dc4 93			    sub   e       ; A = H+carry 
0dc5 57			    ld    d, a    ; H = H+carry 
0dc6 c9			ret 
0dc7			 
0dc7			 
0dc7			addatobc: 
0dc7 81			    add   a, c    ; A = A+L 
0dc8 4f			    ld    c, a    ; L = A+L 
0dc9 88			    adc   a, b    ; A = A+L+H+carry 
0dca 91			    sub   c       ; A = H+carry 
0dcb 47			    ld    b, a    ; H = H+carry 
0dcc c9			ret 
