9d95 15				db WORD_SYS_CORE+OPCODE_HEAP             
9d96 af 9d			dw .HEAP            
9d98 04				db 3 + 1 
9d99 .. 00			db "NEW",0              
9d9d				endm 
# End of macro CWHEAD
9d9d			; | NEW ( -- ) Clears all user words and stack | DONE 
9d9d				 
9d9d				if MALLOC_4 
9d9d					call  heap_init 
9d9d				endif 
9d9d				; reset uword pointers 
9d9d 21 37 d6			ld hl, baseram 
9da0 22 a2 e5			ld (os_last_new_uword), hl 
