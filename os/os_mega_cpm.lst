115e				ld hl, crs_s1 
115e				ld de, .lsworddef 
115e				call .genfile 
115e				ret 
115e			 
115e			.genedword: 
115e				ld de, .edworddef 
115e				ld hl, crs_s2 
115e				call .genfile 
115e				ret 
115e			 
115e			.gendemword: 
115e				ld de, .demoworddef 
115e				ld hl, crs_s3 
115e				call .genfile 
115e				ret 
