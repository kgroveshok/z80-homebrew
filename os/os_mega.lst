2bdc			; | SCRATCH ( u -- addr ) Pushes address of offset u to stack | DONE 
2bdc			; | | The scratch area provides 32 word array. Can be used as single byte or as a word by passing the offset on stack. Pushes the resulting address to stack.  
2bdc			; | | When used with the direct storage writing/malloc and the !@ or word versions it is possible to construct an expanded and flexible variable system 
2bdc			; | |  
2bdc			; | | e.g.    : score $00 scratch ; 
2bdc			; | |  
2bdc			; | | $00 score ! 
2bdc			; | | $01 score +! 
2bdc			; | |  
2bdc			; | | e.g.   : varword $0a scratch ;  
2bdc			; | | 
2bdc			; | | $8000 varword ! 
2bdc					if DEBUG_FORTH_WORDS_KEY 
2bdc						DMARK "SCR" 
2bdc				if DEMARK_VERSION = 1  
2bdc e5					push hl  
2bdd 21 e5 2b				ld hl, .dmark  
2be0 22 9b fd				ld (debug_mark), hl  
2be3				endif  
2be3				if DEMARK_VERSION = 0  
2be3					push af  
2be3					ld a, (.dmark)  
2be3					ld (debug_mark),a  
2be3					ld a, (.dmark+1)  
2be3					ld (debug_mark+1),a  
2be3					ld a, (.dmark+2)  
2be3					ld (debug_mark+2),a  
2be3				endif  
2be3 18 04			jr .pastdmark  
2be5 ..			.dmark: db "SCR"  
2be8				if DEMARK_VERSION = 1  
2be8 00					db 0  
2be9				endif  
2be9				if DEMARK_VERSION = 1  
