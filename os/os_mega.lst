68f7			  
68f7			; **********************************************************************  
68f7			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
68f7			; **********************************************************************  
68f7			;  
68f7			; **  Written as a Small Computer Monitor App   
68f7			; **  Version 0.1 SCC 2018-05-16  
68f7			; **  www.scc.me.uk  
68f7			;  
68f7			; **********************************************************************  
68f7			;  
68f7			; This module provides support for alphanumeric LCD modules using with  
68f7			; *  HD44780 (or compatible) controller  
68f7			; *  5 x 7 pixel fonts  
68f7			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
68f7			; *  Interface via six digital outputs to the display (see below)  
68f7			;  
68f7			; LCD module pinout:  
68f7			;   1  Vss   0v supply  
68f7			;   2  Vdd   5v supply  
68f7			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
68f7			;   4  RS    High = data, Low = instruction  
68f7			;   5  R/W   High = Read, Low = Write  
68f7			;   6  E     Enable signal (active high)  
68f7			;   7  DB0   Data bit 0  
68f7			;   8  DB1   Data bit 1  
68f7			;   9  DB2   Data bit 2  
68f7			;  10  DB3   Data bit 3  
68f7			;  11  DB4   Data bit 4  
68f7			;  12  DB5   Data bit 5  
68f7			;  13  DB6   Data bit 6  
68f7			;  14  DB7   Data bit 7  
68f7			;  15  A     Backlight anode (+)  
68f7			;  16  K     Backlight cathode (-)  
68f7			;  
68f7			; This interfacing method uses 4-bit data mode and uses time delays  
68f7			; rather than polling the display's ready status. As a result the   
68f7			; interface only requires 6 simple output lines:  
68f7			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
68f7			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
68f7			;   LCD DB4 = Microcomputer output port bit 4  
68f7			;   LCD DB5 = Microcomputer output port bit 5  
68f7			;   LCD DB6 = Microcomputer output port bit 6  
68f7			;   LCD DB7 = Microcomputer output port bit 7  
68f7			; Display's R/W is connected to 0v so it is always in write mode  
68f7			; All 6 connections must be on the same port address <kLCDPrt>  
68f7			; This method also allows a decent length of cable from micro to LCD  
68f7			;  
68f7			; **********************************************************************  
68f7			;  
68f7			; To include the code for any given function provided by this module,   
68f7			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
68f7			; the parent source file.  
68f7			; For example:  #REQUIRES   uHexPrefix  
68f7			;  
68f7			; Also #INCLUDE this file at some point after the #REQUIRES statements  
68f7			; in the parent source file.  
68f7			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
68f7			;  
68f7			; These are the function names provided by this module:  
68f7			; fLCD_Init                     ;Initialise LCD  
68f7			; fLCD_Inst                     ;Send instruction to LCD  
68f7			; fLCD_Data                     ;Send data byte to LCD  
68f7			; fLCD_Pos                      ;Position cursor  
68f7			; fLCD_Str                      ;Display string  
68f7			; fLCD_Def                      ;Define custom character  
68f7			;  
68f7			; **********************************************************************  
68f7			;  
68f7			; Requires SCMonAPI.asm to also be included in the project  
68f7			;  
68f7			  
68f7			  
68f7			; **********************************************************************  
68f7			; **  Constants  
68f7			; **********************************************************************  
68f7			  
68f7			; Constants that must be defined externally  
68f7			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
68f7			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
68f7			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
68f7			;kLCDWidth: EQU 20             ;Width in characters  
68f7			  
68f7			; general line offsets in any frame buffer  
68f7			  
68f7			  
68f7			display_row_1: equ 0  
68f7			display_row_2: equ display_row_1+display_cols  
68f7			display_row_3: equ display_row_2 + display_cols  
68f7			display_row_4: equ display_row_3 + display_cols  
68f7			;display_row_4_eol:   
68f7			  
68f7			  
68f7			; Cursor position values for the start of each line  
68f7			  
68f7			; E  
68f7			kLCD_Line1: EQU 0x00   
68f7			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
68f7			; E1  
68f7			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
68f7			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
68f7			  
68f7			; Instructions to send as A register to fLCD_Inst  
68f7			kLCD_Clear: EQU 00000001b     ;LCD clear  
68f7			kLCD_Off:   EQU 00001000b     ;LCD off  
68f7			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
68f7			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
68f7			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
68f7			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
68f7			  
68f7			; Constants used by this code module  
68f7			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
68f7			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
68f7			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
68f7			  
68f7			  
68f7			  
68f7			; **********************************************************************  
68f7			; **  LCD support functions  
68f7			; **********************************************************************  
68f7			  
68f7			; Initialise alphanumeric LCD module  
68f7			; LCD control register codes:  
68f7			;   DL   0 = 4-bit mode        1 = 8-bit mode  
68f7			;   N    0 = 1-line mode       1 = 2-line mode  
68f7			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
68f7			;   D    0 = Display off       1 = Display on  
68f7			;   C    0 = Cursor off        1 = Cursor on  
68f7			;   B    0 = Blinking off      1 = Blinking on  
68f7			;   ID   0 = Decrement mode    1 = Increment mode  
68f7			;   SH   0 = Entire shift off  1 = Entire shift on  
68f7 3e 28		fLCD_Init:  LD   A, 40  
68f9 cd 1e 6a		            CALL LCDDelay       ;Delay 40ms after power up  
68fc			; For reliable reset set 8-bit mode - 3 times  
68fc cd ee 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68ff cd ee 69		            CALL WrFn8bit       ;Function = 8-bit mode  
6902 cd ee 69		            CALL WrFn8bit       ;Function = 8-bit mode  
6905			; Set 4-bit mode  
6905 cd ea 69		            CALL WrFn4bit       ;Function = 4-bit mode  
6908 cd 1c 6a		            CALL LCDDelay1      ;Delay 37 us or more  
690b			; Function set  
690b 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
690d cd 20 69		            CALL fLCD_Inst      ;2 line, display on  
6910			; Display On/Off control  
6910 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6912 cd 20 69		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6915			; Display Clear  
6915 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6917 cd 20 69		            CALL fLCD_Inst      ;Clear display  
691a			; Entry mode  
691a 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
691c cd 20 69		            CALL fLCD_Inst      ;Increment mode, shift off  
691f			; Display module now initialised  
691f c9			            RET  
6920			; ok to here  
6920			  
6920			; Write instruction to LCD  
6920			;   On entry: A = Instruction byte to be written  
6920			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6920 f5			fLCD_Inst:  PUSH AF  
6921 f5			            PUSH AF  
6922 cd 34 69		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6925 f1			            POP  AF  
6926 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6927 17			            RLA  
6928 17			            RLA  
6929 17			            RLA  
692a cd 34 69		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
692d 3e 02		            LD   A, 2  
692f cd 1e 6a		            CALL LCDDelay       ;Delay 2 ms to complete   
6932 f1			            POP  AF  
6933 c9			            RET  
6934			Wr4bits:   
6934 f5					push af  
6935 3a fb fa				ld a, (display_lcde1e2)  
6938 fe 00				cp 0     ; e  
693a 20 10				jr nz, .wea2	  
693c f1					pop af  
693d e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
693f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6941 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6943 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6945 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6947 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6949 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
694b c9			            RET  
694c f1			.wea2:		pop af  
694d e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
694f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6951 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6953 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6955 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6957 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6959 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
695b c9			            RET  
695c			  
695c			  
695c			; Write data to LCD  
695c			;   On entry: A = Data byte to be written  
695c			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
695c f5			fLCD_Data:  PUSH AF  
695d f5			            PUSH AF  
695e cd 70 69		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6961 f1			            POP  AF  
6962 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6963 17			            RLA  
6964 17			            RLA  
6965 17			            RLA  
6966 cd 70 69		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6969 3e 96		            LD   A, 150  
696b 3d			Wait:      DEC  A              ;Wait a while to allow data   
696c 20 fd		            JR   NZ, Wait      ;  write to complete  
696e f1			            POP  AF  
696f c9			            RET  
6970			Wr4bitsa:     
6970 f5					push af  
6971 3a fb fa				ld a, (display_lcde1e2)  
6974 fe 00				cp 0     ; e1  
6976 20 16				jr nz, .we2	  
6978 f1					pop af  
6979 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
697b cb d7		            SET  kLCDBitRS, A  
697d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
697f cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6981 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6983 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6985 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6987 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6989 cb 97		            RES  kLCDBitRS, A  
698b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
698d c9			            RET  
698e f1			.we2:		pop af  
698f e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6991 cb d7		            SET  kLCDBitRS, A  
6993 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6995 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6997 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6999 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
699b cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
699d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
699f cb 97		            RES  kLCDBitRS, A  
69a1 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69a3 c9			            RET  
