11ad			config_fdir: 
11ad				; using the scratch dir go through and release the memory allocated for each string 
11ad				 
11ad				ld hl, scratch 
11ad			.cfdir:	ld e,(hl) 
11ad				inc hl 
11ad				ld d,(hl) 
11ad				inc hl 
11ad			 
11ad				ex de, hl 
11ad				call ishlzero 
11ad				ret z     ; return on null pointer 
11ad				call free 
11ad				ex de, hl 
11ad				jr .cfdir 
11ad			 
11ad			 
11ad				ret 
11ad			 
11ad			 
11ad			config_dir: 
11ad			 
11ad				; for the config menus that need to build a directory of storage call this routine 
11ad				; it will construct a menu in scratch to pass to menu 
11ad			 
11ad				; open storage device 
11ad			 
11ad				; execute DIR to build a list of files and their ids into scratch in menu format 
11ad				; once the menu has finished then will need to call config_fdir to release the strings 
11ad				 
11ad				; c = number items 
11ad			 
11ad				 
11ad				call storage_get_block_0 
11ad			 
11ad				ld hl, store_page     ; get current id count 
11ad				ld b, (hl) 
11ad				ld c, 0    ; count of files   
11ad			 
11ad			 
11ad				ld hl, scratch 
11ad				ld (store_tmp2), hl    ; location to poke strings 
11ad			 
11ad				; check for empty drive 
11ad			 
11ad				ld a, 0 
11ad				cp b 
11ad				jp z, .dirdone 
11ad			 
11ad				 
11ad					if DEBUG_FORTH_WORDS 
11ad						DMARK "Cdc" 
11ad						CALLMONITOR 
11ad					endif 
11ad			 
11ad			 
11ad			.diritem:	 
11ad				push bc 
11ad				; for each of the current ids do a search for them and if found push to stack 
11ad			 
11ad					ld hl, STORE_BLOCK_PHY 
11ad					ld d, 0		 ; look for extent 0 of block id as this contains file name 
11ad					ld e,b 
11ad			 
11ad					call storage_findnextid 
11ad			 
11ad			 
11ad					; if found hl will be non zero 
11ad			 
11ad					call ishlzero 
11ad					jr z, .dirnotfound 
11ad			 
11ad					; increase count 
11ad			 
11ad					pop bc	 
11ad					inc c 
11ad					push bc 
11ad					 
11ad			 
11ad					; get file header and push the file name 
11ad			 
11ad					ld de, store_page 
11ad					call storage_read_block 
11ad			 
11ad					; push file id to stack 
11ad				 
11ad					ld a, (store_page) 
11ad					ld h, 0 
11ad					ld l, a 
11ad			 
11ad					;call forth_push_numhl 
11ad					; TODO store id 
11ad			 
11ad					push hl 
11ad			 
11ad					; push extent count to stack  
11ad				 
11ad					ld hl, store_page+3 
11ad			 
11ad					; get file name length 
11ad			 
11ad					call strlenz   
11ad			 
11ad					inc hl   ; cover zero term 
11ad					inc hl  ; stick the id at the end of the area 
11ad			 
11ad					push hl 
11ad					pop bc    ; move length to bc 
11ad			 
11ad					call malloc 
11ad			 
11ad					; TODO save malloc area to scratch 
11ad			 
11ad					ex de, hl 
11ad					ld hl, (store_tmp2) 
11ad					ld (hl), e 
11ad					inc hl 
11ad					ld (hl), d 
11ad					inc hl 
11ad					ld (store_tmp2), hl 
11ad			 
11ad					 
11ad			 
11ad					;pop hl   ; get source 
11ad			;		ex de, hl    ; swap aronund	 
11ad			 
11ad					ld hl, store_page+3 
11ad					if DEBUG_FORTH_WORDS 
11ad						DMARK "CFd" 
11ad						CALLMONITOR 
11ad					endif 
11ad					ldir 
11ad			 
11ad					; de is past string, move back one and store id 
11ad					 
11ad					dec de 
11ad			 
11ad					; store file id 
11ad			 
11ad					pop hl 
11ad					ex de,hl 
11ad					ld (hl), e 
11ad			 
11ad					if DEBUG_FORTH_WORDS 
11ad						DMARK "Cdi" 
11ad						CALLMONITOR 
11ad					endif 
11ad					 
11ad			.dirnotfound: 
11ad					pop bc     
11ad					djnz .diritem 
11ad				 
11ad			.dirdone:	 
11ad			 
11ad			;		ld a, 0 
11ad					ld hl, (store_tmp2) 
11ad					ld (hl), 0 
11ad					inc hl 
11ad					ld (hl), 0 
11ad					inc hl 
11ad					; push a count of the dir items found 
11ad			 
11ad			;		ld h, 0 
11ad			;		ld l, c 
11ad			 
11ad				ret 
11ad			 
11ad			endif 
