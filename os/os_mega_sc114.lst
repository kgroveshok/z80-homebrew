9e50			; the core word dictionary v4 
9e50			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
9e50			 
9e50			; this is a linked list for each of the system words used 
9e50			; user defined words will follow the same format but will be in ram 
9e50			 
9e50			 
9e50			; 
9e50			; 
9e50			; define linked list: 
9e50			; 
9e50			; 1. compiled byte op code 
9e50			; 2. len of text word 
9e50			; 3. text word 
9e50			; 4. ptr to next dictionary word 
9e50			; 5. asm, calls etc for the word 
9e50			; 
9e50			;  if 1 == 0 then last word in dict  
9e50			;   
9e50			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
9e50			;  
9e50			;  
9e50			; create basic standard set of words 
9e50			; 
9e50			;  
9e50			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
9e50			; 2DUP 2DROP 2SWAP  
9e50			; @ C@ - get byte  
9e50			; ! C! - store byte 
9e50			; 0< true if less than zero 
9e50			; 0= true if zero 
9e50			; < >  
9e50			; = true if same 
9e50			; variables 
9e50			 
