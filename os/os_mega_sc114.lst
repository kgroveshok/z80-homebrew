8fd7			; Select storage bank 
8fd7			 
8fd7			.selbank: 
8fd7			 
8fd7			if STARTUP_V2 
8fd7			;	if STORAGE_SE 
8fd7			;	else 
8fd7			 
8fd7				ld hl, prom_banks 
8fd7				call menu 
8fd7				cp 0 
8fd7				ret z 
8fd7				 
8fd7				; set the bank number from the result 
8fd7			 
8fd7				 
8fd7					ld c, SPI_CE_HIGH 
8fd7					ld b, '0'    ; human readable bank number 
8fd7			 
8fd7			 
8fd7					; active low 
8fd7			 
8fd7			;		cp 0 
8fd7					or a 
8fd7					jr z, .bset 
8fd7					cp 1 
8fd7					jr nz, .b2 
8fd7					res 0, c 
8fd7					ld b, '1'    ; human readable bank number 
8fd7			.b2:		cp 2 
8fd7					jr nz, .b3 
8fd7					res 1, c 
8fd7					ld b, '2'    ; human readable bank number 
8fd7			.b3:		cp 3 
8fd7					jr nz, .b4 
8fd7					res 2, c 
8fd7					ld b, '3'    ; human readable bank number 
8fd7			.b4:		cp 4 
8fd7					jr nz, .b5 
8fd7					res 3, c 
8fd7					ld b, '4'    ; human readable bank number 
8fd7			.b5:		cp 5 
8fd7					jr nz, .bset 
8fd7					res 4, c 
8fd7					ld b, '5'    ; human readable bank number 
