0c50			;-----> Generate a random number 
0c50			; output a=answer 0<=a<=255 
0c50			; all registers are preserved except: af 
0c50			random: 
0c50 e5			        push    hl 
0c51 d5			        push    de 
0c52 2a db fa		        ld      hl,(randData) 
0c55 ed 5f		        ld      a,r 
0c57 57			        ld      d,a 
0c58 5e			        ld      e,(hl) 
0c59 19			        add     hl,de 
0c5a 85			        add     a,l 
0c5b ac			        xor     h 
0c5c 22 db fa		        ld      (randData),hl 
0c5f d1			        pop     de 
0c60 e1			        pop     hl 
0c61 c9			        ret 
