10f2			;Number in a to decimal ASCII 
10f2			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
10f2			;Example: display a=56 as "056" 
10f2			;input: a = number 
10f2			;Output: a=0,value of a in the screen 
10f2			;destroys af,bc (don't know about hl and de) 
10f2			DispAToASCII: 
10f2 0e 9c			ld	c,-100 
10f4 cd fe 10			call	.Na1 
10f7 0e f6			ld	c,-10 
10f9 cd fe 10			call	.Na1 
10fc 0e ff			ld	c,-1 
10fe 06 2f		.Na1:	ld	b,'0'-1 
1100 04			.Na2:	inc	b 
1101 81				add	a,c 
1102 38 fc			jr	c,.Na2 
1104 91				sub	c		;works as add 100/10/1 
1105 f5				push af		;safer than ld c,a 
1106 78				ld	a,b		;char is in b 
1107			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
