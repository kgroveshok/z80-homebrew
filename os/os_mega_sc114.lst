# End of macro CWHEAD
a1d0			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a1d0			; | | At start the current various registers will be displayed with contents. 
a1d0			; | | Top right corner will show the most recent debug marker seen. 
a1d0			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a1d0			; | | and the return stack pointer (RSP). 
a1d0			; | | Pressing: 
a1d0			; | |  
a1d0			; | |    1 - Initial screen 
a1d0			; | |  
a1d0			; | |    2 - Display a data dump of HL 
a1d0			; | |  
a1d0			; | |    3 - Display a data dump of DE 
a1d0			; | |  
a1d0			; | |    4 - Display a data dump of BC 
a1d0			; | |  
a1d0			; | |    5 - Display a data dump of HL 
a1d0			; | |  
a1d0			; | |    6 - Display a data dump of DSP 
a1d0			; | |  
a1d0			; | |    7 - Display a data dump of RSP 
a1d0			; | |  
a1d0			; | |    8 - Display a data dump of what is at DSP 
a1d0			; | |  
a1d0			; | |    9 - Display a data dump of what is at RSP 
a1d0			; | |  
a1d0			; | |    0 - Exit monitor and continue running. This will also enable break points 
a1d0			; | |  
a1d0			; | |    * - Disable break points 
a1d0			; | |  
a1d0			; | |    # - Enter traditional monitor mode 
a1d0			; | |  
a1d0			; | | 
a1d0			; | | Monitor Mode 
a1d0			; | | ------------ 
a1d0			; | | A prompt of '>' will be shown for various commands: 
a1d0			; | |  
a1d0			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a1d0			; | |  
a1d0			; | |    C - Continue display a data dump from the last set address 
a1d0			; | |  
a1d0			; | |    M xxxx - Set start of memory edit at address xx 
a1d0			; | |  
a1d0			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a1d0			; | |  
a1d0			; | |    G xxxx - Exec code at specific address 
a1d0			; | |  
a1d0			; | |    Q - Return to previous 
a1d0				if DEBUG_FORTH_WORDS_KEY 
a1d0					DMARK "MON" 
a1d0				if DEMARK_VERSION = 1  
a1d0 e5					push hl  
a1d1 21 d9 a1				ld hl, .dmark  
a1d4 22 60 ee				ld (debug_mark), hl  
a1d7				endif  
a1d7				if DEMARK_VERSION = 0  
a1d7					push af  
a1d7					ld a, (.dmark)  
a1d7					ld (debug_mark),a  
a1d7					ld a, (.dmark+1)  
a1d7					ld (debug_mark+1),a  
a1d7					ld a, (.dmark+2)  
a1d7					ld (debug_mark+2),a  
a1d7				endif  
a1d7 18 04			jr .pastdmark  
a1d9 ..			.dmark: db "MON"  
a1dc				if DEMARK_VERSION = 1  
a1dc 00					db 0  
a1dd				endif  
a1dd				if DEMARK_VERSION = 1  
a1dd e1			.pastdmark: pop hl  
a1de				endif  
a1de				if DEMARK_VERSION = 0  
a1de			.pastdmark: pop af  
a1de				endif  
a1de			endm  
# End of macro DMARK
