0f52			; Z80 Malloc and Free Functions 
0f52			 
0f52			; Malloc Function: 
0f52			; Input: 
0f52			;   HL: Size of block to allocate 
0f52			; Output: 
0f52			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
0f52			 
0f52			malloc: 
0f52				 
0f52			if DEBUG_FORTH_MALLOC_HIGH 
0f52			call malloc_guard_entry 
0f52			endif 
0f52			 
0f52			 
0f52			 
0f52			 
0f52					if DEBUG_FORTH_MALLOC 
0f52						DMARK "mal" 
0f52						CALLMONITOR 
0f52					endif 
0f52			    push af            ; Save AF register 
0f52			    ld a, l            ; Load low byte of size into A 
0f52			    or h               ; Check if size is zero 
0f52			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
0f52			 
0f52			    ; Allocate memory 
0f52			    ld hl, (heap_start) ; Load start of heap into HL 
0f52					if DEBUG_FORTH_MALLOC 
0f52						DMARK "ma1" 
0f52						CALLMONITOR 
0f52					endif 
0f52			    call malloc_internal ; Call internal malloc function 
0f52			    pop af             ; Restore AF register 
0f52			if DEBUG_FORTH_MALLOC_HIGH 
0f52			call malloc_guard_exit 
0f52			call malloc_guard_zerolen 
0f52			endif 
0f52			    ret                ; Return 
0f52			 
0f52			; Free Function: 
0f52			; Input: 
0f52			;   HL: Pointer to memory block to free 
0f52			; Output: 
0f52			;   None 
0f52			 
0f52			free: 
0f52			    push af            ; Save AF register 
0f52			    ld a, l            ; Load low byte of pointer into A 
0f52			    or h               ; Check if pointer is NULL 
0f52			    jp z, free_exit    ; If pointer is NULL, exit 
0f52			 
0f52			    ; Free memory 
0f52			    ld hl, (heap_start) ; Load start of heap into HL 
0f52			    call free_internal  ; Call internal free function 
0f52			    pop af             ; Restore AF register 
0f52			    ret                ; Return 
0f52			 
0f52			; Internal Malloc Function: 
0f52			; Input: 
0f52			;   HL: Size of block to allocate 
0f52			; Output: 
0f52			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
0f52			 
0f52			malloc_internal: 
0f52			    ld bc, 2           ; Number of bytes to allocate for management overhead 
0f52			    add hl, bc         ; Add management overhead to requested size 
0f52			    ex de, hl          ; Save total size in DE, and keep it in HL 
0f52					if DEBUG_FORTH_MALLOC 
0f52						DMARK "ma2" 
0f52						CALLMONITOR 
0f52					endif 
0f52			 
0f52			    ; Search for free memory block 
0f52			    ld de, (heap_end)  ; Load end of heap into DE 
0f52			    ld bc, 0           ; Initialize counter 
0f52			 
0f52					if DEBUG_FORTH_MALLOC 
0f52						DMARK "ma2" 
0f52						CALLMONITOR 
0f52					endif 
0f52			malloc_search_loop: 
0f52			    ; Check if current block is free 
0f52			    ld a, (hl)         ; Load current block's status (free or used) 
0f52			;    cp 0               ; Compare with zero (free) 
0f52				or a 
0f52			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
0f52			 
0f52			    ; Check if current block is large enough 
0f52			    ld a, (hl+1)       ; Load high byte of block size 
0f52			    cp l               ; Compare with low byte of requested size 
0f52			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
0f52			 
0f52			    ld a, (hl+2)       ; Load low byte of block size 
0f52			    cp h               ; Compare with high byte of requested size 
0f52			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
0f52			 
0f52			    ; Mark block as used 
0f52			    ld (hl), 0xFF      ; Set status byte to indicate used block 
0f52			 
0f52			    ; Calculate remaining space in block 
0f52			    ld bc, 0           ; Clear BC 
0f52			    add hl, bc         ; Increment HL to point to start of data block 
0f52			    add hl, de         ; HL = HL + DE (total size) 
0f52			    ld bc, 1           ; Number of bytes to allocate for management overhead 
0f52			    add hl, bc         ; Add management overhead to start of data block 
0f52			 
0f52			    ; Save pointer to allocated block in HL 
0f52			if DEBUG_FORTH_MALLOC_HIGH 
0f52						DMARK "ma5" 
0f52			call malloc_guard_exit 
0f52			call malloc_guard_zerolen 
0f52			endif 
0f52			    ret 
0f52			 
0f52			malloc_skip_block_check: 
0f52			    ; Move to the next block 
0f52			    ld bc, 3           ; Size of management overhead 
0f52			    add hl, bc         ; Move to the next block 
0f52			    inc de             ; Increment counter 
0f52			 
0f52			    ; Check if we have reached the end of heap 
0f52			    ld a, e            ; Load low byte of heap end address 
0f52			    cp (hl)            ; Compare with low byte of current address 
0f52			    jr nz, malloc_search_loop  ; If not equal, continue searching 
0f52			    ld a, d            ; Load high byte of heap end address 
0f52			;    cp 0               ; Check if it's zero (end of memory) 
0f52				or a 
0f52			    jr nz, malloc_search_loop  ; If not zero, continue searching 
0f52			 
0f52			    ; If we reached here, allocation failed 
0f52			    xor a              ; Set result to NULL 
0f52			if DEBUG_FORTH_MALLOC_HIGH 
0f52						DMARK "ma6" 
0f52			call malloc_guard_exit 
0f52			call malloc_guard_zerolen 
0f52			endif 
0f52			    ret 
0f52			malloc_exit: 
0f52			if DEBUG_FORTH_MALLOC_HIGH 
0f52						DMARK "ma7" 
0f52			call malloc_guard_exit 
0f52			call malloc_guard_zerolen 
0f52			endif 
0f52			    ret 
0f52			 
0f52			; Internal Free Function: 
0f52			; Input: 
0f52			;   HL: Pointer to memory block to free 
0f52			; Output: 
0f52			;   None 
0f52			 
0f52			free_internal: 
0f52			    ld de, (heap_start) ; Load start of heap into DE 
0f52			    ld bc, 0            ; Initialize counter 
0f52			 
0f52			free_search_loop: 
0f52			    ; Check if current block contains the pointer 
0f52			    ld a, l             ; Load low byte of pointer 
0f52			    cp (hl+1)           ; Compare with high byte of current block's address 
0f52			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
0f52			    ld a, h             ; Load high byte of pointer 
0f52			    cp (hl+2)           ; Compare with low byte of current block's address 
0f52			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
0f52			 
0f52			    ; Mark block as free 
0f52			    ld (hl), 0          ; Set status byte to indicate free block 
0f52			    ret                 ; Return 
0f52			 
0f52			free_skip_block_check: 
0f52			    ; Move to the next block 
0f52			    ld bc, 3            ; Size of management overhead 
0f52			    add hl, bc          ; Move to the next block 
0f52			    inc de              ; Increment counter 
0f52			 
0f52			    ; Check if we have reached the end of heap 
0f52			    ld a, e             ; Load low byte of heap end address 
0f52			    cp (hl)             ; Compare with low byte of current address 
0f52			    jr nz, free_search_loop  ; If not equal, continue searching 
0f52			    ld a, d             ; Load high byte of heap end address 
0f52			;    cp 0                ; Check if it's zero (end of memory) 
0f52				or a 
0f52			    jr nz, free_search_loop  ; If not zero, continue searching 
0f52			 
0f52			    ; If we reached here, pointer is not found in heap 
0f52			    ret 
0f52			 
0f52			free_exit: 
0f52			    ret                 ; Return 
0f52			 
