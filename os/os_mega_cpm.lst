1192			config_fdir: 
1192				; using the scratch dir go through and release the memory allocated for each string 
1192				 
1192				ld hl, scratch 
1192			.cfdir:	ld e,(hl) 
1192				inc hl 
1192				ld d,(hl) 
1192				inc hl 
1192			 
1192				ex de, hl 
1192				call ishlzero 
1192				ret z     ; return on null pointer 
1192				call free 
1192				ex de, hl 
1192				jr .cfdir 
1192			 
1192			 
1192				ret 
1192			 
1192			 
1192			config_dir: 
1192			 
1192				; for the config menus that need to build a directory of storage call this routine 
1192				; it will construct a menu in scratch to pass to menu 
1192			 
1192				; open storage device 
1192			 
1192				; execute DIR to build a list of files and their ids into scratch in menu format 
1192				; once the menu has finished then will need to call config_fdir to release the strings 
1192				 
1192				; c = number items 
1192			 
1192				 
1192				call storage_get_block_0 
1192			 
1192				ld hl, store_page     ; get current id count 
1192				ld b, (hl) 
1192				ld c, 0    ; count of files   
1192			 
1192			 
1192				ld hl, scratch 
1192				ld (store_tmp2), hl    ; location to poke strings 
1192			 
1192				; check for empty drive 
1192			 
1192				ld a, 0 
1192				cp b 
1192				jp z, .dirdone 
1192			 
1192				 
1192					if DEBUG_FORTH_WORDS 
1192						DMARK "Cdc" 
1192						CALLMONITOR 
1192					endif 
1192			 
1192			 
1192			.diritem:	 
1192				push bc 
1192				; for each of the current ids do a search for them and if found push to stack 
1192			 
1192					ld hl, STORE_BLOCK_PHY 
1192					ld d, 0		 ; look for extent 0 of block id as this contains file name 
1192					ld e,b 
1192			 
1192					call storage_findnextid 
1192			 
1192			 
1192					; if found hl will be non zero 
1192			 
1192					call ishlzero 
1192					jr z, .dirnotfound 
1192			 
1192					; increase count 
1192			 
1192					pop bc	 
1192					inc c 
1192					push bc 
1192					 
1192			 
1192					; get file header and push the file name 
1192			 
1192					ld de, store_page 
1192					call storage_read_block 
1192			 
1192					; push file id to stack 
1192				 
1192					ld a, (store_page) 
1192					ld h, 0 
1192					ld l, a 
1192			 
1192					;call forth_push_numhl 
1192					; TODO store id 
1192			 
1192					push hl 
1192			 
1192					; push extent count to stack  
1192				 
1192					ld hl, store_page+3 
1192			 
1192					; get file name length 
1192			 
1192					call strlenz   
1192			 
1192					inc hl   ; cover zero term 
1192					inc hl  ; stick the id at the end of the area 
1192			 
1192					push hl 
1192					pop bc    ; move length to bc 
1192			 
1192					call malloc 
1192			 
1192					; TODO save malloc area to scratch 
1192			 
1192					ex de, hl 
1192					ld hl, (store_tmp2) 
1192					ld (hl), e 
1192					inc hl 
1192					ld (hl), d 
1192					inc hl 
1192					ld (store_tmp2), hl 
1192			 
1192					 
1192			 
1192					;pop hl   ; get source 
1192			;		ex de, hl    ; swap aronund	 
1192			 
1192					ld hl, store_page+3 
1192					if DEBUG_FORTH_WORDS 
1192						DMARK "CFd" 
1192						CALLMONITOR 
1192					endif 
1192					ldir 
1192			 
1192					; de is past string, move back one and store id 
1192					 
1192					dec de 
1192			 
1192					; store file id 
1192			 
1192					pop hl 
1192					ex de,hl 
1192					ld (hl), e 
1192			 
1192					if DEBUG_FORTH_WORDS 
1192						DMARK "Cdi" 
1192						CALLMONITOR 
1192					endif 
1192					 
1192			.dirnotfound: 
1192					pop bc     
1192					djnz .diritem 
1192				 
1192			.dirdone:	 
1192			 
1192			;		ld a, 0 
1192					ld hl, (store_tmp2) 
1192					ld (hl), 0 
1192					inc hl 
1192					ld (hl), 0 
1192					inc hl 
1192					; push a count of the dir items found 
1192			 
1192			;		ld h, 0 
1192			;		ld l, c 
1192			 
1192				ret 
1192			 
1192			endif 
