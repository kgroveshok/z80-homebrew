748c			; handle the auto run of code from files in storage 
748c			 
748c			 
748c			include "forth_startup.asm" 
748c			; Which startup method to use? 
748c			; 
748c			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
748c			; followed by loading of a list of scripts in eeprom 
748c			 
748c			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
748c			; from eeprom 
748c			 
748c			; Select with define in main stubs 
748c			 
748c			if STARTUP_V1 
748c				include "forth_startupv1.asm" 
748c			endif 
748c			if STARTUP_V2 
748c				include "forth_startupv2.asm" 
748c			; Version 2 of the startup  
748c			;  
748c			; Auto load any files in bank 1 that start with a '*' 
748c			; If no se storage then revert to using eprom 
748c			 
748c			 
748c			if STORAGE_SE = 0 
748c			 
748c			sprompt1: db "Startup load...",0 
748c			sprompt2: db "Run? 1=No *=End #=All",0 
748c			 
748c			 
748c			 
748c			 
748c			forth_startup: 
748c				ld hl, startcmds 
748c				ld a, 0 
748c				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
748c			 
748c			.start1:	push hl 
748c				call clear_display 
748c				ld de, sprompt1 
748c			        ld a, display_row_1 
748c				call str_at_display 
748c				ld de, sprompt2 
748c			        ld a, display_row_2 
748c				call str_at_display 
748c				pop hl 
748c				push hl 
748c				ld e,(hl) 
748c				inc hl 
748c				ld d,(hl) 
748c			        ld a, display_row_3 
748c				call str_at_display 
748c				call update_display 
748c			 
748c			 
748c				ld a, (os_last_cmd) 
748c			;	cp 0 
748c				or a 
748c				jr z, .startprompt 
748c				call delay250ms 
748c				jr .startdo 
748c				 
748c				 
748c			 
748c			.startprompt: 
748c			 
748c				ld a,display_row_4 + display_cols - 1 
748c			        ld de, endprg 
748c				call str_at_display 
748c				call update_display 
748c				call delay1s 
748c				call cin_wait 
748c						 
748c				cp '*' 
748c				jr z, .startupend1 
748c				cp '#' 
748c				jr nz, .startno 
748c				ld a, 1 
748c				ld (os_last_cmd),a 
748c				jr .startdo 
748c			.startno:	cp '1' 
748c				jr z,.startnxt  
748c			 
748c				; exec startup line 
748c			.startdo:	 
748c				pop hl 
748c				push hl 
748c				 
748c				ld e,(hl) 
748c				inc hl 
748c				ld d,(hl) 
748c				ex de,hl 
748c			 
748c				push hl 
748c			 
748c				ld a, 0 
748c				;ld a, FORTH_END_BUFFER 
748c				call strlent 
748c				inc hl   ; include zero term to copy 
748c				ld b,0 
748c				ld c,l 
748c				pop hl 
748c				ld de, scratch 
748c				ldir 
748c			 
748c			 
748c				ld hl, scratch 
748c				call forthparse 
748c				call forthexec 
748c				call forthexec_cleanup 
748c			 
748c				ld a, display_row_4 
748c				ld de, endprog 
748c			 
748c				call update_display		 
748c			 
748c				ld a, (os_last_cmd) 
748c			;	cp 0 
748c				or a 
748c				jr nz, .startnxt 
