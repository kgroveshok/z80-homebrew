91b8 dd 66 03		      ld    H, (IX+3) 
91bb 23			      inc   HL 
91bc 23			      inc   HL 
91bd 5e			      ld    E, (HL) 
91be 23			      inc   HL 
91bf 56			      ld    D, (HL) 
91c0			 
91c0 e1			      pop   HL                      ; Add sizes of both blocks 
91c1 19			      add   HL, DE 
91c2 eb			      ex    DE, HL 
91c3			 
