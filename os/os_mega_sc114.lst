8e03			;malloc: 
8e03			; 
8e03			;	SAVESP ON 1 
8e03			; 
8e03			;	call malloc_code 
8e03			; 
8e03			;	CHECKSP ON 1 
8e03			;	ret 
8e03			 
8e03			 
8e03			malloc: 
8e03 c5			      push  BC 
8e04 d5			      push  DE 
8e05 dd e5		      push  IX 
8e07			if DEBUG_FORTH_MALLOC_HIGH 
8e07			call malloc_guard_entry 
8e07			endif 
8e07			 
8e07					if DEBUG_FORTH_MALLOC 
8e07						DMARK "mal" 
8e07						CALLMONITOR 
8e07					endif 
8e07 7c			      ld    A, H                    ; Exit if no space requested 
8e08 b5			      or    L 
8e09 ca c8 8e		      jp    Z, malloc_early_exit 
8e0c			 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			; 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			;inc hl 
8e0c			 
8e0c			 
8e0c			 
8e0c			 
8e0c					if DEBUG_FORTH_MALLOC 
8e0c						DMARK "maA" 
8e0c						CALLMONITOR 
8e0c					endif 
8e0c			      ; Set up stack frame 
8e0c eb			      ex    DE, HL 
8e0d 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8e10 39			      add   HL, SP 
8e11 f9			      ld    SP, HL 
8e12 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
8e16 dd 39		      add   IX, SP 
8e18			 
8e18			      ; Setup initial state 
8e18 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
8e1b 19			      add   HL, DE 
8e1c			 
8e1c 44			      ld    B, H                    ; Move want to BC 
8e1d 4d			      ld    C, L 
8e1e			 
8e1e 21 a9 d0		      ld    HL, free_list           ; Store prev_free ptr to stack 
8e21 dd 75 04		      ld    (IX+4), L 
8e24 dd 74 05		      ld    (IX+5), H 
8e27			 
8e27 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
8e28 23			      inc   HL 
8e29 56			      ld    D, (HL) 
8e2a dd 73 02		      ld    (IX+2), E 
8e2d dd 72 03		      ld    (IX+3), D 
8e30 eb			      ex    DE, HL                  ; this_free ptr into HL 
8e31			 
8e31					if DEBUG_FORTH_MALLOC 
8e31						DMARK "maB" 
8e31						CALLMONITOR 
8e31					endif 
8e31			      ; Loop through free block list to find some space 
8e31			malloc_find_space: 
8e31 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
8e32 23			      inc   HL 
8e33 56			      ld    D, (HL) 
8e34			 
8e34 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8e35 b3			      or    E 
8e36 ca c2 8e		      jp    Z, malloc_no_space 
8e39			 
8e39 dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
8e3c dd 72 01		      ld    (IX+1), D 
8e3f			 
8e3f			      ; Does this block have enough space to make the allocation? 
8e3f 23			      inc   HL                      ; Load free block size into DE 
8e40 5e			      ld    E, (HL) 
8e41 23			      inc   HL 
8e42 56			      ld    D, (HL) 
8e43			 
8e43 eb			      ex    DE, HL                  ; Check size of block against want 
8e44 b7			      or    A                       ; Ensure carry flag clear 
8e45 ed 42		      sbc   HL, BC 
8e47 e5			      push  HL                      ; Store the result for later (new block size) 
8e48			 
8e48 ca 97 8e		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8e4b 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8e4d			 
8e4d			      ; this_free block is not big enough, setup ptrs to test next free block 
8e4d e1			      pop   HL                      ; Discard previous result 
8e4e			 
8e4e dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8e51 dd 66 03		      ld    H, (IX+3) 
8e54 dd 75 04		      ld    (IX+4), L 
8e57 dd 74 05		      ld    (IX+5), H 
8e5a			 
8e5a dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8e5d dd 66 01		      ld    H, (IX+1) 
8e60 dd 75 02		      ld    (IX+2), L 
8e63 dd 74 03		      ld    (IX+3), H 
8e66			 
8e66					if DEBUG_FORTH_MALLOC 
8e66						DMARK "MA>" 
8e66						CALLMONITOR 
8e66					endif 
8e66 18 c9		      jr    malloc_find_space 
8e68			 
8e68			      ; split a bigger block into two - requested size and remaining size 
8e68			malloc_alloc_split: 
8e68					if DEBUG_FORTH_MALLOC 
8e68						DMARK "MAs" 
8e68						CALLMONITOR 
8e68					endif 
8e68 eb			      ex    DE, HL                  ; Calculate address of new free block 
8e69 2b			      dec   HL 
8e6a 2b			      dec   HL 
8e6b 2b			      dec   HL 
8e6c 09			      add   HL, BC 
8e6d			 
8e6d			      ; Create a new block and point it at next_free 
8e6d dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
8e70 dd 56 01		      ld    D, (IX+1) 
8e73			 
8e73 73			      ld    (HL), E                 ; Store next_free ptr into new block 
8e74 23			      inc   HL 
8e75 72			      ld    (HL), D 
8e76			 
8e76 d1			      pop   DE                      ; Store size of new block into new block 
8e77 23			      inc   HL 
8e78 73			      ld    (HL), E 
8e79 23			      inc   HL 
8e7a 72			      ld    (HL), D 
8e7b			 
8e7b			      ; Update this_free ptr to point to new block 
8e7b 2b			      dec   HL 
8e7c 2b			      dec   HL 
8e7d 2b			      dec   HL 
8e7e			 
8e7e dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8e81 dd 56 03		      ld    D, (IX+3) 
8e84			 
8e84 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8e87 dd 74 03		      ld    (IX+3), H 
8e8a			 
8e8a			      ; Modify this_free block to be allocation 
8e8a eb			      ex    DE, HL 
8e8b af			      xor   A                       ; Null the next block ptr of allocated block 
8e8c 77			      ld    (HL), A 
8e8d 23			      inc   HL 
8e8e 77			      ld    (HL), A 
8e8f			 
8e8f 23			      inc   HL                      ; Store want size into allocated block 
8e90 71			      ld    (HL), C 
8e91 23			      inc   HL 
8e92 70			      ld    (HL), B 
8e93 23			      inc   HL 
8e94 e5			      push  HL                      ; Address of allocation to return 
8e95			 
8e95 18 19		      jr    malloc_update_links 
8e97			 
8e97			malloc_alloc_fit: 
8e97 e1			      pop   HL                      ; Dont need new block size, want is exact fit 
8e98			 
8e98					if DEBUG_FORTH_MALLOC 
8e98						DMARK "MAf" 
8e98						CALLMONITOR 
8e98					endif 
8e98			      ; Modify this_free block to be allocation 
8e98 eb			      ex    DE, HL 
8e99 2b			      dec   HL 
8e9a 2b			      dec   HL 
8e9b 2b			      dec   HL 
8e9c			 
8e9c af			      xor   A                       ; Null the next block ptr of allocated block 
8e9d 77			      ld    (HL), A 
8e9e 23			      inc   HL 
8e9f 77			      ld    (HL), A 
8ea0			 
8ea0 23			      inc   HL                      ; Store address of allocation to return 
8ea1 23			      inc   HL 
8ea2 23			      inc   HL 
8ea3 e5			      push  HL 
8ea4			 
8ea4			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8ea4 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
8ea7 dd 66 01		      ld    H, (IX+1) 
8eaa			 
8eaa dd 75 02		      ld    (IX+2), L               ; HL to this_free 
8ead dd 74 03		      ld    (IX+3), H 
8eb0			 
8eb0			 
8eb0			malloc_update_links: 
8eb0			      ; Update prev_free ptr to point to this_free 
8eb0 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
8eb3 dd 66 05		      ld    H, (IX+5) 
8eb6			 
8eb6 dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
8eb9 dd 56 03		      ld    D, (IX+3) 
8ebc			 
8ebc 73			      ld    (HL), E                 ; this_free ptr into prev_free 
8ebd 23			      inc   HL 
8ebe 72			      ld    (HL), D 
8ebf			 
8ebf					if DEBUG_FORTH_MALLOC 
8ebf						DMARK "Mul" 
8ebf						CALLMONITOR 
8ebf					endif 
8ebf			      ; Clear the Z flag to indicate successful allocation 
8ebf 7a			      ld    A, D 
8ec0 b3			      or    E 
8ec1			 
8ec1 d1			      pop   DE                      ; Address of allocation 
8ec2					if DEBUG_FORTH_MALLOC 
8ec2						DMARK "MAu" 
8ec2						CALLMONITOR 
8ec2					endif 
8ec2			 
8ec2			malloc_no_space: 
8ec2 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
8ec5 39			      add   HL, SP 
8ec6 f9			      ld    SP, HL 
8ec7			 
8ec7 eb			      ex    DE, HL                  ; Alloc addr into HL for return 
8ec8					if DEBUG_FORTH_MALLOC 
8ec8						DMARK "MAN" 
8ec8						CALLMONITOR 
8ec8					endif 
8ec8			 
8ec8			malloc_early_exit: 
8ec8					if DEBUG_FORTH_MALLOC 
8ec8						DMARK "MAx" 
8ec8						CALLMONITOR 
8ec8					endif 
8ec8 dd e1		      pop   IX 
8eca d1			      pop   DE 
8ecb c1			      pop   BC 
8ecc			 
8ecc			if DEBUG_FORTH_MALLOC_HIGH 
8ecc			call malloc_guard_exit 
8ecc			call malloc_guard_zerolen 
8ecc			endif 
8ecc c9			      ret 
8ecd			 
8ecd			 
8ecd			;------------------------------------------------------------------------------ 
8ecd			;     free                                                                    : 
8ecd			;                                                                             : 
8ecd			; Description                                                                 : 
8ecd			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8ecd			;     returned by malloc, otherwise the behaviour is undefined.               : 
8ecd			;                                                                             : 
8ecd			;     Where possible, directly adjacent free blocks will be merged together   : 
8ecd			;     into larger blocks to help ensure that the heap does not become         : 
8ecd			;     excessively fragmented.                                                 : 
8ecd			;                                                                             : 
8ecd			;     free does not clear or set any other value into the freed space, and    : 
8ecd			;     therefore its contents may be visible through subsequent malloc's. The  : 
8ecd			;     caller should clear the freed space as required.                        : 
8ecd			;                                                                             : 
8ecd			;     This implementation of free uses the stack exclusively, and is          : 
8ecd			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8ecd			;     advisable to disable interrupts before calling free, and recommended    : 
8ecd			;     to avoid the use of free inside ISRs in general.                        : 
8ecd			;                                                                             : 
8ecd			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8ecd			;                                                                             : 
8ecd			; Parameters                                                                  : 
8ecd			;     HL  Pointer to address of first byte of allocation to be freed          : 
8ecd			;                                                                             : 
8ecd			; Returns                                                                     : 
8ecd			;     Nothing                                                                 : 
8ecd			;                                                                             : 
8ecd			; Stack frame                                                                 : 
8ecd			;       |             |                                                       : 
8ecd			;       +-------------+                                                       : 
8ecd			;       |     BC      |                                                       : 
8ecd			;       +-------------+                                                       : 
8ecd			;       |     DE      |                                                       : 
8ecd			;       +-------------+                                                       : 
8ecd			;       |     IX      |                                                       : 
8ecd			;       +-------------+                                                       : 
8ecd			;       |  prev_free  |                                                       : 
8ecd			;   +2  +-------------+                                                       : 
8ecd			;       |  next_free  |                                                       : 
8ecd			;   +0  +-------------+                                                       : 
8ecd			;       |             |                                                       : 
8ecd			;                                                                             : 
8ecd			;------------------------------------------------------------------------------ 
8ecd			free: 
8ecd c5			      push  BC 
8ece d5			      push  DE 
8ecf dd e5		      push  IX 
8ed1			 
8ed1 7c			      ld    A, H                    ; Exit if ptr is null 
8ed2 b5			      or    L 
8ed3 ca 97 8f		      jp    Z, free_early_exit 
8ed6			 
8ed6			      ; Set up stack frame 
8ed6 eb			      ex    DE, HL 
8ed7 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8eda 39			      add   HL, SP 
8edb f9			      ld    SP, HL 
8edc dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
8ee0 dd 39		      add   IX, SP 
8ee2			 
8ee2			      ; The address in HL points to the start of the useable allocated space, 
8ee2			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8ee2			      ; address of the block itself. 
8ee2 eb			      ex    DE, HL 
8ee3 11 fc ff		      ld    DE, -4 
8ee6 19			      add   HL, DE 
8ee7			 
8ee7			      ; An allocated block must have a null next block pointer in it 
8ee7 7e			      ld    A, (HL) 
8ee8 23			      inc   HL 
8ee9 b6			      or    (HL) 
8eea c2 92 8f		      jp    NZ, free_done 
8eed			 
8eed 2b			      dec   HL 
8eee			 
8eee 44			      ld    B, H                    ; Copy HL to BC 
8eef 4d			      ld    C, L 
8ef0			 
8ef0			      ; Loop through the free list to find the first block with an address 
8ef0			      ; higher than the block being freed 
8ef0 21 a9 d0		      ld    HL, free_list 
8ef3			 
8ef3			free_find_higher_block: 
8ef3 5e			      ld    E, (HL)                 ; Load next ptr from free block 
8ef4 23			      inc   HL 
8ef5 56			      ld    D, (HL) 
8ef6 2b			      dec   HL 
8ef7			 
8ef7 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
8efa dd 72 01		      ld    (IX+1), D 
8efd dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
8f00 dd 74 03		      ld    (IX+3), H 
8f03			 
8f03 78			      ld    A, B                    ; Check if DE is greater than BC 
8f04 ba			      cp    D                       ; Compare MSB first 
8f05 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
8f07 30 04		      jr    NC, free_find_higher_block_skip 
8f09 79			      ld    A, C 
8f0a bb			      cp    E                       ; Then compare LSB 
8f0b 38 08		      jr    C, free_found_higher_block 
8f0d			 
8f0d			free_find_higher_block_skip: 
8f0d 7a			      ld    A, D                    ; Reached the end of the free list? 
8f0e b3			      or    E 
8f0f ca 92 8f		      jp    Z, free_done 
8f12			 
8f12 eb			      ex    DE, HL 
8f13			 
8f13 18 de		      jr    free_find_higher_block 
8f15			 
8f15			free_found_higher_block: 
8f15			      ; Insert freed block between prev and next free blocks 
8f15 71			      ld    (HL), C                 ; Point prev free block to freed block 
8f16 23			      inc   HL 
8f17 70			      ld    (HL), B 
8f18			 
8f18 60			      ld    H, B                    ; Point freed block at next free block 
8f19 69			      ld    L, C 
8f1a 73			      ld    (HL), E 
8f1b 23			      inc   HL 
8f1c 72			      ld    (HL), D 
8f1d			 
8f1d			      ; Check if the freed block is adjacent to the next free block 
8f1d 23			      inc   HL                      ; Load size of freed block into HL 
8f1e 5e			      ld    E, (HL) 
8f1f 23			      inc   HL 
8f20 56			      ld    D, (HL) 
8f21 eb			      ex    DE, HL 
8f22			 
8f22 09			      add   HL, BC                  ; Add addr of freed block and its size 
8f23			 
8f23 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
8f26 dd 56 01		      ld    D, (IX+1) 
8f29			 
8f29 b7			      or    A                       ; Clear the carry flag 
8f2a ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8f2c 20 22		      jr    NZ, free_check_adjacent_to_prev 
8f2e			 
8f2e			      ; Freed block is adjacent to next, merge into one bigger block 
8f2e eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
8f2f 5e			      ld    E, (HL) 
8f30 23			      inc   HL 
8f31 56			      ld    D, (HL) 
8f32 e5			      push  HL                      ; Save ptr to next block for later 
8f33			 
8f33 60			      ld    H, B                    ; Store ptr from next block into freed block 
8f34 69			      ld    L, C 
8f35 73			      ld    (HL), E 
8f36 23			      inc   HL 
8f37 72			      ld    (HL), D 
8f38			 
8f38 e1			      pop   HL                      ; Restore ptr to next block 
8f39 23			      inc   HL                      ; Load size of next block into DE 
8f3a 5e			      ld    E, (HL) 
8f3b 23			      inc   HL 
8f3c 56			      ld    D, (HL) 
8f3d d5			      push  DE                      ; Save next block size for later 
8f3e			 
8f3e 60			      ld    H, B                    ; Load size of freed block into HL 
8f3f 69			      ld    L, C 
8f40 23			      inc   HL 
8f41 23			      inc   HL 
8f42 5e			      ld    E, (HL) 
8f43 23			      inc   HL 
8f44 56			      ld    D, (HL) 
8f45 eb			      ex    DE, HL 
8f46			 
8f46 d1			      pop   DE                      ; Restore size of next block 
8f47 19			      add   HL, DE                  ; Add sizes of both blocks 
8f48 eb			      ex    DE, HL 
8f49			 
8f49 60			      ld    H, B                    ; Store new bigger size into freed block 
8f4a 69			      ld    L, C 
8f4b 23			      inc   HL 
8f4c 23			      inc   HL 
8f4d 73			      ld    (HL), E 
8f4e 23			      inc   HL 
8f4f 72			      ld    (HL), D 
8f50			 
8f50			free_check_adjacent_to_prev: 
8f50			      ; Check if the freed block is adjacent to the prev free block 
8f50 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
8f53 dd 66 03		      ld    H, (IX+3) 
8f56			 
8f56 23			      inc   HL                      ; Size of prev free block into DE 
8f57 23			      inc   HL 
8f58 5e			      ld    E, (HL) 
8f59 23			      inc   HL 
8f5a 56			      ld    D, (HL) 
8f5b 2b			      dec   HL 
8f5c 2b			      dec   HL 
8f5d 2b			      dec   HL 
8f5e			 
8f5e 19			      add   HL, DE                  ; Add prev block addr and size 
8f5f			 
8f5f b7			      or    A                       ; Clear the carry flag 
8f60 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8f62 20 2e		      jr    NZ, free_done 
8f64			 
8f64			      ; Freed block is adjacent to prev, merge into one bigger block 
8f64 60			      ld    H, B                    ; Load next ptr from freed block into DE 
8f65 69			      ld    L, C 
8f66 5e			      ld    E, (HL) 
8f67 23			      inc   HL 
8f68 56			      ld    D, (HL) 
8f69 e5			      push  HL                      ; Save freed block ptr for later 
8f6a			 
8f6a dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8f6d dd 66 03		      ld    H, (IX+3) 
8f70 73			      ld    (HL), E 
8f71 23			      inc   HL 
8f72 72			      ld    (HL), D 
8f73			 
8f73 e1			      pop   HL                      ; Restore freed block ptr 
8f74 23			      inc   HL                      ; Load size of freed block into DE 
8f75 5e			      ld    E, (HL) 
8f76 23			      inc   HL 
8f77 56			      ld    D, (HL) 
8f78 d5			      push  DE                      ; Save freed block size for later 
8f79			 
8f79 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
8f7c dd 66 03		      ld    H, (IX+3) 
8f7f 23			      inc   HL 
8f80 23			      inc   HL 
8f81 5e			      ld    E, (HL) 
8f82 23			      inc   HL 
8f83 56			      ld    D, (HL) 
8f84			 
8f84 e1			      pop   HL                      ; Add sizes of both blocks 
8f85 19			      add   HL, DE 
8f86 eb			      ex    DE, HL 
8f87			 
8f87 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
8f8a dd 66 03		      ld    H, (IX+3) 
8f8d 23			      inc   HL 
8f8e 23			      inc   HL 
8f8f 73			      ld    (HL), E 
8f90 23			      inc   HL 
8f91 72			      ld    (HL), D 
8f92			 
8f92			free_done: 
8f92 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
8f95 39			      add   HL, SP 
8f96 f9			      ld    SP, HL 
8f97			 
8f97			free_early_exit: 
8f97 dd e1		      pop   IX 
8f99 d1			      pop   DE 
8f9a c1			      pop   BC 
8f9b			 
8f9b c9			      ret 
