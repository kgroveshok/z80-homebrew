0c55			;-----> Generate a random number 
0c55			; output a=answer 0<=a<=255 
0c55			; all registers are preserved except: af 
0c55			random: 
0c55 e5			        push    hl 
0c56 d5			        push    de 
0c57 2a db fa		        ld      hl,(randData) 
0c5a ed 5f		        ld      a,r 
0c5c 57			        ld      d,a 
0c5d 5e			        ld      e,(hl) 
0c5e 19			        add     hl,de 
0c5f 85			        add     a,l 
0c60 ac			        xor     h 
0c61 22 db fa		        ld      (randData),hl 
0c64 d1			        pop     de 
0c65 e1			        pop     hl 
0c66 c9			        ret 
0c67			 
0c67			 
0c67			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0c67			 
0c67			 
0c67			 
0c67			;------LFSR------ 
0c67			;James Montelongo 
0c67			;optimized by Spencer Putt 
0c67			;out: 
0c67			; a = 8 bit random number 
0c67			RandLFSR: 
0c67 21 e1 fa		        ld hl,LFSRSeed+4 
0c6a 5e			        ld e,(hl) 
0c6b 23			        inc hl 
0c6c 56			        ld d,(hl) 
0c6d 23			        inc hl 
0c6e 4e			        ld c,(hl) 
0c6f 23			        inc hl 
0c70 7e			        ld a,(hl) 
0c71 47			        ld b,a 
0c72 cb 13		        rl e  
0c74 cb 12			rl d 
0c76 cb 11		        rl c  
0c78 17				rla 
0c79 cb 13		        rl e  
0c7b cb 12			rl d 
0c7d cb 11		        rl c  
0c7f 17				rla 
0c80 cb 13		        rl e  
0c82 cb 12			rl d 
0c84 cb 11		        rl c  
0c86 17				rla 
0c87 67			        ld h,a 
0c88 cb 13		        rl e  
0c8a cb 12			rl d 
0c8c cb 11		        rl c  
0c8e 17				rla 
0c8f a8			        xor b 
0c90 cb 13		        rl e  
0c92 cb 12			rl d 
0c94 ac			        xor h 
0c95 a9			        xor c 
0c96 aa			        xor d 
0c97 21 e3 fa		        ld hl,LFSRSeed+6 
0c9a 11 e4 fa		        ld de,LFSRSeed+7 
0c9d 01 07 00		        ld bc,7 
0ca0 ed b8		        lddr 
0ca2 12			        ld (de),a 
0ca3 c9			        ret 
0ca4			 
0ca4			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0ca4			 
0ca4			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0ca4			 
0ca4			 
0ca4			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0ca4			 
0ca4			prng16: 
0ca4			;Inputs: 
0ca4			;   (seed1) contains a 16-bit seed value 
0ca4			;   (seed2) contains a NON-ZERO 16-bit seed value 
0ca4			;Outputs: 
0ca4			;   HL is the result 
0ca4			;   BC is the result of the LCG, so not that great of quality 
0ca4			;   DE is preserved 
0ca4			;Destroys: 
0ca4			;   AF 
0ca4			;cycle: 4,294,901,760 (almost 4.3 billion) 
0ca4			;160cc 
0ca4			;26 bytes 
0ca4 2a d5 fa		    ld hl,(seed1) 
0ca7 44			    ld b,h 
0ca8 4d			    ld c,l 
0ca9 29			    add hl,hl 
0caa 29			    add hl,hl 
0cab 2c			    inc l 
0cac 09			    add hl,bc 
0cad 22 d5 fa		    ld (seed1),hl 
0cb0 2a d3 fa		    ld hl,(seed2) 
0cb3 29			    add hl,hl 
0cb4 9f			    sbc a,a 
0cb5 e6 2d		    and %00101101 
0cb7 ad			    xor l 
0cb8 6f			    ld l,a 
0cb9 22 d3 fa		    ld (seed2),hl 
0cbc 09			    add hl,bc 
0cbd c9			    ret 
0cbe			 
0cbe			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0cbe			 
0cbe			rand32: 
0cbe			;Inputs: 
0cbe			;   (seed1_0) holds the lower 16 bits of the first seed 
0cbe			;   (seed1_1) holds the upper 16 bits of the first seed 
0cbe			;   (seed2_0) holds the lower 16 bits of the second seed 
0cbe			;   (seed2_1) holds the upper 16 bits of the second seed 
0cbe			;   **NOTE: seed2 must be non-zero 
0cbe			;Outputs: 
0cbe			;   HL is the result 
0cbe			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0cbe			;Destroys: 
0cbe			;   AF 
0cbe			;Tested and passes all CAcert tests 
0cbe			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0cbe			;it has a period of 18,446,744,069,414,584,320 
0cbe			;roughly 18.4 quintillion. 
0cbe			;LFSR taps: 0,2,6,7  = 11000101 
0cbe			;291cc 
0cbe			;seed1_0=$+1 
0cbe			;    ld hl,12345 
0cbe			;seed1_1=$+1 
0cbe			;    ld de,6789 
0cbe			;    ld b,h 
0cbe			;    ld c,l 
0cbe			;    add hl,hl \ rl e \ rl d 
0cbe			;    add hl,hl \ rl e \ rl d 
0cbe			;    inc l 
0cbe			;    add hl,bc 
0cbe			;    ld (seed1_0),hl 
0cbe			;    ld hl,(seed1_1) 
0cbe			;    adc hl,de 
0cbe			;    ld (seed1_1),hl 
0cbe			;    ex de,hl 
0cbe			;seed2_0=$+1 
0cbe			;    ld hl,9876 
0cbe			;seed2_1=$+1 
0cbe			;    ld bc,54321 
0cbe			;    add hl,hl \ rl c \ rl b 
0cbe			;    ld (seed2_1),bc 
0cbe			;    sbc a,a 
0cbe			;    and %11000101 
0cbe			;    xor l 
0cbe			;    ld l,a 
0cbe			;    ld (seed2_0),hl 
0cbe			;    ex de,hl 
0cbe			;    add hl,bc 
0cbe			;    ret 
0cbe			; 
0cbe			 
0cbe			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0cbe			; 20 bytes, 86 cycles (excluding ret) 
0cbe			 
0cbe			; returns   hl = pseudorandom number 
0cbe			; corrupts   a 
0cbe			 
0cbe			; generates 16-bit pseudorandom numbers with a period of 65535 
0cbe			; using the xorshift method: 
0cbe			 
0cbe			; hl ^= hl << 7 
0cbe			; hl ^= hl >> 9 
0cbe			; hl ^= hl << 8 
0cbe			 
0cbe			; some alternative shift triplets which also perform well are: 
0cbe			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0cbe			 
0cbe			;  org 32768 
0cbe			 
0cbe			xrnd: 
0cbe 2a d9 fa		  ld hl,(xrandc)       ; seed must not be 0 
0cc1 3e 00		  ld a,0 
0cc3 bd			  cp l 
0cc4 20 02		  jr nz, .xrnd1 
0cc6 2e 01		  ld l, 1 
0cc8			.xrnd1: 
0cc8			 
0cc8 7c			  ld a,h 
0cc9 1f			  rra 
0cca 7d			  ld a,l 
0ccb 1f			  rra 
0ccc ac			  xor h 
0ccd 67			  ld h,a 
0cce 7d			  ld a,l 
0ccf 1f			  rra 
0cd0 7c			  ld a,h 
0cd1 1f			  rra 
0cd2 ad			  xor l 
0cd3 6f			  ld l,a 
0cd4 ac			  xor h 
0cd5 67			  ld h,a 
0cd6			 
0cd6 22 d9 fa		  ld (xrandc),hl 
0cd9			 
0cd9 c9			  ret 
