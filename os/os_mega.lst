0132			; my spi protocol (used by storage) 
0132			 
0132			; SPI pins 
0132			 
0132			SPI_DI: equ 7       ; chip pin 5 - port a7   pin pin 7 
0132			SPI_DO: equ 6      ; chip pin 2 - port a6   pin 8 
0132			SPI_SCLK: equ 5      ; chip pin 6 - port a5  - pin 9 
0132			 
0132			; chip pin 3 (WP), 7 (HOLD) and 8 (VCC) +5v 
0132			; chip pin 4 gnd 
0132			 
0132			 
0132			SPI_CE0: equ 0      ; chip pin 1 - port a3 - pin 15 
0132			SPI_CE1: equ 1      ;    port a1 pin 14  
0132			SPI_CE2: equ 2      ;    port a2 pin pin 13 
0132			SPI_CE3: equ 3      ; port    a3 pin pin 12 
0132			SPI_CE4: equ 4      ; port a4     pin 10 
0132			 
0132			; active low AND masks 
0132			 
0132			;SPI_CE0_MASK: equ    255-1 
0132			;SPI_CE1_MASK: equ   255-2 
0132			;SPI_CE2_MASK: equ   255-4 
0132			;SPI_CE3_MASK: equ   255-8 
0132			;SPI_CE4_MASK: equ   255-16 
0132			SPI_CE_HIGH:  equ 255 
