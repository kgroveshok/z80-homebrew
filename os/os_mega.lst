12f5 cd 6e 0a			call delay1s  
12f8 cd 6e 0a			call delay1s  
12fb cd 6e 0a			call delay1s  
12fe cd 6e 0a			call delay1s  
1301			endif 
1301 c9				ret 
1302			 
1302			; output a high period 
1302			 
1302			tape_high: 
