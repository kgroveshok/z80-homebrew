1132					endif 
1132 7c			      ld    A, H                    ; Exit if no space requested 
1133 b5			      or    L 
1134 ca f3 11		      jp    Z, malloc_early_exit 
1137			 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			; 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			;inc hl 
1137			 
1137			 
1137			 
1137			 
1137					if DEBUG_FORTH_MALLOC 
1137						DMARK "maA" 
1137						CALLMONITOR 
1137					endif 
