0d11 87			    add a,a 
0d12 30 01		    jr nc,Mult12U_NoAdd3 
0d14 19			    add hl,de 
0d15			Mult12U_NoAdd3: 
0d15 29			    add hl,hl 
0d16 87			    add a,a 
0d17 30 01		    jr nc,Mult12U_NoAdd4 
0d19 19			    add hl,de 
0d1a			Mult12U_NoAdd4: 
0d1a 29			    add hl,hl 
0d1b 87			    add a,a 
0d1c 30 01		    jr nc,Mult12U_NoAdd5 
0d1e 19			    add hl,de 
