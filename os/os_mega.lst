25f0			;	call forth_push_numhl 
25f0					FORTH_PUSH_VALUEHL 
25f0				if BASE_CPM=1 
25f0					call forth_push_numhl 
25f0				endif 
25f0				if BASE_KEV=1 
25f0 e7					rst $20 
25f1				endif 
25f1				endm 
