71d6			; handle the auto run of code from files in storage 
71d6			 
71d6			 
71d6			include "forth_startup.asm" 
71d6			; Which startup method to use? 
71d6			; 
71d6			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
71d6			; followed by loading of a list of scripts in eeprom 
71d6			 
71d6			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
71d6			; from eeprom 
71d6			 
71d6			; Select with define in main stubs 
71d6			 
71d6			if STARTUP_V1 
71d6				include "forth_startupv1.asm" 
71d6			endif 
71d6			if STARTUP_V2 
71d6				include "forth_startupv2.asm" 
71d6			; Version 2 of the startup  
71d6			;  
71d6			; Auto load any files in bank 1 that start with a '*' 
71d6			; If no se storage then revert to using eprom 
71d6			 
71d6			 
71d6			if STORAGE_SE = 0 
71d6			 
71d6			sprompt1: db "Startup load...",0 
71d6			sprompt2: db "Run? 1=No *=End #=All",0 
71d6			 
71d6			 
71d6			 
71d6			 
71d6			forth_startup: 
71d6				ld hl, startcmds 
71d6				ld a, 0 
71d6				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
71d6			 
71d6			.start1:	push hl 
71d6				call clear_display 
71d6				ld de, sprompt1 
71d6			        ld a, display_row_1 
71d6				call str_at_display 
71d6				ld de, sprompt2 
71d6			        ld a, display_row_2 
71d6				call str_at_display 
71d6				pop hl 
71d6				push hl 
71d6				ld e,(hl) 
71d6				inc hl 
71d6				ld d,(hl) 
71d6			        ld a, display_row_3 
71d6				call str_at_display 
71d6				call update_display 
71d6			 
71d6			 
71d6				ld a, (os_last_cmd) 
71d6			;	cp 0 
71d6				or a 
71d6				jr z, .startprompt 
71d6				call delay250ms 
71d6				jr .startdo 
71d6				 
71d6				 
71d6			 
71d6			.startprompt: 
71d6			 
71d6				ld a,display_row_4 + display_cols - 1 
71d6			        ld de, endprg 
71d6				call str_at_display 
71d6				call update_display 
71d6				call delay1s 
71d6				call cin_wait 
71d6						 
71d6				cp '*' 
71d6				jr z, .startupend1 
71d6				cp '#' 
71d6				jr nz, .startno 
71d6				ld a, 1 
71d6				ld (os_last_cmd),a 
71d6				jr .startdo 
71d6			.startno:	cp '1' 
71d6				jr z,.startnxt  
71d6			 
71d6				; exec startup line 
71d6			.startdo:	 
71d6				pop hl 
71d6				push hl 
71d6				 
71d6				ld e,(hl) 
71d6				inc hl 
71d6				ld d,(hl) 
71d6				ex de,hl 
71d6			 
71d6				push hl 
71d6			 
71d6				ld a, 0 
71d6				;ld a, FORTH_END_BUFFER 
71d6				call strlent 
71d6				inc hl   ; include zero term to copy 
71d6				ld b,0 
71d6				ld c,l 
71d6				pop hl 
71d6				ld de, scratch 
71d6				ldir 
71d6			 
71d6			 
71d6				ld hl, scratch 
71d6				call forthparse 
71d6				call forthexec 
71d6				call forthexec_cleanup 
71d6			 
71d6				ld a, display_row_4 
71d6				ld de, endprog 
71d6			 
71d6				call update_display		 
71d6			 
71d6				ld a, (os_last_cmd) 
71d6			;	cp 0 
71d6				or a 
71d6				jr nz, .startnxt 
71d6				call next_page_prompt 
71d6			        call clear_display 
71d6				call update_display		 
71d6			 
71d6				; move onto next startup line? 
71d6			.startnxt: 
71d6			 
71d6				call delay250ms 
71d6				pop hl 
71d6			 
71d6				inc hl 
71d6				inc hl 
71d6			 
71d6				push hl 
71d6				ld e, (hl) 
71d6				inc hl 
71d6				ld d, (hl) 
71d6				pop hl 
71d6				; TODO replace 0 test 
71d6			 
71d6				ex de, hl 
71d6				call ishlzero 
71d6			;	ld a,e 
71d6			;	add d 
71d6			;	cp 0    ; any left to do? 
71d6				ex de, hl 
71d6				jp nz, .start1 
71d6				jr .startupend 
71d6			 
71d6			.startupend1: pop hl 
71d6			.startupend: 
71d6			 
71d6				call clear_display 
71d6				call update_display 
71d6				ret 
71d6			endif 
