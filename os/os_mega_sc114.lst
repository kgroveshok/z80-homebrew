a46e					ld (debug_mark+1),a  
a46e					ld a, (.dmark+2)  
a46e					ld (debug_mark+2),a  
a46e				endif  
a46e 18 03			jr .pastdmark  
a470 ..			.dmark: db "SCR"  
a473				if DEMARK_VERSION = 1  
