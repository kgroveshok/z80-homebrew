682b			; **********************************************************************  
682b			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
682b			; **********************************************************************  
682b			;  
682b			; **  Written as a Small Computer Monitor App  
682b			; **  www.scc.me.uk  
682b			;  
682b			; History  
682b			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
682b			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
682b			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
682b			;  
682b			; **********************************************************************  
682b			;  
682b			; This program is an example of one of the methods of interfacing an   
682b			; alphanumeric LCD module.   
682b			;  
682b			; In this example the display is connected to either a Z80 PIO or a   
682b			; simple 8-bit output port.   
682b			;  
682b			; This interfacing method uses 4-bit data mode and uses time delays  
682b			; rather than polling the display's ready status. As a result the   
682b			; interface only requires 6 simple output lines:  
682b			;   Output bit 0 = not used  
682b			;   Output bit 1 = not used  
682b			;   Output bit 2 = RS         High = data, Low = instruction  
682b			;   Output bit 3 = E          Active high  
682b			;   Output bit 4 = DB4  
682b			;   Output bit 5 = DB5  
682b			;   Output bit 6 = DB6  
682b			;   Output bit 7 = DB7  
682b			; Display's R/W is connected to 0v so it is always in write mode  
682b			;  
682b			; This set up should work with any system supporting the RC2014 bus  
682b			  
682b			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
682b			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
682b			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
682b			;  
682b			; **********************************************************************  
682b			  
682b			; Additonal for 4x40. E1 and E2 instead of just E   
682b			; TODO swipe vidout signal on port a to activate E2  
682b			  
682b			; **********************************************************************  
682b			; **  Constants  
682b			; **********************************************************************  
682b			; LCD constants required by LCD support module  
682b			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
682b			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
682b			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
682b			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
682b			; TODO Decide which E is being set  
682b			kLCDWidth:  EQU display_cols             ;Width in characters  
682b			  
682b			; **********************************************************************  
682b			; **  Code library usage  
682b			; **********************************************************************  
682b			  
682b			; send character to current cursor position  
682b			; wraps and/or scrolls screen automatically  
682b			  
682b			  
682b			  
682b			lcd_init:  
682b			  
682b			; SCMonAPI functions used  
682b			  
682b			; Alphanumeric LCD functions used  
682b			; no need to specify specific functions for this module  
682b			  
682b 3e cf		            LD   A, 11001111b  
682d d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
682f 3e 00		            LD   A, 00000000b  
6831 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6833			  
6833			; Initialise alphanumeric LCD module  
6833 3e 00				ld a, 0  
6835 32 fb fa				ld (display_lcde1e2), a  
6838 cd b9 68		            CALL fLCD_Init      ;Initialise LCD module  
683b 3e 01				ld a, 1  
683d 32 fb fa				ld (display_lcde1e2), a  
6840 cd b9 68		            CALL fLCD_Init      ;Initialise LCD module  
6843			  
6843 c9				ret  
6844			  
