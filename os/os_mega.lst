1d30			include "firmware_595shiftreg.asm"  
1d30			; common code for handling a 595 shift reg out on whatever output port 
1d30			 
1d30			; port in c 
1d30			; byte in a 
1d30			 
1d30			 
1d30			shift_bit_data: equ 0 
1d30			shift_bit_clk: equ 1 
1d30			shift_bit_latch: equ 2 
1d30			 
1d30			 
1d30			; shift out a byte to the sound chip 
1d30			 
1d30			; A contains byte to send 
1d30			 
1d30			shift_byte: 
1d30			 
1d30 06 08			ld b, 8   ; 8 bits to shift 
1d32			 
1d32 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
1d34			 
1d34				; set data bit state 
1d34			 
1d34 cb 7f			bit 7, a 
1d36				; high bit is set 
1d36 28 02			jr z, .nb2 
1d38 cb c2			set shift_bit_data, d 
1d3a			 
1d3a				; set latches state  
1d3a cb ca		.nb2:	set shift_bit_clk, d 
1d3c cb 92			res shift_bit_latch, d    ; latch is inverted 
1d3e ed 51			out (c), d 
1d40				 
1d40				; clock the bit out 
1d40 cb 8a			res shift_bit_clk, d 
1d42 ed 51			out (c), d 
1d44			 
1d44				; shift a left one bit and repeat 
1d44 17				rla 
1d45			 
1d45 10 eb			djnz .nb1 
1d47			 
1d47				; latch 
1d47 cb d2			set shift_bit_latch, d 
1d49 ed 51			out (c), d 
1d4b					 
1d4b			 
1d4b				; set  
1d4b c9				ret 
# End of file firmware_595shiftreg.asm
