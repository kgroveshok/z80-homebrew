67c2			  
67c2			; write the frame buffer given in hl to hardware   
67c2 22 f9 fa		write_display: ld (display_write_tmp), hl 	   
67c5 3e 00			ld a, kLCD_Line1  
67c7 cd d1 68		            CALL fLCD_Pos       ;Position cursor to location in A  
67ca 06 28			ld b, display_cols  
67cc ed 5b f9 fa		ld de, (display_write_tmp)  
67d0 cd 1c 68			call write_len_string  
67d3				  
