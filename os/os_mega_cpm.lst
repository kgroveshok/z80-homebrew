10da			      ; Check if the freed block is adjacent to the next free block 
10da 23			      inc   HL                      ; Load size of freed block into HL 
10db 5e			      ld    E, (HL) 
10dc 23			      inc   HL 
10dd 56			      ld    D, (HL) 
10de eb			      ex    DE, HL 
10df			 
10df 09			      add   HL, BC                  ; Add addr of freed block and its size 
10e0			 
10e0 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
10e3 dd 56 01		      ld    D, (IX+1) 
10e6			 
10e6 b7			      or    A                       ; Clear the carry flag 
10e7 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
10e9 20 22		      jr    NZ, free_check_adjacent_to_prev 
