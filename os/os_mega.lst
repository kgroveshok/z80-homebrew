15ab			 
15ab			; Device support for SN76489AN sound chip 
15ab			 
15ab			; https://arduinoplusplus.wordpress.com/2019/10/05/making-noise-with-a-sn76489-digital-sound-generator-part-1/ 
15ab			; http://danceswithferrets.org/geekblog/?p=93 
15ab			; https://www.smspower.org/Development/SN76489 
15ab			 
15ab			; D0 [ 3] 
15ab			; D1 [ 2] 
15ab			; D2 [ 1] 
15ab			; D3 [15] 
15ab			; D4 [13] 
15ab			; D5 [12] 
15ab			; D6 [11] 
15ab			; D7 [10] 
15ab			; /WE [ 5] 
15ab			; CLK [14] 
15ab			; /OE [ 6] 
15ab			; AUDIO [ 7] 
15ab			; GND 8 
15ab			; +5 16 
15ab			; 
15ab			 
15ab			; Write sequence: 
15ab			; CE low 
15ab			; Data bus 
15ab			; WE low then high 
15ab			; 32 clock cycles / 8ns write time at 4mhz 
15ab			; 
15ab			; https://github.com/jblang/SN76489 
15ab			; Shows that the clock needs to be enabled when required. Noticed that with the clock connected it interupted the bus 
15ab			; Tried: 
15ab			; 
15ab			; CE/OE -> Both pins of NAND -> To one pin of second NAND and second pin to full clock -> CLK on chip 
15ab			; 
15ab			; Connected WE to OR too 
15ab			;  
15ab			; That enabled the clock when required 
15ab			; However still random bus corruption. Need further investigation 
15ab			 
15ab			 
15ab			SOUND_LATCH: equ 10000000B 
15ab			SOUND_DATA: equ 0B 
15ab			SOUND_CH0:  equ 0B    ; Tone 
15ab			SOUND_CH1: equ 0100000B        ; Tone 
15ab			SOUND_CH2: equ 1000000B   ; Tone 
15ab			SOUND_CH3: equ 1100000B    ; Noise 
15ab			SOUND_VOL: equ 10000B 
15ab			SOUND_TONE: equ 0B 
15ab			 
15ab			 
15ab c9			sound_init: ret 
