6402			; 
6402			;	ld de, sfaultsu 
6402			;	jp .chk_fault 
6402			 
6402 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
6405 ed 5b bc f0		ld de,(chk_word) 
6409				if DEBUG_STK_FAULT 
