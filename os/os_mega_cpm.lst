1199				ld a, $fe      ; bit 0 clear 
1199				ld (spi_device), a 
1199			 
1199				call storage_get_block_0 
1199			 
1199				pop bc 
1199				ld a,c 
1199				ld (store_page+STORE_0_BANKRUN), a 
1199				ld a,b 
1199				ld (store_page+STORE_0_BANKRUNN), a 
1199					ld hl, 0 
1199					ld de, store_page 
1199				call storage_write_block 
1199			 
