# End of macro CWHEAD
5346			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5346			; | 
5346			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5346			; | |  
5346			; | | e.g. 
5346			; | |         #30 a var ! 
5346			; | |         a var @ . 
5346			; | |   
5346			; | |     Displays the number 30 
5346			; | | 
5346			; | | Each variable pointer is a word so can use for any words that use that:  
5346			; | |  
5346			; | | e.g. 
5346			; | |  
5346			; | |         #30 a var 2! 
5346			; | |         a var 2@ . 
5346			; | |   
5346			; | |     Displays the number 30 
5346			; | |  
5346			; | | > [!NOTE]  
5346			; ! | > If a full string is passed then only the first char is looked at 
5346			; | | > Any other char could exceed bounds checks!  
5346			; | | > 
5346			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5346			 
5346					if DEBUG_FORTH_WORDS_KEY 
5346						DMARK "VAR" 
5346				if DEMARK_VERSION = 1  
5346 e5					push hl  
5347 21 4f 53				ld hl, .dmark  
534a 22 9b fd				ld (debug_mark), hl  
534d				endif  
534d				if DEMARK_VERSION = 0  
534d					push af  
534d					ld a, (.dmark)  
534d					ld (debug_mark),a  
534d					ld a, (.dmark+1)  
534d					ld (debug_mark+1),a  
534d					ld a, (.dmark+2)  
534d					ld (debug_mark+2),a  
534d				endif  
534d 18 04			jr .pastdmark  
534f ..			.dmark: db "VAR"  
5352				if DEMARK_VERSION = 1  
5352 00					db 0  
5353				endif  
5353				if DEMARK_VERSION = 1  
5353 e1			.pastdmark: pop hl  
5354				endif  
5354				if DEMARK_VERSION = 0  
5354			.pastdmark: pop af  
5354				endif  
5354			endm  
# End of macro DMARK
5354						CALLMONITOR 
5354				if BASE_CPM=1  
5354					call debug_vector  
5354				endif  
5354				if BASE_KEV=1  
5354 cf					rst 8  
5355				endif  
