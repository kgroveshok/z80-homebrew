1d3f			include "firmware_595shiftreg.asm"  
1d3f			; common code for handling a 595 shift reg out on whatever output port 
1d3f			 
1d3f			; port in c 
1d3f			; byte in a 
1d3f			 
1d3f			 
1d3f			shift_bit_data: equ 0 
1d3f			shift_bit_clk: equ 1 
1d3f			shift_bit_latch: equ 2 
1d3f			 
1d3f			 
1d3f			; shift out a byte to the sound chip 
1d3f			 
1d3f			; A contains byte to send 
1d3f			 
1d3f			shift_byte: 
1d3f			 
1d3f 06 08			ld b, 8   ; 8 bits to shift 
1d41			 
1d41 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
1d43			 
1d43				; set data bit state 
1d43			 
1d43 cb 7f			bit 7, a 
1d45				; high bit is set 
1d45 28 02			jr z, .nb2 
1d47 cb c2			set shift_bit_data, d 
1d49			 
1d49				; set latches state  
1d49 cb ca		.nb2:	set shift_bit_clk, d 
1d4b cb 92			res shift_bit_latch, d    ; latch is inverted 
1d4d ed 51			out (c), d 
1d4f				 
1d4f				; clock the bit out 
1d4f cb 8a			res shift_bit_clk, d 
1d51 ed 51			out (c), d 
1d53			 
1d53				; shift a left one bit and repeat 
1d53 17				rla 
1d54			 
1d54 10 eb			djnz .nb1 
1d56			 
1d56				; latch 
1d56 cb d2			set shift_bit_latch, d 
1d58 ed 51			out (c), d 
1d5a					 
1d5a			 
1d5a				; set  
1d5a c9				ret 
# End of file firmware_595shiftreg.asm
