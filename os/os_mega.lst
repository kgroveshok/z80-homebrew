69dc			; **********************************************************************  
69dc			; **  LCD support functions  
69dc			; **********************************************************************  
69dc			  
69dc			; Initialise alphanumeric LCD module  
69dc			; LCD control register codes:  
69dc			;   DL   0 = 4-bit mode        1 = 8-bit mode  
69dc			;   N    0 = 1-line mode       1 = 2-line mode  
69dc			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
69dc			;   D    0 = Display off       1 = Display on  
69dc			;   C    0 = Cursor off        1 = Cursor on  
69dc			;   B    0 = Blinking off      1 = Blinking on  
69dc			;   ID   0 = Decrement mode    1 = Increment mode  
69dc			;   SH   0 = Entire shift off  1 = Entire shift on  
69dc 3e 28		fLCD_Init:  LD   A, 40  
69de cd 1f 6b		            CALL LCDDelay       ;Delay 40ms after power up  
69e1			; For reliable reset set 8-bit mode - 3 times  
69e1 cd ef 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69e4 cd ef 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69e7 cd ef 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69ea			; Set 4-bit mode  
69ea cd eb 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
69ed cd 1d 6b		            CALL LCDDelay1      ;Delay 37 us or more  
69f0			; Function set  
69f0 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
69f2 cd 15 6a		            CALL fLCD_Inst      ;2 line, display on  
69f5			; Display On/Off control  
69f5 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
69f7 cd 15 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
69fa			; Display Clear  
69fa 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
69fc cd 15 6a		            CALL fLCD_Inst      ;Clear display  
69ff			; Entry mode  
69ff 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6a01 cd 15 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
6a04			; Display module now initialised  
6a04 c9			            RET  
6a05			; ok to here  
6a05			  
6a05			; decide on setting bit for LED on or off  
6a05			; Set correct bit in A  
6a05 e5			IsLED: push hl  
6a06 21 ad fd			ld hl, hardware_word+1  
6a09 cb 56			bit 2, (hl)    ; led bit  
6a0b 20 04			jr nz, .isled1  
6a0d cb 8f			res kLCDBitLED, a  
6a0f 18 02			jr .isleddone  
6a11 cb cf		.isled1: set kLCDBitLED, a  
6a13			.isleddone:  	  
6a13 e1				pop hl  
6a14			  
6a14 c9				ret  
6a15			  
6a15			  
6a15			; Write instruction to LCD  
6a15			;   On entry: A = Instruction byte to be written  
6a15			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a15 f5			fLCD_Inst:  PUSH AF  
6a16 f5			            PUSH AF  
6a17 cd 29 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a1a f1			            POP  AF  
6a1b 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a1c 17			            RLA  
6a1d 17			            RLA  
6a1e 17			            RLA  
6a1f cd 29 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6a22 3e 02		            LD   A, 2  
6a24 cd 1f 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6a27 f1			            POP  AF  
6a28 c9			            RET  
6a29			Wr4bits:   
6a29 f5					push af  
6a2a 3a fb fa				ld a, (display_lcde1e2)  
6a2d fe 00				cp 0     ; e  
6a2f 20 13				jr nz, .wea2	  
6a31 f1					pop af  
6a32 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a34 cd 05 6a				call IsLED  
6a37 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a39 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6a3b cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6a3d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a3f cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6a41 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a43 c9			            RET  
6a44 f1			.wea2:		pop af  
6a45 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a47 cd 05 6a				call IsLED  
6a4a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a4c cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6a4e cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6a50 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a52 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6a54 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a56 c9			            RET  
6a57			  
6a57			  
6a57			; Write data to LCD  
6a57			;   On entry: A = Data byte to be written  
6a57			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a57 f5			fLCD_Data:  PUSH AF  
6a58 f5			            PUSH AF  
6a59 cd 6b 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6a5c f1			            POP  AF  
6a5d 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a5e 17			            RLA  
6a5f 17			            RLA  
6a60 17			            RLA  
6a61 cd 6b 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6a64 3e 96		            LD   A, 150  
6a66 3d			Wait:      DEC  A              ;Wait a while to allow data   
6a67 20 fd		            JR   NZ, Wait      ;  write to complete  
6a69 f1			            POP  AF  
6a6a c9			            RET  
6a6b			Wr4bitsa:     
6a6b f5					push af  
6a6c 3a fb fa				ld a, (display_lcde1e2)  
6a6f fe 00				cp 0     ; e1  
6a71 20 19				jr nz, .we2	  
6a73 f1					pop af  
6a74 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a76 cd 05 6a				call IsLED  
6a79 cb d7		            SET  kLCDBitRS, A  
6a7b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a7d cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6a7f cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6a81 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a83 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6a85 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a87 cb 97		            RES  kLCDBitRS, A  
6a89 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a8b c9			            RET  
6a8c f1			.we2:		pop af  
6a8d e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a8f cd 05 6a				call IsLED  
6a92 cb d7		            SET  kLCDBitRS, A  
6a94 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a96 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6a98 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6a9a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a9c cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6a9e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6aa0 cb 97		            RES  kLCDBitRS, A  
6aa2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6aa4 c9			            RET  
