5904			include "forth_startup.asm" 
5904			; Which startup method to use? 
5904			; 
5904			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
5904			; followed by loading of a list of scripts in eeprom 
5904			 
5904			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
5904			; from eeprom 
5904			 
5904			; Select with define in main stubs 
5904			 
5904			if STARTUP_V1 
5904				include "forth_startupv1.asm" 
5904			; Startup script loading version 1 
5904			 
5904			; If SE storage is available first stage is to use the selected file 
5904			; then go through the eeprom list 
5904			 
