d6ae			key_init: 
d6ae				; init keyboard macro pointers 
d6ae 21 00 00			ld hl, 0 
d6b1 22 fe ee			ld (key_macroroot), hl 
d6b4 22 fc ee			ld (key_macrolast), hl 
