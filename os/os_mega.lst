6a09			; **********************************************************************  
6a09			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6a09			; **********************************************************************  
6a09			;  
6a09			; **  Written as a Small Computer Monitor App   
6a09			; **  Version 0.1 SCC 2018-05-16  
6a09			; **  www.scc.me.uk  
6a09			;  
6a09			; **********************************************************************  
6a09			;  
6a09			; This module provides support for alphanumeric LCD modules using with  
6a09			; *  HD44780 (or compatible) controller  
6a09			; *  5 x 7 pixel fonts  
6a09			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6a09			; *  Interface via six digital outputs to the display (see below)  
6a09			;  
6a09			; LCD module pinout:  
6a09			;   1  Vss   0v supply  
6a09			;   2  Vdd   5v supply  
6a09			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6a09			;   4  RS    High = data, Low = instruction  
6a09			;   5  R/W   High = Read, Low = Write  
6a09			;   6  E     Enable signal (active high)  
6a09			;   7  DB0   Data bit 0  
6a09			;   8  DB1   Data bit 1  
6a09			;   9  DB2   Data bit 2  
6a09			;  10  DB3   Data bit 3  
6a09			;  11  DB4   Data bit 4  
6a09			;  12  DB5   Data bit 5  
6a09			;  13  DB6   Data bit 6  
6a09			;  14  DB7   Data bit 7  
6a09			;  15  A     Backlight anode (+)  
6a09			;  16  K     Backlight cathode (-)  
6a09			;  
6a09			; This interfacing method uses 4-bit data mode and uses time delays  
6a09			; rather than polling the display's ready status. As a result the   
6a09			; interface only requires 6 simple output lines:  
6a09			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6a09			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6a09			;   LCD DB4 = Microcomputer output port bit 4  
6a09			;   LCD DB5 = Microcomputer output port bit 5  
6a09			;   LCD DB6 = Microcomputer output port bit 6  
6a09			;   LCD DB7 = Microcomputer output port bit 7  
6a09			; Display's R/W is connected to 0v so it is always in write mode  
6a09			; All 6 connections must be on the same port address <kLCDPrt>  
6a09			; This method also allows a decent length of cable from micro to LCD  
6a09			;  
6a09			; **********************************************************************  
6a09			;  
6a09			; To include the code for any given function provided by this module,   
6a09			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6a09			; the parent source file.  
6a09			; For example:  #REQUIRES   uHexPrefix  
6a09			;  
6a09			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6a09			; in the parent source file.  
6a09			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6a09			;  
6a09			; These are the function names provided by this module:  
6a09			; fLCD_Init                     ;Initialise LCD  
6a09			; fLCD_Inst                     ;Send instruction to LCD  
6a09			; fLCD_Data                     ;Send data byte to LCD  
6a09			; fLCD_Pos                      ;Position cursor  
6a09			; fLCD_Str                      ;Display string  
6a09			; fLCD_Def                      ;Define custom character  
6a09			;  
6a09			; **********************************************************************  
6a09			;  
6a09			; Requires SCMonAPI.asm to also be included in the project  
6a09			;  
6a09			  
6a09			  
6a09			; **********************************************************************  
6a09			; **  Constants  
6a09			; **********************************************************************  
6a09			  
6a09			; Constants that must be defined externally  
6a09			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6a09			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6a09			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6a09			;kLCDWidth: EQU 20             ;Width in characters  
6a09			  
6a09			; general line offsets in any frame buffer  
6a09			  
6a09			  
6a09			display_row_1: equ 0  
6a09			display_row_2: equ display_row_1+display_cols  
6a09			display_row_3: equ display_row_2 + display_cols  
6a09			display_row_4: equ display_row_3 + display_cols  
6a09			;display_row_4_eol:   
6a09			  
6a09			  
6a09			; Cursor position values for the start of each line  
6a09			  
6a09			; E  
6a09			kLCD_Line1: EQU 0x00   
6a09			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6a09			; E1  
6a09			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6a09			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6a09			  
6a09			; Instructions to send as A register to fLCD_Inst  
6a09			kLCD_Clear: EQU 00000001b     ;LCD clear  
6a09			kLCD_Off:   EQU 00001000b     ;LCD off  
6a09			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6a09			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6a09			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6a09			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6a09			  
6a09			; Constants used by this code module  
6a09			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6a09			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6a09			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6a09			  
6a09			  
6a09			  
6a09			; **********************************************************************  
6a09			; **  LCD support functions  
6a09			; **********************************************************************  
6a09			  
6a09			; Initialise alphanumeric LCD module  
6a09			; LCD control register codes:  
6a09			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6a09			;   N    0 = 1-line mode       1 = 2-line mode  
6a09			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6a09			;   D    0 = Display off       1 = Display on  
6a09			;   C    0 = Cursor off        1 = Cursor on  
6a09			;   B    0 = Blinking off      1 = Blinking on  
6a09			;   ID   0 = Decrement mode    1 = Increment mode  
6a09			;   SH   0 = Entire shift off  1 = Entire shift on  
6a09 3e 28		fLCD_Init:  LD   A, 40  
6a0b cd 30 6b		            CALL LCDDelay       ;Delay 40ms after power up  
6a0e			; For reliable reset set 8-bit mode - 3 times  
6a0e cd 00 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a11 cd 00 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a14 cd 00 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a17			; Set 4-bit mode  
6a17 cd fc 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
6a1a cd 2e 6b		            CALL LCDDelay1      ;Delay 37 us or more  
6a1d			; Function set  
6a1d 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6a1f cd 32 6a		            CALL fLCD_Inst      ;2 line, display on  
6a22			; Display On/Off control  
6a22 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6a24 cd 32 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6a27			; Display Clear  
6a27 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6a29 cd 32 6a		            CALL fLCD_Inst      ;Clear display  
6a2c			; Entry mode  
6a2c 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6a2e cd 32 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
6a31			; Display module now initialised  
6a31 c9			            RET  
6a32			; ok to here  
6a32			  
6a32			; Write instruction to LCD  
6a32			;   On entry: A = Instruction byte to be written  
6a32			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a32 f5			fLCD_Inst:  PUSH AF  
6a33 f5			            PUSH AF  
6a34 cd 46 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a37 f1			            POP  AF  
6a38 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a39 17			            RLA  
6a3a 17			            RLA  
6a3b 17			            RLA  
6a3c cd 46 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6a3f 3e 02		            LD   A, 2  
6a41 cd 30 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6a44 f1			            POP  AF  
6a45 c9			            RET  
6a46			Wr4bits:   
6a46 f5					push af  
6a47 3a fb fa				ld a, (display_lcde1e2)  
6a4a fe 00				cp 0     ; e  
6a4c 20 10				jr nz, .wea2	  
6a4e f1					pop af  
6a4f e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a51 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a53 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6a55 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6a57 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a59 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6a5b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a5d c9			            RET  
6a5e f1			.wea2:		pop af  
6a5f e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a61 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a63 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6a65 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6a67 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a69 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6a6b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a6d c9			            RET  
6a6e			  
6a6e			  
6a6e			; Write data to LCD  
6a6e			;   On entry: A = Data byte to be written  
6a6e			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a6e f5			fLCD_Data:  PUSH AF  
6a6f f5			            PUSH AF  
6a70 cd 82 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6a73 f1			            POP  AF  
6a74 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a75 17			            RLA  
6a76 17			            RLA  
6a77 17			            RLA  
6a78 cd 82 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6a7b 3e 96		            LD   A, 150  
6a7d 3d			Wait:      DEC  A              ;Wait a while to allow data   
6a7e 20 fd		            JR   NZ, Wait      ;  write to complete  
6a80 f1			            POP  AF  
6a81 c9			            RET  
6a82			Wr4bitsa:     
6a82 f5					push af  
6a83 3a fb fa				ld a, (display_lcde1e2)  
6a86 fe 00				cp 0     ; e1  
6a88 20 16				jr nz, .we2	  
6a8a f1					pop af  
6a8b e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a8d cb d7		            SET  kLCDBitRS, A  
6a8f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a91 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6a93 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6a95 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a97 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6a99 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a9b cb 97		            RES  kLCDBitRS, A  
6a9d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a9f c9			            RET  
6aa0 f1			.we2:		pop af  
6aa1 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6aa3 cb d7		            SET  kLCDBitRS, A  
6aa5 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6aa7 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6aa9 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6aab d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6aad cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6aaf d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6ab1 cb 97		            RES  kLCDBitRS, A  
6ab3 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6ab5 c9			            RET  
6ab6			  
6ab6			  
6ab6			; Position cursor to specified location  
6ab6			;   On entry: A = Cursor position  
6ab6			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ab6 f5			fLCD_Pos:   PUSH AF  
6ab7					; at this point set the E1 or E2 flag depending on position  
6ab7			  
6ab7 c5					push bc  
6ab8			;		push af  
6ab8 06 00				ld b, 0  
6aba 4f					ld c, a  
6abb 3e 4f				ld a, kLCD_Line3-1  
6abd b7			 		or a      ;clear carry flag  
6abe 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6abf 38 04				jr c, .pe1  
6ac1			  
6ac1					; E selection  
6ac1 cb 80				res 0, b         ; bit 0 unset e  
6ac3			;		pop af    ; before line 3 so recover orig pos  
6ac3			;		ld c, a    ; save for poking back  
6ac3 18 06				jr .peset	          
6ac5			.pe1:          	; E2 selection  
6ac5 cb c0				set 0, b         ; bit 0 set e1  
6ac7 79					ld a, c  
6ac8 de 4f				sbc a, kLCD_Line3-1  
6aca 4f					ld c, a	         ; save caculated offset  
6acb			;		pop af     ; bin this original value now we have calculated form  
6acb			  
6acb			.peset:		; set bit  
6acb 78					ld a, b  
6acc 32 fb fa				ld (display_lcde1e2), a 	  
6acf 79					ld a, c  
6ad0 c1					pop bc  
6ad1			  
6ad1 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6ad3 cd 32 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ad6 f1			            POP  AF  
6ad7 c9			            RET  
6ad8			  
6ad8			  
6ad8			; Output text string to LCD  
6ad8			;   On entry: DE = Pointer to null terminated text string  
6ad8			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6ad8 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6ad9 b7			            OR   A              ;Null terminator?  
6ada c8			            RET  Z              ;Yes, so finished  
6adb cd 6e 6a		            CALL fLCD_Data      ;Write character to display  
6ade 13			            INC  DE             ;Point to next character  
6adf 18 f7		            JR   fLCD_Str       ;Repeat  
6ae1 c9					ret  
6ae2			  
6ae2			; Define custom character  
6ae2			;   On entry: A = Character number (0 to 7)  
6ae2			;             DE = Pointer to character bitmap data  
6ae2			;   On exit:  A = Next character number  
6ae2			;             DE = Next location following bitmap  
6ae2			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6ae2			; Character is   
6ae2 c5			fLCD_Def:   PUSH BC  
6ae3 f5			            PUSH AF  
6ae4 07			            RLCA                ;Calculate location  
6ae5 07			            RLCA                ;  for bitmap data  
6ae6 07			            RLCA                ;  = 8 x CharacterNumber  
6ae7 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6ae9 cd 32 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6aec 06 00		            LD   B, 0  
6aee 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6aef cd 6e 6a		            CALL fLCD_Data      ;Write byte to display  
6af2 13			            INC  DE             ;Point to next byte  
6af3 04			            INC  B              ;Count bytes  
6af4 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6af6 28 f6		            JR   Z, Loop       ;No, so repeat  
6af8 f1			            POP  AF  
6af9 3c			            INC  A              ;Increment character number  
6afa c1			            POP  BC  
6afb c9			            RET  
6afc			  
6afc			  
6afc			; **********************************************************************  
6afc			; **  Private functions  
6afc			; **********************************************************************  
6afc			  
6afc			; Write function to LCD  
6afc			;   On entry: A = Function byte to be written  
6afc			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6afc 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6afe 18 02		            JR   WrFunc  
6b00 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6b02 f5			WrFunc:     PUSH AF  
6b03 f5					push af  
6b04 3a fb fa				ld a, (display_lcde1e2)  
6b07 fe 00				cp 0     ; e1  
6b09 20 0f				jr nz, .wfea2	  
6b0b f1					pop af  
6b0c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b0e cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6b10 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b12 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b14 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b16 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b18 18 0d			jr .wfskip  
6b1a f1			.wfea2:		pop af  
6b1b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b1d cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6b1f cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b21 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b23 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b25 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b27 3e 05		.wfskip:            LD  A, 5  
6b29 cd 30 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b2c f1			            POP  AF  
6b2d c9			            RET  
6b2e			  
6b2e			  
6b2e			; Delay in milliseconds  
6b2e			;   On entry: A = Number of milliseconds delay  
6b2e			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6b2e 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
6b30 d5			LCDDelay:   PUSH DE  
6b31 5f			            LD   E, A           ;Delay by 'A' ms  
6b32 16 00		            LD   D, 0  
6b34 cd 59 0a		            CALL aDelayInMS  
6b37 d1			            POP  DE  
6b38 c9			            RET  
