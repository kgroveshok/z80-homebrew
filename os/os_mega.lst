1588			; Sound abstraction layer 
1588			 
1588			; support different sound chips through common interface 
1588			 
1588			SOUND_DEVICE_AY: equ 0 
1588			 
1588			SOUND_DEVICE: equ Device_A 
1588			 
1588			if SOUND_DEVICE_AY 
1588				include "firmware_sound_ay38910.asm" 
1588			else 
1588				include "firmware_sound_sn76489an.asm" 
1588			 
1588			; Device support for SN76489AN sound chip 
1588			 
1588			; https://arduinoplusplus.wordpress.com/2019/10/05/making-noise-with-a-sn76489-digital-sound-generator-part-1/ 
1588			; http://danceswithferrets.org/geekblog/?p=93 
1588			; https://www.smspower.org/Development/SN76489 
1588			 
1588			; D0 [ 3] 
1588			; D1 [ 2] 
1588			; D2 [ 1] 
1588			; D3 [15] 
1588			; D4 [13] 
1588			; D5 [12] 
1588			; D6 [11] 
1588			; D7 [10] 
1588			; /WE [ 5] 
1588			; CLK [14] 
1588			; /OE [ 6] 
1588			; AUDIO [ 7] 
1588			; GND 8 
1588			; +5 16 
1588			; 
1588			 
1588			; Write sequence: 
1588			; CE low 
1588			; Data bus 
1588			; WE low then high 
1588			; 32 clock cycles / 8ns write time at 4mhz 
1588			; 
1588			; https://github.com/jblang/SN76489 
1588			; Shows that the clock needs to be enabled when required. Noticed that with the clock connected it interupted the bus 
1588			; Tried: 
1588			; 
1588			; CE/OE -> Both pins of NAND -> To one pin of second NAND and second pin to full clock -> CLK on chip 
1588			; 
1588			; Connected WE to OR too 
1588			;  
1588			; That enabled the clock when required 
1588			; However still random bus corruption. Need further investigation 
1588			 
1588			 
1588			SOUND_LATCH: equ 10000000B 
1588			SOUND_DATA: equ 0B 
1588			SOUND_CH0:  equ 0B    ; Tone 
1588			SOUND_CH1: equ 0100000B        ; Tone 
1588			SOUND_CH2: equ 1000000B   ; Tone 
1588			SOUND_CH3: equ 1100000B    ; Noise 
1588			SOUND_VOL: equ 10000B 
1588			SOUND_TONE: equ 0B 
1588			 
1588			 
1588			sound_init: 
1588 3e 1f			ld a, SOUND_DATA | SOUND_CH0 | SOUND_VOL | 1111B 
158a cd a5 15			call note_send_byte 
158d 3e 07			ld a, SOUND_DATA | SOUND_CH0 | SOUND_TONE | 0111B 
158f cd a5 15			call note_send_byte 
1592 cd 65 0a			call delay250ms 
1595 3e 05			ld a, SOUND_DATA | SOUND_CH0 | SOUND_TONE | 0101B 
1597 cd a5 15			call note_send_byte 
159a cd 65 0a			call delay250ms 
159d c9				ret 
159e			 
159e			; Play a note 
159e			; h = note 
159e			; l = duration 
159e			; a = channel 
159e			 
159e			 
159e			;  frequ = clock / ( 2 x reg valu x 32 )  
159e			 
159e			note: 
159e			 
159e c9				ret 
159f			 
159f			note_byte:  
159f 0e 00			ld c, SOUND_DEVICE 
15a1 7d				ld a, l 
15a2 ed 79			out (c), a	 
15a4			 
15a4 c9				ret 
15a5			 
15a5			 
15a5			note_send_byte: 
15a5				; byte in a 
15a5			 
15a5				; we high 
15a5 d3 00			out (SOUND_DEVICE), a 
15a7			;	ld a, 1 
15a7			;	call aDelayInMS 
15a7 00				nop  
15a8 00				nop  
15a9 00				nop  
15aa 00				nop  
15ab				; we low 
15ab d3 00			out (SOUND_DEVICE), a 
15ad			;	ld a, 1 
15ad			;	call aDelayInMS 
15ad 00				nop  
15ae 00				nop  
15af 00				nop  
15b0 00				nop  
15b1				; we high 
15b1 d3 00			out (SOUND_DEVICE), a 
15b3			;	ld a, 1 
15b3			;	call aDelayInMS 
15b3 00				nop  
15b4 00				nop  
15b5 00				nop  
15b6 00				nop  
15b7			 
15b7			 
15b7 c9				ret 
15b8			 
15b8			;void SilenceAllChannels() 
15b8			;{ 
15b8			;  SendByte(0x9f); 
15b8			;  SendByte(0xbf); 
15b8			;  SendByte(0xdf); 
15b8			;  SendByte(0xff); 
15b8			;} 
15b8			 
15b8			note_silence: 
15b8 0e 00			ld c, SOUND_DEVICE 
15ba 3e 9f			ld a, 0x9f 
15bc ed 79			out (c), a 
15be			 
15be 3e bf			ld a, 0xbf 
15c0 ed 79			out (c), a 
15c2			 
15c2 3e df			ld a, 0xdf 
15c4 ed 79			out (c), a 
15c6			 
15c6 3e ff			ld a, 0xff 
15c8 ed 79			out (c), a 
15ca c9				ret 
15cb			; eof 
15cb			 
# End of file firmware_sound_sn76489an.asm
15cb			endif 
