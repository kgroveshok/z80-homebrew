43e4			.CARTDEV: 
43e4				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
43e4			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
43e4			; | | Set to zero to disable devices. 
43e4					if DEBUG_FORTH_WORDS_KEY 
43e4						DMARK "CDV" 
43e4						CALLMONITOR 
43e4					endif 
43e4			 
43e4					; disable se storage bank selection 
43e4			 
43e4					ld a, SPI_CE_HIGH		; ce high 
43e4					ld (spi_device), a 
43e4			 
43e4					; get bank 
43e4			 
43e4					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43e4			 
43e4			;		push hl 
43e4			 
43e4					; destroy value TOS 
43e4			 
43e4					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43e4			 
43e4					; one value on hl get other one back 
43e4			 
43e4			;		pop hl 
43e4			 
43e4					; active low 
43e4			 
43e4					ld c, 255 
43e4			 
43e4					ld a, l 
43e4					if DEBUG_FORTH_WORDS 
43e4						DMARK "CDV" 
43e4						CALLMONITOR 
43e4					endif 
43e4			;		cp 0 
43e4					or a 
43e4					jr z, .cset 
43e4					cp 1 
43e4					jr nz, .c2 
43e4					res 0, c 
43e4			.c2:		cp 2 
43e4					jr nz, .c3 
43e4					res 1, c 
43e4			.c3:		cp 3 
43e4					jr nz, .c4 
43e4					res 2, c 
43e4			.c4:		cp 4 
43e4					jr nz, .c5 
43e4					res 3, c 
43e4			.c5:		cp 5 
43e4					jr nz, .c6 
43e4					res 4, c 
43e4			.c6:		cp 6 
43e4					jr nz, .c7 
43e4					res 5, c 
43e4			.c7:		cp 7 
43e4					jr nz, .c8 
43e4					res 6, c 
43e4			.c8:		cp 8 
43e4					jr nz, .cset 
43e4					res 7, c 
43e4			.cset:		ld a, c 
43e4					ld (spi_cartdev),a 
43e4			 
43e4					if DEBUG_FORTH_WORDS 
43e4						DMARK "CD2" 
43e4						CALLMONITOR 
43e4					endif 
43e4			 
43e4					; set default SPI clk pulse time as 10ms for CARTDEV use 
43e4			 
43e4					ld a, $0a 
43e4					ld (spi_clktime), a 
43e4					NEXTW 
43e4			endif 
