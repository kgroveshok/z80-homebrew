8e21			;   +4  +-------------+                                                       : 
8e21			;       |  this_free  |                                                       : 
8e21			;   +2  +-------------+                                                       : 
8e21			;       |  next_free  |                                                       : 
8e21			;   +0  +-------------+                                                       : 
