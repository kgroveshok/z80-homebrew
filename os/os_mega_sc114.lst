897b			; 
897b			 
897b			; 16-bit xorshift pseudorandom number generator by John Metcalf 
897b			; 20 bytes, 86 cycles (excluding ret) 
897b			 
897b			; returns   hl = pseudorandom number 
897b			; corrupts   a 
897b			 
897b			; generates 16-bit pseudorandom numbers with a period of 65535 
897b			; using the xorshift method: 
897b			 
897b			; hl ^= hl << 7 
897b			; hl ^= hl >> 9 
897b			; hl ^= hl << 8 
897b			 
897b			; some alternative shift triplets which also perform well are: 
897b			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
897b			 
897b			;  org 32768 
897b			 
897b			xrnd: 
897b 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
897e 3e 00		  ld a,0 
8980 bd			  cp l 
8981 20 02		  jr nz, .xrnd1 
8983 2e 01		  ld l, 1 
8985			.xrnd1: 
8985			 
8985 7c			  ld a,h 
8986 1f			  rra 
8987 7d			  ld a,l 
8988 1f			  rra 
8989 ac			  xor h 
898a 67			  ld h,a 
898b 7d			  ld a,l 
898c 1f			  rra 
898d 7c			  ld a,h 
898e 1f			  rra 
898f ad			  xor l 
8990 6f			  ld l,a 
8991 ac			  xor h 
8992 67			  ld h,a 
8993			 
8993 22 9e eb		  ld (xrandc),hl 
8996			 
8996 c9			  ret 
