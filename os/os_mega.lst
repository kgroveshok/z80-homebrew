6a2e			  
6a2e			; **********************************************************************  
6a2e			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6a2e			; **********************************************************************  
6a2e			;  
6a2e			; **  Written as a Small Computer Monitor App   
6a2e			; **  Version 0.1 SCC 2018-05-16  
6a2e			; **  www.scc.me.uk  
6a2e			;  
6a2e			; **********************************************************************  
6a2e			;  
6a2e			; This module provides support for alphanumeric LCD modules using with  
6a2e			; *  HD44780 (or compatible) controller  
6a2e			; *  5 x 7 pixel fonts  
6a2e			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6a2e			; *  Interface via six digital outputs to the display (see below)  
6a2e			;  
6a2e			; LCD module pinout:  
6a2e			;   1  Vss   0v supply  
6a2e			;   2  Vdd   5v supply  
6a2e			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6a2e			;   4  RS    High = data, Low = instruction  
6a2e			;   5  R/W   High = Read, Low = Write  
6a2e			;   6  E     Enable signal (active high)  
6a2e			;   7  DB0   Data bit 0  
6a2e			;   8  DB1   Data bit 1  
6a2e			;   9  DB2   Data bit 2  
6a2e			;  10  DB3   Data bit 3  
6a2e			;  11  DB4   Data bit 4  
6a2e			;  12  DB5   Data bit 5  
6a2e			;  13  DB6   Data bit 6  
6a2e			;  14  DB7   Data bit 7  
6a2e			;  15  A     Backlight anode (+)  
6a2e			;  16  K     Backlight cathode (-)  
6a2e			;  
6a2e			; This interfacing method uses 4-bit data mode and uses time delays  
6a2e			; rather than polling the display's ready status. As a result the   
6a2e			; interface only requires 6 simple output lines:  
6a2e			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6a2e			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6a2e			;   LCD DB4 = Microcomputer output port bit 4  
6a2e			;   LCD DB5 = Microcomputer output port bit 5  
6a2e			;   LCD DB6 = Microcomputer output port bit 6  
6a2e			;   LCD DB7 = Microcomputer output port bit 7  
6a2e			; Display's R/W is connected to 0v so it is always in write mode  
6a2e			; All 6 connections must be on the same port address <kLCDPrt>  
6a2e			; This method also allows a decent length of cable from micro to LCD  
6a2e			;  
6a2e			; **********************************************************************  
6a2e			;  
6a2e			; To include the code for any given function provided by this module,   
6a2e			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6a2e			; the parent source file.  
6a2e			; For example:  #REQUIRES   uHexPrefix  
6a2e			;  
6a2e			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6a2e			; in the parent source file.  
6a2e			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6a2e			;  
6a2e			; These are the function names provided by this module:  
6a2e			; fLCD_Init                     ;Initialise LCD  
6a2e			; fLCD_Inst                     ;Send instruction to LCD  
6a2e			; fLCD_Data                     ;Send data byte to LCD  
6a2e			; fLCD_Pos                      ;Position cursor  
6a2e			; fLCD_Str                      ;Display string  
6a2e			; fLCD_Def                      ;Define custom character  
6a2e			;  
6a2e			; **********************************************************************  
6a2e			;  
6a2e			; Requires SCMonAPI.asm to also be included in the project  
6a2e			;  
6a2e			  
6a2e			  
6a2e			; **********************************************************************  
6a2e			; **  Constants  
6a2e			; **********************************************************************  
6a2e			  
6a2e			; Constants that must be defined externally  
6a2e			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6a2e			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6a2e			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6a2e			;kLCDWidth: EQU 20             ;Width in characters  
6a2e			  
6a2e			; general line offsets in any frame buffer  
6a2e			  
6a2e			  
6a2e			display_row_1: equ 0  
6a2e			display_row_2: equ display_row_1+display_cols  
6a2e			display_row_3: equ display_row_2 + display_cols  
6a2e			display_row_4: equ display_row_3 + display_cols  
6a2e			;display_row_4_eol:   
6a2e			  
6a2e			  
6a2e			; Cursor position values for the start of each line  
6a2e			  
6a2e			; E  
6a2e			kLCD_Line1: EQU 0x00   
6a2e			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6a2e			; E1  
6a2e			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6a2e			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6a2e			  
6a2e			; Instructions to send as A register to fLCD_Inst  
6a2e			kLCD_Clear: EQU 00000001b     ;LCD clear  
6a2e			kLCD_Off:   EQU 00001000b     ;LCD off  
6a2e			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6a2e			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6a2e			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6a2e			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6a2e			  
6a2e			; Constants used by this code module  
6a2e			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6a2e			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6a2e			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6a2e			  
6a2e			  
6a2e			  
6a2e			; **********************************************************************  
6a2e			; **  LCD support functions  
6a2e			; **********************************************************************  
6a2e			  
6a2e			; Initialise alphanumeric LCD module  
6a2e			; LCD control register codes:  
6a2e			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6a2e			;   N    0 = 1-line mode       1 = 2-line mode  
6a2e			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6a2e			;   D    0 = Display off       1 = Display on  
6a2e			;   C    0 = Cursor off        1 = Cursor on  
6a2e			;   B    0 = Blinking off      1 = Blinking on  
6a2e			;   ID   0 = Decrement mode    1 = Increment mode  
6a2e			;   SH   0 = Entire shift off  1 = Entire shift on  
6a2e 3e 28		fLCD_Init:  LD   A, 40  
6a30 cd 55 6b		            CALL LCDDelay       ;Delay 40ms after power up  
6a33			; For reliable reset set 8-bit mode - 3 times  
6a33 cd 25 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a36 cd 25 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a39 cd 25 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a3c			; Set 4-bit mode  
6a3c cd 21 6b		            CALL WrFn4bit       ;Function = 4-bit mode  
6a3f cd 53 6b		            CALL LCDDelay1      ;Delay 37 us or more  
6a42			; Function set  
6a42 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6a44 cd 57 6a		            CALL fLCD_Inst      ;2 line, display on  
6a47			; Display On/Off control  
6a47 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6a49 cd 57 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6a4c			; Display Clear  
6a4c 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6a4e cd 57 6a		            CALL fLCD_Inst      ;Clear display  
6a51			; Entry mode  
6a51 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6a53 cd 57 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
6a56			; Display module now initialised  
6a56 c9			            RET  
6a57			; ok to here  
6a57			  
6a57			; Write instruction to LCD  
6a57			;   On entry: A = Instruction byte to be written  
6a57			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a57 f5			fLCD_Inst:  PUSH AF  
6a58 f5			            PUSH AF  
6a59 cd 6b 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a5c f1			            POP  AF  
6a5d 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
