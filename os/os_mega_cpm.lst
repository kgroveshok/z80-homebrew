5a30			; handle the auto run of code from files in storage 
5a30			 
5a30			 
5a30			include "forth_startup.asm" 
5a30			; Which startup method to use? 
5a30			; 
5a30			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
5a30			; followed by loading of a list of scripts in eeprom 
5a30			 
5a30			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
5a30			; from eeprom 
5a30			 
5a30			; Select with define in main stubs 
5a30			 
5a30			if STARTUP_V1 
5a30				include "forth_startupv1.asm" 
5a30			; Startup script loading version 1 
5a30			 
5a30			; If SE storage is available first stage is to use the selected file 
5a30			; then go through the eeprom list 
5a30			 
5a30 .. 00		sprompt1: db "Startup load...",0 
5a40 .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
