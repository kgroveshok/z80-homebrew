4428			 
4428					call tape_calibration 
4428			 
4428					NEXTW 
4428			 
4428			.TTEST: 
4428				CWHEAD .TAPEEND 31 "TAPETEST" 8 WORD_FLAG_CODE 
4428			; | TAPETEST (  -- )    Record a repeating stripe pattern of 0 and 1 for testing record and playback via TAPECAL | TO DO 
4428					if DEBUG_FORTH_WORDS_KEY 
4428						DMARK "TTS" 
4428						CALLMONITOR 
4428					endif 
4428			 
4428					call tape_test 
4428			 
4428					NEXTW 
4428			 
4428			.TAPEEND: 
4428			endif 
