8de2			;      jp    main 
8de2			 
8de2			 
8de2			;      .org  0x100 
8de2			;main: 
8de2			;      ld    HL, 0x8100 
8de2			;      ld    SP, HL 
8de2			; 
8de2			;      call  heap_init 
8de2			; 
8de2			;      ; Make some allocations 
8de2			;      ld    HL, 12 
8de2			;      call  malloc            ; Allocates 0x9004 
8de2			; 
8de2			;      ld    HL, 12 
8de2			;      call  malloc            ; Allocates 0x9014 
8de2			; 
8de2			;      ld    HL, 12 
8de2			;      call  malloc            ; Allocates 0x9024 
8de2			; 
8de2			;      ; Free some allocations 
8de2			;      ld    HL, 0x9014 
8de2			;      call  free 
8de2			; 
8de2			;      ld    HL, 0x9004 
8de2			;      call  free 
8de2			; 
8de2			;      ld    HL, 0x9024 
8de2			;      call  free 
8de2			; 
8de2			; 
8de2			;      halt 
8de2			 
8de2			 
8de2			;------------------------------------------------------------------------------ 
8de2			;     heap_init                                                               : 
8de2			;                                                                             : 
8de2			; Description                                                                 : 
8de2			;     Initialise the heap and make it ready for malloc and free operations.   : 
8de2			;                                                                             : 
8de2			;     The heap is maintained as a linked list, starting with an initial       : 
8de2			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8de2			;     the first free block in the heap. Each block then points to the next    : 
8de2			;     free block within the heap, and the free list ends at the first block   : 
8de2			;     with a null pointer to the next free block.                             : 
8de2			;                                                                             : 
8de2			; Parameters                                                                  : 
8de2			;     Inputs are compile-time only. Two defines which specify the starting    : 
8de2			;     address of the heap and its size are required, along with a memory      : 
8de2			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8de2			;     principally stores a pointer to the first free block in the heap.       : 
8de2			;                                                                             : 
8de2			; Returns                                                                     : 
8de2			;     Nothing                                                                 : 
8de2			;------------------------------------------------------------------------------ 
8de2			heap_init: 
8de2 e5			      push  HL 
8de3			 
8de3			      ; Initialise free list struct 
8de3 21 45 d6		      ld    HL, heap_start 
8de6 22 40 d6		      ld    (free_list), HL 
8de9 21 00 00		      ld    HL, 0 
8dec 22 42 d6		      ld    (free_list+2), HL 
8def			 
8def			      ; Insert first free block at bottom of heap, consumes entire heap 
8def 21 7c e2		      ld    HL, heap_start+heap_size-4 
8df2 22 45 d6		      ld    (heap_start), HL        ; Next block (end of free list) 
8df5 21 37 0c		      ld    HL, heap_size-4 
8df8 22 47 d6		      ld    (heap_start+2), HL      ; Block size 
8dfb			 
8dfb			      ; Insert end of free list block at top of heap - two null words will 
8dfb			      ; terminate the free list 
8dfb 21 00 00		      ld    HL, 0 
8dfe 22 7e e2		      ld    (heap_start+heap_size-2), HL 
8e01 22 7c e2		      ld    (heap_start+heap_size-4), HL 
8e04			 
8e04 e1			      pop   HL 
8e05			 
8e05 c9			      ret 
8e06			 
8e06			 
8e06			;------------------------------------------------------------------------------ 
8e06			;     malloc                                                                  : 
8e06			;                                                                             : 
8e06			; Description                                                                 : 
8e06			;     Allocates the wanted space from the heap and returns the address of the : 
8e06			;     first useable byte of the allocation.                                   : 
8e06			;                                                                             : 
8e06			;     Allocations can happen in one of two ways:                              : 
8e06			;                                                                             : 
8e06			;     1. A free block may be found which is the exact size wanted. In this    : 
8e06			;        case the block is removed from the free list and retuedn to the      : 
8e06			;        caller.                                                              : 
8e06			;     2. A free block may be found which is larger than the size wanted. In   : 
8e06			;        this case, the larger block is split into two. The first portion of  : 
8e06			;        this block will become the requested space by the malloc call and    : 
8e06			;        is returned to the caller. The second portion becomes a new free     : 
8e06			;        block, and the free list is adjusted to maintain continuity via this : 
8e06			;        newly created block.                                                 : 
8e06			;                                                                             : 
8e06			;     malloc does not set any initial value in the allocated space, the       : 
8e06			;     caller is required to do this as required.                              : 
8e06			;                                                                             : 
8e06			;     This implementation of malloc uses the stack exclusively, and is        : 
8e06			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8e06			;     advisable to disable interrupts before calling malloc, and recommended  : 
8e06			;     to avoid the use of malloc inside ISRs in general.                      : 
8e06			;                                                                             : 
8e06			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8e06			;                                                                             : 
8e06			; Parameters                                                                  : 
8e06			;     HL  Number of bytes wanted                                              : 
8e06			;                                                                             : 
8e06			; Returns                                                                     : 
8e06			;     HL  Address of the first useable byte of the allocation                 : 
8e06			;                                                                             : 
8e06			; Flags                                                                       : 
8e06			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8e06			;                                                                             : 
8e06			; Stack frame                                                                 : 
8e06			;       |             |                                                       : 
8e06			;       +-------------+                                                       : 
8e06			;       |     BC      |                                                       : 
8e06			;       +-------------+                                                       : 
8e06			;       |     DE      |                                                       : 
8e06			;       +-------------+                                                       : 
8e06			;       |     IX      |                                                       : 
8e06			;       +-------------+                                                       : 
8e06			;       |  prev_free  |                                                       : 
8e06			;   +4  +-------------+                                                       : 
8e06			;       |  this_free  |                                                       : 
8e06			;   +2  +-------------+                                                       : 
8e06			;       |  next_free  |                                                       : 
8e06			;   +0  +-------------+                                                       : 
8e06			;       |             |                                                       : 
8e06			;                                                                             : 
8e06			;------------------------------------------------------------------------------ 
