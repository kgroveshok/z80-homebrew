20ba			 
20ba			; forth parser 
20ba			 
20ba			; My forth kernel 
20ba			include "forth_kernel.asm" 
20ba			; 
20ba			; kernel to the forth OS 
20ba			 
20ba			DS_TYPE_STR: equ 1     ; string type 
20ba			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
20ba			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
20ba			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
20ba			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
20ba			 
20ba			FORTH_PARSEV1: equ 0 
20ba			FORTH_PARSEV2: equ 0 
20ba			FORTH_PARSEV3: equ 0 
20ba			FORTH_PARSEV4: equ 0 
20ba			FORTH_PARSEV5: equ 0 
20ba			FORTH_PARSEV6: equ 1 
20ba			 
20ba			;if FORTH_PARSEV5 
20ba			;	FORTH_END_BUFFER: equ 0 
20ba			;else 
20ba			FORTH_END_BUFFER: equ 127 
20ba			;endif 
20ba			 
20ba			FORTH_TRUE: equ 1 
20ba			FORTH_FALSE: equ 0 
20ba			 
20ba			if FORTH_PARSEV4 
20ba			include "forth_stackops.asm" 
20ba			endif 
20ba			 
20ba			if FORTH_PARSEV5 
20ba			include "forth_stackopsv5.asm" 
20ba			endif 
20ba			 
20ba			if FORTH_PARSEV6 
20ba			include "forth_stackopsv5.asm" 
20ba			 
20ba			; Stack operations for v5 parser on wards 
20ba			; * DATA stack 
20ba			; * LOOP stack 
20ba			; * RETURN stack 
20ba			 
20ba			 
20ba			 
20ba			FORTH_CHK_DSP_UNDER: macro 
20ba				push hl 
20ba				push de 
20ba				ld hl,(cli_data_sp) 
20ba				ld de, cli_data_stack 
20ba				call cmp16 
20ba				jp c, fault_dsp_under 
20ba				pop de 
20ba				pop hl 
20ba				endm 
20ba			 
20ba			 
20ba			FORTH_CHK_RSP_UNDER: macro 
20ba				push hl 
20ba				push de 
20ba				ld hl,(cli_ret_sp) 
20ba				ld de, cli_ret_stack 
20ba				call cmp16 
20ba				jp c, fault_rsp_under 
20ba				pop de 
20ba				pop hl 
20ba				endm 
20ba			 
20ba			FORTH_CHK_LOOP_UNDER: macro 
20ba				push hl 
20ba				push de 
20ba				ld hl,(cli_loop_sp) 
20ba				ld de, cli_loop_stack 
20ba				call cmp16 
20ba				jp c, fault_loop_under 
20ba				pop de 
20ba				pop hl 
20ba				endm 
20ba			 
20ba			FORTH_ERR_TOS_NOTSTR: macro 
20ba				; TOSO might need more for checks when used 
20ba				push af 
20ba				ld a,(hl) 
20ba				cp DS_TYPE_STR 
20ba				jp nz, type_faultn   
20ba				pop af 
20ba				endm 
20ba			 
20ba			FORTH_ERR_TOS_NOTNUM: macro 
20ba				push af 
20ba				ld a,(hl) 
20ba				cp DS_TYPE_INUM 
20ba				jp nz, type_faultn   
20ba				pop af 
20ba				endm 
20ba			 
20ba			 
20ba			; increase data stack pointer and save hl to it 
20ba				 
20ba			FORTH_DSP_NEXT: macro 
20ba				call macro_forth_dsp_next 
20ba				endm 
20ba			 
20ba			 
20ba			macro_forth_dsp_next: 
20ba				if DEBUG_FORTH_STACK_GUARD 
20ba cd 72 65				call check_stacks 
20bd				endif 
20bd e5				push hl 
20be d5				push de 
20bf eb				ex de,hl 
20c0 2a 05 f9			ld hl,(cli_data_sp) 
20c3 23				inc hl 
20c4 23				inc hl 
20c5			 
20c5			; PARSEV5 
20c5 23				inc hl 
20c6 22 05 f9			ld (cli_data_sp),hl 
20c9 73				ld (hl), e 
20ca 23				inc hl 
20cb 72				ld (hl), d 
20cc d1				pop de 
20cd e1				pop hl 
20ce				if DEBUG_FORTH_STACK_GUARD 
20ce cd 72 65				call check_stacks 
20d1				endif 
20d1 c9				ret 
20d2			 
20d2			 
20d2			; increase ret stack pointer and save hl to it 
20d2				 
20d2			FORTH_RSP_NEXT: macro 
20d2				call macro_forth_rsp_next 
20d2				endm 
20d2			 
20d2			macro_forth_rsp_next: 
20d2				if DEBUG_FORTH_STACK_GUARD 
20d2 cd 72 65				call check_stacks 
20d5				endif 
20d5 e5				push hl 
20d6 d5				push de 
20d7 eb				ex de,hl 
20d8 2a 09 f9			ld hl,(cli_ret_sp) 
20db 23				inc hl 
20dc 23				inc hl 
20dd 22 09 f9			ld (cli_ret_sp),hl 
20e0 73				ld (hl), e 
20e1 23				inc hl 
20e2 72				ld (hl), d 
20e3 d1				pop de 
20e4 e1				pop hl 
20e5				if DEBUG_FORTH_STACK_GUARD 
20e5 cd 72 65				call check_stacks 
20e8				endif 
20e8 c9				ret 
20e9			 
20e9			; get current ret stack pointer and save to hl  
