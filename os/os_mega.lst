0d7b			;;This divides DE by BC, storing the result in DE, remainder in HL 
0d7b			; 
0d7b			;DE_Div_BC:          ;1281-2x, x is at most 16 
0d7b			;     ld a,16        ;7 
0d7b			;     ld hl,0        ;10 
0d7b			;     jp $+5         ;10 
0d7b			;.DivLoop: 
