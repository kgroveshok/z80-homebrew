14e2			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
14e2			;                  .dw   0 
14e2			 
14e2			 
14e2			endif 
14e2			 
14e2			 
14e2			if MALLOC_3 
14e2			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
14e2			;heap_start        .equ  0x9000      ; Starting address of heap 
14e2			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
14e2			; 
14e2			 ;     .org 0 
14e2			  ;    jp    main 
14e2			; 
14e2			; 
14e2			 ;     .org  0x100 
14e2			;main: 
14e2			 ;     ld    HL, 0x8100 
14e2			  ;    ld    SP, HL 
14e2			; 
14e2			;      call  heap_init 
14e2			 
14e2			      ; Make some allocations 
14e2			;      ld    HL, 12 
14e2			;      call  malloc            ; Allocates 0x9004 
14e2			; 
14e2			 ;     ld    HL, 12 
14e2			;      call  malloc            ; Allocates 0x9014 
14e2			 
14e2			;      ld    HL, 12 
14e2			;      call  malloc            ; Allocates 0x9024 
14e2			 
14e2			      ; Free some allocations 
14e2			;      ld    HL, 0x9014 
14e2			;      call  free 
14e2			 
14e2			;      ld    HL, 0x9004 
14e2			;      call  free 
14e2			; 
14e2			;      ld    HL, 0x9024 
14e2			;      call  free 
14e2			 
14e2			 
14e2			 ;     halt 
14e2			 
14e2			 
14e2			;------------------------------------------------------------------------------ 
14e2			;     heap_init                                                               : 
14e2			;                                                                             : 
14e2			; Description                                                                 : 
14e2			;     Initialise the heap and make it ready for malloc and free operations.   : 
14e2			;                                                                             : 
14e2			;     The heap is maintained as a linked list, starting with an initial       : 
14e2			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
14e2			;     the first free block in the heap. Each block then points to the next    : 
14e2			;     free block within the heap, and the free list ends at the first block   : 
14e2			;     with a null pointer to the next free block.                             : 
14e2			;                                                                             : 
14e2			; Parameters                                                                  : 
14e2			;     Inputs are compile-time only. Two defines which specify the starting    : 
14e2			;     address of the heap and its size are required, along with a memory      : 
14e2			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
14e2			;     principally stores a pointer to the first free block in the heap.       : 
14e2			;                                                                             : 
14e2			; Returns                                                                     : 
14e2			;     Nothing                                                                 : 
14e2			;------------------------------------------------------------------------------ 
14e2			heap_init: 
14e2			      push  HL 
14e2			 
14e2			      ; Initialise free list struct 
14e2			      ld    HL, heap_start 
14e2			      ld    (free_list), HL 
14e2			      ld    HL, 0 
14e2			      ld    (free_list+2), HL 
14e2			 
14e2			      ; Insert first free block at bottom of heap, consumes entire heap 
14e2			      ld    HL, heap_start+heap_size-4 
14e2			      ld    (heap_start), HL        ; Next block (end of free list) 
14e2			      ld    HL, heap_size-4 
14e2			      ld    (heap_start+2), HL      ; Block size 
14e2			 
14e2			      ; Insert end of free list block at top of heap - two null words will 
14e2			      ; terminate the free list 
14e2			      ld    HL, 0 
14e2			      ld    (heap_start+heap_size-2), HL 
14e2			      ld    (heap_start+heap_size-4), HL 
14e2			 
14e2			      pop   HL 
14e2			 
14e2			      ret 
14e2			 
14e2			 
14e2			;------------------------------------------------------------------------------ 
14e2			;     malloc                                                                  : 
14e2			;                                                                             : 
14e2			; Description                                                                 : 
14e2			;     Allocates the wanted space from the heap and returns the address of the : 
14e2			;     first useable byte of the allocation.                                   : 
14e2			;                                                                             : 
14e2			;     Allocations can happen in one of two ways:                              : 
14e2			;                                                                             : 
14e2			;     1. A free block may be found which is the exact size wanted. In this    : 
14e2			;        case the block is removed from the free list and retuedn to the      : 
14e2			;        caller.                                                              : 
14e2			;     2. A free block may be found which is larger than the size wanted. In   : 
14e2			;        this case, the larger block is split into two. The first portion of  : 
14e2			;        this block will become the requested space by the malloc call and    : 
14e2			;        is returned to the caller. The second portion becomes a new free     : 
14e2			;        block, and the free list is adjusted to maintain continuity via this : 
14e2			;        newly created block.                                                 : 
14e2			;                                                                             : 
14e2			;     malloc does not set any initial value in the allocated space, the       : 
14e2			;     caller is required to do this as required.                              : 
14e2			;                                                                             : 
14e2			;     This implementation of malloc uses the stack exclusively, and is        : 
14e2			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
14e2			;     advisable to disable interrupts before calling malloc, and recommended  : 
14e2			;     to avoid the use of malloc inside ISRs in general.                      : 
14e2			;                                                                             : 
14e2			;     NOTE: heap_init must be called before malloc and free can be used.      : 
14e2			;                                                                             : 
14e2			; Parameters                                                                  : 
14e2			;     HL  Number of bytes wanted                                              : 
14e2			;                                                                             : 
14e2			; Returns                                                                     : 
14e2			;     HL  Address of the first useable byte of the allocation                 : 
14e2			;                                                                             : 
14e2			; Flags                                                                       : 
14e2			;     Z   Set if the allocation did not succeed, clear otherwise              : 
14e2			;                                                                             : 
14e2			; Stack frame                                                                 : 
14e2			;       |             |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |     BC      |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |     DE      |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |     IX      |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |  prev_free  |                                                       : 
14e2			;   +4  +-------------+                                                       : 
14e2			;       |  this_free  |                                                       : 
14e2			;   +2  +-------------+                                                       : 
14e2			;       |  next_free  |                                                       : 
14e2			;   +0  +-------------+                                                       : 
14e2			;       |             |                                                       : 
14e2			;                                                                             : 
14e2			;------------------------------------------------------------------------------ 
14e2			malloc: 
14e2			      push  BC 
14e2			      push  DE 
14e2			      push  IX 
14e2			 
14e2			      ld    A, H                    ; Exit if no space requested 
14e2			      or    L 
14e2			      jp    Z, malloc_early_exit 
14e2			 
14e2			      ; Set up stack frame 
14e2			      ex    DE, HL 
14e2			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
14e2			      add   HL, SP 
14e2			      ld    SP, HL 
14e2			      ld    IX, 0                   ; Use IX as a frame pointer 
14e2			      add   IX, SP 
14e2			 
14e2			      ; Setup initial state 
14e2			      ld    HL, 4                   ; want must also include space used by block struct 
14e2			      add   HL, DE 
14e2			 
14e2			      ld    B, H                    ; Move want to BC 
14e2			      ld    C, L 
14e2			 
14e2			      ld    HL, free_list           ; Store prev_free ptr to stack 
14e2			      ld    (IX+4), L 
14e2			      ld    (IX+5), H 
14e2			 
14e2			      ld    E, (HL)                 ; Store this_free ptr to stack 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      ld    (IX+2), E 
14e2			      ld    (IX+3), D 
14e2			      ex    DE, HL                  ; this_free ptr into HL 
14e2			 
14e2			      ; Loop through free block list to find some space 
14e2			malloc_find_space: 
14e2			      ld    E, (HL)                 ; Load next_free ptr into DE 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			 
14e2			      ld    A, D                    ; Check for null next_free ptr - end of free list 
14e2			      or    E 
14e2			      jp    Z, malloc_no_space 
14e2			 
14e2			      ld    (IX+0), E               ; Store next_free ptr to stack 
14e2			      ld    (IX+1), D 
14e2			 
14e2			      ; Does this block have enough space to make the allocation? 
14e2			      inc   HL                      ; Load free block size into DE 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			 
14e2			      ex    DE, HL                  ; Check size of block against want 
14e2			      or    A                       ; Ensure carry flag clear 
14e2			      sbc   HL, BC 
14e2			      push  HL                      ; Store the result for later (new block size) 
14e2			 
14e2			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
14e2			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
14e2			 
14e2			      ; this_free block is not big enough, setup ptrs to test next free block 
14e2			      pop   HL                      ; Discard previous result 
14e2			 
14e2			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
14e2			      ld    H, (IX+3) 
14e2			      ld    (IX+4), L 
14e2			      ld    (IX+5), H 
14e2			 
14e2			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
14e2			      ld    H, (IX+1) 
14e2			      ld    (IX+2), L 
14e2			      ld    (IX+3), H 
14e2			 
14e2			      jr    malloc_find_space 
14e2			 
14e2			      ; split a bigger block into two - requested size and remaining size 
14e2			malloc_alloc_split: 
14e2			      ex    DE, HL                  ; Calculate address of new free block 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			      add   HL, BC 
14e2			 
14e2			      ; Create a new block and point it at next_free 
14e2			      ld    E, (IX+0)               ; Load next_free ptr into DE 
14e2			      ld    D, (IX+1) 
14e2			 
14e2			      ld    (HL), E                 ; Store next_free ptr into new block 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			      pop   DE                      ; Store size of new block into new block 
14e2			      inc   HL 
14e2			      ld    (HL), E 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			      ; Update this_free ptr to point to new block 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			 
14e2			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
14e2			      ld    D, (IX+3) 
14e2			 
14e2			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
14e2			      ld    (IX+3), H 
14e2			 
14e2			      ; Modify this_free block to be allocation 
14e2			      ex    DE, HL 
14e2			      xor   A                       ; Null the next block ptr of allocated block 
14e2			      ld    (HL), A 
14e2			      inc   HL 
14e2			      ld    (HL), A 
14e2			 
14e2			      inc   HL                      ; Store want size into allocated block 
14e2			      ld    (HL), C 
14e2			      inc   HL 
14e2			      ld    (HL), B 
14e2			      inc   HL 
14e2			      push  HL                      ; Address of allocation to return 
14e2			 
14e2			      jr    malloc_update_links 
14e2			 
14e2			malloc_alloc_fit: 
14e2			      pop   HL                      ; Dont need new block size, want is exact fit 
14e2			 
14e2			      ; Modify this_free block to be allocation 
14e2			      ex    DE, HL 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			 
14e2			      xor   A                       ; Null the next block ptr of allocated block 
14e2			      ld    (HL), A 
14e2			      inc   HL 
14e2			      ld    (HL), A 
14e2			 
14e2			      inc   HL                      ; Store address of allocation to return 
14e2			      inc   HL 
14e2			      inc   HL 
14e2			      push  HL 
14e2			 
14e2			      ; Copy next_free ptr to this_free, remove allocated block from free list 
14e2			      ld    L, (IX+0)               ; next_free to HL 
14e2			      ld    H, (IX+1) 
14e2			 
14e2			      ld    (IX+2), L               ; HL to this_free 
14e2			      ld    (IX+3), H 
14e2			 
14e2			 
14e2			malloc_update_links: 
14e2			      ; Update prev_free ptr to point to this_free 
14e2			      ld    L, (IX+4)               ; prev_free ptr to HL 
14e2			      ld    H, (IX+5) 
14e2			 
14e2			      ld    E, (IX+2)               ; this_free ptr to DE 
14e2			      ld    D, (IX+3) 
14e2			 
14e2			      ld    (HL), E                 ; this_free ptr into prev_free 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			      ; Clear the Z flag to indicate successful allocation 
14e2			      ld    A, D 
14e2			      or    E 
14e2			 
14e2			      pop   DE                      ; Address of allocation 
14e2			 
14e2			malloc_no_space: 
14e2			      ld    HL, 6                   ; Clean up stack frame 
14e2			      add   HL, SP 
14e2			      ld    SP, HL 
14e2			 
14e2			      ex    DE, HL                  ; Alloc addr into HL for return 
14e2			 
14e2			malloc_early_exit: 
14e2			      pop   IX 
14e2			      pop   DE 
14e2			      pop   BC 
14e2			 
14e2			      ret 
14e2			 
14e2			 
14e2			;------------------------------------------------------------------------------ 
14e2			;     free                                                                    : 
14e2			;                                                                             : 
14e2			; Description                                                                 : 
14e2			;     Return the space pointed to by HL to the heap. HL must be an address as : 
14e2			;     returned by malloc, otherwise the behaviour is undefined.               : 
14e2			;                                                                             : 
14e2			;     Where possible, directly adjacent free blocks will be merged together   : 
14e2			;     into larger blocks to help ensure that the heap does not become         : 
14e2			;     excessively fragmented.                                                 : 
14e2			;                                                                             : 
14e2			;     free does not clear or set any other value into the freed space, and    : 
14e2			;     therefore its contents may be visible through subsequent malloc's. The  : 
14e2			;     caller should clear the freed space as required.                        : 
14e2			;                                                                             : 
14e2			;     This implementation of free uses the stack exclusively, and is          : 
14e2			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
14e2			;     advisable to disable interrupts before calling free, and recommended    : 
14e2			;     to avoid the use of free inside ISRs in general.                        : 
14e2			;                                                                             : 
14e2			;     NOTE: heap_init must be called before malloc and free can be used.      : 
14e2			;                                                                             : 
14e2			; Parameters                                                                  : 
14e2			;     HL  Pointer to address of first byte of allocation to be freed          : 
14e2			;                                                                             : 
14e2			; Returns                                                                     : 
14e2			;     Nothing                                                                 : 
14e2			;                                                                             : 
14e2			; Stack frame                                                                 : 
14e2			;       |             |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |     BC      |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |     DE      |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |     IX      |                                                       : 
14e2			;       +-------------+                                                       : 
14e2			;       |  prev_free  |                                                       : 
14e2			;   +2  +-------------+                                                       : 
14e2			;       |  next_free  |                                                       : 
14e2			;   +0  +-------------+                                                       : 
14e2			;       |             |                                                       : 
14e2			;                                                                             : 
14e2			;------------------------------------------------------------------------------ 
14e2			free: 
14e2			      push  BC 
14e2			      push  DE 
14e2			      push  IX 
14e2			 
14e2			      ld    A, H                    ; Exit if ptr is null 
14e2			      or    L 
14e2			      jp    Z, free_early_exit 
14e2			 
14e2			      ; Set up stack frame 
14e2			      ex    DE, HL 
14e2			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
14e2			      add   HL, SP 
14e2			      ld    SP, HL 
14e2			      ld    IX, 0                   ; Use IX as a frame pointer 
14e2			      add   IX, SP 
14e2			 
14e2			      ; The address in HL points to the start of the useable allocated space, 
14e2			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
14e2			      ; address of the block itself. 
14e2			      ex    DE, HL 
14e2			      ld    DE, -4 
14e2			      add   HL, DE 
14e2			 
14e2			      ; An allocated block must have a null next block pointer in it 
14e2			      ld    A, (HL) 
14e2			      inc   HL 
14e2			      or    (HL) 
14e2			      jp    NZ, free_done 
14e2			 
14e2			      dec   HL 
14e2			 
14e2			      ld    B, H                    ; Copy HL to BC 
14e2			      ld    C, L 
14e2			 
14e2			      ; Loop through the free list to find the first block with an address 
14e2			      ; higher than the block being freed 
14e2			      ld    HL, free_list 
14e2			 
14e2			free_find_higher_block: 
14e2			      ld    E, (HL)                 ; Load next ptr from free block 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      dec   HL 
14e2			 
14e2			      ld    (IX+0), E               ; Save ptr to next free block 
14e2			      ld    (IX+1), D 
14e2			      ld    (IX+2), L               ; Save ptr to prev free block 
14e2			      ld    (IX+3), H 
14e2			 
14e2			      ld    A, B                    ; Check if DE is greater than BC 
14e2			      cp    D                       ; Compare MSB first 
14e2			      jr    Z, $+4                  ; MSB the same, compare LSB 
14e2			      jr    NC, free_find_higher_block_skip 
14e2			      ld    A, C 
14e2			      cp    E                       ; Then compare LSB 
14e2			      jr    C, free_found_higher_block 
14e2			 
14e2			free_find_higher_block_skip: 
14e2			      ld    A, D                    ; Reached the end of the free list? 
14e2			      or    E 
14e2			      jp    Z, free_done 
14e2			 
14e2			      ex    DE, HL 
14e2			 
14e2			      jr    free_find_higher_block 
14e2			 
14e2			free_found_higher_block: 
14e2			      ; Insert freed block between prev and next free blocks 
14e2			      ld    (HL), C                 ; Point prev free block to freed block 
14e2			      inc   HL 
14e2			      ld    (HL), B 
14e2			 
14e2			      ld    H, B                    ; Point freed block at next free block 
14e2			      ld    L, C 
14e2			      ld    (HL), E 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			      ; Check if the freed block is adjacent to the next free block 
14e2			      inc   HL                      ; Load size of freed block into HL 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      ex    DE, HL 
14e2			 
14e2			      add   HL, BC                  ; Add addr of freed block and its size 
14e2			 
14e2			      ld    E, (IX+0)               ; Load addr of next free block into DE 
14e2			      ld    D, (IX+1) 
14e2			 
14e2			      or    A                       ; Clear the carry flag 
14e2			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
14e2			      jr    NZ, free_check_adjacent_to_prev 
14e2			 
14e2			      ; Freed block is adjacent to next, merge into one bigger block 
14e2			      ex    DE, HL                  ; Load next ptr from next block into DE 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      push  HL                      ; Save ptr to next block for later 
14e2			 
14e2			      ld    H, B                    ; Store ptr from next block into freed block 
14e2			      ld    L, C 
14e2			      ld    (HL), E 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			      pop   HL                      ; Restore ptr to next block 
14e2			      inc   HL                      ; Load size of next block into DE 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      push  DE                      ; Save next block size for later 
14e2			 
14e2			      ld    H, B                    ; Load size of freed block into HL 
14e2			      ld    L, C 
14e2			      inc   HL 
14e2			      inc   HL 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      ex    DE, HL 
14e2			 
14e2			      pop   DE                      ; Restore size of next block 
14e2			      add   HL, DE                  ; Add sizes of both blocks 
14e2			      ex    DE, HL 
14e2			 
14e2			      ld    H, B                    ; Store new bigger size into freed block 
14e2			      ld    L, C 
14e2			      inc   HL 
14e2			      inc   HL 
14e2			      ld    (HL), E 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			free_check_adjacent_to_prev: 
14e2			      ; Check if the freed block is adjacent to the prev free block 
14e2			      ld    L, (IX+2)               ; Prev free block ptr into HL 
14e2			      ld    H, (IX+3) 
14e2			 
14e2			      inc   HL                      ; Size of prev free block into DE 
14e2			      inc   HL 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			      dec   HL 
14e2			 
14e2			      add   HL, DE                  ; Add prev block addr and size 
14e2			 
14e2			      or    A                       ; Clear the carry flag 
14e2			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
14e2			      jr    NZ, free_done 
14e2			 
14e2			      ; Freed block is adjacent to prev, merge into one bigger block 
14e2			      ld    H, B                    ; Load next ptr from freed block into DE 
14e2			      ld    L, C 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      push  HL                      ; Save freed block ptr for later 
14e2			 
14e2			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
14e2			      ld    H, (IX+3) 
14e2			      ld    (HL), E 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			      pop   HL                      ; Restore freed block ptr 
14e2			      inc   HL                      ; Load size of freed block into DE 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			      push  DE                      ; Save freed block size for later 
14e2			 
14e2			      ld    L, (IX+2)               ; Load size of prev block into DE 
14e2			      ld    H, (IX+3) 
14e2			      inc   HL 
14e2			      inc   HL 
14e2			      ld    E, (HL) 
14e2			      inc   HL 
14e2			      ld    D, (HL) 
14e2			 
14e2			      pop   HL                      ; Add sizes of both blocks 
14e2			      add   HL, DE 
14e2			      ex    DE, HL 
14e2			 
14e2			      ld    L, (IX+2)               ; Store new bigger size into prev block 
14e2			      ld    H, (IX+3) 
14e2			      inc   HL 
14e2			      inc   HL 
14e2			      ld    (HL), E 
14e2			      inc   HL 
14e2			      ld    (HL), D 
14e2			 
14e2			free_done: 
14e2			      ld    HL, 4                   ; Clean up stack frame 
14e2			      add   HL, SP 
14e2			      ld    SP, HL 
14e2			 
14e2			free_early_exit: 
14e2			      pop   IX 
14e2			      pop   DE 
14e2			      pop   BC 
14e2			 
14e2			      ret 
14e2			 
14e2			 
14e2			;      .org 0x8000 
14e2			; 
14e2			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
14e2			 ;                 .dw   0 
14e2			 
14e2			endif 
14e2			 
14e2			 
14e2			if MALLOC_4 
14e2			 
14e2			; My memory allocation code. Very very simple.... 
14e2			; allocate space under 250 chars 
14e2			 
14e2			heap_init: 
14e2				; init start of heap as zero 
14e2				;  
14e2			 
14e2				ld hl, heap_start 
14e2			;	ld a, 0 
14e2				ld (hl), 0      ; empty block 
14e2				inc hl 
14e2			;	ld a, 0 
14e2				ld (hl), 0      ; length of block 
14e2				; write end of list 
14e2				inc hl 
14e2				ld a,(hl) 
14e2				inc hl 
14e2				ld a,(hl) 
14e2				 
14e2			 
14e2				; init some malloc vars 
14e2			 
14e2				ld hl, 0 
14e2				ld (free_list), hl       ; store last malloc location 
14e2			 
14e2				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
14e2			;	ld a, 0 
14e2				ld (hl), 0 
14e2			 
14e2			 
14e2				ld hl, heap_start 
14e2				;  
14e2				  
14e2				ret 
14e2			 
14e2			 
14e2			;    free block marker 
14e2			;    requested size  
14e2			;    pointer to next block 
14e2			;    .... 
14e2			;    next block marker 
14e2			 
14e2			 
14e2			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
14e2			; 
14e2			 
14e2			 
14e2			malloc:  
14e2				push de 
14e2				push bc 
14e2				push af 
14e2			 
14e2				; hl space required 
14e2				 
14e2				ld c, l    ; hold space   (TODO only a max of 255) 
14e2			 
14e2			;	inc c     ; TODO BUG need to fix memory leak on push str 
14e2			;	inc c 
14e2			;	inc c 
14e2			;	inc c 
14e2			;	inc c 
14e2			;	inc c 
14e2			;	inc c 
14e2			 
14e2			 
14e2			 
14e2				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
14e2			 
14e2				ld a, (free_list+3) 
14e2			;	cp 0 
14e2				or a 
14e2				jr z, .contheap 
14e2			 
14e2				ld hl, (free_list)     ; get last alloc 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "mrs" 
14e2						CALLMONITOR 
14e2					endif 
14e2				jr .startalloc 
14e2			 
14e2			.contheap: 
14e2				ld hl, heap_start 
14e2			 
14e2			.startalloc: 
14e2			 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "mym" 
14e2						CALLMONITOR 
14e2					endif 
14e2			.findblock: 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "mmf" 
14e2						CALLMONITOR 
14e2					endif 
14e2			 
14e2				ld a,(hl)  
14e2				; if byte is zero then clear to use 
14e2			 
14e2			;	cp 0 
14e2				or a 
14e2				jr z, .foundemptyblock 
14e2			 
14e2				; if byte is not clear 
14e2				;     then byte is offset to next block 
14e2			 
14e2				inc hl 
14e2				ld a, (hl) ; get size 
14e2			.nextblock:	inc hl 
14e2					ld e, (hl) 
14e2					inc hl 
14e2					ld d, (hl) 
14e2					ex de, hl 
14e2			;	inc hl  ; move past the store space 
14e2			;	inc hl  ; move past zero index  
14e2			 
14e2				; TODO detect no more space 
14e2			 
14e2				push hl 
14e2				ld de, heap_end 
14e2				call cmp16 
14e2				pop hl 
14e2				jr nc, .nospace 
14e2			 
14e2				jr .findblock 
14e2			 
14e2			.nospace: ld hl, 0 
14e2				jp .exit 
14e2			 
14e2			 
14e2			.foundemptyblock:	 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "mme" 
14e2						CALLMONITOR 
14e2					endif 
14e2			 
14e2			; TODO has block enough space if reusing??? 
14e2			 
14e2				;  
14e2			 
14e2			; see if this block has been previously used 
14e2				inc hl 
14e2				ld a, (hl) 
14e2				dec hl 
14e2			;	cp 0 
14e2				or a 
14e2				jr z, .newblock 
14e2			 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "meR" 
14e2						CALLMONITOR 
14e2					endif 
14e2			 
14e2			; no reusing previously allocated block 
14e2			 
14e2			; is it smaller than previously used? 
14e2				 
14e2				inc hl    ; move to size 
14e2				ld a, c 
14e2				sub (hl)        ; we want c < (hl) 
14e2				dec hl    ; move back to marker 
14e2			        jr z, .findblock 
14e2			 
14e2				; update with the new size which should be lower 
14e2			 
14e2			        ;inc  hl   ; negate next move. move back to size  
14e2			 
14e2			.newblock: 
14e2				; need to be at marker here 
14e2			 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "meN" 
14e2						CALLMONITOR 
14e2					endif 
14e2			 
14e2			 
14e2				ld a, c 
14e2			 
14e2				ld (free_list+3), a	 ; flag resume from last malloc  
14e2				ld (free_list), hl    ; save out last location 
14e2			 
14e2			 
14e2				;inc a     ; space for length byte 
14e2				ld (hl), a     ; save block in use marker 
14e2			 
14e2				inc hl   ; move to space marker 
14e2				ld (hl), a    ; save new space 
14e2			 
14e2				inc hl   ; move to start of allocated area 
14e2				 
14e2			;	push hl     ; save where we are - 1  
14e2			 
14e2			;	inc hl  ; move past zero index  
14e2				; skip space to set down new marker 
14e2			 
14e2				; provide some extra space for now 
14e2			 
14e2				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
14e2				inc a 
14e2				inc a 
14e2			 
14e2				push hl   ; save where we are in the node block 
14e2			 
14e2				call addatohl 
14e2			 
14e2				; write linked list point 
14e2			 
14e2				pop de     ; get our node position 
14e2				ex de, hl 
14e2			 
14e2				ld (hl), e 
14e2				inc hl 
14e2				ld (hl), d 
14e2			 
14e2				inc hl 
14e2			 
14e2				; now at start of allocated data so save pointer 
14e2			 
14e2				push hl 
14e2			 
14e2				; jump to position of next node and setup empty header in DE 
14e2			 
14e2				ex de, hl 
14e2			 
14e2			;	inc hl ; move past end of block 
14e2			 
14e2			;	ld a, 0 
14e2				ld (hl), 0   ; empty marker 
14e2				inc hl 
14e2				ld (hl), 0   ; size 
14e2				inc hl  
14e2				ld (hl), 0   ; ptr 
14e2				inc hl 
14e2				ld (hl), 0   ; ptr 
14e2			 
14e2			 
14e2				pop hl 
14e2			 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "mmr" 
14e2						CALLMONITOR 
14e2					endif 
14e2			 
14e2			.exit: 
14e2				pop af 
14e2				pop bc 
14e2				pop de  
14e2				ret 
14e2			 
14e2			 
14e2			 
14e2			 
14e2			free:  
14e2				push hl 
14e2				push af 
14e2				; get address in hl 
14e2			 
14e2					if DEBUG_FORTH_MALLOC_INT 
14e2						DMARK "fre" 
14e2						CALLMONITOR 
14e2					endif 
14e2				; data is at hl - move to block count 
14e2				dec hl 
14e2				dec hl    ; get past pointer 
14e2				dec hl 
14e2			 
14e2				ld a, (hl)    ; need this for a validation check 
14e2			 
14e2				dec hl    ; move to block marker 
14e2			 
14e2				; now check that the block count and block marker are the same  
14e2			        ; this checks that we are on a malloc node and not random memory 
14e2			        ; OK a faint chance this could be a problem but rare - famous last words! 
14e2			 
14e2				ld c, a 
14e2				ld a, (hl)    
14e2			 
14e2				cp c 
14e2				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
14e2			 
14e2				; yes good chance we are on a malloc node 
14e2			 
14e2			;	ld a, 0      
14e2				ld (hl), 0   ; mark as free 
14e2			 
14e2				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
14e2			 
14e2			.freeignore:  
14e2			 
14e2				pop af 
14e2				pop hl 
14e2			 
14e2				ret 
14e2			 
14e2			 
14e2			 
14e2			endif 
