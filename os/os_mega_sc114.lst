# End of macro CWHEAD
ba88			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
ba88			; | 
ba88			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
ba88			; | |  
ba88			; | | e.g. 
ba88			; | |         #30 a var ! 
ba88			; | |         a var @ . 
ba88			; | |   
ba88			; | |     Displays the number 30 
ba88			; | | 
ba88			; | | Each variable pointer is a word so can use for any words that use that:  
ba88			; | |  
ba88			; | | e.g. 
ba88			; | |  
ba88			; | |         #30 a var 2! 
ba88			; | |         a var 2@ . 
ba88			; | |   
ba88			; | |     Displays the number 30 
ba88			; | |  
ba88			; | | > [!NOTE]  
ba88			; ! | > If a full string is passed then only the first char is looked at 
ba88			; | | > Any other char could exceed bounds checks!  
ba88			; | | > 
ba88			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
ba88			 
ba88					if DEBUG_FORTH_WORDS_KEY 
ba88						DMARK "VAR" 
ba88				if DEMARK_VERSION = 1  
ba88 e5					push hl  
ba89 21 91 ba				ld hl, .dmark  
ba8c 22 5e ee				ld (debug_mark), hl  
ba8f				endif  
ba8f				if DEMARK_VERSION = 0  
