9c5c			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
9c5c			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
9c5c			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
9c5c			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
9c5c			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
9c5c			WORD_SYS_END: equ 0   ; Opcode for all user words 
9c5c			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
9c5c			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
9c5c			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
9c5c			 
9c5c			; Core word preamble macro 
9c5c			 
9c5c			CWHEAD:   macro nxtword opcode lit len opflags 
9c5c				db WORD_SYS_CORE+opcode             
9c5c				; internal op code number 
9c5c				dw nxtword            
9c5c				; link to next dict word block 
9c5c				db len + 1 
9c5c				; literal length of dict word inc zero term 
9c5c				db lit,0              
9c5c				; literal dict word 
9c5c			        ; TODO db opflags        
9c5c				endm 
