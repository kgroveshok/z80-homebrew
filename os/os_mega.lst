0f49			 
0f49			; Get 2 ASCII characters as hex byte from pointer in hl 
0f49			 
0f49			BYTERD: 
0f49 16 00			LD	D,00h		;Set up 
0f4b cd 53 0f			CALL	HEXCON		;Get byte and convert to hex 
