646a			; stack over and underflow checks 
646a			 
646a			; init the words to detect the under/overflow 
646a			 
646a			chk_stk_init: 
646a				; a vague random number to check so we dont get any "lucky" hits 
646a 3e 2d			ld a, 45 
646c 6f				ld l, a 
646d 00				nop 
646e 3e 17			ld a, 23 
6470 67				ld h, a 
6471			 
6471 22 bc f0			ld (chk_word), hl     ; the word we need to check against 
6474			 
6474			;	ld (chk_stund), hl	; stack points.... 
6474 22 3b fe			ld (chk_stovr), hl 
6477 22 0b f9			ld (chk_ret_und), hl 
647a 22 c9 f8			ld (chk_ret_ovr), hl 
647d 22 47 f8			ld (chk_loop_ovr), hl 
6480 22 45 f6			ld (chk_data_ovr), hl 
6483 c9				ret 
6484				 
6484			check_stacks: 
6484				; check all stack words 
6484			 
6484 e5				push hl 
6485 d5				push de 
6486			 
6486			;	ld de,(chk_word) 
6486			;	ld hl, (chk_stund)	; stack points.... 
6486			;	if DEBUG_STK_FAULT 
6486			;		DMARK "FAa" 
6486			;		CALLMONITOR 
6486			;	endif 
6486			;	call cmp16 
6486			;	jp z, .chk_faulta 
6486			; 
6486			;	ld de, sfaultsu 
6486			;	jp .chk_fault 
6486			 
6486 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
6489 ed 5b bc f0		ld de,(chk_word) 
648d				if DEBUG_STK_FAULT 
648d					DMARK "FAb" 
648d					CALLMONITOR 
648d				endif 
648d cd 7d 0d			call cmp16 
6490 28 06			jr z, .chk_fault1 
6492 11 37 65			ld de, sfaultso 
6495 c3 e7 64			jp .chk_fault 
6498			.chk_fault1:  
6498 2a 0b f9			ld hl, (chk_ret_und) 
649b ed 5b bc f0		ld de,(chk_word) 
649f				if DEBUG_STK_FAULT 
649f					DMARK "FAU" 
649f					CALLMONITOR 
649f				endif 
649f cd 7d 0d			call cmp16 
64a2 ca ab 64			jp z, .chk_fault2 
64a5 11 47 65			ld de, sfaultru 
64a8 c3 e7 64			jp .chk_fault 
64ab			.chk_fault2:  
64ab 2a c9 f8			ld hl, (chk_ret_ovr) 
64ae ed 5b bc f0		ld de,(chk_word) 
64b2				if DEBUG_STK_FAULT 
64b2					DMARK "FA1" 
64b2					CALLMONITOR 
64b2				endif 
64b2 cd 7d 0d			call cmp16 
64b5 ca be 64			jp z, .chk_fault3 
64b8 11 55 65			ld de, sfaultro 
64bb c3 e7 64			jp .chk_fault 
64be			.chk_fault3:  
64be 2a 47 f8			ld hl, (chk_loop_ovr) 
64c1 ed 5b bc f0		ld de,(chk_word) 
64c5				if DEBUG_STK_FAULT 
64c5					DMARK "FA2" 
64c5					CALLMONITOR 
64c5				endif 
64c5 cd 7d 0d			call cmp16 
64c8 ca d1 64			jp z, .chk_fault4 
64cb 11 6f 65			ld de, sfaultlo 
64ce c3 e7 64			jp .chk_fault 
64d1			.chk_fault4:  
64d1 2a 45 f6			ld hl, (chk_data_ovr) 
64d4 ed 5b bc f0		ld de,(chk_word) 
64d8				if DEBUG_STK_FAULT 
64d8					DMARK "FA3" 
64d8					CALLMONITOR 
64d8				endif 
64d8 cd 7d 0d			call cmp16 
64db ca e4 64			jp z, .chk_fault5 
64de 11 89 65			ld de, sfaultdo 
64e1 c3 e7 64			jp .chk_fault 
64e4			 
64e4			 
64e4			.chk_fault5:  
64e4 d1				pop de 
64e5 e1				pop hl 
64e6			 
64e6 c9				ret 
