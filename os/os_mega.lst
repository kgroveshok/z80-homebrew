1d24			include "firmware_595shiftreg.asm"  
1d24			; common code for handling a 595 shift reg out on whatever output port 
1d24			 
1d24			; port in c 
1d24			; byte in a 
1d24			 
1d24			 
1d24			shift_bit_data: equ 0 
1d24			shift_bit_clk: equ 1 
1d24			shift_bit_latch: equ 2 
1d24			 
1d24			 
1d24			; shift out a byte to the sound chip 
1d24			 
1d24			; A contains byte to send 
1d24			 
1d24			shift_byte: 
1d24			 
1d24 06 08			ld b, 8   ; 8 bits to shift 
1d26			 
1d26 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
1d28			 
1d28				; set data bit state 
1d28			 
1d28 cb 7f			bit 7, a 
1d2a				; high bit is set 
1d2a 28 02			jr z, .nb2 
1d2c cb c2			set shift_bit_data, d 
1d2e			 
1d2e				; set latches state  
1d2e cb ca		.nb2:	set shift_bit_clk, d 
1d30 cb 92			res shift_bit_latch, d    ; latch is inverted 
1d32 ed 51			out (c), d 
1d34				 
1d34				; clock the bit out 
1d34 cb 8a			res shift_bit_clk, d 
1d36 ed 51			out (c), d 
1d38			 
1d38				; shift a left one bit and repeat 
1d38 17				rla 
1d39			 
1d39 10 eb			djnz .nb1 
1d3b			 
1d3b				; latch 
1d3b cb d2			set shift_bit_latch, d 
1d3d ed 51			out (c), d 
1d3f					 
1d3f			 
1d3f				; set  
1d3f c9				ret 
