1f9a				push de 
1f9a				ld hl,(cli_loop_sp) 
1f9a				ld de, cli_loop_stack 
1f9a				call cmp16 
1f9a				jp c, fault_loop_under 
1f9a				pop de 
1f9a				pop hl 
1f9a				endm 
