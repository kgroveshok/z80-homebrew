1193			malloc_alloc_split: 
1193					if DEBUG_FORTH_MALLOC 
1193						DMARK "MAs" 
1193						CALLMONITOR 
1193					endif 
1193 eb			      ex    DE, HL                  ; Calculate address of new free block 
1194 2b			      dec   HL 
1195 2b			      dec   HL 
1196 2b			      dec   HL 
1197 09			      add   HL, BC 
1198			 
1198			      ; Create a new block and point it at next_free 
1198 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
119b dd 56 01		      ld    D, (IX+1) 
119e			 
119e 73			      ld    (HL), E                 ; Store next_free ptr into new block 
119f 23			      inc   HL 
11a0 72			      ld    (HL), D 
11a1			 
11a1 d1			      pop   DE                      ; Store size of new block into new block 
11a2 23			      inc   HL 
11a3 73			      ld    (HL), E 
11a4 23			      inc   HL 
11a5 72			      ld    (HL), D 
11a6			 
11a6			      ; Update this_free ptr to point to new block 
11a6 2b			      dec   HL 
11a7 2b			      dec   HL 
11a8 2b			      dec   HL 
11a9			 
11a9 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
11ac dd 56 03		      ld    D, (IX+3) 
11af			 
11af dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
11b2 dd 74 03		      ld    (IX+3), H 
11b5			 
11b5			      ; Modify this_free block to be allocation 
11b5 eb			      ex    DE, HL 
11b6 af			      xor   A                       ; Null the next block ptr of allocated block 
11b7 77			      ld    (HL), A 
11b8 23			      inc   HL 
11b9 77			      ld    (HL), A 
11ba			 
11ba 23			      inc   HL                      ; Store want size into allocated block 
11bb 71			      ld    (HL), C 
11bc 23			      inc   HL 
11bd 70			      ld    (HL), B 
11be 23			      inc   HL 
11bf e5			      push  HL                      ; Address of allocation to return 
11c0			 
11c0 18 19		      jr    malloc_update_links 
11c2			 
