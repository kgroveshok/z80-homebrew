0e12			 ;               call    nibble2val      ; Convert nibble to value 
0e12			 ;               call    print_nibble 
0e12			 ;               ret 
0e12			; 
0e12			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
0e12			; A valid hexadecimal digit is denoted by a set C flag. 
0e12			; 
0e12			;is_hex          cp      'F' + 1         ; Greater than 'F'? 
0e12			;                ret     nc              ; Yes 
0e12			;                cp      '0'             ; Less than '0'? 
0e12			;                jr      nc, is_hex_1    ; No, continue 
0e12			;                ccf                     ; Complement carry (i.e. clear it) 
0e12			;                ret 
0e12			;is_hex_1        cp      '9' + 1         ; Less or equal '9*? 
0e12			;                ret     c               ; Yes 
