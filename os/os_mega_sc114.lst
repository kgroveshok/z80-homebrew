9be8			user_word_eol:  
9be8				; hl contains the pointer to where to create a linked list item from the end 
9be8				; of the user dict to continue on at the system word dict 
9be8				 
9be8				; poke the stub of the word list linked list to repoint to rom words 
9be8			 
9be8				; stub format 
9be8				; db   word id 
9be8				; dw    link to next word 
9be8			        ; db char length of token 
9be8				; db string + 0 term 
9be8				; db exec code....  
9be8			 
9be8			;	ld a, WORD_SYS_ROOT     ; root word 
9be8 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9bea 23				inc hl 
9beb			 
9beb 11 94 9d			ld de, sysdict 
9bee 73				ld (hl), e		; next word link ie system dict 
9bef 23				inc hl 
