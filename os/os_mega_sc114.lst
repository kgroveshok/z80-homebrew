d564 23				inc hl   ; include zero term to copy 
d565 06 00			ld b,0 
d567 4d				ld c,l 
d568 e1				pop hl 
d569 11 a4 e2			ld de, scratch 
d56c ed b0			ldir 
d56e			 
d56e			 
