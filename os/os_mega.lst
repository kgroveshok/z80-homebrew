2c7f			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2c7f			; | | At start the current various registers will be displayed with contents. 
2c7f			; | | Top right corner will show the most recent debug marker seen. 
2c7f			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2c7f			; | | and the return stack pointer (RSP). 
2c7f			; | | Pressing: 
2c7f			; | |  
2c7f			; | |    1 - Initial screen 
2c7f			; | |  
2c7f			; | |    2 - Display a data dump of HL 
2c7f			; | |  
2c7f			; | |    3 - Display a data dump of DE 
2c7f			; | |  
2c7f			; | |    4 - Display a data dump of BC 
2c7f			; | |  
2c7f			; | |    5 - Display a data dump of HL 
2c7f			; | |  
2c7f			; | |    6 - Display a data dump of DSP 
2c7f			; | |  
2c7f			; | |    7 - Display a data dump of RSP 
2c7f			; | |  
2c7f			; | |    8 - Display a data dump of what is at DSP 
2c7f			; | |  
2c7f			; | |    9 - Display a data dump of what is at RSP 
2c7f			; | |  
2c7f			; | |    0 - Exit monitor and continue running. This will also enable break points 
2c7f			; | |  
2c7f			; | |    * - Disable break points 
2c7f			; | |  
2c7f			; | |    # - Enter traditional monitor mode 
2c7f			; | |  
2c7f			; | | 
2c7f			; | | Monitor Mode 
2c7f			; | | ------------ 
2c7f			; | | A prompt of '>' will be shown for various commands: 
2c7f			; | |  
2c7f			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2c7f			; | |  
2c7f			; | |    C - Continue display a data dump from the last set address 
2c7f			; | |  
2c7f			; | |    M xxxx - Set start of memory edit at address xx 
2c7f			; | |  
2c7f			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2c7f			; | |  
2c7f			; | |    G xxxx - Exec code at specific address 
2c7f			; | |  
2c7f			; | |    Q - Return to previous 
2c7f				if DEBUG_FORTH_WORDS_KEY 
2c7f					DMARK "MON" 
2c7f				if DEMARK_VERSION = 1  
2c7f e5					push hl  
2c80 21 88 2c				ld hl, .dmark  
2c83 22 9b fd				ld (debug_mark), hl  
2c86				endif  
