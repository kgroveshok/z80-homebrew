8912			 
8912			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
8912			 
8912			 
8912			;-----> Generate a random number 
8912			; output a=answer 0<=a<=255 
8912			; all registers are preserved except: af 
8912			random: 
8912 e5			        push    hl 
8913 d5			        push    de 
8914 2a a0 eb		        ld      hl,(randData) 
8917 ed 5f		        ld      a,r 
8919 57			        ld      d,a 
891a 5e			        ld      e,(hl) 
891b 19			        add     hl,de 
891c 85			        add     a,l 
891d ac			        xor     h 
891e 22 a0 eb		        ld      (randData),hl 
8921 d1			        pop     de 
8922 e1			        pop     hl 
8923 c9			        ret 
8924			 
8924			 
8924			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
8924			 
8924			 
8924			 
8924			;------LFSR------ 
8924			;James Montelongo 
8924			;optimized by Spencer Putt 
8924			;out: 
8924			; a = 8 bit random number 
8924			RandLFSR: 
8924 21 a6 eb		        ld hl,LFSRSeed+4 
8927 5e			        ld e,(hl) 
8928 23			        inc hl 
8929 56			        ld d,(hl) 
892a 23			        inc hl 
892b 4e			        ld c,(hl) 
892c 23			        inc hl 
892d 7e			        ld a,(hl) 
892e 47			        ld b,a 
892f cb 13		        rl e  
8931 cb 12			rl d 
8933 cb 11		        rl c  
8935 17				rla 
8936 cb 13		        rl e  
8938 cb 12			rl d 
893a cb 11		        rl c  
893c 17				rla 
893d cb 13		        rl e  
893f cb 12			rl d 
8941 cb 11		        rl c  
8943 17				rla 
8944 67			        ld h,a 
8945 cb 13		        rl e  
8947 cb 12			rl d 
8949 cb 11		        rl c  
894b 17				rla 
894c a8			        xor b 
894d cb 13		        rl e  
894f cb 12			rl d 
8951 ac			        xor h 
8952 a9			        xor c 
8953 aa			        xor d 
8954 21 a8 eb		        ld hl,LFSRSeed+6 
8957 11 a9 eb		        ld de,LFSRSeed+7 
895a 01 07 00		        ld bc,7 
895d ed b8		        lddr 
895f 12			        ld (de),a 
8960 c9			        ret 
8961			 
8961			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
8961			 
8961			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
8961			 
8961			 
8961			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
8961			 
8961			prng16: 
8961			;Inputs: 
8961			;   (seed1) contains a 16-bit seed value 
8961			;   (seed2) contains a NON-ZERO 16-bit seed value 
8961			;Outputs: 
8961			;   HL is the result 
8961			;   BC is the result of the LCG, so not that great of quality 
8961			;   DE is preserved 
8961			;Destroys: 
8961			;   AF 
8961			;cycle: 4,294,901,760 (almost 4.3 billion) 
8961			;160cc 
8961			;26 bytes 
8961 2a 9a eb		    ld hl,(seed1) 
8964 44			    ld b,h 
8965 4d			    ld c,l 
8966 29			    add hl,hl 
8967 29			    add hl,hl 
8968 2c			    inc l 
8969 09			    add hl,bc 
896a 22 9a eb		    ld (seed1),hl 
896d 2a 98 eb		    ld hl,(seed2) 
8970 29			    add hl,hl 
8971 9f			    sbc a,a 
8972 e6 2d		    and %00101101 
8974 ad			    xor l 
8975 6f			    ld l,a 
8976 22 98 eb		    ld (seed2),hl 
8979 09			    add hl,bc 
897a c9			    ret 
897b			 
897b			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
897b			 
897b			rand32: 
897b			;Inputs: 
897b			;   (seed1_0) holds the lower 16 bits of the first seed 
897b			;   (seed1_1) holds the upper 16 bits of the first seed 
897b			;   (seed2_0) holds the lower 16 bits of the second seed 
897b			;   (seed2_1) holds the upper 16 bits of the second seed 
897b			;   **NOTE: seed2 must be non-zero 
897b			;Outputs: 
897b			;   HL is the result 
897b			;   BC,DE can be used as lower quality values, but are not independent of HL. 
897b			;Destroys: 
897b			;   AF 
897b			;Tested and passes all CAcert tests 
897b			;Uses a very simple 32-bit LCG and 32-bit LFSR 
897b			;it has a period of 18,446,744,069,414,584,320 
897b			;roughly 18.4 quintillion. 
897b			;LFSR taps: 0,2,6,7  = 11000101 
897b			;291cc 
897b			;seed1_0=$+1 
897b			;    ld hl,12345 
897b			;seed1_1=$+1 
897b			;    ld de,6789 
897b			;    ld b,h 
897b			;    ld c,l 
897b			;    add hl,hl \ rl e \ rl d 
897b			;    add hl,hl \ rl e \ rl d 
897b			;    inc l 
897b			;    add hl,bc 
897b			;    ld (seed1_0),hl 
897b			;    ld hl,(seed1_1) 
897b			;    adc hl,de 
897b			;    ld (seed1_1),hl 
897b			;    ex de,hl 
897b			;seed2_0=$+1 
897b			;    ld hl,9876 
897b			;seed2_1=$+1 
897b			;    ld bc,54321 
897b			;    add hl,hl \ rl c \ rl b 
897b			;    ld (seed2_1),bc 
897b			;    sbc a,a 
897b			;    and %11000101 
897b			;    xor l 
897b			;    ld l,a 
897b			;    ld (seed2_0),hl 
897b			;    ex de,hl 
897b			;    add hl,bc 
897b			;    ret 
897b			; 
897b			 
897b			; 16-bit xorshift pseudorandom number generator by John Metcalf 
897b			; 20 bytes, 86 cycles (excluding ret) 
897b			 
897b			; returns   hl = pseudorandom number 
897b			; corrupts   a 
897b			 
897b			; generates 16-bit pseudorandom numbers with a period of 65535 
897b			; using the xorshift method: 
897b			 
897b			; hl ^= hl << 7 
897b			; hl ^= hl >> 9 
897b			; hl ^= hl << 8 
897b			 
897b			; some alternative shift triplets which also perform well are: 
897b			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
897b			 
897b			;  org 32768 
897b			 
897b			xrnd: 
897b 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
897e 3e 00		  ld a,0 
8980 bd			  cp l 
8981 20 02		  jr nz, .xrnd1 
8983 2e 01		  ld l, 1 
8985			.xrnd1: 
8985			 
8985 7c			  ld a,h 
8986 1f			  rra 
8987 7d			  ld a,l 
8988 1f			  rra 
8989 ac			  xor h 
898a 67			  ld h,a 
898b 7d			  ld a,l 
898c 1f			  rra 
898d 7c			  ld a,h 
898e 1f			  rra 
898f ad			  xor l 
8990 6f			  ld l,a 
8991 ac			  xor h 
8992 67			  ld h,a 
8993			 
8993 22 9e eb		  ld (xrandc),hl 
8996			 
8996 c9			  ret 
