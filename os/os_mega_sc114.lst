8f4b eb			      ex    DE, HL 
8f4c			 
8f4c 60			      ld    H, B                    ; Store new bigger size into freed block 
8f4d 69			      ld    L, C 
8f4e 23			      inc   HL 
8f4f 23			      inc   HL 
8f50 73			      ld    (HL), E 
8f51 23			      inc   HL 
8f52 72			      ld    (HL), D 
