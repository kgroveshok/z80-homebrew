1255			;Number in a to decimal ASCII 
1255			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
1255			;Example: display a=56 as "056" 
1255			;input: a = number 
1255			;Output: a=0,value of a in the screen 
1255			;destroys af,bc (don't know about hl and de) 
1255			DispAToASCII: 
1255 0e 9c			ld	c,-100 
1257 cd 61 12			call	.Na1 
125a 0e f6			ld	c,-10 
125c cd 61 12			call	.Na1 
125f 0e ff			ld	c,-1 
1261 06 2f		.Na1:	ld	b,'0'-1 
1263 04			.Na2:	inc	b 
1264 81				add	a,c 
1265 38 fc			jr	c,.Na2 
1267 91				sub	c		;works as add 100/10/1 
1268 f5				push af		;safer than ld c,a 
1269 78				ld	a,b		;char is in b 
126a			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
126a f1				pop af		;safer than ld a,c 
126b c9				ret 
