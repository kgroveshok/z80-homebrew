0d7b			; 
0d7b			;.DivLoopEnd: 
0d7b			 
0d7b			;HL_Div_C: 
0d7b			;Inputs: 
0d7b			;     HL is the numerator 
0d7b			;     C is the denominator 
0d7b			;Outputs: 
0d7b			;     A is the remainder 
0d7b			;     B is 0 
0d7b			;     C is not changed 
0d7b			;     DE is not changed 
0d7b			;     HL is the quotient 
0d7b			; 
0d7b			;       ld b,16 
0d7b			;       xor a 
0d7b			;         add hl,hl 
0d7b			;         rla 
0d7b			;         cp c 
0d7b			;         jr c,$+4 
0d7b			;           inc l 
0d7b			;           sub c 
0d7b			;         djnz $-7 
