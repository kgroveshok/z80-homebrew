2328			user_word_eol:  
2328				; hl contains the pointer to where to create a linked list item from the end 
2328				; of the user dict to continue on at the system word dict 
2328				 
2328				; poke the stub of the word list linked list to repoint to rom words 
2328			 
2328				; stub format 
2328				; db   word id 
2328				; dw    link to next word 
2328			        ; db char length of token 
2328				; db string + 0 term 
2328				; db exec code....  
2328			 
2328			;	ld a, WORD_SYS_ROOT     ; root word 
2328 36 00			ld (hl), WORD_SYS_ROOT		; word id 
232a 23				inc hl 
232b			 
232b 11 d4 24			ld de, sysdict 
232e 73				ld (hl), e		; next word link ie system dict 
232f 23				inc hl 
2330 72				ld (hl), d		; next word link ie system dict 
2331 23				inc hl	 
2332			 
2332			;	ld (hl), sysdict		; next word link ie system dict 
2332			;	inc hl 
2332			;	inc hl 
2332			 
2332			;	inc hl 
2332			;	inc hl 
2332			 
2332			;	ld a, 2			; word length is 0 
2332 36 02			ld (hl), 2 
2334 23				inc hl 
2335			 
2335			;	ld a, '~'			; word length is 0 
2335 36 7e			ld (hl), '~' 
2337 23				inc hl 
2338			;	ld a, 0			; save empty word 
2338 36 00			ld (hl), 0 
233a			 
