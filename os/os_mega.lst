65cb			; stack over and underflow checks 
65cb			 
65cb			; init the words to detect the under/overflow 
65cb			 
65cb			chk_stk_init: 
65cb				; a vague random number to check so we dont get any "lucky" hits 
65cb 3e 2d			ld a, 45 
65cd 6f				ld l, a 
65ce 00				nop 
65cf 3e 17			ld a, 23 
65d1 67				ld h, a 
65d2			 
65d2 22 b9 f0			ld (chk_word), hl     ; the word we need to check against 
65d5			 
65d5			;	ld (chk_stund), hl	; stack points.... 
65d5 22 3b fe			ld (chk_stovr), hl 
65d8 22 08 f9			ld (chk_ret_und), hl 
65db 22 c6 f8			ld (chk_ret_ovr), hl 
65de 22 44 f8			ld (chk_loop_ovr), hl 
65e1 22 42 f6			ld (chk_data_ovr), hl 
65e4 c9				ret 
65e5				 
65e5			check_stacks: 
65e5				; check all stack words 
65e5			 
65e5 e5				push hl 
65e6 d5				push de 
65e7			 
65e7			;	ld de,(chk_word) 
65e7			;	ld hl, (chk_stund)	; stack points.... 
65e7			;	if DEBUG_STK_FAULT 
65e7			;		DMARK "FAa" 
65e7			;		CALLMONITOR 
65e7			;	endif 
65e7			;	call cmp16 
65e7			;	jp z, .chk_faulta 
65e7			; 
65e7			;	ld de, sfaultsu 
65e7			;	jp .chk_fault 
65e7			 
65e7 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
65ea ed 5b b9 f0		ld de,(chk_word) 
65ee				if DEBUG_STK_FAULT 
65ee					DMARK "FAb" 
65ee					CALLMONITOR 
65ee				endif 
65ee cd 99 0d			call cmp16 
65f1 28 06			jr z, .chk_fault1 
65f3 11 98 66			ld de, sfaultso 
65f6 c3 48 66			jp .chk_fault 
65f9			.chk_fault1:  
65f9 2a 08 f9			ld hl, (chk_ret_und) 
65fc ed 5b b9 f0		ld de,(chk_word) 
6600				if DEBUG_STK_FAULT 
6600					DMARK "FAU" 
6600					CALLMONITOR 
6600				endif 
6600 cd 99 0d			call cmp16 
6603 ca 0c 66			jp z, .chk_fault2 
6606 11 a8 66			ld de, sfaultru 
6609 c3 48 66			jp .chk_fault 
660c			.chk_fault2:  
660c 2a c6 f8			ld hl, (chk_ret_ovr) 
660f ed 5b b9 f0		ld de,(chk_word) 
6613				if DEBUG_STK_FAULT 
6613					DMARK "FA1" 
6613					CALLMONITOR 
6613				endif 
6613 cd 99 0d			call cmp16 
6616 ca 1f 66			jp z, .chk_fault3 
6619 11 b6 66			ld de, sfaultro 
661c c3 48 66			jp .chk_fault 
661f			.chk_fault3:  
661f 2a 44 f8			ld hl, (chk_loop_ovr) 
6622 ed 5b b9 f0		ld de,(chk_word) 
6626				if DEBUG_STK_FAULT 
6626					DMARK "FA2" 
6626					CALLMONITOR 
6626				endif 
6626 cd 99 0d			call cmp16 
6629 ca 32 66			jp z, .chk_fault4 
662c 11 d0 66			ld de, sfaultlo 
662f c3 48 66			jp .chk_fault 
6632			.chk_fault4:  
6632 2a 42 f6			ld hl, (chk_data_ovr) 
6635 ed 5b b9 f0		ld de,(chk_word) 
6639				if DEBUG_STK_FAULT 
6639					DMARK "FA3" 
6639					CALLMONITOR 
6639				endif 
6639 cd 99 0d			call cmp16 
663c ca 45 66			jp z, .chk_fault5 
663f 11 ea 66			ld de, sfaultdo 
6642 c3 48 66			jp .chk_fault 
