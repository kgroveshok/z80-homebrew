10d4 70			      ld    (HL), B 
10d5			 
10d5 60			      ld    H, B                    ; Point freed block at next free block 
10d6 69			      ld    L, C 
10d7 73			      ld    (HL), E 
10d8 23			      inc   HL 
10d9 72			      ld    (HL), D 
