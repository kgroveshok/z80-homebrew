8a1a 17			    rla 
8a1b cb 11		    rl c 
8a1d 30 07		    jr nc,Mult32_NoAdd 
8a1f 19			    add hl,de 
8a20 ce 00		    adc a,0 
8a22 d2 26 8a		    jp nc,Mult32_NoAdd 
8a25 0c			    inc c 
8a26			Mult32_NoAdd: 
8a26 10 f1		    djnz Mult32_Loop 
8a28 41			    ld b,c 
8a29 4f			    ld c,a 
8a2a c9			    ret 
