117b 47					LD B, A 
117c					; Upper nybble 
117c cb 3f				SRL A 
117e cb 3f				SRL A 
1180 cb 3f				SRL A 
1182 cb 3f				SRL A 
1184 cd 94 11				CALL tohex 
1187 77					ld (hl),a 
1188 23					inc hl	 
1189					 
1189					; Lower nybble 
1189 78					LD A, B 
118a e6 0f				AND 0FH 
118c cd 94 11				CALL tohex 
118f 77					ld (hl),a 
1190 23					inc hl	 
1191					 
1191 f1					POP AF 
1192 c1					POP BC 
1193 c9					RET 
