bff2			 
bff2			 
bff2			.SESEL: 
bff2				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
bff2			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
bff2			; | | Zero is disabled storage. 
bff2					if DEBUG_FORTH_WORDS_KEY 
bff2						DMARK "BN?" 
bff2						CALLMONITOR 
bff2					endif 
bff2					ld a, (spi_device_id) 
bff2					sub '0' 
bff2					ld h, 0 
bff2					ld l, a 
bff2					FORTH_PUSH_VALUEHL 
bff2					;call forth_push_numhl 
bff2					NEXTW 
bff2			.SESELS: 
bff2				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
bff2			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
bff2			; | | Set to zero to disable storage. 
bff2					if DEBUG_FORTH_WORDS_KEY 
bff2						DMARK "BNK" 
bff2						CALLMONITOR 
bff2					endif 
bff2			 
bff2					ld a, 255 
bff2					ld (spi_cartdev), a 
bff2			 
bff2					; get bank 
bff2			 
bff2					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
bff2			 
bff2			;		push hl 
bff2			 
bff2					; destroy value TOS 
bff2			 
bff2					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
bff2			 
bff2					; one value on hl get other one back 
bff2			 
bff2			;		pop hl 
bff2			 
bff2			 
bff2					ld c, SPI_CE_HIGH 
bff2					ld b, '0'    ; human readable bank number 
bff2			 
bff2					ld a, l 
bff2			 
bff2					if DEBUG_FORTH_WORDS 
bff2						DMARK "BNK" 
bff2						CALLMONITOR 
bff2					endif 
bff2			 
bff2					; active low 
bff2			 
bff2			;		cp 0 
bff2					or a 
bff2					jr z, .bset 
bff2					cp 1 
bff2					jr nz, .b2 
bff2					res 0, c 
bff2					ld b, '1'    ; human readable bank number 
bff2			.b2:		cp 2 
bff2					jr nz, .b3 
bff2					res 1, c 
bff2					ld b, '2'    ; human readable bank number 
bff2			.b3:		cp 3 
bff2					jr nz, .b4 
bff2					res 2, c 
bff2					ld b, '3'    ; human readable bank number 
bff2			.b4:		cp 4 
bff2					jr nz, .b5 
bff2					res 3, c 
bff2					ld b, '4'    ; human readable bank number 
bff2			.b5:		cp 5 
bff2					jr nz, .bset 
bff2					res 4, c 
bff2					ld b, '5'    ; human readable bank number 
bff2			 
bff2			.bset: 
bff2					ld a, c 
bff2					ld (spi_device),a 
bff2					ld a, b 
bff2					ld (spi_device_id),a 
bff2					if DEBUG_FORTH_WORDS 
bff2						DMARK "BN2" 
bff2						CALLMONITOR 
bff2					endif 
bff2			 
bff2					; set default SPI clk pulse time as disabled for BANK use 
bff2			 
bff2					ld a, 0 
bff2					ld (spi_clktime), a 
bff2			 
bff2					NEXTW 
bff2			 
bff2			.CARTDEV: 
