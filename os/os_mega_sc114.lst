98ed			; Stack operations for v5 parser on wards 
98ed			; * DATA stack 
98ed			; * LOOP stack 
98ed			; * RETURN stack 
98ed			 
98ed			 
98ed			 
98ed			FORTH_CHK_DSP_UNDER: macro 
98ed				push hl 
98ed				push de 
98ed				ld hl,(cli_data_sp) 
98ed				ld de, cli_data_stack 
98ed				call cmp16 
98ed				jp c, fault_dsp_under 
98ed				pop de 
98ed				pop hl 
98ed				endm 
98ed			 
98ed			 
98ed			FORTH_CHK_RSP_UNDER: macro 
98ed				push hl 
98ed				push de 
98ed				ld hl,(cli_ret_sp) 
98ed				ld de, cli_ret_stack 
98ed				call cmp16 
98ed				jp c, fault_rsp_under 
98ed				pop de 
98ed				pop hl 
98ed				endm 
98ed			 
98ed			FORTH_CHK_LOOP_UNDER: macro 
98ed				push hl 
98ed				push de 
98ed				ld hl,(cli_loop_sp) 
98ed				ld de, cli_loop_stack 
98ed				call cmp16 
98ed				jp c, fault_loop_under 
98ed				pop de 
98ed				pop hl 
98ed				endm 
98ed			 
98ed			FORTH_ERR_TOS_NOTSTR: macro 
98ed				; TOSO might need more for checks when used 
98ed				push af 
98ed				ld a,(hl) 
98ed				cp DS_TYPE_STR 
98ed				jp nz, type_faultn   
98ed				pop af 
98ed				endm 
98ed			 
98ed			FORTH_ERR_TOS_NOTNUM: macro 
98ed				push af 
98ed				ld a,(hl) 
98ed				cp DS_TYPE_INUM 
98ed				jp nz, type_faultn   
98ed				pop af 
98ed				endm 
98ed			 
98ed			 
98ed			; increase data stack pointer and save hl to it 
