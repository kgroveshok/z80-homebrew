0d7d			;;http://z80-heaven.wikidot.com/math 
0d7d			;;This divides DE by BC, storing the result in DE, remainder in HL 
0d7d			; 
0d7d			;DE_Div_BC:          ;1281-2x, x is at most 16 
0d7d			;     ld a,16        ;7 
0d7d			;     ld hl,0        ;10 
0d7d			;     jp $+5         ;10 
0d7d			;.DivLoop: 
0d7d			;       add hl,bc    ;-- 
0d7d			;       dec a        ;64 
0d7d			;       jr z,.DivLoopEnd        ;86 
0d7d			; 
0d7d			;       sla e        ;128 
0d7d			;       rl d         ;128 
0d7d			;       adc hl,hl    ;240 
0d7d			;       sbc hl,bc    ;240 
0d7d			;       jr nc,.DivLoop ;23|21 
0d7d			;       inc e        ;-- 
0d7d			;       jp .DivLoop+1 
0d7d			; 
0d7d			;.DivLoopEnd: 
0d7d			 
0d7d			;HL_Div_C: 
0d7d			;Inputs: 
0d7d			;     HL is the numerator 
0d7d			;     C is the denominator 
0d7d			;Outputs: 
0d7d			;     A is the remainder 
0d7d			;     B is 0 
0d7d			;     C is not changed 
0d7d			;     DE is not changed 
0d7d			;     HL is the quotient 
0d7d			; 
0d7d			;       ld b,16 
0d7d			;       xor a 
0d7d			;         add hl,hl 
0d7d			;         rla 
0d7d			;         cp c 
0d7d			;         jr c,$+4 
0d7d			;           inc l 
0d7d			;           sub c 
0d7d			;         djnz $-7 
