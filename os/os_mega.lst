1413			;------------------------------------------------------------------------------ 
1413			;     free                                                                    : 
1413			;                                                                             : 
1413			; Description                                                                 : 
1413			;     Return the space pointed to by HL to the heap. HL must be an address as : 
1413			;     returned by malloc, otherwise the behaviour is undefined.               : 
1413			;                                                                             : 
1413			;     Where possible, directly adjacent free blocks will be merged together   : 
1413			;     into larger blocks to help ensure that the heap does not become         : 
1413			;     excessively fragmented.                                                 : 
1413			;                                                                             : 
1413			;     free does not clear or set any other value into the freed space, and    : 
1413			;     therefore its contents may be visible through subsequent malloc's. The  : 
1413			;     caller should clear the freed space as required.                        : 
1413			;                                                                             : 
1413			;     This implementation of free uses the stack exclusively, and is          : 
1413			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1413			;     advisable to disable interrupts before calling free, and recommended    : 
1413			;     to avoid the use of free inside ISRs in general.                        : 
1413			;                                                                             : 
1413			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1413			;                                                                             : 
1413			; Parameters                                                                  : 
1413			;     HL  Pointer to address of first byte of allocation to be freed          : 
1413			;                                                                             : 
1413			; Returns                                                                     : 
1413			;     Nothing                                                                 : 
1413			;                                                                             : 
1413			; Stack frame                                                                 : 
1413			;       |             |                                                       : 
1413			;       +-------------+                                                       : 
1413			;       |     BC      |                                                       : 
1413			;       +-------------+                                                       : 
1413			;       |     DE      |                                                       : 
1413			;       +-------------+                                                       : 
1413			;       |     IX      |                                                       : 
1413			;       +-------------+                                                       : 
1413			;       |  prev_free  |                                                       : 
1413			;   +2  +-------------+                                                       : 
1413			;       |  next_free  |                                                       : 
1413			;   +0  +-------------+                                                       : 
1413			;       |             |                                                       : 
1413			;                                                                             : 
1413			;------------------------------------------------------------------------------ 
1413			free: 
1413 c5			      push  BC 
1414 d5			      push  DE 
1415 dd e5		      push  IX 
1417			 
1417 7c			      ld    A, H                    ; Exit if ptr is null 
1418 b5			      or    L 
1419 ca dd 14		      jp    Z, free_early_exit 
141c			 
141c			      ; Set up stack frame 
141c eb			      ex    DE, HL 
141d 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
1420 39			      add   HL, SP 
1421 f9			      ld    SP, HL 
1422 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1426 dd 39		      add   IX, SP 
1428			 
1428			      ; The address in HL points to the start of the useable allocated space, 
1428			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
1428			      ; address of the block itself. 
1428 eb			      ex    DE, HL 
1429 11 fc ff		      ld    DE, -4 
142c 19			      add   HL, DE 
142d			 
142d			      ; An allocated block must have a null next block pointer in it 
142d 7e			      ld    A, (HL) 
142e 23			      inc   HL 
142f b6			      or    (HL) 
1430 c2 d8 14		      jp    NZ, free_done 
1433			 
1433 2b			      dec   HL 
1434			 
1434 44			      ld    B, H                    ; Copy HL to BC 
1435 4d			      ld    C, L 
1436			 
1436			      ; Loop through the free list to find the first block with an address 
1436			      ; higher than the block being freed 
1436 21 0a 80		      ld    HL, free_list 
1439			 
1439			free_find_higher_block: 
1439 5e			      ld    E, (HL)                 ; Load next ptr from free block 
143a 23			      inc   HL 
143b 56			      ld    D, (HL) 
143c 2b			      dec   HL 
143d			 
143d dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
1440 dd 72 01		      ld    (IX+1), D 
1443 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1446 dd 74 03		      ld    (IX+3), H 
1449			 
1449 78			      ld    A, B                    ; Check if DE is greater than BC 
144a ba			      cp    D                       ; Compare MSB first 
144b 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
144d 30 04		      jr    NC, free_find_higher_block_skip 
144f 79			      ld    A, C 
1450 bb			      cp    E                       ; Then compare LSB 
1451 38 08		      jr    C, free_found_higher_block 
1453			 
1453			free_find_higher_block_skip: 
1453 7a			      ld    A, D                    ; Reached the end of the free list? 
1454 b3			      or    E 
1455 ca d8 14		      jp    Z, free_done 
1458			 
1458 eb			      ex    DE, HL 
1459			 
1459 18 de		      jr    free_find_higher_block 
145b			 
145b			free_found_higher_block: 
145b			      ; Insert freed block between prev and next free blocks 
145b 71			      ld    (HL), C                 ; Point prev free block to freed block 
145c 23			      inc   HL 
145d 70			      ld    (HL), B 
145e			 
145e 60			      ld    H, B                    ; Point freed block at next free block 
145f 69			      ld    L, C 
1460 73			      ld    (HL), E 
1461 23			      inc   HL 
1462 72			      ld    (HL), D 
1463			 
1463			      ; Check if the freed block is adjacent to the next free block 
1463 23			      inc   HL                      ; Load size of freed block into HL 
1464 5e			      ld    E, (HL) 
1465 23			      inc   HL 
1466 56			      ld    D, (HL) 
1467 eb			      ex    DE, HL 
1468			 
1468 09			      add   HL, BC                  ; Add addr of freed block and its size 
1469			 
1469 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
146c dd 56 01		      ld    D, (IX+1) 
146f			 
146f b7			      or    A                       ; Clear the carry flag 
1470 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
1472 20 22		      jr    NZ, free_check_adjacent_to_prev 
1474			 
1474			      ; Freed block is adjacent to next, merge into one bigger block 
1474 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
1475 5e			      ld    E, (HL) 
1476 23			      inc   HL 
1477 56			      ld    D, (HL) 
1478 e5			      push  HL                      ; Save ptr to next block for later 
1479			 
1479 60			      ld    H, B                    ; Store ptr from next block into freed block 
147a 69			      ld    L, C 
147b 73			      ld    (HL), E 
147c 23			      inc   HL 
147d 72			      ld    (HL), D 
147e			 
147e e1			      pop   HL                      ; Restore ptr to next block 
147f 23			      inc   HL                      ; Load size of next block into DE 
1480 5e			      ld    E, (HL) 
1481 23			      inc   HL 
1482 56			      ld    D, (HL) 
1483 d5			      push  DE                      ; Save next block size for later 
1484			 
1484 60			      ld    H, B                    ; Load size of freed block into HL 
1485 69			      ld    L, C 
1486 23			      inc   HL 
1487 23			      inc   HL 
1488 5e			      ld    E, (HL) 
1489 23			      inc   HL 
148a 56			      ld    D, (HL) 
148b eb			      ex    DE, HL 
148c			 
148c d1			      pop   DE                      ; Restore size of next block 
148d 19			      add   HL, DE                  ; Add sizes of both blocks 
148e eb			      ex    DE, HL 
148f			 
148f 60			      ld    H, B                    ; Store new bigger size into freed block 
1490 69			      ld    L, C 
1491 23			      inc   HL 
1492 23			      inc   HL 
1493 73			      ld    (HL), E 
1494 23			      inc   HL 
1495 72			      ld    (HL), D 
1496			 
1496			free_check_adjacent_to_prev: 
1496			      ; Check if the freed block is adjacent to the prev free block 
1496 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1499 dd 66 03		      ld    H, (IX+3) 
149c			 
149c 23			      inc   HL                      ; Size of prev free block into DE 
149d 23			      inc   HL 
149e 5e			      ld    E, (HL) 
149f 23			      inc   HL 
14a0 56			      ld    D, (HL) 
14a1 2b			      dec   HL 
14a2 2b			      dec   HL 
14a3 2b			      dec   HL 
14a4			 
14a4 19			      add   HL, DE                  ; Add prev block addr and size 
14a5			 
14a5 b7			      or    A                       ; Clear the carry flag 
14a6 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
14a8 20 2e		      jr    NZ, free_done 
14aa			 
14aa			      ; Freed block is adjacent to prev, merge into one bigger block 
14aa 60			      ld    H, B                    ; Load next ptr from freed block into DE 
14ab 69			      ld    L, C 
14ac 5e			      ld    E, (HL) 
14ad 23			      inc   HL 
14ae 56			      ld    D, (HL) 
14af e5			      push  HL                      ; Save freed block ptr for later 
14b0			 
14b0 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
14b3 dd 66 03		      ld    H, (IX+3) 
14b6 73			      ld    (HL), E 
14b7 23			      inc   HL 
14b8 72			      ld    (HL), D 
14b9			 
14b9 e1			      pop   HL                      ; Restore freed block ptr 
14ba 23			      inc   HL                      ; Load size of freed block into DE 
14bb 5e			      ld    E, (HL) 
14bc 23			      inc   HL 
14bd 56			      ld    D, (HL) 
14be d5			      push  DE                      ; Save freed block size for later 
14bf			 
14bf dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
14c2 dd 66 03		      ld    H, (IX+3) 
14c5 23			      inc   HL 
14c6 23			      inc   HL 
14c7 5e			      ld    E, (HL) 
14c8 23			      inc   HL 
14c9 56			      ld    D, (HL) 
14ca			 
14ca e1			      pop   HL                      ; Add sizes of both blocks 
14cb 19			      add   HL, DE 
14cc eb			      ex    DE, HL 
14cd			 
14cd dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
14d0 dd 66 03		      ld    H, (IX+3) 
14d3 23			      inc   HL 
14d4 23			      inc   HL 
14d5 73			      ld    (HL), E 
14d6 23			      inc   HL 
14d7 72			      ld    (HL), D 
14d8			 
14d8			free_done: 
14d8 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
14db 39			      add   HL, SP 
14dc f9			      ld    SP, HL 
14dd			 
14dd			free_early_exit: 
14dd dd e1		      pop   IX 
14df d1			      pop   DE 
14e0 c1			      pop   BC 
14e1			 
14e1 c9			      ret 
