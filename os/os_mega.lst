6388 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
638a 18 02		            JR   WrFunc  
638c 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
638e f5			WrFunc:     PUSH AF  
638f f5					push af  
6390 3a fb fa				ld a, (display_lcde1e2)  
6393 fe 00				cp 0     ; e1  
6395 20 0f				jr nz, .wfea2	  
6397 f1					pop af  
6398 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
639a cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
639c cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
639e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
63a0 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
63a2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
63a4 18 0d			jr .wfskip  
63a6 f1			.wfea2:		pop af  
63a7 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
63a9 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
63ab cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
63ad d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
63af cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
63b1 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
63b3 3e 05		.wfskip:            LD  A, 5  
63b5 cd bc 63		            CALL LCDDelay       ;Delay 5 ms to complete  
63b8 f1			            POP  AF  
63b9 c9			            RET  
