8dab			 
8dab			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
8dab			 
8dab			;moved to firmware.asm 
8dab			;heap_start        .equ  0x9000      ; Starting address of heap 
8dab			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8dab			 
8dab			;      .org 0 
8dab			;      jp    main 
8dab			 
8dab			 
8dab			;      .org  0x100 
8dab			;main: 
8dab			;      ld    HL, 0x8100 
8dab			;      ld    SP, HL 
8dab			; 
8dab			;      call  heap_init 
8dab			; 
8dab			;      ; Make some allocations 
8dab			;      ld    HL, 12 
8dab			;      call  malloc            ; Allocates 0x9004 
8dab			; 
8dab			;      ld    HL, 12 
8dab			;      call  malloc            ; Allocates 0x9014 
8dab			; 
8dab			;      ld    HL, 12 
8dab			;      call  malloc            ; Allocates 0x9024 
8dab			; 
8dab			;      ; Free some allocations 
8dab			;      ld    HL, 0x9014 
8dab			;      call  free 
8dab			; 
8dab			;      ld    HL, 0x9004 
8dab			;      call  free 
8dab			; 
8dab			;      ld    HL, 0x9024 
8dab			;      call  free 
8dab			; 
8dab			; 
8dab			;      halt 
8dab			 
8dab			 
8dab			;------------------------------------------------------------------------------ 
8dab			;     heap_init                                                               : 
8dab			;                                                                             : 
8dab			; Description                                                                 : 
8dab			;     Initialise the heap and make it ready for malloc and free operations.   : 
8dab			;                                                                             : 
8dab			;     The heap is maintained as a linked list, starting with an initial       : 
8dab			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8dab			;     the first free block in the heap. Each block then points to the next    : 
8dab			;     free block within the heap, and the free list ends at the first block   : 
8dab			;     with a null pointer to the next free block.                             : 
8dab			;                                                                             : 
8dab			; Parameters                                                                  : 
8dab			;     Inputs are compile-time only. Two defines which specify the starting    : 
8dab			;     address of the heap and its size are required, along with a memory      : 
8dab			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8dab			;     principally stores a pointer to the first free block in the heap.       : 
8dab			;                                                                             : 
8dab			; Returns                                                                     : 
8dab			;     Nothing                                                                 : 
8dab			;------------------------------------------------------------------------------ 
8dab			heap_init: 
8dab e5			      push  HL 
8dac			 
8dac			      ; Initialise free list struct 
8dac 21 5a cf		      ld    HL, heap_start 
8daf 22 55 cf		      ld    (free_list), HL 
8db2 21 00 00		      ld    HL, 0 
8db5 22 57 cf		      ld    (free_list+2), HL 
8db8			 
8db8			      ; Insert first free block at bottom of heap, consumes entire heap 
8db8 21 8b e2		      ld    HL, heap_start+heap_size-4 
8dbb 22 5a cf		      ld    (heap_start), HL        ; Next block (end of free list) 
8dbe 21 31 13		      ld    HL, heap_size-4 
8dc1 22 5c cf		      ld    (heap_start+2), HL      ; Block size 
8dc4			 
8dc4			      ; Insert end of free list block at top of heap - two null words will 
8dc4			      ; terminate the free list 
8dc4 21 00 00		      ld    HL, 0 
8dc7 22 8d e2		      ld    (heap_start+heap_size-2), HL 
8dca 22 8b e2		      ld    (heap_start+heap_size-4), HL 
8dcd			 
8dcd e1			      pop   HL 
8dce			 
8dce c9			      ret 
8dcf			 
8dcf			 
8dcf			;------------------------------------------------------------------------------ 
8dcf			;     malloc                                                                  : 
8dcf			;                                                                             : 
8dcf			; Description                                                                 : 
8dcf			;     Allocates the wanted space from the heap and returns the address of the : 
8dcf			;     first useable byte of the allocation.                                   : 
8dcf			;                                                                             : 
8dcf			;     Allocations can happen in one of two ways:                              : 
8dcf			;                                                                             : 
8dcf			;     1. A free block may be found which is the exact size wanted. In this    : 
8dcf			;        case the block is removed from the free list and retuedn to the      : 
8dcf			;        caller.                                                              : 
8dcf			;     2. A free block may be found which is larger than the size wanted. In   : 
8dcf			;        this case, the larger block is split into two. The first portion of  : 
8dcf			;        this block will become the requested space by the malloc call and    : 
8dcf			;        is returned to the caller. The second portion becomes a new free     : 
8dcf			;        block, and the free list is adjusted to maintain continuity via this : 
8dcf			;        newly created block.                                                 : 
8dcf			;                                                                             : 
8dcf			;     malloc does not set any initial value in the allocated space, the       : 
8dcf			;     caller is required to do this as required.                              : 
8dcf			;                                                                             : 
8dcf			;     This implementation of malloc uses the stack exclusively, and is        : 
8dcf			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8dcf			;     advisable to disable interrupts before calling malloc, and recommended  : 
8dcf			;     to avoid the use of malloc inside ISRs in general.                      : 
8dcf			;                                                                             : 
8dcf			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8dcf			;                                                                             : 
8dcf			; Parameters                                                                  : 
8dcf			;     HL  Number of bytes wanted                                              : 
8dcf			;                                                                             : 
8dcf			; Returns                                                                     : 
8dcf			;     HL  Address of the first useable byte of the allocation                 : 
8dcf			;                                                                             : 
8dcf			; Flags                                                                       : 
8dcf			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8dcf			;                                                                             : 
8dcf			; Stack frame                                                                 : 
8dcf			;       |             |                                                       : 
8dcf			;       +-------------+                                                       : 
8dcf			;       |     BC      |                                                       : 
8dcf			;       +-------------+                                                       : 
8dcf			;       |     DE      |                                                       : 
8dcf			;       +-------------+                                                       : 
8dcf			;       |     IX      |                                                       : 
8dcf			;       +-------------+                                                       : 
8dcf			;       |  prev_free  |                                                       : 
8dcf			;   +4  +-------------+                                                       : 
8dcf			;       |  this_free  |                                                       : 
8dcf			;   +2  +-------------+                                                       : 
8dcf			;       |  next_free  |                                                       : 
8dcf			;   +0  +-------------+                                                       : 
8dcf			;       |             |                                                       : 
8dcf			;                                                                             : 
8dcf			;------------------------------------------------------------------------------ 
8dcf			 
8dcf			 
8dcf			;malloc: 
8dcf			; 
8dcf			;	SAVESP ON 1 
8dcf			; 
8dcf			;	call malloc_code 
8dcf			; 
8dcf			;	CHECKSP ON 1 
8dcf			;	ret 
8dcf			 
8dcf			 
8dcf			malloc: 
8dcf c5			      push  BC 
8dd0 d5			      push  DE 
8dd1 dd e5		      push  IX 
8dd3			if DEBUG_FORTH_MALLOC_HIGH 
8dd3			call malloc_guard_entry 
8dd3			endif 
8dd3			 
8dd3					if DEBUG_FORTH_MALLOC 
8dd3						DMARK "mal" 
8dd3						CALLMONITOR 
8dd3					endif 
8dd3 7c			      ld    A, H                    ; Exit if no space requested 
8dd4 b5			      or    L 
8dd5 ca 94 8e		      jp    Z, malloc_early_exit 
8dd8			 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			; 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			;inc hl 
8dd8			 
8dd8			 
8dd8			 
8dd8			 
8dd8					if DEBUG_FORTH_MALLOC 
8dd8						DMARK "maA" 
8dd8						CALLMONITOR 
8dd8					endif 
8dd8			      ; Set up stack frame 
8dd8 eb			      ex    DE, HL 
8dd9 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8ddc 39			      add   HL, SP 
8ddd f9			      ld    SP, HL 
8dde dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
8de2 dd 39		      add   IX, SP 
8de4			 
8de4			      ; Setup initial state 
8de4 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
8de7 19			      add   HL, DE 
8de8			 
8de8 44			      ld    B, H                    ; Move want to BC 
8de9 4d			      ld    C, L 
8dea			 
8dea 21 55 cf		      ld    HL, free_list           ; Store prev_free ptr to stack 
8ded dd 75 04		      ld    (IX+4), L 
8df0 dd 74 05		      ld    (IX+5), H 
8df3			 
8df3 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
8df4 23			      inc   HL 
8df5 56			      ld    D, (HL) 
8df6 dd 73 02		      ld    (IX+2), E 
8df9 dd 72 03		      ld    (IX+3), D 
8dfc eb			      ex    DE, HL                  ; this_free ptr into HL 
8dfd			 
8dfd					if DEBUG_FORTH_MALLOC 
8dfd						DMARK "maB" 
8dfd						CALLMONITOR 
8dfd					endif 
8dfd			      ; Loop through free block list to find some space 
8dfd			malloc_find_space: 
8dfd 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
8dfe 23			      inc   HL 
8dff 56			      ld    D, (HL) 
8e00			 
8e00 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8e01 b3			      or    E 
8e02 ca 8e 8e		      jp    Z, malloc_no_space 
8e05			 
8e05 dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
8e08 dd 72 01		      ld    (IX+1), D 
8e0b			 
8e0b			      ; Does this block have enough space to make the allocation? 
8e0b 23			      inc   HL                      ; Load free block size into DE 
8e0c 5e			      ld    E, (HL) 
8e0d 23			      inc   HL 
8e0e 56			      ld    D, (HL) 
8e0f			 
8e0f eb			      ex    DE, HL                  ; Check size of block against want 
8e10 b7			      or    A                       ; Ensure carry flag clear 
8e11 ed 42		      sbc   HL, BC 
8e13 e5			      push  HL                      ; Store the result for later (new block size) 
8e14			 
8e14 ca 63 8e		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8e17 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8e19			 
8e19			      ; this_free block is not big enough, setup ptrs to test next free block 
8e19 e1			      pop   HL                      ; Discard previous result 
8e1a			 
8e1a dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8e1d dd 66 03		      ld    H, (IX+3) 
8e20 dd 75 04		      ld    (IX+4), L 
8e23 dd 74 05		      ld    (IX+5), H 
8e26			 
8e26 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8e29 dd 66 01		      ld    H, (IX+1) 
8e2c dd 75 02		      ld    (IX+2), L 
8e2f dd 74 03		      ld    (IX+3), H 
8e32			 
8e32					if DEBUG_FORTH_MALLOC 
8e32						DMARK "MA>" 
8e32						CALLMONITOR 
8e32					endif 
8e32 18 c9		      jr    malloc_find_space 
8e34			 
8e34			      ; split a bigger block into two - requested size and remaining size 
8e34			malloc_alloc_split: 
8e34					if DEBUG_FORTH_MALLOC 
8e34						DMARK "MAs" 
8e34						CALLMONITOR 
8e34					endif 
8e34 eb			      ex    DE, HL                  ; Calculate address of new free block 
8e35 2b			      dec   HL 
8e36 2b			      dec   HL 
8e37 2b			      dec   HL 
8e38 09			      add   HL, BC 
8e39			 
8e39			      ; Create a new block and point it at next_free 
8e39 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
8e3c dd 56 01		      ld    D, (IX+1) 
8e3f			 
8e3f 73			      ld    (HL), E                 ; Store next_free ptr into new block 
8e40 23			      inc   HL 
8e41 72			      ld    (HL), D 
8e42			 
8e42 d1			      pop   DE                      ; Store size of new block into new block 
8e43 23			      inc   HL 
8e44 73			      ld    (HL), E 
8e45 23			      inc   HL 
8e46 72			      ld    (HL), D 
8e47			 
8e47			      ; Update this_free ptr to point to new block 
8e47 2b			      dec   HL 
8e48 2b			      dec   HL 
8e49 2b			      dec   HL 
8e4a			 
8e4a dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8e4d dd 56 03		      ld    D, (IX+3) 
8e50			 
8e50 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8e53 dd 74 03		      ld    (IX+3), H 
8e56			 
8e56			      ; Modify this_free block to be allocation 
8e56 eb			      ex    DE, HL 
8e57 af			      xor   A                       ; Null the next block ptr of allocated block 
8e58 77			      ld    (HL), A 
8e59 23			      inc   HL 
8e5a 77			      ld    (HL), A 
8e5b			 
8e5b 23			      inc   HL                      ; Store want size into allocated block 
8e5c 71			      ld    (HL), C 
8e5d 23			      inc   HL 
8e5e 70			      ld    (HL), B 
8e5f 23			      inc   HL 
8e60 e5			      push  HL                      ; Address of allocation to return 
8e61			 
8e61 18 19		      jr    malloc_update_links 
8e63			 
8e63			malloc_alloc_fit: 
8e63 e1			      pop   HL                      ; Dont need new block size, want is exact fit 
8e64			 
8e64					if DEBUG_FORTH_MALLOC 
8e64						DMARK "MAf" 
8e64						CALLMONITOR 
8e64					endif 
8e64			      ; Modify this_free block to be allocation 
8e64 eb			      ex    DE, HL 
8e65 2b			      dec   HL 
8e66 2b			      dec   HL 
8e67 2b			      dec   HL 
8e68			 
8e68 af			      xor   A                       ; Null the next block ptr of allocated block 
8e69 77			      ld    (HL), A 
8e6a 23			      inc   HL 
8e6b 77			      ld    (HL), A 
8e6c			 
8e6c 23			      inc   HL                      ; Store address of allocation to return 
8e6d 23			      inc   HL 
8e6e 23			      inc   HL 
8e6f e5			      push  HL 
8e70			 
8e70			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8e70 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
8e73 dd 66 01		      ld    H, (IX+1) 
8e76			 
8e76 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
8e79 dd 74 03		      ld    (IX+3), H 
8e7c			 
8e7c			 
8e7c			malloc_update_links: 
8e7c			      ; Update prev_free ptr to point to this_free 
8e7c dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
8e7f dd 66 05		      ld    H, (IX+5) 
8e82			 
8e82 dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
8e85 dd 56 03		      ld    D, (IX+3) 
8e88			 
8e88 73			      ld    (HL), E                 ; this_free ptr into prev_free 
8e89 23			      inc   HL 
8e8a 72			      ld    (HL), D 
8e8b			 
8e8b					if DEBUG_FORTH_MALLOC 
8e8b						DMARK "Mul" 
8e8b						CALLMONITOR 
8e8b					endif 
8e8b			      ; Clear the Z flag to indicate successful allocation 
8e8b 7a			      ld    A, D 
8e8c b3			      or    E 
8e8d			 
8e8d d1			      pop   DE                      ; Address of allocation 
8e8e					if DEBUG_FORTH_MALLOC 
8e8e						DMARK "MAu" 
8e8e						CALLMONITOR 
8e8e					endif 
8e8e			 
8e8e			malloc_no_space: 
8e8e 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
8e91 39			      add   HL, SP 
8e92 f9			      ld    SP, HL 
8e93			 
8e93 eb			      ex    DE, HL                  ; Alloc addr into HL for return 
8e94					if DEBUG_FORTH_MALLOC 
8e94						DMARK "MAN" 
8e94						CALLMONITOR 
8e94					endif 
8e94			 
8e94			malloc_early_exit: 
8e94					if DEBUG_FORTH_MALLOC 
8e94						DMARK "MAx" 
8e94						CALLMONITOR 
8e94					endif 
8e94 dd e1		      pop   IX 
8e96 d1			      pop   DE 
8e97 c1			      pop   BC 
8e98			 
8e98			if DEBUG_FORTH_MALLOC_HIGH 
8e98			call malloc_guard_exit 
8e98			call malloc_guard_zerolen 
8e98			endif 
8e98 c9			      ret 
8e99			 
8e99			 
8e99			;------------------------------------------------------------------------------ 
8e99			;     free                                                                    : 
8e99			;                                                                             : 
8e99			; Description                                                                 : 
8e99			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8e99			;     returned by malloc, otherwise the behaviour is undefined.               : 
8e99			;                                                                             : 
8e99			;     Where possible, directly adjacent free blocks will be merged together   : 
8e99			;     into larger blocks to help ensure that the heap does not become         : 
8e99			;     excessively fragmented.                                                 : 
8e99			;                                                                             : 
8e99			;     free does not clear or set any other value into the freed space, and    : 
8e99			;     therefore its contents may be visible through subsequent malloc's. The  : 
8e99			;     caller should clear the freed space as required.                        : 
8e99			;                                                                             : 
8e99			;     This implementation of free uses the stack exclusively, and is          : 
8e99			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8e99			;     advisable to disable interrupts before calling free, and recommended    : 
8e99			;     to avoid the use of free inside ISRs in general.                        : 
8e99			;                                                                             : 
8e99			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8e99			;                                                                             : 
8e99			; Parameters                                                                  : 
8e99			;     HL  Pointer to address of first byte of allocation to be freed          : 
8e99			;                                                                             : 
8e99			; Returns                                                                     : 
8e99			;     Nothing                                                                 : 
8e99			;                                                                             : 
8e99			; Stack frame                                                                 : 
8e99			;       |             |                                                       : 
8e99			;       +-------------+                                                       : 
8e99			;       |     BC      |                                                       : 
8e99			;       +-------------+                                                       : 
8e99			;       |     DE      |                                                       : 
8e99			;       +-------------+                                                       : 
8e99			;       |     IX      |                                                       : 
8e99			;       +-------------+                                                       : 
8e99			;       |  prev_free  |                                                       : 
8e99			;   +2  +-------------+                                                       : 
8e99			;       |  next_free  |                                                       : 
8e99			;   +0  +-------------+                                                       : 
8e99			;       |             |                                                       : 
8e99			;                                                                             : 
8e99			;------------------------------------------------------------------------------ 
8e99			free: 
8e99 c5			      push  BC 
8e9a d5			      push  DE 
8e9b dd e5		      push  IX 
8e9d			 
8e9d 7c			      ld    A, H                    ; Exit if ptr is null 
8e9e b5			      or    L 
8e9f ca 63 8f		      jp    Z, free_early_exit 
8ea2			 
8ea2			      ; Set up stack frame 
8ea2 eb			      ex    DE, HL 
8ea3 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8ea6 39			      add   HL, SP 
8ea7 f9			      ld    SP, HL 
8ea8 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
8eac dd 39		      add   IX, SP 
8eae			 
8eae			      ; The address in HL points to the start of the useable allocated space, 
8eae			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8eae			      ; address of the block itself. 
8eae eb			      ex    DE, HL 
8eaf 11 fc ff		      ld    DE, -4 
8eb2 19			      add   HL, DE 
8eb3			 
8eb3			      ; An allocated block must have a null next block pointer in it 
8eb3 7e			      ld    A, (HL) 
8eb4 23			      inc   HL 
8eb5 b6			      or    (HL) 
8eb6 c2 5e 8f		      jp    NZ, free_done 
8eb9			 
8eb9 2b			      dec   HL 
8eba			 
8eba 44			      ld    B, H                    ; Copy HL to BC 
8ebb 4d			      ld    C, L 
8ebc			 
8ebc			      ; Loop through the free list to find the first block with an address 
8ebc			      ; higher than the block being freed 
8ebc 21 55 cf		      ld    HL, free_list 
8ebf			 
8ebf			free_find_higher_block: 
8ebf 5e			      ld    E, (HL)                 ; Load next ptr from free block 
8ec0 23			      inc   HL 
8ec1 56			      ld    D, (HL) 
8ec2 2b			      dec   HL 
8ec3			 
8ec3 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
8ec6 dd 72 01		      ld    (IX+1), D 
8ec9 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
8ecc dd 74 03		      ld    (IX+3), H 
8ecf			 
8ecf 78			      ld    A, B                    ; Check if DE is greater than BC 
8ed0 ba			      cp    D                       ; Compare MSB first 
8ed1 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
8ed3 30 04		      jr    NC, free_find_higher_block_skip 
8ed5 79			      ld    A, C 
8ed6 bb			      cp    E                       ; Then compare LSB 
8ed7 38 08		      jr    C, free_found_higher_block 
8ed9			 
8ed9			free_find_higher_block_skip: 
8ed9 7a			      ld    A, D                    ; Reached the end of the free list? 
8eda b3			      or    E 
8edb ca 5e 8f		      jp    Z, free_done 
8ede			 
8ede eb			      ex    DE, HL 
8edf			 
8edf 18 de		      jr    free_find_higher_block 
8ee1			 
8ee1			free_found_higher_block: 
8ee1			      ; Insert freed block between prev and next free blocks 
8ee1 71			      ld    (HL), C                 ; Point prev free block to freed block 
8ee2 23			      inc   HL 
8ee3 70			      ld    (HL), B 
8ee4			 
8ee4 60			      ld    H, B                    ; Point freed block at next free block 
8ee5 69			      ld    L, C 
8ee6 73			      ld    (HL), E 
8ee7 23			      inc   HL 
8ee8 72			      ld    (HL), D 
8ee9			 
8ee9			      ; Check if the freed block is adjacent to the next free block 
8ee9 23			      inc   HL                      ; Load size of freed block into HL 
8eea 5e			      ld    E, (HL) 
8eeb 23			      inc   HL 
8eec 56			      ld    D, (HL) 
8eed eb			      ex    DE, HL 
8eee			 
8eee 09			      add   HL, BC                  ; Add addr of freed block and its size 
8eef			 
8eef dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
8ef2 dd 56 01		      ld    D, (IX+1) 
8ef5			 
8ef5 b7			      or    A                       ; Clear the carry flag 
8ef6 ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8ef8 20 22		      jr    NZ, free_check_adjacent_to_prev 
8efa			 
8efa			      ; Freed block is adjacent to next, merge into one bigger block 
8efa eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
8efb 5e			      ld    E, (HL) 
8efc 23			      inc   HL 
8efd 56			      ld    D, (HL) 
8efe e5			      push  HL                      ; Save ptr to next block for later 
8eff			 
8eff 60			      ld    H, B                    ; Store ptr from next block into freed block 
8f00 69			      ld    L, C 
8f01 73			      ld    (HL), E 
8f02 23			      inc   HL 
8f03 72			      ld    (HL), D 
8f04			 
8f04 e1			      pop   HL                      ; Restore ptr to next block 
8f05 23			      inc   HL                      ; Load size of next block into DE 
8f06 5e			      ld    E, (HL) 
8f07 23			      inc   HL 
8f08 56			      ld    D, (HL) 
8f09 d5			      push  DE                      ; Save next block size for later 
8f0a			 
8f0a 60			      ld    H, B                    ; Load size of freed block into HL 
8f0b 69			      ld    L, C 
8f0c 23			      inc   HL 
8f0d 23			      inc   HL 
8f0e 5e			      ld    E, (HL) 
8f0f 23			      inc   HL 
8f10 56			      ld    D, (HL) 
8f11 eb			      ex    DE, HL 
8f12			 
8f12 d1			      pop   DE                      ; Restore size of next block 
8f13 19			      add   HL, DE                  ; Add sizes of both blocks 
8f14 eb			      ex    DE, HL 
8f15			 
8f15 60			      ld    H, B                    ; Store new bigger size into freed block 
8f16 69			      ld    L, C 
8f17 23			      inc   HL 
8f18 23			      inc   HL 
8f19 73			      ld    (HL), E 
8f1a 23			      inc   HL 
8f1b 72			      ld    (HL), D 
8f1c			 
8f1c			free_check_adjacent_to_prev: 
8f1c			      ; Check if the freed block is adjacent to the prev free block 
8f1c dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
8f1f dd 66 03		      ld    H, (IX+3) 
8f22			 
8f22 23			      inc   HL                      ; Size of prev free block into DE 
8f23 23			      inc   HL 
8f24 5e			      ld    E, (HL) 
8f25 23			      inc   HL 
8f26 56			      ld    D, (HL) 
8f27 2b			      dec   HL 
8f28 2b			      dec   HL 
8f29 2b			      dec   HL 
8f2a			 
8f2a 19			      add   HL, DE                  ; Add prev block addr and size 
8f2b			 
8f2b b7			      or    A                       ; Clear the carry flag 
8f2c ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8f2e 20 2e		      jr    NZ, free_done 
8f30			 
8f30			      ; Freed block is adjacent to prev, merge into one bigger block 
8f30 60			      ld    H, B                    ; Load next ptr from freed block into DE 
8f31 69			      ld    L, C 
8f32 5e			      ld    E, (HL) 
8f33 23			      inc   HL 
8f34 56			      ld    D, (HL) 
8f35 e5			      push  HL                      ; Save freed block ptr for later 
8f36			 
8f36 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8f39 dd 66 03		      ld    H, (IX+3) 
8f3c 73			      ld    (HL), E 
8f3d 23			      inc   HL 
8f3e 72			      ld    (HL), D 
8f3f			 
8f3f e1			      pop   HL                      ; Restore freed block ptr 
8f40 23			      inc   HL                      ; Load size of freed block into DE 
8f41 5e			      ld    E, (HL) 
8f42 23			      inc   HL 
8f43 56			      ld    D, (HL) 
8f44 d5			      push  DE                      ; Save freed block size for later 
8f45			 
8f45 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
8f48 dd 66 03		      ld    H, (IX+3) 
8f4b 23			      inc   HL 
8f4c 23			      inc   HL 
8f4d 5e			      ld    E, (HL) 
8f4e 23			      inc   HL 
8f4f 56			      ld    D, (HL) 
8f50			 
8f50 e1			      pop   HL                      ; Add sizes of both blocks 
8f51 19			      add   HL, DE 
8f52 eb			      ex    DE, HL 
8f53			 
8f53 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
8f56 dd 66 03		      ld    H, (IX+3) 
8f59 23			      inc   HL 
8f5a 23			      inc   HL 
8f5b 73			      ld    (HL), E 
8f5c 23			      inc   HL 
8f5d 72			      ld    (HL), D 
8f5e			 
8f5e			free_done: 
8f5e 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
8f61 39			      add   HL, SP 
8f62 f9			      ld    SP, HL 
8f63			 
8f63			free_early_exit: 
8f63 dd e1		      pop   IX 
8f65 d1			      pop   DE 
8f66 c1			      pop   BC 
8f67			 
8f67 c9			      ret 
8f68			 
