12ce			 
12ce 3e c8			ld a, 200 
12d0 32 82 f9			ld (tape_tm_freq), a 
12d3			 
12d3 21 32 00			ld hl, 50 
12d6 22 80 f9			ld (tape_tm_high), hl 
12d9			 
12d9 21 0a 00			ld hl, 10 
12dc 22 7e f9			ld (tape_tm_low), hl 
12df c9				ret 
12e0			 
