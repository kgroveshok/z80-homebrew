9685			; forth parser 
9685			 
9685			; My forth kernel 
9685			include "forth_kernel.asm" 
9685			; 
9685			; kernel to the forth OS 
9685			 
9685			DS_TYPE_STR: equ 1     ; string type 
9685			DS_TYPE_INUM: equ 2     ; $ 16 bit unsigned int usually a hex address 
9685			DS_TYPE_SNUM: equ 3     ; $ 16 bit signed int  
9685			DS_TYPE_CONST: equ 4     ; string type that won't be freed on a POP 
9685			;DS_TYPE_FNUM: equ 3      ; 24/32 bit floating point  do string conversion instead of a new type 
9685			 
9685			FORTH_PARSEV1: equ 0 
9685			FORTH_PARSEV2: equ 0 
9685			FORTH_PARSEV3: equ 0 
9685			FORTH_PARSEV4: equ 0 
9685			FORTH_PARSEV5: equ 0 
9685			FORTH_PARSEV6: equ 1 
9685			 
9685			;if FORTH_PARSEV5 
9685			;	FORTH_END_BUFFER: equ 0 
9685			;else 
9685			FORTH_END_BUFFER: equ 127 
9685			;endif 
9685			 
9685			FORTH_TRUE: equ 1 
9685			FORTH_FALSE: equ 0 
9685			 
9685			if FORTH_PARSEV4 
9685			include "forth_stackops.asm" 
9685			endif 
9685			 
9685			if FORTH_PARSEV5 
9685			include "forth_stackopsv5.asm" 
9685			endif 
9685			 
9685			if FORTH_PARSEV6 
9685			include "forth_stackopsv5.asm" 
9685			 
9685			; Stack operations for v5 parser on wards 
9685			; * DATA stack 
9685			; * LOOP stack 
9685			; * RETURN stack 
9685			 
9685			 
9685			 
9685			FORTH_CHK_DSP_UNDER: macro 
9685				push hl 
9685				push de 
9685				ld hl,(cli_data_sp) 
9685				ld de, cli_data_stack 
9685				call cmp16 
9685				jp c, fault_dsp_under 
9685				pop de 
9685				pop hl 
9685				endm 
9685			 
9685			 
9685			FORTH_CHK_RSP_UNDER: macro 
9685				push hl 
9685				push de 
9685				ld hl,(cli_ret_sp) 
9685				ld de, cli_ret_stack 
9685				call cmp16 
9685				jp c, fault_rsp_under 
9685				pop de 
9685				pop hl 
9685				endm 
9685			 
9685			FORTH_CHK_LOOP_UNDER: macro 
9685				push hl 
9685				push de 
9685				ld hl,(cli_loop_sp) 
9685				ld de, cli_loop_stack 
9685				call cmp16 
9685				jp c, fault_loop_under 
9685				pop de 
9685				pop hl 
9685				endm 
9685			 
9685			FORTH_ERR_TOS_NOTSTR: macro 
9685				; TOSO might need more for checks when used 
9685				push af 
9685				ld a,(hl) 
9685				cp DS_TYPE_STR 
9685				jp nz, type_faultn   
9685				pop af 
9685				endm 
9685			 
9685			FORTH_ERR_TOS_NOTNUM: macro 
9685				push af 
9685				ld a,(hl) 
9685				cp DS_TYPE_INUM 
9685				jp nz, type_faultn   
9685				pop af 
9685				endm 
9685			 
9685			 
9685			; increase data stack pointer and save hl to it 
9685				 
9685			FORTH_DSP_NEXT: macro 
9685				call macro_forth_dsp_next 
9685				endm 
9685			 
9685			 
9685			macro_forth_dsp_next: 
9685				if DEBUG_FORTH_STACK_GUARD 
9685 cd 9b cb				call check_stacks 
9688				endif 
9688 e5				push hl 
9689 d5				push de 
968a eb				ex de,hl 
968b 2a e1 e9			ld hl,(cli_data_sp) 
968e 23				inc hl 
968f 23				inc hl 
9690			 
9690			; PARSEV5 
9690 23				inc hl 
9691 22 e1 e9			ld (cli_data_sp),hl 
9694 73				ld (hl), e 
9695 23				inc hl 
9696 72				ld (hl), d 
9697 d1				pop de 
9698 e1				pop hl 
9699				if DEBUG_FORTH_STACK_GUARD 
9699 cd 9b cb				call check_stacks 
969c				endif 
969c c9				ret 
969d			 
969d			 
969d			; increase ret stack pointer and save hl to it 
969d				 
969d			FORTH_RSP_NEXT: macro 
969d				call macro_forth_rsp_next 
969d				endm 
969d			 
969d			macro_forth_rsp_next: 
