25b6			.NEW: 
25b6			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
25b6 15				db WORD_SYS_CORE+OPCODE_HEAP             
25b7 d0 25			dw .HEAP            
25b9 04				db 3 + 1 
25ba .. 00			db "NEW",0              
25be				endm 
# End of macro CWHEAD
25be			; | NEW ( -- ) Clears all user words and stack | DONE 
25be				 
25be				if MALLOC_4 
25be					call  heap_init 
25be				endif 
25be				; reset uword pointers 
25be 21 00 80			ld hl, baseram 
25c1 22 da f3			ld (os_last_new_uword), hl 
25c4 cd 0a 24			call user_word_eol 
25c7				; clear stack 
25c7 cd 23 24			call forth_warmstart 
25ca				NEXTW 
25ca cd a3 fd			call parse_vector 
25cd c3 7d 24			jp macro_next 
25d0				endm 
# End of macro NEXTW
25d0			 
25d0			.HEAP: 
25d0			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
25d0 15				db WORD_SYS_CORE+OPCODE_HEAP             
25d1 01 26			dw .EXEC            
25d3 05				db 4 + 1 
25d4 .. 00			db "HEAP",0              
25d9				endm 
# End of macro CWHEAD
25d9			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
25d9			; | | u1 - Current number of bytes in the heap 
25d9			; | | u2 - Remaining bytes left on the heap 
25d9			; | |  
25d9			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
25d9			 
25d9			 
25d9				if DEBUG_FORTH_WORDS_KEY 
25d9					DMARK "HEP" 
25d9				if DEMARK_VERSION = 1  
25d9 e5					push hl  
25da 21 e2 25				ld hl, .dmark  
25dd 22 9b fd				ld (debug_mark), hl  
25e0				endif  
25e0				if DEMARK_VERSION = 0  
25e0					push af  
25e0					ld a, (.dmark)  
25e0					ld (debug_mark),a  
25e0					ld a, (.dmark+1)  
25e0					ld (debug_mark+1),a  
25e0					ld a, (.dmark+2)  
25e0					ld (debug_mark+2),a  
25e0				endif  
25e0 18 04			jr .pastdmark  
25e2 ..			.dmark: db "HEP"  
25e5				if DEMARK_VERSION = 1  
25e5 00					db 0  
25e6				endif  
25e6				if DEMARK_VERSION = 1  
25e6 e1			.pastdmark: pop hl  
25e7				endif  
25e7				if DEMARK_VERSION = 0  
25e7			.pastdmark: pop af  
25e7				endif  
25e7			endm  
# End of macro DMARK
25e7					CALLMONITOR 
25e7				if BASE_CPM=1  
25e7					call debug_vector  
25e7				endif  
25e7				if BASE_KEV=1  
25e7 cf					rst 8  
25e8				endif  
25e8				endm  
# End of macro CALLMONITOR
25e8				endif 
25e8 2a 0a 80			ld hl, (free_list )      
25eb 11 0e 80			ld de, heap_start 
25ee			 
25ee ed 52			sbc hl, de  
