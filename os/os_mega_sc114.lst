a732					ld (debug_mark+1),a  
a732					ld a, (.dmark+2)  
a732					ld (debug_mark+2),a  
a732				endif  
a732 18 04			jr .pastdmark  
a734 ..			.dmark: db "SCR"  
a737				if DEMARK_VERSION = 1  
a737 00					db 0  
a738				endif  
