bf34					ld (debug_mark+1),a  
bf34					ld a, (.dmark+2)  
bf34					ld (debug_mark+2),a  
bf34				endif  
bf34 18 04			jr .pastdmark  
bf36 ..			.dmark: db "VAR"  
bf39				if DEMARK_VERSION = 1  
bf39 00					db 0  
bf3a				endif  
bf3a				if DEMARK_VERSION = 1  
bf3a e1			.pastdmark: pop hl  
bf3b				endif  
bf3b				if DEMARK_VERSION = 0  
