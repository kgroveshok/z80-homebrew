4296			 
4296			.SESEL: 
4296				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
4296			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
4296			; | | Zero is disabled storage. 
4296					if DEBUG_FORTH_WORDS_KEY 
4296						DMARK "BN?" 
4296						CALLMONITOR 
4296					endif 
4296					ld a, (spi_device_id) 
4296					sub '0' 
4296					ld h, 0 
4296					ld l, a 
4296					FORTH_PUSH_VALUEHL 
4296					;call forth_push_numhl 
4296					NEXTW 
4296			.SESELS: 
4296				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
4296			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
4296			; | | Set to zero to disable storage. 
4296					if DEBUG_FORTH_WORDS_KEY 
4296						DMARK "BNK" 
4296						CALLMONITOR 
4296					endif 
4296			 
4296					ld a, 255 
4296					ld (spi_cartdev), a 
4296			 
4296					; get bank 
4296			 
4296					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4296			 
4296			;		push hl 
4296			 
4296					; destroy value TOS 
4296			 
4296					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4296			 
4296					; one value on hl get other one back 
4296			 
4296			;		pop hl 
4296			 
4296			 
4296					ld c, SPI_CE_HIGH 
4296					ld b, '0'    ; human readable bank number 
4296			 
4296					ld a, l 
4296			 
4296					if DEBUG_FORTH_WORDS 
4296						DMARK "BNK" 
4296						CALLMONITOR 
4296					endif 
4296			 
4296					; active low 
4296			 
4296			;		cp 0 
4296					or a 
4296					jr z, .bset 
4296					cp 1 
4296					jr nz, .b2 
4296					res 0, c 
4296					ld b, '1'    ; human readable bank number 
4296			.b2:		cp 2 
4296					jr nz, .b3 
4296					res 1, c 
4296					ld b, '2'    ; human readable bank number 
4296			.b3:		cp 3 
4296					jr nz, .b4 
4296					res 2, c 
4296					ld b, '3'    ; human readable bank number 
4296			.b4:		cp 4 
4296					jr nz, .b5 
4296					res 3, c 
4296					ld b, '4'    ; human readable bank number 
4296			.b5:		cp 5 
4296					jr nz, .bset 
4296					res 4, c 
4296					ld b, '5'    ; human readable bank number 
4296			 
4296			.bset: 
4296					ld a, c 
4296					ld (spi_device),a 
4296					ld a, b 
4296					ld (spi_device_id),a 
4296					if DEBUG_FORTH_WORDS 
4296						DMARK "BN2" 
4296						CALLMONITOR 
4296					endif 
4296			 
4296					; set default SPI clk pulse time as disabled for BANK use 
4296			 
4296					ld a, 0 
4296					ld (spi_clktime), a 
4296			 
4296					NEXTW 
4296			 
4296			.CARTDEV: 
4296				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
4296			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
4296			; | | Set to zero to disable devices. 
4296					if DEBUG_FORTH_WORDS_KEY 
4296						DMARK "CDV" 
4296						CALLMONITOR 
4296					endif 
4296			 
4296					; disable se storage bank selection 
4296			 
4296					ld a, SPI_CE_HIGH		; ce high 
4296					ld (spi_device), a 
4296			 
4296					; get bank 
4296			 
4296					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4296			 
4296			;		push hl 
4296			 
4296					; destroy value TOS 
4296			 
4296					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4296			 
4296					; one value on hl get other one back 
4296			 
4296			;		pop hl 
4296			 
4296					; active low 
4296			 
4296					ld c, 255 
4296			 
4296					ld a, l 
4296					if DEBUG_FORTH_WORDS 
4296						DMARK "CDV" 
4296						CALLMONITOR 
4296					endif 
4296			;		cp 0 
4296					or a 
4296					jr z, .cset 
4296					cp 1 
4296					jr nz, .c2 
4296					res 0, c 
4296			.c2:		cp 2 
4296					jr nz, .c3 
4296					res 1, c 
4296			.c3:		cp 3 
4296					jr nz, .c4 
4296					res 2, c 
4296			.c4:		cp 4 
4296					jr nz, .c5 
4296					res 3, c 
4296			.c5:		cp 5 
4296					jr nz, .c6 
4296					res 4, c 
4296			.c6:		cp 6 
4296					jr nz, .c7 
4296					res 5, c 
4296			.c7:		cp 7 
4296					jr nz, .c8 
4296					res 6, c 
4296			.c8:		cp 8 
4296					jr nz, .cset 
4296					res 7, c 
4296			.cset:		ld a, c 
4296					ld (spi_cartdev),a 
4296			 
4296					if DEBUG_FORTH_WORDS 
4296						DMARK "CD2" 
4296						CALLMONITOR 
4296					endif 
4296			 
4296					; set default SPI clk pulse time as 10ms for CARTDEV use 
4296			 
4296					ld a, $0a 
4296					ld (spi_clktime), a 
4296					NEXTW 
4296			endif 
4296			 
4296			.ENDDEVICE: 
