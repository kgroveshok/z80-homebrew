115e			;heap_start        .equ  0x9000      ; Starting address of heap 
115e			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
115e			; 
115e			 ;     .org 0 
115e			  ;    jp    main 
115e			; 
115e			; 
115e			 ;     .org  0x100 
115e			;main: 
115e			 ;     ld    HL, 0x8100 
115e			  ;    ld    SP, HL 
115e			; 
115e			;      call  heap_init 
115e			 
115e			      ; Make some allocations 
115e			;      ld    HL, 12 
115e			;      call  malloc            ; Allocates 0x9004 
115e			; 
115e			 ;     ld    HL, 12 
115e			;      call  malloc            ; Allocates 0x9014 
115e			 
115e			;      ld    HL, 12 
115e			;      call  malloc            ; Allocates 0x9024 
115e			 
115e			      ; Free some allocations 
115e			;      ld    HL, 0x9014 
115e			;      call  free 
115e			 
115e			;      ld    HL, 0x9004 
115e			;      call  free 
115e			; 
115e			;      ld    HL, 0x9024 
115e			;      call  free 
115e			 
115e			 
115e			 ;     halt 
115e			 
115e			 
115e			;------------------------------------------------------------------------------ 
115e			;     heap_init                                                               : 
115e			;                                                                             : 
115e			; Description                                                                 : 
115e			;     Initialise the heap and make it ready for malloc and free operations.   : 
115e			;                                                                             : 
115e			;     The heap is maintained as a linked list, starting with an initial       : 
115e			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
115e			;     the first free block in the heap. Each block then points to the next    : 
115e			;     free block within the heap, and the free list ends at the first block   : 
115e			;     with a null pointer to the next free block.                             : 
115e			;                                                                             : 
115e			; Parameters                                                                  : 
115e			;     Inputs are compile-time only. Two defines which specify the starting    : 
115e			;     address of the heap and its size are required, along with a memory      : 
115e			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
115e			;     principally stores a pointer to the first free block in the heap.       : 
115e			;                                                                             : 
115e			; Returns                                                                     : 
115e			;     Nothing                                                                 : 
115e			;------------------------------------------------------------------------------ 
115e			heap_init: 
115e			      push  HL 
115e			 
115e			      ; Initialise free list struct 
115e			      ld    HL, heap_start 
115e			      ld    (free_list), HL 
115e			      ld    HL, 0 
115e			      ld    (free_list+2), HL 
115e			 
115e			      ; Insert first free block at bottom of heap, consumes entire heap 
115e			      ld    HL, heap_start+heap_size-4 
115e			      ld    (heap_start), HL        ; Next block (end of free list) 
115e			      ld    HL, heap_size-4 
115e			      ld    (heap_start+2), HL      ; Block size 
115e			 
115e			      ; Insert end of free list block at top of heap - two null words will 
115e			      ; terminate the free list 
115e			      ld    HL, 0 
115e			      ld    (heap_start+heap_size-2), HL 
115e			      ld    (heap_start+heap_size-4), HL 
115e			 
115e			      pop   HL 
115e			 
115e			      ret 
115e			 
115e			 
115e			;------------------------------------------------------------------------------ 
115e			;     malloc                                                                  : 
115e			;                                                                             : 
115e			; Description                                                                 : 
115e			;     Allocates the wanted space from the heap and returns the address of the : 
115e			;     first useable byte of the allocation.                                   : 
115e			;                                                                             : 
115e			;     Allocations can happen in one of two ways:                              : 
115e			;                                                                             : 
115e			;     1. A free block may be found which is the exact size wanted. In this    : 
115e			;        case the block is removed from the free list and retuedn to the      : 
115e			;        caller.                                                              : 
115e			;     2. A free block may be found which is larger than the size wanted. In   : 
115e			;        this case, the larger block is split into two. The first portion of  : 
115e			;        this block will become the requested space by the malloc call and    : 
115e			;        is returned to the caller. The second portion becomes a new free     : 
115e			;        block, and the free list is adjusted to maintain continuity via this : 
115e			;        newly created block.                                                 : 
115e			;                                                                             : 
115e			;     malloc does not set any initial value in the allocated space, the       : 
115e			;     caller is required to do this as required.                              : 
115e			;                                                                             : 
115e			;     This implementation of malloc uses the stack exclusively, and is        : 
115e			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
115e			;     advisable to disable interrupts before calling malloc, and recommended  : 
115e			;     to avoid the use of malloc inside ISRs in general.                      : 
115e			;                                                                             : 
115e			;     NOTE: heap_init must be called before malloc and free can be used.      : 
115e			;                                                                             : 
115e			; Parameters                                                                  : 
115e			;     HL  Number of bytes wanted                                              : 
115e			;                                                                             : 
115e			; Returns                                                                     : 
115e			;     HL  Address of the first useable byte of the allocation                 : 
115e			;                                                                             : 
115e			; Flags                                                                       : 
115e			;     Z   Set if the allocation did not succeed, clear otherwise              : 
115e			;                                                                             : 
115e			; Stack frame                                                                 : 
115e			;       |             |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |     BC      |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |     DE      |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |     IX      |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |  prev_free  |                                                       : 
115e			;   +4  +-------------+                                                       : 
115e			;       |  this_free  |                                                       : 
115e			;   +2  +-------------+                                                       : 
115e			;       |  next_free  |                                                       : 
115e			;   +0  +-------------+                                                       : 
115e			;       |             |                                                       : 
115e			;                                                                             : 
115e			;------------------------------------------------------------------------------ 
115e			malloc: 
115e			      push  BC 
115e			      push  DE 
115e			      push  IX 
115e			 
115e			      ld    A, H                    ; Exit if no space requested 
115e			      or    L 
115e			      jp    Z, malloc_early_exit 
115e			 
115e			      ; Set up stack frame 
115e			      ex    DE, HL 
115e			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
115e			      add   HL, SP 
115e			      ld    SP, HL 
115e			      ld    IX, 0                   ; Use IX as a frame pointer 
115e			      add   IX, SP 
115e			 
115e			      ; Setup initial state 
115e			      ld    HL, 4                   ; want must also include space used by block struct 
115e			      add   HL, DE 
115e			 
115e			      ld    B, H                    ; Move want to BC 
115e			      ld    C, L 
115e			 
115e			      ld    HL, free_list           ; Store prev_free ptr to stack 
115e			      ld    (IX+4), L 
115e			      ld    (IX+5), H 
115e			 
115e			      ld    E, (HL)                 ; Store this_free ptr to stack 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      ld    (IX+2), E 
115e			      ld    (IX+3), D 
115e			      ex    DE, HL                  ; this_free ptr into HL 
115e			 
115e			      ; Loop through free block list to find some space 
115e			malloc_find_space: 
115e			      ld    E, (HL)                 ; Load next_free ptr into DE 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			 
115e			      ld    A, D                    ; Check for null next_free ptr - end of free list 
115e			      or    E 
115e			      jp    Z, malloc_no_space 
115e			 
115e			      ld    (IX+0), E               ; Store next_free ptr to stack 
115e			      ld    (IX+1), D 
115e			 
115e			      ; Does this block have enough space to make the allocation? 
115e			      inc   HL                      ; Load free block size into DE 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			 
115e			      ex    DE, HL                  ; Check size of block against want 
115e			      or    A                       ; Ensure carry flag clear 
115e			      sbc   HL, BC 
115e			      push  HL                      ; Store the result for later (new block size) 
115e			 
115e			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
115e			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
115e			 
115e			      ; this_free block is not big enough, setup ptrs to test next free block 
115e			      pop   HL                      ; Discard previous result 
115e			 
115e			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
115e			      ld    H, (IX+3) 
115e			      ld    (IX+4), L 
115e			      ld    (IX+5), H 
115e			 
115e			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
115e			      ld    H, (IX+1) 
115e			      ld    (IX+2), L 
115e			      ld    (IX+3), H 
115e			 
115e			      jr    malloc_find_space 
115e			 
115e			      ; split a bigger block into two - requested size and remaining size 
115e			malloc_alloc_split: 
115e			      ex    DE, HL                  ; Calculate address of new free block 
115e			      dec   HL 
115e			      dec   HL 
115e			      dec   HL 
115e			      add   HL, BC 
115e			 
115e			      ; Create a new block and point it at next_free 
115e			      ld    E, (IX+0)               ; Load next_free ptr into DE 
115e			      ld    D, (IX+1) 
115e			 
115e			      ld    (HL), E                 ; Store next_free ptr into new block 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			      pop   DE                      ; Store size of new block into new block 
115e			      inc   HL 
115e			      ld    (HL), E 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			      ; Update this_free ptr to point to new block 
115e			      dec   HL 
115e			      dec   HL 
115e			      dec   HL 
115e			 
115e			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
115e			      ld    D, (IX+3) 
115e			 
115e			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
115e			      ld    (IX+3), H 
115e			 
115e			      ; Modify this_free block to be allocation 
115e			      ex    DE, HL 
115e			      xor   A                       ; Null the next block ptr of allocated block 
115e			      ld    (HL), A 
115e			      inc   HL 
115e			      ld    (HL), A 
115e			 
115e			      inc   HL                      ; Store want size into allocated block 
115e			      ld    (HL), C 
115e			      inc   HL 
115e			      ld    (HL), B 
115e			      inc   HL 
115e			      push  HL                      ; Address of allocation to return 
115e			 
115e			      jr    malloc_update_links 
115e			 
115e			malloc_alloc_fit: 
115e			      pop   HL                      ; Dont need new block size, want is exact fit 
115e			 
115e			      ; Modify this_free block to be allocation 
115e			      ex    DE, HL 
115e			      dec   HL 
115e			      dec   HL 
115e			      dec   HL 
115e			 
115e			      xor   A                       ; Null the next block ptr of allocated block 
115e			      ld    (HL), A 
115e			      inc   HL 
115e			      ld    (HL), A 
115e			 
115e			      inc   HL                      ; Store address of allocation to return 
115e			      inc   HL 
115e			      inc   HL 
115e			      push  HL 
115e			 
115e			      ; Copy next_free ptr to this_free, remove allocated block from free list 
115e			      ld    L, (IX+0)               ; next_free to HL 
115e			      ld    H, (IX+1) 
115e			 
115e			      ld    (IX+2), L               ; HL to this_free 
115e			      ld    (IX+3), H 
115e			 
115e			 
115e			malloc_update_links: 
115e			      ; Update prev_free ptr to point to this_free 
115e			      ld    L, (IX+4)               ; prev_free ptr to HL 
115e			      ld    H, (IX+5) 
115e			 
115e			      ld    E, (IX+2)               ; this_free ptr to DE 
115e			      ld    D, (IX+3) 
115e			 
115e			      ld    (HL), E                 ; this_free ptr into prev_free 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			      ; Clear the Z flag to indicate successful allocation 
115e			      ld    A, D 
115e			      or    E 
115e			 
115e			      pop   DE                      ; Address of allocation 
115e			 
115e			malloc_no_space: 
115e			      ld    HL, 6                   ; Clean up stack frame 
115e			      add   HL, SP 
115e			      ld    SP, HL 
115e			 
115e			      ex    DE, HL                  ; Alloc addr into HL for return 
115e			 
115e			malloc_early_exit: 
115e			      pop   IX 
115e			      pop   DE 
115e			      pop   BC 
115e			 
115e			      ret 
115e			 
115e			 
115e			;------------------------------------------------------------------------------ 
115e			;     free                                                                    : 
115e			;                                                                             : 
115e			; Description                                                                 : 
115e			;     Return the space pointed to by HL to the heap. HL must be an address as : 
115e			;     returned by malloc, otherwise the behaviour is undefined.               : 
115e			;                                                                             : 
115e			;     Where possible, directly adjacent free blocks will be merged together   : 
115e			;     into larger blocks to help ensure that the heap does not become         : 
115e			;     excessively fragmented.                                                 : 
115e			;                                                                             : 
115e			;     free does not clear or set any other value into the freed space, and    : 
115e			;     therefore its contents may be visible through subsequent malloc's. The  : 
115e			;     caller should clear the freed space as required.                        : 
115e			;                                                                             : 
115e			;     This implementation of free uses the stack exclusively, and is          : 
115e			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
115e			;     advisable to disable interrupts before calling free, and recommended    : 
115e			;     to avoid the use of free inside ISRs in general.                        : 
115e			;                                                                             : 
115e			;     NOTE: heap_init must be called before malloc and free can be used.      : 
115e			;                                                                             : 
115e			; Parameters                                                                  : 
115e			;     HL  Pointer to address of first byte of allocation to be freed          : 
115e			;                                                                             : 
115e			; Returns                                                                     : 
115e			;     Nothing                                                                 : 
115e			;                                                                             : 
115e			; Stack frame                                                                 : 
115e			;       |             |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |     BC      |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |     DE      |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |     IX      |                                                       : 
115e			;       +-------------+                                                       : 
115e			;       |  prev_free  |                                                       : 
115e			;   +2  +-------------+                                                       : 
115e			;       |  next_free  |                                                       : 
115e			;   +0  +-------------+                                                       : 
115e			;       |             |                                                       : 
115e			;                                                                             : 
115e			;------------------------------------------------------------------------------ 
115e			free: 
115e			      push  BC 
115e			      push  DE 
115e			      push  IX 
115e			 
115e			      ld    A, H                    ; Exit if ptr is null 
115e			      or    L 
115e			      jp    Z, free_early_exit 
115e			 
115e			      ; Set up stack frame 
115e			      ex    DE, HL 
115e			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
115e			      add   HL, SP 
115e			      ld    SP, HL 
115e			      ld    IX, 0                   ; Use IX as a frame pointer 
115e			      add   IX, SP 
115e			 
115e			      ; The address in HL points to the start of the useable allocated space, 
115e			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
115e			      ; address of the block itself. 
115e			      ex    DE, HL 
115e			      ld    DE, -4 
115e			      add   HL, DE 
115e			 
115e			      ; An allocated block must have a null next block pointer in it 
115e			      ld    A, (HL) 
115e			      inc   HL 
115e			      or    (HL) 
115e			      jp    NZ, free_done 
115e			 
115e			      dec   HL 
115e			 
115e			      ld    B, H                    ; Copy HL to BC 
115e			      ld    C, L 
115e			 
115e			      ; Loop through the free list to find the first block with an address 
115e			      ; higher than the block being freed 
115e			      ld    HL, free_list 
115e			 
115e			free_find_higher_block: 
115e			      ld    E, (HL)                 ; Load next ptr from free block 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      dec   HL 
115e			 
115e			      ld    (IX+0), E               ; Save ptr to next free block 
115e			      ld    (IX+1), D 
115e			      ld    (IX+2), L               ; Save ptr to prev free block 
115e			      ld    (IX+3), H 
115e			 
115e			      ld    A, B                    ; Check if DE is greater than BC 
115e			      cp    D                       ; Compare MSB first 
115e			      jr    Z, $+4                  ; MSB the same, compare LSB 
115e			      jr    NC, free_find_higher_block_skip 
115e			      ld    A, C 
115e			      cp    E                       ; Then compare LSB 
115e			      jr    C, free_found_higher_block 
115e			 
115e			free_find_higher_block_skip: 
115e			      ld    A, D                    ; Reached the end of the free list? 
115e			      or    E 
115e			      jp    Z, free_done 
115e			 
115e			      ex    DE, HL 
115e			 
115e			      jr    free_find_higher_block 
115e			 
115e			free_found_higher_block: 
115e			      ; Insert freed block between prev and next free blocks 
115e			      ld    (HL), C                 ; Point prev free block to freed block 
115e			      inc   HL 
115e			      ld    (HL), B 
115e			 
115e			      ld    H, B                    ; Point freed block at next free block 
115e			      ld    L, C 
115e			      ld    (HL), E 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			      ; Check if the freed block is adjacent to the next free block 
115e			      inc   HL                      ; Load size of freed block into HL 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      ex    DE, HL 
115e			 
115e			      add   HL, BC                  ; Add addr of freed block and its size 
115e			 
115e			      ld    E, (IX+0)               ; Load addr of next free block into DE 
115e			      ld    D, (IX+1) 
115e			 
115e			      or    A                       ; Clear the carry flag 
115e			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
115e			      jr    NZ, free_check_adjacent_to_prev 
115e			 
115e			      ; Freed block is adjacent to next, merge into one bigger block 
115e			      ex    DE, HL                  ; Load next ptr from next block into DE 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      push  HL                      ; Save ptr to next block for later 
115e			 
115e			      ld    H, B                    ; Store ptr from next block into freed block 
115e			      ld    L, C 
115e			      ld    (HL), E 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			      pop   HL                      ; Restore ptr to next block 
115e			      inc   HL                      ; Load size of next block into DE 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      push  DE                      ; Save next block size for later 
115e			 
115e			      ld    H, B                    ; Load size of freed block into HL 
115e			      ld    L, C 
115e			      inc   HL 
115e			      inc   HL 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      ex    DE, HL 
115e			 
115e			      pop   DE                      ; Restore size of next block 
115e			      add   HL, DE                  ; Add sizes of both blocks 
115e			      ex    DE, HL 
115e			 
115e			      ld    H, B                    ; Store new bigger size into freed block 
115e			      ld    L, C 
115e			      inc   HL 
115e			      inc   HL 
115e			      ld    (HL), E 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			free_check_adjacent_to_prev: 
115e			      ; Check if the freed block is adjacent to the prev free block 
115e			      ld    L, (IX+2)               ; Prev free block ptr into HL 
115e			      ld    H, (IX+3) 
115e			 
115e			      inc   HL                      ; Size of prev free block into DE 
115e			      inc   HL 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      dec   HL 
115e			      dec   HL 
115e			      dec   HL 
115e			 
115e			      add   HL, DE                  ; Add prev block addr and size 
115e			 
115e			      or    A                       ; Clear the carry flag 
115e			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
115e			      jr    NZ, free_done 
115e			 
115e			      ; Freed block is adjacent to prev, merge into one bigger block 
115e			      ld    H, B                    ; Load next ptr from freed block into DE 
115e			      ld    L, C 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      push  HL                      ; Save freed block ptr for later 
115e			 
115e			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
115e			      ld    H, (IX+3) 
115e			      ld    (HL), E 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			      pop   HL                      ; Restore freed block ptr 
115e			      inc   HL                      ; Load size of freed block into DE 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			      push  DE                      ; Save freed block size for later 
115e			 
115e			      ld    L, (IX+2)               ; Load size of prev block into DE 
115e			      ld    H, (IX+3) 
115e			      inc   HL 
115e			      inc   HL 
115e			      ld    E, (HL) 
115e			      inc   HL 
115e			      ld    D, (HL) 
115e			 
115e			      pop   HL                      ; Add sizes of both blocks 
115e			      add   HL, DE 
115e			      ex    DE, HL 
115e			 
115e			      ld    L, (IX+2)               ; Store new bigger size into prev block 
115e			      ld    H, (IX+3) 
115e			      inc   HL 
115e			      inc   HL 
115e			      ld    (HL), E 
115e			      inc   HL 
115e			      ld    (HL), D 
115e			 
115e			free_done: 
115e			      ld    HL, 4                   ; Clean up stack frame 
115e			      add   HL, SP 
115e			      ld    SP, HL 
115e			 
115e			free_early_exit: 
115e			      pop   IX 
115e			      pop   DE 
115e			      pop   BC 
115e			 
115e			      ret 
115e			 
115e			 
115e			;      .org 0x8000 
115e			; 
115e			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
115e			 ;                 .dw   0 
115e			 
115e			endif 
115e			 
115e			 
115e			if MALLOC_4 
115e			 
115e			; My memory allocation code. Very very simple.... 
115e			; allocate space under 250 chars 
115e			 
115e			heap_init: 
115e				; init start of heap as zero 
115e				;  
115e			 
115e				ld hl, heap_start 
115e			;	ld a, 0 
115e				ld (hl), 0      ; empty block 
115e				inc hl 
115e			;	ld a, 0 
115e				ld (hl), 0      ; length of block 
115e				; write end of list 
115e				inc hl 
115e				ld a,(hl) 
115e				inc hl 
115e				ld a,(hl) 
115e				 
115e			 
115e				; init some malloc vars 
115e			 
115e				ld hl, 0 
115e				ld (free_list), hl       ; store last malloc location 
115e			 
115e				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
115e			;	ld a, 0 
115e				ld (hl), 0 
115e			 
115e			 
115e				ld hl, heap_start 
115e				;  
115e				  
115e				ret 
115e			 
115e			 
115e			;    free block marker 
115e			;    requested size  
115e			;    pointer to next block 
115e			;    .... 
115e			;    next block marker 
115e			 
115e			 
115e			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
115e			; 
115e			 
115e			 
115e			malloc:  
115e				push de 
115e				push bc 
115e				push af 
115e			 
115e				; hl space required 
115e				 
115e				ld c, l    ; hold space   (TODO only a max of 255) 
115e			 
115e			;	inc c     ; TODO BUG need to fix memory leak on push str 
115e			;	inc c 
115e			;	inc c 
115e			;	inc c 
115e			;	inc c 
115e			;	inc c 
115e			;	inc c 
115e			 
115e			 
115e			 
115e				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
115e			 
115e				ld a, (free_list+3) 
115e			;	cp 0 
115e				or a 
115e				jr z, .contheap 
115e			 
115e				ld hl, (free_list)     ; get last alloc 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "mrs" 
115e						CALLMONITOR 
115e					endif 
115e				jr .startalloc 
115e			 
115e			.contheap: 
115e				ld hl, heap_start 
115e			 
115e			.startalloc: 
115e			 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "mym" 
115e						CALLMONITOR 
115e					endif 
115e			.findblock: 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "mmf" 
115e						CALLMONITOR 
115e					endif 
115e			 
115e				ld a,(hl)  
115e				; if byte is zero then clear to use 
115e			 
115e			;	cp 0 
115e				or a 
115e				jr z, .foundemptyblock 
115e			 
115e				; if byte is not clear 
115e				;     then byte is offset to next block 
115e			 
115e				inc hl 
115e				ld a, (hl) ; get size 
115e			.nextblock:	inc hl 
115e					ld e, (hl) 
115e					inc hl 
115e					ld d, (hl) 
115e					ex de, hl 
115e			;	inc hl  ; move past the store space 
115e			;	inc hl  ; move past zero index  
115e			 
115e				; TODO detect no more space 
115e			 
115e				push hl 
115e				ld de, heap_end 
115e				call cmp16 
115e				pop hl 
115e				jr nc, .nospace 
115e			 
115e				jr .findblock 
115e			 
115e			.nospace: ld hl, 0 
115e				jp .exit 
115e			 
115e			 
115e			.foundemptyblock:	 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "mme" 
115e						CALLMONITOR 
115e					endif 
115e			 
115e			; TODO has block enough space if reusing??? 
115e			 
115e				;  
115e			 
115e			; see if this block has been previously used 
115e				inc hl 
115e				ld a, (hl) 
115e				dec hl 
115e			;	cp 0 
115e				or a 
115e				jr z, .newblock 
115e			 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "meR" 
115e						CALLMONITOR 
115e					endif 
115e			 
115e			; no reusing previously allocated block 
115e			 
115e			; is it smaller than previously used? 
115e				 
115e				inc hl    ; move to size 
115e				ld a, c 
115e				sub (hl)        ; we want c < (hl) 
115e				dec hl    ; move back to marker 
115e			        jr z, .findblock 
115e			 
115e				; update with the new size which should be lower 
115e			 
115e			        ;inc  hl   ; negate next move. move back to size  
115e			 
115e			.newblock: 
115e				; need to be at marker here 
115e			 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "meN" 
115e						CALLMONITOR 
115e					endif 
115e			 
115e			 
115e				ld a, c 
115e			 
115e				ld (free_list+3), a	 ; flag resume from last malloc  
115e				ld (free_list), hl    ; save out last location 
115e			 
115e			 
115e				;inc a     ; space for length byte 
115e				ld (hl), a     ; save block in use marker 
115e			 
115e				inc hl   ; move to space marker 
115e				ld (hl), a    ; save new space 
115e			 
115e				inc hl   ; move to start of allocated area 
115e				 
115e			;	push hl     ; save where we are - 1  
115e			 
115e			;	inc hl  ; move past zero index  
115e				; skip space to set down new marker 
115e			 
115e				; provide some extra space for now 
115e			 
115e				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
115e				inc a 
115e				inc a 
115e			 
115e				push hl   ; save where we are in the node block 
115e			 
115e				call addatohl 
115e			 
115e				; write linked list point 
115e			 
115e				pop de     ; get our node position 
115e				ex de, hl 
115e			 
115e				ld (hl), e 
115e				inc hl 
115e				ld (hl), d 
115e			 
115e				inc hl 
115e			 
115e				; now at start of allocated data so save pointer 
115e			 
115e				push hl 
115e			 
115e				; jump to position of next node and setup empty header in DE 
115e			 
115e				ex de, hl 
115e			 
115e			;	inc hl ; move past end of block 
115e			 
115e			;	ld a, 0 
115e				ld (hl), 0   ; empty marker 
115e				inc hl 
115e				ld (hl), 0   ; size 
115e				inc hl  
115e				ld (hl), 0   ; ptr 
115e				inc hl 
115e				ld (hl), 0   ; ptr 
115e			 
115e			 
115e				pop hl 
115e			 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "mmr" 
115e						CALLMONITOR 
115e					endif 
115e			 
115e			.exit: 
115e				pop af 
115e				pop bc 
115e				pop de  
115e				ret 
115e			 
115e			 
115e			 
115e			 
115e			free:  
115e				push hl 
115e				push af 
115e				; get address in hl 
115e			 
115e					if DEBUG_FORTH_MALLOC_INT 
115e						DMARK "fre" 
115e						CALLMONITOR 
115e					endif 
115e				; data is at hl - move to block count 
115e				dec hl 
115e				dec hl    ; get past pointer 
115e				dec hl 
115e			 
115e				ld a, (hl)    ; need this for a validation check 
115e			 
115e				dec hl    ; move to block marker 
115e			 
115e				; now check that the block count and block marker are the same  
115e			        ; this checks that we are on a malloc node and not random memory 
115e			        ; OK a faint chance this could be a problem but rare - famous last words! 
115e			 
115e				ld c, a 
115e				ld a, (hl)    
115e			 
115e				cp c 
115e				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
115e			 
115e				; yes good chance we are on a malloc node 
115e			 
115e			;	ld a, 0      
115e				ld (hl), 0   ; mark as free 
115e			 
115e				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
115e			 
115e			.freeignore:  
115e			 
115e				pop af 
115e				pop hl 
115e			 
115e				ret 
115e			 
115e			 
115e			 
115e			endif 
115e			 
