105c			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
105c			 
105c			toUpper: 
105c			;A is the char. 
105c			;If A is a lowercase letter, this sets it to the matching uppercase 
105c			;18cc or 30cc or 41cc 
105c			;avg: 26.75cc 
105c fe 61		  cp 'a' 
105e d8			  ret c 
105f fe 7b		  cp 'z'+1 
1061 d0			  ret nc 
1062 d6 20		  sub 'a'-'A' 
1064 c9			  ret 
