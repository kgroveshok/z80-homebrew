5ad9			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
5ad9			; | | e.g. 
5ad9			; | | $01 OPEN $01 DO READ . LOOP 
5ad9			; | | 
5ad9			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
5ad9			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
5ad9			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
5ad9			; | | two bytes contain the file id and extent. 
5ad9			; | |  
5ad9			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
5ad9			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
5ad9			; | | > [!NOTE] 
5ad9			; | | > Compatible with PicoSPINet  
5ad9			 
5ad9					if DEBUG_FORTH_WORDS_KEY 
5ad9						DMARK "REA" 
5ad9 f5				push af  
5ada 3a ee 5a			ld a, (.dmark)  
5add 32 99 fd			ld (debug_mark),a  
5ae0 3a ef 5a			ld a, (.dmark+1)  
5ae3 32 9a fd			ld (debug_mark+1),a  
5ae6 3a f0 5a			ld a, (.dmark+2)  
5ae9 32 9b fd			ld (debug_mark+2),a  
5aec 18 03			jr .pastdmark  
5aee ..			.dmark: db "REA"  
5af1 f1			.pastdmark: pop af  
5af2			endm  
