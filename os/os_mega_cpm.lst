1bd3			user_word_eol:  
1bd3				; hl contains the pointer to where to create a linked list item from the end 
1bd3				; of the user dict to continue on at the system word dict 
1bd3				 
1bd3				; poke the stub of the word list linked list to repoint to rom words 
1bd3			 
1bd3				; stub format 
1bd3				; db   word id 
1bd3				; dw    link to next word 
1bd3			        ; db char length of token 
1bd3				; db string + 0 term 
1bd3				; db exec code....  
