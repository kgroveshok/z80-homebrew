bff2					call spi_send_byte 
bff2			;		call spi_ce_high 
bff2			 
bff2					NEXTW 
bff2			 
bff2			.SPII: 
bff2				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bff2			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bff2					if DEBUG_FORTH_WORDS_KEY 
bff2						DMARK "SPi" 
bff2						CALLMONITOR 
bff2					endif 
bff2			 
bff2					; TODO Get SPI byte 
bff2			 
