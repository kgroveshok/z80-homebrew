9257			.cfdir:	ld e,(hl) 
9257				inc hl 
9257				ld d,(hl) 
9257				inc hl 
9257			 
9257				ex de, hl 
9257				call ishlzero 
9257				ret z     ; return on null pointer 
9257				call free 
9257				ex de, hl 
9257				jr .cfdir 
9257			 
9257			 
9257				ret 
9257			 
9257			 
9257			config_dir: 
9257			 
9257				; for the config menus that need to build a directory of storage call this routine 
9257				; it will construct a menu in scratch to pass to menu 
9257			 
9257				; open storage device 
9257			 
9257				; execute DIR to build a list of files and their ids into scratch in menu format 
9257				; once the menu has finished then will need to call config_fdir to release the strings 
9257				 
9257				; c = number items 
9257			 
9257				 
9257				call storage_get_block_0 
9257			 
9257				ld hl, store_page     ; get current id count 
9257				ld b, (hl) 
9257				ld c, 0    ; count of files   
9257			 
9257			 
9257				ld hl, scratch 
9257				ld (store_tmp2), hl    ; location to poke strings 
9257			 
9257				; check for empty drive 
9257			 
9257				ld a, 0 
9257				cp b 
9257				jp z, .dirdone 
9257			 
9257				 
9257					if DEBUG_FORTH_WORDS 
9257						DMARK "Cdc" 
9257						CALLMONITOR 
9257					endif 
9257			 
9257			 
9257			.diritem:	 
9257				push bc 
9257				; for each of the current ids do a search for them and if found push to stack 
9257			 
9257					ld hl, STORE_BLOCK_PHY 
9257					ld d, 0		 ; look for extent 0 of block id as this contains file name 
9257					ld e,b 
9257			 
9257					call storage_findnextid 
9257			 
9257			 
9257					; if found hl will be non zero 
9257			 
9257					call ishlzero 
9257					jr z, .dirnotfound 
9257			 
9257					; increase count 
9257			 
9257					pop bc	 
9257					inc c 
9257					push bc 
9257					 
9257			 
9257					; get file header and push the file name 
9257			 
9257					ld de, store_page 
9257					call storage_read_block 
9257			 
9257					; push file id to stack 
9257				 
9257					ld a, (store_page) 
9257					ld h, 0 
9257					ld l, a 
9257			 
9257					;call forth_push_numhl 
9257					; TODO store id 
9257			 
9257					push hl 
9257			 
9257					; push extent count to stack  
9257				 
9257					ld hl, store_page+3 
9257			 
9257					; get file name length 
9257			 
9257					call strlenz   
9257			 
9257					inc hl   ; cover zero term 
9257					inc hl  ; stick the id at the end of the area 
9257			 
9257					push hl 
9257					pop bc    ; move length to bc 
9257			 
9257					call malloc 
9257			 
9257					; TODO save malloc area to scratch 
9257			 
9257					ex de, hl 
9257					ld hl, (store_tmp2) 
9257					ld (hl), e 
9257					inc hl 
9257					ld (hl), d 
9257					inc hl 
9257					ld (store_tmp2), hl 
9257			 
9257					 
9257			 
9257					;pop hl   ; get source 
9257			;		ex de, hl    ; swap aronund	 
9257			 
9257					ld hl, store_page+3 
9257					if DEBUG_FORTH_WORDS 
9257						DMARK "CFd" 
9257						CALLMONITOR 
9257					endif 
9257					ldir 
9257			 
9257					; de is past string, move back one and store id 
9257					 
9257					dec de 
9257			 
9257					; store file id 
9257			 
9257					pop hl 
9257					ex de,hl 
9257					ld (hl), e 
9257			 
9257					if DEBUG_FORTH_WORDS 
9257						DMARK "Cdi" 
9257						CALLMONITOR 
9257					endif 
9257					 
9257			.dirnotfound: 
9257					pop bc     
9257					djnz .diritem 
9257				 
9257			.dirdone:	 
9257			 
9257			;		ld a, 0 
9257					ld hl, (store_tmp2) 
9257					ld (hl), 0 
9257					inc hl 
9257					ld (hl), 0 
9257					inc hl 
9257					; push a count of the dir items found 
9257			 
9257			;		ld h, 0 
9257			;		ld l, c 
9257			 
9257				ret 
9257			 
9257			endif 
