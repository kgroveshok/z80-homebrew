1cfc			include "firmware_595shiftreg.asm"  
1cfc			; common code for handling a 595 shift reg out on whatever output port 
1cfc			 
1cfc			; port in c 
1cfc			; byte in a 
1cfc			 
1cfc			 
1cfc			shift_bit_data: equ 0 
1cfc			shift_bit_clk: equ 1 
1cfc			shift_bit_latch: equ 2 
1cfc			 
1cfc			 
1cfc			; shift out a byte to the sound chip 
1cfc			 
1cfc			; A contains byte to send 
1cfc			 
1cfc			shift_byte: 
1cfc			 
1cfc 06 08			ld b, 8   ; 8 bits to shift 
1cfe			 
1cfe 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
1d00			 
1d00				; set data bit state 
1d00			 
1d00 cb 7f			bit 7, a 
1d02				; high bit is set 
1d02 28 02			jr z, .nb2 
1d04 cb c2			set shift_bit_data, d 
1d06			 
1d06				; set latches state  
1d06 cb ca		.nb2:	set shift_bit_clk, d 
1d08 cb 92			res shift_bit_latch, d    ; latch is inverted 
1d0a ed 51			out (c), d 
1d0c				 
1d0c				; clock the bit out 
1d0c cb 8a			res shift_bit_clk, d 
1d0e ed 51			out (c), d 
1d10			 
1d10				; shift a left one bit and repeat 
1d10 17				rla 
1d11			 
1d11 10 eb			djnz .nb1 
1d13			 
1d13				; latch 
1d13 cb d2			set shift_bit_latch, d 
1d15 ed 51			out (c), d 
1d17					 
1d17			 
1d17				; set  
1d17 c9				ret 
# End of file firmware_595shiftreg.asm
