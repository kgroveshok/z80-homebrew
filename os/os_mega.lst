2dc2 3a cc 2d			ld a, (.dmark+2)  
2dc5 32 9b fd			ld (debug_mark+2),a  
2dc8 18 03			jr .pastdmark  
2dca ..			.dmark: db "MON"  
2dcd f1			.pastdmark: pop af  
2dce			endm  
# End of macro DMARK
2dce					CALLMONITOR 
