# End of macro CWHEAD
a4cf			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a4cf			; | | At start the current various registers will be displayed with contents. 
a4cf			; | | Top right corner will show the most recent debug marker seen. 
a4cf			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a4cf			; | | and the return stack pointer (RSP). 
a4cf			; | | Pressing: 
a4cf			; | |  
a4cf			; | |    1 - Initial screen 
a4cf			; | |  
a4cf			; | |    2 - Display a data dump of HL 
a4cf			; | |  
a4cf			; | |    3 - Display a data dump of DE 
a4cf			; | |  
a4cf			; | |    4 - Display a data dump of BC 
a4cf			; | |  
a4cf			; | |    5 - Display a data dump of HL 
a4cf			; | |  
a4cf			; | |    6 - Display a data dump of DSP 
a4cf			; | |  
a4cf			; | |    7 - Display a data dump of RSP 
a4cf			; | |  
a4cf			; | |    8 - Display a data dump of what is at DSP 
a4cf			; | |  
a4cf			; | |    9 - Display a data dump of what is at RSP 
a4cf			; | |  
a4cf			; | |    0 - Exit monitor and continue running. This will also enable break points 
a4cf			; | |  
a4cf			; | |    * - Disable break points 
a4cf			; | |  
a4cf			; | |    # - Enter traditional monitor mode 
a4cf			; | |  
a4cf			; | | 
a4cf			; | | Monitor Mode 
a4cf			; | | ------------ 
a4cf			; | | A prompt of '>' will be shown for various commands: 
a4cf			; | |  
a4cf			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a4cf			; | |  
a4cf			; | |    C - Continue display a data dump from the last set address 
a4cf			; | |  
a4cf			; | |    M xxxx - Set start of memory edit at address xx 
a4cf			; | |  
a4cf			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a4cf			; | |  
a4cf			; | |    G xxxx - Exec code at specific address 
a4cf			; | |  
a4cf			; | |    Q - Return to previous 
a4cf				if DEBUG_FORTH_WORDS_KEY 
a4cf					DMARK "MON" 
a4cf				if DEMARK_VERSION = 1  
a4cf e5					push hl  
a4d0 21 d8 a4				ld hl, .dmark  
a4d3 22 60 ee				ld (debug_mark), hl  
a4d6				endif  
a4d6				if DEMARK_VERSION = 0  
a4d6					push af  
a4d6					ld a, (.dmark)  
a4d6					ld (debug_mark),a  
a4d6					ld a, (.dmark+1)  
a4d6					ld (debug_mark+1),a  
a4d6					ld a, (.dmark+2)  
a4d6					ld (debug_mark+2),a  
a4d6				endif  
a4d6 18 04			jr .pastdmark  
a4d8 ..			.dmark: db "MON"  
a4db				if DEMARK_VERSION = 1  
a4db 00					db 0  
a4dc				endif  
a4dc				if DEMARK_VERSION = 1  
a4dc e1			.pastdmark: pop hl  
a4dd				endif  
a4dd				if DEMARK_VERSION = 0  
a4dd			.pastdmark: pop af  
a4dd				endif  
a4dd			endm  
# End of macro DMARK
a4dd					CALLMONITOR 
a4dd				if BASE_CPM=1  
a4dd					call debug_vector  
a4dd				endif  
a4dd				if BASE_KEV=1  
a4dd					rst 8  
a4dd				endif  
a4dd				endm  
# End of macro CALLMONITOR
a4dd				endif 
