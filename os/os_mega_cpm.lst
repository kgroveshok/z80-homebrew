1088 71			      ld    (HL), C                 ; Point prev free block to freed block 
1089 23			      inc   HL 
108a 70			      ld    (HL), B 
108b			 
108b 60			      ld    H, B                    ; Point freed block at next free block 
108c 69			      ld    L, C 
108d 73			      ld    (HL), E 
108e 23			      inc   HL 
108f 72			      ld    (HL), D 
1090			 
1090			      ; Check if the freed block is adjacent to the next free block 
1090 23			      inc   HL                      ; Load size of freed block into HL 
1091 5e			      ld    E, (HL) 
1092 23			      inc   HL 
1093 56			      ld    D, (HL) 
1094 eb			      ex    DE, HL 
1095			 
1095 09			      add   HL, BC                  ; Add addr of freed block and its size 
1096			 
1096 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
1099 dd 56 01		      ld    D, (IX+1) 
109c			 
109c b7			      or    A                       ; Clear the carry flag 
109d ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
109f 20 22		      jr    NZ, free_check_adjacent_to_prev 
10a1			 
10a1			      ; Freed block is adjacent to next, merge into one bigger block 
10a1 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
10a2 5e			      ld    E, (HL) 
10a3 23			      inc   HL 
10a4 56			      ld    D, (HL) 
10a5 e5			      push  HL                      ; Save ptr to next block for later 
10a6			 
10a6 60			      ld    H, B                    ; Store ptr from next block into freed block 
10a7 69			      ld    L, C 
10a8 73			      ld    (HL), E 
10a9 23			      inc   HL 
10aa 72			      ld    (HL), D 
10ab			 
10ab e1			      pop   HL                      ; Restore ptr to next block 
10ac 23			      inc   HL                      ; Load size of next block into DE 
10ad 5e			      ld    E, (HL) 
10ae 23			      inc   HL 
10af 56			      ld    D, (HL) 
10b0 d5			      push  DE                      ; Save next block size for later 
10b1			 
10b1 60			      ld    H, B                    ; Load size of freed block into HL 
10b2 69			      ld    L, C 
10b3 23			      inc   HL 
10b4 23			      inc   HL 
10b5 5e			      ld    E, (HL) 
10b6 23			      inc   HL 
10b7 56			      ld    D, (HL) 
10b8 eb			      ex    DE, HL 
10b9			 
10b9 d1			      pop   DE                      ; Restore size of next block 
10ba 19			      add   HL, DE                  ; Add sizes of both blocks 
10bb eb			      ex    DE, HL 
10bc			 
10bc 60			      ld    H, B                    ; Store new bigger size into freed block 
10bd 69			      ld    L, C 
10be 23			      inc   HL 
10bf 23			      inc   HL 
10c0 73			      ld    (HL), E 
10c1 23			      inc   HL 
10c2 72			      ld    (HL), D 
