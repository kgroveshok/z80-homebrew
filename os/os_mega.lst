00d3 cd 74 0a			call delay1s  
00d6 3e 2b			ld a,'+'  
00d8 cd 3a 0b			call fill_display  
00db cd 6d 0b			call update_display  
00de cd 74 0a			call delay1s  
00e1 3e 2a			ld a,'*'  
00e3 cd 3a 0b			call fill_display  
00e6 cd 6d 0b			call update_display  
00e9 cd 74 0a			call delay1s  
