0fa1			 
0fa1			 
0fa1			;      .org  0x100 
0fa1			;main: 
0fa1			;      ld    HL, 0x8100 
0fa1			;      ld    SP, HL 
0fa1			; 
0fa1			;      call  heap_init 
0fa1			; 
0fa1			;      ; Make some allocations 
0fa1			;      ld    HL, 12 
0fa1			;      call  malloc            ; Allocates 0x9004 
0fa1			; 
0fa1			;      ld    HL, 12 
0fa1			;      call  malloc            ; Allocates 0x9014 
0fa1			; 
0fa1			;      ld    HL, 12 
0fa1			;      call  malloc            ; Allocates 0x9024 
0fa1			; 
0fa1			;      ; Free some allocations 
0fa1			;      ld    HL, 0x9014 
0fa1			;      call  free 
0fa1			; 
0fa1			;      ld    HL, 0x9004 
0fa1			;      call  free 
0fa1			; 
0fa1			;      ld    HL, 0x9024 
0fa1			;      call  free 
0fa1			; 
0fa1			; 
0fa1			;      halt 
0fa1			 
0fa1			 
0fa1			;------------------------------------------------------------------------------ 
0fa1			;     heap_init                                                               : 
0fa1			;                                                                             : 
0fa1			; Description                                                                 : 
0fa1			;     Initialise the heap and make it ready for malloc and free operations.   : 
0fa1			;                                                                             : 
0fa1			;     The heap is maintained as a linked list, starting with an initial       : 
0fa1			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
0fa1			;     the first free block in the heap. Each block then points to the next    : 
0fa1			;     free block within the heap, and the free list ends at the first block   : 
0fa1			;     with a null pointer to the next free block.                             : 
0fa1			;                                                                             : 
0fa1			; Parameters                                                                  : 
0fa1			;     Inputs are compile-time only. Two defines which specify the starting    : 
0fa1			;     address of the heap and its size are required, along with a memory      : 
0fa1			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
0fa1			;     principally stores a pointer to the first free block in the heap.       : 
0fa1			;                                                                             : 
0fa1			; Returns                                                                     : 
0fa1			;     Nothing                                                                 : 
0fa1			;------------------------------------------------------------------------------ 
0fa1			heap_init: 
0fa1 e5			      push  HL 
0fa2			 
0fa2			      ; Initialise free list struct 
0fa2 21 28 5b		      ld    HL, heap_start 
0fa5 22 23 5b		      ld    (free_list), HL 
0fa8 21 00 00		      ld    HL, 0 
0fab 22 25 5b		      ld    (free_list+2), HL 
0fae			 
0fae			      ; Insert first free block at bottom of heap, consumes entire heap 
0fae 21 74 e2		      ld    HL, heap_start+heap_size-4 
0fb1 22 28 5b		      ld    (heap_start), HL        ; Next block (end of free list) 
0fb4 21 4c 87		      ld    HL, heap_size-4 
0fb7 22 2a 5b		      ld    (heap_start+2), HL      ; Block size 
0fba			 
0fba			      ; Insert end of free list block at top of heap - two null words will 
0fba			      ; terminate the free list 
0fba 21 00 00		      ld    HL, 0 
0fbd 22 76 e2		      ld    (heap_start+heap_size-2), HL 
0fc0 22 74 e2		      ld    (heap_start+heap_size-4), HL 
0fc3			 
0fc3 e1			      pop   HL 
0fc4			 
0fc4 c9			      ret 
0fc5			 
0fc5			 
0fc5			;------------------------------------------------------------------------------ 
0fc5			;     malloc                                                                  : 
0fc5			;                                                                             : 
0fc5			; Description                                                                 : 
0fc5			;     Allocates the wanted space from the heap and returns the address of the : 
0fc5			;     first useable byte of the allocation.                                   : 
0fc5			;                                                                             : 
0fc5			;     Allocations can happen in one of two ways:                              : 
0fc5			;                                                                             : 
0fc5			;     1. A free block may be found which is the exact size wanted. In this    : 
0fc5			;        case the block is removed from the free list and retuedn to the      : 
0fc5			;        caller.                                                              : 
0fc5			;     2. A free block may be found which is larger than the size wanted. In   : 
0fc5			;        this case, the larger block is split into two. The first portion of  : 
0fc5			;        this block will become the requested space by the malloc call and    : 
0fc5			;        is returned to the caller. The second portion becomes a new free     : 
0fc5			;        block, and the free list is adjusted to maintain continuity via this : 
0fc5			;        newly created block.                                                 : 
0fc5			;                                                                             : 
0fc5			;     malloc does not set any initial value in the allocated space, the       : 
0fc5			;     caller is required to do this as required.                              : 
0fc5			;                                                                             : 
0fc5			;     This implementation of malloc uses the stack exclusively, and is        : 
0fc5			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
0fc5			;     advisable to disable interrupts before calling malloc, and recommended  : 
0fc5			;     to avoid the use of malloc inside ISRs in general.                      : 
0fc5			;                                                                             : 
0fc5			;     NOTE: heap_init must be called before malloc and free can be used.      : 
0fc5			;                                                                             : 
0fc5			; Parameters                                                                  : 
0fc5			;     HL  Number of bytes wanted                                              : 
0fc5			;                                                                             : 
0fc5			; Returns                                                                     : 
0fc5			;     HL  Address of the first useable byte of the allocation                 : 
0fc5			;                                                                             : 
0fc5			; Flags                                                                       : 
0fc5			;     Z   Set if the allocation did not succeed, clear otherwise              : 
0fc5			;                                                                             : 
0fc5			; Stack frame                                                                 : 
0fc5			;       |             |                                                       : 
0fc5			;       +-------------+                                                       : 
0fc5			;       |     BC      |                                                       : 
0fc5			;       +-------------+                                                       : 
0fc5			;       |     DE      |                                                       : 
0fc5			;       +-------------+                                                       : 
0fc5			;       |     IX      |                                                       : 
0fc5			;       +-------------+                                                       : 
0fc5			;       |  prev_free  |                                                       : 
0fc5			;   +4  +-------------+                                                       : 
0fc5			;       |  this_free  |                                                       : 
0fc5			;   +2  +-------------+                                                       : 
0fc5			;       |  next_free  |                                                       : 
0fc5			;   +0  +-------------+                                                       : 
0fc5			;       |             |                                                       : 
0fc5			;                                                                             : 
0fc5			;------------------------------------------------------------------------------ 
0fc5			 
0fc5			 
0fc5			;malloc: 
0fc5			; 
0fc5			;	SAVESP ON 1 
0fc5			; 
0fc5			;	call malloc_code 
0fc5			; 
0fc5			;	CHECKSP ON 1 
0fc5			;	ret 
0fc5			 
0fc5			 
0fc5			malloc: 
0fc5 c5			      push  BC 
0fc6 d5			      push  DE 
0fc7 dd e5		      push  IX 
0fc9			if DEBUG_FORTH_MALLOC_HIGH 
0fc9			call malloc_guard_entry 
0fc9			endif 
0fc9			 
0fc9					if DEBUG_FORTH_MALLOC 
0fc9						DMARK "mal" 
0fc9						CALLMONITOR 
0fc9					endif 
0fc9 7c			      ld    A, H                    ; Exit if no space requested 
0fca b5			      or    L 
0fcb ca 8a 10		      jp    Z, malloc_early_exit 
0fce			 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			; 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			;inc hl 
0fce			 
0fce			 
0fce			 
0fce			 
0fce					if DEBUG_FORTH_MALLOC 
0fce						DMARK "maA" 
0fce						CALLMONITOR 
0fce					endif 
0fce			      ; Set up stack frame 
0fce eb			      ex    DE, HL 
0fcf 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
0fd2 39			      add   HL, SP 
0fd3 f9			      ld    SP, HL 
0fd4 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
0fd8 dd 39		      add   IX, SP 
0fda			 
0fda			      ; Setup initial state 
0fda 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
0fdd 19			      add   HL, DE 
0fde			 
0fde 44			      ld    B, H                    ; Move want to BC 
0fdf 4d			      ld    C, L 
0fe0			 
0fe0 21 23 5b		      ld    HL, free_list           ; Store prev_free ptr to stack 
0fe3 dd 75 04		      ld    (IX+4), L 
0fe6 dd 74 05		      ld    (IX+5), H 
0fe9			 
0fe9 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
0fea 23			      inc   HL 
0feb 56			      ld    D, (HL) 
0fec dd 73 02		      ld    (IX+2), E 
0fef dd 72 03		      ld    (IX+3), D 
0ff2 eb			      ex    DE, HL                  ; this_free ptr into HL 
0ff3			 
0ff3					if DEBUG_FORTH_MALLOC 
0ff3						DMARK "maB" 
0ff3						CALLMONITOR 
0ff3					endif 
0ff3			      ; Loop through free block list to find some space 
0ff3			malloc_find_space: 
0ff3 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
0ff4 23			      inc   HL 
0ff5 56			      ld    D, (HL) 
0ff6			 
0ff6 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
0ff7 b3			      or    E 
0ff8 ca 84 10		      jp    Z, malloc_no_space 
0ffb			 
0ffb dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
0ffe dd 72 01		      ld    (IX+1), D 
1001			 
1001			      ; Does this block have enough space to make the allocation? 
1001 23			      inc   HL                      ; Load free block size into DE 
1002 5e			      ld    E, (HL) 
1003 23			      inc   HL 
1004 56			      ld    D, (HL) 
1005			 
1005 eb			      ex    DE, HL                  ; Check size of block against want 
1006 b7			      or    A                       ; Ensure carry flag clear 
1007 ed 42		      sbc   HL, BC 
1009 e5			      push  HL                      ; Store the result for later (new block size) 
100a			 
100a ca 59 10		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
100d 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
100f			 
100f			      ; this_free block is not big enough, setup ptrs to test next free block 
100f e1			      pop   HL                      ; Discard previous result 
1010			 
1010 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1013 dd 66 03		      ld    H, (IX+3) 
1016 dd 75 04		      ld    (IX+4), L 
1019 dd 74 05		      ld    (IX+5), H 
101c			 
101c dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
101f dd 66 01		      ld    H, (IX+1) 
1022 dd 75 02		      ld    (IX+2), L 
1025 dd 74 03		      ld    (IX+3), H 
1028			 
1028					if DEBUG_FORTH_MALLOC 
1028						DMARK "MA>" 
1028						CALLMONITOR 
1028					endif 
1028 18 c9		      jr    malloc_find_space 
102a			 
102a			      ; split a bigger block into two - requested size and remaining size 
102a			malloc_alloc_split: 
102a					if DEBUG_FORTH_MALLOC 
102a						DMARK "MAs" 
102a						CALLMONITOR 
102a					endif 
102a eb			      ex    DE, HL                  ; Calculate address of new free block 
102b 2b			      dec   HL 
102c 2b			      dec   HL 
102d 2b			      dec   HL 
102e 09			      add   HL, BC 
102f			 
102f			      ; Create a new block and point it at next_free 
102f dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
1032 dd 56 01		      ld    D, (IX+1) 
1035			 
1035 73			      ld    (HL), E                 ; Store next_free ptr into new block 
1036 23			      inc   HL 
1037 72			      ld    (HL), D 
1038			 
1038 d1			      pop   DE                      ; Store size of new block into new block 
1039 23			      inc   HL 
103a 73			      ld    (HL), E 
103b 23			      inc   HL 
103c 72			      ld    (HL), D 
103d			 
103d			      ; Update this_free ptr to point to new block 
103d 2b			      dec   HL 
103e 2b			      dec   HL 
103f 2b			      dec   HL 
1040			 
1040 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
1043 dd 56 03		      ld    D, (IX+3) 
1046			 
1046 dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
1049 dd 74 03		      ld    (IX+3), H 
104c			 
104c			      ; Modify this_free block to be allocation 
104c eb			      ex    DE, HL 
104d af			      xor   A                       ; Null the next block ptr of allocated block 
104e 77			      ld    (HL), A 
104f 23			      inc   HL 
1050 77			      ld    (HL), A 
1051			 
1051 23			      inc   HL                      ; Store want size into allocated block 
1052 71			      ld    (HL), C 
1053 23			      inc   HL 
1054 70			      ld    (HL), B 
1055 23			      inc   HL 
1056 e5			      push  HL                      ; Address of allocation to return 
1057			 
1057 18 19		      jr    malloc_update_links 
1059			 
1059			malloc_alloc_fit: 
1059 e1			      pop   HL                      ; Dont need new block size, want is exact fit 
105a			 
105a					if DEBUG_FORTH_MALLOC 
105a						DMARK "MAf" 
105a						CALLMONITOR 
105a					endif 
105a			      ; Modify this_free block to be allocation 
105a eb			      ex    DE, HL 
105b 2b			      dec   HL 
105c 2b			      dec   HL 
105d 2b			      dec   HL 
105e			 
105e af			      xor   A                       ; Null the next block ptr of allocated block 
105f 77			      ld    (HL), A 
1060 23			      inc   HL 
1061 77			      ld    (HL), A 
1062			 
1062 23			      inc   HL                      ; Store address of allocation to return 
1063 23			      inc   HL 
1064 23			      inc   HL 
1065 e5			      push  HL 
1066			 
1066			      ; Copy next_free ptr to this_free, remove allocated block from free list 
1066 dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
1069 dd 66 01		      ld    H, (IX+1) 
106c			 
106c dd 75 02		      ld    (IX+2), L               ; HL to this_free 
106f dd 74 03		      ld    (IX+3), H 
1072			 
1072			 
1072			malloc_update_links: 
1072			      ; Update prev_free ptr to point to this_free 
1072 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
1075 dd 66 05		      ld    H, (IX+5) 
1078			 
1078 dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
107b dd 56 03		      ld    D, (IX+3) 
107e			 
107e 73			      ld    (HL), E                 ; this_free ptr into prev_free 
107f 23			      inc   HL 
1080 72			      ld    (HL), D 
1081			 
1081					if DEBUG_FORTH_MALLOC 
1081						DMARK "Mul" 
1081						CALLMONITOR 
1081					endif 
1081			      ; Clear the Z flag to indicate successful allocation 
1081 7a			      ld    A, D 
1082 b3			      or    E 
1083			 
1083 d1			      pop   DE                      ; Address of allocation 
1084					if DEBUG_FORTH_MALLOC 
1084						DMARK "MAu" 
1084						CALLMONITOR 
1084					endif 
1084			 
1084			malloc_no_space: 
1084 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
1087 39			      add   HL, SP 
1088 f9			      ld    SP, HL 
1089			 
1089 eb			      ex    DE, HL                  ; Alloc addr into HL for return 
108a					if DEBUG_FORTH_MALLOC 
108a						DMARK "MAN" 
108a						CALLMONITOR 
108a					endif 
108a			 
108a			malloc_early_exit: 
108a					if DEBUG_FORTH_MALLOC 
108a						DMARK "MAx" 
108a						CALLMONITOR 
108a					endif 
108a dd e1		      pop   IX 
108c d1			      pop   DE 
108d c1			      pop   BC 
108e			 
108e			if DEBUG_FORTH_MALLOC_HIGH 
108e			call malloc_guard_exit 
108e			call malloc_guard_zerolen 
108e			endif 
108e c9			      ret 
108f			 
108f			 
108f			;------------------------------------------------------------------------------ 
108f			;     free                                                                    : 
108f			;                                                                             : 
108f			; Description                                                                 : 
108f			;     Return the space pointed to by HL to the heap. HL must be an address as : 
108f			;     returned by malloc, otherwise the behaviour is undefined.               : 
108f			;                                                                             : 
108f			;     Where possible, directly adjacent free blocks will be merged together   : 
108f			;     into larger blocks to help ensure that the heap does not become         : 
108f			;     excessively fragmented.                                                 : 
108f			;                                                                             : 
108f			;     free does not clear or set any other value into the freed space, and    : 
108f			;     therefore its contents may be visible through subsequent malloc's. The  : 
108f			;     caller should clear the freed space as required.                        : 
108f			;                                                                             : 
108f			;     This implementation of free uses the stack exclusively, and is          : 
108f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
108f			;     advisable to disable interrupts before calling free, and recommended    : 
108f			;     to avoid the use of free inside ISRs in general.                        : 
108f			;                                                                             : 
108f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
108f			;                                                                             : 
108f			; Parameters                                                                  : 
108f			;     HL  Pointer to address of first byte of allocation to be freed          : 
108f			;                                                                             : 
108f			; Returns                                                                     : 
108f			;     Nothing                                                                 : 
108f			;                                                                             : 
108f			; Stack frame                                                                 : 
108f			;       |             |                                                       : 
108f			;       +-------------+                                                       : 
108f			;       |     BC      |                                                       : 
108f			;       +-------------+                                                       : 
108f			;       |     DE      |                                                       : 
108f			;       +-------------+                                                       : 
108f			;       |     IX      |                                                       : 
108f			;       +-------------+                                                       : 
108f			;       |  prev_free  |                                                       : 
108f			;   +2  +-------------+                                                       : 
108f			;       |  next_free  |                                                       : 
108f			;   +0  +-------------+                                                       : 
108f			;       |             |                                                       : 
108f			;                                                                             : 
108f			;------------------------------------------------------------------------------ 
108f			free: 
108f c5			      push  BC 
1090 d5			      push  DE 
1091 dd e5		      push  IX 
1093			 
1093 7c			      ld    A, H                    ; Exit if ptr is null 
1094 b5			      or    L 
1095 ca 59 11		      jp    Z, free_early_exit 
1098			 
1098			      ; Set up stack frame 
1098 eb			      ex    DE, HL 
1099 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
109c 39			      add   HL, SP 
109d f9			      ld    SP, HL 
109e dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
10a2 dd 39		      add   IX, SP 
10a4			 
10a4			      ; The address in HL points to the start of the useable allocated space, 
10a4			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
10a4			      ; address of the block itself. 
10a4 eb			      ex    DE, HL 
10a5 11 fc ff		      ld    DE, -4 
10a8 19			      add   HL, DE 
10a9			 
10a9			      ; An allocated block must have a null next block pointer in it 
10a9 7e			      ld    A, (HL) 
10aa 23			      inc   HL 
10ab b6			      or    (HL) 
10ac c2 54 11		      jp    NZ, free_done 
10af			 
10af 2b			      dec   HL 
10b0			 
10b0 44			      ld    B, H                    ; Copy HL to BC 
10b1 4d			      ld    C, L 
10b2			 
10b2			      ; Loop through the free list to find the first block with an address 
10b2			      ; higher than the block being freed 
10b2 21 23 5b		      ld    HL, free_list 
10b5			 
10b5			free_find_higher_block: 
10b5 5e			      ld    E, (HL)                 ; Load next ptr from free block 
10b6 23			      inc   HL 
10b7 56			      ld    D, (HL) 
10b8 2b			      dec   HL 
10b9			 
10b9 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
10bc dd 72 01		      ld    (IX+1), D 
10bf dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
10c2 dd 74 03		      ld    (IX+3), H 
10c5			 
10c5 78			      ld    A, B                    ; Check if DE is greater than BC 
10c6 ba			      cp    D                       ; Compare MSB first 
10c7 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
10c9 30 04		      jr    NC, free_find_higher_block_skip 
10cb 79			      ld    A, C 
10cc bb			      cp    E                       ; Then compare LSB 
10cd 38 08		      jr    C, free_found_higher_block 
10cf			 
10cf			free_find_higher_block_skip: 
10cf 7a			      ld    A, D                    ; Reached the end of the free list? 
10d0 b3			      or    E 
10d1 ca 54 11		      jp    Z, free_done 
10d4			 
10d4 eb			      ex    DE, HL 
10d5			 
10d5 18 de		      jr    free_find_higher_block 
10d7			 
10d7			free_found_higher_block: 
10d7			      ; Insert freed block between prev and next free blocks 
10d7 71			      ld    (HL), C                 ; Point prev free block to freed block 
10d8 23			      inc   HL 
10d9 70			      ld    (HL), B 
10da			 
10da 60			      ld    H, B                    ; Point freed block at next free block 
10db 69			      ld    L, C 
10dc 73			      ld    (HL), E 
10dd 23			      inc   HL 
10de 72			      ld    (HL), D 
10df			 
10df			      ; Check if the freed block is adjacent to the next free block 
10df 23			      inc   HL                      ; Load size of freed block into HL 
10e0 5e			      ld    E, (HL) 
10e1 23			      inc   HL 
10e2 56			      ld    D, (HL) 
10e3 eb			      ex    DE, HL 
10e4			 
10e4 09			      add   HL, BC                  ; Add addr of freed block and its size 
10e5			 
10e5 dd 5e 00		      ld    E, (IX+0)               ; Load addr of next free block into DE 
10e8 dd 56 01		      ld    D, (IX+1) 
10eb			 
10eb b7			      or    A                       ; Clear the carry flag 
10ec ed 52		      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
10ee 20 22		      jr    NZ, free_check_adjacent_to_prev 
10f0			 
10f0			      ; Freed block is adjacent to next, merge into one bigger block 
10f0 eb			      ex    DE, HL                  ; Load next ptr from next block into DE 
10f1 5e			      ld    E, (HL) 
10f2 23			      inc   HL 
10f3 56			      ld    D, (HL) 
10f4 e5			      push  HL                      ; Save ptr to next block for later 
10f5			 
10f5 60			      ld    H, B                    ; Store ptr from next block into freed block 
10f6 69			      ld    L, C 
10f7 73			      ld    (HL), E 
10f8 23			      inc   HL 
10f9 72			      ld    (HL), D 
10fa			 
10fa e1			      pop   HL                      ; Restore ptr to next block 
10fb 23			      inc   HL                      ; Load size of next block into DE 
10fc 5e			      ld    E, (HL) 
10fd 23			      inc   HL 
10fe 56			      ld    D, (HL) 
10ff d5			      push  DE                      ; Save next block size for later 
1100			 
1100 60			      ld    H, B                    ; Load size of freed block into HL 
1101 69			      ld    L, C 
1102 23			      inc   HL 
1103 23			      inc   HL 
1104 5e			      ld    E, (HL) 
1105 23			      inc   HL 
1106 56			      ld    D, (HL) 
1107 eb			      ex    DE, HL 
1108			 
1108 d1			      pop   DE                      ; Restore size of next block 
1109 19			      add   HL, DE                  ; Add sizes of both blocks 
110a eb			      ex    DE, HL 
110b			 
110b 60			      ld    H, B                    ; Store new bigger size into freed block 
110c 69			      ld    L, C 
110d 23			      inc   HL 
110e 23			      inc   HL 
110f 73			      ld    (HL), E 
1110 23			      inc   HL 
1111 72			      ld    (HL), D 
1112			 
1112			free_check_adjacent_to_prev: 
1112			      ; Check if the freed block is adjacent to the prev free block 
1112 dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1115 dd 66 03		      ld    H, (IX+3) 
1118			 
1118 23			      inc   HL                      ; Size of prev free block into DE 
1119 23			      inc   HL 
111a 5e			      ld    E, (HL) 
111b 23			      inc   HL 
111c 56			      ld    D, (HL) 
111d 2b			      dec   HL 
111e 2b			      dec   HL 
111f 2b			      dec   HL 
1120			 
1120 19			      add   HL, DE                  ; Add prev block addr and size 
1121			 
1121 b7			      or    A                       ; Clear the carry flag 
1122 ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
1124 20 2e		      jr    NZ, free_done 
1126			 
1126			      ; Freed block is adjacent to prev, merge into one bigger block 
1126 60			      ld    H, B                    ; Load next ptr from freed block into DE 
1127 69			      ld    L, C 
1128 5e			      ld    E, (HL) 
1129 23			      inc   HL 
112a 56			      ld    D, (HL) 
112b e5			      push  HL                      ; Save freed block ptr for later 
112c			 
112c dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
112f dd 66 03		      ld    H, (IX+3) 
1132 73			      ld    (HL), E 
1133 23			      inc   HL 
1134 72			      ld    (HL), D 
1135			 
1135 e1			      pop   HL                      ; Restore freed block ptr 
1136 23			      inc   HL                      ; Load size of freed block into DE 
1137 5e			      ld    E, (HL) 
1138 23			      inc   HL 
1139 56			      ld    D, (HL) 
113a d5			      push  DE                      ; Save freed block size for later 
113b			 
113b dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
113e dd 66 03		      ld    H, (IX+3) 
1141 23			      inc   HL 
1142 23			      inc   HL 
1143 5e			      ld    E, (HL) 
1144 23			      inc   HL 
1145 56			      ld    D, (HL) 
1146			 
1146 e1			      pop   HL                      ; Add sizes of both blocks 
1147 19			      add   HL, DE 
1148 eb			      ex    DE, HL 
1149			 
1149 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
114c dd 66 03		      ld    H, (IX+3) 
114f 23			      inc   HL 
1150 23			      inc   HL 
1151 73			      ld    (HL), E 
1152 23			      inc   HL 
1153 72			      ld    (HL), D 
1154			 
1154			free_done: 
1154 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
1157 39			      add   HL, SP 
1158 f9			      ld    SP, HL 
1159			 
1159			free_early_exit: 
1159 dd e1		      pop   IX 
115b d1			      pop   DE 
115c c1			      pop   BC 
115d			 
115d c9			      ret 
