6a5b			  
6a5b			; **********************************************************************  
6a5b			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
6a5b			; **********************************************************************  
6a5b			;  
6a5b			; **  Written as a Small Computer Monitor App   
6a5b			; **  Version 0.1 SCC 2018-05-16  
6a5b			; **  www.scc.me.uk  
6a5b			;  
6a5b			; **********************************************************************  
6a5b			;  
6a5b			; This module provides support for alphanumeric LCD modules using with  
6a5b			; *  HD44780 (or compatible) controller  
6a5b			; *  5 x 7 pixel fonts  
6a5b			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
6a5b			; *  Interface via six digital outputs to the display (see below)  
6a5b			;  
6a5b			; LCD module pinout:  
6a5b			;   1  Vss   0v supply  
6a5b			;   2  Vdd   5v supply  
6a5b			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
6a5b			;   4  RS    High = data, Low = instruction  
6a5b			;   5  R/W   High = Read, Low = Write  
6a5b			;   6  E     Enable signal (active high)  
6a5b			;   7  DB0   Data bit 0  
6a5b			;   8  DB1   Data bit 1  
6a5b			;   9  DB2   Data bit 2  
6a5b			;  10  DB3   Data bit 3  
6a5b			;  11  DB4   Data bit 4  
6a5b			;  12  DB5   Data bit 5  
6a5b			;  13  DB6   Data bit 6  
6a5b			;  14  DB7   Data bit 7  
6a5b			;  15  A     Backlight anode (+)  
6a5b			;  16  K     Backlight cathode (-)  
6a5b			;  
6a5b			; This interfacing method uses 4-bit data mode and uses time delays  
6a5b			; rather than polling the display's ready status. As a result the   
6a5b			; interface only requires 6 simple output lines:  
6a5b			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
6a5b			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
6a5b			;   LCD DB4 = Microcomputer output port bit 4  
6a5b			;   LCD DB5 = Microcomputer output port bit 5  
6a5b			;   LCD DB6 = Microcomputer output port bit 6  
6a5b			;   LCD DB7 = Microcomputer output port bit 7  
6a5b			; Display's R/W is connected to 0v so it is always in write mode  
6a5b			; All 6 connections must be on the same port address <kLCDPrt>  
6a5b			; This method also allows a decent length of cable from micro to LCD  
6a5b			;  
6a5b			; **********************************************************************  
6a5b			;  
6a5b			; To include the code for any given function provided by this module,   
6a5b			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
6a5b			; the parent source file.  
6a5b			; For example:  #REQUIRES   uHexPrefix  
6a5b			;  
6a5b			; Also #INCLUDE this file at some point after the #REQUIRES statements  
6a5b			; in the parent source file.  
6a5b			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
6a5b			;  
6a5b			; These are the function names provided by this module:  
6a5b			; fLCD_Init                     ;Initialise LCD  
6a5b			; fLCD_Inst                     ;Send instruction to LCD  
6a5b			; fLCD_Data                     ;Send data byte to LCD  
6a5b			; fLCD_Pos                      ;Position cursor  
6a5b			; fLCD_Str                      ;Display string  
6a5b			; fLCD_Def                      ;Define custom character  
6a5b			;  
6a5b			; **********************************************************************  
6a5b			;  
6a5b			; Requires SCMonAPI.asm to also be included in the project  
6a5b			;  
6a5b			  
6a5b			  
6a5b			; **********************************************************************  
6a5b			; **  Constants  
6a5b			; **********************************************************************  
6a5b			  
6a5b			; Constants that must be defined externally  
6a5b			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6a5b			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6a5b			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6a5b			;kLCDWidth: EQU 20             ;Width in characters  
6a5b			  
6a5b			; general line offsets in any frame buffer  
6a5b			  
6a5b			  
6a5b			display_row_1: equ 0  
6a5b			display_row_2: equ display_row_1+display_cols  
6a5b			display_row_3: equ display_row_2 + display_cols  
6a5b			display_row_4: equ display_row_3 + display_cols  
6a5b			;display_row_4_eol:   
6a5b			  
6a5b			  
6a5b			; Cursor position values for the start of each line  
6a5b			  
6a5b			; E  
6a5b			kLCD_Line1: EQU 0x00   
6a5b			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6a5b			; E1  
6a5b			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6a5b			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6a5b			  
6a5b			; Instructions to send as A register to fLCD_Inst  
6a5b			kLCD_Clear: EQU 00000001b     ;LCD clear  
6a5b			kLCD_Off:   EQU 00001000b     ;LCD off  
6a5b			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6a5b			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6a5b			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6a5b			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6a5b			  
6a5b			; Constants used by this code module  
6a5b			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6a5b			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6a5b			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6a5b			  
6a5b			  
6a5b			  
6a5b			; **********************************************************************  
6a5b			; **  LCD support functions  
6a5b			; **********************************************************************  
6a5b			  
6a5b			; Initialise alphanumeric LCD module  
6a5b			; LCD control register codes:  
6a5b			;   DL   0 = 4-bit mode        1 = 8-bit mode  
6a5b			;   N    0 = 1-line mode       1 = 2-line mode  
6a5b			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
6a5b			;   D    0 = Display off       1 = Display on  
6a5b			;   C    0 = Cursor off        1 = Cursor on  
6a5b			;   B    0 = Blinking off      1 = Blinking on  
6a5b			;   ID   0 = Decrement mode    1 = Increment mode  
6a5b			;   SH   0 = Entire shift off  1 = Entire shift on  
6a5b 3e 28		fLCD_Init:  LD   A, 40  
6a5d cd 9e 6b		            CALL LCDDelay       ;Delay 40ms after power up  
6a60			; For reliable reset set 8-bit mode - 3 times  
6a60 cd 6e 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a63 cd 6e 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a66 cd 6e 6b		            CALL WrFn8bit       ;Function = 8-bit mode  
6a69			; Set 4-bit mode  
6a69 cd 6a 6b		            CALL WrFn4bit       ;Function = 4-bit mode  
6a6c cd 9c 6b		            CALL LCDDelay1      ;Delay 37 us or more  
6a6f			; Function set  
6a6f 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6a71 cd 94 6a		            CALL fLCD_Inst      ;2 line, display on  
6a74			; Display On/Off control  
6a74 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6a76 cd 94 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
6a79			; Display Clear  
6a79 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
6a7b cd 94 6a		            CALL fLCD_Inst      ;Clear display  
6a7e			; Entry mode  
6a7e 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6a80 cd 94 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
6a83			; Display module now initialised  
6a83 c9			            RET  
6a84			; ok to here  
6a84			  
6a84			; decide on setting bit for LED on or off  
6a84			; Set correct bit in A  
6a84 e5			IsLED: push hl  
6a85 21 ad fd			ld hl, hardware_word+1  
6a88 cb 56			bit 2, (hl)    ; led bit  
6a8a 20 04			jr nz, .isled1  
6a8c cb 8f			res kLCDBitLED, a  
6a8e 18 02			jr .isleddone  
6a90 cb cf		.isled1: set kLCDBitLED, a  
6a92			.isleddone:  	  
6a92 e1				pop hl  
6a93			  
6a93 c9				ret  
6a94			  
6a94			  
6a94			; Write instruction to LCD  
6a94			;   On entry: A = Instruction byte to be written  
6a94			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a94 f5			fLCD_Inst:  PUSH AF  
6a95 f5			            PUSH AF  
6a96 cd a8 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a99 f1			            POP  AF  
6a9a 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a9b 17			            RLA  
6a9c 17			            RLA  
6a9d 17			            RLA  
6a9e cd a8 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6aa1 3e 02		            LD   A, 2  
6aa3 cd 9e 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6aa6 f1			            POP  AF  
6aa7 c9			            RET  
6aa8			Wr4bits:   
6aa8 f5					push af  
6aa9 3a fb fa				ld a, (display_lcde1e2)  
6aac fe 00				cp 0     ; e  
6aae 20 13				jr nz, .wea2	  
6ab0 f1					pop af  
6ab1 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6ab3 cd 84 6a				call IsLED  
6ab6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6ab8 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6aba cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6abc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6abe cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6ac0 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6ac2 c9			            RET  
6ac3 f1			.wea2:		pop af  
6ac4 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6ac6 cd 84 6a				call IsLED  
6ac9 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6acb cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6acd cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6acf d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6ad1 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6ad3 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6ad5 c9			            RET  
6ad6			  
6ad6			  
6ad6			; Write data to LCD  
6ad6			;   On entry: A = Data byte to be written  
6ad6			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ad6 f5			fLCD_Data:  PUSH AF  
6ad7 f5			            PUSH AF  
6ad8 cd ea 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6adb f1			            POP  AF  
6adc 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6add 17			            RLA  
6ade 17			            RLA  
6adf 17			            RLA  
6ae0 cd ea 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6ae3 3e 96		            LD   A, 150  
6ae5 3d			Wait:      DEC  A              ;Wait a while to allow data   
6ae6 20 fd		            JR   NZ, Wait      ;  write to complete  
6ae8 f1			            POP  AF  
6ae9 c9			            RET  
6aea			Wr4bitsa:     
6aea f5					push af  
6aeb 3a fb fa				ld a, (display_lcde1e2)  
6aee fe 00				cp 0     ; e1  
6af0 20 19				jr nz, .we2	  
6af2 f1					pop af  
6af3 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6af5 cd 84 6a				call IsLED  
6af8 cb d7		            SET  kLCDBitRS, A  
6afa d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6afc cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6afe cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6b00 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6b02 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6b04 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6b06 cb 97		            RES  kLCDBitRS, A  
6b08 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b0a c9			            RET  
6b0b f1			.we2:		pop af  
6b0c e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6b0e cd 84 6a				call IsLED  
6b11 cb d7		            SET  kLCDBitRS, A  
6b13 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6b15 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6b17 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6b19 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6b1b cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6b1d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6b1f cb 97		            RES  kLCDBitRS, A  
6b21 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b23 c9			            RET  
