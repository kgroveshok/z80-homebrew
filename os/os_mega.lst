20ea			FORTH_CHK_DSP_UNDER: macro 
20ea				push hl 
20ea				push de 
20ea				ld hl,(cli_data_sp) 
20ea				ld de, cli_data_stack 
20ea				call cmp16 
20ea				jp c, fault_dsp_under 
