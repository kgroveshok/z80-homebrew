9109			;------------------------------------------------------------------------------ 
9109			;     free                                                                    : 
9109			;                                                                             : 
9109			; Description                                                                 : 
9109			;     Return the space pointed to by HL to the heap. HL must be an address as : 
9109			;     returned by malloc, otherwise the behaviour is undefined.               : 
9109			;                                                                             : 
9109			;     Where possible, directly adjacent free blocks will be merged together   : 
9109			;     into larger blocks to help ensure that the heap does not become         : 
9109			;     excessively fragmented.                                                 : 
9109			;                                                                             : 
9109			;     free does not clear or set any other value into the freed space, and    : 
9109			;     therefore its contents may be visible through subsequent malloc's. The  : 
9109			;     caller should clear the freed space as required.                        : 
9109			;                                                                             : 
9109			;     This implementation of free uses the stack exclusively, and is          : 
9109			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
9109			;     advisable to disable interrupts before calling free, and recommended    : 
9109			;     to avoid the use of free inside ISRs in general.                        : 
9109			;                                                                             : 
9109			;     NOTE: heap_init must be called before malloc and free can be used.      : 
9109			;                                                                             : 
9109			; Parameters                                                                  : 
9109			;     HL  Pointer to address of first byte of allocation to be freed          : 
9109			;                                                                             : 
9109			; Returns                                                                     : 
9109			;     Nothing                                                                 : 
9109			;                                                                             : 
9109			; Stack frame                                                                 : 
9109			;       |             |                                                       : 
9109			;       +-------------+                                                       : 
9109			;       |     BC      |                                                       : 
9109			;       +-------------+                                                       : 
9109			;       |     DE      |                                                       : 
9109			;       +-------------+                                                       : 
9109			;       |     IX      |                                                       : 
9109			;       +-------------+                                                       : 
9109			;       |  prev_free  |                                                       : 
9109			;   +2  +-------------+                                                       : 
9109			;       |  next_free  |                                                       : 
9109			;   +0  +-------------+                                                       : 
9109			;       |             |                                                       : 
9109			;                                                                             : 
9109			;------------------------------------------------------------------------------ 
9109			free: 
9109 c5			      push  BC 
910a d5			      push  DE 
910b dd e5		      push  IX 
910d			 
910d 7c			      ld    A, H                    ; Exit if ptr is null 
910e b5			      or    L 
910f ca d3 91		      jp    Z, free_early_exit 
9112			 
9112			      ; Set up stack frame 
9112 eb			      ex    DE, HL 
9113 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
9116 39			      add   HL, SP 
9117 f9			      ld    SP, HL 
9118 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
911c dd 39		      add   IX, SP 
911e			 
911e			      ; The address in HL points to the start of the useable allocated space, 
911e			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
911e			      ; address of the block itself. 
911e eb			      ex    DE, HL 
911f 11 fc ff		      ld    DE, -4 
9122 19			      add   HL, DE 
9123			 
9123			      ; An allocated block must have a null next block pointer in it 
9123 7e			      ld    A, (HL) 
9124 23			      inc   HL 
9125 b6			      or    (HL) 
9126 c2 ce 91		      jp    NZ, free_done 
9129			 
9129 2b			      dec   HL 
912a			 
912a 44			      ld    B, H                    ; Copy HL to BC 
912b 4d			      ld    C, L 
912c			 
912c			      ; Loop through the free list to find the first block with an address 
912c			      ; higher than the block being freed 
912c 21 79 e2		      ld    HL, free_list 
912f			 
912f			free_find_higher_block: 
912f 5e			      ld    E, (HL)                 ; Load next ptr from free block 
9130 23			      inc   HL 
9131 56			      ld    D, (HL) 
9132 2b			      dec   HL 
9133			 
9133 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
9136 dd 72 01		      ld    (IX+1), D 
9139 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
913c dd 74 03		      ld    (IX+3), H 
913f			 
913f 78			      ld    A, B                    ; Check if DE is greater than BC 
9140 ba			      cp    D                       ; Compare MSB first 
9141 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
9143 30 04		      jr    NC, free_find_higher_block_skip 
9145 79			      ld    A, C 
9146 bb			      cp    E                       ; Then compare LSB 
9147 38 08		      jr    C, free_found_higher_block 
9149			 
9149			free_find_higher_block_skip: 
9149 7a			      ld    A, D                    ; Reached the end of the free list? 
914a b3			      or    E 
914b ca ce 91		      jp    Z, free_done 
914e			 
914e eb			      ex    DE, HL 
914f			 
914f 18 de		      jr    free_find_higher_block 
