471a					ld a, (.dmark+1)  
471a					ld (debug_mark+1),a  
471a					ld a, (.dmark+2)  
471a					ld (debug_mark+2),a  
471a				endif  
471a 18 03			jr .pastdmark  
471c ..			.dmark: db "REA"  
471f				if DEMARK_VERSION = 1  
471f e1			.pastdmark: pop hl  
4720				endif  
