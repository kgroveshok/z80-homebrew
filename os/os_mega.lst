0fac			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0fac			;;    subtract $30, if result > 9 then subtract $7 more 
0fac			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0fac			atohex: 
0fac d6 30				SUB $30 
0fae fe 0a				CP 10 
0fb0 f8					RET M		; If result negative it was 0-9 so we're done 
0fb1 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0fb3 c9					RET		 
