d4fd				call str_at_display 
d4fd			 
d4fd				call update_display 
d4fd			 
d4fd				call cin_wait 
d4fd				cp 'n' 
d4fd				ret z 
d4fd				cp 'N' 
d4fd				ret z 
d4fd			 
d4fd				call delay1s 
d4fd			 
d4fd				ld a, (store_page+2) 
d4fd				ld (store_openmaxext), a    ; save count of ext 
d4fd				ld a, 1  
d4fd				ld (store_openext), a    ; save count of ext 
d4fd			 
d4fd			.autof:  
