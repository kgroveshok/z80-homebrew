8f41			 
8f41 60			      ld    H, B                    ; Load size of freed block into HL 
8f42 69			      ld    L, C 
8f43 23			      inc   HL 
8f44 23			      inc   HL 
8f45 5e			      ld    E, (HL) 
8f46 23			      inc   HL 
8f47 56			      ld    D, (HL) 
