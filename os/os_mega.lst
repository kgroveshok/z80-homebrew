10e9			;------------------------------------------------------------------------------ 
10e9			;     heap_init                                                               : 
10e9			;                                                                             : 
10e9			; Description                                                                 : 
10e9			;     Initialise the heap and make it ready for malloc and free operations.   : 
10e9			;                                                                             : 
10e9			;     The heap is maintained as a linked list, starting with an initial       : 
10e9			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
10e9			;     the first free block in the heap. Each block then points to the next    : 
10e9			;     free block within the heap, and the free list ends at the first block   : 
10e9			;     with a null pointer to the next free block.                             : 
10e9			;                                                                             : 
10e9			; Parameters                                                                  : 
10e9			;     Inputs are compile-time only. Two defines which specify the starting    : 
10e9			;     address of the heap and its size are required, along with a memory      : 
10e9			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
10e9			;     principally stores a pointer to the first free block in the heap.       : 
10e9			;                                                                             : 
10e9			; Returns                                                                     : 
10e9			;     Nothing                                                                 : 
10e9			;------------------------------------------------------------------------------ 
10e9			heap_init: 
10e9 e5			      push  HL 
10ea			 
10ea			      ; Initialise free list struct 
10ea 21 0e 80		      ld    HL, heap_start 
10ed 22 0a 80		      ld    (free_list), HL 
10f0 21 00 00		      ld    HL, 0 
10f3 22 0c 80		      ld    (free_list+2), HL 
10f6			 
10f6			      ; Insert first free block at bottom of heap, consumes entire heap 
10f6 21 c8 f0		      ld    HL, heap_start+heap_size-4 
10f9 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
10fc 21 ba 70		      ld    HL, heap_size-4 
10ff 22 10 80		      ld    (heap_start+2), HL      ; Block size 
1102			 
1102			      ; Insert end of free list block at top of heap - two null words will 
1102			      ; terminate the free list 
1102 21 00 00		      ld    HL, 0 
1105 22 ca f0		      ld    (heap_start+heap_size-2), HL 
1108 22 c8 f0		      ld    (heap_start+heap_size-4), HL 
110b			 
110b e1			      pop   HL 
110c			 
110c c9			      ret 
110d			 
110d			 
110d			;------------------------------------------------------------------------------ 
110d			;     malloc                                                                  : 
110d			;                                                                             : 
110d			; Description                                                                 : 
110d			;     Allocates the wanted space from the heap and returns the address of the : 
110d			;     first useable byte of the allocation.                                   : 
110d			;                                                                             : 
110d			;     Allocations can happen in one of two ways:                              : 
110d			;                                                                             : 
110d			;     1. A free block may be found which is the exact size wanted. In this    : 
110d			;        case the block is removed from the free list and retuedn to the      : 
110d			;        caller.                                                              : 
110d			;     2. A free block may be found which is larger than the size wanted. In   : 
110d			;        this case, the larger block is split into two. The first portion of  : 
110d			;        this block will become the requested space by the malloc call and    : 
110d			;        is returned to the caller. The second portion becomes a new free     : 
110d			;        block, and the free list is adjusted to maintain continuity via this : 
110d			;        newly created block.                                                 : 
110d			;                                                                             : 
110d			;     malloc does not set any initial value in the allocated space, the       : 
110d			;     caller is required to do this as required.                              : 
110d			;                                                                             : 
110d			;     This implementation of malloc uses the stack exclusively, and is        : 
110d			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
110d			;     advisable to disable interrupts before calling malloc, and recommended  : 
110d			;     to avoid the use of malloc inside ISRs in general.                      : 
110d			;                                                                             : 
110d			;     NOTE: heap_init must be called before malloc and free can be used.      : 
110d			;                                                                             : 
110d			; Parameters                                                                  : 
110d			;     HL  Number of bytes wanted                                              : 
110d			;                                                                             : 
110d			; Returns                                                                     : 
110d			;     HL  Address of the first useable byte of the allocation                 : 
110d			;                                                                             : 
110d			; Flags                                                                       : 
110d			;     Z   Set if the allocation did not succeed, clear otherwise              : 
110d			;                                                                             : 
110d			; Stack frame                                                                 : 
110d			;       |             |                                                       : 
110d			;       +-------------+                                                       : 
110d			;       |     BC      |                                                       : 
110d			;       +-------------+                                                       : 
110d			;       |     DE      |                                                       : 
110d			;       +-------------+                                                       : 
110d			;       |     IX      |                                                       : 
110d			;       +-------------+                                                       : 
110d			;       |  prev_free  |                                                       : 
110d			;   +4  +-------------+                                                       : 
110d			;       |  this_free  |                                                       : 
110d			;   +2  +-------------+                                                       : 
110d			;       |  next_free  |                                                       : 
110d			;   +0  +-------------+                                                       : 
110d			;       |             |                                                       : 
110d			;                                                                             : 
110d			;------------------------------------------------------------------------------ 
110d			 
110d			 
110d			;malloc: 
110d			; 
110d			;	SAVESP ON 1 
110d			; 
110d			;	call malloc_code 
110d			; 
110d			;	CHECKSP ON 1 
110d			;	ret 
110d			 
110d			 
110d			malloc: 
110d c5			      push  BC 
110e d5			      push  DE 
110f dd e5		      push  IX 
1111			if DEBUG_FORTH_MALLOC_HIGH 
1111			call malloc_guard_entry 
1111			endif 
1111			 
1111					if DEBUG_FORTH_MALLOC 
1111						DMARK "mal" 
1111						CALLMONITOR 
1111					endif 
1111 7c			      ld    A, H                    ; Exit if no space requested 
1112 b5			      or    L 
1113 ca d2 11		      jp    Z, malloc_early_exit 
1116			 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			; 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			;inc hl 
1116			 
1116			 
1116			 
1116			 
1116					if DEBUG_FORTH_MALLOC 
1116						DMARK "maA" 
1116						CALLMONITOR 
1116					endif 
1116			      ; Set up stack frame 
1116 eb			      ex    DE, HL 
1117 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
111a 39			      add   HL, SP 
111b f9			      ld    SP, HL 
111c dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
1120 dd 39		      add   IX, SP 
1122			 
1122			      ; Setup initial state 
1122 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
1125 19			      add   HL, DE 
1126			 
1126 44			      ld    B, H                    ; Move want to BC 
1127 4d			      ld    C, L 
1128			 
1128 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
112b dd 75 04		      ld    (IX+4), L 
112e dd 74 05		      ld    (IX+5), H 
1131			 
1131 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
1132 23			      inc   HL 
1133 56			      ld    D, (HL) 
1134 dd 73 02		      ld    (IX+2), E 
1137 dd 72 03		      ld    (IX+3), D 
113a eb			      ex    DE, HL                  ; this_free ptr into HL 
113b			 
113b					if DEBUG_FORTH_MALLOC 
113b						DMARK "maB" 
113b						CALLMONITOR 
113b					endif 
113b			      ; Loop through free block list to find some space 
113b			malloc_find_space: 
113b 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
113c 23			      inc   HL 
113d 56			      ld    D, (HL) 
113e			 
113e 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
113f b3			      or    E 
1140 ca cc 11		      jp    Z, malloc_no_space 
1143			 
1143 dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1146 dd 72 01		      ld    (IX+1), D 
1149			 
1149			      ; Does this block have enough space to make the allocation? 
1149 23			      inc   HL                      ; Load free block size into DE 
114a 5e			      ld    E, (HL) 
114b 23			      inc   HL 
114c 56			      ld    D, (HL) 
114d			 
114d eb			      ex    DE, HL                  ; Check size of block against want 
114e b7			      or    A                       ; Ensure carry flag clear 
114f ed 42		      sbc   HL, BC 
1151 e5			      push  HL                      ; Store the result for later (new block size) 
1152			 
1152 ca a1 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1155 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1157			 
1157			      ; this_free block is not big enough, setup ptrs to test next free block 
1157 e1			      pop   HL                      ; Discard previous result 
1158			 
1158 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
115b dd 66 03		      ld    H, (IX+3) 
115e dd 75 04		      ld    (IX+4), L 
1161 dd 74 05		      ld    (IX+5), H 
1164			 
1164 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
1167 dd 66 01		      ld    H, (IX+1) 
116a dd 75 02		      ld    (IX+2), L 
116d dd 74 03		      ld    (IX+3), H 
1170			 
1170					if DEBUG_FORTH_MALLOC 
1170						DMARK "MA>" 
1170						CALLMONITOR 
1170					endif 
1170 18 c9		      jr    malloc_find_space 
1172			 
1172			      ; split a bigger block into two - requested size and remaining size 
1172			malloc_alloc_split: 
1172					if DEBUG_FORTH_MALLOC 
1172						DMARK "MAs" 
1172						CALLMONITOR 
1172					endif 
1172 eb			      ex    DE, HL                  ; Calculate address of new free block 
1173 2b			      dec   HL 
1174 2b			      dec   HL 
1175 2b			      dec   HL 
1176 09			      add   HL, BC 
1177			 
1177			      ; Create a new block and point it at next_free 
1177 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
117a dd 56 01		      ld    D, (IX+1) 
117d			 
117d 73			      ld    (HL), E                 ; Store next_free ptr into new block 
117e 23			      inc   HL 
117f 72			      ld    (HL), D 
1180			 
1180 d1			      pop   DE                      ; Store size of new block into new block 
1181 23			      inc   HL 
1182 73			      ld    (HL), E 
1183 23			      inc   HL 
1184 72			      ld    (HL), D 
1185			 
1185			      ; Update this_free ptr to point to new block 
1185 2b			      dec   HL 
1186 2b			      dec   HL 
1187 2b			      dec   HL 
1188			 
1188 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
118b dd 56 03		      ld    D, (IX+3) 
118e			 
118e dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
1191 dd 74 03		      ld    (IX+3), H 
1194			 
1194			      ; Modify this_free block to be allocation 
1194 eb			      ex    DE, HL 
1195 af			      xor   A                       ; Null the next block ptr of allocated block 
1196 77			      ld    (HL), A 
1197 23			      inc   HL 
1198 77			      ld    (HL), A 
1199			 
1199 23			      inc   HL                      ; Store want size into allocated block 
119a 71			      ld    (HL), C 
119b 23			      inc   HL 
119c 70			      ld    (HL), B 
119d 23			      inc   HL 
119e e5			      push  HL                      ; Address of allocation to return 
119f			 
119f 18 19		      jr    malloc_update_links 
11a1			 
11a1			malloc_alloc_fit: 
11a1 e1			      pop   HL                      ; Dont need new block size, want is exact fit 
11a2			 
11a2					if DEBUG_FORTH_MALLOC 
11a2						DMARK "MAf" 
11a2						CALLMONITOR 
11a2					endif 
11a2			      ; Modify this_free block to be allocation 
11a2 eb			      ex    DE, HL 
11a3 2b			      dec   HL 
11a4 2b			      dec   HL 
11a5 2b			      dec   HL 
11a6			 
11a6 af			      xor   A                       ; Null the next block ptr of allocated block 
11a7 77			      ld    (HL), A 
11a8 23			      inc   HL 
11a9 77			      ld    (HL), A 
11aa			 
11aa 23			      inc   HL                      ; Store address of allocation to return 
11ab 23			      inc   HL 
11ac 23			      inc   HL 
11ad e5			      push  HL 
11ae			 
11ae			      ; Copy next_free ptr to this_free, remove allocated block from free list 
11ae dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11b1 dd 66 01		      ld    H, (IX+1) 
11b4			 
11b4 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11b7 dd 74 03		      ld    (IX+3), H 
11ba			 
11ba			 
11ba			malloc_update_links: 
11ba			      ; Update prev_free ptr to point to this_free 
11ba dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
11bd dd 66 05		      ld    H, (IX+5) 
11c0			 
11c0 dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
11c3 dd 56 03		      ld    D, (IX+3) 
11c6			 
11c6 73			      ld    (HL), E                 ; this_free ptr into prev_free 
11c7 23			      inc   HL 
11c8 72			      ld    (HL), D 
11c9			 
11c9					if DEBUG_FORTH_MALLOC 
11c9						DMARK "Mul" 
11c9						CALLMONITOR 
11c9					endif 
11c9			      ; Clear the Z flag to indicate successful allocation 
11c9 7a			      ld    A, D 
11ca b3			      or    E 
11cb			 
11cb d1			      pop   DE                      ; Address of allocation 
11cc					if DEBUG_FORTH_MALLOC 
11cc						DMARK "MAu" 
11cc						CALLMONITOR 
11cc					endif 
11cc			 
11cc			malloc_no_space: 
11cc 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
11cf 39			      add   HL, SP 
11d0 f9			      ld    SP, HL 
11d1			 
11d1 eb			      ex    DE, HL                  ; Alloc addr into HL for return 
11d2					if DEBUG_FORTH_MALLOC 
11d2						DMARK "MAN" 
11d2						CALLMONITOR 
11d2					endif 
11d2			 
11d2			malloc_early_exit: 
11d2					if DEBUG_FORTH_MALLOC 
11d2						DMARK "MAx" 
11d2						CALLMONITOR 
11d2					endif 
11d2 dd e1		      pop   IX 
11d4 d1			      pop   DE 
11d5 c1			      pop   BC 
11d6			 
11d6			if DEBUG_FORTH_MALLOC_HIGH 
11d6			call malloc_guard_exit 
11d6			call malloc_guard_zerolen 
11d6			endif 
11d6 c9			      ret 
