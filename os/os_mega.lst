109d			;.str2:   db "string2",0 
109d			 
109d			; only care about direct match or not 
109d			; hl and de strings 
109d			; zero set if the same 
109d			 
109d			strcmp: 
109d 1a				ld a, (de) 
109e be				cp (hl) 
109f 28 02			jr z, .ssame 
10a1 b7				or a 
10a2 c9				ret 
10a3			 
10a3			.ssame:  
10a3			;	cp 0 
10a3 b7				or a 
10a4 c8				ret z 
10a5			 
10a5 23				inc hl 
10a6 13				inc de 
10a7 18 f4			jr strcmp 
