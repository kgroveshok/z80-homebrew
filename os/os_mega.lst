65f8			; init the words to detect the under/overflow 
65f8			 
65f8			chk_stk_init: 
65f8				; a vague random number to check so we dont get any "lucky" hits 
65f8 3e 2d			ld a, 45 
65fa 6f				ld l, a 
65fb 00				nop 
65fc 3e 17			ld a, 23 
65fe 67				ld h, a 
65ff			 
65ff 22 b9 f0			ld (chk_word), hl     ; the word we need to check against 
6602			 
6602			;	ld (chk_stund), hl	; stack points.... 
6602 22 3b fe			ld (chk_stovr), hl 
6605 22 08 f9			ld (chk_ret_und), hl 
6608 22 c6 f8			ld (chk_ret_ovr), hl 
660b 22 44 f8			ld (chk_loop_ovr), hl 
660e 22 42 f6			ld (chk_data_ovr), hl 
6611 c9				ret 
