0d8d			subafromhl: 
0d8d			   ; If A=0 do nothing 
0d8d			    ; Otherwise flip A's sign. Since 
0d8d			    ; the upper byte becomes -1, also 
0d8d			    ; substract 1 from H. 
0d8d ed 44		    neg 
0d8f ca 98 0d		    jp    z, Skip 
0d92 25			    dec   h 
0d93			     
0d93			    ; Now add the low byte as usual 
0d93			    ; Two's complement takes care of 
0d93			    ; ensuring the result is correct 
0d93 85			    add   a, l 
0d94 6f			    ld    l, a 
0d95 8c			    adc   a, h 
0d96 95			    sub   l 
0d97 67			    ld    h, a 
0d98			Skip: 
0d98 c9				ret 
