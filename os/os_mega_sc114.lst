8fe0 4f				ld c, a 
8fe1 16 ff			ld d, 255 
8fe3 2a 45 ea			ld hl, (tape_tm_high) 
8fe6 cd bb 8f			call tape_osc 
8fe9 c9				 ret 
8fea			 
