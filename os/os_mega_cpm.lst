4463			; var handler 
4463			 
4463			 
4463			.VARS: 
4463				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
4463 77				db WORD_SYS_CORE+99             
4464 e0 44			dw .V0            
4466 04				db 3 + 1 
4467 .. 00			db "VAR",0              
446b				endm 
# End of macro CWHEAD
446b			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
446b			; | 
446b			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
446b			; | |  
446b			; | | e.g. 
446b			; | |         #30 a var ! 
446b			; | |         a var @ . 
446b			; | |   
446b			; | |     Displays the number 30 
446b			; | | 
446b			; | | Each variable pointer is a word so can use for any words that use that:  
446b			; | |  
446b			; | | e.g. 
446b			; | |  
446b			; | |         #30 a var 2! 
446b			; | |         a var 2@ . 
446b			; | |   
446b			; | |     Displays the number 30 
446b			; | |  
446b			; | | > [!NOTE]  
446b			; ! | > If a full string is passed then only the first char is looked at 
446b			; | | > Any other char could exceed bounds checks!  
446b			; | | > 
446b			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
446b			 
446b					if DEBUG_FORTH_WORDS_KEY 
446b						DMARK "VAR" 
446b				if DEMARK_VERSION = 1  
446b e5					push hl  
446c 21 74 44				ld hl, .dmark  
446f 22 60 ee				ld (debug_mark), hl  
4472				endif  
4472				if DEMARK_VERSION = 0  
4472					push af  
4472					ld a, (.dmark)  
4472					ld (debug_mark),a  
4472					ld a, (.dmark+1)  
4472					ld (debug_mark+1),a  
4472					ld a, (.dmark+2)  
4472					ld (debug_mark+2),a  
4472				endif  
4472 18 04			jr .pastdmark  
4474 ..			.dmark: db "VAR"  
4477				if DEMARK_VERSION = 1  
4477 00					db 0  
4478				endif  
4478				if DEMARK_VERSION = 1  
4478 e1			.pastdmark: pop hl  
4479				endif  
4479				if DEMARK_VERSION = 0  
4479			.pastdmark: pop af  
4479				endif  
4479			endm  
# End of macro DMARK
4479						CALLMONITOR 
4479				if BASE_CPM=1  
4479 cd 6b ee				call debug_vector  
447c				endif  
447c				if BASE_KEV=1  
447c					rst 8  
447c				endif  
447c				endm  
# End of macro CALLMONITOR
447c					endif 
447c			 
447c					FORTH_DSP_VALUEHL 
447c				if BASE_CPM=1 
447c cd 5f 1a			call macro_dsp_valuehl 
447f				endif 
447f				if BASE_KEV=1 
447f					rst $18 
447f				endif 
447f				endm 
# End of macro FORTH_DSP_VALUEHL
