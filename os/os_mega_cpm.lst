13ba			.selbank: 
13ba			 
13ba			if STARTUP_V2 
13ba			;	if STORAGE_SE 
13ba			;	else 
13ba			 
13ba				ld hl, prom_banks 
13ba				call menu 
13ba				cp 0 
13ba				ret z 
13ba				 
13ba				; set the bank number from the result 
13ba			 
13ba				 
13ba					ld c, SPI_CE_HIGH 
13ba					ld b, '0'    ; human readable bank number 
13ba			 
13ba			 
13ba					; active low 
13ba			 
13ba			;		cp 0 
13ba					or a 
13ba					jr z, .bset 
13ba					cp 1 
13ba					jr nz, .b2 
13ba					res 0, c 
13ba					ld b, '1'    ; human readable bank number 
13ba			.b2:		cp 2 
13ba					jr nz, .b3 
13ba					res 1, c 
13ba					ld b, '2'    ; human readable bank number 
13ba			.b3:		cp 3 
13ba					jr nz, .b4 
13ba					res 2, c 
13ba					ld b, '3'    ; human readable bank number 
13ba			.b4:		cp 4 
13ba					jr nz, .b5 
13ba					res 3, c 
13ba					ld b, '4'    ; human readable bank number 
13ba			.b5:		cp 5 
13ba					jr nz, .bset 
13ba					res 4, c 
13ba					ld b, '5'    ; human readable bank number 
13ba			 
13ba			.bset: 
13ba			 
13ba					ld a, c 
13ba			;		ld (spi_device),a 
13ba					ld a, b 
13ba			;		ld (spi_device_id),a 
13ba					push bc 
