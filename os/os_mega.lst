7591 23			cpr1:	inc hl  
7592 0d				dec c  
7593 20 fc			jr nz, cpr1  
7595 05				dec b  
7596 20 f7			jr nz, cpr  
7598			  
7598				; add col	  
7598			  
7598 23			cpr2:	inc hl  
7599 1d				dec e  
759a 20 fc			jr nz, cpr2  
759c			  
759c c1				pop bc  
759d c9				ret  
