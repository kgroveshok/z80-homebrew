901b			if MALLOC_2 
901b			; Z80 Malloc and Free Functions 
901b			 
901b			; Malloc Function: 
901b			; Input: 
901b			;   HL: Size of block to allocate 
901b			; Output: 
901b			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
901b			 
901b			malloc: 
901b				 
901b			if DEBUG_FORTH_MALLOC_HIGH 
901b			call malloc_guard_entry 
901b			endif 
901b			 
901b			 
901b			 
901b			 
901b					if DEBUG_FORTH_MALLOC 
901b						DMARK "mal" 
901b						CALLMONITOR 
901b					endif 
901b			    push af            ; Save AF register 
901b			    ld a, l            ; Load low byte of size into A 
901b			    or h               ; Check if size is zero 
901b			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
901b			 
901b			    ; Allocate memory 
901b			    ld hl, (heap_start) ; Load start of heap into HL 
901b					if DEBUG_FORTH_MALLOC 
901b						DMARK "ma1" 
901b						CALLMONITOR 
901b					endif 
901b			    call malloc_internal ; Call internal malloc function 
901b			    pop af             ; Restore AF register 
901b			if DEBUG_FORTH_MALLOC_HIGH 
901b			call malloc_guard_exit 
901b			call malloc_guard_zerolen 
901b			endif 
901b			    ret                ; Return 
901b			 
901b			; Free Function: 
901b			; Input: 
901b			;   HL: Pointer to memory block to free 
901b			; Output: 
901b			;   None 
901b			 
901b			free: 
901b			    push af            ; Save AF register 
901b			    ld a, l            ; Load low byte of pointer into A 
901b			    or h               ; Check if pointer is NULL 
901b			    jp z, free_exit    ; If pointer is NULL, exit 
901b			 
901b			    ; Free memory 
901b			    ld hl, (heap_start) ; Load start of heap into HL 
901b			    call free_internal  ; Call internal free function 
901b			    pop af             ; Restore AF register 
901b			    ret                ; Return 
901b			 
901b			; Internal Malloc Function: 
901b			; Input: 
901b			;   HL: Size of block to allocate 
901b			; Output: 
901b			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
901b			 
901b			malloc_internal: 
901b			    ld bc, 2           ; Number of bytes to allocate for management overhead 
901b			    add hl, bc         ; Add management overhead to requested size 
901b			    ex de, hl          ; Save total size in DE, and keep it in HL 
901b					if DEBUG_FORTH_MALLOC 
901b						DMARK "ma2" 
901b						CALLMONITOR 
901b					endif 
901b			 
901b			    ; Search for free memory block 
901b			    ld de, (heap_end)  ; Load end of heap into DE 
901b			    ld bc, 0           ; Initialize counter 
901b			 
901b					if DEBUG_FORTH_MALLOC 
901b						DMARK "ma2" 
901b						CALLMONITOR 
901b					endif 
901b			malloc_search_loop: 
901b			    ; Check if current block is free 
901b			    ld a, (hl)         ; Load current block's status (free or used) 
901b			;    cp 0               ; Compare with zero (free) 
901b				or a 
901b			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
901b			 
901b			    ; Check if current block is large enough 
901b			    ld a, (hl+1)       ; Load high byte of block size 
901b			    cp l               ; Compare with low byte of requested size 
901b			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
901b			 
901b			    ld a, (hl+2)       ; Load low byte of block size 
901b			    cp h               ; Compare with high byte of requested size 
901b			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
901b			 
901b			    ; Mark block as used 
901b			    ld (hl), 0xFF      ; Set status byte to indicate used block 
901b			 
901b			    ; Calculate remaining space in block 
901b			    ld bc, 0           ; Clear BC 
901b			    add hl, bc         ; Increment HL to point to start of data block 
901b			    add hl, de         ; HL = HL + DE (total size) 
901b			    ld bc, 1           ; Number of bytes to allocate for management overhead 
901b			    add hl, bc         ; Add management overhead to start of data block 
901b			 
901b			    ; Save pointer to allocated block in HL 
901b			if DEBUG_FORTH_MALLOC_HIGH 
901b						DMARK "ma5" 
901b			call malloc_guard_exit 
901b			call malloc_guard_zerolen 
901b			endif 
901b			    ret 
901b			 
901b			malloc_skip_block_check: 
901b			    ; Move to the next block 
901b			    ld bc, 3           ; Size of management overhead 
901b			    add hl, bc         ; Move to the next block 
901b			    inc de             ; Increment counter 
901b			 
901b			    ; Check if we have reached the end of heap 
901b			    ld a, e            ; Load low byte of heap end address 
901b			    cp (hl)            ; Compare with low byte of current address 
901b			    jr nz, malloc_search_loop  ; If not equal, continue searching 
901b			    ld a, d            ; Load high byte of heap end address 
901b			;    cp 0               ; Check if it's zero (end of memory) 
901b				or a 
901b			    jr nz, malloc_search_loop  ; If not zero, continue searching 
901b			 
901b			    ; If we reached here, allocation failed 
901b			    xor a              ; Set result to NULL 
901b			if DEBUG_FORTH_MALLOC_HIGH 
901b						DMARK "ma6" 
901b			call malloc_guard_exit 
901b			call malloc_guard_zerolen 
901b			endif 
901b			    ret 
901b			malloc_exit: 
901b			if DEBUG_FORTH_MALLOC_HIGH 
901b						DMARK "ma7" 
901b			call malloc_guard_exit 
901b			call malloc_guard_zerolen 
901b			endif 
901b			    ret 
901b			 
901b			; Internal Free Function: 
901b			; Input: 
901b			;   HL: Pointer to memory block to free 
901b			; Output: 
901b			;   None 
901b			 
901b			free_internal: 
901b			    ld de, (heap_start) ; Load start of heap into DE 
901b			    ld bc, 0            ; Initialize counter 
901b			 
901b			free_search_loop: 
901b			    ; Check if current block contains the pointer 
901b			    ld a, l             ; Load low byte of pointer 
901b			    cp (hl+1)           ; Compare with high byte of current block's address 
901b			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
901b			    ld a, h             ; Load high byte of pointer 
901b			    cp (hl+2)           ; Compare with low byte of current block's address 
901b			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
901b			 
901b			    ; Mark block as free 
901b			    ld (hl), 0          ; Set status byte to indicate free block 
901b			    ret                 ; Return 
901b			 
901b			free_skip_block_check: 
901b			    ; Move to the next block 
901b			    ld bc, 3            ; Size of management overhead 
901b			    add hl, bc          ; Move to the next block 
901b			    inc de              ; Increment counter 
901b			 
901b			    ; Check if we have reached the end of heap 
901b			    ld a, e             ; Load low byte of heap end address 
901b			    cp (hl)             ; Compare with low byte of current address 
901b			    jr nz, free_search_loop  ; If not equal, continue searching 
901b			    ld a, d             ; Load high byte of heap end address 
901b			;    cp 0                ; Check if it's zero (end of memory) 
901b				or a 
901b			    jr nz, free_search_loop  ; If not zero, continue searching 
901b			 
901b			    ; If we reached here, pointer is not found in heap 
901b			    ret 
901b			 
901b			free_exit: 
901b			    ret                 ; Return 
901b			 
901b			; Define heap start and end addresses 
901b			;heap_start:    .dw 0xC000   ; Start of heap 
901b			;heap_end:      .dw 0xE000   ; End of heap 
901b			 
901b			endif 
901b			 
