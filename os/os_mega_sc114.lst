8d67 26 3a		  ld h,'9'+1 
8d69 25			  dec h  
8d6a c6 0a		  add a,10  
8d6c 30 fb		   jr nc,$-3 
8d6e c6 30		  add a,'0' 
8d70 eb			  ex de,hl 
8d71 72			  ld (hl),d 
8d72 23			  inc hl 
8d73 77			  ld (hl),a 
8d74 23			  inc hl 
8d75 36 00		  ld (hl),0 
8d77			 
