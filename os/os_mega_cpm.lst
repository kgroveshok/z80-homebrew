0d77			; https://map.grauw.nl/articles/mult_div_shifts.php 
0d77			; Divide 16-bit values (with 16-bit result) 
0d77			; In: Divide BC by divider DE 
0d77			; Out: BC = result, HL = rest 
0d77			; 
0d77			Div16: 
0d77 21 00 00		    ld hl,0 
0d7a 78			    ld a,b 
0d7b 06 08		    ld b,8 
0d7d			Div16_Loop1: 
0d7d 17			    rla 
0d7e ed 6a		    adc hl,hl 
0d80 ed 52		    sbc hl,de 
0d82 30 01		    jr nc,Div16_NoAdd1 
0d84 19			    add hl,de 
0d85			Div16_NoAdd1: 
0d85 10 f6		    djnz Div16_Loop1 
0d87 17			    rla 
0d88 2f			    cpl 
0d89 47			    ld b,a 
0d8a 79			    ld a,c 
0d8b 48			    ld c,b 
0d8c 06 08		    ld b,8 
0d8e			Div16_Loop2: 
0d8e 17			    rla 
0d8f ed 6a		    adc hl,hl 
0d91 ed 52		    sbc hl,de 
0d93 30 01		    jr nc,Div16_NoAdd2 
0d95 19			    add hl,de 
0d96			Div16_NoAdd2: 
0d96 10 f6		    djnz Div16_Loop2 
0d98 17			    rla 
0d99 2f			    cpl 
0d9a 41			    ld b,c 
0d9b 4f			    ld c,a 
0d9c c9			ret 
