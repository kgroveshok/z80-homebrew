0cc4			 
0cc4			;http://z80-heaven.wikidot.com/math 
0cc4			; 
0cc4			;Inputs: 
0cc4			;     DE and A are factors 
0cc4			;Outputs: 
0cc4			;     A is not changed 
0cc4			;     B is 0 
0cc4			;     C is not changed 
0cc4			;     DE is not changed 
0cc4			;     HL is the product 
0cc4			;Time: 
0cc4			;     342+6x 
0cc4			; 
0cc4			Mult16: 
0cc4			 
0cc4 06 08		     ld b,8          ;7           7 
0cc6 21 00 00		     ld hl,0         ;10         10 
0cc9 29			       add hl,hl     ;11*8       88 
0cca 07			       rlca          ;4*8        32 
0ccb 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0ccd 19			         add hl,de   ;--         -- 
0cce 10 f9		       djnz $-5      ;13*7+8     99 
0cd0 c9			ret 
