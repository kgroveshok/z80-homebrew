59ea			include "forth_startup.asm" 
59ea			; Which startup method to use? 
59ea			; 
59ea			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
59ea			; followed by loading of a list of scripts in eeprom 
59ea			 
59ea			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
59ea			; from eeprom 
59ea			 
59ea			; Select with define in main stubs 
59ea			 
59ea			if STARTUP_V1 
59ea				include "forth_startupv1.asm" 
59ea			; Startup script loading version 1 
59ea			 
59ea			; If SE storage is available first stage is to use the selected file 
59ea			; then go through the eeprom list 
59ea			 
59ea .. 00		sprompt1: db "Startup load...",0 
59fa .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
