1121			 
1121			;written by Zeda 
1121			;Converts a 16-bit unsigned integer to an ASCII string. 
1121			 
1121			uitoa_16: 
1121			;Input: 
1121			;   DE is the number to convert 
1121			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1121			;Output: 
1121			;   HL points to the null-terminated ASCII string 
1121			;      NOTE: This isn't necessarily the same as the input HL. 
1121 d5			  push de 
1122 c5			  push bc 
1123 f5			  push af 
1124 eb			  ex de,hl 
1125			 
1125 01 f0 d8		  ld bc,-10000 
1128 3e 2f		  ld a,'0'-1 
112a 3c			  inc a 
112b 09			  add hl,bc  
112c 38 fc		   jr c,$-2 
112e 12			  ld (de),a 
112f 13			  inc de 
1130			 
1130 01 e8 03		  ld bc,1000 
1133 3e 3a		  ld a,'9'+1 
1135 3d			  dec a  
1136 09			  add hl,bc  
1137 30 fc		   jr nc,$-2 
1139 12			  ld (de),a 
113a 13			  inc de 
113b			 
113b 01 9c ff		  ld bc,-100 
113e 3e 2f		  ld a,'0'-1 
1140 3c			  inc a  
1141 09			  add hl,bc  
1142 38 fc		   jr c,$-2 
1144 12			  ld (de),a 
1145 13			  inc de 
1146			 
1146 7d			  ld a,l 
1147 26 3a		  ld h,'9'+1 
1149 25			  dec h  
114a c6 0a		  add a,10  
114c 30 fb		   jr nc,$-3 
114e c6 30		  add a,'0' 
1150 eb			  ex de,hl 
1151 72			  ld (hl),d 
1152 23			  inc hl 
1153 77			  ld (hl),a 
1154 23			  inc hl 
1155 36 00		  ld (hl),0 
1157			 
1157			;Now strip the leading zeros 
1157 0e fa		  ld c,-6 
1159 09			  add hl,bc 
115a 3e 30		  ld a,'0' 
115c 23			  inc hl  
115d be			  cp (hl)  
115e 28 fc		  jr z,$-2 
1160			 
1160			;Make sure that the string is non-empty! 
1160 7e			  ld a,(hl) 
1161 b7			  or a 
1162 20 01		  jr nz,.atoub 
1164 2b			  dec hl 
1165			.atoub: 
