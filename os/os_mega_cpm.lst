0b3d cb 13		    rl e 
0b3f 17			    rla 
0b40 91			    sub c 
0b41 30 01		    jr nc,Div8_NoAdd 
0b43 81			    add a,c 
0b44			Div8_NoAdd: 
0b44 10 f7		    djnz Div8_Loop 
0b46 47			    ld b,a 
0b47 7b			    ld a,e 
0b48 17			    rla 
0b49 2f			    cpl 
0b4a c9			    ret 
