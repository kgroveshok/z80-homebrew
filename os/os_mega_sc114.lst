8c1a			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
8c1a			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
8c1a			tohex: 
8c1a e5					PUSH HL 
8c1b d5					PUSH DE 
8c1c 16 00				LD D, 0 
8c1e 5f					LD E, A 
8c1f 21 27 8c				LD HL, .DATA 
8c22 19					ADD HL, DE 
8c23 7e					LD A, (HL) 
8c24 d1					POP DE 
8c25 e1					POP HL 
8c26 c9					RET 
