8a5b			addatode: 
8a5b 83			    add   a, e    ; A = A+L 
8a5c 5f			    ld    e, a    ; L = A+L 
8a5d 8a			    adc   a, d    ; A = A+L+H+carry 
8a5e 93			    sub   e       ; A = H+carry 
8a5f 57			    ld    d, a    ; H = H+carry 
8a60 c9			ret 
