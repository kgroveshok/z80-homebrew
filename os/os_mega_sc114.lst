99b1 23				inc hl 
99b2 36 00			ld (hl),0 
99b4			 
99b4 21 1d e9			ld hl, cli_loop_stack 
99b7 22 e3 e9			ld (cli_loop_sp), hl	 
99ba				; set bottom of stack 
99ba			;	ld a,0 
99ba 36 00			ld (hl),0 
99bc 23				inc hl 
99bd 36 00			ld (hl),0 
