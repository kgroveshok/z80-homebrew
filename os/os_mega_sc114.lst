8c89			; 
8c89			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8c89			; Since the routines get_byte and therefore get_nibble are called, only valid 
8c89			; characters (0-9a-f) are accepted. 
8c89			; 
8c89			;get_word        push    af 
8c89			;                call    get_byte        ; Get the upper byte 
8c89			;                ld      h, a 
8c89			;                call    get_byte        ; Get the lower byte 
8c89			;                ld      l, a 
8c89			;                pop     af 
8c89			;                ret 
8c89			; 
8c89			; Get a byte in hexadecimal notation. The result is returned in A. Since 
8c89			; the routine get_nibble is used only valid characters are accepted - the  
8c89			; input routine only accepts characters 0-9a-f. 
8c89			; 
8c89 c5			get_byte:        push    bc              ; Save contents of B (and C) 
8c8a 7e					ld a,(hl) 
8c8b 23					inc hl 
8c8c cd b1 8c		                call    nibble2val      ; Get upper nibble 
8c8f cb 07		                rlc     a 
8c91 cb 07		                rlc     a 
8c93 cb 07		                rlc     a 
8c95 cb 07		                rlc     a 
8c97 47			                ld      b, a            ; Save upper four bits 
8c98 7e					ld a,(hl) 
8c99 cd b1 8c		                call    nibble2val      ; Get lower nibble 
8c9c b0			                or      b               ; Combine both nibbles 
8c9d c1			                pop     bc              ; Restore B (and C) 
8c9e c9			                ret 
8c9f			; 
8c9f			; Get a hexadecimal digit from the serial line. This routine blocks until 
8c9f			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
8c9f			; to the serial line interface. The lower 4 bits of A contain the value of  
8c9f			; that particular digit. 
8c9f			; 
8c9f			;get_nibble      ld a,(hl)           ; Read a character 
8c9f			;                call    to_upper        ; Convert to upper case 
8c9f			;                call    is_hex          ; Was it a hex digit? 
8c9f			;                jr      nc, get_nibble  ; No, get another character 
8c9f			 ;               call    nibble2val      ; Convert nibble to value 
8c9f			 ;               call    print_nibble 
8c9f			 ;               ret 
8c9f			; 
8c9f			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
8c9f			; A valid hexadecimal digit is denoted by a set C flag. 
8c9f			; 
8c9f			;is_hex          cp      'F' + 1         ; Greater than 'F'? 
8c9f			;                ret     nc              ; Yes 
8c9f			;                cp      '0'             ; Less than '0'? 
