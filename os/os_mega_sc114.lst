8dab			;	ld (os_view_disable), a 
8dab			 
8dab				pop de 
8dab				pop hl 
8dab			 
8dab				 
8dab			 
8dab				CALLMONITOR 
8dab			.lowalloz: 
8dab			 
8dab			 
8dab				pop af 
8dab				pop de 
8dab				pop hl 
8dab			ret 
