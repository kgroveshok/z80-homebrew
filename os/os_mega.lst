1113			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
1113			 
1113			; String Length 
1113			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
1113			 
1113			; Get the length of the null-terminated string starting at $8000 hl 
1113			;    LD     HL, $8000 
1113			 
1113			strlenz: 
1113			 
1113 af			    XOR    A               ; Zero is the value we are looking for. 
1114 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
1115 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
1116			                           ; 65, 536 bytes (the entire addressable memory space). 
1116 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
1118			 
1118			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
1118 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
1119 6f			    LD     L, A             ; number of bytes 
111a ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
111c 2b			    DEC    HL              ; Compensate for null. 
111d c9				ret 
111e			 
111e			; Get the length of the A terminated string starting at $8000 hl 
111e			;    LD     HL, $8000 
111e			 
111e			strlent: 
111e			 
111e			                  ; A is the value we are looking for. 
111e 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
1120 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
1122			                           ; 65, 536 bytes (the entire addressable memory space). 
1122 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
1124			 
1124			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
1124 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
1126 2e 00		    LD     L, 0             ; number of bytes 
1128 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
112a 2b			    DEC    HL              ; Compensate for null. 
112b c9				ret 
112c			 
112c			 
112c			;Comparing Strings 
112c			 
112c			;IN    HL     Address of string1. 
112c			;      DE     Address of string2. 
112c			 
112c			; doc given but wrong??? 
112c			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
112c			;      carry  Set if string1 > string2, reset if string1 <= string2. 
112c			; tested 
112c			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
112c			 
112c			strcmp_old: 
112c e5			    PUSH   HL 
112d d5			    PUSH   DE 
112e			 
112e 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
112f be			    CP     (HL)            ; (want to minimize work). 
1130 38 01		    JR     C, Str1IsBigger 
1132 7e			    LD     A, (HL) 
1133			 
1133			Str1IsBigger: 
1133 4f			    LD     C, A             ; Put length in BC 
1134 06 00		    LD     B, 0 
1136 13			    INC    DE              ; Increment pointers to meat of string. 
1137 23			    INC    HL 
1138			 
1138			CmpLoop: 
1138 1a			    LD     A, (DE)          ; Compare bytes. 
1139 ed a1		    CPI 
113b 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
113d 13			    INC    DE              ; Update pointer. 
113e ea 38 11		    JP     PE, CmpLoop 
1141			 
1141 d1			    POP    DE 
1142 e1			    POP    HL 
1143 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
1144 be			    CP     (HL) 
1145 c9			    RET 
1146			 
1146			NoMatch: 
1146 2b			    DEC    HL 
1147 be			    CP     (HL)            ; Compare again to affect carry. 
1148 d1			    POP    DE 
1149 e1			    POP    HL 
114a c9			    RET 
