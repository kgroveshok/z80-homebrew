103a			; Decimal Unsigned Version 
103a			 
103a			;Number in a to decimal ASCII 
103a			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
103a			;Example: display a=56 as "056" 
103a			;input: a = number 
103a			;Output: a=0,value of a in the screen 
103a			;destroys af,bc (don't know about hl and de) 
103a			DispAToASCII: 
103a 0e 9c			ld	c,-100 
103c cd 46 10			call	.Na1 
103f 0e f6			ld	c,-10 
1041 cd 46 10			call	.Na1 
1044 0e ff			ld	c,-1 
1046 06 2f		.Na1:	ld	b,'0'-1 
1048 04			.Na2:	inc	b 
1049 81				add	a,c 
104a 38 fc			jr	c,.Na2 
104c 91				sub	c		;works as add 100/10/1 
104d f5				push af		;safer than ld c,a 
104e 78				ld	a,b		;char is in b 
104f			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
104f f1				pop af		;safer than ld a,c 
1050 c9				ret 
