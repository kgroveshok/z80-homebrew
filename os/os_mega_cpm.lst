0f9c			if MALLOC_2 
0f9c			; Z80 Malloc and Free Functions 
0f9c			 
0f9c			; Malloc Function: 
0f9c			; Input: 
0f9c			;   HL: Size of block to allocate 
0f9c			; Output: 
0f9c			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
0f9c			 
0f9c			malloc: 
0f9c				 
0f9c			if DEBUG_FORTH_MALLOC_HIGH 
0f9c			call malloc_guard_entry 
0f9c			endif 
0f9c			 
0f9c			 
0f9c			 
0f9c			 
0f9c					if DEBUG_FORTH_MALLOC 
0f9c						DMARK "mal" 
0f9c						CALLMONITOR 
0f9c					endif 
0f9c			    push af            ; Save AF register 
0f9c			    ld a, l            ; Load low byte of size into A 
0f9c			    or h               ; Check if size is zero 
0f9c			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
0f9c			 
0f9c			    ; Allocate memory 
0f9c			    ld hl, (heap_start) ; Load start of heap into HL 
0f9c					if DEBUG_FORTH_MALLOC 
0f9c						DMARK "ma1" 
0f9c						CALLMONITOR 
0f9c					endif 
0f9c			    call malloc_internal ; Call internal malloc function 
0f9c			    pop af             ; Restore AF register 
0f9c			if DEBUG_FORTH_MALLOC_HIGH 
0f9c			call malloc_guard_exit 
0f9c			call malloc_guard_zerolen 
0f9c			endif 
0f9c			    ret                ; Return 
0f9c			 
0f9c			; Free Function: 
0f9c			; Input: 
0f9c			;   HL: Pointer to memory block to free 
0f9c			; Output: 
0f9c			;   None 
0f9c			 
0f9c			free: 
0f9c			    push af            ; Save AF register 
0f9c			    ld a, l            ; Load low byte of pointer into A 
0f9c			    or h               ; Check if pointer is NULL 
0f9c			    jp z, free_exit    ; If pointer is NULL, exit 
0f9c			 
0f9c			    ; Free memory 
0f9c			    ld hl, (heap_start) ; Load start of heap into HL 
0f9c			    call free_internal  ; Call internal free function 
0f9c			    pop af             ; Restore AF register 
0f9c			    ret                ; Return 
0f9c			 
0f9c			; Internal Malloc Function: 
0f9c			; Input: 
0f9c			;   HL: Size of block to allocate 
0f9c			; Output: 
0f9c			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
0f9c			 
0f9c			malloc_internal: 
0f9c			    ld bc, 2           ; Number of bytes to allocate for management overhead 
0f9c			    add hl, bc         ; Add management overhead to requested size 
0f9c			    ex de, hl          ; Save total size in DE, and keep it in HL 
0f9c					if DEBUG_FORTH_MALLOC 
0f9c						DMARK "ma2" 
0f9c						CALLMONITOR 
0f9c					endif 
0f9c			 
0f9c			    ; Search for free memory block 
0f9c			    ld de, (heap_end)  ; Load end of heap into DE 
0f9c			    ld bc, 0           ; Initialize counter 
0f9c			 
0f9c					if DEBUG_FORTH_MALLOC 
0f9c						DMARK "ma2" 
0f9c						CALLMONITOR 
0f9c					endif 
0f9c			malloc_search_loop: 
0f9c			    ; Check if current block is free 
0f9c			    ld a, (hl)         ; Load current block's status (free or used) 
0f9c			;    cp 0               ; Compare with zero (free) 
0f9c				or a 
0f9c			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
0f9c			 
0f9c			    ; Check if current block is large enough 
0f9c			    ld a, (hl+1)       ; Load high byte of block size 
0f9c			    cp l               ; Compare with low byte of requested size 
0f9c			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
0f9c			 
0f9c			    ld a, (hl+2)       ; Load low byte of block size 
0f9c			    cp h               ; Compare with high byte of requested size 
0f9c			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
0f9c			 
0f9c			    ; Mark block as used 
0f9c			    ld (hl), 0xFF      ; Set status byte to indicate used block 
0f9c			 
0f9c			    ; Calculate remaining space in block 
0f9c			    ld bc, 0           ; Clear BC 
0f9c			    add hl, bc         ; Increment HL to point to start of data block 
0f9c			    add hl, de         ; HL = HL + DE (total size) 
0f9c			    ld bc, 1           ; Number of bytes to allocate for management overhead 
0f9c			    add hl, bc         ; Add management overhead to start of data block 
0f9c			 
0f9c			    ; Save pointer to allocated block in HL 
0f9c			if DEBUG_FORTH_MALLOC_HIGH 
0f9c						DMARK "ma5" 
0f9c			call malloc_guard_exit 
0f9c			call malloc_guard_zerolen 
0f9c			endif 
0f9c			    ret 
0f9c			 
0f9c			malloc_skip_block_check: 
0f9c			    ; Move to the next block 
0f9c			    ld bc, 3           ; Size of management overhead 
0f9c			    add hl, bc         ; Move to the next block 
0f9c			    inc de             ; Increment counter 
0f9c			 
0f9c			    ; Check if we have reached the end of heap 
0f9c			    ld a, e            ; Load low byte of heap end address 
0f9c			    cp (hl)            ; Compare with low byte of current address 
0f9c			    jr nz, malloc_search_loop  ; If not equal, continue searching 
0f9c			    ld a, d            ; Load high byte of heap end address 
0f9c			;    cp 0               ; Check if it's zero (end of memory) 
0f9c				or a 
0f9c			    jr nz, malloc_search_loop  ; If not zero, continue searching 
0f9c			 
0f9c			    ; If we reached here, allocation failed 
0f9c			    xor a              ; Set result to NULL 
0f9c			if DEBUG_FORTH_MALLOC_HIGH 
0f9c						DMARK "ma6" 
0f9c			call malloc_guard_exit 
0f9c			call malloc_guard_zerolen 
0f9c			endif 
0f9c			    ret 
0f9c			malloc_exit: 
0f9c			if DEBUG_FORTH_MALLOC_HIGH 
0f9c						DMARK "ma7" 
0f9c			call malloc_guard_exit 
0f9c			call malloc_guard_zerolen 
0f9c			endif 
0f9c			    ret 
0f9c			 
0f9c			; Internal Free Function: 
0f9c			; Input: 
0f9c			;   HL: Pointer to memory block to free 
0f9c			; Output: 
0f9c			;   None 
0f9c			 
0f9c			free_internal: 
0f9c			    ld de, (heap_start) ; Load start of heap into DE 
0f9c			    ld bc, 0            ; Initialize counter 
0f9c			 
0f9c			free_search_loop: 
0f9c			    ; Check if current block contains the pointer 
0f9c			    ld a, l             ; Load low byte of pointer 
0f9c			    cp (hl+1)           ; Compare with high byte of current block's address 
0f9c			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
0f9c			    ld a, h             ; Load high byte of pointer 
0f9c			    cp (hl+2)           ; Compare with low byte of current block's address 
0f9c			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
0f9c			 
0f9c			    ; Mark block as free 
0f9c			    ld (hl), 0          ; Set status byte to indicate free block 
0f9c			    ret                 ; Return 
0f9c			 
0f9c			free_skip_block_check: 
0f9c			    ; Move to the next block 
0f9c			    ld bc, 3            ; Size of management overhead 
0f9c			    add hl, bc          ; Move to the next block 
0f9c			    inc de              ; Increment counter 
0f9c			 
0f9c			    ; Check if we have reached the end of heap 
0f9c			    ld a, e             ; Load low byte of heap end address 
0f9c			    cp (hl)             ; Compare with low byte of current address 
0f9c			    jr nz, free_search_loop  ; If not equal, continue searching 
0f9c			    ld a, d             ; Load high byte of heap end address 
0f9c			;    cp 0                ; Check if it's zero (end of memory) 
0f9c				or a 
0f9c			    jr nz, free_search_loop  ; If not zero, continue searching 
0f9c			 
0f9c			    ; If we reached here, pointer is not found in heap 
0f9c			    ret 
0f9c			 
0f9c			free_exit: 
0f9c			    ret                 ; Return 
0f9c			 
0f9c			; Define heap start and end addresses 
0f9c			;heap_start:    .dw 0xC000   ; Start of heap 
0f9c			;heap_end:      .dw 0xE000   ; End of heap 
0f9c			 
0f9c			endif 
