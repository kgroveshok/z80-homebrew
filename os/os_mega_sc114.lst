a691 32 5f ee			ld (debug_mark+1),a  
a694 3a 9e a6			ld a, (.dmark+2)  
a697 32 60 ee			ld (debug_mark+2),a  
a69a 18 03			jr .pastdmark  
a69c ..			.dmark: db "BP."  
a69f f1			.pastdmark: pop af  
a6a0			endm  
