8a15			; 
8a15			; Multiply 16-bit values (with 32-bit result) 
8a15			; In: Multiply BC with DE 
8a15			; Out: BCHL = result 
8a15			; 
8a15			Mult32: 
8a15 79			    ld a,c 
8a16 48			    ld c,b 
8a17 21 00 00		    ld hl,0 
8a1a 06 10		    ld b,16 
8a1c			Mult32_Loop: 
8a1c 29			    add hl,hl 
8a1d 17			    rla 
8a1e cb 11		    rl c 
8a20 30 07		    jr nc,Mult32_NoAdd 
8a22 19			    add hl,de 
8a23 ce 00		    adc a,0 
8a25 d2 29 8a		    jp nc,Mult32_NoAdd 
8a28 0c			    inc c 
8a29			Mult32_NoAdd: 
8a29 10 f1		    djnz Mult32_Loop 
8a2b 41			    ld b,c 
8a2c 4f			    ld c,a 
8a2d c9			    ret 
