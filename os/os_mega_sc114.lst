8dc6			;Comparing Strings 
8dc6			 
8dc6			;IN    HL     Address of string1. 
8dc6			;      DE     Address of string2. 
8dc6			 
8dc6			; doc given but wrong??? 
8dc6			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
8dc6			;      carry  Set if string1 > string2, reset if string1 <= string2. 
8dc6			; tested 
8dc6			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
8dc6			 
8dc6			strcmp_old: 
8dc6 e5			    PUSH   HL 
8dc7 d5			    PUSH   DE 
8dc8			 
8dc8 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
8dc9 be			    CP     (HL)            ; (want to minimize work). 
8dca 38 01		    JR     C, Str1IsBigger 
8dcc 7e			    LD     A, (HL) 
8dcd			 
8dcd			Str1IsBigger: 
8dcd 4f			    LD     C, A             ; Put length in BC 
8dce 06 00		    LD     B, 0 
8dd0 13			    INC    DE              ; Increment pointers to meat of string. 
8dd1 23			    INC    HL 
8dd2			 
8dd2			CmpLoop: 
8dd2 1a			    LD     A, (DE)          ; Compare bytes. 
8dd3 ed a1		    CPI 
8dd5 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
8dd7 13			    INC    DE              ; Update pointer. 
8dd8 ea d2 8d		    JP     PE, CmpLoop 
8ddb			 
8ddb d1			    POP    DE 
8ddc e1			    POP    HL 
8ddd 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
8dde be			    CP     (HL) 
8ddf c9			    RET 
8de0			 
8de0			NoMatch: 
8de0 2b			    DEC    HL 
8de1 be			    CP     (HL)            ; Compare again to affect carry. 
8de2 d1			    POP    DE 
8de3 e1			    POP    HL 
8de4 c9			    RET 
8de5			 
