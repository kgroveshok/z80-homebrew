6adb			; Position cursor to specified location  
6adb			;   On entry: A = Cursor position  
6adb			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6adb f5			fLCD_Pos:   PUSH AF  
6adc					; at this point set the E1 or E2 flag depending on position  
6adc			  
6adc c5					push bc  
6add			;		push af  
6add 06 00				ld b, 0  
6adf 4f					ld c, a  
6ae0 3e 4f				ld a, kLCD_Line3-1  
6ae2 b7			 		or a      ;clear carry flag  
6ae3 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6ae4 38 04				jr c, .pe1  
6ae6			  
6ae6					; E selection  
6ae6 cb 80				res 0, b         ; bit 0 unset e  
6ae8			;		pop af    ; before line 3 so recover orig pos  
6ae8			;		ld c, a    ; save for poking back  
6ae8 18 06				jr .peset	          
6aea			.pe1:          	; E2 selection  
6aea cb c0				set 0, b         ; bit 0 set e1  
6aec 79					ld a, c  
6aed de 4f				sbc a, kLCD_Line3-1  
6aef 4f					ld c, a	         ; save caculated offset  
6af0			;		pop af     ; bin this original value now we have calculated form  
6af0			  
6af0			.peset:		; set bit  
6af0 78					ld a, b  
6af1 32 fb fa				ld (display_lcde1e2), a 	  
6af4 79					ld a, c  
6af5 c1					pop bc  
