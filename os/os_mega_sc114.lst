9d66					ld (debug_mark+1),a  
9d66					ld a, (.dmark+2)  
9d66					ld (debug_mark+2),a  
9d66				endif  
9d66 18 04			jr .pastdmark  
9d68 ..			.dmark: db "HEP"  
9d6b				if DEMARK_VERSION = 1  
9d6b 00					db 0  
9d6c				endif  
9d6c				if DEMARK_VERSION = 1  
9d6c e1			.pastdmark: pop hl  
9d6d				endif  
