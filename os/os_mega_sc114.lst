bfd1			.SPII: 
bfd1				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
bfd1			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
bfd1					if DEBUG_FORTH_WORDS_KEY 
