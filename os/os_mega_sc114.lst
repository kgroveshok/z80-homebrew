bbd6						DMARK "VAR" 
bbd6				if DEMARK_VERSION = 1  
bbd6 e5					push hl  
bbd7 21 df bb				ld hl, .dmark  
bbda 22 60 ee				ld (debug_mark), hl  
bbdd				endif  
