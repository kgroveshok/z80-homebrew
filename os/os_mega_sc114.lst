d2b9			; stack over and underflow checks 
d2b9			 
d2b9			; init the words to detect the under/overflow 
d2b9			 
d2b9			chk_stk_init: 
d2b9				; a vague random number to check so we dont get any "lucky" hits 
d2b9 3e 2d			ld a, 45 
d2bb 6f				ld l, a 
d2bc 00				nop 
d2bd 3e 17			ld a, 23 
d2bf 67				ld h, a 
d2c0			 
d2c0 22 80 e2			ld (chk_word), hl     ; the word we need to check against 
d2c3			 
d2c3			;	ld (chk_stund), hl	; stack points.... 
d2c3 22 00 ef			ld (chk_stovr), hl 
d2c6 22 cf e9			ld (chk_ret_und), hl 
d2c9 22 8d e9			ld (chk_ret_ovr), hl 
d2cc 22 0b e9			ld (chk_loop_ovr), hl 
d2cf 22 09 e8			ld (chk_data_ovr), hl 
d2d2 c9				ret 
d2d3				 
d2d3			check_stacks: 
d2d3				; check all stack words 
d2d3			 
d2d3 e5				push hl 
d2d4 d5				push de 
d2d5			 
d2d5			;	ld de,(chk_word) 
d2d5			;	ld hl, (chk_stund)	; stack points.... 
d2d5			;	if DEBUG_STK_FAULT 
d2d5			;		DMARK "FAa" 
d2d5			;		CALLMONITOR 
d2d5			;	endif 
d2d5			;	call cmp16 
d2d5			;	jp z, .chk_faulta 
d2d5			; 
d2d5			;	ld de, sfaultsu 
d2d5			;	jp .chk_fault 
d2d5			 
d2d5 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
d2d8 ed 5b 80 e2		ld de,(chk_word) 
d2dc				if DEBUG_STK_FAULT 
d2dc					DMARK "FAb" 
d2dc					CALLMONITOR 
d2dc				endif 
d2dc cd 58 8a			call cmp16 
d2df 28 06			jr z, .chk_fault1 
d2e1 11 86 d3			ld de, sfaultso 
d2e4 c3 36 d3			jp .chk_fault 
d2e7			.chk_fault1:  
d2e7 2a cf e9			ld hl, (chk_ret_und) 
d2ea ed 5b 80 e2		ld de,(chk_word) 
d2ee				if DEBUG_STK_FAULT 
d2ee					DMARK "FAU" 
d2ee					CALLMONITOR 
d2ee				endif 
d2ee cd 58 8a			call cmp16 
d2f1 ca fa d2			jp z, .chk_fault2 
d2f4 11 96 d3			ld de, sfaultru 
d2f7 c3 36 d3			jp .chk_fault 
d2fa			.chk_fault2:  
d2fa 2a 8d e9			ld hl, (chk_ret_ovr) 
d2fd ed 5b 80 e2		ld de,(chk_word) 
d301				if DEBUG_STK_FAULT 
d301					DMARK "FA1" 
d301					CALLMONITOR 
d301				endif 
d301 cd 58 8a			call cmp16 
d304 ca 0d d3			jp z, .chk_fault3 
d307 11 a4 d3			ld de, sfaultro 
d30a c3 36 d3			jp .chk_fault 
d30d			.chk_fault3:  
d30d 2a 0b e9			ld hl, (chk_loop_ovr) 
d310 ed 5b 80 e2		ld de,(chk_word) 
d314				if DEBUG_STK_FAULT 
d314					DMARK "FA2" 
d314					CALLMONITOR 
d314				endif 
d314 cd 58 8a			call cmp16 
d317 ca 20 d3			jp z, .chk_fault4 
d31a 11 be d3			ld de, sfaultlo 
d31d c3 36 d3			jp .chk_fault 
d320			.chk_fault4:  
d320 2a 09 e8			ld hl, (chk_data_ovr) 
d323 ed 5b 80 e2		ld de,(chk_word) 
d327				if DEBUG_STK_FAULT 
d327					DMARK "FA3" 
d327					CALLMONITOR 
d327				endif 
d327 cd 58 8a			call cmp16 
d32a ca 33 d3			jp z, .chk_fault5 
d32d 11 d8 d3			ld de, sfaultdo 
d330 c3 36 d3			jp .chk_fault 
