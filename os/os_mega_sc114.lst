# End of macro CWHEAD
a49d			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a49d			; | | At start the current various registers will be displayed with contents. 
a49d			; | | Top right corner will show the most recent debug marker seen. 
a49d			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a49d			; | | and the return stack pointer (RSP). 
a49d			; | | Pressing: 
a49d			; | |  
a49d			; | |    1 - Initial screen 
a49d			; | |  
a49d			; | |    2 - Display a data dump of HL 
a49d			; | |  
a49d			; | |    3 - Display a data dump of DE 
a49d			; | |  
a49d			; | |    4 - Display a data dump of BC 
a49d			; | |  
a49d			; | |    5 - Display a data dump of HL 
a49d			; | |  
a49d			; | |    6 - Display a data dump of DSP 
a49d			; | |  
a49d			; | |    7 - Display a data dump of RSP 
a49d			; | |  
a49d			; | |    8 - Display a data dump of what is at DSP 
a49d			; | |  
a49d			; | |    9 - Display a data dump of what is at RSP 
a49d			; | |  
a49d			; | |    0 - Exit monitor and continue running. This will also enable break points 
a49d			; | |  
a49d			; | |    * - Disable break points 
a49d			; | |  
a49d			; | |    # - Enter traditional monitor mode 
a49d			; | |  
a49d			; | | 
a49d			; | | Monitor Mode 
a49d			; | | ------------ 
a49d			; | | A prompt of '>' will be shown for various commands: 
a49d			; | |  
a49d			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a49d			; | |  
a49d			; | |    C - Continue display a data dump from the last set address 
a49d			; | |  
a49d			; | |    M xxxx - Set start of memory edit at address xx 
a49d			; | |  
a49d			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a49d			; | |  
a49d			; | |    G xxxx - Exec code at specific address 
a49d			; | |  
a49d			; | |    Q - Return to previous 
a49d				if DEBUG_FORTH_WORDS_KEY 
a49d					DMARK "MON" 
a49d				if DEMARK_VERSION = 1  
a49d e5					push hl  
a49e 21 a6 a4				ld hl, .dmark  
a4a1 22 60 ee				ld (debug_mark), hl  
a4a4				endif  
a4a4				if DEMARK_VERSION = 0  
a4a4					push af  
a4a4					ld a, (.dmark)  
a4a4					ld (debug_mark),a  
a4a4					ld a, (.dmark+1)  
a4a4					ld (debug_mark+1),a  
a4a4					ld a, (.dmark+2)  
a4a4					ld (debug_mark+2),a  
a4a4				endif  
a4a4 18 04			jr .pastdmark  
a4a6 ..			.dmark: db "MON"  
a4a9				if DEMARK_VERSION = 1  
a4a9 00					db 0  
a4aa				endif  
a4aa				if DEMARK_VERSION = 1  
a4aa e1			.pastdmark: pop hl  
a4ab				endif  
a4ab				if DEMARK_VERSION = 0  
a4ab			.pastdmark: pop af  
a4ab				endif  
a4ab			endm  
# End of macro DMARK
a4ab					CALLMONITOR 
a4ab				if BASE_CPM=1  
a4ab					call debug_vector  
a4ab				endif  
a4ab				if BASE_KEV=1  
a4ab					rst 8  
a4ab				endif  
a4ab				endm  
# End of macro CALLMONITOR
a4ab				endif 
a4ab			;		ld a, 0 
