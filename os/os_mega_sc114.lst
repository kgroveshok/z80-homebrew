d558 e1				pop hl 
d559 e5				push hl 
d55a				 
d55a 5e				ld e,(hl) 
d55b 23				inc hl 
d55c 56				ld d,(hl) 
d55d eb				ex de,hl 
d55e			 
d55e e5				push hl 
d55f			 
d55f 3e 00			ld a, 0 
d561				;ld a, FORTH_END_BUFFER 
