89c7			;    ld a,l 
89c7			;    ld l,h 
89c7			;    ld h,d 
89c7			;    or a 
89c7			;    ld b,8 
89c7			;Sqr16_Loop: 
89c7			;    sbc hl,de 
89c7			;    jr nc,Sqr16_Skip 
89c7			;    add hl,de 
89c7			;Sqr16_Skip: 
89c7			;    ccf 
89c7			;    rl d 
89c7			;    add a,a 
89c7			;    adc hl,hl 
89c7			;    add a,a 
89c7			;    adc hl,hl 
89c7			;    djnz Sqr16_Loop 
89c7			;    ret 
89c7			; 
89c7			; 
89c7			; Divide 8-bit values 
89c7			; In: Divide E by divider C 
89c7			; Out: A = result, B = rest 
89c7			; 
89c7			Div8: 
89c7 af			    xor a 
89c8 06 08		    ld b,8 
89ca			Div8_Loop: 
89ca cb 13		    rl e 
89cc 17			    rla 
89cd 91			    sub c 
89ce 30 01		    jr nc,Div8_NoAdd 
89d0 81			    add a,c 
89d1			Div8_NoAdd: 
89d1 10 f7		    djnz Div8_Loop 
89d3 47			    ld b,a 
89d4 7b			    ld a,e 
89d5 17			    rla 
89d6 2f			    cpl 
89d7 c9			    ret 
