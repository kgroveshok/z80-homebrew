a7d7					ld (debug_mark+1),a  
a7d7					ld a, (.dmark+2)  
a7d7					ld (debug_mark+2),a  
a7d7				endif  
a7d7 18 04			jr .pastdmark  
a7d9 ..			.dmark: db "SCR"  
