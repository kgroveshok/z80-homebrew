8ec5			 
8ec5			; 
8ec5			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8ec5			; Since the routines get_byte and therefore get_nibble are called, only valid 
8ec5			; characters (0-9a-f) are accepted. 
8ec5			; 
8ec5			;get_word        push    af 
8ec5			;                call    get_byte        ; Get the upper byte 
8ec5			;                ld      h, a 
8ec5			;                call    get_byte        ; Get the lower byte 
8ec5			;                ld      l, a 
8ec5			;                pop     af 
8ec5			;                ret 
8ec5			; 
8ec5			; Get a byte in hexadecimal notation. The result is returned in A. Since 
8ec5			; the routine get_nibble is used only valid characters are accepted - the  
8ec5			; input routine only accepts characters 0-9a-f. 
8ec5			; 
8ec5 c5			get_byte:        push    bc              ; Save contents of B (and C) 
8ec6 7e					ld a,(hl) 
8ec7 23					inc hl 
8ec8 cd ed 8e		                call    nibble2val      ; Get upper nibble 
8ecb cb 07		                rlc     a 
8ecd cb 07		                rlc     a 
8ecf cb 07		                rlc     a 
8ed1 cb 07		                rlc     a 
8ed3 47			                ld      b, a            ; Save upper four bits 
8ed4 7e					ld a,(hl) 
8ed5 cd ed 8e		                call    nibble2val      ; Get lower nibble 
8ed8 b0			                or      b               ; Combine both nibbles 
