1053			; Decimal Unsigned Version 
1053			 
1053			;Number in a to decimal ASCII 
1053			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
1053			;Example: display a=56 as "056" 
1053			;input: a = number 
1053			;Output: a=0,value of a in the screen 
1053			;destroys af,bc (don't know about hl and de) 
1053			DispAToASCII: 
1053 0e 9c			ld	c,-100 
1055 cd 5f 10			call	.Na1 
1058 0e f6			ld	c,-10 
105a cd 5f 10			call	.Na1 
105d 0e ff			ld	c,-1 
105f 06 2f		.Na1:	ld	b,'0'-1 
1061 04			.Na2:	inc	b 
1062 81				add	a,c 
1063 38 fc			jr	c,.Na2 
1065 91				sub	c		;works as add 100/10/1 
1066 f5				push af		;safer than ld c,a 
1067 78				ld	a,b		;char is in b 
1068			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
1068 f1				pop af		;safer than ld a,c 
1069 c9				ret 
106a			 
106a			; Decimal Signed Version 
106a			 
106a			; DispA 
106a			; -------------------------------------------------------------- 
106a			; Converts a signed integer value to a zero-terminated ASCII 
106a			; string representative of that value (using radix 10). 
106a			; -------------------------------------------------------------- 
106a			; INPUTS: 
106a			;     HL     Value to convert (two's complement integer). 
106a			;     DE     Base address of string destination. (pointer). 
106a			; -------------------------------------------------------------- 
106a			; OUTPUTS: 
106a			;     None 
106a			; -------------------------------------------------------------- 
106a			; REGISTERS/MEMORY DESTROYED 
106a			; AF HL 
106a			; -------------------------------------------------------------- 
106a			 
106a			;DispHLToASCII: 
106a			;   push    de 
106a			;   push    bc 
106a			; 
106a			;; Detect sign of HL. 
106a			;    bit    7, h 
106a			;    jr     z, ._DoConvert 
106a			; 
106a			;; HL is negative. Output '-' to string and negate HL. 
106a			;    ld     a, '-' 
106a			;    ld     (de), a 
106a			;    inc    de 
106a			; 
106a			;; Negate HL (using two's complement) 
106a			;    xor    a 
106a			;    sub    l 
106a			;    ld     l, a 
106a			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
106a			;    sbc    a, h 
106a			;    ld     h, a 
106a			; 
106a			;; Convert HL to digit characters 
106a			;._DoConvert: 
106a			;    ld     b, 0     ; B will count character length of number 
106a			;-   ld     a, 10 
106a			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
106a			;    push   af 
106a			;    inc    b 
106a			;    ld     a, h 
106a			;    or     l 
106a			;    jr     nz, - 
106a			; 
106a			;; Retrieve digits from stack 
106a			;-   pop    af 
106a			;    or     $30 
106a			;    ld     (de), a 
106a			;    inc    de 
106a			;    djnz   - 
106a			; 
106a			;; Terminate string with NULL 
106a			;    xor    a 
106a			;    ld     (de), a 
106a			; 
106a			;    pop    bc 
106a			;    pop    de 
106a			;    ret 
106a			 
106a			;Comments 
106a			; 
106a			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
106a			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
106a			;    Note that the output string will not be fixed-width. 
106a			; 
106a			;Example Usage 
106a			; 
106a			;    ld    hl, -1004 
106a			;    ld    de, OP1 
106a			;    call  DispA 
106a			;    ld    hl, OP1 
106a			;    syscall  PutS 
106a			 
106a			 
106a			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
106a			 
106a			 
106a			;Converts an ASCII string to an unsigned 16-bit integer 
106a			;Quits when it reaches a non-decimal digit 
106a			 
106a			string_to_uint16: 
106a			atoui_16: 
106a			;Input: 
106a			;     DE points to the string 
106a			;Outputs: 
106a			;     HL is the result 
106a			;     A is the 8-bit value of the number 
106a			;     DE points to the byte after the number 
106a			;Destroys: 
106a			;     BC 
106a			;       if the string is non-empty, BC is HL/10 
106a			;Size:  24 bytes 
106a			;Speed: 42+d(104+{0,9}) 
106a			;       d is the number of digits in the number 
106a			;       max is 640 cycles for a 5 digit number 
106a			;Assuming no leading zeros: 
106a			;1 digit:  146cc 
106a			;2 digit:  250cc 
106a			;3 digit:  354cc or 363cc (avg: 354.126cc) 
106a			;4 digit:  458cc or 467cc (avg: 458.27cc) 
106a			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
106a			;avg: 544.81158447265625cc (544+13297/16384) 
106a			;=============================================================== 
106a 21 00 00		  ld hl,0 
106d			.u16a: 
106d 1a			  ld a,(de) 
106e d6 30		  sub 30h 
1070 fe 0a		  cp 10 
1072 d0			  ret nc 
1073 13			  inc de 
1074 44			  ld b,h 
1075 4d			  ld c,l 
1076 29			  add hl,hl 
1077 29			  add hl,hl 
1078 09			  add hl,bc 
1079 29			  add hl,hl 
107a 85			  add a,l 
107b 6f			  ld l,a 
107c 30 ef		  jr nc,.u16a 
107e 24			  inc h 
107f c3 6d 10		  jp .u16a 
1082			 
1082			 
1082			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1082			 
1082			;written by Zeda 
1082			;Converts a 16-bit unsigned integer to an ASCII string. 
1082			 
1082			uitoa_16: 
1082			;Input: 
1082			;   DE is the number to convert 
1082			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1082			;Output: 
1082			;   HL points to the null-terminated ASCII string 
1082			;      NOTE: This isn't necessarily the same as the input HL. 
1082 d5			  push de 
1083 c5			  push bc 
1084 f5			  push af 
1085 eb			  ex de,hl 
1086			 
1086 01 f0 d8		  ld bc,-10000 
1089 3e 2f		  ld a,'0'-1 
108b 3c			  inc a 
108c 09			  add hl,bc  
108d 38 fc		   jr c,$-2 
108f 12			  ld (de),a 
1090 13			  inc de 
1091			 
1091 01 e8 03		  ld bc,1000 
1094 3e 3a		  ld a,'9'+1 
1096 3d			  dec a  
1097 09			  add hl,bc  
1098 30 fc		   jr nc,$-2 
109a 12			  ld (de),a 
109b 13			  inc de 
109c			 
109c 01 9c ff		  ld bc,-100 
109f 3e 2f		  ld a,'0'-1 
10a1 3c			  inc a  
10a2 09			  add hl,bc  
10a3 38 fc		   jr c,$-2 
10a5 12			  ld (de),a 
10a6 13			  inc de 
10a7			 
10a7 7d			  ld a,l 
10a8 26 3a		  ld h,'9'+1 
10aa 25			  dec h  
10ab c6 0a		  add a,10  
10ad 30 fb		   jr nc,$-3 
10af c6 30		  add a,'0' 
10b1 eb			  ex de,hl 
10b2 72			  ld (hl),d 
10b3 23			  inc hl 
10b4 77			  ld (hl),a 
10b5 23			  inc hl 
10b6 36 00		  ld (hl),0 
10b8			 
10b8			;Now strip the leading zeros 
10b8 0e fa		  ld c,-6 
10ba 09			  add hl,bc 
10bb 3e 30		  ld a,'0' 
10bd 23			  inc hl  
10be be			  cp (hl)  
10bf 28 fc		  jr z,$-2 
10c1			 
10c1			;Make sure that the string is non-empty! 
10c1 7e			  ld a,(hl) 
10c2 b7			  or a 
10c3 20 01		  jr nz,.atoub 
10c5 2b			  dec hl 
10c6			.atoub: 
10c6			 
10c6 f1			  pop af 
10c7 c1			  pop bc 
10c8 d1			  pop de 
10c9 c9			  ret 
10ca			 
10ca			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
10ca			 
10ca			toUpper: 
10ca			;A is the char. 
10ca			;If A is a lowercase letter, this sets it to the matching uppercase 
10ca			;18cc or 30cc or 41cc 
10ca			;avg: 26.75cc 
10ca fe 61		  cp 'a' 
10cc d8			  ret c 
10cd fe 7b		  cp 'z'+1 
10cf d0			  ret nc 
10d0 d6 20		  sub 'a'-'A' 
10d2 c9			  ret 
10d3			 
10d3			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
10d3			 
10d3			; String Length 
10d3			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
10d3			 
10d3			; Get the length of the null-terminated string starting at $8000 hl 
10d3			;    LD     HL, $8000 
10d3			 
10d3			strlenz: 
10d3			 
10d3 af			    XOR    A               ; Zero is the value we are looking for. 
10d4 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
10d5 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
10d6			                           ; 65, 536 bytes (the entire addressable memory space). 
10d6 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10d8			 
10d8			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10d8 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
10d9 6f			    LD     L, A             ; number of bytes 
10da ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10dc 2b			    DEC    HL              ; Compensate for null. 
10dd c9				ret 
10de			 
10de			; Get the length of the A terminated string starting at $8000 hl 
10de			;    LD     HL, $8000 
10de			 
10de			strlent: 
10de			 
10de			                  ; A is the value we are looking for. 
10de 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
10e0 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
10e2			                           ; 65, 536 bytes (the entire addressable memory space). 
10e2 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
10e4			 
10e4			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
10e4 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
10e6 2e 00		    LD     L, 0             ; number of bytes 
10e8 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
10ea 2b			    DEC    HL              ; Compensate for null. 
10eb c9				ret 
