65f0			; stack over and underflow checks 
65f0			 
65f0			; init the words to detect the under/overflow 
65f0			 
65f0			chk_stk_init: 
65f0				; a vague random number to check so we dont get any "lucky" hits 
65f0 3e 2d			ld a, 45 
65f2 6f				ld l, a 
65f3 00				nop 
65f4 3e 17			ld a, 23 
65f6 67				ld h, a 
65f7			 
65f7 22 b9 f0			ld (chk_word), hl     ; the word we need to check against 
65fa			 
65fa			;	ld (chk_stund), hl	; stack points.... 
65fa 22 3b fe			ld (chk_stovr), hl 
65fd 22 08 f9			ld (chk_ret_und), hl 
6600 22 c6 f8			ld (chk_ret_ovr), hl 
6603 22 44 f8			ld (chk_loop_ovr), hl 
6606 22 42 f6			ld (chk_data_ovr), hl 
6609 c9				ret 
660a				 
660a			check_stacks: 
660a				; check all stack words 
660a			 
660a e5				push hl 
660b d5				push de 
660c			 
660c			;	ld de,(chk_word) 
660c			;	ld hl, (chk_stund)	; stack points.... 
660c			;	if DEBUG_STK_FAULT 
660c			;		DMARK "FAa" 
660c			;		CALLMONITOR 
660c			;	endif 
660c			;	call cmp16 
660c			;	jp z, .chk_faulta 
660c			; 
660c			;	ld de, sfaultsu 
660c			;	jp .chk_fault 
660c			 
660c 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
660f ed 5b b9 f0		ld de,(chk_word) 
6613				if DEBUG_STK_FAULT 
6613					DMARK "FAb" 
6613					CALLMONITOR 
6613				endif 
6613 cd 99 0d			call cmp16 
6616 28 06			jr z, .chk_fault1 
6618 11 bd 66			ld de, sfaultso 
661b c3 6d 66			jp .chk_fault 
661e			.chk_fault1:  
661e 2a 08 f9			ld hl, (chk_ret_und) 
6621 ed 5b b9 f0		ld de,(chk_word) 
6625				if DEBUG_STK_FAULT 
6625					DMARK "FAU" 
6625					CALLMONITOR 
6625				endif 
6625 cd 99 0d			call cmp16 
6628 ca 31 66			jp z, .chk_fault2 
662b 11 cd 66			ld de, sfaultru 
662e c3 6d 66			jp .chk_fault 
6631			.chk_fault2:  
6631 2a c6 f8			ld hl, (chk_ret_ovr) 
6634 ed 5b b9 f0		ld de,(chk_word) 
6638				if DEBUG_STK_FAULT 
6638					DMARK "FA1" 
6638					CALLMONITOR 
6638				endif 
6638 cd 99 0d			call cmp16 
663b ca 44 66			jp z, .chk_fault3 
663e 11 db 66			ld de, sfaultro 
6641 c3 6d 66			jp .chk_fault 
6644			.chk_fault3:  
6644 2a 44 f8			ld hl, (chk_loop_ovr) 
6647 ed 5b b9 f0		ld de,(chk_word) 
664b				if DEBUG_STK_FAULT 
664b					DMARK "FA2" 
664b					CALLMONITOR 
664b				endif 
664b cd 99 0d			call cmp16 
664e ca 57 66			jp z, .chk_fault4 
6651 11 f5 66			ld de, sfaultlo 
6654 c3 6d 66			jp .chk_fault 
