cc12			 
cc12			 
cc12			.SESEL: 
cc12				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
cc12			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
cc12			; | | Zero is disabled storage. 
cc12					if DEBUG_FORTH_WORDS_KEY 
cc12						DMARK "BN?" 
cc12						CALLMONITOR 
cc12					endif 
cc12					ld a, (spi_device_id) 
cc12					sub '0' 
cc12					ld h, 0 
cc12					ld l, a 
cc12					call forth_push_numhl 
cc12					NEXTW 
cc12			.SESELS: 
cc12				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
cc12			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
cc12			; | | Set to zero to disable storage. 
cc12					if DEBUG_FORTH_WORDS_KEY 
cc12						DMARK "BNK" 
cc12						CALLMONITOR 
cc12					endif 
cc12			 
cc12					ld a, 255 
cc12					ld (spi_cartdev), a 
cc12			 
cc12					; get bank 
cc12			 
cc12					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cc12			 
cc12			;		push hl 
cc12			 
cc12					; destroy value TOS 
cc12			 
cc12					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cc12			 
cc12					; one value on hl get other one back 
cc12			 
cc12			;		pop hl 
cc12			 
cc12			 
cc12					ld c, SPI_CE_HIGH 
cc12					ld b, '0'    ; human readable bank number 
cc12			 
cc12					ld a, l 
cc12			 
cc12					if DEBUG_FORTH_WORDS 
cc12						DMARK "BNK" 
cc12						CALLMONITOR 
cc12					endif 
cc12			 
cc12					; active low 
cc12			 
cc12			;		cp 0 
cc12					or a 
cc12					jr z, .bset 
cc12					cp 1 
cc12					jr nz, .b2 
cc12					res 0, c 
cc12					ld b, '1'    ; human readable bank number 
cc12			.b2:		cp 2 
cc12					jr nz, .b3 
cc12					res 1, c 
cc12					ld b, '2'    ; human readable bank number 
cc12			.b3:		cp 3 
cc12					jr nz, .b4 
cc12					res 2, c 
cc12					ld b, '3'    ; human readable bank number 
cc12			.b4:		cp 4 
cc12					jr nz, .b5 
cc12					res 3, c 
cc12					ld b, '4'    ; human readable bank number 
cc12			.b5:		cp 5 
cc12					jr nz, .bset 
cc12					res 4, c 
cc12					ld b, '5'    ; human readable bank number 
cc12			 
cc12			.bset: 
cc12					ld a, c 
cc12					ld (spi_device),a 
cc12					ld a, b 
cc12					ld (spi_device_id),a 
cc12					if DEBUG_FORTH_WORDS 
cc12						DMARK "BN2" 
cc12						CALLMONITOR 
cc12					endif 
cc12			 
cc12					; set default SPI clk pulse time as disabled for BANK use 
cc12			 
cc12					ld a, 0 
cc12					ld (spi_clktime), a 
cc12			 
cc12					NEXTW 
cc12			 
cc12			.CARTDEV: 
cc12				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
cc12			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
cc12			; | | Set to zero to disable devices. 
cc12					if DEBUG_FORTH_WORDS_KEY 
cc12						DMARK "CDV" 
cc12						CALLMONITOR 
cc12					endif 
cc12			 
cc12					; disable se storage bank selection 
cc12			 
cc12					ld a, SPI_CE_HIGH		; ce high 
cc12					ld (spi_device), a 
cc12			 
cc12					; get bank 
cc12			 
cc12					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
cc12			 
cc12			;		push hl 
cc12			 
cc12					; destroy value TOS 
cc12			 
cc12					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
cc12			 
cc12					; one value on hl get other one back 
cc12			 
cc12			;		pop hl 
cc12			 
cc12					; active low 
cc12			 
cc12					ld c, 255 
cc12			 
cc12					ld a, l 
cc12					if DEBUG_FORTH_WORDS 
cc12						DMARK "CDV" 
cc12						CALLMONITOR 
cc12					endif 
cc12			;		cp 0 
cc12					or a 
cc12					jr z, .cset 
cc12					cp 1 
cc12					jr nz, .c2 
cc12					res 0, c 
cc12			.c2:		cp 2 
cc12					jr nz, .c3 
