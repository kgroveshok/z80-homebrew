0dfc			; 
0dfc			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
0dfc			; Since the routines get_byte and therefore get_nibble are called, only valid 
0dfc			; characters (0-9a-f) are accepted. 
0dfc			; 
0dfc			;get_word        push    af 
0dfc			;                call    get_byte        ; Get the upper byte 
0dfc			;                ld      h, a 
0dfc			;                call    get_byte        ; Get the lower byte 
0dfc			;                ld      l, a 
0dfc			;                pop     af 
0dfc			;                ret 
0dfc			; 
0dfc			; Get a byte in hexadecimal notation. The result is returned in A. Since 
0dfc			; the routine get_nibble is used only valid characters are accepted - the  
0dfc			; input routine only accepts characters 0-9a-f. 
0dfc			; 
0dfc c5			get_byte:        push    bc              ; Save contents of B (and C) 
0dfd 7e					ld a,(hl) 
0dfe 23					inc hl 
0dff cd 24 0e		                call    nibble2val      ; Get upper nibble 
0e02 cb 07		                rlc     a 
0e04 cb 07		                rlc     a 
0e06 cb 07		                rlc     a 
0e08 cb 07		                rlc     a 
0e0a 47			                ld      b, a            ; Save upper four bits 
0e0b 7e					ld a,(hl) 
0e0c cd 24 0e		                call    nibble2val      ; Get lower nibble 
0e0f b0			                or      b               ; Combine both nibbles 
0e10 c1			                pop     bc              ; Restore B (and C) 
0e11 c9			                ret 
0e12			; 
0e12			; Get a hexadecimal digit from the serial line. This routine blocks until 
0e12			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
0e12			; to the serial line interface. The lower 4 bits of A contain the value of  
0e12			; that particular digit. 
