ba80			 
ba80			.SPIO: 
ba80			 
ba80			if STORAGE_SE 
ba80				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
ba80			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
ba80			 
ba80					call spi_ce_low 
ba80			    NEXTW 
ba80			 
ba80			.SPICEH: 
ba80				CWHEAD .SPIOb 61 "SPICEH" 6 WORD_FLAG_CODE 
ba80			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
ba80			 
ba80					call spi_ce_high 
ba80			    NEXTW 
ba80			 
ba80			 
ba80			.SPIOb: 
ba80			 
ba80				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
ba80			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
ba80			 
ba80					if DEBUG_FORTH_WORDS_KEY 
ba80						DMARK "SPo" 
ba80						CALLMONITOR 
ba80					endif 
ba80					; get port 
ba80			 
ba80			 
ba80					; get byte to send 
ba80			 
ba80					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
ba80			 
ba80			;		push hl    ; u1  
ba80			 
ba80					; destroy value TOS 
ba80			 
ba80					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
ba80			 
ba80					; one value on hl get other one back 
ba80			 
ba80			;		pop hl   ; u2 - addr 
ba80			 
ba80					; TODO Send SPI byte 
ba80			 
ba80			;		push hl 
ba80			;		call spi_ce_low 
ba80			;		pop hl 
ba80					ld a, l 
ba80					call spi_send_byte 
ba80			;		call spi_ce_high 
ba80			 
ba80					NEXTW 
ba80			 
ba80			.SPII: 
ba80				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
ba80			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
ba80					if DEBUG_FORTH_WORDS_KEY 
ba80						DMARK "SPi" 
ba80						CALLMONITOR 
ba80					endif 
ba80			 
ba80					; TODO Get SPI byte 
ba80			 
ba80					call spi_read_byte 
ba80			 
ba80					if DEBUG_FORTH_WORDS 
ba80						DMARK "Si2" 
ba80						CALLMONITOR 
ba80					endif 
ba80					ld h, 0 
ba80					ld l, a 
ba80					if DEBUG_FORTH_WORDS 
ba80						DMARK "Si3" 
ba80						CALLMONITOR 
ba80					endif 
ba80					;call forth_push_numhl 
ba80					FORTH_PUSH_VALUEHL 
ba80			 
ba80					NEXTW 
ba80			 
ba80			 
ba80			 
ba80			.SESEL: 
ba80				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
ba80			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
ba80			; | | Zero is disabled storage. 
ba80					if DEBUG_FORTH_WORDS_KEY 
ba80						DMARK "BN?" 
ba80						CALLMONITOR 
ba80					endif 
ba80					ld a, (spi_device_id) 
ba80					sub '0' 
ba80					ld h, 0 
ba80					ld l, a 
ba80					FORTH_PUSH_VALUEHL 
ba80					;call forth_push_numhl 
ba80					NEXTW 
ba80			.SESELS: 
ba80				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
ba80			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
ba80			; | | Set to zero to disable storage. 
ba80					if DEBUG_FORTH_WORDS_KEY 
ba80						DMARK "BNK" 
ba80						CALLMONITOR 
ba80					endif 
ba80			 
ba80					ld a, 255 
ba80					ld (spi_cartdev), a 
ba80			 
ba80					; get bank 
ba80			 
ba80					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
ba80			 
ba80			;		push hl 
ba80			 
ba80					; destroy value TOS 
ba80			 
ba80					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
ba80			 
ba80					; one value on hl get other one back 
ba80			 
ba80			;		pop hl 
ba80			 
ba80			 
ba80					ld c, SPI_CE_HIGH 
ba80					ld b, '0'    ; human readable bank number 
ba80			 
ba80					ld a, l 
ba80			 
ba80					if DEBUG_FORTH_WORDS 
ba80						DMARK "BNK" 
ba80						CALLMONITOR 
ba80					endif 
ba80			 
ba80					; active low 
ba80			 
ba80			;		cp 0 
ba80					or a 
ba80					jr z, .bset 
ba80					cp 1 
ba80					jr nz, .b2 
ba80					res 0, c 
ba80					ld b, '1'    ; human readable bank number 
ba80			.b2:		cp 2 
ba80					jr nz, .b3 
ba80					res 1, c 
ba80					ld b, '2'    ; human readable bank number 
ba80			.b3:		cp 3 
ba80					jr nz, .b4 
ba80					res 2, c 
ba80					ld b, '3'    ; human readable bank number 
ba80			.b4:		cp 4 
ba80					jr nz, .b5 
ba80					res 3, c 
ba80					ld b, '4'    ; human readable bank number 
ba80			.b5:		cp 5 
ba80					jr nz, .bset 
ba80					res 4, c 
ba80					ld b, '5'    ; human readable bank number 
ba80			 
ba80			.bset: 
ba80					ld a, c 
ba80					ld (spi_device),a 
ba80					ld a, b 
ba80					ld (spi_device_id),a 
ba80					if DEBUG_FORTH_WORDS 
ba80						DMARK "BN2" 
ba80						CALLMONITOR 
ba80					endif 
ba80			 
ba80					; set default SPI clk pulse time as disabled for BANK use 
ba80			 
ba80					ld a, 0 
ba80					ld (spi_clktime), a 
ba80			 
ba80					NEXTW 
ba80			 
ba80			.CARTDEV: 
ba80				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
ba80			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
ba80			; | | Set to zero to disable devices. 
ba80					if DEBUG_FORTH_WORDS_KEY 
ba80						DMARK "CDV" 
ba80						CALLMONITOR 
ba80					endif 
ba80			 
ba80					; disable se storage bank selection 
ba80			 
ba80					ld a, SPI_CE_HIGH		; ce high 
ba80					ld (spi_device), a 
ba80			 
ba80					; get bank 
ba80			 
ba80					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
ba80			 
ba80			;		push hl 
ba80			 
ba80					; destroy value TOS 
ba80			 
ba80					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
ba80			 
ba80					; one value on hl get other one back 
ba80			 
ba80			;		pop hl 
ba80			 
ba80					; active low 
ba80			 
ba80					ld c, 255 
ba80			 
ba80					ld a, l 
ba80					if DEBUG_FORTH_WORDS 
ba80						DMARK "CDV" 
ba80						CALLMONITOR 
ba80					endif 
ba80			;		cp 0 
ba80					or a 
ba80					jr z, .cset 
ba80					cp 1 
ba80					jr nz, .c2 
ba80					res 0, c 
ba80			.c2:		cp 2 
ba80					jr nz, .c3 
ba80					res 1, c 
ba80			.c3:		cp 3 
ba80					jr nz, .c4 
ba80					res 2, c 
ba80			.c4:		cp 4 
ba80					jr nz, .c5 
ba80					res 3, c 
ba80			.c5:		cp 5 
ba80					jr nz, .c6 
ba80					res 4, c 
ba80			.c6:		cp 6 
ba80					jr nz, .c7 
ba80					res 5, c 
ba80			.c7:		cp 7 
ba80					jr nz, .c8 
ba80					res 6, c 
ba80			.c8:		cp 8 
ba80					jr nz, .cset 
ba80					res 7, c 
ba80			.cset:		ld a, c 
ba80					ld (spi_cartdev),a 
ba80			 
ba80					if DEBUG_FORTH_WORDS 
ba80						DMARK "CD2" 
ba80						CALLMONITOR 
ba80					endif 
ba80			 
ba80					; set default SPI clk pulse time as 10ms for CARTDEV use 
ba80			 
ba80					ld a, $0a 
