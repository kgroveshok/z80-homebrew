929e			config_fdir: 
929e				; using the scratch dir go through and release the memory allocated for each string 
929e				 
929e				ld hl, scratch 
929e			.cfdir:	ld e,(hl) 
929e				inc hl 
929e				ld d,(hl) 
929e				inc hl 
929e			 
929e				ex de, hl 
929e				call ishlzero 
929e				ret z     ; return on null pointer 
929e				call free 
929e				ex de, hl 
929e				jr .cfdir 
929e			 
929e			 
929e				ret 
929e			 
929e			 
929e			config_dir: 
929e			 
929e				; for the config menus that need to build a directory of storage call this routine 
929e				; it will construct a menu in scratch to pass to menu 
929e			 
929e				; open storage device 
929e			 
929e				; execute DIR to build a list of files and their ids into scratch in menu format 
929e				; once the menu has finished then will need to call config_fdir to release the strings 
929e				 
929e				; c = number items 
929e			 
929e				 
929e				call storage_get_block_0 
929e			 
929e				ld hl, store_page     ; get current id count 
929e				ld b, (hl) 
929e				ld c, 0    ; count of files   
929e			 
929e			 
929e				ld hl, scratch 
929e				ld (store_tmp2), hl    ; location to poke strings 
929e			 
929e				; check for empty drive 
929e			 
929e				ld a, 0 
929e				cp b 
929e				jp z, .dirdone 
929e			 
929e				 
929e					if DEBUG_FORTH_WORDS 
929e						DMARK "Cdc" 
929e						CALLMONITOR 
929e					endif 
929e			 
929e			 
929e			.diritem:	 
929e				push bc 
929e				; for each of the current ids do a search for them and if found push to stack 
929e			 
929e					ld hl, STORE_BLOCK_PHY 
929e					ld d, 0		 ; look for extent 0 of block id as this contains file name 
929e					ld e,b 
929e			 
929e					call storage_findnextid 
929e			 
929e			 
929e					; if found hl will be non zero 
929e			 
929e					call ishlzero 
929e					jr z, .dirnotfound 
929e			 
929e					; increase count 
929e			 
929e					pop bc	 
929e					inc c 
929e					push bc 
929e					 
929e			 
929e					; get file header and push the file name 
929e			 
929e					ld de, store_page 
929e					call storage_read_block 
929e			 
929e					; push file id to stack 
929e				 
929e					ld a, (store_page) 
929e					ld h, 0 
929e					ld l, a 
929e			 
929e					;call forth_push_numhl 
929e					; TODO store id 
929e			 
929e					push hl 
929e			 
929e					; push extent count to stack  
929e				 
929e					ld hl, store_page+3 
929e			 
929e					; get file name length 
929e			 
929e					call strlenz   
929e			 
929e					inc hl   ; cover zero term 
929e					inc hl  ; stick the id at the end of the area 
929e			 
929e					push hl 
929e					pop bc    ; move length to bc 
929e			 
929e					call malloc 
929e			 
929e					; TODO save malloc area to scratch 
929e			 
929e					ex de, hl 
929e					ld hl, (store_tmp2) 
929e					ld (hl), e 
929e					inc hl 
929e					ld (hl), d 
929e					inc hl 
929e					ld (store_tmp2), hl 
929e			 
929e					 
929e			 
929e					;pop hl   ; get source 
929e			;		ex de, hl    ; swap aronund	 
929e			 
929e					ld hl, store_page+3 
929e					if DEBUG_FORTH_WORDS 
929e						DMARK "CFd" 
929e						CALLMONITOR 
929e					endif 
929e					ldir 
929e			 
929e					; de is past string, move back one and store id 
929e					 
929e					dec de 
929e			 
929e					; store file id 
929e			 
929e					pop hl 
929e					ex de,hl 
929e					ld (hl), e 
929e			 
929e					if DEBUG_FORTH_WORDS 
929e						DMARK "Cdi" 
929e						CALLMONITOR 
929e					endif 
929e					 
929e			.dirnotfound: 
929e					pop bc     
929e					djnz .diritem 
929e				 
929e			.dirdone:	 
929e			 
929e			;		ld a, 0 
929e					ld hl, (store_tmp2) 
929e					ld (hl), 0 
929e					inc hl 
929e					ld (hl), 0 
929e					inc hl 
929e					; push a count of the dir items found 
929e			 
929e			;		ld h, 0 
929e			;		ld l, c 
929e			 
929e				ret 
929e			 
929e			endif 
