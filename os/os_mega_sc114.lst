8d29			 
8d29			;Converts an ASCII string to an unsigned 16-bit integer 
8d29			;Quits when it reaches a non-decimal digit 
8d29			 
8d29			string_to_uint16: 
8d29			atoui_16: 
8d29			;Input: 
8d29			;     DE points to the string 
8d29			;Outputs: 
8d29			;     HL is the result 
8d29			;     A is the 8-bit value of the number 
8d29			;     DE points to the byte after the number 
8d29			;Destroys: 
8d29			;     BC 
8d29			;       if the string is non-empty, BC is HL/10 
8d29			;Size:  24 bytes 
8d29			;Speed: 42+d(104+{0,9}) 
8d29			;       d is the number of digits in the number 
8d29			;       max is 640 cycles for a 5 digit number 
8d29			;Assuming no leading zeros: 
8d29			;1 digit:  146cc 
8d29			;2 digit:  250cc 
8d29			;3 digit:  354cc or 363cc (avg: 354.126cc) 
8d29			;4 digit:  458cc or 467cc (avg: 458.27cc) 
8d29			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
8d29			;avg: 544.81158447265625cc (544+13297/16384) 
8d29			;=============================================================== 
8d29 21 00 00		  ld hl,0 
8d2c			.u16a: 
8d2c 1a			  ld a,(de) 
8d2d d6 30		  sub 30h 
8d2f fe 0a		  cp 10 
8d31 d0			  ret nc 
8d32 13			  inc de 
8d33 44			  ld b,h 
8d34 4d			  ld c,l 
8d35 29			  add hl,hl 
8d36 29			  add hl,hl 
8d37 09			  add hl,bc 
8d38 29			  add hl,hl 
8d39 85			  add a,l 
8d3a 6f			  ld l,a 
8d3b 30 ef		  jr nc,.u16a 
8d3d 24			  inc h 
8d3e c3 2c 8d		  jp .u16a 
