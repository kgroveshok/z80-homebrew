1055			; Decimal Unsigned Version 
1055			 
1055			;Number in a to decimal ASCII 
1055			;adapted from 16 bit found in z80 Bits to 8 bit by Galandros 
1055			;Example: display a=56 as "056" 
1055			;input: a = number 
1055			;Output: a=0,value of a in the screen 
1055			;destroys af,bc (don't know about hl and de) 
1055			DispAToASCII: 
1055 0e 9c			ld	c,-100 
1057 cd 61 10			call	.Na1 
105a 0e f6			ld	c,-10 
105c cd 61 10			call	.Na1 
105f 0e ff			ld	c,-1 
1061 06 2f		.Na1:	ld	b,'0'-1 
1063 04			.Na2:	inc	b 
1064 81				add	a,c 
1065 38 fc			jr	c,.Na2 
1067 91				sub	c		;works as add 100/10/1 
1068 f5				push af		;safer than ld c,a 
1069 78				ld	a,b		;char is in b 
106a			;TODO	CALL	PUTCHAR	;plot a char. Replace with bcall(_PutC) or similar. 
106a f1				pop af		;safer than ld a,c 
106b c9				ret 
106c			 
106c			; Decimal Signed Version 
106c			 
106c			; DispA 
106c			; -------------------------------------------------------------- 
106c			; Converts a signed integer value to a zero-terminated ASCII 
106c			; string representative of that value (using radix 10). 
106c			; -------------------------------------------------------------- 
106c			; INPUTS: 
106c			;     HL     Value to convert (two's complement integer). 
106c			;     DE     Base address of string destination. (pointer). 
106c			; -------------------------------------------------------------- 
106c			; OUTPUTS: 
106c			;     None 
106c			; -------------------------------------------------------------- 
106c			; REGISTERS/MEMORY DESTROYED 
106c			; AF HL 
106c			; -------------------------------------------------------------- 
106c			 
106c			;DispHLToASCII: 
106c			;   push    de 
106c			;   push    bc 
106c			; 
106c			;; Detect sign of HL. 
106c			;    bit    7, h 
106c			;    jr     z, ._DoConvert 
106c			; 
106c			;; HL is negative. Output '-' to string and negate HL. 
106c			;    ld     a, '-' 
106c			;    ld     (de), a 
106c			;    inc    de 
106c			; 
106c			;; Negate HL (using two's complement) 
106c			;    xor    a 
106c			;    sub    l 
106c			;    ld     l, a 
106c			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
106c			;    sbc    a, h 
106c			;    ld     h, a 
106c			; 
106c			;; Convert HL to digit characters 
106c			;._DoConvert: 
106c			;    ld     b, 0     ; B will count character length of number 
106c			;-   ld     a, 10 
106c			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
106c			;    push   af 
106c			;    inc    b 
106c			;    ld     a, h 
106c			;    or     l 
106c			;    jr     nz, - 
106c			; 
106c			;; Retrieve digits from stack 
106c			;-   pop    af 
106c			;    or     $30 
106c			;    ld     (de), a 
106c			;    inc    de 
106c			;    djnz   - 
106c			; 
106c			;; Terminate string with NULL 
106c			;    xor    a 
106c			;    ld     (de), a 
106c			; 
106c			;    pop    bc 
106c			;    pop    de 
106c			;    ret 
106c			 
106c			;Comments 
106c			; 
106c			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
106c			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
106c			;    Note that the output string will not be fixed-width. 
106c			; 
106c			;Example Usage 
106c			; 
106c			;    ld    hl, -1004 
106c			;    ld    de, OP1 
106c			;    call  DispA 
106c			;    ld    hl, OP1 
106c			;    syscall  PutS 
106c			 
106c			 
106c			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
106c			 
106c			 
106c			;Converts an ASCII string to an unsigned 16-bit integer 
106c			;Quits when it reaches a non-decimal digit 
106c			 
106c			string_to_uint16: 
106c			atoui_16: 
106c			;Input: 
106c			;     DE points to the string 
106c			;Outputs: 
106c			;     HL is the result 
106c			;     A is the 8-bit value of the number 
106c			;     DE points to the byte after the number 
106c			;Destroys: 
106c			;     BC 
106c			;       if the string is non-empty, BC is HL/10 
106c			;Size:  24 bytes 
106c			;Speed: 42+d(104+{0,9}) 
106c			;       d is the number of digits in the number 
106c			;       max is 640 cycles for a 5 digit number 
106c			;Assuming no leading zeros: 
106c			;1 digit:  146cc 
106c			;2 digit:  250cc 
106c			;3 digit:  354cc or 363cc (avg: 354.126cc) 
106c			;4 digit:  458cc or 467cc (avg: 458.27cc) 
106c			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
106c			;avg: 544.81158447265625cc (544+13297/16384) 
106c			;=============================================================== 
106c 21 00 00		  ld hl,0 
106f			.u16a: 
106f 1a			  ld a,(de) 
1070 d6 30		  sub 30h 
1072 fe 0a		  cp 10 
1074 d0			  ret nc 
1075 13			  inc de 
1076 44			  ld b,h 
1077 4d			  ld c,l 
1078 29			  add hl,hl 
1079 29			  add hl,hl 
107a 09			  add hl,bc 
107b 29			  add hl,hl 
107c 85			  add a,l 
107d 6f			  ld l,a 
107e 30 ef		  jr nc,.u16a 
1080 24			  inc h 
1081 c3 6f 10		  jp .u16a 
1084			 
1084			 
1084			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1084			 
1084			;written by Zeda 
1084			;Converts a 16-bit unsigned integer to an ASCII string. 
1084			 
1084			uitoa_16: 
1084			;Input: 
1084			;   DE is the number to convert 
1084			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1084			;Output: 
1084			;   HL points to the null-terminated ASCII string 
1084			;      NOTE: This isn't necessarily the same as the input HL. 
1084 d5			  push de 
1085 c5			  push bc 
1086 f5			  push af 
1087 eb			  ex de,hl 
1088			 
1088 01 f0 d8		  ld bc,-10000 
108b 3e 2f		  ld a,'0'-1 
108d 3c			  inc a 
108e 09			  add hl,bc  
108f 38 fc		   jr c,$-2 
1091 12			  ld (de),a 
1092 13			  inc de 
1093			 
1093 01 e8 03		  ld bc,1000 
1096 3e 3a		  ld a,'9'+1 
1098 3d			  dec a  
1099 09			  add hl,bc  
109a 30 fc		   jr nc,$-2 
109c 12			  ld (de),a 
109d 13			  inc de 
109e			 
109e 01 9c ff		  ld bc,-100 
10a1 3e 2f		  ld a,'0'-1 
10a3 3c			  inc a  
10a4 09			  add hl,bc  
10a5 38 fc		   jr c,$-2 
10a7 12			  ld (de),a 
10a8 13			  inc de 
10a9			 
10a9 7d			  ld a,l 
10aa 26 3a		  ld h,'9'+1 
10ac 25			  dec h  
10ad c6 0a		  add a,10  
10af 30 fb		   jr nc,$-3 
10b1 c6 30		  add a,'0' 
10b3 eb			  ex de,hl 
10b4 72			  ld (hl),d 
10b5 23			  inc hl 
10b6 77			  ld (hl),a 
10b7 23			  inc hl 
10b8 36 00		  ld (hl),0 
10ba			 
10ba			;Now strip the leading zeros 
10ba 0e fa		  ld c,-6 
10bc 09			  add hl,bc 
10bd 3e 30		  ld a,'0' 
10bf 23			  inc hl  
10c0 be			  cp (hl)  
10c1 28 fc		  jr z,$-2 
10c3			 
10c3			;Make sure that the string is non-empty! 
10c3 7e			  ld a,(hl) 
10c4 b7			  or a 
10c5 20 01		  jr nz,.atoub 
10c7 2b			  dec hl 
10c8			.atoub: 
10c8			 
10c8 f1			  pop af 
10c9 c1			  pop bc 
10ca d1			  pop de 
10cb c9			  ret 
