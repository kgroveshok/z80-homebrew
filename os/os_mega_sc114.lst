8a03			;;This divides DE by BC, storing the result in DE, remainder in HL 
8a03			; 
8a03			;DE_Div_BC:          ;1281-2x, x is at most 16 
8a03			;     ld a,16        ;7 
8a03			;     ld hl,0        ;10 
8a03			;     jp $+5         ;10 
8a03			;.DivLoop: 
8a03			;       add hl,bc    ;-- 
8a03			;       dec a        ;64 
8a03			;       jr z,.DivLoopEnd        ;86 
8a03			; 
8a03			;       sla e        ;128 
8a03			;       rl d         ;128 
8a03			;       adc hl,hl    ;240 
8a03			;       sbc hl,bc    ;240 
8a03			;       jr nc,.DivLoop ;23|21 
8a03			;       inc e        ;-- 
8a03			;       jp .DivLoop+1 
8a03			; 
8a03			;.DivLoopEnd: 
8a03			 
8a03			;HL_Div_C: 
8a03			;Inputs: 
8a03			;     HL is the numerator 
8a03			;     C is the denominator 
8a03			;Outputs: 
8a03			;     A is the remainder 
8a03			;     B is 0 
8a03			;     C is not changed 
8a03			;     DE is not changed 
8a03			;     HL is the quotient 
8a03			; 
8a03			;       ld b,16 
8a03			;       xor a 
8a03			;         add hl,hl 
8a03			;         rla 
8a03			;         cp c 
8a03			;         jr c,$+4 
8a03			;           inc l 
8a03			;           sub c 
8a03			;         djnz $-7 
8a03			 
8a03			; https://plutiedev.com/z80-add-8bit-to-16bit 
8a03			 
8a03			addatohl: 
8a03 85			    add   a, l    ; A = A+L 
8a04 6f			    ld    l, a    ; L = A+L 
8a05 8c			    adc   a, h    ; A = A+L+H+carry 
8a06 95			    sub   l       ; A = H+carry 
8a07 67			    ld    h, a    ; H = H+carry 
8a08 c9			ret 
8a09			 
8a09			addatode: 
8a09 83			    add   a, e    ; A = A+L 
8a0a 5f			    ld    e, a    ; L = A+L 
8a0b 8a			    adc   a, d    ; A = A+L+H+carry 
8a0c 93			    sub   e       ; A = H+carry 
8a0d 57			    ld    d, a    ; H = H+carry 
8a0e c9			ret 
8a0f			 
8a0f			 
8a0f			addatobc: 
8a0f 81			    add   a, c    ; A = A+L 
8a10 4f			    ld    c, a    ; L = A+L 
8a11 88			    adc   a, b    ; A = A+L+H+carry 
8a12 91			    sub   c       ; A = H+carry 
8a13 47			    ld    b, a    ; H = H+carry 
8a14 c9			ret 
