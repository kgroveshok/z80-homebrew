651b			; stack over and underflow checks 
651b			 
651b			; init the words to detect the under/overflow 
651b			 
651b			chk_stk_init: 
651b				; a vague random number to check so we dont get any "lucky" hits 
651b 3e 2d			ld a, 45 
651d 6f				ld l, a 
651e 00				nop 
651f 3e 17			ld a, 23 
6521 67				ld h, a 
6522			 
6522 22 b9 f0			ld (chk_word), hl     ; the word we need to check against 
6525			 
6525			;	ld (chk_stund), hl	; stack points.... 
6525 22 3b fe			ld (chk_stovr), hl 
6528 22 08 f9			ld (chk_ret_und), hl 
652b 22 c6 f8			ld (chk_ret_ovr), hl 
652e 22 44 f8			ld (chk_loop_ovr), hl 
6531 22 42 f6			ld (chk_data_ovr), hl 
6534 c9				ret 
6535				 
6535			check_stacks: 
6535				; check all stack words 
6535			 
6535 e5				push hl 
6536 d5				push de 
6537			 
6537			;	ld de,(chk_word) 
6537			;	ld hl, (chk_stund)	; stack points.... 
6537			;	if DEBUG_STK_FAULT 
6537			;		DMARK "FAa" 
6537			;		CALLMONITOR 
6537			;	endif 
6537			;	call cmp16 
6537			;	jp z, .chk_faulta 
6537			; 
6537			;	ld de, sfaultsu 
6537			;	jp .chk_fault 
6537			 
6537 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
653a ed 5b b9 f0		ld de,(chk_word) 
653e				if DEBUG_STK_FAULT 
653e					DMARK "FAb" 
653e					CALLMONITOR 
653e				endif 
653e cd 99 0d			call cmp16 
6541 28 06			jr z, .chk_fault1 
6543 11 e8 65			ld de, sfaultso 
6546 c3 98 65			jp .chk_fault 
6549			.chk_fault1:  
6549 2a 08 f9			ld hl, (chk_ret_und) 
654c ed 5b b9 f0		ld de,(chk_word) 
6550				if DEBUG_STK_FAULT 
6550					DMARK "FAU" 
6550					CALLMONITOR 
6550				endif 
6550 cd 99 0d			call cmp16 
6553 ca 5c 65			jp z, .chk_fault2 
6556 11 f8 65			ld de, sfaultru 
6559 c3 98 65			jp .chk_fault 
655c			.chk_fault2:  
655c 2a c6 f8			ld hl, (chk_ret_ovr) 
655f ed 5b b9 f0		ld de,(chk_word) 
6563				if DEBUG_STK_FAULT 
6563					DMARK "FA1" 
6563					CALLMONITOR 
6563				endif 
6563 cd 99 0d			call cmp16 
6566 ca 6f 65			jp z, .chk_fault3 
6569 11 06 66			ld de, sfaultro 
656c c3 98 65			jp .chk_fault 
656f			.chk_fault3:  
656f 2a 44 f8			ld hl, (chk_loop_ovr) 
6572 ed 5b b9 f0		ld de,(chk_word) 
6576				if DEBUG_STK_FAULT 
6576					DMARK "FA2" 
6576					CALLMONITOR 
6576				endif 
6576 cd 99 0d			call cmp16 
6579 ca 82 65			jp z, .chk_fault4 
657c 11 20 66			ld de, sfaultlo 
657f c3 98 65			jp .chk_fault 
6582			.chk_fault4:  
6582 2a 42 f6			ld hl, (chk_data_ovr) 
6585 ed 5b b9 f0		ld de,(chk_word) 
6589				if DEBUG_STK_FAULT 
6589					DMARK "FA3" 
6589					CALLMONITOR 
6589				endif 
6589 cd 99 0d			call cmp16 
658c ca 95 65			jp z, .chk_fault5 
658f 11 3a 66			ld de, sfaultdo 
6592 c3 98 65			jp .chk_fault 
6595			 
6595			 
6595			.chk_fault5:  
6595 d1				pop de 
6596 e1				pop hl 
6597			 
6597 c9				ret 
