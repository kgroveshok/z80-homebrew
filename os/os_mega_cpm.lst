110f			;------------------------------------------------------------------------------ 
110f			;     heap_init                                                               : 
110f			;                                                                             : 
110f			; Description                                                                 : 
110f			;     Initialise the heap and make it ready for malloc and free operations.   : 
110f			;                                                                             : 
110f			;     The heap is maintained as a linked list, starting with an initial       : 
110f			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
110f			;     the first free block in the heap. Each block then points to the next    : 
110f			;     free block within the heap, and the free list ends at the first block   : 
110f			;     with a null pointer to the next free block.                             : 
110f			;                                                                             : 
110f			; Parameters                                                                  : 
110f			;     Inputs are compile-time only. Two defines which specify the starting    : 
110f			;     address of the heap and its size are required, along with a memory      : 
110f			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
110f			;     principally stores a pointer to the first free block in the heap.       : 
110f			;                                                                             : 
110f			; Returns                                                                     : 
110f			;     Nothing                                                                 : 
110f			;------------------------------------------------------------------------------ 
110f			heap_init: 
110f			      push  HL 
110f			 
110f			      ; Initialise free list struct 
110f			      ld    HL, heap_start 
110f			      ld    (free_list), HL 
110f			      ld    HL, 0 
110f			      ld    (free_list+2), HL 
110f			 
110f			      ; Insert first free block at bottom of heap, consumes entire heap 
110f			      ld    HL, heap_start+heap_size-4 
110f			      ld    (heap_start), HL        ; Next block (end of free list) 
110f			      ld    HL, heap_size-4 
110f			      ld    (heap_start+2), HL      ; Block size 
110f			 
110f			      ; Insert end of free list block at top of heap - two null words will 
110f			      ; terminate the free list 
110f			      ld    HL, 0 
110f			      ld    (heap_start+heap_size-2), HL 
110f			      ld    (heap_start+heap_size-4), HL 
110f			 
110f			      pop   HL 
110f			 
110f			      ret 
110f			 
110f			 
110f			;------------------------------------------------------------------------------ 
110f			;     malloc                                                                  : 
110f			;                                                                             : 
110f			; Description                                                                 : 
110f			;     Allocates the wanted space from the heap and returns the address of the : 
110f			;     first useable byte of the allocation.                                   : 
110f			;                                                                             : 
110f			;     Allocations can happen in one of two ways:                              : 
110f			;                                                                             : 
110f			;     1. A free block may be found which is the exact size wanted. In this    : 
110f			;        case the block is removed from the free list and retuedn to the      : 
110f			;        caller.                                                              : 
110f			;     2. A free block may be found which is larger than the size wanted. In   : 
110f			;        this case, the larger block is split into two. The first portion of  : 
110f			;        this block will become the requested space by the malloc call and    : 
110f			;        is returned to the caller. The second portion becomes a new free     : 
110f			;        block, and the free list is adjusted to maintain continuity via this : 
110f			;        newly created block.                                                 : 
110f			;                                                                             : 
110f			;     malloc does not set any initial value in the allocated space, the       : 
110f			;     caller is required to do this as required.                              : 
110f			;                                                                             : 
110f			;     This implementation of malloc uses the stack exclusively, and is        : 
110f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
110f			;     advisable to disable interrupts before calling malloc, and recommended  : 
110f			;     to avoid the use of malloc inside ISRs in general.                      : 
110f			;                                                                             : 
110f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
110f			;                                                                             : 
110f			; Parameters                                                                  : 
110f			;     HL  Number of bytes wanted                                              : 
110f			;                                                                             : 
110f			; Returns                                                                     : 
110f			;     HL  Address of the first useable byte of the allocation                 : 
110f			;                                                                             : 
110f			; Flags                                                                       : 
110f			;     Z   Set if the allocation did not succeed, clear otherwise              : 
110f			;                                                                             : 
110f			; Stack frame                                                                 : 
110f			;       |             |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |     BC      |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |     DE      |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |     IX      |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |  prev_free  |                                                       : 
110f			;   +4  +-------------+                                                       : 
110f			;       |  this_free  |                                                       : 
110f			;   +2  +-------------+                                                       : 
110f			;       |  next_free  |                                                       : 
110f			;   +0  +-------------+                                                       : 
110f			;       |             |                                                       : 
110f			;                                                                             : 
110f			;------------------------------------------------------------------------------ 
110f			malloc: 
110f			      push  BC 
110f			      push  DE 
110f			      push  IX 
110f			 
110f			      ld    A, H                    ; Exit if no space requested 
110f			      or    L 
110f			      jp    Z, malloc_early_exit 
110f			 
110f			      ; Set up stack frame 
110f			      ex    DE, HL 
110f			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
110f			      add   HL, SP 
110f			      ld    SP, HL 
110f			      ld    IX, 0                   ; Use IX as a frame pointer 
110f			      add   IX, SP 
110f			 
110f			      ; Setup initial state 
110f			      ld    HL, 4                   ; want must also include space used by block struct 
110f			      add   HL, DE 
110f			 
110f			      ld    B, H                    ; Move want to BC 
110f			      ld    C, L 
110f			 
110f			      ld    HL, free_list           ; Store prev_free ptr to stack 
110f			      ld    (IX+4), L 
110f			      ld    (IX+5), H 
110f			 
110f			      ld    E, (HL)                 ; Store this_free ptr to stack 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      ld    (IX+2), E 
110f			      ld    (IX+3), D 
110f			      ex    DE, HL                  ; this_free ptr into HL 
110f			 
110f			      ; Loop through free block list to find some space 
110f			malloc_find_space: 
110f			      ld    E, (HL)                 ; Load next_free ptr into DE 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			 
110f			      ld    A, D                    ; Check for null next_free ptr - end of free list 
110f			      or    E 
110f			      jp    Z, malloc_no_space 
110f			 
110f			      ld    (IX+0), E               ; Store next_free ptr to stack 
110f			      ld    (IX+1), D 
110f			 
110f			      ; Does this block have enough space to make the allocation? 
110f			      inc   HL                      ; Load free block size into DE 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			 
110f			      ex    DE, HL                  ; Check size of block against want 
110f			      or    A                       ; Ensure carry flag clear 
110f			      sbc   HL, BC 
110f			      push  HL                      ; Store the result for later (new block size) 
110f			 
110f			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
110f			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
110f			 
110f			      ; this_free block is not big enough, setup ptrs to test next free block 
110f			      pop   HL                      ; Discard previous result 
110f			 
110f			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
110f			      ld    H, (IX+3) 
110f			      ld    (IX+4), L 
110f			      ld    (IX+5), H 
110f			 
110f			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
110f			      ld    H, (IX+1) 
110f			      ld    (IX+2), L 
110f			      ld    (IX+3), H 
110f			 
110f			      jr    malloc_find_space 
110f			 
110f			      ; split a bigger block into two - requested size and remaining size 
110f			malloc_alloc_split: 
110f			      ex    DE, HL                  ; Calculate address of new free block 
110f			      dec   HL 
110f			      dec   HL 
110f			      dec   HL 
110f			      add   HL, BC 
110f			 
110f			      ; Create a new block and point it at next_free 
110f			      ld    E, (IX+0)               ; Load next_free ptr into DE 
110f			      ld    D, (IX+1) 
110f			 
110f			      ld    (HL), E                 ; Store next_free ptr into new block 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			      pop   DE                      ; Store size of new block into new block 
110f			      inc   HL 
110f			      ld    (HL), E 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			      ; Update this_free ptr to point to new block 
110f			      dec   HL 
110f			      dec   HL 
110f			      dec   HL 
110f			 
110f			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
110f			      ld    D, (IX+3) 
110f			 
110f			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
110f			      ld    (IX+3), H 
110f			 
110f			      ; Modify this_free block to be allocation 
110f			      ex    DE, HL 
110f			      xor   A                       ; Null the next block ptr of allocated block 
110f			      ld    (HL), A 
110f			      inc   HL 
110f			      ld    (HL), A 
110f			 
110f			      inc   HL                      ; Store want size into allocated block 
110f			      ld    (HL), C 
110f			      inc   HL 
110f			      ld    (HL), B 
110f			      inc   HL 
110f			      push  HL                      ; Address of allocation to return 
110f			 
110f			      jr    malloc_update_links 
110f			 
110f			malloc_alloc_fit: 
110f			      pop   HL                      ; Dont need new block size, want is exact fit 
110f			 
110f			      ; Modify this_free block to be allocation 
110f			      ex    DE, HL 
110f			      dec   HL 
110f			      dec   HL 
110f			      dec   HL 
110f			 
110f			      xor   A                       ; Null the next block ptr of allocated block 
110f			      ld    (HL), A 
110f			      inc   HL 
110f			      ld    (HL), A 
110f			 
110f			      inc   HL                      ; Store address of allocation to return 
110f			      inc   HL 
110f			      inc   HL 
110f			      push  HL 
110f			 
110f			      ; Copy next_free ptr to this_free, remove allocated block from free list 
110f			      ld    L, (IX+0)               ; next_free to HL 
110f			      ld    H, (IX+1) 
110f			 
110f			      ld    (IX+2), L               ; HL to this_free 
110f			      ld    (IX+3), H 
110f			 
110f			 
110f			malloc_update_links: 
110f			      ; Update prev_free ptr to point to this_free 
110f			      ld    L, (IX+4)               ; prev_free ptr to HL 
110f			      ld    H, (IX+5) 
110f			 
110f			      ld    E, (IX+2)               ; this_free ptr to DE 
110f			      ld    D, (IX+3) 
110f			 
110f			      ld    (HL), E                 ; this_free ptr into prev_free 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			      ; Clear the Z flag to indicate successful allocation 
110f			      ld    A, D 
110f			      or    E 
110f			 
110f			      pop   DE                      ; Address of allocation 
110f			 
110f			malloc_no_space: 
110f			      ld    HL, 6                   ; Clean up stack frame 
110f			      add   HL, SP 
110f			      ld    SP, HL 
110f			 
110f			      ex    DE, HL                  ; Alloc addr into HL for return 
110f			 
110f			malloc_early_exit: 
110f			      pop   IX 
110f			      pop   DE 
110f			      pop   BC 
110f			 
110f			      ret 
110f			 
110f			 
110f			;------------------------------------------------------------------------------ 
110f			;     free                                                                    : 
110f			;                                                                             : 
110f			; Description                                                                 : 
110f			;     Return the space pointed to by HL to the heap. HL must be an address as : 
110f			;     returned by malloc, otherwise the behaviour is undefined.               : 
110f			;                                                                             : 
110f			;     Where possible, directly adjacent free blocks will be merged together   : 
110f			;     into larger blocks to help ensure that the heap does not become         : 
110f			;     excessively fragmented.                                                 : 
110f			;                                                                             : 
110f			;     free does not clear or set any other value into the freed space, and    : 
110f			;     therefore its contents may be visible through subsequent malloc's. The  : 
110f			;     caller should clear the freed space as required.                        : 
110f			;                                                                             : 
110f			;     This implementation of free uses the stack exclusively, and is          : 
110f			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
110f			;     advisable to disable interrupts before calling free, and recommended    : 
110f			;     to avoid the use of free inside ISRs in general.                        : 
110f			;                                                                             : 
110f			;     NOTE: heap_init must be called before malloc and free can be used.      : 
110f			;                                                                             : 
110f			; Parameters                                                                  : 
110f			;     HL  Pointer to address of first byte of allocation to be freed          : 
110f			;                                                                             : 
110f			; Returns                                                                     : 
110f			;     Nothing                                                                 : 
110f			;                                                                             : 
110f			; Stack frame                                                                 : 
110f			;       |             |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |     BC      |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |     DE      |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |     IX      |                                                       : 
110f			;       +-------------+                                                       : 
110f			;       |  prev_free  |                                                       : 
110f			;   +2  +-------------+                                                       : 
110f			;       |  next_free  |                                                       : 
110f			;   +0  +-------------+                                                       : 
110f			;       |             |                                                       : 
110f			;                                                                             : 
110f			;------------------------------------------------------------------------------ 
110f			free: 
110f			      push  BC 
110f			      push  DE 
110f			      push  IX 
110f			 
110f			      ld    A, H                    ; Exit if ptr is null 
110f			      or    L 
110f			      jp    Z, free_early_exit 
110f			 
110f			      ; Set up stack frame 
110f			      ex    DE, HL 
110f			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
110f			      add   HL, SP 
110f			      ld    SP, HL 
110f			      ld    IX, 0                   ; Use IX as a frame pointer 
110f			      add   IX, SP 
110f			 
110f			      ; The address in HL points to the start of the useable allocated space, 
110f			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
110f			      ; address of the block itself. 
110f			      ex    DE, HL 
110f			      ld    DE, -4 
110f			      add   HL, DE 
110f			 
110f			      ; An allocated block must have a null next block pointer in it 
110f			      ld    A, (HL) 
110f			      inc   HL 
110f			      or    (HL) 
110f			      jp    NZ, free_done 
110f			 
110f			      dec   HL 
110f			 
110f			      ld    B, H                    ; Copy HL to BC 
110f			      ld    C, L 
110f			 
110f			      ; Loop through the free list to find the first block with an address 
110f			      ; higher than the block being freed 
110f			      ld    HL, free_list 
110f			 
110f			free_find_higher_block: 
110f			      ld    E, (HL)                 ; Load next ptr from free block 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      dec   HL 
110f			 
110f			      ld    (IX+0), E               ; Save ptr to next free block 
110f			      ld    (IX+1), D 
110f			      ld    (IX+2), L               ; Save ptr to prev free block 
110f			      ld    (IX+3), H 
110f			 
110f			      ld    A, B                    ; Check if DE is greater than BC 
110f			      cp    D                       ; Compare MSB first 
110f			      jr    Z, $+4                  ; MSB the same, compare LSB 
110f			      jr    NC, free_find_higher_block_skip 
110f			      ld    A, C 
110f			      cp    E                       ; Then compare LSB 
110f			      jr    C, free_found_higher_block 
110f			 
110f			free_find_higher_block_skip: 
110f			      ld    A, D                    ; Reached the end of the free list? 
110f			      or    E 
110f			      jp    Z, free_done 
110f			 
110f			      ex    DE, HL 
110f			 
110f			      jr    free_find_higher_block 
110f			 
110f			free_found_higher_block: 
110f			      ; Insert freed block between prev and next free blocks 
110f			      ld    (HL), C                 ; Point prev free block to freed block 
110f			      inc   HL 
110f			      ld    (HL), B 
110f			 
110f			      ld    H, B                    ; Point freed block at next free block 
110f			      ld    L, C 
110f			      ld    (HL), E 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			      ; Check if the freed block is adjacent to the next free block 
110f			      inc   HL                      ; Load size of freed block into HL 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      ex    DE, HL 
110f			 
110f			      add   HL, BC                  ; Add addr of freed block and its size 
110f			 
110f			      ld    E, (IX+0)               ; Load addr of next free block into DE 
110f			      ld    D, (IX+1) 
110f			 
110f			      or    A                       ; Clear the carry flag 
110f			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
110f			      jr    NZ, free_check_adjacent_to_prev 
110f			 
110f			      ; Freed block is adjacent to next, merge into one bigger block 
110f			      ex    DE, HL                  ; Load next ptr from next block into DE 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      push  HL                      ; Save ptr to next block for later 
110f			 
110f			      ld    H, B                    ; Store ptr from next block into freed block 
110f			      ld    L, C 
110f			      ld    (HL), E 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			      pop   HL                      ; Restore ptr to next block 
110f			      inc   HL                      ; Load size of next block into DE 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      push  DE                      ; Save next block size for later 
110f			 
110f			      ld    H, B                    ; Load size of freed block into HL 
110f			      ld    L, C 
110f			      inc   HL 
110f			      inc   HL 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      ex    DE, HL 
110f			 
110f			      pop   DE                      ; Restore size of next block 
110f			      add   HL, DE                  ; Add sizes of both blocks 
110f			      ex    DE, HL 
110f			 
110f			      ld    H, B                    ; Store new bigger size into freed block 
110f			      ld    L, C 
110f			      inc   HL 
110f			      inc   HL 
110f			      ld    (HL), E 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			free_check_adjacent_to_prev: 
110f			      ; Check if the freed block is adjacent to the prev free block 
110f			      ld    L, (IX+2)               ; Prev free block ptr into HL 
110f			      ld    H, (IX+3) 
110f			 
110f			      inc   HL                      ; Size of prev free block into DE 
110f			      inc   HL 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      dec   HL 
110f			      dec   HL 
110f			      dec   HL 
110f			 
110f			      add   HL, DE                  ; Add prev block addr and size 
110f			 
110f			      or    A                       ; Clear the carry flag 
110f			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
110f			      jr    NZ, free_done 
110f			 
110f			      ; Freed block is adjacent to prev, merge into one bigger block 
110f			      ld    H, B                    ; Load next ptr from freed block into DE 
110f			      ld    L, C 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      push  HL                      ; Save freed block ptr for later 
110f			 
110f			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
110f			      ld    H, (IX+3) 
110f			      ld    (HL), E 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			      pop   HL                      ; Restore freed block ptr 
110f			      inc   HL                      ; Load size of freed block into DE 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			      push  DE                      ; Save freed block size for later 
110f			 
110f			      ld    L, (IX+2)               ; Load size of prev block into DE 
110f			      ld    H, (IX+3) 
110f			      inc   HL 
110f			      inc   HL 
110f			      ld    E, (HL) 
110f			      inc   HL 
110f			      ld    D, (HL) 
110f			 
110f			      pop   HL                      ; Add sizes of both blocks 
110f			      add   HL, DE 
110f			      ex    DE, HL 
110f			 
110f			      ld    L, (IX+2)               ; Store new bigger size into prev block 
110f			      ld    H, (IX+3) 
110f			      inc   HL 
110f			      inc   HL 
110f			      ld    (HL), E 
110f			      inc   HL 
110f			      ld    (HL), D 
110f			 
110f			free_done: 
110f			      ld    HL, 4                   ; Clean up stack frame 
110f			      add   HL, SP 
110f			      ld    SP, HL 
110f			 
110f			free_early_exit: 
110f			      pop   IX 
110f			      pop   DE 
110f			      pop   BC 
110f			 
110f			      ret 
110f			 
110f			 
110f			;      .org 0x8000 
110f			; 
110f			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
110f			 ;                 .dw   0 
110f			 
110f			endif 
110f			 
110f			 
110f			if MALLOC_4 
110f			 
110f			; My memory allocation code. Very very simple.... 
110f			; allocate space under 250 chars 
110f			 
110f			heap_init: 
110f				; init start of heap as zero 
110f				;  
110f			 
110f				ld hl, heap_start 
110f			;	ld a, 0 
110f				ld (hl), 0      ; empty block 
110f				inc hl 
110f			;	ld a, 0 
110f				ld (hl), 0      ; length of block 
110f				; write end of list 
110f				inc hl 
110f				ld a,(hl) 
110f				inc hl 
110f				ld a,(hl) 
110f				 
110f			 
110f				; init some malloc vars 
110f			 
110f				ld hl, 0 
110f				ld (free_list), hl       ; store last malloc location 
110f			 
110f				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
110f			;	ld a, 0 
110f				ld (hl), 0 
110f			 
110f			 
110f				ld hl, heap_start 
110f				;  
110f				  
110f				ret 
110f			 
110f			 
110f			;    free block marker 
110f			;    requested size  
110f			;    pointer to next block 
110f			;    .... 
110f			;    next block marker 
110f			 
110f			 
110f			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
110f			; 
110f			 
110f			 
110f			malloc:  
110f				push de 
110f				push bc 
110f				push af 
110f			 
110f				; hl space required 
110f				 
110f				ld c, l    ; hold space   (TODO only a max of 255) 
110f			 
110f			;	inc c     ; TODO BUG need to fix memory leak on push str 
110f			;	inc c 
110f			;	inc c 
110f			;	inc c 
110f			;	inc c 
110f			;	inc c 
110f			;	inc c 
110f			 
110f			 
110f			 
110f				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
110f			 
110f				ld a, (free_list+3) 
110f			;	cp 0 
110f				or a 
110f				jr z, .contheap 
110f			 
110f				ld hl, (free_list)     ; get last alloc 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "mrs" 
110f						CALLMONITOR 
110f					endif 
110f				jr .startalloc 
110f			 
110f			.contheap: 
110f				ld hl, heap_start 
110f			 
110f			.startalloc: 
110f			 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "mym" 
110f						CALLMONITOR 
110f					endif 
110f			.findblock: 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "mmf" 
110f						CALLMONITOR 
110f					endif 
110f			 
110f				ld a,(hl)  
110f				; if byte is zero then clear to use 
110f			 
110f			;	cp 0 
110f				or a 
110f				jr z, .foundemptyblock 
110f			 
110f				; if byte is not clear 
110f				;     then byte is offset to next block 
110f			 
110f				inc hl 
110f				ld a, (hl) ; get size 
110f			.nextblock:	inc hl 
110f					ld e, (hl) 
110f					inc hl 
110f					ld d, (hl) 
110f					ex de, hl 
110f			;	inc hl  ; move past the store space 
110f			;	inc hl  ; move past zero index  
110f			 
110f				; TODO detect no more space 
110f			 
110f				push hl 
110f				ld de, heap_end 
110f				call cmp16 
110f				pop hl 
110f				jr nc, .nospace 
110f			 
110f				jr .findblock 
110f			 
110f			.nospace: ld hl, 0 
110f				jp .exit 
110f			 
110f			 
110f			.foundemptyblock:	 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "mme" 
110f						CALLMONITOR 
110f					endif 
110f			 
110f			; TODO has block enough space if reusing??? 
110f			 
110f				;  
110f			 
110f			; see if this block has been previously used 
110f				inc hl 
110f				ld a, (hl) 
110f				dec hl 
110f			;	cp 0 
110f				or a 
110f				jr z, .newblock 
110f			 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "meR" 
110f						CALLMONITOR 
110f					endif 
110f			 
110f			; no reusing previously allocated block 
110f			 
110f			; is it smaller than previously used? 
110f				 
110f				inc hl    ; move to size 
110f				ld a, c 
110f				sub (hl)        ; we want c < (hl) 
110f				dec hl    ; move back to marker 
110f			        jr z, .findblock 
110f			 
110f				; update with the new size which should be lower 
110f			 
110f			        ;inc  hl   ; negate next move. move back to size  
110f			 
110f			.newblock: 
110f				; need to be at marker here 
110f			 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "meN" 
110f						CALLMONITOR 
110f					endif 
110f			 
110f			 
110f				ld a, c 
110f			 
110f				ld (free_list+3), a	 ; flag resume from last malloc  
110f				ld (free_list), hl    ; save out last location 
110f			 
110f			 
110f				;inc a     ; space for length byte 
110f				ld (hl), a     ; save block in use marker 
110f			 
110f				inc hl   ; move to space marker 
110f				ld (hl), a    ; save new space 
110f			 
110f				inc hl   ; move to start of allocated area 
110f				 
110f			;	push hl     ; save where we are - 1  
110f			 
110f			;	inc hl  ; move past zero index  
110f				; skip space to set down new marker 
110f			 
110f				; provide some extra space for now 
110f			 
110f				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
110f				inc a 
110f				inc a 
110f			 
110f				push hl   ; save where we are in the node block 
110f			 
110f				call addatohl 
110f			 
110f				; write linked list point 
110f			 
110f				pop de     ; get our node position 
110f				ex de, hl 
110f			 
110f				ld (hl), e 
110f				inc hl 
110f				ld (hl), d 
110f			 
110f				inc hl 
110f			 
110f				; now at start of allocated data so save pointer 
110f			 
110f				push hl 
110f			 
110f				; jump to position of next node and setup empty header in DE 
110f			 
110f				ex de, hl 
110f			 
110f			;	inc hl ; move past end of block 
110f			 
110f			;	ld a, 0 
110f				ld (hl), 0   ; empty marker 
110f				inc hl 
110f				ld (hl), 0   ; size 
110f				inc hl  
110f				ld (hl), 0   ; ptr 
110f				inc hl 
110f				ld (hl), 0   ; ptr 
110f			 
110f			 
110f				pop hl 
110f			 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "mmr" 
110f						CALLMONITOR 
110f					endif 
110f			 
110f			.exit: 
110f				pop af 
110f				pop bc 
110f				pop de  
110f				ret 
110f			 
110f			 
110f			 
110f			 
110f			free:  
110f				push hl 
110f				push af 
110f				; get address in hl 
110f			 
110f					if DEBUG_FORTH_MALLOC_INT 
110f						DMARK "fre" 
110f						CALLMONITOR 
110f					endif 
110f				; data is at hl - move to block count 
110f				dec hl 
110f				dec hl    ; get past pointer 
110f				dec hl 
110f			 
110f				ld a, (hl)    ; need this for a validation check 
110f			 
110f				dec hl    ; move to block marker 
110f			 
110f				; now check that the block count and block marker are the same  
110f			        ; this checks that we are on a malloc node and not random memory 
110f			        ; OK a faint chance this could be a problem but rare - famous last words! 
110f			 
110f				ld c, a 
110f				ld a, (hl)    
110f			 
110f				cp c 
110f				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
110f			 
110f				; yes good chance we are on a malloc node 
110f			 
110f			;	ld a, 0      
110f				ld (hl), 0   ; mark as free 
110f			 
110f				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
110f			 
110f			.freeignore:  
110f			 
110f				pop af 
110f				pop hl 
110f			 
110f				ret 
110f			 
110f			 
110f			 
110f			endif 
110f			 
