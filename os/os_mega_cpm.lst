297e			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
297e			; | | At start the current various registers will be displayed with contents. 
297e			; | | Top right corner will show the most recent debug marker seen. 
297e			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
297e			; | | and the return stack pointer (RSP). 
297e			; | | Pressing: 
297e			; | |  
297e			; | |    1 - Initial screen 
297e			; | |  
297e			; | |    2 - Display a data dump of HL 
297e			; | |  
297e			; | |    3 - Display a data dump of DE 
297e			; | |  
297e			; | |    4 - Display a data dump of BC 
297e			; | |  
297e			; | |    5 - Display a data dump of HL 
297e			; | |  
297e			; | |    6 - Display a data dump of DSP 
297e			; | |  
297e			; | |    7 - Display a data dump of RSP 
297e			; | |  
297e			; | |    8 - Display a data dump of what is at DSP 
297e			; | |  
297e			; | |    9 - Display a data dump of what is at RSP 
297e			; | |  
297e			; | |    0 - Exit monitor and continue running. This will also enable break points 
297e			; | |  
297e			; | |    * - Disable break points 
297e			; | |  
297e			; | |    # - Enter traditional monitor mode 
297e			; | |  
297e			; | | 
297e			; | | Monitor Mode 
297e			; | | ------------ 
297e			; | | A prompt of '>' will be shown for various commands: 
297e			; | |  
297e			; | |    D xxxx - Display a data dump starting from hex address xxxx 
297e			; | |  
297e			; | |    C - Continue display a data dump from the last set address 
297e			; | |  
297e			; | |    M xxxx - Set start of memory edit at address xx 
297e			; | |  
297e			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
297e			; | |  
297e			; | |    G xxxx - Exec code at specific address 
297e			; | |  
297e			; | |    Q - Return to previous 
297e				if DEBUG_FORTH_WORDS_KEY 
297e					DMARK "MON" 
297e f5				push af  
297f 3a 93 29			ld a, (.dmark)  
2982 32 5e ee			ld (debug_mark),a  
2985 3a 94 29			ld a, (.dmark+1)  
2988 32 5f ee			ld (debug_mark+1),a  
298b 3a 95 29			ld a, (.dmark+2)  
298e 32 60 ee			ld (debug_mark+2),a  
2991 18 03			jr .pastdmark  
2993 ..			.dmark: db "MON"  
2996 f1			.pastdmark: pop af  
2997			endm  
# End of macro DMARK
2997					CALLMONITOR 
2997				if BASE_CPM=1  
2997 cd 6b ee				call debug_vector  
299a				endif  
299a				if BASE_KEV=1  
299a					rst 8  
299a				endif  
299a				endm  
# End of macro CALLMONITOR
299a				endif 
299a			;		ld a, 0 
299a			;		ld (os_view_disable), a 
299a cd 8a 14			call bp_on 
299d			 
299d				CALLMONITOR 
299d				if BASE_CPM=1  
