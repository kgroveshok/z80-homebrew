00a0			hardware_init:  
00a0			  
00a0				  
00a0			  
00a0					;ld a, 0  
00a0					;ld (hardware_diag), a  
00a0			  
00a0					; clear all the buffers  
00a0			  
00a0 21 40 fc				ld hl, display_fb1  
00a3 22 fc fa				ld (display_fb_active), hl  
00a6			  
00a6 cd 2f 0b				call clear_display  
00a9			  
00a9 21 fe fa				ld hl, display_fb2  
00ac 22 fc fa				ld (display_fb_active), hl  
00af			  
00af cd 2f 0b				call clear_display  
00b2			  
00b2					; init primary frame buffer area  
00b2 21 e1 fc				ld hl, display_fb0  
00b5 22 fc fa				ld (display_fb_active), hl  
00b8			  
00b8 cd 2f 0b				call clear_display  
00bb			  
00bb			  
00bb cd 2b 68				call lcd_init		; lcd hardware first as some screen functions called during key_init e.g. cursor shapes  
00be			  
00be cd c2 6a			call key_init  
00c1 cd 94 02			call storage_init  
00c4				if TAPE_SUPPORT  
00c4 cd c4 12				call tape_init  
00c7				endif  
00c7			  
00c7				; setup malloc functions  
00c7			  
00c7				if MALLOC_1  
00c7 cd 07 11				call  heap_init  
00ca				endif  
