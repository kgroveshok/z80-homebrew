01e2			 
01e2			; persisent storage hardware abstraction layer  
01e2			 
01e2			 
01e2			 
01e2			; Block 0 on storage is a config state 
01e2			 
01e2			 
01e2			 
01e2			; TODO add read phy block and write phy block functions 
01e2			; TODO add presence check (i.e. read write byte 0 of block 0 for eeprom) 
01e2			 
01e2			; Abstraction layer  
01e2			 
01e2			; Logocial block size is same size as physical size - using tape concept 
01e2			 
01e2			;STORE_BLOCK_PHY2LOG: equ (STORE_BLOCK_LOG/STORE_BLOCK_PHY)       ; How many physical blocks make up a logical block 
01e2			;STORE_BLOCK_MAX: equ (STORE_BLOCK_PHY*STORE_DEVICE_MAXBLOCKS)/255    ; Max number of logical blocks on the device 
01e2			 
01e2			 
01e2			 
01e2			; Filesystem layout (Logical layout) 
01e2			; 
01e2			; Block 0 - Bank config  
01e2			; 
01e2			;      Byte - 0 file id counter 
01e2			;      Byte - 1-2 formated: Byte pattern: 0x80 x27 
01e2			;      Byte - 3-20 zero terminated bank label 
01e2			; 
