1d01			include "firmware_595shiftreg.asm"  
1d01			; common code for handling a 595 shift reg out on whatever output port 
1d01			 
1d01			; port in c 
1d01			; byte in a 
1d01			 
1d01			 
1d01			shift_bit_data: equ 0 
1d01			shift_bit_clk: equ 1 
1d01			shift_bit_latch: equ 2 
1d01			 
1d01			 
1d01			; shift out a byte to the sound chip 
1d01			 
1d01			; A contains byte to send 
1d01			 
1d01			shift_byte: 
1d01			 
1d01 06 08			ld b, 8   ; 8 bits to shift 
1d03			 
1d03 16 00		.nb1:	ld d, 0    ; our work byte to send to the device with flags 
1d05			 
1d05				; set data bit state 
1d05			 
1d05 cb 7f			bit 7, a 
1d07				; high bit is set 
1d07 28 02			jr z, .nb2 
1d09 cb c2			set shift_bit_data, d 
1d0b			 
1d0b				; set latches state  
1d0b cb ca		.nb2:	set shift_bit_clk, d 
1d0d cb 92			res shift_bit_latch, d    ; latch is inverted 
1d0f ed 51			out (c), d 
1d11				 
1d11				; clock the bit out 
1d11 cb 8a			res shift_bit_clk, d 
1d13 ed 51			out (c), d 
1d15			 
1d15				; shift a left one bit and repeat 
1d15 17				rla 
1d16			 
1d16 10 eb			djnz .nb1 
1d18			 
1d18				; latch 
1d18 cb d2			set shift_bit_latch, d 
1d1a ed 51			out (c), d 
1d1c					 
1d1c			 
1d1c				; set  
1d1c c9				ret 
# End of file firmware_595shiftreg.asm
