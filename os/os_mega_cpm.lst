1d5e			.NEW: 
1d5e			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
1d5e 15				db WORD_SYS_CORE+OPCODE_HEAP             
1d5f 78 1d			dw .HEAP            
1d61 04				db 3 + 1 
1d62 .. 00			db "NEW",0              
1d66				endm 
# End of macro CWHEAD
1d66			; | NEW ( -- ) Clears all user words and stack | DONE 
1d66				 
1d66				if MALLOC_4 
1d66					call  heap_init 
1d66				endif 
1d66				; reset uword pointers 
1d66 21 16 5c			ld hl, baseram 
1d69 22 9f e5			ld (os_last_new_uword), hl 
1d6c cd b2 1b			call user_word_eol 
1d6f				; clear stack 
1d6f cd cb 1b			call forth_warmstart 
1d72				NEXTW 
1d72 cd 68 ee			call parse_vector 
1d75 c3 25 1c			jp macro_next 
1d78				endm 
# End of macro NEXTW
1d78			 
1d78			.HEAP: 
1d78			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
1d78 15				db WORD_SYS_CORE+OPCODE_HEAP             
1d79 af 1d			dw .EXEC            
1d7b 05				db 4 + 1 
1d7c .. 00			db "HEAP",0              
1d81				endm 
# End of macro CWHEAD
1d81			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
1d81			; | | u1 - Current number of bytes in the heap 
1d81			; | | u2 - Remaining bytes left on the heap 
1d81			; | |  
1d81			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
1d81			 
1d81			 
1d81				if DEBUG_FORTH_WORDS_KEY 
1d81					DMARK "HEP" 
1d81				if DEMARK_VERSION = 1  
1d81 e5					push hl  
1d82 21 8a 1d				ld hl, .dmark  
1d85 22 60 ee				ld (debug_mark), hl  
1d88				endif  
1d88				if DEMARK_VERSION = 0  
1d88					push af  
1d88					ld a, (.dmark)  
1d88					ld (debug_mark),a  
1d88					ld a, (.dmark+1)  
1d88					ld (debug_mark+1),a  
1d88					ld a, (.dmark+2)  
1d88					ld (debug_mark+2),a  
1d88				endif  
1d88 18 04			jr .pastdmark  
1d8a ..			.dmark: db "HEP"  
1d8d				if DEMARK_VERSION = 1  
1d8d 00					db 0  
1d8e				endif  
1d8e				if DEMARK_VERSION = 1  
1d8e e1			.pastdmark: pop hl  
1d8f				endif  
1d8f				if DEMARK_VERSION = 0  
1d8f			.pastdmark: pop af  
1d8f				endif  
1d8f			endm  
# End of macro DMARK
