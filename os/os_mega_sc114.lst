9e56 15				db WORD_SYS_CORE+OPCODE_HEAP             
9e57 70 9e			dw .HEAP            
9e59 04				db 3 + 1 
9e5a .. 00			db "NEW",0              
9e5e				endm 
# End of macro CWHEAD
9e5e			; | NEW ( -- ) Clears all user words and stack | DONE 
9e5e				 
9e5e				if MALLOC_4 
9e5e					call  heap_init 
9e5e				endif 
9e5e				; reset uword pointers 
9e5e 21 e4 d5			ld hl, baseram 
9e61 22 9f e5			ld (os_last_new_uword), hl 
9e64 cd aa 9c			call user_word_eol 
9e67				; clear stack 
9e67 cd c3 9c			call forth_warmstart 
9e6a				NEXTW 
9e6a cd 68 ee			call parse_vector 
9e6d c3 1d 9d			jp macro_next 
9e70				endm 
# End of macro NEXTW
