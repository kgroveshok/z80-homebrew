bea3			 
bea3			;		pop hl 
bea3			 
bea3					; active low 
bea3			 
bea3					ld c, 255 
bea3			 
bea3					ld a, l 
bea3					if DEBUG_FORTH_WORDS 
bea3						DMARK "CDV" 
bea3						CALLMONITOR 
bea3					endif 
bea3			;		cp 0 
bea3					or a 
bea3					jr z, .cset 
bea3					cp 1 
bea3					jr nz, .c2 
bea3					res 0, c 
bea3			.c2:		cp 2 
bea3					jr nz, .c3 
bea3					res 1, c 
bea3			.c3:		cp 3 
bea3					jr nz, .c4 
bea3					res 2, c 
bea3			.c4:		cp 4 
bea3					jr nz, .c5 
