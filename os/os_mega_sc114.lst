8bd0			; Out: BC = result, HL = rest 
8bd0			; 
8bd0			Div16: 
8bd0 21 00 00		    ld hl,0 
8bd3 78			    ld a,b 
8bd4 06 08		    ld b,8 
8bd6			Div16_Loop1: 
8bd6 17			    rla 
8bd7 ed 6a		    adc hl,hl 
8bd9 ed 52		    sbc hl,de 
8bdb 30 01		    jr nc,Div16_NoAdd1 
8bdd 19			    add hl,de 
8bde			Div16_NoAdd1: 
8bde 10 f6		    djnz Div16_Loop1 
8be0 17			    rla 
8be1 2f			    cpl 
8be2 47			    ld b,a 
8be3 79			    ld a,c 
8be4 48			    ld c,b 
8be5 06 08		    ld b,8 
8be7			Div16_Loop2: 
8be7 17			    rla 
8be8 ed 6a		    adc hl,hl 
8bea ed 52		    sbc hl,de 
8bec 30 01		    jr nc,Div16_NoAdd2 
8bee 19			    add hl,de 
8bef			Div16_NoAdd2: 
8bef 10 f6		    djnz Div16_Loop2 
8bf1 17			    rla 
8bf2 2f			    cpl 
8bf3 41			    ld b,c 
8bf4 4f			    ld c,a 
8bf5 c9			ret 
