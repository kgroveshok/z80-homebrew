d6c4			key_init: 
d6c4				; init keyboard macro pointers 
d6c4 21 00 00			ld hl, 0 
d6c7 22 fe ee			ld (key_macroroot), hl 
d6ca 22 fc ee			ld (key_macrolast), hl 
d6cd				; no init as handled by the SCM bios 
d6cd c9				ret 
d6ce			 
d6ce			 
d6ce			cin_wait: 
d6ce			;	ld a, 0 
d6ce			;	ret 
d6ce			 
d6ce				;in a,(SC114_SIO_1_IN) 
d6ce			        ; Use SCM API to get from whatever console device we are using 
d6ce c5				push bc 
d6cf 0e 01			ld c, $01 
d6d1 f7				rst $30 
d6d2 c1				pop bc 
d6d3 c9				ret 
d6d4			 
d6d4			cinndb: 	 
d6d4			cin: 
d6d4			 
d6d4			 
d6d4 c5				push bc 
d6d5			 
d6d5				; any key waiting to process? 
d6d5 0e 03			ld c, $03 
d6d7 f7				rst $30 
d6d8 28 05			jr z, .cin_skip 
d6da			 
d6da				; yep, get it 
d6da			 
d6da 0e 01			ld c, $01 
d6dc f7				rst $30 
d6dd c1				pop bc 
d6de c9				ret 
d6df			.cin_skip: 
d6df 3e 00			ld a, 0 
d6e1 c1				pop bc 
d6e2 c9				ret 
