0d7b			; 
0d7b			;       sla e        ;128 
0d7b			;       rl d         ;128 
0d7b			;       adc hl,hl    ;240 
0d7b			;       sbc hl,bc    ;240 
0d7b			;       jr nc,.DivLoop ;23|21 
