1119			StrictStrCmp: 
1119				; Load next chars of each string 
1119 1a				ld a, (de) 
111a 47				ld b, a 
111b 7e				ld a, (hl) 
111c				; Compare 
111c b8				cp b 
111d				; Return non-zero if chars don't match 
111d c0				ret nz 
111e				; Check for end of both strings 
111e fe 00			cp "\0" 
1120				; Return if strings have ended 
1120 c8				ret z 
1121				; Otherwise, advance to next chars 
1121 23				inc hl 
1122 13				inc de 
1123 18 f4			jr StrictStrCmp 
