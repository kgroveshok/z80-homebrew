681b			; **********************************************************************  
681b			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
681b			; **********************************************************************  
681b			;  
681b			; **  Written as a Small Computer Monitor App  
681b			; **  www.scc.me.uk  
681b			;  
681b			; History  
681b			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
681b			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
681b			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
681b			;  
681b			; **********************************************************************  
681b			;  
681b			; This program is an example of one of the methods of interfacing an   
681b			; alphanumeric LCD module.   
681b			;  
681b			; In this example the display is connected to either a Z80 PIO or a   
681b			; simple 8-bit output port.   
681b			;  
681b			; This interfacing method uses 4-bit data mode and uses time delays  
681b			; rather than polling the display's ready status. As a result the   
681b			; interface only requires 6 simple output lines:  
681b			;   Output bit 0 = not used  
681b			;   Output bit 1 = not used  
681b			;   Output bit 2 = RS         High = data, Low = instruction  
681b			;   Output bit 3 = E          Active high  
681b			;   Output bit 4 = DB4  
681b			;   Output bit 5 = DB5  
681b			;   Output bit 6 = DB6  
681b			;   Output bit 7 = DB7  
681b			; Display's R/W is connected to 0v so it is always in write mode  
681b			;  
681b			; This set up should work with any system supporting the RC2014 bus  
681b			  
681b			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
681b			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
681b			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
681b			;  
681b			; **********************************************************************  
681b			  
681b			; Additonal for 4x40. E1 and E2 instead of just E   
681b			; TODO swipe vidout signal on port a to activate E2  
681b			  
681b			; **********************************************************************  
681b			; **  Constants  
681b			; **********************************************************************  
681b			; LCD constants required by LCD support module  
681b			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
681b			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
681b			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
681b			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
681b			; TODO Decide which E is being set  
681b			kLCDWidth:  EQU display_cols             ;Width in characters  
681b			  
681b			; **********************************************************************  
681b			; **  Code library usage  
681b			; **********************************************************************  
681b			  
681b			; send character to current cursor position  
681b			; wraps and/or scrolls screen automatically  
681b			  
681b			  
681b			  
681b			lcd_init:  
681b			  
681b			; SCMonAPI functions used  
681b			  
681b			; Alphanumeric LCD functions used  
681b			; no need to specify specific functions for this module  
681b			  
681b 3e cf		            LD   A, 11001111b  
681d d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
681f 3e 00		            LD   A, 00000000b  
6821 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
6823			  
6823			; Initialise alphanumeric LCD module  
6823 3e 00				ld a, 0  
6825 32 fb fa				ld (display_lcde1e2), a  
6828 cd a9 68		            CALL fLCD_Init      ;Initialise LCD module  
682b 3e 01				ld a, 1  
682d 32 fb fa				ld (display_lcde1e2), a  
6830 cd a9 68		            CALL fLCD_Init      ;Initialise LCD module  
6833			  
6833 c9				ret  
6834			  
