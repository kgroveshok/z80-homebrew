5810			; stack over and underflow checks 
5810			 
5810			; init the words to detect the under/overflow 
5810			 
5810			chk_stk_init: 
5810				; a vague random number to check so we dont get any "lucky" hits 
5810 3e 2d			ld a, 45 
5812 6f				ld l, a 
5813 00				nop 
5814 3e 17			ld a, 23 
5816 67				ld h, a 
5817			 
5817 22 7e e2			ld (chk_word), hl     ; the word we need to check against 
581a			 
581a			;	ld (chk_stund), hl	; stack points.... 
581a 22 00 ef			ld (chk_stovr), hl 
581d 22 cd e9			ld (chk_ret_und), hl 
5820 22 8b e9			ld (chk_ret_ovr), hl 
5823 22 09 e9			ld (chk_loop_ovr), hl 
5826 22 07 e8			ld (chk_data_ovr), hl 
5829 c9				ret 
582a				 
582a			check_stacks: 
582a				; check all stack words 
582a			 
582a e5				push hl 
582b d5				push de 
582c			 
582c			;	ld de,(chk_word) 
582c			;	ld hl, (chk_stund)	; stack points.... 
582c			;	if DEBUG_STK_FAULT 
582c			;		DMARK "FAa" 
582c			;		CALLMONITOR 
582c			;	endif 
582c			;	call cmp16 
582c			;	jp z, .chk_faulta 
582c			; 
582c			;	ld de, sfaultsu 
582c			;	jp .chk_fault 
582c			 
582c 2a 00 ef		.chk_faulta: ld hl, (chk_stovr) 
582f ed 5b 7e e2		ld de,(chk_word) 
5833				if DEBUG_STK_FAULT 
5833					DMARK "FAb" 
5833					CALLMONITOR 
5833				endif 
5833 cd 12 0c			call cmp16 
5836 28 06			jr z, .chk_fault1 
5838 11 dd 58			ld de, sfaultso 
583b c3 8d 58			jp .chk_fault 
583e			.chk_fault1:  
583e 2a cd e9			ld hl, (chk_ret_und) 
5841 ed 5b 7e e2		ld de,(chk_word) 
5845				if DEBUG_STK_FAULT 
5845					DMARK "FAU" 
5845					CALLMONITOR 
5845				endif 
5845 cd 12 0c			call cmp16 
5848 ca 51 58			jp z, .chk_fault2 
584b 11 ed 58			ld de, sfaultru 
584e c3 8d 58			jp .chk_fault 
5851			.chk_fault2:  
5851 2a 8b e9			ld hl, (chk_ret_ovr) 
5854 ed 5b 7e e2		ld de,(chk_word) 
5858				if DEBUG_STK_FAULT 
5858					DMARK "FA1" 
5858					CALLMONITOR 
5858				endif 
5858 cd 12 0c			call cmp16 
585b ca 64 58			jp z, .chk_fault3 
585e 11 fb 58			ld de, sfaultro 
5861 c3 8d 58			jp .chk_fault 
5864			.chk_fault3:  
5864 2a 09 e9			ld hl, (chk_loop_ovr) 
5867 ed 5b 7e e2		ld de,(chk_word) 
586b				if DEBUG_STK_FAULT 
586b					DMARK "FA2" 
586b					CALLMONITOR 
586b				endif 
586b cd 12 0c			call cmp16 
586e ca 77 58			jp z, .chk_fault4 
5871 11 15 59			ld de, sfaultlo 
5874 c3 8d 58			jp .chk_fault 
5877			.chk_fault4:  
5877 2a 07 e8			ld hl, (chk_data_ovr) 
587a ed 5b 7e e2		ld de,(chk_word) 
587e				if DEBUG_STK_FAULT 
587e					DMARK "FA3" 
587e					CALLMONITOR 
587e				endif 
587e cd 12 0c			call cmp16 
5881 ca 8a 58			jp z, .chk_fault5 
5884 11 2f 59			ld de, sfaultdo 
5887 c3 8d 58			jp .chk_fault 
