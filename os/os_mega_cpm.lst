4428				CWHEAD .GPI 31 "SETTAPE" 7 WORD_FLAG_CODE 
4428			; | SETTAPE ( port gap samples hpulse lpulse high low -- )   Set parameters for tape support | DONE 
4428			; | | port - Device address port; default is Device A on 00h 
4428			; | | samples - How many sample cycles to count pulses 
4428			; | | gap - Gap period counter; default is 250 
4428			; | | hpulse - Count of pulses for 1; default is 6 
4428			; | | lpulse - Count of pulses for 0; default is 2 
4428			; | | high - High bit period counter; default is 150 
4428			; | | low - Low bit period counter; default is 50 
4428			 
4428					if DEBUG_FORTH_WORDS_KEY 
4428						DMARK "TSE" 
4428						CALLMONITOR 
4428					endif 
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld (tape_tm_low), hl 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld (tape_tm_high), hl 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld a, l 
4428					ld (tape_pulse_low), a 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld a, l 
4428					ld (tape_pulse_high), a 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld (tape_samples), hl 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld a, l 
4428					ld (tape_tm_gap), a 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					ld a, l 
4428					ld (tape_port), a 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428					NEXTW 
4428			 
4428			 
4428			.GPI: 
4428				CWHEAD .GPS 31 "SAVES" 5 WORD_FLAG_CODE 
4428			; | SAVES ( s1 ... sn c n -- )    Save a count of c strings using file name of n to tape | DONE 
4428					if DEBUG_FORTH_WORDS_KEY 
4428						DMARK "SAS" 
4428						CALLMONITOR 
4428					endif 
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					push hl    ; file name 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					push hl    ; count 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4428					  ; top string 
4428					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4428			 
4428					pop bc    ; count 
4428					pop de    ; file name 
4428			 
4428			; TODO handle more than one string 
4428					call tape_save 
4428							 
4428					NEXTW 
4428			 
4428			 
4428			.GPS: 
4428				CWHEAD .TLOAD 31 "SAVE" 7 WORD_FLAG_CODE 
4428			; | SAVE ( n -- )    Save all uuser words to tape with given name n | TO DO 
4428					if DEBUG_FORTH_WORDS_KEY 
4428						DMARK "SAV" 
