bfbb			; var handler 
bfbb			 
bfbb			 
bfbb			.VARS: 
bfbb				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
bfbb 77				db WORD_SYS_CORE+99             
bfbc 23 c0			dw .V0            
bfbe 04				db 3 + 1 
bfbf .. 00			db "VAR",0              
bfc3				endm 
# End of macro CWHEAD
bfc3			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bfc3			; | 
bfc3			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bfc3			; | |  
bfc3			; | | e.g. 
bfc3			; | |         #30 a var ! 
bfc3			; | |         a var @ . 
bfc3			; | |   
bfc3			; | |     Displays the number 30 
bfc3			; | | 
bfc3			; | | Each variable pointer is a word so can use for any words that use that:  
bfc3			; | |  
bfc3			; | | e.g. 
bfc3			; | |  
bfc3			; | |         #30 a var 2! 
bfc3			; | |         a var 2@ . 
bfc3			; | |   
bfc3			; | |     Displays the number 30 
bfc3			; | |  
bfc3			; | | > [!NOTE]  
bfc3			; ! | > If a full string is passed then only the first char is looked at 
bfc3			; | | > Any other char could exceed bounds checks!  
bfc3			; | | > 
bfc3			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bfc3			 
bfc3					if DEBUG_FORTH_WORDS_KEY 
bfc3						DMARK "VAR" 
bfc3				if DEMARK_VERSION = 1  
bfc3 e5					push hl  
bfc4 21 cc bf				ld hl, .dmark  
bfc7 22 60 ee				ld (debug_mark), hl  
bfca				endif  
bfca				if DEMARK_VERSION = 0  
bfca					push af  
bfca					ld a, (.dmark)  
bfca					ld (debug_mark),a  
bfca					ld a, (.dmark+1)  
bfca					ld (debug_mark+1),a  
bfca					ld a, (.dmark+2)  
bfca					ld (debug_mark+2),a  
bfca				endif  
bfca 18 04			jr .pastdmark  
bfcc ..			.dmark: db "VAR"  
bfcf				if DEMARK_VERSION = 1  
bfcf 00					db 0  
bfd0				endif  
bfd0				if DEMARK_VERSION = 1  
bfd0 e1			.pastdmark: pop hl  
bfd1				endif  
bfd1				if DEMARK_VERSION = 0  
bfd1			.pastdmark: pop af  
bfd1				endif  
bfd1			endm  
# End of macro DMARK
bfd1						CALLMONITOR 
bfd1				if BASE_CPM=1  
bfd1					call debug_vector  
bfd1				endif  
bfd1				if BASE_KEV=1  
bfd1					rst 8  
bfd1				endif  
bfd1				endm  
# End of macro CALLMONITOR
bfd1					endif 
bfd1			 
bfd1					FORTH_DSP_VALUEHL 
bfd1				if BASE_CPM=1 
bfd1				call macro_dsp_valuehl 
bfd1				endif 
bfd1				if BASE_KEV=1 
bfd1					rst $18 
bfd1				endif 
bfd1				endm 
# End of macro FORTH_DSP_VALUEHL
