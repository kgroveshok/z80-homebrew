12d5			if TAPE_SUPPORT   
12d5				include "firmware_tape.asm"    ; Tape support on Device A by default  
12d5			; Tape support 
12d5			 
12d5			 
12d5			; encoding 
12d5			;  
12d5			; pulse marks  of stream 
12d5			; proportial 
12d5			 
12d5			 
12d5			; setup default tape params 
12d5			tape_init:     
12d5 3e 00			ld a, Device_A 
12d7 32 8e f9			ld (tape_port), a 
12da			 
12da 3e fa			ld a, 250 
12dc 32 8b f9			ld (tape_tm_gap), a 
12df			 
12df 3e 06			ld a, 6 
12e1 32 8d f9			ld (tape_pulse_high), a 
12e4			 
12e4 3e 02			ld a, 2 
12e6 32 8c f9			ld (tape_pulse_low), a 
12e9			 
12e9 21 32 00			ld hl, 50 
12ec 22 89 f9			ld (tape_tm_high), hl 
12ef			 
12ef 21 32 00			ld hl, 50 
12f2 22 87 f9			ld (tape_tm_low), hl 
12f5 c9				ret 
12f6			 
12f6			; support routinues for tape 
12f6			 
12f6			 
12f6			; Tape Output 
12f6			 
12f6			; osciallate the pin for the required duration 
12f6			 
12f6			tape_osc:  
12f6				; hl has the number of iterations 
12f6				; c = port number 
12f6				; d = bus data 
12f6				 
12f6 ed 51			out (c), d 
12f8			 
12f8 2b				dec hl 
12f9 cd 88 0d			call ishlzero 
12fc 20 f8			jr nz, tape_osc 
12fe				 
12fe c9				ret 
12ff			 
12ff			; output a gap period 
12ff			tape_gap:  
12ff 3a 8b f9			ld a, (tape_tm_gap) 
1302 cd 53 0a			call aDelayInMS 
1305 c9				ret 
1306			 
1306			tape_byte_gap: 
1306 cd ff 12			call tape_gap 
1309 cd ff 12			call tape_gap 
130c cd ff 12			call tape_gap 
130f cd ff 12			call tape_gap 
1312 c9				ret 
1313			 
1313			; output a high period 
1313			 
1313			tape_high: 
1313 3a 8e f9			ld a, (tape_port) 
1316 4f				ld c, a 
1317 16 ff			ld d, 255 
1319 3a 8d f9			ld a, (tape_pulse_high) 
131c 47				ld b, a 
131d 2a 89 f9		.th:	ld hl, (tape_tm_high) 
1320 cd f6 12			call tape_osc 
1323 cd ff 12			call tape_gap 
1326 10 f5			djnz .th 
1328 c9				 ret 
1329			 
1329			; output a low period 
1329			 
1329			tape_low:  
1329			 
1329 3a 8e f9			ld a, (tape_port) 
132c 4f				ld c, a 
132d 16 ff			ld d, 255 
132f 3a 8c f9			ld a, (tape_pulse_low) 
1332 47				ld b, a 
1333 2a 87 f9		.tl:	ld hl, (tape_tm_low) 
1336 cd f6 12			call tape_osc 
1339 cd ff 12			call tape_gap 
133c 10 f5			djnz .tl 
133e c9				 ret 
133f			 
133f			; end of save marker 
133f			 
133f			tape_end: 
133f 3e ff			ld a, 255 
1341 cd 58 13			call tape_byte_out 
1344 cd 06 13			call tape_byte_gap 
1347			 
1347 3e ff			ld a, 255 
1349 cd 58 13			call tape_byte_out 
134c cd 06 13			call tape_byte_gap 
134f 3e ff			ld a, 255 
1351 cd 58 13			call tape_byte_out 
1354 cd 06 13			call tape_byte_gap 
1357 c9				 ret 
1358			 
1358			; output an encoded byte 
1358			 
1358			tape_byte_out: 
1358				; a = byte to output 
1358 06 08			ld b, 8 
135a 4f				ld c, a 
135b			.tbo:    
135b c5				push bc 
135c cb 79			bit 7, c 
135e 28 05			jr z, .tbol 
1360 cd 13 13			call tape_high 
1363 18 03			jr .tbn 
1365			.tbol: 
