11c3 eb			      ex    DE, HL 
11c4 2b			      dec   HL 
11c5 2b			      dec   HL 
11c6 2b			      dec   HL 
11c7			 
11c7 af			      xor   A                       ; Null the next block ptr of allocated block 
11c8 77			      ld    (HL), A 
11c9 23			      inc   HL 
11ca 77			      ld    (HL), A 
11cb			 
11cb 23			      inc   HL                      ; Store address of allocation to return 
11cc 23			      inc   HL 
11cd 23			      inc   HL 
11ce e5			      push  HL 
11cf			 
