92b4			config_fdir: 
92b4				; using the scratch dir go through and release the memory allocated for each string 
92b4				 
92b4				ld hl, scratch 
92b4			.cfdir:	ld e,(hl) 
92b4				inc hl 
92b4				ld d,(hl) 
92b4				inc hl 
92b4			 
92b4				ex de, hl 
92b4				call ishlzero 
92b4				ret z     ; return on null pointer 
92b4				call free 
92b4				ex de, hl 
92b4				jr .cfdir 
92b4			 
92b4			 
92b4				ret 
92b4			 
92b4			 
92b4			config_dir: 
92b4			 
92b4				; for the config menus that need to build a directory of storage call this routine 
92b4				; it will construct a menu in scratch to pass to menu 
92b4			 
92b4				; open storage device 
92b4			 
92b4				; execute DIR to build a list of files and their ids into scratch in menu format 
92b4				; once the menu has finished then will need to call config_fdir to release the strings 
92b4				 
92b4				; c = number items 
92b4			 
92b4				 
92b4				call storage_get_block_0 
92b4			 
92b4				ld hl, store_page     ; get current id count 
92b4				ld b, (hl) 
92b4				ld c, 0    ; count of files   
92b4			 
92b4			 
92b4				ld hl, scratch 
92b4				ld (store_tmp2), hl    ; location to poke strings 
92b4			 
92b4				; check for empty drive 
92b4			 
92b4				ld a, 0 
92b4				cp b 
92b4				jp z, .dirdone 
92b4			 
92b4				 
92b4					if DEBUG_FORTH_WORDS 
92b4						DMARK "Cdc" 
92b4						CALLMONITOR 
92b4					endif 
92b4			 
92b4			 
92b4			.diritem:	 
92b4				push bc 
92b4				; for each of the current ids do a search for them and if found push to stack 
92b4			 
92b4					ld hl, STORE_BLOCK_PHY 
92b4					ld d, 0		 ; look for extent 0 of block id as this contains file name 
92b4					ld e,b 
92b4			 
92b4					call storage_findnextid 
92b4			 
92b4			 
92b4					; if found hl will be non zero 
92b4			 
92b4					call ishlzero 
92b4					jr z, .dirnotfound 
92b4			 
92b4					; increase count 
92b4			 
92b4					pop bc	 
92b4					inc c 
92b4					push bc 
92b4					 
92b4			 
92b4					; get file header and push the file name 
92b4			 
92b4					ld de, store_page 
92b4					call storage_read_block 
92b4			 
92b4					; push file id to stack 
92b4				 
92b4					ld a, (store_page) 
92b4					ld h, 0 
92b4					ld l, a 
92b4			 
92b4					;call forth_push_numhl 
92b4					; TODO store id 
92b4			 
92b4					push hl 
92b4			 
92b4					; push extent count to stack  
92b4				 
92b4					ld hl, store_page+3 
92b4			 
92b4					; get file name length 
92b4			 
92b4					call strlenz   
92b4			 
92b4					inc hl   ; cover zero term 
92b4					inc hl  ; stick the id at the end of the area 
92b4			 
92b4					push hl 
92b4					pop bc    ; move length to bc 
92b4			 
92b4					call malloc 
92b4			 
92b4					; TODO save malloc area to scratch 
92b4			 
92b4					ex de, hl 
92b4					ld hl, (store_tmp2) 
92b4					ld (hl), e 
92b4					inc hl 
92b4					ld (hl), d 
92b4					inc hl 
92b4					ld (store_tmp2), hl 
92b4			 
92b4					 
92b4			 
92b4					;pop hl   ; get source 
92b4			;		ex de, hl    ; swap aronund	 
92b4			 
92b4					ld hl, store_page+3 
92b4					if DEBUG_FORTH_WORDS 
92b4						DMARK "CFd" 
92b4						CALLMONITOR 
92b4					endif 
92b4					ldir 
92b4			 
92b4					; de is past string, move back one and store id 
92b4					 
92b4					dec de 
92b4			 
92b4					; store file id 
92b4			 
92b4					pop hl 
92b4					ex de,hl 
92b4					ld (hl), e 
92b4			 
92b4					if DEBUG_FORTH_WORDS 
92b4						DMARK "Cdi" 
92b4						CALLMONITOR 
92b4					endif 
92b4					 
92b4			.dirnotfound: 
92b4					pop bc     
92b4					djnz .diritem 
92b4				 
92b4			.dirdone:	 
92b4			 
92b4			;		ld a, 0 
92b4					ld hl, (store_tmp2) 
92b4					ld (hl), 0 
92b4					inc hl 
92b4					ld (hl), 0 
92b4					inc hl 
92b4					; push a count of the dir items found 
92b4			 
92b4			;		ld h, 0 
92b4			;		ld l, c 
92b4			 
92b4				ret 
92b4			 
92b4			endif 
