0f75			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0f75			;;    subtract $30, if result > 9 then subtract $7 more 
0f75			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0f75			atohex: 
0f75 d6 30				SUB $30 
0f77 fe 0a				CP 10 
0f79 f8					RET M		; If result negative it was 0-9 so we're done 
0f7a d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0f7c c9					RET		 
