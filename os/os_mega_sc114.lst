9af2						CALLMONITOR 
9af2					endif 
9af2 d5				push de 
9af3			 
9af3			.fnt1:	 
9af3				; find first char of token to locate 
9af3			 
9af3 1a				ld a, (de) 
9af4 4f				ld c,a 
9af5 7e				ld a,(hl) 
9af6 cd 52 8d			call toUpper 
9af9					if DEBUG_FORTH 
9af9						DMARK "NT1" 
9af9						CALLMONITOR 
9af9					endif 
9af9 b9				cp c 
9afa			 
9afa 28 03			jr z, .fnt2cmpmorefirst	 
9afc			 
9afc				; first char not found move to next char 
9afc			 
9afc 23				inc hl 
9afd 18 f4			jr .fnt1 
9aff			 
9aff			.fnt2cmpmorefirst:	 
9aff				; first char of token found.  
9aff			 
9aff e5				push hl     ; save start of token just in case it is the right one 
9b00 d9				exx 
9b01 e1				pop hl        ; save it to hl' 
9b02 d9				exx 
9b03			 
9b03			 
9b03			.fnt2cmpmore:	 
9b03				; compare the rest 
9b03				 
9b03 23				inc hl 
9b04 13				inc de 
9b05				 
9b05 1a				ld a, (de) 
9b06 4f				ld c,a 
9b07 7e				ld a,(hl) 
9b08 cd 52 8d			call toUpper 
9b0b			 
9b0b					if DEBUG_FORTH 
9b0b						DMARK "NT2" 
9b0b						CALLMONITOR 
9b0b					endif 
9b0b				; c has the token to find char 
9b0b				; a has the mem to scan char 
9b0b			 
9b0b b9				cp c 
9b0c 28 04			jr z,.fntmatch1 
9b0e			 
9b0e				; they are not the same 
9b0e			 
9b0e					if DEBUG_FORTH 
9b0e						DMARK "NT3" 
9b0e						CALLMONITOR 
9b0e					endif 
9b0e d1				pop de	; reset de token to look for 
9b0f d5				push de 
9b10 18 e1			jr .fnt1 
9b12				 
9b12			.fntmatch1: 
9b12			 
9b12				; is the same char a null which means we might have a full hit? 
9b12					if DEBUG_FORTH 
9b12						DMARK "NT4" 
9b12						CALLMONITOR 
9b12					endif 
9b12			 
9b12			;	cp 0 
9b12 b7				or a 
9b13 28 0b			jr z, .fntmatchyes 
9b15			 
9b15				; are we at the end of the token to find? 
9b15			 
9b15					if DEBUG_FORTH 
9b15						DMARK "NT5" 
9b15						CALLMONITOR 
9b15					endif 
9b15 3e 00			ld a, 0 
9b17 b9				cp c 
9b18			 
9b18 c2 03 9b			jp nz, .fnt2cmpmore    ; no, so keep going to a direct hit 
9b1b			 
9b1b					if DEBUG_FORTH 
9b1b						DMARK "NT6" 
9b1b						CALLMONITOR 
9b1b					endif 
9b1b				; token to find is exhusted but no match to stream 
9b1b			 
9b1b				; restore tok pointer and continue on 
9b1b d1				pop de 
9b1c d5				push de 
9b1d c3 f3 9a			jp .fnt1 
