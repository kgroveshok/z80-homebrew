d517 cb ff			set 7,a 
d519 32 72 ee		        ld (hardware_word+1),a 
d51c			 
d51c				; call user function 
d51c cd 6e ee			call nmi_vector 
d51f f5				push af 
d520 c5				push bc 
d521 d5				push de 
d522 e5				push hl 
d523 ed 45			retn 
