6ad8			; **********************************************************************  
6ad8			  
6ad8			; Write function to LCD  
6ad8			;   On entry: A = Function byte to be written  
6ad8			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6ad8 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6ada 18 02		            JR   WrFunc  
6adc 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6ade f5			WrFunc:     PUSH AF  
6adf f5					push af  
6ae0 3a fb fa				ld a, (display_lcde1e2)  
6ae3 fe 00				cp 0     ; e1  
6ae5 20 0f				jr nz, .wfea2	  
6ae7 f1					pop af  
6ae8 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6aea cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6aec cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6aee d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6af0 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6af2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6af4 18 0d			jr .wfskip  
6af6 f1			.wfea2:		pop af  
6af7 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6af9 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6afb cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6afd d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6aff cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b01 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b03 3e 05		.wfskip:            LD  A, 5  
6b05 cd 0c 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b08 f1			            POP  AF  
6b09 c9			            RET  
6b0a			  
6b0a			  
6b0a			; Delay in milliseconds  
6b0a			;   On entry: A = Number of milliseconds delay  
6b0a			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6b0a 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
6b0c d5			LCDDelay:   PUSH DE  
6b0d 5f			            LD   E, A           ;Delay by 'A' ms  
6b0e 16 00		            LD   D, 0  
6b10 cd 56 0a		            CALL aDelayInMS  
6b13 d1			            POP  DE  
6b14 c9			            RET  
