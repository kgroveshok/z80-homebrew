13ce			 
13ce					pop hl 
13ce					ex de,hl 
13ce					ld (hl), e 
13ce			 
13ce					if DEBUG_FORTH_WORDS 
13ce						DMARK "Cdi" 
13ce						CALLMONITOR 
13ce					endif 
