1163			if MALLOC_2 
1163			; Z80 Malloc and Free Functions 
1163			 
1163			; Malloc Function: 
1163			; Input: 
1163			;   HL: Size of block to allocate 
1163			; Output: 
1163			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1163			 
1163			malloc: 
1163				 
1163			if DEBUG_FORTH_MALLOC_HIGH 
1163			call malloc_guard_entry 
1163			endif 
1163			 
1163			 
1163			 
1163			 
1163					if DEBUG_FORTH_MALLOC 
1163						DMARK "mal" 
1163						CALLMONITOR 
1163					endif 
1163			    push af            ; Save AF register 
1163			    ld a, l            ; Load low byte of size into A 
1163			    or h               ; Check if size is zero 
1163			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1163			 
1163			    ; Allocate memory 
1163			    ld hl, (heap_start) ; Load start of heap into HL 
1163					if DEBUG_FORTH_MALLOC 
1163						DMARK "ma1" 
1163						CALLMONITOR 
1163					endif 
1163			    call malloc_internal ; Call internal malloc function 
1163			    pop af             ; Restore AF register 
1163			if DEBUG_FORTH_MALLOC_HIGH 
1163			call malloc_guard_exit 
1163			call malloc_guard_zerolen 
1163			endif 
1163			    ret                ; Return 
1163			 
1163			; Free Function: 
1163			; Input: 
1163			;   HL: Pointer to memory block to free 
1163			; Output: 
1163			;   None 
1163			 
1163			free: 
1163			    push af            ; Save AF register 
1163			    ld a, l            ; Load low byte of pointer into A 
1163			    or h               ; Check if pointer is NULL 
1163			    jp z, free_exit    ; If pointer is NULL, exit 
1163			 
1163			    ; Free memory 
1163			    ld hl, (heap_start) ; Load start of heap into HL 
1163			    call free_internal  ; Call internal free function 
1163			    pop af             ; Restore AF register 
1163			    ret                ; Return 
1163			 
1163			; Internal Malloc Function: 
1163			; Input: 
1163			;   HL: Size of block to allocate 
1163			; Output: 
1163			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1163			 
1163			malloc_internal: 
1163			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1163			    add hl, bc         ; Add management overhead to requested size 
1163			    ex de, hl          ; Save total size in DE, and keep it in HL 
1163					if DEBUG_FORTH_MALLOC 
1163						DMARK "ma2" 
1163						CALLMONITOR 
1163					endif 
1163			 
1163			    ; Search for free memory block 
1163			    ld de, (heap_end)  ; Load end of heap into DE 
1163			    ld bc, 0           ; Initialize counter 
1163			 
1163					if DEBUG_FORTH_MALLOC 
1163						DMARK "ma2" 
1163						CALLMONITOR 
1163					endif 
1163			malloc_search_loop: 
1163			    ; Check if current block is free 
1163			    ld a, (hl)         ; Load current block's status (free or used) 
1163			;    cp 0               ; Compare with zero (free) 
1163				or a 
1163			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1163			 
1163			    ; Check if current block is large enough 
1163			    ld a, (hl+1)       ; Load high byte of block size 
1163			    cp l               ; Compare with low byte of requested size 
1163			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1163			 
1163			    ld a, (hl+2)       ; Load low byte of block size 
1163			    cp h               ; Compare with high byte of requested size 
1163			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1163			 
1163			    ; Mark block as used 
1163			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1163			 
1163			    ; Calculate remaining space in block 
1163			    ld bc, 0           ; Clear BC 
1163			    add hl, bc         ; Increment HL to point to start of data block 
1163			    add hl, de         ; HL = HL + DE (total size) 
1163			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1163			    add hl, bc         ; Add management overhead to start of data block 
1163			 
1163			    ; Save pointer to allocated block in HL 
1163			if DEBUG_FORTH_MALLOC_HIGH 
1163						DMARK "ma5" 
1163			call malloc_guard_exit 
1163			call malloc_guard_zerolen 
1163			endif 
1163			    ret 
1163			 
1163			malloc_skip_block_check: 
1163			    ; Move to the next block 
1163			    ld bc, 3           ; Size of management overhead 
1163			    add hl, bc         ; Move to the next block 
1163			    inc de             ; Increment counter 
1163			 
1163			    ; Check if we have reached the end of heap 
1163			    ld a, e            ; Load low byte of heap end address 
1163			    cp (hl)            ; Compare with low byte of current address 
1163			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1163			    ld a, d            ; Load high byte of heap end address 
1163			;    cp 0               ; Check if it's zero (end of memory) 
1163				or a 
1163			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1163			 
1163			    ; If we reached here, allocation failed 
1163			    xor a              ; Set result to NULL 
1163			if DEBUG_FORTH_MALLOC_HIGH 
1163						DMARK "ma6" 
1163			call malloc_guard_exit 
1163			call malloc_guard_zerolen 
1163			endif 
1163			    ret 
1163			malloc_exit: 
1163			if DEBUG_FORTH_MALLOC_HIGH 
1163						DMARK "ma7" 
1163			call malloc_guard_exit 
1163			call malloc_guard_zerolen 
1163			endif 
1163			    ret 
1163			 
1163			; Internal Free Function: 
1163			; Input: 
1163			;   HL: Pointer to memory block to free 
1163			; Output: 
1163			;   None 
1163			 
1163			free_internal: 
1163			    ld de, (heap_start) ; Load start of heap into DE 
1163			    ld bc, 0            ; Initialize counter 
1163			 
1163			free_search_loop: 
1163			    ; Check if current block contains the pointer 
1163			    ld a, l             ; Load low byte of pointer 
1163			    cp (hl+1)           ; Compare with high byte of current block's address 
1163			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1163			    ld a, h             ; Load high byte of pointer 
1163			    cp (hl+2)           ; Compare with low byte of current block's address 
1163			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1163			 
1163			    ; Mark block as free 
1163			    ld (hl), 0          ; Set status byte to indicate free block 
1163			    ret                 ; Return 
1163			 
1163			free_skip_block_check: 
1163			    ; Move to the next block 
1163			    ld bc, 3            ; Size of management overhead 
1163			    add hl, bc          ; Move to the next block 
1163			    inc de              ; Increment counter 
1163			 
1163			    ; Check if we have reached the end of heap 
1163			    ld a, e             ; Load low byte of heap end address 
1163			    cp (hl)             ; Compare with low byte of current address 
1163			    jr nz, free_search_loop  ; If not equal, continue searching 
1163			    ld a, d             ; Load high byte of heap end address 
1163			;    cp 0                ; Check if it's zero (end of memory) 
1163				or a 
1163			    jr nz, free_search_loop  ; If not zero, continue searching 
1163			 
1163			    ; If we reached here, pointer is not found in heap 
1163			    ret 
1163			 
1163			free_exit: 
1163			    ret                 ; Return 
1163			 
1163			; Define heap start and end addresses 
1163			;heap_start:    .dw 0xC000   ; Start of heap 
1163			;heap_end:      .dw 0xE000   ; End of heap 
1163			 
1163			endif 
1163			 
1163			 
1163			if MALLOC_1 
