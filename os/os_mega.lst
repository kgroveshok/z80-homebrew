11d7			 
11d7			;------------------------------------------------------------------------------ 
11d7			;     free                                                                    : 
11d7			;                                                                             : 
11d7			; Description                                                                 : 
11d7			;     Return the space pointed to by HL to the heap. HL must be an address as : 
11d7			;     returned by malloc, otherwise the behaviour is undefined.               : 
11d7			;                                                                             : 
11d7			;     Where possible, directly adjacent free blocks will be merged together   : 
11d7			;     into larger blocks to help ensure that the heap does not become         : 
11d7			;     excessively fragmented.                                                 : 
11d7			;                                                                             : 
11d7			;     free does not clear or set any other value into the freed space, and    : 
11d7			;     therefore its contents may be visible through subsequent malloc's. The  : 
11d7			;     caller should clear the freed space as required.                        : 
11d7			;                                                                             : 
11d7			;     This implementation of free uses the stack exclusively, and is          : 
11d7			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
11d7			;     advisable to disable interrupts before calling free, and recommended    : 
11d7			;     to avoid the use of free inside ISRs in general.                        : 
11d7			;                                                                             : 
11d7			;     NOTE: heap_init must be called before malloc and free can be used.      : 
11d7			;                                                                             : 
11d7			; Parameters                                                                  : 
11d7			;     HL  Pointer to address of first byte of allocation to be freed          : 
11d7			;                                                                             : 
11d7			; Returns                                                                     : 
11d7			;     Nothing                                                                 : 
11d7			;                                                                             : 
11d7			; Stack frame                                                                 : 
11d7			;       |             |                                                       : 
11d7			;       +-------------+                                                       : 
11d7			;       |     BC      |                                                       : 
11d7			;       +-------------+                                                       : 
11d7			;       |     DE      |                                                       : 
11d7			;       +-------------+                                                       : 
11d7			;       |     IX      |                                                       : 
11d7			;       +-------------+                                                       : 
11d7			;       |  prev_free  |                                                       : 
11d7			;   +2  +-------------+                                                       : 
11d7			;       |  next_free  |                                                       : 
11d7			;   +0  +-------------+                                                       : 
11d7			;       |             |                                                       : 
11d7			;                                                                             : 
11d7			;------------------------------------------------------------------------------ 
11d7			free: 
11d7 c5			      push  BC 
11d8 d5			      push  DE 
11d9 dd e5		      push  IX 
11db			 
11db 7c			      ld    A, H                    ; Exit if ptr is null 
11dc b5			      or    L 
11dd ca a1 12		      jp    Z, free_early_exit 
11e0			 
11e0			      ; Set up stack frame 
11e0 eb			      ex    DE, HL 
11e1 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
11e4 39			      add   HL, SP 
11e5 f9			      ld    SP, HL 
11e6 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
11ea dd 39		      add   IX, SP 
11ec			 
11ec			      ; The address in HL points to the start of the useable allocated space, 
11ec			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
11ec			      ; address of the block itself. 
11ec eb			      ex    DE, HL 
11ed 11 fc ff		      ld    DE, -4 
11f0 19			      add   HL, DE 
11f1			 
11f1			      ; An allocated block must have a null next block pointer in it 
11f1 7e			      ld    A, (HL) 
11f2 23			      inc   HL 
11f3 b6			      or    (HL) 
11f4 c2 9c 12		      jp    NZ, free_done 
11f7			 
11f7 2b			      dec   HL 
11f8			 
11f8 44			      ld    B, H                    ; Copy HL to BC 
11f9 4d			      ld    C, L 
11fa			 
11fa			      ; Loop through the free list to find the first block with an address 
11fa			      ; higher than the block being freed 
11fa 21 0a 80		      ld    HL, free_list 
11fd			 
11fd			free_find_higher_block: 
11fd 5e			      ld    E, (HL)                 ; Load next ptr from free block 
11fe 23			      inc   HL 
11ff 56			      ld    D, (HL) 
1200 2b			      dec   HL 
1201			 
1201 dd 73 00		      ld    (IX+0), E               ; Save ptr to next free block 
1204 dd 72 01		      ld    (IX+1), D 
1207 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
120a dd 74 03		      ld    (IX+3), H 
120d			 
120d 78			      ld    A, B                    ; Check if DE is greater than BC 
120e ba			      cp    D                       ; Compare MSB first 
120f 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
1211 30 04		      jr    NC, free_find_higher_block_skip 
1213 79			      ld    A, C 
1214 bb			      cp    E                       ; Then compare LSB 
1215 38 08		      jr    C, free_found_higher_block 
1217			 
