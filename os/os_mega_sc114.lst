9da5				OPCODE_CAT: equ 12 
9da5				OPCODE_BANG: equ 13 
9da5				OPCODE_CBANG: equ 14 
9da5				OPCODE_SCALL: equ 15 
9da5				OPCODE_DEPTH: equ 16 
9da5				OPCODE_OVER: equ 17 
9da5				OPCODE_PAUSE: equ 18 
9da5				OPCODE_PAUSES: equ 19 
9da5				OPCODE_ROT: equ 20 
9da5			;free to reuse	OPCODE_WORDS: equ 21 
9da5			        OPCODE_NOT: equ 21 
