68e4			lcd_init:  
68e4			  
68e4			; SCMonAPI functions used  
68e4			  
68e4			; Alphanumeric LCD functions used  
68e4			; no need to specify specific functions for this module  
68e4			  
68e4 3e cf		            LD   A, 11001111b  
68e6 d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
68e8 3e 00		            LD   A, 00000000b  
68ea d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
68ec			  
