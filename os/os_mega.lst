00a0			; Macro to make adding debug marks easier  
00a0			  
00a0			  
00a0			  
00a0			DMARK: macro str  
00a0			  
00a0				if DEMARK_VERSION = 1  
00a0					push hl  
00a0					ld hl, .dmark  
00a0					ld (debug_mark), hl  
00a0				endif  
00a0			  
00a0			  
00a0				if DEMARK_VERSION = 0  
00a0					push af  
00a0					ld a, (.dmark)  
00a0					ld (debug_mark),a  
00a0					ld a, (.dmark+1)  
00a0					ld (debug_mark+1),a  
00a0					ld a, (.dmark+2)  
00a0					ld (debug_mark+2),a  
00a0			  
00a0				endif  
00a0			  
00a0				jr .pastdmark  
00a0			.dmark: db str  
00a0			  
00a0				if DEMARK_VERSION = 1  
00a0					; add a terminator as this is printed direct  
00a0					; other version stuffs into a buffer  
00a0					db 0  
00a0				endif  
00a0			  
00a0			; skip string  
00a0			  
00a0				if DEMARK_VERSION = 1  
00a0			.pastdmark: pop hl  
00a0				endif  
00a0			  
00a0				if DEMARK_VERSION = 0  
00a0			.pastdmark: pop af  
00a0				endif  
00a0			  
00a0			endm  
00a0			  
00a0			  
00a0			; macro to detect for stack imbalances  
00a0			  
00a0			include "stackimbal.asm"  
00a0			; Macro and code to detect stock imbalances 
00a0			 
00a0			SPPUSH: equ 0 
00a0			 
00a0			; Add a stack frame which can be checked before return 
00a0			 
00a0			STACKFRAME: macro onoff frame1 frame2 
00a0			 
00a0				if DEBUG_STACK_IMB 
00a0					if onoff 
00a0						; save current SP 
00a0						exx 
00a0			 
00a0						ld de, frame1 
00a0						ld a, d 
00a0						ld hl, curframe 
00a0						call hexout 
00a0						ld a, e 
00a0						ld hl, curframe+2 
00a0						call hexout 
00a0			  
00a0						ld hl, frame1 
00a0						push hl 
00a0						ld hl, frame2 
00a0						push hl 
00a0						exx 
00a0					endif 
00a0					 
00a0				endif 
00a0			endm 
00a0			 
00a0			STACKFRAMECHK: macro onoff frame1 frame2 
00a0			 
00a0					 
00a0				if DEBUG_STACK_IMB 
00a0					if onoff 
00a0						exx 
00a0						; check stack frame SP 
00a0			 
00a0						ld hl, frame2 
00a0						pop de   ; frame2 
00a0			 
00a0						call cmp16 
00a0						jr nz, .spnosame 
00a0						 
00a0			 
00a0						ld hl, frame1 
00a0						pop de   ; frame1 
00a0			 
00a0						call cmp16 
00a0						jr z, .spfrsame 
00a0			 
00a0						.spnosame: call showsperror 
00a0			 
00a0						.spfrsame: nop 
00a0			 
00a0						exx 
00a0					endif 
00a0					 
00a0				endif 
00a0			 
00a0			 
00a0			endm 
00a0			 
00a0			 
00a0			; for a sub routine, wrap SP collection and comparisons 
00a0			 
00a0			; Usage: 
00a0			; 
00a0			; SAVESP ON/OFF 0-STACK_IMB_STORE/4 
00a0			; CHECKSP ON/OFF 0-STACK_IMB_STORE/4 
00a0			 
00a0			SAVESP: macro onoff storeword 
00a0			 
00a0				if DEBUG_STACK_IMB 
00a0					if onoff 
00a0						; save current SP 
00a0			 
00a0						ld (store_sp+(storeword*4)), sp 
00a0			 
00a0					endif 
00a0					 
00a0				endif 
00a0			 
00a0			endm 
00a0			 
00a0			CHECKSP: macro onoff storeword 
00a0			 
00a0				if DEBUG_STACK_IMB 
00a0					if onoff 
00a0			 
00a0						; save SP after last save 
00a0				 
00a0						ld (store_sp+(storeword*4)+2), sp 
00a0			 
00a0						push hl 
00a0						ld hl, store_sp+(storeword*4) 
00a0						call check_stack_sp  
00a0						pop hl 
00a0			 
00a0			 
00a0					endif 
00a0					 
00a0				endif 
00a0			 
00a0			endm 
00a0			 
00a0			if DEBUG_STACK_IMB 
00a0			 
00a0			check_stack_sp: 
00a0					push de 
00a0			 
00a0					ld e, (hl) 
00a0					inc hl 
00a0					ld d, (hl) 
00a0					inc hl 
00a0			 
00a0					push de 
00a0			 
00a0			 
00a0					ld e, (hl) 
00a0					inc hl 
00a0					ld d, (hl) 
00a0					inc hl 
00a0			 
00a0					pop hl 
00a0			 
00a0			 
00a0					; check to see if the same 
00a0			 
00a0					call cmp16 
00a0					jr z, .spsame 
00a0			 
00a0					; not same 
00a0			 
00a0					call showsperror 
00a0			.spsame: 
00a0			 
00a0					pop de 
00a0			 
00a0					ret 
00a0			 
00a0			.sperr:  db "Stack imbalance",0 
00a0			 
00a0			 
00a0			showsperror: 
00a0			 
00a0			 
00a0				push hl 
00a0				push af 
00a0				push de 
00a0				call clear_display 
00a0				ld de, .sperr 
00a0				ld a,0 
00a0			;	ld de,os_word_scratch 
00a0				call str_at_display 
00a0				ld a, display_row_1+17 
00a0				ld de, debug_mark 
00a0				call str_at_display 
00a0				ld a, 0 
00a0				ld (curframe+4),a 
00a0				ld hl, curframe 
00a0				ld de, os_word_scratch 
00a0				ld a, display_row_4 
00a0				call str_at_display 
00a0				call update_display 
00a0				;call break_point_state 
00a0				call cin_wait 
00a0			 
00a0			;	ld a, ' ' 
00a0			;	ld (os_view_disable), a 
00a0				call bp_on 
00a0				pop de	 
00a0				pop af 
00a0				pop hl 
00a0				CALLMONITOR 
00a0				ret 
00a0			 
00a0			endif 
00a0			 
00a0			 
00a0			 
00a0			; eof 
# End of file stackimbal.asm
