1107				ld de, 255 
1107				sbc hl, de 
1107				jr c, .lowalloc 
1107			 
1107				push de 
1107					ld hl, display_fb0 
1107					ld (display_fb_active), hl 
1107				call clear_display 
1107				ld a, 0 
1107				ld de, .mallocsize 
1107				call str_at_display 
1107				call update_display 
1107				call delay1s 
1107				call delay1s 
1107			;	ld a, 0 
