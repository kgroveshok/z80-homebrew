69ae 18 02		            JR   WrFunc  
69b0 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
69b2 f5			WrFunc:     PUSH AF  
69b3 f5					push af  
69b4 3a fb fa				ld a, (display_lcde1e2)  
69b7 fe 00				cp 0     ; e1  
69b9 20 0f				jr nz, .wfea2	  
69bb f1					pop af  
69bc d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69be cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
69c0 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
69c2 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
69c4 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
69c6 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69c8 18 0d			jr .wfskip  
69ca f1			.wfea2:		pop af  
69cb d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69cd cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
69cf cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
69d1 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
69d3 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
69d5 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
69d7 3e 05		.wfskip:            LD  A, 5  
69d9 cd e0 69		            CALL LCDDelay       ;Delay 5 ms to complete  
69dc f1			            POP  AF  
69dd c9			            RET  
69de			  
69de			  
69de			; Delay in milliseconds  
69de			;   On entry: A = Number of milliseconds delay  
69de			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
69de 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
69e0 d5			LCDDelay:   PUSH DE  
69e1 5f			            LD   E, A           ;Delay by 'A' ms  
69e2 16 00		            LD   D, 0  
69e4 cd 53 0a		            CALL aDelayInMS  
69e7 d1			            POP  DE  
69e8 c9			            RET  
