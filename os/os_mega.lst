# End of macro CWHEAD
5119			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5119			; | 
5119			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5119			; | |  
5119			; | | e.g. 
5119			; | |         #30 a var ! 
5119			; | |         a var @ . 
5119			; | |   
5119			; | |     Displays the number 30 
5119			; | | 
5119			; | | Each variable pointer is a word so can use for any words that use that:  
5119			; | |  
5119			; | | e.g. 
5119			; | |  
5119			; | |         #30 a var 2! 
5119			; | |         a var 2@ . 
5119			; | |   
5119			; | |     Displays the number 30 
5119			; | |  
5119			; | | > [!NOTE]  
5119			; ! | > If a full string is passed then only the first char is looked at 
5119			; | | > Any other char could exceed bounds checks!  
5119			; | | > 
5119			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5119			 
5119					if DEBUG_FORTH_WORDS_KEY 
5119						DMARK "VAR" 
5119				if DEMARK_VERSION = 1  
5119 e5					push hl  
511a 21 22 51				ld hl, .dmark  
511d 22 9b fd				ld (debug_mark), hl  
5120				endif  
5120				if DEMARK_VERSION = 0  
5120					push af  
5120					ld a, (.dmark)  
5120					ld (debug_mark),a  
5120					ld a, (.dmark+1)  
5120					ld (debug_mark+1),a  
5120					ld a, (.dmark+2)  
5120					ld (debug_mark+2),a  
5120				endif  
5120 18 04			jr .pastdmark  
5122 ..			.dmark: db "VAR"  
5125				if DEMARK_VERSION = 1  
5125 00					db 0  
5126				endif  
5126				if DEMARK_VERSION = 1  
5126 e1			.pastdmark: pop hl  
5127				endif  
5127				if DEMARK_VERSION = 0  
5127			.pastdmark: pop af  
5127				endif  
5127			endm  
# End of macro DMARK
5127						CALLMONITOR 
5127				if BASE_CPM=1  
5127					call debug_vector  
5127				endif  
