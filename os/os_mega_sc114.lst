89a1			 
89a1			; Display an activity indicator 
89a1			; Each call returns the new char pointed to in hl 
89a1			 
89a1			active: 
89a1 3a b9 eb			ld a, (display_active) 
89a4 fe 06			cp 6 
89a6			 
89a6 20 02			jr nz, .sne 
89a8				; gone past the last one reset sequence 
89a8 3e ff			ld a, 255 
89aa			 
89aa			.sne:   
89aa				; get the next char in seq 
89aa 3c				inc a 
89ab 32 b9 eb			ld (display_active), a 
89ae			 
89ae				; look up the string in the table 
89ae 21 c5 89			ld hl, actseq 
89b1 cb 27			sla a 
89b3 cd 73 8c			call addatohl 
89b6 cd 9d 9c			call loadwordinhl 
89b9			 
89b9				; forth will write the to string when pushing so move from rom to ram 
89b9			 
89b9 11 ba eb			ld de, display_active+1 
89bc 01 02 00			ld bc, 2 
89bf ed b0			ldir 
89c1			 
