6ed7 11 0b fe		            LD   DE, keyscan_table_row4  
6eda cd 05 6b		            CALL fLCD_Str       ;Display string pointed to by DE  
6edd			  
6edd cd 68 0a			call delay250ms  
6ee0 c3 d3 6d			jp matrix  
6ee3			  
6ee3			; pass de as row display flags  
6ee3			.rowscan:   
6ee3			;	out (portbdata),a  
6ee3 db c1			in a,(portbdata)  
6ee5 4f				ld c,a  
6ee6				; reset flags for the row   
6ee6 06 7e			ld b,KEY_MATRIX_NO_PRESS  
6ee8 e6 01			and 1  
6eea 28 02			jr z, .p1on  
6eec 06 23			ld b,'#'  
6eee			.p1on:  
6eee 70				ld (hl), b  
6eef 23				inc hl  
6ef0			  
6ef0 06 7e			ld b,KEY_MATRIX_NO_PRESS  
6ef2 79				ld a,c  
6ef3 e6 02			and 2  
6ef5			;	bit 0,a  
6ef5 28 02			jr z, .p2on  
6ef7 06 23			ld b,'#'  
6ef9			.p2on:  
6ef9 70				ld (hl), b  
6efa 23				inc hl  
6efb			;  
6efb 06 7e			ld b,KEY_MATRIX_NO_PRESS  
6efd 79				ld a,c  
6efe e6 04			and 4  
6f00			;;	bit 0,a  
6f00 28 02			jr z, .p3on  
6f02 06 23			ld b,'#'  
6f04			.p3on:  
6f04 70				ld (hl), b  
6f05 23				inc hl  
6f06			;;  
6f06 06 7e			ld b,KEY_MATRIX_NO_PRESS  
6f08			;;	bit 0,a  
6f08 79				ld a,c  
6f09 e6 08			and 8  
6f0b 28 02			jr z, .p4on  
6f0d 06 23			ld b,'#'  
6f0f			.p4on:  
6f0f 70				ld (hl), b  
6f10 23				inc hl  
6f11			  
6f11 06 7e			ld b,KEY_MATRIX_NO_PRESS  
6f13			;;	bit 0,a  
6f13 79				ld a,c  
6f14 e6 10			and 16  
6f16 28 02			jr z, .p5on  
6f18 06 23			ld b,'#'  
6f1a			.p5on:  
6f1a 70				ld (hl), b  
6f1b 23				inc hl  
6f1c			; zero term  
6f1c			;	ld b,0  
6f1c 36 00			ld (hl), 0  
6f1e			  
6f1e c9			.rscandone: ret  
