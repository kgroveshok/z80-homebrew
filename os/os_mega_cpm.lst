106d dd 72 01		      ld    (IX+1), D 
1070 dd 75 02		      ld    (IX+2), L               ; Save ptr to prev free block 
1073 dd 74 03		      ld    (IX+3), H 
1076			 
1076 78			      ld    A, B                    ; Check if DE is greater than BC 
1077 ba			      cp    D                       ; Compare MSB first 
1078 28 02		      jr    Z, $+4                  ; MSB the same, compare LSB 
107a 30 04		      jr    NC, free_find_higher_block_skip 
107c 79			      ld    A, C 
107d bb			      cp    E                       ; Then compare LSB 
107e 38 08		      jr    C, free_found_higher_block 
1080			 
1080			free_find_higher_block_skip: 
1080 7a			      ld    A, D                    ; Reached the end of the free list? 
1081 b3			      or    E 
1082 ca 05 11		      jp    Z, free_done 
1085			 
1085 eb			      ex    DE, HL 
1086			 
1086 18 de		      jr    free_find_higher_block 
