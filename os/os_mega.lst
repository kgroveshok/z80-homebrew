6b30 f5					push af  
6b31 3a fb fa				ld a, (display_lcde1e2)  
6b34 fe 00				cp 0     ; e1  
6b36 20 0f				jr nz, .wfea2	  
6b38 f1					pop af  
6b39 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b3b cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6b3d cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b3f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b41 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b43 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b45 18 0d			jr .wfskip  
6b47 f1			.wfea2:		pop af  
6b48 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b4a cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6b4c cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b4e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b50 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b52 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b54 3e 05		.wfskip:            LD  A, 5  
6b56 cd 5d 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b59 f1			            POP  AF  
6b5a c9			            RET  
