1107				push de 
1107				push af 
1107			 
1107			 	or a      ;clear carry flag 
1107				push hl 
1107				ld de, 255 
1107				sbc hl, de 
1107				jr c, .lowallocx 
1107			 
1107				push de 
1107					ld hl, display_fb0 
1107					ld (display_fb_active), hl 
