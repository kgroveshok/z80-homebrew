a489					ld (debug_mark+1),a  
a489					ld a, (.dmark+2)  
a489					ld (debug_mark+2),a  
a489				endif  
a489 18 04			jr .pastdmark  
a48b ..			.dmark: db "BP."  
a48e				if DEMARK_VERSION = 1  
a48e 00					db 0  
a48f				endif  
a48f				if DEMARK_VERSION = 1  
a48f e1			.pastdmark: pop hl  
a490				endif  
a490				if DEMARK_VERSION = 0  
