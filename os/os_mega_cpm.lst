3aac				endif 
3aac				if BASE_KEV=1 
3aac					rst $10 
3aac				endif 
3aac				endm 
# End of macro FORTH_DSP_POP
3aac			 
3aac				; allocate memory for (count + 1 ) * 2 for word array plus zero pointer 
3aac			 
3aac					; l contains count 
3aac			 
3aac 7d					ld a,l 
3aad 32 a5 e2				ld (scratch), a     ; save it for the loading loop 
3ab0			 
3ab0 2c					inc l  ; for zero pointer 
3ab1 eb					ex de, hl 
3ab2 3e 02				ld a, 2 
3ab4 cd 61 0b				call Mult16 
3ab7			 
3ab7					; hl is the size of block to allocate 
3ab7			 
3ab7 cd aa 0f				call malloc 
3aba				if DEBUG_FORTH_MALLOC_GUARD 
3aba cc 6d 46				call z,malloc_error 
3abd				endif 
3abd					; hl is the pointer to the array block 
3abd						 
3abd 22 a6 e2				ld (scratch+1), hl    ; save the base for later push to stack 
3ac0 22 a8 e2				ld (scratch+3), hl    ; save the base for current string to push 
3ac3			 
3ac3 3a a5 e2				ld a, (scratch) 
3ac6 47					ld b, a 
3ac7			 
3ac7				; for each string 
3ac7			 
3ac7			.tablelop: 
3ac7			 
3ac7 c5					push bc 
3ac8			 
3ac8				;     get string pointer 
