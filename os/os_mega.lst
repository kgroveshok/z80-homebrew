10cc			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
10cc			 
10cc			toUpper: 
10cc			;A is the char. 
10cc			;If A is a lowercase letter, this sets it to the matching uppercase 
10cc			;18cc or 30cc or 41cc 
10cc			;avg: 26.75cc 
10cc fe 61		  cp 'a' 
10ce d8			  ret c 
10cf fe 7b		  cp 'z'+1 
10d1 d0			  ret nc 
10d2 d6 20		  sub 'a'-'A' 
10d4 c9			  ret 
