8eda 21 fc ff		      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8edd 39			      add   HL, SP 
8ede f9			      ld    SP, HL 
8edf dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
8ee3 dd 39		      add   IX, SP 
