# End of macro CWHEAD
5244			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5244			; | 
5244			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5244			; | |  
5244			; | | e.g. 
5244			; | |         #30 a var ! 
5244			; | |         a var @ . 
5244			; | |   
5244			; | |     Displays the number 30 
5244			; | | 
5244			; | | Each variable pointer is a word so can use for any words that use that:  
5244			; | |  
5244			; | | e.g. 
5244			; | |  
5244			; | |         #30 a var 2! 
5244			; | |         a var 2@ . 
5244			; | |   
5244			; | |     Displays the number 30 
5244			; | |  
5244			; | | > [!NOTE]  
5244			; ! | > If a full string is passed then only the first char is looked at 
5244			; | | > Any other char could exceed bounds checks!  
5244			; | | > 
5244			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5244			 
5244					if DEBUG_FORTH_WORDS_KEY 
5244						DMARK "VAR" 
