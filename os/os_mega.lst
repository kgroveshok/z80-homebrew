6af6 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6af8 cd 57 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6afb f1			            POP  AF  
6afc c9			            RET  
