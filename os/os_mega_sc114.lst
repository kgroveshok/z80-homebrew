9dfc					ld (debug_mark+1),a  
9dfc					ld a, (.dmark+2)  
9dfc					ld (debug_mark+2),a  
9dfc				endif  
9dfc 18 04			jr .pastdmark  
9dfe ..			.dmark: db "DUP"  
9e01				if DEMARK_VERSION = 1  
9e01 00					db 0  
9e02				endif  
9e02				if DEMARK_VERSION = 1  
