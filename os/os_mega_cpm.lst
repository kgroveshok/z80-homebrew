0f86			 
0f86			malloc_guard_entry: 
0f86				push hl 
0f86				push de 
0f86				push af 
0f86			 
0f86			 	or a      ;clear carry flag 
0f86				push hl 
0f86				ld de, 255 
0f86				sbc hl, de 
0f86				jr c, .lowalloc 
0f86			 
0f86				push de 
0f86					ld hl, display_fb0 
0f86					ld (display_fb_active), hl 
0f86				call clear_display 
0f86				ld a, 0 
0f86				ld de, .mallocsize 
0f86				call str_at_display 
0f86				call update_display 
0f86				call delay1s 
0f86				call delay1s 
0f86			;	ld a, 0 
0f86			;	ld (os_view_disable), a 
0f86				call bp_on 
0f86			 
0f86				pop de 
0f86				pop hl 
0f86			 
0f86				 
0f86			 
0f86				CALLMONITOR 
0f86				jr .lowdone 
0f86			.lowalloc: 
0f86			 
0f86			 
0f86				pop hl 
0f86			.lowdone:	pop af 
0f86				pop de 
0f86				pop hl 
0f86			ret 
0f86			 
0f86			malloc_guard_exit: 
0f86				push hl 
0f86				push de 
0f86				push af 
0f86			 
0f86			 	or a      ;clear carry flag 
0f86				push hl 
0f86				ld de, 255 
0f86				sbc hl, de 
0f86				jr c, .lowallocx 
0f86			 
0f86				push de 
0f86					ld hl, display_fb0 
0f86					ld (display_fb_active), hl 
0f86				call clear_display 
0f86				ld a, 0 
0f86				ld de, .mallocasize 
0f86				call str_at_display 
0f86				call update_display 
0f86				call delay1s 
0f86				call delay1s 
