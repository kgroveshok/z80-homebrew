13ce			config_fdir: 
13ce				; using the scratch dir go through and release the memory allocated for each string 
13ce				 
13ce				ld hl, scratch 
13ce			.cfdir:	ld e,(hl) 
13ce				inc hl 
13ce				ld d,(hl) 
13ce				inc hl 
13ce			 
13ce				ex de, hl 
13ce				call ishlzero 
13ce				ret z     ; return on null pointer 
13ce				call free 
13ce				ex de, hl 
13ce				jr .cfdir 
13ce			 
13ce			 
13ce				ret 
