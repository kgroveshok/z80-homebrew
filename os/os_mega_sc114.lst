9b90			user_word_eol:  
9b90				; hl contains the pointer to where to create a linked list item from the end 
9b90				; of the user dict to continue on at the system word dict 
9b90				 
9b90				; poke the stub of the word list linked list to repoint to rom words 
9b90			 
9b90				; stub format 
9b90				; db   word id 
9b90				; dw    link to next word 
9b90			        ; db char length of token 
9b90				; db string + 0 term 
9b90				; db exec code....  
9b90			 
9b90			;	ld a, WORD_SYS_ROOT     ; root word 
9b90 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9b92 23				inc hl 
9b93			 
9b93 11 3c 9d			ld de, sysdict 
9b96 73				ld (hl), e		; next word link ie system dict 
9b97 23				inc hl 
9b98 72				ld (hl), d		; next word link ie system dict 
9b99 23				inc hl	 
9b9a			 
9b9a			;	ld (hl), sysdict		; next word link ie system dict 
9b9a			;	inc hl 
9b9a			;	inc hl 
9b9a			 
9b9a			;	inc hl 
9b9a			;	inc hl 
9b9a			 
9b9a			;	ld a, 2			; word length is 0 
9b9a 36 02			ld (hl), 2 
9b9c 23				inc hl 
9b9d			 
9b9d			;	ld a, '~'			; word length is 0 
9b9d 36 7e			ld (hl), '~' 
9b9f 23				inc hl 
9ba0			;	ld a, 0			; save empty word 
9ba0 36 00			ld (hl), 0 
