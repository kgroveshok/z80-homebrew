12a6			if MALLOC_3 
12a6			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
12a6			;heap_start        .equ  0x9000      ; Starting address of heap 
12a6			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
12a6			; 
12a6			 ;     .org 0 
12a6			  ;    jp    main 
12a6			; 
12a6			; 
12a6			 ;     .org  0x100 
12a6			;main: 
12a6			 ;     ld    HL, 0x8100 
12a6			  ;    ld    SP, HL 
12a6			; 
12a6			;      call  heap_init 
12a6			 
12a6			      ; Make some allocations 
12a6			;      ld    HL, 12 
12a6			;      call  malloc            ; Allocates 0x9004 
12a6			; 
12a6			 ;     ld    HL, 12 
12a6			;      call  malloc            ; Allocates 0x9014 
12a6			 
12a6			;      ld    HL, 12 
12a6			;      call  malloc            ; Allocates 0x9024 
12a6			 
12a6			      ; Free some allocations 
12a6			;      ld    HL, 0x9014 
12a6			;      call  free 
12a6			 
12a6			;      ld    HL, 0x9004 
12a6			;      call  free 
12a6			; 
12a6			;      ld    HL, 0x9024 
12a6			;      call  free 
12a6			 
12a6			 
12a6			 ;     halt 
12a6			 
12a6			 
12a6			;------------------------------------------------------------------------------ 
12a6			;     heap_init                                                               : 
12a6			;                                                                             : 
12a6			; Description                                                                 : 
12a6			;     Initialise the heap and make it ready for malloc and free operations.   : 
12a6			;                                                                             : 
12a6			;     The heap is maintained as a linked list, starting with an initial       : 
12a6			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
12a6			;     the first free block in the heap. Each block then points to the next    : 
12a6			;     free block within the heap, and the free list ends at the first block   : 
12a6			;     with a null pointer to the next free block.                             : 
12a6			;                                                                             : 
12a6			; Parameters                                                                  : 
12a6			;     Inputs are compile-time only. Two defines which specify the starting    : 
12a6			;     address of the heap and its size are required, along with a memory      : 
12a6			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
12a6			;     principally stores a pointer to the first free block in the heap.       : 
12a6			;                                                                             : 
12a6			; Returns                                                                     : 
12a6			;     Nothing                                                                 : 
12a6			;------------------------------------------------------------------------------ 
12a6			heap_init: 
12a6			      push  HL 
12a6			 
12a6			      ; Initialise free list struct 
12a6			      ld    HL, heap_start 
12a6			      ld    (free_list), HL 
12a6			      ld    HL, 0 
12a6			      ld    (free_list+2), HL 
12a6			 
12a6			      ; Insert first free block at bottom of heap, consumes entire heap 
12a6			      ld    HL, heap_start+heap_size-4 
12a6			      ld    (heap_start), HL        ; Next block (end of free list) 
12a6			      ld    HL, heap_size-4 
12a6			      ld    (heap_start+2), HL      ; Block size 
12a6			 
12a6			      ; Insert end of free list block at top of heap - two null words will 
12a6			      ; terminate the free list 
12a6			      ld    HL, 0 
12a6			      ld    (heap_start+heap_size-2), HL 
12a6			      ld    (heap_start+heap_size-4), HL 
12a6			 
12a6			      pop   HL 
12a6			 
12a6			      ret 
12a6			 
12a6			 
12a6			;------------------------------------------------------------------------------ 
12a6			;     malloc                                                                  : 
12a6			;                                                                             : 
12a6			; Description                                                                 : 
12a6			;     Allocates the wanted space from the heap and returns the address of the : 
12a6			;     first useable byte of the allocation.                                   : 
12a6			;                                                                             : 
12a6			;     Allocations can happen in one of two ways:                              : 
12a6			;                                                                             : 
12a6			;     1. A free block may be found which is the exact size wanted. In this    : 
12a6			;        case the block is removed from the free list and retuedn to the      : 
12a6			;        caller.                                                              : 
12a6			;     2. A free block may be found which is larger than the size wanted. In   : 
12a6			;        this case, the larger block is split into two. The first portion of  : 
12a6			;        this block will become the requested space by the malloc call and    : 
12a6			;        is returned to the caller. The second portion becomes a new free     : 
12a6			;        block, and the free list is adjusted to maintain continuity via this : 
12a6			;        newly created block.                                                 : 
12a6			;                                                                             : 
12a6			;     malloc does not set any initial value in the allocated space, the       : 
12a6			;     caller is required to do this as required.                              : 
12a6			;                                                                             : 
12a6			;     This implementation of malloc uses the stack exclusively, and is        : 
12a6			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12a6			;     advisable to disable interrupts before calling malloc, and recommended  : 
12a6			;     to avoid the use of malloc inside ISRs in general.                      : 
12a6			;                                                                             : 
12a6			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12a6			;                                                                             : 
12a6			; Parameters                                                                  : 
12a6			;     HL  Number of bytes wanted                                              : 
12a6			;                                                                             : 
12a6			; Returns                                                                     : 
12a6			;     HL  Address of the first useable byte of the allocation                 : 
12a6			;                                                                             : 
12a6			; Flags                                                                       : 
12a6			;     Z   Set if the allocation did not succeed, clear otherwise              : 
12a6			;                                                                             : 
12a6			; Stack frame                                                                 : 
12a6			;       |             |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |     BC      |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |     DE      |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |     IX      |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |  prev_free  |                                                       : 
12a6			;   +4  +-------------+                                                       : 
12a6			;       |  this_free  |                                                       : 
12a6			;   +2  +-------------+                                                       : 
12a6			;       |  next_free  |                                                       : 
12a6			;   +0  +-------------+                                                       : 
12a6			;       |             |                                                       : 
12a6			;                                                                             : 
12a6			;------------------------------------------------------------------------------ 
12a6			malloc: 
12a6			      push  BC 
12a6			      push  DE 
12a6			      push  IX 
12a6			 
12a6			      ld    A, H                    ; Exit if no space requested 
12a6			      or    L 
12a6			      jp    Z, malloc_early_exit 
12a6			 
12a6			      ; Set up stack frame 
12a6			      ex    DE, HL 
12a6			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
12a6			      add   HL, SP 
12a6			      ld    SP, HL 
12a6			      ld    IX, 0                   ; Use IX as a frame pointer 
12a6			      add   IX, SP 
12a6			 
12a6			      ; Setup initial state 
12a6			      ld    HL, 4                   ; want must also include space used by block struct 
12a6			      add   HL, DE 
12a6			 
12a6			      ld    B, H                    ; Move want to BC 
12a6			      ld    C, L 
12a6			 
12a6			      ld    HL, free_list           ; Store prev_free ptr to stack 
12a6			      ld    (IX+4), L 
12a6			      ld    (IX+5), H 
12a6			 
12a6			      ld    E, (HL)                 ; Store this_free ptr to stack 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      ld    (IX+2), E 
12a6			      ld    (IX+3), D 
12a6			      ex    DE, HL                  ; this_free ptr into HL 
12a6			 
12a6			      ; Loop through free block list to find some space 
12a6			malloc_find_space: 
12a6			      ld    E, (HL)                 ; Load next_free ptr into DE 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			 
12a6			      ld    A, D                    ; Check for null next_free ptr - end of free list 
12a6			      or    E 
12a6			      jp    Z, malloc_no_space 
12a6			 
12a6			      ld    (IX+0), E               ; Store next_free ptr to stack 
12a6			      ld    (IX+1), D 
12a6			 
12a6			      ; Does this block have enough space to make the allocation? 
12a6			      inc   HL                      ; Load free block size into DE 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			 
12a6			      ex    DE, HL                  ; Check size of block against want 
12a6			      or    A                       ; Ensure carry flag clear 
12a6			      sbc   HL, BC 
12a6			      push  HL                      ; Store the result for later (new block size) 
12a6			 
12a6			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
12a6			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
12a6			 
12a6			      ; this_free block is not big enough, setup ptrs to test next free block 
12a6			      pop   HL                      ; Discard previous result 
12a6			 
12a6			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
12a6			      ld    H, (IX+3) 
12a6			      ld    (IX+4), L 
12a6			      ld    (IX+5), H 
12a6			 
12a6			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
12a6			      ld    H, (IX+1) 
12a6			      ld    (IX+2), L 
12a6			      ld    (IX+3), H 
12a6			 
12a6			      jr    malloc_find_space 
12a6			 
12a6			      ; split a bigger block into two - requested size and remaining size 
12a6			malloc_alloc_split: 
12a6			      ex    DE, HL                  ; Calculate address of new free block 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			      add   HL, BC 
12a6			 
12a6			      ; Create a new block and point it at next_free 
12a6			      ld    E, (IX+0)               ; Load next_free ptr into DE 
12a6			      ld    D, (IX+1) 
12a6			 
12a6			      ld    (HL), E                 ; Store next_free ptr into new block 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			      pop   DE                      ; Store size of new block into new block 
12a6			      inc   HL 
12a6			      ld    (HL), E 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			      ; Update this_free ptr to point to new block 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			 
12a6			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
12a6			      ld    D, (IX+3) 
12a6			 
12a6			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
12a6			      ld    (IX+3), H 
12a6			 
12a6			      ; Modify this_free block to be allocation 
12a6			      ex    DE, HL 
12a6			      xor   A                       ; Null the next block ptr of allocated block 
12a6			      ld    (HL), A 
12a6			      inc   HL 
12a6			      ld    (HL), A 
12a6			 
12a6			      inc   HL                      ; Store want size into allocated block 
12a6			      ld    (HL), C 
12a6			      inc   HL 
12a6			      ld    (HL), B 
12a6			      inc   HL 
12a6			      push  HL                      ; Address of allocation to return 
12a6			 
12a6			      jr    malloc_update_links 
12a6			 
12a6			malloc_alloc_fit: 
12a6			      pop   HL                      ; Dont need new block size, want is exact fit 
12a6			 
12a6			      ; Modify this_free block to be allocation 
12a6			      ex    DE, HL 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			 
12a6			      xor   A                       ; Null the next block ptr of allocated block 
12a6			      ld    (HL), A 
12a6			      inc   HL 
12a6			      ld    (HL), A 
12a6			 
12a6			      inc   HL                      ; Store address of allocation to return 
12a6			      inc   HL 
12a6			      inc   HL 
12a6			      push  HL 
12a6			 
12a6			      ; Copy next_free ptr to this_free, remove allocated block from free list 
12a6			      ld    L, (IX+0)               ; next_free to HL 
12a6			      ld    H, (IX+1) 
12a6			 
12a6			      ld    (IX+2), L               ; HL to this_free 
12a6			      ld    (IX+3), H 
12a6			 
12a6			 
12a6			malloc_update_links: 
12a6			      ; Update prev_free ptr to point to this_free 
12a6			      ld    L, (IX+4)               ; prev_free ptr to HL 
12a6			      ld    H, (IX+5) 
12a6			 
12a6			      ld    E, (IX+2)               ; this_free ptr to DE 
12a6			      ld    D, (IX+3) 
12a6			 
12a6			      ld    (HL), E                 ; this_free ptr into prev_free 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			      ; Clear the Z flag to indicate successful allocation 
12a6			      ld    A, D 
12a6			      or    E 
12a6			 
12a6			      pop   DE                      ; Address of allocation 
12a6			 
12a6			malloc_no_space: 
12a6			      ld    HL, 6                   ; Clean up stack frame 
12a6			      add   HL, SP 
12a6			      ld    SP, HL 
12a6			 
12a6			      ex    DE, HL                  ; Alloc addr into HL for return 
12a6			 
12a6			malloc_early_exit: 
12a6			      pop   IX 
12a6			      pop   DE 
12a6			      pop   BC 
12a6			 
12a6			      ret 
12a6			 
12a6			 
12a6			;------------------------------------------------------------------------------ 
12a6			;     free                                                                    : 
12a6			;                                                                             : 
12a6			; Description                                                                 : 
12a6			;     Return the space pointed to by HL to the heap. HL must be an address as : 
12a6			;     returned by malloc, otherwise the behaviour is undefined.               : 
12a6			;                                                                             : 
12a6			;     Where possible, directly adjacent free blocks will be merged together   : 
12a6			;     into larger blocks to help ensure that the heap does not become         : 
12a6			;     excessively fragmented.                                                 : 
12a6			;                                                                             : 
12a6			;     free does not clear or set any other value into the freed space, and    : 
12a6			;     therefore its contents may be visible through subsequent malloc's. The  : 
12a6			;     caller should clear the freed space as required.                        : 
12a6			;                                                                             : 
12a6			;     This implementation of free uses the stack exclusively, and is          : 
12a6			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
12a6			;     advisable to disable interrupts before calling free, and recommended    : 
12a6			;     to avoid the use of free inside ISRs in general.                        : 
12a6			;                                                                             : 
12a6			;     NOTE: heap_init must be called before malloc and free can be used.      : 
12a6			;                                                                             : 
12a6			; Parameters                                                                  : 
12a6			;     HL  Pointer to address of first byte of allocation to be freed          : 
12a6			;                                                                             : 
12a6			; Returns                                                                     : 
12a6			;     Nothing                                                                 : 
12a6			;                                                                             : 
12a6			; Stack frame                                                                 : 
12a6			;       |             |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |     BC      |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |     DE      |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |     IX      |                                                       : 
12a6			;       +-------------+                                                       : 
12a6			;       |  prev_free  |                                                       : 
12a6			;   +2  +-------------+                                                       : 
12a6			;       |  next_free  |                                                       : 
12a6			;   +0  +-------------+                                                       : 
12a6			;       |             |                                                       : 
12a6			;                                                                             : 
12a6			;------------------------------------------------------------------------------ 
12a6			free: 
12a6			      push  BC 
12a6			      push  DE 
12a6			      push  IX 
12a6			 
12a6			      ld    A, H                    ; Exit if ptr is null 
12a6			      or    L 
12a6			      jp    Z, free_early_exit 
12a6			 
12a6			      ; Set up stack frame 
12a6			      ex    DE, HL 
12a6			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
12a6			      add   HL, SP 
12a6			      ld    SP, HL 
12a6			      ld    IX, 0                   ; Use IX as a frame pointer 
12a6			      add   IX, SP 
12a6			 
12a6			      ; The address in HL points to the start of the useable allocated space, 
12a6			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
12a6			      ; address of the block itself. 
12a6			      ex    DE, HL 
12a6			      ld    DE, -4 
12a6			      add   HL, DE 
12a6			 
12a6			      ; An allocated block must have a null next block pointer in it 
12a6			      ld    A, (HL) 
12a6			      inc   HL 
12a6			      or    (HL) 
12a6			      jp    NZ, free_done 
12a6			 
12a6			      dec   HL 
12a6			 
12a6			      ld    B, H                    ; Copy HL to BC 
12a6			      ld    C, L 
12a6			 
12a6			      ; Loop through the free list to find the first block with an address 
12a6			      ; higher than the block being freed 
12a6			      ld    HL, free_list 
12a6			 
12a6			free_find_higher_block: 
12a6			      ld    E, (HL)                 ; Load next ptr from free block 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      dec   HL 
12a6			 
12a6			      ld    (IX+0), E               ; Save ptr to next free block 
12a6			      ld    (IX+1), D 
12a6			      ld    (IX+2), L               ; Save ptr to prev free block 
12a6			      ld    (IX+3), H 
12a6			 
12a6			      ld    A, B                    ; Check if DE is greater than BC 
12a6			      cp    D                       ; Compare MSB first 
12a6			      jr    Z, $+4                  ; MSB the same, compare LSB 
12a6			      jr    NC, free_find_higher_block_skip 
12a6			      ld    A, C 
12a6			      cp    E                       ; Then compare LSB 
12a6			      jr    C, free_found_higher_block 
12a6			 
12a6			free_find_higher_block_skip: 
12a6			      ld    A, D                    ; Reached the end of the free list? 
12a6			      or    E 
12a6			      jp    Z, free_done 
12a6			 
12a6			      ex    DE, HL 
12a6			 
12a6			      jr    free_find_higher_block 
12a6			 
12a6			free_found_higher_block: 
12a6			      ; Insert freed block between prev and next free blocks 
12a6			      ld    (HL), C                 ; Point prev free block to freed block 
12a6			      inc   HL 
12a6			      ld    (HL), B 
12a6			 
12a6			      ld    H, B                    ; Point freed block at next free block 
12a6			      ld    L, C 
12a6			      ld    (HL), E 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			      ; Check if the freed block is adjacent to the next free block 
12a6			      inc   HL                      ; Load size of freed block into HL 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      ex    DE, HL 
12a6			 
12a6			      add   HL, BC                  ; Add addr of freed block and its size 
12a6			 
12a6			      ld    E, (IX+0)               ; Load addr of next free block into DE 
12a6			      ld    D, (IX+1) 
12a6			 
12a6			      or    A                       ; Clear the carry flag 
12a6			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
12a6			      jr    NZ, free_check_adjacent_to_prev 
12a6			 
12a6			      ; Freed block is adjacent to next, merge into one bigger block 
12a6			      ex    DE, HL                  ; Load next ptr from next block into DE 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      push  HL                      ; Save ptr to next block for later 
12a6			 
12a6			      ld    H, B                    ; Store ptr from next block into freed block 
12a6			      ld    L, C 
12a6			      ld    (HL), E 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			      pop   HL                      ; Restore ptr to next block 
12a6			      inc   HL                      ; Load size of next block into DE 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      push  DE                      ; Save next block size for later 
12a6			 
12a6			      ld    H, B                    ; Load size of freed block into HL 
12a6			      ld    L, C 
12a6			      inc   HL 
12a6			      inc   HL 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      ex    DE, HL 
12a6			 
12a6			      pop   DE                      ; Restore size of next block 
12a6			      add   HL, DE                  ; Add sizes of both blocks 
12a6			      ex    DE, HL 
12a6			 
12a6			      ld    H, B                    ; Store new bigger size into freed block 
12a6			      ld    L, C 
12a6			      inc   HL 
12a6			      inc   HL 
12a6			      ld    (HL), E 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			free_check_adjacent_to_prev: 
12a6			      ; Check if the freed block is adjacent to the prev free block 
12a6			      ld    L, (IX+2)               ; Prev free block ptr into HL 
12a6			      ld    H, (IX+3) 
12a6			 
12a6			      inc   HL                      ; Size of prev free block into DE 
12a6			      inc   HL 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			      dec   HL 
12a6			 
12a6			      add   HL, DE                  ; Add prev block addr and size 
12a6			 
12a6			      or    A                       ; Clear the carry flag 
12a6			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
12a6			      jr    NZ, free_done 
12a6			 
12a6			      ; Freed block is adjacent to prev, merge into one bigger block 
12a6			      ld    H, B                    ; Load next ptr from freed block into DE 
12a6			      ld    L, C 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      push  HL                      ; Save freed block ptr for later 
12a6			 
12a6			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
12a6			      ld    H, (IX+3) 
12a6			      ld    (HL), E 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			      pop   HL                      ; Restore freed block ptr 
12a6			      inc   HL                      ; Load size of freed block into DE 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			      push  DE                      ; Save freed block size for later 
12a6			 
12a6			      ld    L, (IX+2)               ; Load size of prev block into DE 
12a6			      ld    H, (IX+3) 
12a6			      inc   HL 
12a6			      inc   HL 
12a6			      ld    E, (HL) 
12a6			      inc   HL 
12a6			      ld    D, (HL) 
12a6			 
12a6			      pop   HL                      ; Add sizes of both blocks 
12a6			      add   HL, DE 
12a6			      ex    DE, HL 
12a6			 
12a6			      ld    L, (IX+2)               ; Store new bigger size into prev block 
12a6			      ld    H, (IX+3) 
12a6			      inc   HL 
12a6			      inc   HL 
12a6			      ld    (HL), E 
12a6			      inc   HL 
12a6			      ld    (HL), D 
12a6			 
12a6			free_done: 
12a6			      ld    HL, 4                   ; Clean up stack frame 
12a6			      add   HL, SP 
12a6			      ld    SP, HL 
12a6			 
12a6			free_early_exit: 
12a6			      pop   IX 
12a6			      pop   DE 
12a6			      pop   BC 
12a6			 
12a6			      ret 
12a6			 
12a6			 
12a6			;      .org 0x8000 
12a6			; 
12a6			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
12a6			 ;                 .dw   0 
12a6			 
12a6			endif 
12a6			 
12a6			 
12a6			if MALLOC_4 
12a6			 
12a6			; My memory allocation code. Very very simple.... 
12a6			; allocate space under 250 chars 
12a6			 
12a6			heap_init: 
12a6				; init start of heap as zero 
12a6				;  
12a6			 
12a6				ld hl, heap_start 
12a6			;	ld a, 0 
12a6				ld (hl), 0      ; empty block 
12a6				inc hl 
12a6			;	ld a, 0 
12a6				ld (hl), 0      ; length of block 
12a6				; write end of list 
12a6				inc hl 
12a6				ld a,(hl) 
12a6				inc hl 
12a6				ld a,(hl) 
12a6				 
12a6			 
12a6				; init some malloc vars 
12a6			 
12a6				ld hl, 0 
12a6				ld (free_list), hl       ; store last malloc location 
12a6			 
12a6				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
12a6			;	ld a, 0 
12a6				ld (hl), 0 
12a6			 
12a6			 
12a6				ld hl, heap_start 
12a6				;  
12a6				  
12a6				ret 
12a6			 
12a6			 
12a6			;    free block marker 
12a6			;    requested size  
12a6			;    pointer to next block 
12a6			;    .... 
12a6			;    next block marker 
12a6			 
12a6			 
12a6			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
12a6			; 
12a6			 
12a6			 
12a6			malloc:  
12a6				push de 
12a6				push bc 
12a6				push af 
12a6			 
12a6				; hl space required 
12a6				 
12a6				ld c, l    ; hold space   (TODO only a max of 255) 
12a6			 
12a6			;	inc c     ; TODO BUG need to fix memory leak on push str 
12a6			;	inc c 
12a6			;	inc c 
12a6			;	inc c 
12a6			;	inc c 
12a6			;	inc c 
12a6			;	inc c 
12a6			 
12a6			 
12a6			 
12a6				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
12a6			 
12a6				ld a, (free_list+3) 
12a6			;	cp 0 
12a6				or a 
12a6				jr z, .contheap 
12a6			 
12a6				ld hl, (free_list)     ; get last alloc 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "mrs" 
12a6						CALLMONITOR 
12a6					endif 
12a6				jr .startalloc 
12a6			 
12a6			.contheap: 
12a6				ld hl, heap_start 
12a6			 
12a6			.startalloc: 
12a6			 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "mym" 
12a6						CALLMONITOR 
12a6					endif 
12a6			.findblock: 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "mmf" 
12a6						CALLMONITOR 
12a6					endif 
12a6			 
12a6				ld a,(hl)  
12a6				; if byte is zero then clear to use 
12a6			 
12a6			;	cp 0 
12a6				or a 
12a6				jr z, .foundemptyblock 
12a6			 
12a6				; if byte is not clear 
12a6				;     then byte is offset to next block 
12a6			 
12a6				inc hl 
12a6				ld a, (hl) ; get size 
12a6			.nextblock:	inc hl 
12a6					ld e, (hl) 
12a6					inc hl 
12a6					ld d, (hl) 
12a6					ex de, hl 
12a6			;	inc hl  ; move past the store space 
12a6			;	inc hl  ; move past zero index  
12a6			 
12a6				; TODO detect no more space 
12a6			 
12a6				push hl 
12a6				ld de, heap_end 
12a6				call cmp16 
12a6				pop hl 
12a6				jr nc, .nospace 
12a6			 
12a6				jr .findblock 
12a6			 
12a6			.nospace: ld hl, 0 
12a6				jp .exit 
12a6			 
12a6			 
12a6			.foundemptyblock:	 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "mme" 
12a6						CALLMONITOR 
12a6					endif 
12a6			 
12a6			; TODO has block enough space if reusing??? 
12a6			 
12a6				;  
12a6			 
12a6			; see if this block has been previously used 
12a6				inc hl 
12a6				ld a, (hl) 
12a6				dec hl 
12a6			;	cp 0 
12a6				or a 
12a6				jr z, .newblock 
12a6			 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "meR" 
12a6						CALLMONITOR 
12a6					endif 
12a6			 
12a6			; no reusing previously allocated block 
12a6			 
12a6			; is it smaller than previously used? 
12a6				 
12a6				inc hl    ; move to size 
12a6				ld a, c 
12a6				sub (hl)        ; we want c < (hl) 
12a6				dec hl    ; move back to marker 
12a6			        jr z, .findblock 
12a6			 
12a6				; update with the new size which should be lower 
12a6			 
12a6			        ;inc  hl   ; negate next move. move back to size  
12a6			 
12a6			.newblock: 
12a6				; need to be at marker here 
12a6			 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "meN" 
12a6						CALLMONITOR 
12a6					endif 
12a6			 
12a6			 
12a6				ld a, c 
12a6			 
12a6				ld (free_list+3), a	 ; flag resume from last malloc  
12a6				ld (free_list), hl    ; save out last location 
12a6			 
12a6			 
12a6				;inc a     ; space for length byte 
12a6				ld (hl), a     ; save block in use marker 
12a6			 
12a6				inc hl   ; move to space marker 
12a6				ld (hl), a    ; save new space 
12a6			 
12a6				inc hl   ; move to start of allocated area 
12a6				 
12a6			;	push hl     ; save where we are - 1  
12a6			 
12a6			;	inc hl  ; move past zero index  
12a6				; skip space to set down new marker 
12a6			 
12a6				; provide some extra space for now 
12a6			 
12a6				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
12a6				inc a 
12a6				inc a 
12a6			 
12a6				push hl   ; save where we are in the node block 
12a6			 
12a6				call addatohl 
12a6			 
12a6				; write linked list point 
12a6			 
12a6				pop de     ; get our node position 
12a6				ex de, hl 
12a6			 
12a6				ld (hl), e 
12a6				inc hl 
12a6				ld (hl), d 
12a6			 
12a6				inc hl 
12a6			 
12a6				; now at start of allocated data so save pointer 
12a6			 
12a6				push hl 
12a6			 
12a6				; jump to position of next node and setup empty header in DE 
12a6			 
12a6				ex de, hl 
12a6			 
12a6			;	inc hl ; move past end of block 
12a6			 
12a6			;	ld a, 0 
12a6				ld (hl), 0   ; empty marker 
12a6				inc hl 
12a6				ld (hl), 0   ; size 
12a6				inc hl  
12a6				ld (hl), 0   ; ptr 
12a6				inc hl 
12a6				ld (hl), 0   ; ptr 
12a6			 
12a6			 
12a6				pop hl 
12a6			 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "mmr" 
12a6						CALLMONITOR 
12a6					endif 
12a6			 
12a6			.exit: 
12a6				pop af 
12a6				pop bc 
12a6				pop de  
12a6				ret 
12a6			 
12a6			 
12a6			 
12a6			 
12a6			free:  
12a6				push hl 
12a6				push af 
12a6				; get address in hl 
12a6			 
12a6					if DEBUG_FORTH_MALLOC_INT 
12a6						DMARK "fre" 
12a6						CALLMONITOR 
12a6					endif 
12a6				; data is at hl - move to block count 
12a6				dec hl 
12a6				dec hl    ; get past pointer 
12a6				dec hl 
12a6			 
12a6				ld a, (hl)    ; need this for a validation check 
12a6			 
12a6				dec hl    ; move to block marker 
12a6			 
12a6				; now check that the block count and block marker are the same  
12a6			        ; this checks that we are on a malloc node and not random memory 
12a6			        ; OK a faint chance this could be a problem but rare - famous last words! 
12a6			 
12a6				ld c, a 
12a6				ld a, (hl)    
12a6			 
12a6				cp c 
12a6				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
12a6			 
12a6				; yes good chance we are on a malloc node 
12a6			 
12a6			;	ld a, 0      
12a6				ld (hl), 0   ; mark as free 
12a6			 
12a6				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
12a6			 
12a6			.freeignore:  
12a6			 
12a6				pop af 
12a6				pop hl 
12a6			 
12a6				ret 
12a6			 
12a6			 
12a6			 
12a6			endif 
12a6			 
