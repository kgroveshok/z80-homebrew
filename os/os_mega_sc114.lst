ca26					NEXTW 
ca26			 
ca26			.SPII: 
ca26				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
ca26			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
ca26					if DEBUG_FORTH_WORDS_KEY 
ca26						DMARK "SPi" 
ca26						CALLMONITOR 
ca26					endif 
ca26			 
ca26					; TODO Get SPI byte 
ca26			 
ca26					call spi_read_byte 
ca26			 
ca26					if DEBUG_FORTH_WORDS 
ca26						DMARK "Si2" 
ca26						CALLMONITOR 
ca26					endif 
ca26					ld h, 0 
ca26					ld l, a 
ca26					if DEBUG_FORTH_WORDS 
ca26						DMARK "Si3" 
ca26						CALLMONITOR 
ca26					endif 
ca26					;call forth_push_numhl 
ca26					FORTH_PUSH_VALUEHL 
ca26			 
ca26					NEXTW 
