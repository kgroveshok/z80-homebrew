0d18			;;;; int maths 
0d18			 
0d18			; https://map.grauw.nl/articles/mult_div_shifts.php 
0d18			; Divide 16-bit values (with 16-bit result) 
0d18			; In: Divide BC by divider DE 
0d18			; Out: BC = result, HL = rest 
0d18			; 
0d18			Div16: 
0d18 21 00 00		    ld hl,0 
0d1b 78			    ld a,b 
0d1c 06 08		    ld b,8 
0d1e			Div16_Loop1: 
0d1e 17			    rla 
0d1f ed 6a		    adc hl,hl 
0d21 ed 52		    sbc hl,de 
0d23 30 01		    jr nc,Div16_NoAdd1 
0d25 19			    add hl,de 
0d26			Div16_NoAdd1: 
0d26 10 f6		    djnz Div16_Loop1 
0d28 17			    rla 
0d29 2f			    cpl 
0d2a 47			    ld b,a 
0d2b 79			    ld a,c 
0d2c 48			    ld c,b 
0d2d 06 08		    ld b,8 
0d2f			Div16_Loop2: 
0d2f 17			    rla 
0d30 ed 6a		    adc hl,hl 
0d32 ed 52		    sbc hl,de 
0d34 30 01		    jr nc,Div16_NoAdd2 
0d36 19			    add hl,de 
0d37			Div16_NoAdd2: 
0d37 10 f6		    djnz Div16_Loop2 
0d39 17			    rla 
0d3a 2f			    cpl 
0d3b 41			    ld b,c 
0d3c 4f			    ld c,a 
0d3d c9			ret 
0d3e			 
0d3e			 
0d3e			;http://z80-heaven.wikidot.com/math 
0d3e			; 
0d3e			;Inputs: 
0d3e			;     DE and A are factors 
0d3e			;Outputs: 
0d3e			;     A is not changed 
0d3e			;     B is 0 
0d3e			;     C is not changed 
0d3e			;     DE is not changed 
0d3e			;     HL is the product 
0d3e			;Time: 
0d3e			;     342+6x 
0d3e			; 
0d3e			Mult16: 
0d3e			 
0d3e 06 08		     ld b,8          ;7           7 
0d40 21 00 00		     ld hl,0         ;10         10 
0d43 29			       add hl,hl     ;11*8       88 
0d44 07			       rlca          ;4*8        32 
0d45 30 01		       jr nc,$+3     ;(12|18)*8  96+6x 
0d47 19			         add hl,de   ;--         -- 
0d48 10 f9		       djnz $-5      ;13*7+8     99 
0d4a c9			ret 
0d4b			 
0d4b			; 
0d4b			; Square root of 16-bit value 
0d4b			; In:  HL = value 
0d4b			; Out:  D = result (rounded down) 
0d4b			; 
0d4b			;Sqr16: 
0d4b			;    ld de,#0040 
0d4b			;    ld a,l 
0d4b			;    ld l,h 
0d4b			;    ld h,d 
0d4b			;    or a 
0d4b			;    ld b,8 
0d4b			;Sqr16_Loop: 
0d4b			;    sbc hl,de 
0d4b			;    jr nc,Sqr16_Skip 
0d4b			;    add hl,de 
0d4b			;Sqr16_Skip: 
0d4b			;    ccf 
0d4b			;    rl d 
0d4b			;    add a,a 
0d4b			;    adc hl,hl 
0d4b			;    add a,a 
0d4b			;    adc hl,hl 
0d4b			;    djnz Sqr16_Loop 
0d4b			;    ret 
0d4b			; 
0d4b			; 
0d4b			; Divide 8-bit values 
0d4b			; In: Divide E by divider C 
0d4b			; Out: A = result, B = rest 
0d4b			; 
0d4b			Div8: 
0d4b af			    xor a 
0d4c 06 08		    ld b,8 
0d4e			Div8_Loop: 
0d4e cb 13		    rl e 
0d50 17			    rla 
0d51 91			    sub c 
0d52 30 01		    jr nc,Div8_NoAdd 
0d54 81			    add a,c 
0d55			Div8_NoAdd: 
0d55 10 f7		    djnz Div8_Loop 
0d57 47			    ld b,a 
0d58 7b			    ld a,e 
0d59 17			    rla 
0d5a 2f			    cpl 
0d5b c9			    ret 
0d5c			 
0d5c			; 
0d5c			; Multiply 8-bit value with a 16-bit value (unrolled) 
0d5c			; In: Multiply A with DE 
0d5c			; Out: HL = result 
0d5c			; 
0d5c			Mult12U: 
0d5c 2e 00		    ld l,0 
0d5e 87			    add a,a 
0d5f 30 01		    jr nc,Mult12U_NoAdd0 
0d61 19			    add hl,de 
0d62			Mult12U_NoAdd0: 
