a41e			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
a41e			; | | At start the current various registers will be displayed with contents. 
a41e			; | | Top right corner will show the most recent debug marker seen. 
a41e			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
a41e			; | | and the return stack pointer (RSP). 
a41e			; | | Pressing: 
a41e			; | |  
a41e			; | |    1 - Initial screen 
a41e			; | |  
a41e			; | |    2 - Display a data dump of HL 
a41e			; | |  
a41e			; | |    3 - Display a data dump of DE 
a41e			; | |  
a41e			; | |    4 - Display a data dump of BC 
a41e			; | |  
a41e			; | |    5 - Display a data dump of HL 
a41e			; | |  
a41e			; | |    6 - Display a data dump of DSP 
a41e			; | |  
a41e			; | |    7 - Display a data dump of RSP 
a41e			; | |  
a41e			; | |    8 - Display a data dump of what is at DSP 
a41e			; | |  
a41e			; | |    9 - Display a data dump of what is at RSP 
a41e			; | |  
a41e			; | |    0 - Exit monitor and continue running. This will also enable break points 
a41e			; | |  
a41e			; | |    * - Disable break points 
a41e			; | |  
a41e			; | |    # - Enter traditional monitor mode 
a41e			; | |  
a41e			; | | 
a41e			; | | Monitor Mode 
a41e			; | | ------------ 
a41e			; | | A prompt of '>' will be shown for various commands: 
a41e			; | |  
a41e			; | |    D xxxx - Display a data dump starting from hex address xxxx 
a41e			; | |  
a41e			; | |    C - Continue display a data dump from the last set address 
a41e			; | |  
a41e			; | |    M xxxx - Set start of memory edit at address xx 
a41e			; | |  
a41e			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
a41e			; | |  
a41e			; | |    G xxxx - Exec code at specific address 
a41e			; | |  
a41e			; | |    Q - Return to previous 
a41e				if DEBUG_FORTH_WORDS_KEY 
a41e					DMARK "MON" 
a41e				if DEMARK_VERSION = 1  
a41e e5					push hl  
a41f 21 27 a4				ld hl, .dmark  
a422 22 60 ee				ld (debug_mark), hl  
a425				endif  
a425				if DEMARK_VERSION = 0  
a425					push af  
a425					ld a, (.dmark)  
a425					ld (debug_mark),a  
a425					ld a, (.dmark+1)  
a425					ld (debug_mark+1),a  
a425					ld a, (.dmark+2)  
a425					ld (debug_mark+2),a  
a425				endif  
a425 18 04			jr .pastdmark  
a427 ..			.dmark: db "MON"  
a42a				if DEMARK_VERSION = 1  
a42a 00					db 0  
a42b				endif  
a42b				if DEMARK_VERSION = 1  
a42b e1			.pastdmark: pop hl  
a42c				endif  
a42c				if DEMARK_VERSION = 0  
a42c			.pastdmark: pop af  
a42c				endif  
a42c			endm  
# End of macro DMARK
a42c					CALLMONITOR 
a42c				if BASE_CPM=1  
a42c					call debug_vector  
a42c				endif  
a42c				if BASE_KEV=1  
a42c					rst 8  
a42c				endif  
