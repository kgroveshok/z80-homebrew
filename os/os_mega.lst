23f9			; the core word dictionary v4 
23f9			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
23f9			 
23f9			; this is a linked list for each of the system words used 
23f9			; user defined words will follow the same format but will be in ram 
23f9			 
23f9			 
23f9			; 
23f9			; 
23f9			; define linked list: 
23f9			; 
23f9			; 1. compiled byte op code 
23f9			; 2. len of text word 
23f9			; 3. text word 
23f9			; 4. ptr to next dictionary word 
23f9			; 5. asm, calls etc for the word 
23f9			; 
23f9			;  if 1 == 0 then last word in dict  
23f9			;   
23f9			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
23f9			;  
23f9			;  
23f9			; create basic standard set of words 
23f9			; 
23f9			;  
23f9			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
23f9			; 2DUP 2DROP 2SWAP  
23f9			; @ C@ - get byte  
23f9			; ! C! - store byte 
23f9			; 0< true if less than zero 
23f9			; 0= true if zero 
23f9			; < >  
23f9			; = true if same 
23f9			; variables 
