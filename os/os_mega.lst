6a09 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a0b cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6a0d cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
