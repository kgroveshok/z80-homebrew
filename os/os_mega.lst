5cc2			; stack over and underflow checks 
5cc2			 
5cc2			; init the words to detect the under/overflow 
5cc2			 
5cc2			chk_stk_init: 
5cc2				; a vague random number to check so we dont get any "lucky" hits 
5cc2 3e 2d			ld a, 45 
5cc4 6f				ld l, a 
5cc5 00				nop 
5cc6 3e 17			ld a, 23 
5cc8 67				ld h, a 
5cc9			 
5cc9 22 cb f0			ld (chk_word), hl     ; the word we need to check against 
5ccc			 
5ccc			;	ld (chk_stund), hl	; stack points.... 
5ccc 22 3b fe			ld (chk_stovr), hl 
5ccf 22 1a f9			ld (chk_ret_und), hl 
5cd2 22 d8 f8			ld (chk_ret_ovr), hl 
5cd5 22 56 f8			ld (chk_loop_ovr), hl 
5cd8 22 54 f6			ld (chk_data_ovr), hl 
5cdb c9				ret 
5cdc				 
5cdc			check_stacks: 
5cdc				; check all stack words 
5cdc			 
5cdc e5				push hl 
5cdd d5				push de 
5cde			 
5cde			;	ld de,(chk_word) 
5cde			;	ld hl, (chk_stund)	; stack points.... 
5cde			;	if DEBUG_STK_FAULT 
5cde			;		DMARK "FAa" 
5cde			;		CALLMONITOR 
5cde			;	endif 
5cde			;	call cmp16 
5cde			;	jp z, .chk_faulta 
5cde			; 
5cde			;	ld de, sfaultsu 
5cde			;	jp .chk_fault 
5cde			 
5cde 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
5ce1 ed 5b cb f0		ld de,(chk_word) 
5ce5				if DEBUG_STK_FAULT 
5ce5					DMARK "FAb" 
5ce5					CALLMONITOR 
5ce5				endif 
5ce5 cd 2b 0d			call cmp16 
5ce8 28 06			jr z, .chk_fault1 
5cea 11 8f 5d			ld de, sfaultso 
5ced c3 3f 5d			jp .chk_fault 
5cf0			.chk_fault1:  
5cf0 2a 1a f9			ld hl, (chk_ret_und) 
5cf3 ed 5b cb f0		ld de,(chk_word) 
5cf7				if DEBUG_STK_FAULT 
5cf7					DMARK "FAU" 
5cf7					CALLMONITOR 
5cf7				endif 
5cf7 cd 2b 0d			call cmp16 
5cfa ca 03 5d			jp z, .chk_fault2 
5cfd 11 9f 5d			ld de, sfaultru 
5d00 c3 3f 5d			jp .chk_fault 
5d03			.chk_fault2:  
5d03 2a d8 f8			ld hl, (chk_ret_ovr) 
5d06 ed 5b cb f0		ld de,(chk_word) 
5d0a				if DEBUG_STK_FAULT 
5d0a					DMARK "FA1" 
5d0a					CALLMONITOR 
5d0a				endif 
5d0a cd 2b 0d			call cmp16 
5d0d ca 16 5d			jp z, .chk_fault3 
5d10 11 ad 5d			ld de, sfaultro 
5d13 c3 3f 5d			jp .chk_fault 
5d16			.chk_fault3:  
5d16 2a 56 f8			ld hl, (chk_loop_ovr) 
5d19 ed 5b cb f0		ld de,(chk_word) 
5d1d				if DEBUG_STK_FAULT 
5d1d					DMARK "FA2" 
5d1d					CALLMONITOR 
5d1d				endif 
5d1d cd 2b 0d			call cmp16 
5d20 ca 29 5d			jp z, .chk_fault4 
5d23 11 c7 5d			ld de, sfaultlo 
5d26 c3 3f 5d			jp .chk_fault 
5d29			.chk_fault4:  
5d29 2a 54 f6			ld hl, (chk_data_ovr) 
5d2c ed 5b cb f0		ld de,(chk_word) 
5d30				if DEBUG_STK_FAULT 
5d30					DMARK "FA3" 
5d30					CALLMONITOR 
5d30				endif 
5d30 cd 2b 0d			call cmp16 
5d33 ca 3c 5d			jp z, .chk_fault5 
5d36 11 e1 5d			ld de, sfaultdo 
5d39 c3 3f 5d			jp .chk_fault 
5d3c			 
5d3c			 
