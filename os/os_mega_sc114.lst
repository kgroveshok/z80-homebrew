8a62			subafromhl: 
8a62			   ; If A=0 do nothing 
8a62			    ; Otherwise flip A's sign. Since 
8a62			    ; the upper byte becomes -1, also 
8a62			    ; substract 1 from H. 
8a62 ed 44		    neg 
8a64 ca 6d 8a		    jp    z, Skip 
8a67 25			    dec   h 
8a68			     
8a68			    ; Now add the low byte as usual 
8a68			    ; Two's complement takes care of 
8a68			    ; ensuring the result is correct 
8a68 85			    add   a, l 
8a69 6f			    ld    l, a 
8a6a 8c			    adc   a, h 
8a6b 95			    sub   l 
8a6c 67			    ld    h, a 
8a6d			Skip: 
8a6d c9				ret 
