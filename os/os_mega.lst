1125			;------------------------------------------------------------------------------ 
1125			;     heap_init                                                               : 
1125			;                                                                             : 
1125			; Description                                                                 : 
1125			;     Initialise the heap and make it ready for malloc and free operations.   : 
1125			;                                                                             : 
1125			;     The heap is maintained as a linked list, starting with an initial       : 
1125			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
1125			;     the first free block in the heap. Each block then points to the next    : 
1125			;     free block within the heap, and the free list ends at the first block   : 
1125			;     with a null pointer to the next free block.                             : 
1125			;                                                                             : 
1125			; Parameters                                                                  : 
1125			;     Inputs are compile-time only. Two defines which specify the starting    : 
1125			;     address of the heap and its size are required, along with a memory      : 
1125			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
1125			;     principally stores a pointer to the first free block in the heap.       : 
1125			;                                                                             : 
1125			; Returns                                                                     : 
1125			;     Nothing                                                                 : 
1125			;------------------------------------------------------------------------------ 
1125			heap_init: 
1125 e5			      push  HL 
1126			 
1126			      ; Initialise free list struct 
1126 21 0e 80		      ld    HL, heap_start 
1129 22 0a 80		      ld    (free_list), HL 
112c 21 00 00		      ld    HL, 0 
112f 22 0c 80		      ld    (free_list+2), HL 
1132			 
1132			      ; Insert first free block at bottom of heap, consumes entire heap 
1132 21 af f0		      ld    HL, heap_start+heap_size-4 
1135 22 0e 80		      ld    (heap_start), HL        ; Next block (end of free list) 
1138 21 a1 70		      ld    HL, heap_size-4 
113b 22 10 80		      ld    (heap_start+2), HL      ; Block size 
113e			 
113e			      ; Insert end of free list block at top of heap - two null words will 
113e			      ; terminate the free list 
113e 21 00 00		      ld    HL, 0 
1141 22 b1 f0		      ld    (heap_start+heap_size-2), HL 
1144 22 af f0		      ld    (heap_start+heap_size-4), HL 
1147			 
1147 e1			      pop   HL 
1148			 
1148 c9			      ret 
1149			 
1149			 
1149			;------------------------------------------------------------------------------ 
1149			;     malloc                                                                  : 
1149			;                                                                             : 
1149			; Description                                                                 : 
1149			;     Allocates the wanted space from the heap and returns the address of the : 
1149			;     first useable byte of the allocation.                                   : 
1149			;                                                                             : 
1149			;     Allocations can happen in one of two ways:                              : 
1149			;                                                                             : 
1149			;     1. A free block may be found which is the exact size wanted. In this    : 
1149			;        case the block is removed from the free list and retuedn to the      : 
1149			;        caller.                                                              : 
1149			;     2. A free block may be found which is larger than the size wanted. In   : 
1149			;        this case, the larger block is split into two. The first portion of  : 
1149			;        this block will become the requested space by the malloc call and    : 
1149			;        is returned to the caller. The second portion becomes a new free     : 
1149			;        block, and the free list is adjusted to maintain continuity via this : 
1149			;        newly created block.                                                 : 
1149			;                                                                             : 
1149			;     malloc does not set any initial value in the allocated space, the       : 
1149			;     caller is required to do this as required.                              : 
1149			;                                                                             : 
1149			;     This implementation of malloc uses the stack exclusively, and is        : 
1149			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
1149			;     advisable to disable interrupts before calling malloc, and recommended  : 
1149			;     to avoid the use of malloc inside ISRs in general.                      : 
1149			;                                                                             : 
1149			;     NOTE: heap_init must be called before malloc and free can be used.      : 
1149			;                                                                             : 
1149			; Parameters                                                                  : 
1149			;     HL  Number of bytes wanted                                              : 
1149			;                                                                             : 
1149			; Returns                                                                     : 
1149			;     HL  Address of the first useable byte of the allocation                 : 
1149			;                                                                             : 
1149			; Flags                                                                       : 
1149			;     Z   Set if the allocation did not succeed, clear otherwise              : 
1149			;                                                                             : 
1149			; Stack frame                                                                 : 
1149			;       |             |                                                       : 
1149			;       +-------------+                                                       : 
1149			;       |     BC      |                                                       : 
1149			;       +-------------+                                                       : 
1149			;       |     DE      |                                                       : 
1149			;       +-------------+                                                       : 
1149			;       |     IX      |                                                       : 
1149			;       +-------------+                                                       : 
1149			;       |  prev_free  |                                                       : 
1149			;   +4  +-------------+                                                       : 
1149			;       |  this_free  |                                                       : 
1149			;   +2  +-------------+                                                       : 
1149			;       |  next_free  |                                                       : 
1149			;   +0  +-------------+                                                       : 
1149			;       |             |                                                       : 
1149			;                                                                             : 
1149			;------------------------------------------------------------------------------ 
1149			 
1149			 
1149			;malloc: 
1149			; 
1149			;	SAVESP ON 1 
1149			; 
1149			;	call malloc_code 
1149			; 
1149			;	CHECKSP ON 1 
1149			;	ret 
1149			 
1149			 
1149			malloc: 
1149 c5			      push  BC 
114a d5			      push  DE 
114b dd e5		      push  IX 
114d			if DEBUG_FORTH_MALLOC_HIGH 
114d			call malloc_guard_entry 
114d			endif 
114d			 
114d					if DEBUG_FORTH_MALLOC 
114d						DMARK "mal" 
114d						CALLMONITOR 
114d					endif 
114d 7c			      ld    A, H                    ; Exit if no space requested 
114e b5			      or    L 
114f ca 0e 12		      jp    Z, malloc_early_exit 
1152			 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			; 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			;inc hl 
1152			 
1152			 
1152			 
1152			 
1152					if DEBUG_FORTH_MALLOC 
1152						DMARK "maA" 
1152						CALLMONITOR 
1152					endif 
1152			      ; Set up stack frame 
1152 eb			      ex    DE, HL 
1153 21 fa ff		      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
1156 39			      add   HL, SP 
1157 f9			      ld    SP, HL 
1158 dd 21 00 00	      ld    IX, 0                   ; Use IX as a frame pointer 
115c dd 39		      add   IX, SP 
115e			 
115e			      ; Setup initial state 
115e 21 04 00		      ld    HL, 4                   ; want must also include space used by block struct 
1161 19			      add   HL, DE 
1162			 
1162 44			      ld    B, H                    ; Move want to BC 
1163 4d			      ld    C, L 
1164			 
1164 21 0a 80		      ld    HL, free_list           ; Store prev_free ptr to stack 
1167 dd 75 04		      ld    (IX+4), L 
116a dd 74 05		      ld    (IX+5), H 
116d			 
116d 5e			      ld    E, (HL)                 ; Store this_free ptr to stack 
116e 23			      inc   HL 
116f 56			      ld    D, (HL) 
1170 dd 73 02		      ld    (IX+2), E 
1173 dd 72 03		      ld    (IX+3), D 
1176 eb			      ex    DE, HL                  ; this_free ptr into HL 
1177			 
1177					if DEBUG_FORTH_MALLOC 
1177						DMARK "maB" 
1177						CALLMONITOR 
1177					endif 
1177			      ; Loop through free block list to find some space 
1177			malloc_find_space: 
1177 5e			      ld    E, (HL)                 ; Load next_free ptr into DE 
1178 23			      inc   HL 
1179 56			      ld    D, (HL) 
117a			 
117a 7a			      ld    A, D                    ; Check for null next_free ptr - end of free list 
117b b3			      or    E 
117c ca 08 12		      jp    Z, malloc_no_space 
117f			 
117f dd 73 00		      ld    (IX+0), E               ; Store next_free ptr to stack 
1182 dd 72 01		      ld    (IX+1), D 
1185			 
1185			      ; Does this block have enough space to make the allocation? 
1185 23			      inc   HL                      ; Load free block size into DE 
1186 5e			      ld    E, (HL) 
1187 23			      inc   HL 
1188 56			      ld    D, (HL) 
1189			 
1189 eb			      ex    DE, HL                  ; Check size of block against want 
118a b7			      or    A                       ; Ensure carry flag clear 
118b ed 42		      sbc   HL, BC 
118d e5			      push  HL                      ; Store the result for later (new block size) 
118e			 
118e ca dd 11		      jp   Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
1191 30 1b		      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
1193			 
1193			      ; this_free block is not big enough, setup ptrs to test next free block 
1193 e1			      pop   HL                      ; Discard previous result 
1194			 
1194 dd 6e 02		      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
1197 dd 66 03		      ld    H, (IX+3) 
119a dd 75 04		      ld    (IX+4), L 
119d dd 74 05		      ld    (IX+5), H 
11a0			 
11a0 dd 6e 00		      ld    L, (IX+0)               ; Move next_free ptr into this_free 
11a3 dd 66 01		      ld    H, (IX+1) 
11a6 dd 75 02		      ld    (IX+2), L 
11a9 dd 74 03		      ld    (IX+3), H 
11ac			 
11ac					if DEBUG_FORTH_MALLOC 
11ac						DMARK "MA>" 
11ac						CALLMONITOR 
11ac					endif 
11ac 18 c9		      jr    malloc_find_space 
11ae			 
11ae			      ; split a bigger block into two - requested size and remaining size 
11ae			malloc_alloc_split: 
11ae					if DEBUG_FORTH_MALLOC 
11ae						DMARK "MAs" 
11ae						CALLMONITOR 
11ae					endif 
11ae eb			      ex    DE, HL                  ; Calculate address of new free block 
11af 2b			      dec   HL 
11b0 2b			      dec   HL 
11b1 2b			      dec   HL 
11b2 09			      add   HL, BC 
11b3			 
11b3			      ; Create a new block and point it at next_free 
11b3 dd 5e 00		      ld    E, (IX+0)               ; Load next_free ptr into DE 
11b6 dd 56 01		      ld    D, (IX+1) 
11b9			 
11b9 73			      ld    (HL), E                 ; Store next_free ptr into new block 
11ba 23			      inc   HL 
11bb 72			      ld    (HL), D 
11bc			 
11bc d1			      pop   DE                      ; Store size of new block into new block 
11bd 23			      inc   HL 
11be 73			      ld    (HL), E 
11bf 23			      inc   HL 
11c0 72			      ld    (HL), D 
11c1			 
11c1			      ; Update this_free ptr to point to new block 
11c1 2b			      dec   HL 
11c2 2b			      dec   HL 
11c3 2b			      dec   HL 
11c4			 
11c4 dd 5e 02		      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
11c7 dd 56 03		      ld    D, (IX+3) 
11ca			 
11ca dd 75 02		      ld    (IX+2), L               ; Store new block addr as this_free ptr 
11cd dd 74 03		      ld    (IX+3), H 
11d0			 
11d0			      ; Modify this_free block to be allocation 
11d0 eb			      ex    DE, HL 
11d1 af			      xor   A                       ; Null the next block ptr of allocated block 
11d2 77			      ld    (HL), A 
11d3 23			      inc   HL 
11d4 77			      ld    (HL), A 
11d5			 
11d5 23			      inc   HL                      ; Store want size into allocated block 
11d6 71			      ld    (HL), C 
11d7 23			      inc   HL 
11d8 70			      ld    (HL), B 
11d9 23			      inc   HL 
11da e5			      push  HL                      ; Address of allocation to return 
11db			 
11db 18 19		      jr    malloc_update_links 
11dd			 
11dd			malloc_alloc_fit: 
11dd e1			      pop   HL                      ; Dont need new block size, want is exact fit 
11de			 
11de					if DEBUG_FORTH_MALLOC 
11de						DMARK "MAf" 
11de						CALLMONITOR 
11de					endif 
11de			      ; Modify this_free block to be allocation 
11de eb			      ex    DE, HL 
11df 2b			      dec   HL 
11e0 2b			      dec   HL 
11e1 2b			      dec   HL 
11e2			 
11e2 af			      xor   A                       ; Null the next block ptr of allocated block 
11e3 77			      ld    (HL), A 
11e4 23			      inc   HL 
11e5 77			      ld    (HL), A 
11e6			 
11e6 23			      inc   HL                      ; Store address of allocation to return 
11e7 23			      inc   HL 
11e8 23			      inc   HL 
11e9 e5			      push  HL 
11ea			 
11ea			      ; Copy next_free ptr to this_free, remove allocated block from free list 
11ea dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11ed dd 66 01		      ld    H, (IX+1) 
11f0			 
11f0 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11f3 dd 74 03		      ld    (IX+3), H 
11f6			 
11f6			 
11f6			malloc_update_links: 
11f6			      ; Update prev_free ptr to point to this_free 
11f6 dd 6e 04		      ld    L, (IX+4)               ; prev_free ptr to HL 
11f9 dd 66 05		      ld    H, (IX+5) 
11fc			 
11fc dd 5e 02		      ld    E, (IX+2)               ; this_free ptr to DE 
11ff dd 56 03		      ld    D, (IX+3) 
1202			 
1202 73			      ld    (HL), E                 ; this_free ptr into prev_free 
1203 23			      inc   HL 
1204 72			      ld    (HL), D 
1205			 
1205					if DEBUG_FORTH_MALLOC 
1205						DMARK "Mul" 
1205						CALLMONITOR 
1205					endif 
1205			      ; Clear the Z flag to indicate successful allocation 
1205 7a			      ld    A, D 
1206 b3			      or    E 
1207			 
1207 d1			      pop   DE                      ; Address of allocation 
1208					if DEBUG_FORTH_MALLOC 
1208						DMARK "MAu" 
1208						CALLMONITOR 
1208					endif 
1208			 
1208			malloc_no_space: 
1208 21 06 00		      ld    HL, 6                   ; Clean up stack frame 
120b 39			      add   HL, SP 
120c f9			      ld    SP, HL 
120d			 
120d eb			      ex    DE, HL                  ; Alloc addr into HL for return 
120e					if DEBUG_FORTH_MALLOC 
120e						DMARK "MAN" 
120e						CALLMONITOR 
120e					endif 
120e			 
120e			malloc_early_exit: 
120e					if DEBUG_FORTH_MALLOC 
120e						DMARK "MAx" 
120e						CALLMONITOR 
120e					endif 
120e dd e1		      pop   IX 
1210 d1			      pop   DE 
1211 c1			      pop   BC 
1212			 
1212			if DEBUG_FORTH_MALLOC_HIGH 
1212			call malloc_guard_exit 
1212			call malloc_guard_zerolen 
1212			endif 
1212 c9			      ret 
