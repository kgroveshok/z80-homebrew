244d			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
244d			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
244d			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
244d			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
244d			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
244d			WORD_SYS_END: equ 0   ; Opcode for all user words 
244d			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
244d			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
244d			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
244d			 
244d			; Core word preamble macro 
244d			 
244d			CWHEAD:   macro nxtword opcode lit len opflags 
244d				db WORD_SYS_CORE+opcode             
244d				; internal op code number 
244d				dw nxtword            
244d				; link to next dict word block 
244d				db len + 1 
244d				; literal length of dict word inc zero term 
244d				db lit,0              
244d				; literal dict word 
244d			        ; TODO db opflags        
244d				endm 
