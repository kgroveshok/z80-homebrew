8fb5			 
8fb5			free_early_exit: 
8fb5 dd e1		      pop   IX 
8fb7 d1			      pop   DE 
8fb8 c1			      pop   BC 
8fb9			 
8fb9 c9			      ret 
8fba			 
8fba			; moved to firmware.asm 
8fba			; 
8fba			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8fba			;                  .dw   0 
8fba			 
8fba			 
8fba			endif 
8fba			 
8fba			 
8fba			if MALLOC_3 
8fba			; https://gist.githubusercontent.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca/raw/5a08fb30a480d98c0deb4a6afe2d48961cc8e9d9/z80_malloc.s 
8fba			;heap_start        .equ  0x9000      ; Starting address of heap 
8fba			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8fba			; 
8fba			 ;     .org 0 
8fba			  ;    jp    main 
8fba			; 
8fba			; 
8fba			 ;     .org  0x100 
8fba			;main: 
8fba			 ;     ld    HL, 0x8100 
8fba			  ;    ld    SP, HL 
8fba			; 
8fba			;      call  heap_init 
8fba			 
8fba			      ; Make some allocations 
8fba			;      ld    HL, 12 
8fba			;      call  malloc            ; Allocates 0x9004 
8fba			; 
8fba			 ;     ld    HL, 12 
8fba			;      call  malloc            ; Allocates 0x9014 
8fba			 
8fba			;      ld    HL, 12 
8fba			;      call  malloc            ; Allocates 0x9024 
8fba			 
8fba			      ; Free some allocations 
8fba			;      ld    HL, 0x9014 
8fba			;      call  free 
8fba			 
8fba			;      ld    HL, 0x9004 
8fba			;      call  free 
8fba			; 
8fba			;      ld    HL, 0x9024 
8fba			;      call  free 
8fba			 
8fba			 
8fba			 ;     halt 
8fba			 
8fba			 
8fba			;------------------------------------------------------------------------------ 
8fba			;     heap_init                                                               : 
8fba			;                                                                             : 
8fba			; Description                                                                 : 
8fba			;     Initialise the heap and make it ready for malloc and free operations.   : 
8fba			;                                                                             : 
8fba			;     The heap is maintained as a linked list, starting with an initial       : 
8fba			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8fba			;     the first free block in the heap. Each block then points to the next    : 
8fba			;     free block within the heap, and the free list ends at the first block   : 
8fba			;     with a null pointer to the next free block.                             : 
8fba			;                                                                             : 
8fba			; Parameters                                                                  : 
8fba			;     Inputs are compile-time only. Two defines which specify the starting    : 
8fba			;     address of the heap and its size are required, along with a memory      : 
8fba			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8fba			;     principally stores a pointer to the first free block in the heap.       : 
8fba			;                                                                             : 
8fba			; Returns                                                                     : 
8fba			;     Nothing                                                                 : 
8fba			;------------------------------------------------------------------------------ 
8fba			heap_init: 
8fba			      push  HL 
8fba			 
8fba			      ; Initialise free list struct 
8fba			      ld    HL, heap_start 
8fba			      ld    (free_list), HL 
8fba			      ld    HL, 0 
8fba			      ld    (free_list+2), HL 
8fba			 
8fba			      ; Insert first free block at bottom of heap, consumes entire heap 
8fba			      ld    HL, heap_start+heap_size-4 
8fba			      ld    (heap_start), HL        ; Next block (end of free list) 
8fba			      ld    HL, heap_size-4 
8fba			      ld    (heap_start+2), HL      ; Block size 
8fba			 
8fba			      ; Insert end of free list block at top of heap - two null words will 
8fba			      ; terminate the free list 
8fba			      ld    HL, 0 
8fba			      ld    (heap_start+heap_size-2), HL 
8fba			      ld    (heap_start+heap_size-4), HL 
8fba			 
8fba			      pop   HL 
8fba			 
8fba			      ret 
8fba			 
8fba			 
8fba			;------------------------------------------------------------------------------ 
8fba			;     malloc                                                                  : 
8fba			;                                                                             : 
8fba			; Description                                                                 : 
8fba			;     Allocates the wanted space from the heap and returns the address of the : 
8fba			;     first useable byte of the allocation.                                   : 
8fba			;                                                                             : 
8fba			;     Allocations can happen in one of two ways:                              : 
8fba			;                                                                             : 
8fba			;     1. A free block may be found which is the exact size wanted. In this    : 
8fba			;        case the block is removed from the free list and retuedn to the      : 
8fba			;        caller.                                                              : 
8fba			;     2. A free block may be found which is larger than the size wanted. In   : 
8fba			;        this case, the larger block is split into two. The first portion of  : 
8fba			;        this block will become the requested space by the malloc call and    : 
8fba			;        is returned to the caller. The second portion becomes a new free     : 
8fba			;        block, and the free list is adjusted to maintain continuity via this : 
8fba			;        newly created block.                                                 : 
8fba			;                                                                             : 
8fba			;     malloc does not set any initial value in the allocated space, the       : 
8fba			;     caller is required to do this as required.                              : 
8fba			;                                                                             : 
8fba			;     This implementation of malloc uses the stack exclusively, and is        : 
8fba			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8fba			;     advisable to disable interrupts before calling malloc, and recommended  : 
8fba			;     to avoid the use of malloc inside ISRs in general.                      : 
8fba			;                                                                             : 
8fba			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8fba			;                                                                             : 
8fba			; Parameters                                                                  : 
8fba			;     HL  Number of bytes wanted                                              : 
8fba			;                                                                             : 
8fba			; Returns                                                                     : 
8fba			;     HL  Address of the first useable byte of the allocation                 : 
8fba			;                                                                             : 
8fba			; Flags                                                                       : 
8fba			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8fba			;                                                                             : 
8fba			; Stack frame                                                                 : 
8fba			;       |             |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |     BC      |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |     DE      |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |     IX      |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |  prev_free  |                                                       : 
8fba			;   +4  +-------------+                                                       : 
8fba			;       |  this_free  |                                                       : 
8fba			;   +2  +-------------+                                                       : 
8fba			;       |  next_free  |                                                       : 
8fba			;   +0  +-------------+                                                       : 
8fba			;       |             |                                                       : 
8fba			;                                                                             : 
8fba			;------------------------------------------------------------------------------ 
8fba			malloc: 
8fba			      push  BC 
8fba			      push  DE 
8fba			      push  IX 
8fba			 
8fba			      ld    A, H                    ; Exit if no space requested 
8fba			      or    L 
8fba			      jp    Z, malloc_early_exit 
8fba			 
8fba			      ; Set up stack frame 
8fba			      ex    DE, HL 
8fba			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8fba			      add   HL, SP 
8fba			      ld    SP, HL 
8fba			      ld    IX, 0                   ; Use IX as a frame pointer 
8fba			      add   IX, SP 
8fba			 
8fba			      ; Setup initial state 
8fba			      ld    HL, 4                   ; want must also include space used by block struct 
8fba			      add   HL, DE 
8fba			 
8fba			      ld    B, H                    ; Move want to BC 
8fba			      ld    C, L 
8fba			 
8fba			      ld    HL, free_list           ; Store prev_free ptr to stack 
8fba			      ld    (IX+4), L 
8fba			      ld    (IX+5), H 
8fba			 
8fba			      ld    E, (HL)                 ; Store this_free ptr to stack 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      ld    (IX+2), E 
8fba			      ld    (IX+3), D 
8fba			      ex    DE, HL                  ; this_free ptr into HL 
8fba			 
8fba			      ; Loop through free block list to find some space 
8fba			malloc_find_space: 
8fba			      ld    E, (HL)                 ; Load next_free ptr into DE 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			 
8fba			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8fba			      or    E 
8fba			      jp    Z, malloc_no_space 
8fba			 
8fba			      ld    (IX+0), E               ; Store next_free ptr to stack 
8fba			      ld    (IX+1), D 
8fba			 
8fba			      ; Does this block have enough space to make the allocation? 
8fba			      inc   HL                      ; Load free block size into DE 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			 
8fba			      ex    DE, HL                  ; Check size of block against want 
8fba			      or    A                       ; Ensure carry flag clear 
8fba			      sbc   HL, BC 
8fba			      push  HL                      ; Store the result for later (new block size) 
8fba			 
8fba			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8fba			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8fba			 
8fba			      ; this_free block is not big enough, setup ptrs to test next free block 
8fba			      pop   HL                      ; Discard previous result 
8fba			 
8fba			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8fba			      ld    H, (IX+3) 
8fba			      ld    (IX+4), L 
8fba			      ld    (IX+5), H 
8fba			 
8fba			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8fba			      ld    H, (IX+1) 
8fba			      ld    (IX+2), L 
8fba			      ld    (IX+3), H 
8fba			 
8fba			      jr    malloc_find_space 
8fba			 
8fba			      ; split a bigger block into two - requested size and remaining size 
8fba			malloc_alloc_split: 
8fba			      ex    DE, HL                  ; Calculate address of new free block 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			      add   HL, BC 
8fba			 
8fba			      ; Create a new block and point it at next_free 
8fba			      ld    E, (IX+0)               ; Load next_free ptr into DE 
8fba			      ld    D, (IX+1) 
8fba			 
8fba			      ld    (HL), E                 ; Store next_free ptr into new block 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			      pop   DE                      ; Store size of new block into new block 
8fba			      inc   HL 
8fba			      ld    (HL), E 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			      ; Update this_free ptr to point to new block 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			 
8fba			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8fba			      ld    D, (IX+3) 
8fba			 
8fba			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8fba			      ld    (IX+3), H 
8fba			 
8fba			      ; Modify this_free block to be allocation 
8fba			      ex    DE, HL 
8fba			      xor   A                       ; Null the next block ptr of allocated block 
8fba			      ld    (HL), A 
8fba			      inc   HL 
8fba			      ld    (HL), A 
8fba			 
8fba			      inc   HL                      ; Store want size into allocated block 
8fba			      ld    (HL), C 
8fba			      inc   HL 
8fba			      ld    (HL), B 
8fba			      inc   HL 
8fba			      push  HL                      ; Address of allocation to return 
8fba			 
8fba			      jr    malloc_update_links 
8fba			 
8fba			malloc_alloc_fit: 
8fba			      pop   HL                      ; Dont need new block size, want is exact fit 
8fba			 
8fba			      ; Modify this_free block to be allocation 
8fba			      ex    DE, HL 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			 
8fba			      xor   A                       ; Null the next block ptr of allocated block 
8fba			      ld    (HL), A 
8fba			      inc   HL 
8fba			      ld    (HL), A 
8fba			 
8fba			      inc   HL                      ; Store address of allocation to return 
8fba			      inc   HL 
8fba			      inc   HL 
8fba			      push  HL 
8fba			 
8fba			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8fba			      ld    L, (IX+0)               ; next_free to HL 
8fba			      ld    H, (IX+1) 
8fba			 
8fba			      ld    (IX+2), L               ; HL to this_free 
8fba			      ld    (IX+3), H 
8fba			 
8fba			 
8fba			malloc_update_links: 
8fba			      ; Update prev_free ptr to point to this_free 
8fba			      ld    L, (IX+4)               ; prev_free ptr to HL 
8fba			      ld    H, (IX+5) 
8fba			 
8fba			      ld    E, (IX+2)               ; this_free ptr to DE 
8fba			      ld    D, (IX+3) 
8fba			 
8fba			      ld    (HL), E                 ; this_free ptr into prev_free 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			      ; Clear the Z flag to indicate successful allocation 
8fba			      ld    A, D 
8fba			      or    E 
8fba			 
8fba			      pop   DE                      ; Address of allocation 
8fba			 
8fba			malloc_no_space: 
8fba			      ld    HL, 6                   ; Clean up stack frame 
8fba			      add   HL, SP 
8fba			      ld    SP, HL 
8fba			 
8fba			      ex    DE, HL                  ; Alloc addr into HL for return 
8fba			 
8fba			malloc_early_exit: 
8fba			      pop   IX 
8fba			      pop   DE 
8fba			      pop   BC 
8fba			 
8fba			      ret 
8fba			 
8fba			 
8fba			;------------------------------------------------------------------------------ 
8fba			;     free                                                                    : 
8fba			;                                                                             : 
8fba			; Description                                                                 : 
8fba			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8fba			;     returned by malloc, otherwise the behaviour is undefined.               : 
8fba			;                                                                             : 
8fba			;     Where possible, directly adjacent free blocks will be merged together   : 
8fba			;     into larger blocks to help ensure that the heap does not become         : 
8fba			;     excessively fragmented.                                                 : 
8fba			;                                                                             : 
8fba			;     free does not clear or set any other value into the freed space, and    : 
8fba			;     therefore its contents may be visible through subsequent malloc's. The  : 
8fba			;     caller should clear the freed space as required.                        : 
8fba			;                                                                             : 
8fba			;     This implementation of free uses the stack exclusively, and is          : 
8fba			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8fba			;     advisable to disable interrupts before calling free, and recommended    : 
8fba			;     to avoid the use of free inside ISRs in general.                        : 
8fba			;                                                                             : 
8fba			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8fba			;                                                                             : 
8fba			; Parameters                                                                  : 
8fba			;     HL  Pointer to address of first byte of allocation to be freed          : 
8fba			;                                                                             : 
8fba			; Returns                                                                     : 
8fba			;     Nothing                                                                 : 
8fba			;                                                                             : 
8fba			; Stack frame                                                                 : 
8fba			;       |             |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |     BC      |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |     DE      |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |     IX      |                                                       : 
8fba			;       +-------------+                                                       : 
8fba			;       |  prev_free  |                                                       : 
8fba			;   +2  +-------------+                                                       : 
8fba			;       |  next_free  |                                                       : 
8fba			;   +0  +-------------+                                                       : 
8fba			;       |             |                                                       : 
8fba			;                                                                             : 
8fba			;------------------------------------------------------------------------------ 
8fba			free: 
8fba			      push  BC 
8fba			      push  DE 
8fba			      push  IX 
8fba			 
8fba			      ld    A, H                    ; Exit if ptr is null 
8fba			      or    L 
8fba			      jp    Z, free_early_exit 
8fba			 
8fba			      ; Set up stack frame 
8fba			      ex    DE, HL 
8fba			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8fba			      add   HL, SP 
8fba			      ld    SP, HL 
8fba			      ld    IX, 0                   ; Use IX as a frame pointer 
8fba			      add   IX, SP 
8fba			 
8fba			      ; The address in HL points to the start of the useable allocated space, 
8fba			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8fba			      ; address of the block itself. 
8fba			      ex    DE, HL 
8fba			      ld    DE, -4 
8fba			      add   HL, DE 
8fba			 
8fba			      ; An allocated block must have a null next block pointer in it 
8fba			      ld    A, (HL) 
8fba			      inc   HL 
8fba			      or    (HL) 
8fba			      jp    NZ, free_done 
8fba			 
8fba			      dec   HL 
8fba			 
8fba			      ld    B, H                    ; Copy HL to BC 
8fba			      ld    C, L 
8fba			 
8fba			      ; Loop through the free list to find the first block with an address 
8fba			      ; higher than the block being freed 
8fba			      ld    HL, free_list 
8fba			 
8fba			free_find_higher_block: 
8fba			      ld    E, (HL)                 ; Load next ptr from free block 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      dec   HL 
8fba			 
8fba			      ld    (IX+0), E               ; Save ptr to next free block 
8fba			      ld    (IX+1), D 
8fba			      ld    (IX+2), L               ; Save ptr to prev free block 
8fba			      ld    (IX+3), H 
8fba			 
8fba			      ld    A, B                    ; Check if DE is greater than BC 
8fba			      cp    D                       ; Compare MSB first 
8fba			      jr    Z, $+4                  ; MSB the same, compare LSB 
8fba			      jr    NC, free_find_higher_block_skip 
8fba			      ld    A, C 
8fba			      cp    E                       ; Then compare LSB 
8fba			      jr    C, free_found_higher_block 
8fba			 
8fba			free_find_higher_block_skip: 
8fba			      ld    A, D                    ; Reached the end of the free list? 
8fba			      or    E 
8fba			      jp    Z, free_done 
8fba			 
8fba			      ex    DE, HL 
8fba			 
8fba			      jr    free_find_higher_block 
8fba			 
8fba			free_found_higher_block: 
8fba			      ; Insert freed block between prev and next free blocks 
8fba			      ld    (HL), C                 ; Point prev free block to freed block 
8fba			      inc   HL 
8fba			      ld    (HL), B 
8fba			 
8fba			      ld    H, B                    ; Point freed block at next free block 
8fba			      ld    L, C 
8fba			      ld    (HL), E 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			      ; Check if the freed block is adjacent to the next free block 
8fba			      inc   HL                      ; Load size of freed block into HL 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      ex    DE, HL 
8fba			 
8fba			      add   HL, BC                  ; Add addr of freed block and its size 
8fba			 
8fba			      ld    E, (IX+0)               ; Load addr of next free block into DE 
8fba			      ld    D, (IX+1) 
8fba			 
8fba			      or    A                       ; Clear the carry flag 
8fba			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8fba			      jr    NZ, free_check_adjacent_to_prev 
8fba			 
8fba			      ; Freed block is adjacent to next, merge into one bigger block 
8fba			      ex    DE, HL                  ; Load next ptr from next block into DE 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      push  HL                      ; Save ptr to next block for later 
8fba			 
8fba			      ld    H, B                    ; Store ptr from next block into freed block 
8fba			      ld    L, C 
8fba			      ld    (HL), E 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			      pop   HL                      ; Restore ptr to next block 
8fba			      inc   HL                      ; Load size of next block into DE 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      push  DE                      ; Save next block size for later 
8fba			 
8fba			      ld    H, B                    ; Load size of freed block into HL 
8fba			      ld    L, C 
8fba			      inc   HL 
8fba			      inc   HL 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      ex    DE, HL 
8fba			 
8fba			      pop   DE                      ; Restore size of next block 
8fba			      add   HL, DE                  ; Add sizes of both blocks 
8fba			      ex    DE, HL 
8fba			 
8fba			      ld    H, B                    ; Store new bigger size into freed block 
8fba			      ld    L, C 
8fba			      inc   HL 
8fba			      inc   HL 
8fba			      ld    (HL), E 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			free_check_adjacent_to_prev: 
8fba			      ; Check if the freed block is adjacent to the prev free block 
8fba			      ld    L, (IX+2)               ; Prev free block ptr into HL 
8fba			      ld    H, (IX+3) 
8fba			 
8fba			      inc   HL                      ; Size of prev free block into DE 
8fba			      inc   HL 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			      dec   HL 
8fba			 
8fba			      add   HL, DE                  ; Add prev block addr and size 
8fba			 
8fba			      or    A                       ; Clear the carry flag 
8fba			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8fba			      jr    NZ, free_done 
8fba			 
8fba			      ; Freed block is adjacent to prev, merge into one bigger block 
8fba			      ld    H, B                    ; Load next ptr from freed block into DE 
8fba			      ld    L, C 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      push  HL                      ; Save freed block ptr for later 
8fba			 
8fba			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8fba			      ld    H, (IX+3) 
8fba			      ld    (HL), E 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			      pop   HL                      ; Restore freed block ptr 
8fba			      inc   HL                      ; Load size of freed block into DE 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			      push  DE                      ; Save freed block size for later 
8fba			 
8fba			      ld    L, (IX+2)               ; Load size of prev block into DE 
8fba			      ld    H, (IX+3) 
8fba			      inc   HL 
8fba			      inc   HL 
8fba			      ld    E, (HL) 
8fba			      inc   HL 
8fba			      ld    D, (HL) 
8fba			 
8fba			      pop   HL                      ; Add sizes of both blocks 
8fba			      add   HL, DE 
8fba			      ex    DE, HL 
8fba			 
8fba			      ld    L, (IX+2)               ; Store new bigger size into prev block 
8fba			      ld    H, (IX+3) 
8fba			      inc   HL 
8fba			      inc   HL 
8fba			      ld    (HL), E 
8fba			      inc   HL 
8fba			      ld    (HL), D 
8fba			 
8fba			free_done: 
8fba			      ld    HL, 4                   ; Clean up stack frame 
8fba			      add   HL, SP 
8fba			      ld    SP, HL 
8fba			 
8fba			free_early_exit: 
8fba			      pop   IX 
8fba			      pop   DE 
8fba			      pop   BC 
8fba			 
8fba			      ret 
8fba			 
8fba			 
8fba			;      .org 0x8000 
8fba			; 
8fba			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8fba			 ;                 .dw   0 
8fba			 
8fba			endif 
