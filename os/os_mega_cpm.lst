573e			include "forth_startup.asm" 
573e			; Which startup method to use? 
573e			; 
573e			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
573e			; followed by loading of a list of scripts in eeprom 
573e			 
573e			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
573e			; from eeprom 
573e			 
573e			; Select with define in main stubs 
573e			 
573e			if STARTUP_V1 
573e				include "forth_startupv1.asm" 
573e			; Startup script loading version 1 
573e			 
573e			; If SE storage is available first stage is to use the selected file 
573e			; then go through the eeprom list 
573e			 
573e .. 00		sprompt1: db "Startup load...",0 
574e .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
