641b					CALLMONITOR 
641b				endif 
641b cd 7d 0d			call cmp16 
641e ca 27 64			jp z, .chk_fault2 
6421 11 c3 64			ld de, sfaultru 
6424 c3 63 64			jp .chk_fault 
