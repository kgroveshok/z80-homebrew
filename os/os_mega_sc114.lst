8c6b			;                jr      nc, get_nibble  ; No, get another character 
8c6b			 ;               call    nibble2val      ; Convert nibble to value 
8c6b			 ;               call    print_nibble 
8c6b			 ;               ret 
8c6b			; 
8c6b			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
8c6b			; A valid hexadecimal digit is denoted by a set C flag. 
