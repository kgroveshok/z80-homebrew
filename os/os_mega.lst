0299			store_read_ins: equ 000000011b   ; Read data from memory array beginning at selected address 
0299			store_write_ins: equ 000000010b  ;  Write data to memory array beginning at selected address 
0299			store_wren_ins: equ 000000110b   ;  Set the write enable latch (enable write operations) 
0299			 
0299			; INSTRUCTION SET 
0299			; READ 0000 0011 Read data from memory array beginning at selected address 
0299			; WRITE 0000 0010 Write data to memory array beginning at selected address 
0299			; WREN 0000 0110 Set the write enable latch (enable write operations) 
0299			; WRDI 0000 0100 Reset the write enable latch (disable write operations) 
0299			; RDSR 0000 0101 Read STATUS register 
0299			; WRSR 0000 0001 Write STATUS register 
0299			; PE 0100 0010 Page Erase – erase one page in memory array 
0299			; SE 1101 1000 Sector Erase – erase one sector in memory array 
0299			; CE 1100 0111 Chip Erase – erase all sectors in memory array 
0299			; RDID 1010 1011 Release from Deep power-down and read electronic signature 
0299			 
