1860			FORTH_CHK_DSP_UNDER: macro 
1860				push hl 
1860				push de 
1860				ld hl,(cli_data_sp) 
1860				ld de, cli_data_stack 
1860				call cmp16 
1860				jp c, fault_dsp_under 
1860				pop de 
1860				pop hl 
1860				endm 
1860			 
1860			 
1860			FORTH_CHK_RSP_UNDER: macro 
1860				push hl 
1860				push de 
1860				ld hl,(cli_ret_sp) 
1860				ld de, cli_ret_stack 
1860				call cmp16 
1860				jp c, fault_rsp_under 
1860				pop de 
1860				pop hl 
1860				endm 
1860			 
1860			FORTH_CHK_LOOP_UNDER: macro 
1860				push hl 
1860				push de 
1860				ld hl,(cli_loop_sp) 
1860				ld de, cli_loop_stack 
1860				call cmp16 
1860				jp c, fault_loop_under 
1860				pop de 
1860				pop hl 
1860				endm 
1860			 
1860			FORTH_ERR_TOS_NOTSTR: macro 
1860				; TOSO might need more for checks when used 
1860				push af 
1860				ld a,(hl) 
1860				cp DS_TYPE_STR 
1860				jp nz, type_faultn   
1860				pop af 
1860				endm 
1860			 
1860			FORTH_ERR_TOS_NOTNUM: macro 
1860				push af 
1860				ld a,(hl) 
1860				cp DS_TYPE_INUM 
1860				jp nz, type_faultn   
1860				pop af 
1860				endm 
