6aeb			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6aeb 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
6aed 18 02		            JR   WrFunc  
6aef 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
6af1 f5			WrFunc:     PUSH AF  
6af2 f5					push af  
6af3 3a fb fa				ld a, (display_lcde1e2)  
6af6 fe 00				cp 0     ; e1  
6af8 20 0f				jr nz, .wfea2	  
6afa f1					pop af  
6afb d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6afd cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
6aff cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b01 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b03 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b05 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b07 18 0d			jr .wfskip  
6b09 f1			.wfea2:		pop af  
6b0a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b0c cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6b0e cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6b10 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6b12 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6b14 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6b16 3e 05		.wfskip:            LD  A, 5  
6b18 cd 1f 6b		            CALL LCDDelay       ;Delay 5 ms to complete  
6b1b f1			            POP  AF  
6b1c c9			            RET  
