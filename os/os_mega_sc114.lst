bd06				endm 
# End of macro CWHEAD
bd06			; | SPITIME ( -- u1 )   Pushes address of the SPI pulse counter/delay to stack | DONE 
bd06			; 
bd06			; | | If using BANK devices then leave as is. 
bd06			; | | Only really useful for the CARTDEV where other devices may be far too slow. In particular 
