64f2			; stack over and underflow checks 
64f2			 
64f2			; init the words to detect the under/overflow 
64f2			 
64f2			chk_stk_init: 
64f2				; a vague random number to check so we dont get any "lucky" hits 
64f2 3e 2d			ld a, 45 
64f4 6f				ld l, a 
64f5 00				nop 
64f6 3e 17			ld a, 23 
64f8 67				ld h, a 
64f9			 
64f9 22 bb f0			ld (chk_word), hl     ; the word we need to check against 
64fc			 
64fc			;	ld (chk_stund), hl	; stack points.... 
64fc 22 3b fe			ld (chk_stovr), hl 
64ff 22 0a f9			ld (chk_ret_und), hl 
6502 22 c8 f8			ld (chk_ret_ovr), hl 
6505 22 46 f8			ld (chk_loop_ovr), hl 
6508 22 44 f6			ld (chk_data_ovr), hl 
650b c9				ret 
650c				 
650c			check_stacks: 
650c				; check all stack words 
650c			 
650c e5				push hl 
650d d5				push de 
650e			 
650e			;	ld de,(chk_word) 
650e			;	ld hl, (chk_stund)	; stack points.... 
650e			;	if DEBUG_STK_FAULT 
650e			;		DMARK "FAa" 
650e			;		CALLMONITOR 
650e			;	endif 
650e			;	call cmp16 
650e			;	jp z, .chk_faulta 
650e			; 
650e			;	ld de, sfaultsu 
650e			;	jp .chk_fault 
650e			 
650e 2a 3b fe		.chk_faulta: ld hl, (chk_stovr) 
