1125			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
1125			 
1125			;moved to firmware.asm 
1125			;heap_start        .equ  0x9000      ; Starting address of heap 
1125			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
1125			 
1125			;      .org 0 
1125			;      jp    main 
1125			 
1125			 
1125			;      .org  0x100 
1125			;main: 
1125			;      ld    HL, 0x8100 
1125			;      ld    SP, HL 
1125			; 
1125			;      call  heap_init 
1125			; 
1125			;      ; Make some allocations 
1125			;      ld    HL, 12 
1125			;      call  malloc            ; Allocates 0x9004 
1125			; 
1125			;      ld    HL, 12 
1125			;      call  malloc            ; Allocates 0x9014 
1125			; 
1125			;      ld    HL, 12 
1125			;      call  malloc            ; Allocates 0x9024 
1125			; 
1125			;      ; Free some allocations 
1125			;      ld    HL, 0x9014 
1125			;      call  free 
1125			; 
1125			;      ld    HL, 0x9004 
1125			;      call  free 
1125			; 
1125			;      ld    HL, 0x9024 
1125			;      call  free 
1125			; 
1125			; 
1125			;      halt 
