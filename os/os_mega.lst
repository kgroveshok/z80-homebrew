10ec			 
10ec			; only care about direct match or not 
10ec			; hl and de strings 
10ec			; zero set if the same 
10ec			 
10ec			strcmp: 
10ec 1a				ld a, (de) 
10ed be				cp (hl) 
10ee 28 02			jr z, .ssame 
10f0 b7				or a 
10f1 c9				ret 
10f2			 
10f2			.ssame:  
10f2			;	cp 0 
10f2 b7				or a 
10f3 c8				ret z 
10f4			 
10f4 23				inc hl 
10f5 13				inc de 
10f6 18 f4			jr strcmp 
