9e22 18 f4			jr .fnt1 
9e24			 
9e24			.fnt2cmpmorefirst:	 
9e24				; first char of token found.  
9e24			 
9e24 e5				push hl     ; save start of token just in case it is the right one 
9e25 d9				exx 
9e26 e1				pop hl        ; save it to hl' 
9e27 d9				exx 
9e28			 
9e28			 
9e28			.fnt2cmpmore:	 
