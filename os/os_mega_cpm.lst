1bdd			;	inc hl 
1bdd			 
1bdd			;	inc hl 
1bdd			;	inc hl 
1bdd			 
1bdd			;	ld a, 2			; word length is 0 
1bdd 36 02			ld (hl), 2 
1bdf 23				inc hl 
1be0			 
1be0			;	ld a, '~'			; word length is 0 
1be0 36 7e			ld (hl), '~' 
1be2 23				inc hl 
1be3			;	ld a, 0			; save empty word 
1be3 36 00			ld (hl), 0 
