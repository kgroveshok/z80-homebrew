208e 2a 0e f9			ld hl,(cli_ret_sp) 
2091 23				inc hl 
2092 23				inc hl 
2093 22 0e f9			ld (cli_ret_sp),hl 
2096 73				ld (hl), e 
2097 23				inc hl 
2098 72				ld (hl), d 
2099 d1				pop de 
209a e1				pop hl 
209b				if DEBUG_FORTH_STACK_GUARD 
209b cd bf 65				call check_stacks 
209e				endif 
209e c9				ret 
