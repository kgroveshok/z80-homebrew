6986				if DEMARK_VERSION = 1  
6986 00					db 0  
6987				endif  
6987				if DEMARK_VERSION = 1  
6987 e1			.pastdmark: pop hl  
6988				endif  
6988				if DEMARK_VERSION = 0  
6988			.pastdmark: pop af  
6988				endif  
6988			endm  
