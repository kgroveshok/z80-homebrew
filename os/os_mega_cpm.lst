1c0f			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
1c0f			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
1c0f			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
1c0f			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
1c0f			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
1c0f			WORD_SYS_END: equ 0   ; Opcode for all user words 
1c0f			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
1c0f			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
1c0f			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
1c0f			 
1c0f			; Core word preamble macro 
1c0f			 
1c0f			CWHEAD:   macro nxtword opcode lit len opflags 
1c0f				db WORD_SYS_CORE+opcode             
1c0f				; internal op code number 
1c0f				dw nxtword            
1c0f				; link to next dict word block 
1c0f				db len + 1 
1c0f				; literal length of dict word inc zero term 
1c0f				db lit,0              
1c0f				; literal dict word 
1c0f			        ; TODO db opflags        
1c0f				endm 
