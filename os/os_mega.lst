0d19			Mult12U: 
0d19 2e 00		    ld l,0 
0d1b 87			    add a,a 
0d1c 30 01		    jr nc,Mult12U_NoAdd0 
0d1e 19			    add hl,de 
0d1f			Mult12U_NoAdd0: 
0d1f 29			    add hl,hl 
0d20 87			    add a,a 
0d21 30 01		    jr nc,Mult12U_NoAdd1 
0d23 19			    add hl,de 
0d24			Mult12U_NoAdd1: 
0d24 29			    add hl,hl 
0d25 87			    add a,a 
0d26 30 01		    jr nc,Mult12U_NoAdd2 
0d28 19			    add hl,de 
0d29			Mult12U_NoAdd2: 
0d29 29			    add hl,hl 
0d2a 87			    add a,a 
0d2b 30 01		    jr nc,Mult12U_NoAdd3 
0d2d 19			    add hl,de 
0d2e			Mult12U_NoAdd3: 
0d2e 29			    add hl,hl 
0d2f 87			    add a,a 
0d30 30 01		    jr nc,Mult12U_NoAdd4 
0d32 19			    add hl,de 
0d33			Mult12U_NoAdd4: 
0d33 29			    add hl,hl 
0d34 87			    add a,a 
0d35 30 01		    jr nc,Mult12U_NoAdd5 
0d37 19			    add hl,de 
0d38			Mult12U_NoAdd5: 
