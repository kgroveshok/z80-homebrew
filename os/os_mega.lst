4c9f			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4c9f			; | | e.g. 
4c9f			; | | $01 OPEN $01 DO READ . LOOP 
4c9f			; | | 
4c9f			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4c9f			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4c9f			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4c9f			; | | two bytes contain the file id and extent. 
4c9f			; | |  
4c9f			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4c9f			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4c9f			; | | > [!NOTE] 
4c9f			; | | > Compatible with PicoSPINet  
4c9f			 
4c9f					if DEBUG_FORTH_WORDS_KEY 
4c9f						DMARK "REA" 
4c9f				if DEMARK_VERSION = 1  
4c9f e5					push hl  
4ca0 21 a8 4c				ld hl, .dmark  
4ca3 22 9b fd				ld (debug_mark), hl  
4ca6				endif  
