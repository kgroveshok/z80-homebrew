8c55			; 
8c55			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
8c55			; Since the routines get_byte and therefore get_nibble are called, only valid 
8c55			; characters (0-9a-f) are accepted. 
8c55			; 
8c55			;get_word        push    af 
8c55			;                call    get_byte        ; Get the upper byte 
8c55			;                ld      h, a 
8c55			;                call    get_byte        ; Get the lower byte 
8c55			;                ld      l, a 
8c55			;                pop     af 
8c55			;                ret 
8c55			; 
8c55			; Get a byte in hexadecimal notation. The result is returned in A. Since 
8c55			; the routine get_nibble is used only valid characters are accepted - the  
8c55			; input routine only accepts characters 0-9a-f. 
8c55			; 
8c55 c5			get_byte:        push    bc              ; Save contents of B (and C) 
8c56 7e					ld a,(hl) 
8c57 23					inc hl 
8c58 cd 7d 8c		                call    nibble2val      ; Get upper nibble 
8c5b cb 07		                rlc     a 
8c5d cb 07		                rlc     a 
8c5f cb 07		                rlc     a 
8c61 cb 07		                rlc     a 
8c63 47			                ld      b, a            ; Save upper four bits 
8c64 7e					ld a,(hl) 
8c65 cd 7d 8c		                call    nibble2val      ; Get lower nibble 
8c68 b0			                or      b               ; Combine both nibbles 
8c69 c1			                pop     bc              ; Restore B (and C) 
8c6a c9			                ret 
8c6b			; 
8c6b			; Get a hexadecimal digit from the serial line. This routine blocks until 
8c6b			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
8c6b			; to the serial line interface. The lower 4 bits of A contain the value of  
8c6b			; that particular digit. 
