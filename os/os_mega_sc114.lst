98dc			;	FORTH_END_BUFFER: equ 0 
98dc			;else 
98dc			FORTH_END_BUFFER: equ 127 
98dc			;endif 
98dc			 
98dc			FORTH_TRUE: equ 1 
98dc			FORTH_FALSE: equ 0 
