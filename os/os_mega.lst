11cf dd 6e 00		      ld    L, (IX+0)               ; next_free to HL 
11d2 dd 66 01		      ld    H, (IX+1) 
11d5			 
11d5 dd 75 02		      ld    (IX+2), L               ; HL to this_free 
11d8 dd 74 03		      ld    (IX+3), H 
