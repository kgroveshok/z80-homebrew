43e4			.SESEL: 
43e4				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
43e4			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
43e4			; | | Zero is disabled storage. 
43e4					if DEBUG_FORTH_WORDS_KEY 
43e4						DMARK "BN?" 
43e4						CALLMONITOR 
43e4					endif 
43e4					ld a, (spi_device_id) 
43e4					sub '0' 
43e4					ld h, 0 
43e4					ld l, a 
43e4					FORTH_PUSH_VALUEHL 
43e4					;call forth_push_numhl 
43e4					NEXTW 
43e4			.SESELS: 
43e4				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
43e4			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
43e4			; | | Set to zero to disable storage. 
43e4					if DEBUG_FORTH_WORDS_KEY 
43e4						DMARK "BNK" 
43e4						CALLMONITOR 
43e4					endif 
43e4			 
43e4					ld a, 255 
43e4					ld (spi_cartdev), a 
43e4			 
43e4					; get bank 
43e4			 
43e4					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
43e4			 
43e4			;		push hl 
43e4			 
43e4					; destroy value TOS 
43e4			 
43e4					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
43e4			 
43e4					; one value on hl get other one back 
43e4			 
43e4			;		pop hl 
43e4			 
43e4			 
43e4					ld c, SPI_CE_HIGH 
43e4					ld b, '0'    ; human readable bank number 
43e4			 
43e4					ld a, l 
43e4			 
43e4					if DEBUG_FORTH_WORDS 
43e4						DMARK "BNK" 
43e4						CALLMONITOR 
43e4					endif 
43e4			 
43e4					; active low 
43e4			 
43e4			;		cp 0 
43e4					or a 
43e4					jr z, .bset 
43e4					cp 1 
43e4					jr nz, .b2 
43e4					res 0, c 
43e4					ld b, '1'    ; human readable bank number 
43e4			.b2:		cp 2 
43e4					jr nz, .b3 
43e4					res 1, c 
43e4					ld b, '2'    ; human readable bank number 
43e4			.b3:		cp 3 
43e4					jr nz, .b4 
43e4					res 2, c 
43e4					ld b, '3'    ; human readable bank number 
43e4			.b4:		cp 4 
43e4					jr nz, .b5 
43e4					res 3, c 
43e4					ld b, '4'    ; human readable bank number 
43e4			.b5:		cp 5 
43e4					jr nz, .bset 
43e4					res 4, c 
43e4					ld b, '5'    ; human readable bank number 
43e4			 
43e4			.bset: 
43e4					ld a, c 
43e4					ld (spi_device),a 
43e4					ld a, b 
43e4					ld (spi_device_id),a 
43e4					if DEBUG_FORTH_WORDS 
43e4						DMARK "BN2" 
43e4						CALLMONITOR 
43e4					endif 
43e4			 
43e4					; set default SPI clk pulse time as disabled for BANK use 
43e4			 
43e4					ld a, 0 
43e4					ld (spi_clktime), a 
43e4			 
43e4					NEXTW 
