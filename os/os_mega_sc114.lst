8a58			 
8a58			; compare hl and de 
8a58			; returns:  
8a58			; if hl = de, z=1, s=0, c0=0 
8a58			; if hl > de, z=0, s=0, c=0 
8a58			; if hl < de, z=0, s=1, c=1 
8a58			cmp16:	 
8a58 b7				or a 
8a59 ed 52			sbc hl,de 
8a5b e0				ret po 
8a5c 7c				ld a,h 
8a5d 1f				rra 
8a5e ee 40			xor 01000000B 
8a60 37				scf 
8a61 8f				adc a,a 
8a62 c9				ret 
