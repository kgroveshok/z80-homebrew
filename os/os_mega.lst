0121 3e 5f		ld a, '_'  
0123 32 9b fd		ld (debug_mark),a  
0126 32 9c fd		ld (debug_mark+1),a  
0129 32 9d fd		ld (debug_mark+2),a  
012c 3e 00		ld a,0  
