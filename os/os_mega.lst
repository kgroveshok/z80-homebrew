2c5c			; | MONITOR ( -- ) Display system breakpoint/monitor | DONE 
2c5c			; | | At start the current various registers will be displayed with contents. 
2c5c			; | | Top right corner will show the most recent debug marker seen. 
2c5c			; | | The bottom of the screen will also show the values of the data stack pointer (DSP) 
2c5c			; | | and the return stack pointer (RSP). 
2c5c			; | | Pressing: 
2c5c			; | |  
2c5c			; | |    1 - Initial screen 
2c5c			; | |  
2c5c			; | |    2 - Display a data dump of HL 
2c5c			; | |  
2c5c			; | |    3 - Display a data dump of DE 
2c5c			; | |  
2c5c			; | |    4 - Display a data dump of BC 
2c5c			; | |  
2c5c			; | |    5 - Display a data dump of HL 
2c5c			; | |  
2c5c			; | |    6 - Display a data dump of DSP 
2c5c			; | |  
2c5c			; | |    7 - Display a data dump of RSP 
2c5c			; | |  
2c5c			; | |    8 - Display a data dump of what is at DSP 
2c5c			; | |  
2c5c			; | |    9 - Display a data dump of what is at RSP 
2c5c			; | |  
2c5c			; | |    0 - Exit monitor and continue running. This will also enable break points 
2c5c			; | |  
2c5c			; | |    * - Disable break points 
2c5c			; | |  
2c5c			; | |    # - Enter traditional monitor mode 
2c5c			; | |  
2c5c			; | | 
2c5c			; | | Monitor Mode 
2c5c			; | | ------------ 
2c5c			; | | A prompt of '>' will be shown for various commands: 
2c5c			; | |  
2c5c			; | |    D xxxx - Display a data dump starting from hex address xxxx 
2c5c			; | |  
2c5c			; | |    C - Continue display a data dump from the last set address 
2c5c			; | |  
2c5c			; | |    M xxxx - Set start of memory edit at address xx 
2c5c			; | |  
2c5c			; | |    U xx - Poke the hex byte xx into the address set by M and increment the address to the next location 
2c5c			; | |  
2c5c			; | |    G xxxx - Exec code at specific address 
2c5c			; | |  
2c5c			; | |    Q - Return to previous 
2c5c				if DEBUG_FORTH_WORDS_KEY 
2c5c					DMARK "MON" 
2c5c				if DEMARK_VERSION = 1  
2c5c e5					push hl  
2c5d 21 65 2c				ld hl, .dmark  
2c60 22 9b fd				ld (debug_mark), hl  
2c63				endif  
