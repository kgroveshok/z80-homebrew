109d			;	endif 
109d			; 
109d			;ld de, .str1 
109d			;ld hl, .str2 
109d			;call strcmp 
109d			;jr c, .c1 
109d			; 
109d			;	if DEBUG_FORTH_WORDS 
109d			;		DMARK "Nc1" 
109d			;		CALLMONITOR 
109d			;	endif 
109d			;.c1: 
109d			;;this 
109d			;	if DEBUG_FORTH_WORDS 
109d			;		DMARK "cc1" 
109d			;		CALLMONITOR 
109d			;	endif 
109d			; 
109d			;ld de, .str1 
109d			;ld hl, .str1 
109d			;call strcmp 
109d			;jr c, .c2 
109d			;;this 
109d			;	if DEBUG_FORTH_WORDS 
109d			;		DMARK "Nc2" 
109d			;		CALLMONITOR 
109d			;	endif 
109d			;.c2: 
109d			; 
109d			;	if DEBUG_FORTH_WORDS 
