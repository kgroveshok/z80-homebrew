5168			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
5168			; | 
5168			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
5168			; | |  
5168			; | | e.g. 
5168			; | |         #30 a var ! 
5168			; | |         a var @ . 
5168			; | |   
5168			; | |     Displays the number 30 
5168			; | | 
5168			; | | Each variable pointer is a word so can use for any words that use that:  
5168			; | |  
5168			; | | e.g. 
5168			; | |  
5168			; | |         #30 a var 2! 
5168			; | |         a var 2@ . 
5168			; | |   
5168			; | |     Displays the number 30 
5168			; | |  
5168			; | | > [!NOTE]  
5168			; ! | > If a full string is passed then only the first char is looked at 
5168			; | | > Any other char could exceed bounds checks!  
5168			; | | > 
5168			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
5168			 
5168					if DEBUG_FORTH_WORDS_KEY 
5168						DMARK "VAR" 
5168				if DEMARK_VERSION = 1  
5168 e5					push hl  
5169 21 71 51				ld hl, .dmark  
