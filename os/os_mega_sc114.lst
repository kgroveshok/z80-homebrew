8d26			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
8d26			 
8d26			 
8d26			;Converts an ASCII string to an unsigned 16-bit integer 
8d26			;Quits when it reaches a non-decimal digit 
8d26			 
8d26			string_to_uint16: 
8d26			atoui_16: 
8d26			;Input: 
8d26			;     DE points to the string 
8d26			;Outputs: 
8d26			;     HL is the result 
8d26			;     A is the 8-bit value of the number 
8d26			;     DE points to the byte after the number 
8d26			;Destroys: 
8d26			;     BC 
8d26			;       if the string is non-empty, BC is HL/10 
8d26			;Size:  24 bytes 
8d26			;Speed: 42+d(104+{0,9}) 
8d26			;       d is the number of digits in the number 
8d26			;       max is 640 cycles for a 5 digit number 
8d26			;Assuming no leading zeros: 
8d26			;1 digit:  146cc 
8d26			;2 digit:  250cc 
8d26			;3 digit:  354cc or 363cc (avg: 354.126cc) 
8d26			;4 digit:  458cc or 467cc (avg: 458.27cc) 
8d26			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
8d26			;avg: 544.81158447265625cc (544+13297/16384) 
8d26			;=============================================================== 
8d26 21 00 00		  ld hl,0 
8d29			.u16a: 
8d29 1a			  ld a,(de) 
8d2a d6 30		  sub 30h 
8d2c fe 0a		  cp 10 
8d2e d0			  ret nc 
8d2f 13			  inc de 
8d30 44			  ld b,h 
8d31 4d			  ld c,l 
8d32 29			  add hl,hl 
8d33 29			  add hl,hl 
8d34 09			  add hl,bc 
8d35 29			  add hl,hl 
8d36 85			  add a,l 
8d37 6f			  ld l,a 
8d38 30 ef		  jr nc,.u16a 
8d3a 24			  inc h 
8d3b c3 29 8d		  jp .u16a 
8d3e			 
