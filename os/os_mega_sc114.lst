99f5			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
99f5			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
99f5			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
99f5			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
99f5			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
99f5			WORD_SYS_END: equ 0   ; Opcode for all user words 
99f5			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
99f5			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
99f5			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
99f5			 
99f5			; Core word preamble macro 
99f5			 
99f5			CWHEAD:   macro nxtword opcode lit len opflags 
99f5				db WORD_SYS_CORE+opcode             
99f5				; internal op code number 
99f5				dw nxtword            
99f5				; link to next dict word block 
99f5				db len + 1 
99f5				; literal length of dict word inc zero term 
99f5				db lit,0              
99f5				; literal dict word 
99f5			        ; TODO db opflags        
99f5				endm 
