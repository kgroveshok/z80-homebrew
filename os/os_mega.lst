110b			; hl and de strings 
110b			; zero set if the same 
110b			 
110b			strcmp: 
110b 1a				ld a, (de) 
110c be				cp (hl) 
110d 28 02			jr z, .ssame 
110f b7				or a 
1110 c9				ret 
1111			 
