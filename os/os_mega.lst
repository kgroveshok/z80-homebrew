68b9			  
68b9			; **********************************************************************  
68b9			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
68b9			; **********************************************************************  
68b9			;  
68b9			; **  Written as a Small Computer Monitor App   
68b9			; **  Version 0.1 SCC 2018-05-16  
68b9			; **  www.scc.me.uk  
68b9			;  
68b9			; **********************************************************************  
68b9			;  
68b9			; This module provides support for alphanumeric LCD modules using with  
68b9			; *  HD44780 (or compatible) controller  
68b9			; *  5 x 7 pixel fonts  
68b9			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
68b9			; *  Interface via six digital outputs to the display (see below)  
68b9			;  
68b9			; LCD module pinout:  
68b9			;   1  Vss   0v supply  
68b9			;   2  Vdd   5v supply  
68b9			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
68b9			;   4  RS    High = data, Low = instruction  
68b9			;   5  R/W   High = Read, Low = Write  
68b9			;   6  E     Enable signal (active high)  
68b9			;   7  DB0   Data bit 0  
68b9			;   8  DB1   Data bit 1  
68b9			;   9  DB2   Data bit 2  
68b9			;  10  DB3   Data bit 3  
68b9			;  11  DB4   Data bit 4  
68b9			;  12  DB5   Data bit 5  
68b9			;  13  DB6   Data bit 6  
68b9			;  14  DB7   Data bit 7  
68b9			;  15  A     Backlight anode (+)  
68b9			;  16  K     Backlight cathode (-)  
68b9			;  
68b9			; This interfacing method uses 4-bit data mode and uses time delays  
68b9			; rather than polling the display's ready status. As a result the   
68b9			; interface only requires 6 simple output lines:  
68b9			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
68b9			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
68b9			;   LCD DB4 = Microcomputer output port bit 4  
68b9			;   LCD DB5 = Microcomputer output port bit 5  
68b9			;   LCD DB6 = Microcomputer output port bit 6  
68b9			;   LCD DB7 = Microcomputer output port bit 7  
68b9			; Display's R/W is connected to 0v so it is always in write mode  
68b9			; All 6 connections must be on the same port address <kLCDPrt>  
68b9			; This method also allows a decent length of cable from micro to LCD  
68b9			;  
68b9			; **********************************************************************  
68b9			;  
68b9			; To include the code for any given function provided by this module,   
68b9			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
68b9			; the parent source file.  
68b9			; For example:  #REQUIRES   uHexPrefix  
68b9			;  
68b9			; Also #INCLUDE this file at some point after the #REQUIRES statements  
68b9			; in the parent source file.  
68b9			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
68b9			;  
68b9			; These are the function names provided by this module:  
68b9			; fLCD_Init                     ;Initialise LCD  
68b9			; fLCD_Inst                     ;Send instruction to LCD  
68b9			; fLCD_Data                     ;Send data byte to LCD  
68b9			; fLCD_Pos                      ;Position cursor  
68b9			; fLCD_Str                      ;Display string  
68b9			; fLCD_Def                      ;Define custom character  
68b9			;  
68b9			; **********************************************************************  
68b9			;  
68b9			; Requires SCMonAPI.asm to also be included in the project  
68b9			;  
68b9			  
68b9			  
68b9			; **********************************************************************  
68b9			; **  Constants  
68b9			; **********************************************************************  
68b9			  
68b9			; Constants that must be defined externally  
68b9			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
68b9			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
68b9			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
68b9			;kLCDWidth: EQU 20             ;Width in characters  
68b9			  
68b9			; general line offsets in any frame buffer  
68b9			  
68b9			  
68b9			display_row_1: equ 0  
68b9			display_row_2: equ display_row_1+display_cols  
68b9			display_row_3: equ display_row_2 + display_cols  
68b9			display_row_4: equ display_row_3 + display_cols  
68b9			;display_row_4_eol:   
68b9			  
68b9			  
68b9			; Cursor position values for the start of each line  
68b9			  
68b9			; E  
68b9			kLCD_Line1: EQU 0x00   
68b9			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
68b9			; E1  
68b9			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
68b9			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
68b9			  
68b9			; Instructions to send as A register to fLCD_Inst  
68b9			kLCD_Clear: EQU 00000001b     ;LCD clear  
68b9			kLCD_Off:   EQU 00001000b     ;LCD off  
68b9			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
68b9			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
68b9			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
68b9			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
68b9			  
68b9			; Constants used by this code module  
68b9			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
68b9			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
68b9			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
68b9			  
68b9			  
68b9			  
68b9			; **********************************************************************  
68b9			; **  LCD support functions  
68b9			; **********************************************************************  
68b9			  
68b9			; Initialise alphanumeric LCD module  
68b9			; LCD control register codes:  
68b9			;   DL   0 = 4-bit mode        1 = 8-bit mode  
68b9			;   N    0 = 1-line mode       1 = 2-line mode  
68b9			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
68b9			;   D    0 = Display off       1 = Display on  
68b9			;   C    0 = Cursor off        1 = Cursor on  
68b9			;   B    0 = Blinking off      1 = Blinking on  
68b9			;   ID   0 = Decrement mode    1 = Increment mode  
68b9			;   SH   0 = Entire shift off  1 = Entire shift on  
68b9 3e 28		fLCD_Init:  LD   A, 40  
68bb cd e0 69		            CALL LCDDelay       ;Delay 40ms after power up  
68be			; For reliable reset set 8-bit mode - 3 times  
68be cd b0 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68c1 cd b0 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68c4 cd b0 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68c7			; Set 4-bit mode  
68c7 cd ac 69		            CALL WrFn4bit       ;Function = 4-bit mode  
68ca cd de 69		            CALL LCDDelay1      ;Delay 37 us or more  
68cd			; Function set  
68cd 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
68cf cd e2 68		            CALL fLCD_Inst      ;2 line, display on  
68d2			; Display On/Off control  
68d2 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
68d4 cd e2 68		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
68d7			; Display Clear  
68d7 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
68d9 cd e2 68		            CALL fLCD_Inst      ;Clear display  
68dc			; Entry mode  
68dc 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
68de cd e2 68		            CALL fLCD_Inst      ;Increment mode, shift off  
68e1			; Display module now initialised  
68e1 c9			            RET  
68e2			; ok to here  
68e2			  
68e2			; Write instruction to LCD  
68e2			;   On entry: A = Instruction byte to be written  
68e2			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
68e2 f5			fLCD_Inst:  PUSH AF  
68e3 f5			            PUSH AF  
68e4 cd f6 68		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
68e7 f1			            POP  AF  
68e8 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
68e9 17			            RLA  
68ea 17			            RLA  
68eb 17			            RLA  
68ec cd f6 68		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
68ef 3e 02		            LD   A, 2  
68f1 cd e0 69		            CALL LCDDelay       ;Delay 2 ms to complete   
68f4 f1			            POP  AF  
68f5 c9			            RET  
68f6			Wr4bits:   
68f6 f5					push af  
68f7 3a fb fa				ld a, (display_lcde1e2)  
68fa fe 00				cp 0     ; e  
68fc 20 10				jr nz, .wea2	  
68fe f1					pop af  
68ff e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6901 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6903 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6905 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6907 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6909 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
690b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
690d c9			            RET  
690e f1			.wea2:		pop af  
690f e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6911 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6913 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6915 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6917 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6919 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
691b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
691d c9			            RET  
691e			  
691e			  
691e			; Write data to LCD  
691e			;   On entry: A = Data byte to be written  
691e			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
691e f5			fLCD_Data:  PUSH AF  
691f f5			            PUSH AF  
6920 cd 32 69		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6923 f1			            POP  AF  
6924 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6925 17			            RLA  
6926 17			            RLA  
6927 17			            RLA  
6928 cd 32 69		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
692b 3e 96		            LD   A, 150  
692d 3d			Wait:      DEC  A              ;Wait a while to allow data   
692e 20 fd		            JR   NZ, Wait      ;  write to complete  
6930 f1			            POP  AF  
6931 c9			            RET  
6932			Wr4bitsa:     
6932 f5					push af  
6933 3a fb fa				ld a, (display_lcde1e2)  
6936 fe 00				cp 0     ; e1  
6938 20 16				jr nz, .we2	  
693a f1					pop af  
693b e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
693d cb d7		            SET  kLCDBitRS, A  
693f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6941 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6943 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6945 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6947 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6949 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
694b cb 97		            RES  kLCDBitRS, A  
694d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
694f c9			            RET  
6950 f1			.we2:		pop af  
6951 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6953 cb d7		            SET  kLCDBitRS, A  
6955 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6957 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6959 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
695b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
695d cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
695f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6961 cb 97		            RES  kLCDBitRS, A  
6963 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6965 c9			            RET  
6966			  
6966			  
6966			; Position cursor to specified location  
6966			;   On entry: A = Cursor position  
6966			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6966 f5			fLCD_Pos:   PUSH AF  
6967					; at this point set the E1 or E2 flag depending on position  
6967			  
6967 c5					push bc  
6968			;		push af  
6968 06 00				ld b, 0  
696a 4f					ld c, a  
696b 3e 4f				ld a, kLCD_Line3-1  
696d b7			 		or a      ;clear carry flag  
696e 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
696f 38 04				jr c, .pe1  
6971			  
6971					; E selection  
6971 cb 80				res 0, b         ; bit 0 unset e  
6973			;		pop af    ; before line 3 so recover orig pos  
6973			;		ld c, a    ; save for poking back  
6973 18 06				jr .peset	          
6975			.pe1:          	; E2 selection  
6975 cb c0				set 0, b         ; bit 0 set e1  
6977 79					ld a, c  
6978 de 4f				sbc a, kLCD_Line3-1  
697a 4f					ld c, a	         ; save caculated offset  
697b			;		pop af     ; bin this original value now we have calculated form  
697b			  
697b			.peset:		; set bit  
697b 78					ld a, b  
697c 32 fb fa				ld (display_lcde1e2), a 	  
697f 79					ld a, c  
6980 c1					pop bc  
6981			  
6981 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6983 cd e2 68		            CALL fLCD_Inst      ;Write instruction to LCD  
6986 f1			            POP  AF  
6987 c9			            RET  
6988			  
6988			  
6988			; Output text string to LCD  
6988			;   On entry: DE = Pointer to null terminated text string  
6988			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6988 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6989 b7			            OR   A              ;Null terminator?  
698a c8			            RET  Z              ;Yes, so finished  
698b cd 1e 69		            CALL fLCD_Data      ;Write character to display  
698e 13			            INC  DE             ;Point to next character  
698f 18 f7		            JR   fLCD_Str       ;Repeat  
6991 c9					ret  
6992			  
6992			; Define custom character  
6992			;   On entry: A = Character number (0 to 7)  
6992			;             DE = Pointer to character bitmap data  
6992			;   On exit:  A = Next character number  
6992			;             DE = Next location following bitmap  
6992			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6992			; Character is   
6992 c5			fLCD_Def:   PUSH BC  
6993 f5			            PUSH AF  
6994 07			            RLCA                ;Calculate location  
6995 07			            RLCA                ;  for bitmap data  
6996 07			            RLCA                ;  = 8 x CharacterNumber  
6997 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6999 cd e2 68		            CALL fLCD_Inst      ;Write instruction to LCD  
699c 06 00		            LD   B, 0  
699e 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
699f cd 1e 69		            CALL fLCD_Data      ;Write byte to display  
69a2 13			            INC  DE             ;Point to next byte  
69a3 04			            INC  B              ;Count bytes  
69a4 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
69a6 28 f6		            JR   Z, Loop       ;No, so repeat  
69a8 f1			            POP  AF  
69a9 3c			            INC  A              ;Increment character number  
69aa c1			            POP  BC  
69ab c9			            RET  
