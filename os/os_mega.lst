4b7b			; | READ ( -- n  )  Reads next page of current file id and push to stack | DONE 
4b7b			; | | e.g. 
4b7b			; | | $01 OPEN $01 DO READ . LOOP 
4b7b			; | | 
4b7b			; | | As this word only reads one 64 byte block in at a time, if the APPEND word has created extra blocks for the excess, this READ 
4b7b			; | | word is unaware so the long string needs to be joined if the string is a full. A single block read might be what you want, 
4b7b			; | | but if not then writing a word to join blocks will be required. The upshot is a full string will be 62 bytes as the first 
4b7b			; | | two bytes contain the file id and extent. 
4b7b			; | |  
4b7b			; | | Note: There is a flag that enables/disables long block reads called 'store_longread' and a poke of a non-zero value will 
4b7b			; | | enable the code to automatically read futher blocks if full. It is BUGGY so don't use for now. 
4b7b			; | | > [!NOTE] 
4b7b			; | | > Compatible with PicoSPINet  
4b7b			 
4b7b					if DEBUG_FORTH_WORDS_KEY 
4b7b						DMARK "REA" 
4b7b				if DEMARK_VERSION = 1  
4b7b e5					push hl  
4b7c 21 84 4b				ld hl, .dmark  
4b7f 22 9b fd				ld (debug_mark), hl  
4b82				endif  
