bc0d					ld c, SPI_CE_HIGH 
bc0d					ld b, '0'    ; human readable bank number 
bc0d			 
bc0d					ld a, l 
bc0d			 
bc0d					if DEBUG_FORTH_WORDS 
bc0d						DMARK "BNK" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d			 
bc0d					; active low 
bc0d			 
bc0d			;		cp 0 
bc0d					or a 
bc0d					jr z, .bset 
bc0d					cp 1 
bc0d					jr nz, .b2 
bc0d					res 0, c 
bc0d					ld b, '1'    ; human readable bank number 
bc0d			.b2:		cp 2 
bc0d					jr nz, .b3 
bc0d					res 1, c 
bc0d					ld b, '2'    ; human readable bank number 
bc0d			.b3:		cp 3 
bc0d					jr nz, .b4 
bc0d					res 2, c 
bc0d					ld b, '3'    ; human readable bank number 
bc0d			.b4:		cp 4 
bc0d					jr nz, .b5 
bc0d					res 3, c 
bc0d					ld b, '4'    ; human readable bank number 
bc0d			.b5:		cp 5 
bc0d					jr nz, .bset 
bc0d					res 4, c 
bc0d					ld b, '5'    ; human readable bank number 
bc0d			 
bc0d			.bset: 
bc0d					ld a, c 
bc0d					ld (spi_device),a 
bc0d					ld a, b 
bc0d					ld (spi_device_id),a 
bc0d					if DEBUG_FORTH_WORDS 
bc0d						DMARK "BN2" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d			 
bc0d					; set default SPI clk pulse time as disabled for BANK use 
bc0d			 
bc0d					ld a, 0 
bc0d					ld (spi_clktime), a 
bc0d			 
bc0d					NEXTW 
bc0d			 
bc0d			.CARTDEV: 
bc0d				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
bc0d			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
bc0d			; | | Set to zero to disable devices. 
bc0d					if DEBUG_FORTH_WORDS_KEY 
bc0d						DMARK "CDV" 
bc0d						CALLMONITOR 
bc0d					endif 
bc0d			 
bc0d					; disable se storage bank selection 
