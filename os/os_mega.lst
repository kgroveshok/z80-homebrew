68a9			  
68a9			; **********************************************************************  
68a9			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
68a9			; **********************************************************************  
68a9			;  
68a9			; **  Written as a Small Computer Monitor App   
68a9			; **  Version 0.1 SCC 2018-05-16  
68a9			; **  www.scc.me.uk  
68a9			;  
68a9			; **********************************************************************  
68a9			;  
68a9			; This module provides support for alphanumeric LCD modules using with  
68a9			; *  HD44780 (or compatible) controller  
68a9			; *  5 x 7 pixel fonts  
68a9			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
68a9			; *  Interface via six digital outputs to the display (see below)  
68a9			;  
68a9			; LCD module pinout:  
68a9			;   1  Vss   0v supply  
68a9			;   2  Vdd   5v supply  
68a9			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
68a9			;   4  RS    High = data, Low = instruction  
68a9			;   5  R/W   High = Read, Low = Write  
68a9			;   6  E     Enable signal (active high)  
68a9			;   7  DB0   Data bit 0  
68a9			;   8  DB1   Data bit 1  
68a9			;   9  DB2   Data bit 2  
68a9			;  10  DB3   Data bit 3  
68a9			;  11  DB4   Data bit 4  
68a9			;  12  DB5   Data bit 5  
68a9			;  13  DB6   Data bit 6  
68a9			;  14  DB7   Data bit 7  
68a9			;  15  A     Backlight anode (+)  
68a9			;  16  K     Backlight cathode (-)  
68a9			;  
68a9			; This interfacing method uses 4-bit data mode and uses time delays  
68a9			; rather than polling the display's ready status. As a result the   
68a9			; interface only requires 6 simple output lines:  
68a9			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
68a9			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
68a9			;   LCD DB4 = Microcomputer output port bit 4  
68a9			;   LCD DB5 = Microcomputer output port bit 5  
68a9			;   LCD DB6 = Microcomputer output port bit 6  
68a9			;   LCD DB7 = Microcomputer output port bit 7  
68a9			; Display's R/W is connected to 0v so it is always in write mode  
68a9			; All 6 connections must be on the same port address <kLCDPrt>  
68a9			; This method also allows a decent length of cable from micro to LCD  
68a9			;  
68a9			; **********************************************************************  
68a9			;  
68a9			; To include the code for any given function provided by this module,   
68a9			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
68a9			; the parent source file.  
68a9			; For example:  #REQUIRES   uHexPrefix  
68a9			;  
68a9			; Also #INCLUDE this file at some point after the #REQUIRES statements  
68a9			; in the parent source file.  
68a9			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
68a9			;  
68a9			; These are the function names provided by this module:  
68a9			; fLCD_Init                     ;Initialise LCD  
68a9			; fLCD_Inst                     ;Send instruction to LCD  
68a9			; fLCD_Data                     ;Send data byte to LCD  
68a9			; fLCD_Pos                      ;Position cursor  
68a9			; fLCD_Str                      ;Display string  
68a9			; fLCD_Def                      ;Define custom character  
68a9			;  
68a9			; **********************************************************************  
68a9			;  
68a9			; Requires SCMonAPI.asm to also be included in the project  
68a9			;  
68a9			  
68a9			  
68a9			; **********************************************************************  
68a9			; **  Constants  
68a9			; **********************************************************************  
68a9			  
68a9			; Constants that must be defined externally  
68a9			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
68a9			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
68a9			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
68a9			;kLCDWidth: EQU 20             ;Width in characters  
68a9			  
68a9			; general line offsets in any frame buffer  
68a9			  
68a9			  
68a9			display_row_1: equ 0  
68a9			display_row_2: equ display_row_1+display_cols  
68a9			display_row_3: equ display_row_2 + display_cols  
68a9			display_row_4: equ display_row_3 + display_cols  
68a9			;display_row_4_eol:   
68a9			  
68a9			  
68a9			; Cursor position values for the start of each line  
68a9			  
68a9			; E  
68a9			kLCD_Line1: EQU 0x00   
68a9			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
68a9			; E1  
68a9			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
68a9			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
68a9			  
68a9			; Instructions to send as A register to fLCD_Inst  
68a9			kLCD_Clear: EQU 00000001b     ;LCD clear  
68a9			kLCD_Off:   EQU 00001000b     ;LCD off  
68a9			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
68a9			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
68a9			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
68a9			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
68a9			  
68a9			; Constants used by this code module  
68a9			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
68a9			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
68a9			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
68a9			  
68a9			  
68a9			  
68a9			; **********************************************************************  
68a9			; **  LCD support functions  
68a9			; **********************************************************************  
68a9			  
68a9			; Initialise alphanumeric LCD module  
68a9			; LCD control register codes:  
68a9			;   DL   0 = 4-bit mode        1 = 8-bit mode  
68a9			;   N    0 = 1-line mode       1 = 2-line mode  
68a9			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
68a9			;   D    0 = Display off       1 = Display on  
68a9			;   C    0 = Cursor off        1 = Cursor on  
68a9			;   B    0 = Blinking off      1 = Blinking on  
68a9			;   ID   0 = Decrement mode    1 = Increment mode  
68a9			;   SH   0 = Entire shift off  1 = Entire shift on  
68a9 3e 28		fLCD_Init:  LD   A, 40  
68ab cd d0 69		            CALL LCDDelay       ;Delay 40ms after power up  
68ae			; For reliable reset set 8-bit mode - 3 times  
68ae cd a0 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68b1 cd a0 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68b4 cd a0 69		            CALL WrFn8bit       ;Function = 8-bit mode  
68b7			; Set 4-bit mode  
68b7 cd 9c 69		            CALL WrFn4bit       ;Function = 4-bit mode  
68ba cd ce 69		            CALL LCDDelay1      ;Delay 37 us or more  
68bd			; Function set  
68bd 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
68bf cd d2 68		            CALL fLCD_Inst      ;2 line, display on  
68c2			; Display On/Off control  
68c2 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
68c4 cd d2 68		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
68c7			; Display Clear  
68c7 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
68c9 cd d2 68		            CALL fLCD_Inst      ;Clear display  
68cc			; Entry mode  
68cc 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
68ce cd d2 68		            CALL fLCD_Inst      ;Increment mode, shift off  
68d1			; Display module now initialised  
68d1 c9			            RET  
68d2			; ok to here  
68d2			  
68d2			; Write instruction to LCD  
68d2			;   On entry: A = Instruction byte to be written  
68d2			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
68d2 f5			fLCD_Inst:  PUSH AF  
68d3 f5			            PUSH AF  
68d4 cd e6 68		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
68d7 f1			            POP  AF  
68d8 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
68d9 17			            RLA  
68da 17			            RLA  
68db 17			            RLA  
68dc cd e6 68		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
68df 3e 02		            LD   A, 2  
68e1 cd d0 69		            CALL LCDDelay       ;Delay 2 ms to complete   
68e4 f1			            POP  AF  
68e5 c9			            RET  
68e6			Wr4bits:   
68e6 f5					push af  
68e7 3a fb fa				ld a, (display_lcde1e2)  
68ea fe 00				cp 0     ; e  
68ec 20 10				jr nz, .wea2	  
68ee f1					pop af  
68ef e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
68f1 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
68f3 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
68f5 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
68f7 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
68f9 cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
68fb d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
68fd c9			            RET  
68fe f1			.wea2:		pop af  
68ff e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6901 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6903 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6905 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6907 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6909 cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
690b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
690d c9			            RET  
690e			  
690e			  
690e			; Write data to LCD  
690e			;   On entry: A = Data byte to be written  
690e			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
690e f5			fLCD_Data:  PUSH AF  
690f f5			            PUSH AF  
6910 cd 22 69		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6913 f1			            POP  AF  
6914 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6915 17			            RLA  
6916 17			            RLA  
6917 17			            RLA  
6918 cd 22 69		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
691b 3e 96		            LD   A, 150  
691d 3d			Wait:      DEC  A              ;Wait a while to allow data   
691e 20 fd		            JR   NZ, Wait      ;  write to complete  
6920 f1			            POP  AF  
6921 c9			            RET  
6922			Wr4bitsa:     
6922 f5					push af  
6923 3a fb fa				ld a, (display_lcde1e2)  
6926 fe 00				cp 0     ; e1  
6928 20 16				jr nz, .we2	  
692a f1					pop af  
692b e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
692d cb d7		            SET  kLCDBitRS, A  
692f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6931 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6933 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6935 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6937 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6939 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
693b cb 97		            RES  kLCDBitRS, A  
693d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
693f c9			            RET  
6940 f1			.we2:		pop af  
6941 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6943 cb d7		            SET  kLCDBitRS, A  
6945 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6947 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6949 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
694b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
694d cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
694f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6951 cb 97		            RES  kLCDBitRS, A  
6953 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6955 c9			            RET  
