0276			 
0276			storage_init: 
0276			 
0276			 
0276					; set default SPI clk pulse time as disabled 
0276			 
0276 3e 00				ld a, 0 
0278 32 92 f9				ld (spi_clktime), a 
027b			 
027b					; init hardware 
027b			 
027b 3e cf		            LD   A, 11001111b 
027d d3 82		            OUT  (storage_actl), A  ;Port A = PIO 'control' mode 
027f 3e 00		            LD   A, 00000000b 
0281 cb f7			set SPI_DO,a 
0283			;            LD   A, SPI_DO      ; only one input line  the rest are outputs 
0283 d3 82		            OUT  (storage_actl),A   ;Port A = all lines are outputs 
0285			 
0285 3e cf		            LD   A, 11001111b 
0287 d3 83		            OUT  (storage_bctl), A  ;Port A = PIO 'control' mode 
0289 3e 00		            LD   A, 00000000b 
028b d3 83		            OUT  (storage_bctl),A   ;Port A = all lines are outputs 
028d			 
028d				; set all external spi devices off  
028d 3e ff			ld a, 255 
028f 32 8e f9			ld (spi_device), a 
0292 32 91 f9			ld (spi_cartdev), a 
0295			 
0295					; ensure the spi bus is in a default stable state 
0295 cd 38 01				call se_stable_spi 
