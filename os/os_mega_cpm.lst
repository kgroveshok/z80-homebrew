0e1a			; Get 2 ASCII characters as hex byte from pointer in hl 
0e1a			 
0e1a			BYTERD: 
0e1a 16 00			LD	D,00h		;Set up 
0e1c cd 24 0e			CALL	HEXCON		;Get byte and convert to hex 
0e1f 87				ADD	A,A		;First nibble so 
0e20 87				ADD	A,A		;multiply by 16 
0e21 87				ADD	A,A		; 
0e22 87				ADD	A,A		; 
0e23 57				LD	D,A		;Save hi nibble in D 
0e24			HEXCON: 
0e24 7e				ld a, (hl)		;Get next chr 
0e25 23				inc hl 
0e26 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
0e28 fe 0a			CP	00Ah		;Is it 0-9 ? 
0e2a 38 02			JR	C,NALPHA	;If so miss next bit 
0e2c d6 07			SUB	007h		;Else convert alpha 
0e2e			NALPHA: 
0e2e b2				OR	D		;Add hi nibble back 
0e2f c9				RET			; 
