1120			 
1120			; from https://gist.github.com/tomstorey/947a8b084bad69391a4b2a1c5b6d69ca 
1120			 
1120			;moved to firmware.asm 
1120			;heap_start        .equ  0x9000      ; Starting address of heap 
1120			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
1120			 
1120			;      .org 0 
1120			;      jp    main 
1120			 
1120			 
1120			;      .org  0x100 
1120			;main: 
1120			;      ld    HL, 0x8100 
1120			;      ld    SP, HL 
1120			; 
1120			;      call  heap_init 
1120			; 
1120			;      ; Make some allocations 
1120			;      ld    HL, 12 
1120			;      call  malloc            ; Allocates 0x9004 
1120			; 
1120			;      ld    HL, 12 
1120			;      call  malloc            ; Allocates 0x9014 
1120			; 
1120			;      ld    HL, 12 
1120			;      call  malloc            ; Allocates 0x9024 
1120			; 
1120			;      ; Free some allocations 
1120			;      ld    HL, 0x9014 
1120			;      call  free 
1120			; 
1120			;      ld    HL, 0x9004 
1120			;      call  free 
1120			; 
1120			;      ld    HL, 0x9024 
1120			;      call  free 
1120			; 
1120			; 
1120			;      halt 
