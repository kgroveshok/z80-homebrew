9257				pop de 
9257				pop hl 
9257			 
9257			 
9257				push de 
9257				call storage_create 
9257				; id in hl 
9257				pop de   ; table of strings to add 
9257			 
9257			.genloop: 
9257			 
9257				push hl ; save id for next time around 
9257				push de ; save de for next time around 
9257			 
9257				ex de, hl 
9257				call loadwordinhl 
9257				ex de, hl 
9257			 
9257				; need hl to be the id 
9257				; need de to be the string ptr 
9257				 
9257				call storage_append 
9257			 
9257				pop de 
9257				pop hl 
9257			 
9257				inc de 
9257				inc de 
9257			 
9257				ld a,(de) 
9257				cp 0 
9257				jr nz, .genloop 
9257				inc de 
9257				ld a, (de) 
9257				dec de 
9257				cp 0 
9257				jr nz, .genloop	 
9257			 
9257				ret 
