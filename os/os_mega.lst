0d7e 83			    add   a, e    ; A = A+L 
0d7f 5f			    ld    e, a    ; L = A+L 
0d80 8a			    adc   a, d    ; A = A+L+H+carry 
0d81 93			    sub   e       ; A = H+carry 
0d82 57			    ld    d, a    ; H = H+carry 
0d83 c9			ret 
