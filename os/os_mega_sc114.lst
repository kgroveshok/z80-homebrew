8a3a			;;http://z80-heaven.wikidot.com/math 
8a3a			;;This divides DE by BC, storing the result in DE, remainder in HL 
8a3a			; 
8a3a			;DE_Div_BC:          ;1281-2x, x is at most 16 
8a3a			;     ld a,16        ;7 
8a3a			;     ld hl,0        ;10 
8a3a			;     jp $+5         ;10 
8a3a			;.DivLoop: 
8a3a			;       add hl,bc    ;-- 
8a3a			;       dec a        ;64 
8a3a			;       jr z,.DivLoopEnd        ;86 
8a3a			; 
8a3a			;       sla e        ;128 
8a3a			;       rl d         ;128 
8a3a			;       adc hl,hl    ;240 
8a3a			;       sbc hl,bc    ;240 
8a3a			;       jr nc,.DivLoop ;23|21 
8a3a			;       inc e        ;-- 
8a3a			;       jp .DivLoop+1 
8a3a			; 
8a3a			;.DivLoopEnd: 
8a3a			 
8a3a			;HL_Div_C: 
8a3a			;Inputs: 
8a3a			;     HL is the numerator 
8a3a			;     C is the denominator 
8a3a			;Outputs: 
8a3a			;     A is the remainder 
8a3a			;     B is 0 
8a3a			;     C is not changed 
8a3a			;     DE is not changed 
8a3a			;     HL is the quotient 
8a3a			; 
8a3a			;       ld b,16 
8a3a			;       xor a 
8a3a			;         add hl,hl 
8a3a			;         rla 
8a3a			;         cp c 
8a3a			;         jr c,$+4 
8a3a			;           inc l 
8a3a			;           sub c 
8a3a			;         djnz $-7 
8a3a			 
8a3a			; https://plutiedev.com/z80-add-8bit-to-16bit 
8a3a			 
8a3a			addatohl: 
8a3a 85			    add   a, l    ; A = A+L 
8a3b 6f			    ld    l, a    ; L = A+L 
8a3c 8c			    adc   a, h    ; A = A+L+H+carry 
8a3d 95			    sub   l       ; A = H+carry 
8a3e 67			    ld    h, a    ; H = H+carry 
8a3f c9			ret 
8a40			 
8a40			addatode: 
8a40 83			    add   a, e    ; A = A+L 
8a41 5f			    ld    e, a    ; L = A+L 
8a42 8a			    adc   a, d    ; A = A+L+H+carry 
8a43 93			    sub   e       ; A = H+carry 
8a44 57			    ld    d, a    ; H = H+carry 
8a45 c9			ret 
8a46			 
8a46			 
8a46			addatobc: 
8a46 81			    add   a, c    ; A = A+L 
8a47 4f			    ld    c, a    ; L = A+L 
8a48 88			    adc   a, b    ; A = A+L+H+carry 
8a49 91			    sub   c       ; A = H+carry 
8a4a 47			    ld    b, a    ; H = H+carry 
8a4b c9			ret 
8a4c			 
8a4c			subafromhl: 
8a4c			   ; If A=0 do nothing 
8a4c			    ; Otherwise flip A's sign. Since 
8a4c			    ; the upper byte becomes -1, also 
8a4c			    ; substract 1 from H. 
8a4c ed 44		    neg 
8a4e ca 57 8a		    jp    z, Skip 
8a51 25			    dec   h 
8a52			     
8a52			    ; Now add the low byte as usual 
8a52			    ; Two's complement takes care of 
8a52			    ; ensuring the result is correct 
8a52 85			    add   a, l 
8a53 6f			    ld    l, a 
8a54 8c			    adc   a, h 
8a55 95			    sub   l 
8a56 67			    ld    h, a 
8a57			Skip: 
8a57 c9				ret 
