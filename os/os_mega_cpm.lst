0f46			StrictStrCmp: 
0f46				; Load next chars of each string 
0f46 1a				ld a, (de) 
0f47 47				ld b, a 
0f48 7e				ld a, (hl) 
0f49				; Compare 
0f49 b8				cp b 
0f4a				; Return non-zero if chars don't match 
0f4a c0				ret nz 
0f4b				; Check for end of both strings 
0f4b fe 00			cp "\0" 
0f4d				; Return if strings have ended 
0f4d c8				ret z 
0f4e				; Otherwise, advance to next chars 
0f4e 23				inc hl 
0f4f 13				inc de 
0f50 18 f4			jr StrictStrCmp 
