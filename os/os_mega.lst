0fa9 23				inc hl 
0faa d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
0fac fe 0a			CP	00Ah		;Is it 0-9 ? 
0fae 38 02			JR	C,NALPHA	;If so miss next bit 
0fb0 d6 07			SUB	007h		;Else convert alpha 
0fb2			NALPHA: 
0fb2 b2				OR	D		;Add hi nibble back 
0fb3 c9				RET			; 
