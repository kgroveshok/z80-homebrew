0b20			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0b20			 
0b20			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0b20			 
0b20			 
0b20			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0b20			 
0b20			prng16: 
0b20			;Inputs: 
0b20			;   (seed1) contains a 16-bit seed value 
0b20			;   (seed2) contains a NON-ZERO 16-bit seed value 
0b20			;Outputs: 
0b20			;   HL is the result 
0b20			;   BC is the result of the LCG, so not that great of quality 
0b20			;   DE is preserved 
0b20			;Destroys: 
0b20			;   AF 
0b20			;cycle: 4,294,901,760 (almost 4.3 billion) 
0b20			;160cc 
0b20			;26 bytes 
0b20 2a 9a eb		    ld hl,(seed1) 
0b23 44			    ld b,h 
0b24 4d			    ld c,l 
0b25 29			    add hl,hl 
0b26 29			    add hl,hl 
0b27 2c			    inc l 
0b28 09			    add hl,bc 
0b29 22 9a eb		    ld (seed1),hl 
0b2c 2a 98 eb		    ld hl,(seed2) 
0b2f 29			    add hl,hl 
0b30 9f			    sbc a,a 
0b31 e6 2d		    and %00101101 
0b33 ad			    xor l 
0b34 6f			    ld l,a 
0b35 22 98 eb		    ld (seed2),hl 
0b38 09			    add hl,bc 
0b39 c9			    ret 
0b3a			 
0b3a			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
0b3a			 
0b3a			rand32: 
0b3a			;Inputs: 
0b3a			;   (seed1_0) holds the lower 16 bits of the first seed 
0b3a			;   (seed1_1) holds the upper 16 bits of the first seed 
0b3a			;   (seed2_0) holds the lower 16 bits of the second seed 
0b3a			;   (seed2_1) holds the upper 16 bits of the second seed 
0b3a			;   **NOTE: seed2 must be non-zero 
0b3a			;Outputs: 
0b3a			;   HL is the result 
0b3a			;   BC,DE can be used as lower quality values, but are not independent of HL. 
0b3a			;Destroys: 
0b3a			;   AF 
0b3a			;Tested and passes all CAcert tests 
0b3a			;Uses a very simple 32-bit LCG and 32-bit LFSR 
0b3a			;it has a period of 18,446,744,069,414,584,320 
0b3a			;roughly 18.4 quintillion. 
0b3a			;LFSR taps: 0,2,6,7  = 11000101 
0b3a			;291cc 
0b3a			;seed1_0=$+1 
0b3a			;    ld hl,12345 
0b3a			;seed1_1=$+1 
0b3a			;    ld de,6789 
0b3a			;    ld b,h 
0b3a			;    ld c,l 
0b3a			;    add hl,hl \ rl e \ rl d 
0b3a			;    add hl,hl \ rl e \ rl d 
0b3a			;    inc l 
0b3a			;    add hl,bc 
0b3a			;    ld (seed1_0),hl 
0b3a			;    ld hl,(seed1_1) 
0b3a			;    adc hl,de 
0b3a			;    ld (seed1_1),hl 
0b3a			;    ex de,hl 
0b3a			;seed2_0=$+1 
0b3a			;    ld hl,9876 
0b3a			;seed2_1=$+1 
0b3a			;    ld bc,54321 
0b3a			;    add hl,hl \ rl c \ rl b 
0b3a			;    ld (seed2_1),bc 
0b3a			;    sbc a,a 
0b3a			;    and %11000101 
0b3a			;    xor l 
0b3a			;    ld l,a 
0b3a			;    ld (seed2_0),hl 
0b3a			;    ex de,hl 
0b3a			;    add hl,bc 
0b3a			;    ret 
0b3a			; 
0b3a			 
0b3a			; 16-bit xorshift pseudorandom number generator by John Metcalf 
0b3a			; 20 bytes, 86 cycles (excluding ret) 
0b3a			 
0b3a			; returns   hl = pseudorandom number 
0b3a			; corrupts   a 
0b3a			 
0b3a			; generates 16-bit pseudorandom numbers with a period of 65535 
0b3a			; using the xorshift method: 
0b3a			 
0b3a			; hl ^= hl << 7 
0b3a			; hl ^= hl >> 9 
0b3a			; hl ^= hl << 8 
0b3a			 
0b3a			; some alternative shift triplets which also perform well are: 
0b3a			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
0b3a			 
0b3a			;  org 32768 
0b3a			 
0b3a			xrnd: 
0b3a 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
0b3d 3e 00		  ld a,0 
0b3f bd			  cp l 
0b40 20 02		  jr nz, .xrnd1 
0b42 2e 01		  ld l, 1 
0b44			.xrnd1: 
0b44			 
0b44 7c			  ld a,h 
0b45 1f			  rra 
0b46 7d			  ld a,l 
0b47 1f			  rra 
0b48 ac			  xor h 
0b49 67			  ld h,a 
0b4a 7d			  ld a,l 
0b4b 1f			  rra 
0b4c 7c			  ld a,h 
0b4d 1f			  rra 
0b4e ad			  xor l 
0b4f 6f			  ld l,a 
0b50 ac			  xor h 
0b51 67			  ld h,a 
0b52			 
0b52 22 9e eb		  ld (xrandc),hl 
0b55			 
0b55 c9			  ret 
