89d8			; 
89d8			; Multiply 8-bit value with a 16-bit value (unrolled) 
89d8			; In: Multiply A with DE 
89d8			; Out: HL = result 
89d8			; 
89d8			Mult12U: 
89d8 2e 00		    ld l,0 
89da 87			    add a,a 
89db 30 01		    jr nc,Mult12U_NoAdd0 
89dd 19			    add hl,de 
89de			Mult12U_NoAdd0: 
89de 29			    add hl,hl 
89df 87			    add a,a 
89e0 30 01		    jr nc,Mult12U_NoAdd1 
89e2 19			    add hl,de 
89e3			Mult12U_NoAdd1: 
89e3 29			    add hl,hl 
89e4 87			    add a,a 
89e5 30 01		    jr nc,Mult12U_NoAdd2 
89e7 19			    add hl,de 
89e8			Mult12U_NoAdd2: 
89e8 29			    add hl,hl 
89e9 87			    add a,a 
89ea 30 01		    jr nc,Mult12U_NoAdd3 
89ec 19			    add hl,de 
89ed			Mult12U_NoAdd3: 
89ed 29			    add hl,hl 
89ee 87			    add a,a 
89ef 30 01		    jr nc,Mult12U_NoAdd4 
89f1 19			    add hl,de 
89f2			Mult12U_NoAdd4: 
89f2 29			    add hl,hl 
89f3 87			    add a,a 
89f4 30 01		    jr nc,Mult12U_NoAdd5 
89f6 19			    add hl,de 
89f7			Mult12U_NoAdd5: 
89f7 29			    add hl,hl 
89f8 87			    add a,a 
89f9 30 01		    jr nc,Mult12U_NoAdd6 
89fb 19			    add hl,de 
89fc			Mult12U_NoAdd6: 
89fc 29			    add hl,hl 
89fd 87			    add a,a 
89fe d0			    ret nc 
89ff 19			    add hl,de 
8a00 c9			    ret 
