11cf			; 
11cf			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
11cf			; Since the routines get_byte and therefore get_nibble are called, only valid 
11cf			; characters (0-9a-f) are accepted. 
11cf			; 
11cf			;get_word        push    af 
11cf			;                call    get_byte        ; Get the upper byte 
11cf			;                ld      h, a 
11cf			;                call    get_byte        ; Get the lower byte 
11cf			;                ld      l, a 
11cf			;                pop     af 
11cf			;                ret 
11cf			; 
11cf			; Get a byte in hexadecimal notation. The result is returned in A. Since 
11cf			; the routine get_nibble is used only valid characters are accepted - the  
11cf			; input routine only accepts characters 0-9a-f. 
11cf			; 
11cf c5			get_byte:        push    bc              ; Save contents of B (and C) 
11d0 7e					ld a,(hl) 
11d1 23					inc hl 
11d2 cd f7 11		                call    nibble2val      ; Get upper nibble 
11d5 cb 07		                rlc     a 
11d7 cb 07		                rlc     a 
11d9 cb 07		                rlc     a 
11db cb 07		                rlc     a 
11dd 47			                ld      b, a            ; Save upper four bits 
11de 7e					ld a,(hl) 
11df cd f7 11		                call    nibble2val      ; Get lower nibble 
11e2 b0			                or      b               ; Combine both nibbles 
11e3 c1			                pop     bc              ; Restore B (and C) 
11e4 c9			                ret 
11e5			; 
11e5			; Get a hexadecimal digit from the serial line. This routine blocks until 
11e5			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
11e5			; to the serial line interface. The lower 4 bits of A contain the value of  
11e5			; that particular digit. 
11e5			; 
11e5			;get_nibble      ld a,(hl)           ; Read a character 
11e5			;                call    to_upper        ; Convert to upper case 
11e5			;                call    is_hex          ; Was it a hex digit? 
11e5			;                jr      nc, get_nibble  ; No, get another character 
11e5			 ;               call    nibble2val      ; Convert nibble to value 
11e5			 ;               call    print_nibble 
11e5			 ;               ret 
11e5			; 
11e5			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
11e5			; A valid hexadecimal digit is denoted by a set C flag. 
11e5			; 
11e5			;is_hex          cp      'F' + 1         ; Greater than 'F'? 
11e5			;                ret     nc              ; Yes 
11e5			;                cp      '0'             ; Less than '0'? 
11e5			;                jr      nc, is_hex_1    ; No, continue 
11e5			;                ccf                     ; Complement carry (i.e. clear it) 
11e5			;                ret 
11e5			;is_hex_1        cp      '9' + 1         ; Less or equal '9*? 
11e5			;                ret     c               ; Yes 
11e5			;                cp      'A'             ; Less than 'A'? 
11e5			;                jr      nc, is_hex_2    ; No, continue 
11e5			;                ccf                     ; Yes - clear carry and return 
11e5			;                ret 
11e5			;is_hex_2        scf                     ; Set carry 
11e5			;                ret 
11e5			; 
11e5			; Convert a single character contained in A to upper case: 
11e5			; 
11e5 fe 61		to_upper:        cp      'a'             ; Nothing to do if not lower case 
11e7 d8			                ret     c 
11e8 fe 7b		                cp      'z' + 1         ; > 'z'? 
11ea d0			                ret     nc              ; Nothing to do, either 
11eb e6 5f		                and     $5f             ; Convert to upper case 
11ed c9			                ret 
