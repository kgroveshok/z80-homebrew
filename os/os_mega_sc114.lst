8ddf			;heap_size         .equ  0x0100      ; Number of bytes available in heap 
8ddf			 
8ddf			;      .org 0 
8ddf			;      jp    main 
8ddf			 
8ddf			 
8ddf			;      .org  0x100 
8ddf			;main: 
8ddf			;      ld    HL, 0x8100 
8ddf			;      ld    SP, HL 
8ddf			; 
8ddf			;      call  heap_init 
8ddf			; 
8ddf			;      ; Make some allocations 
8ddf			;      ld    HL, 12 
8ddf			;      call  malloc            ; Allocates 0x9004 
8ddf			; 
8ddf			;      ld    HL, 12 
8ddf			;      call  malloc            ; Allocates 0x9014 
8ddf			; 
8ddf			;      ld    HL, 12 
8ddf			;      call  malloc            ; Allocates 0x9024 
8ddf			; 
8ddf			;      ; Free some allocations 
8ddf			;      ld    HL, 0x9014 
8ddf			;      call  free 
8ddf			; 
8ddf			;      ld    HL, 0x9004 
8ddf			;      call  free 
8ddf			; 
8ddf			;      ld    HL, 0x9024 
8ddf			;      call  free 
8ddf			; 
8ddf			; 
8ddf			;      halt 
8ddf			 
8ddf			 
8ddf			;------------------------------------------------------------------------------ 
8ddf			;     heap_init                                                               : 
8ddf			;                                                                             : 
8ddf			; Description                                                                 : 
8ddf			;     Initialise the heap and make it ready for malloc and free operations.   : 
8ddf			;                                                                             : 
8ddf			;     The heap is maintained as a linked list, starting with an initial       : 
8ddf			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8ddf			;     the first free block in the heap. Each block then points to the next    : 
8ddf			;     free block within the heap, and the free list ends at the first block   : 
8ddf			;     with a null pointer to the next free block.                             : 
8ddf			;                                                                             : 
8ddf			; Parameters                                                                  : 
8ddf			;     Inputs are compile-time only. Two defines which specify the starting    : 
8ddf			;     address of the heap and its size are required, along with a memory      : 
8ddf			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8ddf			;     principally stores a pointer to the first free block in the heap.       : 
8ddf			;                                                                             : 
8ddf			; Returns                                                                     : 
8ddf			;     Nothing                                                                 : 
8ddf			;------------------------------------------------------------------------------ 
8ddf			heap_init: 
8ddf e5			      push  HL 
8de0			 
8de0			      ; Initialise free list struct 
8de0 21 36 d3		      ld    HL, heap_start 
8de3 22 31 d3		      ld    (free_list), HL 
8de6 21 00 00		      ld    HL, 0 
8de9 22 33 d3		      ld    (free_list+2), HL 
8dec			 
8dec			      ; Insert first free block at bottom of heap, consumes entire heap 
8dec 21 8d e2		      ld    HL, heap_start+heap_size-4 
8def 22 36 d3		      ld    (heap_start), HL        ; Next block (end of free list) 
8df2 21 57 0f		      ld    HL, heap_size-4 
8df5 22 38 d3		      ld    (heap_start+2), HL      ; Block size 
8df8			 
8df8			      ; Insert end of free list block at top of heap - two null words will 
8df8			      ; terminate the free list 
8df8 21 00 00		      ld    HL, 0 
8dfb 22 8f e2		      ld    (heap_start+heap_size-2), HL 
8dfe 22 8d e2		      ld    (heap_start+heap_size-4), HL 
8e01			 
8e01 e1			      pop   HL 
8e02			 
8e02 c9			      ret 
8e03			 
8e03			 
8e03			;------------------------------------------------------------------------------ 
8e03			;     malloc                                                                  : 
8e03			;                                                                             : 
8e03			; Description                                                                 : 
8e03			;     Allocates the wanted space from the heap and returns the address of the : 
8e03			;     first useable byte of the allocation.                                   : 
8e03			;                                                                             : 
8e03			;     Allocations can happen in one of two ways:                              : 
8e03			;                                                                             : 
8e03			;     1. A free block may be found which is the exact size wanted. In this    : 
8e03			;        case the block is removed from the free list and retuedn to the      : 
8e03			;        caller.                                                              : 
8e03			;     2. A free block may be found which is larger than the size wanted. In   : 
8e03			;        this case, the larger block is split into two. The first portion of  : 
8e03			;        this block will become the requested space by the malloc call and    : 
8e03			;        is returned to the caller. The second portion becomes a new free     : 
8e03			;        block, and the free list is adjusted to maintain continuity via this : 
8e03			;        newly created block.                                                 : 
8e03			;                                                                             : 
8e03			;     malloc does not set any initial value in the allocated space, the       : 
8e03			;     caller is required to do this as required.                              : 
8e03			;                                                                             : 
8e03			;     This implementation of malloc uses the stack exclusively, and is        : 
8e03			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8e03			;     advisable to disable interrupts before calling malloc, and recommended  : 
8e03			;     to avoid the use of malloc inside ISRs in general.                      : 
8e03			;                                                                             : 
8e03			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8e03			;                                                                             : 
8e03			; Parameters                                                                  : 
8e03			;     HL  Number of bytes wanted                                              : 
8e03			;                                                                             : 
8e03			; Returns                                                                     : 
8e03			;     HL  Address of the first useable byte of the allocation                 : 
8e03			;                                                                             : 
8e03			; Flags                                                                       : 
8e03			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8e03			;                                                                             : 
8e03			; Stack frame                                                                 : 
8e03			;       |             |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |     BC      |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |     DE      |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |     IX      |                                                       : 
8e03			;       +-------------+                                                       : 
8e03			;       |  prev_free  |                                                       : 
8e03			;   +4  +-------------+                                                       : 
8e03			;       |  this_free  |                                                       : 
8e03			;   +2  +-------------+                                                       : 
8e03			;       |  next_free  |                                                       : 
8e03			;   +0  +-------------+                                                       : 
8e03			;       |             |                                                       : 
8e03			;                                                                             : 
8e03			;------------------------------------------------------------------------------ 
