8f56 e1			      pop   HL                      ; Restore ptr to next block 
8f57 23			      inc   HL                      ; Load size of next block into DE 
8f58 5e			      ld    E, (HL) 
8f59 23			      inc   HL 
8f5a 56			      ld    D, (HL) 
8f5b d5			      push  DE                      ; Save next block size for later 
8f5c			 
8f5c 60			      ld    H, B                    ; Load size of freed block into HL 
8f5d 69			      ld    L, C 
8f5e 23			      inc   HL 
8f5f 23			      inc   HL 
8f60 5e			      ld    E, (HL) 
8f61 23			      inc   HL 
8f62 56			      ld    D, (HL) 
8f63 eb			      ex    DE, HL 
