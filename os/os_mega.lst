25ca			.HEAP: 
25ca			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
25ca 15				db WORD_SYS_CORE+OPCODE_HEAP             
25cb fb 25			dw .EXEC            
25cd 05				db 4 + 1 
25ce .. 00			db "HEAP",0              
25d3				endm 
# End of macro CWHEAD
25d3			; | HEAP ( -- u1 u2 )   Pushes u1 the current number of bytes in the heap and u2 the remaining bytes - Only present if using my MALLOC | DONE 
25d3			; | | u1 - Current number of bytes in the heap 
25d3			; | | u2 - Remaining bytes left on the heap 
25d3			; | |  
25d3			; | | The heap is used for storing user defined words as well as any values pushed to stack. 
25d3			 
25d3			 
25d3				if DEBUG_FORTH_WORDS_KEY 
25d3					DMARK "HEP" 
25d3				if DEMARK_VERSION = 1  
25d3 e5					push hl  
25d4 21 dc 25				ld hl, .dmark  
25d7 22 9b fd				ld (debug_mark), hl  
25da				endif  
25da				if DEMARK_VERSION = 0  
25da					push af  
25da					ld a, (.dmark)  
25da					ld (debug_mark),a  
25da					ld a, (.dmark+1)  
25da					ld (debug_mark+1),a  
25da					ld a, (.dmark+2)  
25da					ld (debug_mark+2),a  
25da				endif  
25da 18 04			jr .pastdmark  
25dc ..			.dmark: db "HEP"  
25df				if DEMARK_VERSION = 1  
25df 00					db 0  
25e0				endif  
25e0				if DEMARK_VERSION = 1  
25e0 e1			.pastdmark: pop hl  
25e1				endif  
25e1				if DEMARK_VERSION = 0  
25e1			.pastdmark: pop af  
25e1				endif  
25e1			endm  
# End of macro DMARK
