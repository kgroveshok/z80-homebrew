110d			; only care about direct match or not 
110d			; hl and de strings 
110d			; zero set if the same 
110d			 
110d			strcmp: 
110d 1a				ld a, (de) 
110e be				cp (hl) 
110f 28 02			jr z, .ssame 
1111 b7				or a 
1112 c9				ret 
