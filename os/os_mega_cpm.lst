449a			.SPIO: 
449a			 
449a			if STORAGE_SE 
449a				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
449a			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
449a			 
449a					call spi_ce_low 
449a			    NEXTW 
449a			 
449a			.SPICEH: 
449a				CWHEAD .SPIBOb 61 "SPICEH" 6 WORD_FLAG_CODE 
449a			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
449a			 
449a					call spi_ce_high 
449a			    NEXTW 
449a			 
449a			.SPIBOb: 
449a			 
449a				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
449a			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
449a			 
449a					if DEBUG_FORTH_WORDS_KEY 
449a						DMARK "SPo" 
449a						CALLMONITOR 
449a					endif 
449a					; get port 
449a			 
449a			 
449a					; get byte to send 
449a			 
449a					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
449a			 
449a			;		push hl    ; u1  
449a			 
449a					; destroy value TOS 
449a			 
449a					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
449a			 
449a					; one value on hl get other one back 
449a			 
449a			;		pop hl   ; u2 - addr 
449a			 
449a					; TODO Send SPI byte 
449a			 
449a			;		push hl 
449a			;		call spi_ce_low 
449a			;		pop hl 
449a					ld a, l 
449a					call spi_send_byte 
449a			;		call spi_ce_high 
449a			 
449a					NEXTW 
449a			 
449a			.SPII: 
449a				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
449a			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
449a					if DEBUG_FORTH_WORDS_KEY 
449a						DMARK "SPi" 
449a						CALLMONITOR 
449a					endif 
449a			 
449a					; TODO Get SPI byte 
449a			 
449a					call spi_read_byte 
449a			 
449a					if DEBUG_FORTH_WORDS 
449a						DMARK "Si2" 
449a						CALLMONITOR 
449a					endif 
449a					ld h, 0 
449a					ld l, a 
449a					if DEBUG_FORTH_WORDS 
449a						DMARK "Si3" 
449a						CALLMONITOR 
449a					endif 
449a					;call forth_push_numhl 
449a					FORTH_PUSH_VALUEHL 
449a			 
449a					NEXTW 
449a			 
449a			 
449a			 
449a			.SESEL: 
449a				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
449a			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
449a			; | | Zero is disabled storage. 
449a					if DEBUG_FORTH_WORDS_KEY 
449a						DMARK "BN?" 
449a						CALLMONITOR 
449a					endif 
449a					ld a, (spi_device_id) 
449a					sub '0' 
449a					ld h, 0 
449a					ld l, a 
449a					FORTH_PUSH_VALUEHL 
449a					;call forth_push_numhl 
449a					NEXTW 
449a			.SESELS: 
449a				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
449a			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
449a			; | | Set to zero to disable storage. 
449a					if DEBUG_FORTH_WORDS_KEY 
449a						DMARK "BNK" 
449a						CALLMONITOR 
449a					endif 
449a			 
449a					ld a, 255 
449a					ld (spi_cartdev), a 
449a			 
449a					; get bank 
449a			 
449a					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
449a			 
449a			;		push hl 
449a			 
449a					; destroy value TOS 
449a			 
449a					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
449a			 
449a					; one value on hl get other one back 
449a			 
449a			;		pop hl 
449a			 
449a			 
449a					ld c, SPI_CE_HIGH 
449a					ld b, '0'    ; human readable bank number 
449a			 
449a					ld a, l 
449a			 
449a					if DEBUG_FORTH_WORDS 
449a						DMARK "BNK" 
449a						CALLMONITOR 
449a					endif 
449a			 
449a					; active low 
449a			 
449a			;		cp 0 
449a					or a 
449a					jr z, .bset 
449a					cp 1 
449a					jr nz, .b2 
449a					res 0, c 
449a					ld b, '1'    ; human readable bank number 
449a			.b2:		cp 2 
449a					jr nz, .b3 
449a					res 1, c 
449a					ld b, '2'    ; human readable bank number 
449a			.b3:		cp 3 
449a					jr nz, .b4 
449a					res 2, c 
449a					ld b, '3'    ; human readable bank number 
449a			.b4:		cp 4 
449a					jr nz, .b5 
449a					res 3, c 
449a					ld b, '4'    ; human readable bank number 
449a			.b5:		cp 5 
449a					jr nz, .bset 
449a					res 4, c 
449a					ld b, '5'    ; human readable bank number 
449a			 
449a			.bset: 
449a					ld a, c 
449a					ld (spi_device),a 
449a					ld a, b 
449a					ld (spi_device_id),a 
449a					if DEBUG_FORTH_WORDS 
449a						DMARK "BN2" 
449a						CALLMONITOR 
449a					endif 
449a			 
449a					; set default SPI clk pulse time as disabled for BANK use 
449a			 
449a					ld a, 0 
449a					ld (spi_clktime), a 
449a			 
449a					NEXTW 
449a			 
449a			.CARTDEV: 
449a				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
449a			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
449a			; | | Set to zero to disable devices. 
449a					if DEBUG_FORTH_WORDS_KEY 
449a						DMARK "CDV" 
449a						CALLMONITOR 
449a					endif 
449a			 
449a					; disable se storage bank selection 
449a			 
449a					ld a, SPI_CE_HIGH		; ce high 
449a					ld (spi_device), a 
449a			 
449a					; get bank 
449a			 
449a					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
449a			 
449a			;		push hl 
449a			 
449a					; destroy value TOS 
449a			 
449a					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
449a			 
449a					; one value on hl get other one back 
449a			 
449a			;		pop hl 
449a			 
449a					; active low 
449a			 
449a					ld c, 255 
449a			 
449a					ld a, l 
449a					if DEBUG_FORTH_WORDS 
449a						DMARK "CDV" 
449a						CALLMONITOR 
449a					endif 
449a			;		cp 0 
449a					or a 
449a					jr z, .cset 
449a					cp 1 
449a					jr nz, .c2 
449a					res 0, c 
449a			.c2:		cp 2 
449a					jr nz, .c3 
449a					res 1, c 
449a			.c3:		cp 3 
449a					jr nz, .c4 
449a					res 2, c 
449a			.c4:		cp 4 
449a					jr nz, .c5 
449a					res 3, c 
449a			.c5:		cp 5 
449a					jr nz, .c6 
449a					res 4, c 
449a			.c6:		cp 6 
449a					jr nz, .c7 
449a					res 5, c 
449a			.c7:		cp 7 
449a					jr nz, .c8 
449a					res 6, c 
449a			.c8:		cp 8 
449a					jr nz, .cset 
449a					res 7, c 
449a			.cset:		ld a, c 
449a					ld (spi_cartdev),a 
449a			 
449a					if DEBUG_FORTH_WORDS 
449a						DMARK "CD2" 
449a						CALLMONITOR 
449a					endif 
449a			 
449a					; set default SPI clk pulse time as 10ms for CARTDEV use 
449a			 
449a					ld a, $0a 
449a					ld (spi_clktime), a 
449a					NEXTW 
449a			endif 
449a			 
449a			.ENDDEVICE: 
449a			; eof 
449a			 
# End of file forth_words_device.asm
449a			 
449a			; var handler 
449a			 
449a			 
449a			.VARS: 
449a				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
449a 77				db WORD_SYS_CORE+99             
449b 17 45			dw .V0            
449d 04				db 3 + 1 
449e .. 00			db "VAR",0              
44a2				endm 
# End of macro CWHEAD
44a2			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
44a2			; | 
44a2			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
44a2			; | |  
44a2			; | | e.g. 
44a2			; | |         #30 a var ! 
44a2			; | |         a var @ . 
44a2			; | |   
44a2			; | |     Displays the number 30 
44a2			; | | 
44a2			; | | Each variable pointer is a word so can use for any words that use that:  
44a2			; | |  
44a2			; | | e.g. 
44a2			; | |  
44a2			; | |         #30 a var 2! 
44a2			; | |         a var 2@ . 
44a2			; | |   
44a2			; | |     Displays the number 30 
44a2			; | |  
44a2			; | | > [!NOTE]  
44a2			; ! | > If a full string is passed then only the first char is looked at 
44a2			; | | > Any other char could exceed bounds checks!  
44a2			; | | > 
44a2			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
44a2			 
44a2					if DEBUG_FORTH_WORDS_KEY 
44a2						DMARK "VAR" 
44a2				if DEMARK_VERSION = 1  
44a2 e5					push hl  
44a3 21 ab 44				ld hl, .dmark  
44a6 22 60 ee				ld (debug_mark), hl  
44a9				endif  
44a9				if DEMARK_VERSION = 0  
44a9					push af  
44a9					ld a, (.dmark)  
44a9					ld (debug_mark),a  
44a9					ld a, (.dmark+1)  
44a9					ld (debug_mark+1),a  
44a9					ld a, (.dmark+2)  
44a9					ld (debug_mark+2),a  
44a9				endif  
44a9 18 04			jr .pastdmark  
44ab ..			.dmark: db "VAR"  
44ae				if DEMARK_VERSION = 1  
44ae 00					db 0  
44af				endif  
44af				if DEMARK_VERSION = 1  
44af e1			.pastdmark: pop hl  
44b0				endif  
44b0				if DEMARK_VERSION = 0  
44b0			.pastdmark: pop af  
44b0				endif  
44b0			endm  
# End of macro DMARK
44b0						CALLMONITOR 
44b0				if BASE_CPM=1  
