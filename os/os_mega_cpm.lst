0cf2			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
0cf2			 
0cf2			 
0cf2			;-----> Generate a random number 
0cf2			; output a=answer 0<=a<=255 
0cf2			; all registers are preserved except: af 
0cf2			random: 
0cf2 e5			        push    hl 
0cf3 d5			        push    de 
0cf4 2a 9e eb		        ld      hl,(randData) 
0cf7 ed 5f		        ld      a,r 
0cf9 57			        ld      d,a 
0cfa 5e			        ld      e,(hl) 
0cfb 19			        add     hl,de 
0cfc 85			        add     a,l 
0cfd ac			        xor     h 
0cfe 22 9e eb		        ld      (randData),hl 
0d01 d1			        pop     de 
0d02 e1			        pop     hl 
0d03 c9			        ret 
0d04			 
0d04			 
0d04			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
0d04			 
0d04			 
0d04			 
0d04			;------LFSR------ 
0d04			;James Montelongo 
0d04			;optimized by Spencer Putt 
0d04			;out: 
0d04			; a = 8 bit random number 
0d04			RandLFSR: 
0d04 21 a4 eb		        ld hl,LFSRSeed+4 
0d07 5e			        ld e,(hl) 
0d08 23			        inc hl 
0d09 56			        ld d,(hl) 
0d0a 23			        inc hl 
0d0b 4e			        ld c,(hl) 
0d0c 23			        inc hl 
0d0d 7e			        ld a,(hl) 
0d0e 47			        ld b,a 
0d0f cb 13		        rl e  
0d11 cb 12			rl d 
0d13 cb 11		        rl c  
0d15 17				rla 
0d16 cb 13		        rl e  
0d18 cb 12			rl d 
0d1a cb 11		        rl c  
0d1c 17				rla 
0d1d cb 13		        rl e  
0d1f cb 12			rl d 
0d21 cb 11		        rl c  
0d23 17				rla 
0d24 67			        ld h,a 
0d25 cb 13		        rl e  
0d27 cb 12			rl d 
0d29 cb 11		        rl c  
0d2b 17				rla 
0d2c a8			        xor b 
0d2d cb 13		        rl e  
0d2f cb 12			rl d 
0d31 ac			        xor h 
0d32 a9			        xor c 
0d33 aa			        xor d 
0d34 21 a6 eb		        ld hl,LFSRSeed+6 
0d37 11 a7 eb		        ld de,LFSRSeed+7 
0d3a 01 07 00		        ld bc,7 
0d3d ed b8		        lddr 
0d3f 12			        ld (de),a 
0d40 c9			        ret 
0d41			 
0d41			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
0d41			 
0d41			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
0d41			 
0d41			 
0d41			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
0d41			 
0d41			prng16: 
0d41			;Inputs: 
0d41			;   (seed1) contains a 16-bit seed value 
0d41			;   (seed2) contains a NON-ZERO 16-bit seed value 
0d41			;Outputs: 
0d41			;   HL is the result 
0d41			;   BC is the result of the LCG, so not that great of quality 
0d41			;   DE is preserved 
0d41			;Destroys: 
0d41			;   AF 
0d41			;cycle: 4,294,901,760 (almost 4.3 billion) 
0d41			;160cc 
0d41			;26 bytes 
0d41 2a 98 eb		    ld hl,(seed1) 
0d44 44			    ld b,h 
0d45 4d			    ld c,l 
0d46 29			    add hl,hl 
0d47 29			    add hl,hl 
0d48 2c			    inc l 
0d49 09			    add hl,bc 
0d4a 22 98 eb		    ld (seed1),hl 
0d4d 2a 96 eb		    ld hl,(seed2) 
0d50 29			    add hl,hl 
0d51 9f			    sbc a,a 
0d52 e6 2d		    and %00101101 
