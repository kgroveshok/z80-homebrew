25c5			.NEW: 
25c5			CWHEAD .HEAP OPCODE_HEAP "NEW" 3 WORD_FLAG_CODE 
25c5 15				db WORD_SYS_CORE+OPCODE_HEAP             
25c6 df 25			dw .HEAP            
25c8 04				db 3 + 1 
25c9 .. 00			db "NEW",0              
25cd				endm 
# End of macro CWHEAD
25cd			; | NEW ( -- ) Clears all user words and stack | DONE 
25cd				 
25cd				if MALLOC_4 
25cd					call  heap_init 
25cd				endif 
25cd				; reset uword pointers 
25cd 21 00 80			ld hl, baseram 
25d0 22 d5 f3			ld (os_last_new_uword), hl 
25d3 cd 19 24			call user_word_eol 
25d6				; clear stack 
25d6 cd 32 24			call forth_warmstart 
25d9				NEXTW 
25d9 cd a3 fd			call parse_vector 
25dc c3 8c 24			jp macro_next 
25df				endm 
# End of macro NEXTW
25df			 
25df			.HEAP: 
25df			CWHEAD .EXEC OPCODE_HEAP "HEAP" 4 WORD_FLAG_CODE 
25df 15				db WORD_SYS_CORE+OPCODE_HEAP             
25e0 10 26			dw .EXEC            
25e2 05				db 4 + 1 
25e3 .. 00			db "HEAP",0              
