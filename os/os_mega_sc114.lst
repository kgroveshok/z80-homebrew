9bf9			user_word_eol:  
9bf9				; hl contains the pointer to where to create a linked list item from the end 
9bf9				; of the user dict to continue on at the system word dict 
9bf9				 
9bf9				; poke the stub of the word list linked list to repoint to rom words 
9bf9			 
9bf9				; stub format 
9bf9				; db   word id 
9bf9				; dw    link to next word 
9bf9			        ; db char length of token 
9bf9				; db string + 0 term 
9bf9				; db exec code....  
9bf9			 
9bf9			;	ld a, WORD_SYS_ROOT     ; root word 
9bf9 36 00			ld (hl), WORD_SYS_ROOT		; word id 
9bfb 23				inc hl 
9bfc			 
9bfc 11 a5 9d			ld de, sysdict 
9bff 73				ld (hl), e		; next word link ie system dict 
9c00 23				inc hl 
9c01 72				ld (hl), d		; next word link ie system dict 
9c02 23				inc hl	 
9c03			 
9c03			;	ld (hl), sysdict		; next word link ie system dict 
9c03			;	inc hl 
9c03			;	inc hl 
9c03			 
9c03			;	inc hl 
9c03			;	inc hl 
9c03			 
9c03			;	ld a, 2			; word length is 0 
9c03 36 02			ld (hl), 2 
9c05 23				inc hl 
9c06			 
9c06			;	ld a, '~'			; word length is 0 
9c06 36 7e			ld (hl), '~' 
9c08 23				inc hl 
9c09			;	ld a, 0			; save empty word 
9c09 36 00			ld (hl), 0 
9c0b			 
9c0b c9				ret 
