bff2			.VARS: 
bff2				CWHEAD .V0 99 "VAR" 3 WORD_FLAG_CODE 
bff2 77				db WORD_SYS_CORE+99             
bff3 5a c0			dw .V0            
bff5 04				db 3 + 1 
bff6 .. 00			db "VAR",0              
bffa				endm 
# End of macro CWHEAD
bffa			; | VAR ( u1 -- )  Get the address of the (word) variable referenced on TOS  | DONE 
bffa			; | 
bffa			; | | The variable name should consist of a single letter (a-z). e.g. "a" 
bffa			; | |  
bffa			; | | e.g. 
bffa			; | |         #30 a var ! 
bffa			; | |         a var @ . 
bffa			; | |   
bffa			; | |     Displays the number 30 
bffa			; | | 
bffa			; | | Each variable pointer is a word so can use for any words that use that:  
bffa			; | |  
bffa			; | | e.g. 
bffa			; | |  
bffa			; | |         #30 a var 2! 
bffa			; | |         a var 2@ . 
bffa			; | |   
bffa			; | |     Displays the number 30 
bffa			; | |  
bffa			; | | > [!NOTE]  
bffa			; ! | > If a full string is passed then only the first char is looked at 
bffa			; | | > Any other char could exceed bounds checks!  
bffa			; | | > 
bffa			; | | > Each variable location follows the previous. Watch you don't clobber any others. 
bffa			 
bffa					if DEBUG_FORTH_WORDS_KEY 
bffa						DMARK "VAR" 
bffa				if DEMARK_VERSION = 1  
bffa e5					push hl  
bffb 21 03 c0				ld hl, .dmark  
bffe 22 60 ee				ld (debug_mark), hl  
c001				endif  
