65ec			  
65ec			; **********************************************************************  
65ec			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
65ec			; **********************************************************************  
65ec			;  
65ec			; **  Written as a Small Computer Monitor App   
65ec			; **  Version 0.1 SCC 2018-05-16  
65ec			; **  www.scc.me.uk  
65ec			;  
65ec			; **********************************************************************  
65ec			;  
65ec			; This module provides support for alphanumeric LCD modules using with  
65ec			; *  HD44780 (or compatible) controller  
65ec			; *  5 x 7 pixel fonts  
65ec			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
65ec			; *  Interface via six digital outputs to the display (see below)  
65ec			;  
65ec			; LCD module pinout:  
65ec			;   1  Vss   0v supply  
65ec			;   2  Vdd   5v supply  
65ec			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
65ec			;   4  RS    High = data, Low = instruction  
65ec			;   5  R/W   High = Read, Low = Write  
65ec			;   6  E     Enable signal (active high)  
65ec			;   7  DB0   Data bit 0  
65ec			;   8  DB1   Data bit 1  
65ec			;   9  DB2   Data bit 2  
65ec			;  10  DB3   Data bit 3  
65ec			;  11  DB4   Data bit 4  
65ec			;  12  DB5   Data bit 5  
65ec			;  13  DB6   Data bit 6  
65ec			;  14  DB7   Data bit 7  
65ec			;  15  A     Backlight anode (+)  
65ec			;  16  K     Backlight cathode (-)  
65ec			;  
65ec			; This interfacing method uses 4-bit data mode and uses time delays  
65ec			; rather than polling the display's ready status. As a result the   
65ec			; interface only requires 6 simple output lines:  
65ec			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
65ec			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
65ec			;   LCD DB4 = Microcomputer output port bit 4  
65ec			;   LCD DB5 = Microcomputer output port bit 5  
65ec			;   LCD DB6 = Microcomputer output port bit 6  
65ec			;   LCD DB7 = Microcomputer output port bit 7  
65ec			; Display's R/W is connected to 0v so it is always in write mode  
65ec			; All 6 connections must be on the same port address <kLCDPrt>  
65ec			; This method also allows a decent length of cable from micro to LCD  
65ec			;  
65ec			; **********************************************************************  
65ec			;  
65ec			; To include the code for any given function provided by this module,   
65ec			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
65ec			; the parent source file.  
65ec			; For example:  #REQUIRES   uHexPrefix  
65ec			;  
65ec			; Also #INCLUDE this file at some point after the #REQUIRES statements  
65ec			; in the parent source file.  
65ec			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
65ec			;  
65ec			; These are the function names provided by this module:  
65ec			; fLCD_Init                     ;Initialise LCD  
65ec			; fLCD_Inst                     ;Send instruction to LCD  
65ec			; fLCD_Data                     ;Send data byte to LCD  
65ec			; fLCD_Pos                      ;Position cursor  
65ec			; fLCD_Str                      ;Display string  
65ec			; fLCD_Def                      ;Define custom character  
65ec			;  
65ec			; **********************************************************************  
65ec			;  
65ec			; Requires SCMonAPI.asm to also be included in the project  
65ec			;  
65ec			  
65ec			  
65ec			; **********************************************************************  
65ec			; **  Constants  
65ec			; **********************************************************************  
65ec			  
65ec			; Constants that must be defined externally  
65ec			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
65ec			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
65ec			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
65ec			;kLCDWidth: EQU 20             ;Width in characters  
65ec			  
65ec			; general line offsets in any frame buffer  
65ec			  
65ec			  
65ec			display_row_1: equ 0  
65ec			display_row_2: equ display_row_1+display_cols  
65ec			display_row_3: equ display_row_2 + display_cols  
65ec			display_row_4: equ display_row_3 + display_cols  
65ec			;display_row_4_eol:   
65ec			  
65ec			  
65ec			; Cursor position values for the start of each line  
65ec			  
65ec			; E  
65ec			kLCD_Line1: EQU 0x00   
65ec			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
65ec			; E1  
65ec			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
65ec			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
65ec			  
65ec			; Instructions to send as A register to fLCD_Inst  
65ec			kLCD_Clear: EQU 00000001b     ;LCD clear  
65ec			kLCD_Off:   EQU 00001000b     ;LCD off  
65ec			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
65ec			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
65ec			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
65ec			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
65ec			  
65ec			; Constants used by this code module  
65ec			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
65ec			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
65ec			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
65ec			  
65ec			  
65ec			  
65ec			; **********************************************************************  
65ec			; **  LCD support functions  
65ec			; **********************************************************************  
65ec			  
65ec			; Initialise alphanumeric LCD module  
65ec			; LCD control register codes:  
65ec			;   DL   0 = 4-bit mode        1 = 8-bit mode  
65ec			;   N    0 = 1-line mode       1 = 2-line mode  
65ec			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
65ec			;   D    0 = Display off       1 = Display on  
65ec			;   C    0 = Cursor off        1 = Cursor on  
65ec			;   B    0 = Blinking off      1 = Blinking on  
65ec			;   ID   0 = Decrement mode    1 = Increment mode  
65ec			;   SH   0 = Entire shift off  1 = Entire shift on  
65ec 3e 28		fLCD_Init:  LD   A, 40  
65ee cd 13 67		            CALL LCDDelay       ;Delay 40ms after power up  
65f1			; For reliable reset set 8-bit mode - 3 times  
65f1 cd e3 66		            CALL WrFn8bit       ;Function = 8-bit mode  
65f4 cd e3 66		            CALL WrFn8bit       ;Function = 8-bit mode  
65f7 cd e3 66		            CALL WrFn8bit       ;Function = 8-bit mode  
65fa			; Set 4-bit mode  
65fa cd df 66		            CALL WrFn4bit       ;Function = 4-bit mode  
65fd cd 11 67		            CALL LCDDelay1      ;Delay 37 us or more  
6600			; Function set  
6600 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
6602 cd 15 66		            CALL fLCD_Inst      ;2 line, display on  
6605			; Display On/Off control  
6605 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
6607 cd 15 66		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
660a			; Display Clear  
660a 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
660c cd 15 66		            CALL fLCD_Inst      ;Clear display  
660f			; Entry mode  
660f 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
6611 cd 15 66		            CALL fLCD_Inst      ;Increment mode, shift off  
6614			; Display module now initialised  
6614 c9			            RET  
6615			; ok to here  
6615			  
6615			; Write instruction to LCD  
6615			;   On entry: A = Instruction byte to be written  
6615			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6615 f5			fLCD_Inst:  PUSH AF  
6616 f5			            PUSH AF  
6617 cd 29 66		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
661a f1			            POP  AF  
661b 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
661c 17			            RLA  
661d 17			            RLA  
661e 17			            RLA  
661f cd 29 66		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6622 3e 02		            LD   A, 2  
6624 cd 13 67		            CALL LCDDelay       ;Delay 2 ms to complete   
6627 f1			            POP  AF  
6628 c9			            RET  
6629			Wr4bits:   
6629 f5					push af  
662a 3a fb fa				ld a, (display_lcde1e2)  
662d fe 00				cp 0     ; e  
662f 20 10				jr nz, .wea2	  
6631 f1					pop af  
6632 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6634 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6636 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6638 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
663a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
663c cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
663e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6640 c9			            RET  
6641 f1			.wea2:		pop af  
6642 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6644 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6646 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6648 cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
664a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
664c cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
664e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6650 c9			            RET  
6651			  
6651			  
6651			; Write data to LCD  
6651			;   On entry: A = Data byte to be written  
6651			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6651 f5			fLCD_Data:  PUSH AF  
6652 f5			            PUSH AF  
6653 cd 65 66		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6656 f1			            POP  AF  
6657 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6658 17			            RLA  
6659 17			            RLA  
665a 17			            RLA  
665b cd 65 66		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
665e 3e 96		            LD   A, 150  
6660 3d			Wait:      DEC  A              ;Wait a while to allow data   
6661 20 fd		            JR   NZ, Wait      ;  write to complete  
6663 f1			            POP  AF  
6664 c9			            RET  
6665			Wr4bitsa:     
6665 f5					push af  
6666 3a fb fa				ld a, (display_lcde1e2)  
6669 fe 00				cp 0     ; e1  
666b 20 16				jr nz, .we2	  
666d f1					pop af  
666e e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6670 cb d7		            SET  kLCDBitRS, A  
6672 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6674 cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6676 cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6678 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
667a cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
667c d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
667e cb 97		            RES  kLCDBitRS, A  
6680 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6682 c9			            RET  
6683 f1			.we2:		pop af  
6684 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6686 cb d7		            SET  kLCDBitRS, A  
6688 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
668a cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
668c cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
668e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6690 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6692 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6694 cb 97		            RES  kLCDBitRS, A  
6696 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6698 c9			            RET  
6699			  
6699			  
6699			; Position cursor to specified location  
6699			;   On entry: A = Cursor position  
6699			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6699 f5			fLCD_Pos:   PUSH AF  
669a					; at this point set the E1 or E2 flag depending on position  
669a			  
669a c5					push bc  
669b			;		push af  
669b 06 00				ld b, 0  
669d 4f					ld c, a  
669e 3e 4f				ld a, kLCD_Line3-1  
66a0 b7			 		or a      ;clear carry flag  
66a1 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
66a2 38 04				jr c, .pe1  
66a4			  
66a4					; E selection  
66a4 cb 80				res 0, b         ; bit 0 unset e  
66a6			;		pop af    ; before line 3 so recover orig pos  
66a6			;		ld c, a    ; save for poking back  
66a6 18 06				jr .peset	          
66a8			.pe1:          	; E2 selection  
66a8 cb c0				set 0, b         ; bit 0 set e1  
66aa 79					ld a, c  
66ab de 4f				sbc a, kLCD_Line3-1  
66ad 4f					ld c, a	         ; save caculated offset  
66ae			;		pop af     ; bin this original value now we have calculated form  
66ae			  
66ae			.peset:		; set bit  
66ae 78					ld a, b  
66af 32 fb fa				ld (display_lcde1e2), a 	  
66b2 79					ld a, c  
66b3 c1					pop bc  
66b4			  
66b4 f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
66b6 cd 15 66		            CALL fLCD_Inst      ;Write instruction to LCD  
66b9 f1			            POP  AF  
66ba c9			            RET  
66bb			  
66bb			  
66bb			; Output text string to LCD  
66bb			;   On entry: DE = Pointer to null terminated text string  
66bb			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
66bb 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
66bc b7			            OR   A              ;Null terminator?  
66bd c8			            RET  Z              ;Yes, so finished  
66be cd 51 66		            CALL fLCD_Data      ;Write character to display  
66c1 13			            INC  DE             ;Point to next character  
66c2 18 f7		            JR   fLCD_Str       ;Repeat  
66c4 c9					ret  
66c5			  
66c5			; Define custom character  
66c5			;   On entry: A = Character number (0 to 7)  
66c5			;             DE = Pointer to character bitmap data  
66c5			;   On exit:  A = Next character number  
66c5			;             DE = Next location following bitmap  
66c5			;             BC HL IX IY I AF' BC' DE' HL' preserved  
66c5			; Character is   
66c5 c5			fLCD_Def:   PUSH BC  
66c6 f5			            PUSH AF  
66c7 07			            RLCA                ;Calculate location  
66c8 07			            RLCA                ;  for bitmap data  
66c9 07			            RLCA                ;  = 8 x CharacterNumber  
66ca f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
66cc cd 15 66		            CALL fLCD_Inst      ;Write instruction to LCD  
66cf 06 00		            LD   B, 0  
66d1 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
66d2 cd 51 66		            CALL fLCD_Data      ;Write byte to display  
66d5 13			            INC  DE             ;Point to next byte  
66d6 04			            INC  B              ;Count bytes  
66d7 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
66d9 28 f6		            JR   Z, Loop       ;No, so repeat  
66db f1			            POP  AF  
66dc 3c			            INC  A              ;Increment character number  
66dd c1			            POP  BC  
66de c9			            RET  
66df			  
66df			  
66df			; **********************************************************************  
66df			; **  Private functions  
66df			; **********************************************************************  
66df			  
66df			; Write function to LCD  
66df			;   On entry: A = Function byte to be written  
66df			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
66df 3e 20		WrFn4bit:   LD   A, 00100000b  ;4-bit mode  
66e1 18 02		            JR   WrFunc  
66e3 3e 30		WrFn8bit:   LD   A, 00110000b  ;8-bit mode  
66e5 f5			WrFunc:     PUSH AF  
66e6 f5					push af  
66e7 3a fb fa				ld a, (display_lcde1e2)  
66ea fe 00				cp 0     ; e1  
66ec 20 0f				jr nz, .wfea2	  
66ee f1					pop af  
66ef d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
66f1 cb df		            SET  kLCDBitE, A     ; TODO Decide which E is being set  
66f3 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
66f5 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
66f7 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
66f9 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
66fb 18 0d			jr .wfskip  
66fd f1			.wfea2:		pop af  
66fe d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6700 cb c7		            SET  kLCDBitE2, A     ; TODO Decide which E is being set  
6702 cb 9f		            RES  kLCDBitE, A      ; TODO Decide which E is being set  
6704 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6706 cb 87		            RES  kLCDBitE2, A      ; TODO Decide which E is being set  
6708 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
670a 3e 05		.wfskip:            LD  A, 5  
670c cd 13 67		            CALL LCDDelay       ;Delay 5 ms to complete  
670f f1			            POP  AF  
6710 c9			            RET  
6711			  
6711			  
6711			; Delay in milliseconds  
6711			;   On entry: A = Number of milliseconds delay  
6711			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6711 3e 01		LCDDelay1:  LD   A, 1           ;Delay by 1 ms  
6713 d5			LCDDelay:   PUSH DE  
6714 5f			            LD   E, A           ;Delay by 'A' ms  
6715 16 00		            LD   D, 0  
6717 cd 50 0a		            CALL aDelayInMS  
671a d1			            POP  DE  
671b c9			            RET  
