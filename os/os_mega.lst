238c			user_word_eol:  
238c				; hl contains the pointer to where to create a linked list item from the end 
238c				; of the user dict to continue on at the system word dict 
238c				 
238c				; poke the stub of the word list linked list to repoint to rom words 
238c			 
238c				; stub format 
238c				; db   word id 
238c				; dw    link to next word 
238c			        ; db char length of token 
238c				; db string + 0 term 
238c				; db exec code....  
238c			 
238c			;	ld a, WORD_SYS_ROOT     ; root word 
238c 36 00			ld (hl), WORD_SYS_ROOT		; word id 
238e 23				inc hl 
238f			 
238f 11 38 25			ld de, sysdict 
2392 73				ld (hl), e		; next word link ie system dict 
2393 23				inc hl 
2394 72				ld (hl), d		; next word link ie system dict 
2395 23				inc hl	 
2396			 
2396			;	ld (hl), sysdict		; next word link ie system dict 
2396			;	inc hl 
2396			;	inc hl 
2396			 
2396			;	inc hl 
2396			;	inc hl 
2396			 
2396			;	ld a, 2			; word length is 0 
2396 36 02			ld (hl), 2 
2398 23				inc hl 
2399			 
2399			;	ld a, '~'			; word length is 0 
2399 36 7e			ld (hl), '~' 
239b 23				inc hl 
239c			;	ld a, 0			; save empty word 
239c 36 00			ld (hl), 0 
239e			 
239e c9				ret 
