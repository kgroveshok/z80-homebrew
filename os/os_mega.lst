24fd			.fnt1:	 
24fd				; find first char of token to locate 
24fd			 
24fd 1a				ld a, (de) 
24fe 4f				ld c,a 
24ff 7e				ld a,(hl) 
2500 cd b1 10			call toUpper 
2503					if DEBUG_FORTH 
