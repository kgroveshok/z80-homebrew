80ea			; Filesystem layout (Logical layout) 
80ea			; 
80ea			; Block 0 - Bank config  
80ea			; 
80ea			;      Byte - 0 file id counter 
80ea			;      Byte - 1-2 formated: Byte pattern: 0x80 x27 
80ea			;      Byte - 3-20 zero terminated bank label 
80ea			; 
80ea			; Block 1 > File storage 
80ea			; 
80ea			;      Byte 0 file id    - block 0 file details 
80ea			;      Byte 1 block id - block 0 is file  
80ea			;            Byte 2-15 - File name 
80ea			; 
80ea			;       - to end of block data 
80ea			; 
80ea			 
