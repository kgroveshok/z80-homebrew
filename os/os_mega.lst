0fb5 7e					ld a,(hl) 
0fb6 23					inc hl 
0fb7 cd dc 0f		                call    nibble2val      ; Get upper nibble 
0fba cb 07		                rlc     a 
0fbc cb 07		                rlc     a 
0fbe cb 07		                rlc     a 
0fc0 cb 07		                rlc     a 
0fc2 47			                ld      b, a            ; Save upper four bits 
0fc3 7e					ld a,(hl) 
0fc4 cd dc 0f		                call    nibble2val      ; Get lower nibble 
0fc7 b0			                or      b               ; Combine both nibbles 
0fc8 c1			                pop     bc              ; Restore B (and C) 
0fc9 c9			                ret 
