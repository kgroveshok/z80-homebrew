1107			 
1107			;      .org  0x100 
1107			;main: 
1107			;      ld    HL, 0x8100 
1107			;      ld    SP, HL 
1107			; 
1107			;      call  heap_init 
1107			; 
1107			;      ; Make some allocations 
1107			;      ld    HL, 12 
1107			;      call  malloc            ; Allocates 0x9004 
1107			; 
1107			;      ld    HL, 12 
1107			;      call  malloc            ; Allocates 0x9014 
1107			; 
1107			;      ld    HL, 12 
1107			;      call  malloc            ; Allocates 0x9024 
1107			; 
1107			;      ; Free some allocations 
1107			;      ld    HL, 0x9014 
1107			;      call  free 
1107			; 
1107			;      ld    HL, 0x9004 
1107			;      call  free 
1107			; 
1107			;      ld    HL, 0x9024 
1107			;      call  free 
1107			; 
1107			; 
1107			;      halt 
