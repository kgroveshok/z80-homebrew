9ca4			;WORD_SYS_LOWPRIM: equ 4    ; Offset for low level prim words opcode 
9ca4			;WORD_SYS_BRANCH: equ 10    ; Offset for branching and loop words opcode 
9ca4			WORD_SYS_UWORD: equ 1   ; Opcode for all user words 
9ca4			WORD_SYS_DELETED: equ 3 ; Op code for a deleted UWORD 
9ca4			WORD_SYS_ROOT: equ 0   ; Opcode for all user words 
9ca4			WORD_SYS_END: equ 0   ; Opcode for all user words 
9ca4			WORD_SYS_CORE: equ 20    ; Offset for dict core words opcode 
9ca4			WORD_FLAG_CODE: equ 0	   ; opcodeflag to exec pure code for this word 
9ca4			WORD_FLAG_JP: equ 1	   ; opcodeflag to list zero term jump table words 
9ca4			 
9ca4			; Core word preamble macro 
9ca4			 
9ca4			CWHEAD:   macro nxtword opcode lit len opflags 
9ca4				db WORD_SYS_CORE+opcode             
