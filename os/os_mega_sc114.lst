8f9c			; 
8f9c			; 
8f9c			 ;     .org  0x100 
8f9c			;main: 
8f9c			 ;     ld    HL, 0x8100 
8f9c			  ;    ld    SP, HL 
8f9c			; 
8f9c			;      call  heap_init 
8f9c			 
8f9c			      ; Make some allocations 
8f9c			;      ld    HL, 12 
8f9c			;      call  malloc            ; Allocates 0x9004 
8f9c			; 
8f9c			 ;     ld    HL, 12 
8f9c			;      call  malloc            ; Allocates 0x9014 
8f9c			 
8f9c			;      ld    HL, 12 
8f9c			;      call  malloc            ; Allocates 0x9024 
8f9c			 
8f9c			      ; Free some allocations 
8f9c			;      ld    HL, 0x9014 
8f9c			;      call  free 
8f9c			 
8f9c			;      ld    HL, 0x9004 
8f9c			;      call  free 
8f9c			; 
8f9c			;      ld    HL, 0x9024 
8f9c			;      call  free 
8f9c			 
8f9c			 
8f9c			 ;     halt 
8f9c			 
8f9c			 
8f9c			;------------------------------------------------------------------------------ 
8f9c			;     heap_init                                                               : 
8f9c			;                                                                             : 
8f9c			; Description                                                                 : 
8f9c			;     Initialise the heap and make it ready for malloc and free operations.   : 
8f9c			;                                                                             : 
8f9c			;     The heap is maintained as a linked list, starting with an initial       : 
8f9c			;     "dummy block" of zero size which is mainly used to hold a pointer to    : 
8f9c			;     the first free block in the heap. Each block then points to the next    : 
8f9c			;     free block within the heap, and the free list ends at the first block   : 
8f9c			;     with a null pointer to the next free block.                             : 
8f9c			;                                                                             : 
8f9c			; Parameters                                                                  : 
8f9c			;     Inputs are compile-time only. Two defines which specify the starting    : 
8f9c			;     address of the heap and its size are required, along with a memory      : 
8f9c			;     allocation of 4 consecutive bytes which is used for a dummy block which : 
8f9c			;     principally stores a pointer to the first free block in the heap.       : 
8f9c			;                                                                             : 
8f9c			; Returns                                                                     : 
8f9c			;     Nothing                                                                 : 
8f9c			;------------------------------------------------------------------------------ 
8f9c			heap_init: 
8f9c			      push  HL 
8f9c			 
8f9c			      ; Initialise free list struct 
8f9c			      ld    HL, heap_start 
8f9c			      ld    (free_list), HL 
8f9c			      ld    HL, 0 
8f9c			      ld    (free_list+2), HL 
8f9c			 
8f9c			      ; Insert first free block at bottom of heap, consumes entire heap 
8f9c			      ld    HL, heap_start+heap_size-4 
8f9c			      ld    (heap_start), HL        ; Next block (end of free list) 
8f9c			      ld    HL, heap_size-4 
8f9c			      ld    (heap_start+2), HL      ; Block size 
8f9c			 
8f9c			      ; Insert end of free list block at top of heap - two null words will 
8f9c			      ; terminate the free list 
8f9c			      ld    HL, 0 
8f9c			      ld    (heap_start+heap_size-2), HL 
8f9c			      ld    (heap_start+heap_size-4), HL 
8f9c			 
8f9c			      pop   HL 
8f9c			 
8f9c			      ret 
8f9c			 
8f9c			 
8f9c			;------------------------------------------------------------------------------ 
8f9c			;     malloc                                                                  : 
8f9c			;                                                                             : 
8f9c			; Description                                                                 : 
8f9c			;     Allocates the wanted space from the heap and returns the address of the : 
8f9c			;     first useable byte of the allocation.                                   : 
8f9c			;                                                                             : 
8f9c			;     Allocations can happen in one of two ways:                              : 
8f9c			;                                                                             : 
8f9c			;     1. A free block may be found which is the exact size wanted. In this    : 
8f9c			;        case the block is removed from the free list and retuedn to the      : 
8f9c			;        caller.                                                              : 
8f9c			;     2. A free block may be found which is larger than the size wanted. In   : 
8f9c			;        this case, the larger block is split into two. The first portion of  : 
8f9c			;        this block will become the requested space by the malloc call and    : 
8f9c			;        is returned to the caller. The second portion becomes a new free     : 
8f9c			;        block, and the free list is adjusted to maintain continuity via this : 
8f9c			;        newly created block.                                                 : 
8f9c			;                                                                             : 
8f9c			;     malloc does not set any initial value in the allocated space, the       : 
8f9c			;     caller is required to do this as required.                              : 
8f9c			;                                                                             : 
8f9c			;     This implementation of malloc uses the stack exclusively, and is        : 
8f9c			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8f9c			;     advisable to disable interrupts before calling malloc, and recommended  : 
8f9c			;     to avoid the use of malloc inside ISRs in general.                      : 
8f9c			;                                                                             : 
8f9c			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8f9c			;                                                                             : 
8f9c			; Parameters                                                                  : 
8f9c			;     HL  Number of bytes wanted                                              : 
8f9c			;                                                                             : 
8f9c			; Returns                                                                     : 
8f9c			;     HL  Address of the first useable byte of the allocation                 : 
8f9c			;                                                                             : 
8f9c			; Flags                                                                       : 
8f9c			;     Z   Set if the allocation did not succeed, clear otherwise              : 
8f9c			;                                                                             : 
8f9c			; Stack frame                                                                 : 
8f9c			;       |             |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |     BC      |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |     DE      |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |     IX      |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |  prev_free  |                                                       : 
8f9c			;   +4  +-------------+                                                       : 
8f9c			;       |  this_free  |                                                       : 
8f9c			;   +2  +-------------+                                                       : 
8f9c			;       |  next_free  |                                                       : 
8f9c			;   +0  +-------------+                                                       : 
8f9c			;       |             |                                                       : 
8f9c			;                                                                             : 
8f9c			;------------------------------------------------------------------------------ 
8f9c			malloc: 
8f9c			      push  BC 
8f9c			      push  DE 
8f9c			      push  IX 
8f9c			 
8f9c			      ld    A, H                    ; Exit if no space requested 
8f9c			      or    L 
8f9c			      jp    Z, malloc_early_exit 
8f9c			 
8f9c			      ; Set up stack frame 
8f9c			      ex    DE, HL 
8f9c			      ld    HL, -6                  ; Reserve 6 bytes for stack frame 
8f9c			      add   HL, SP 
8f9c			      ld    SP, HL 
8f9c			      ld    IX, 0                   ; Use IX as a frame pointer 
8f9c			      add   IX, SP 
8f9c			 
8f9c			      ; Setup initial state 
8f9c			      ld    HL, 4                   ; want must also include space used by block struct 
8f9c			      add   HL, DE 
8f9c			 
8f9c			      ld    B, H                    ; Move want to BC 
8f9c			      ld    C, L 
8f9c			 
8f9c			      ld    HL, free_list           ; Store prev_free ptr to stack 
8f9c			      ld    (IX+4), L 
8f9c			      ld    (IX+5), H 
8f9c			 
8f9c			      ld    E, (HL)                 ; Store this_free ptr to stack 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      ld    (IX+2), E 
8f9c			      ld    (IX+3), D 
8f9c			      ex    DE, HL                  ; this_free ptr into HL 
8f9c			 
8f9c			      ; Loop through free block list to find some space 
8f9c			malloc_find_space: 
8f9c			      ld    E, (HL)                 ; Load next_free ptr into DE 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			 
8f9c			      ld    A, D                    ; Check for null next_free ptr - end of free list 
8f9c			      or    E 
8f9c			      jp    Z, malloc_no_space 
8f9c			 
8f9c			      ld    (IX+0), E               ; Store next_free ptr to stack 
8f9c			      ld    (IX+1), D 
8f9c			 
8f9c			      ; Does this block have enough space to make the allocation? 
8f9c			      inc   HL                      ; Load free block size into DE 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			 
8f9c			      ex    DE, HL                  ; Check size of block against want 
8f9c			      or    A                       ; Ensure carry flag clear 
8f9c			      sbc   HL, BC 
8f9c			      push  HL                      ; Store the result for later (new block size) 
8f9c			 
8f9c			      jr    Z, malloc_alloc_fit     ; Z means block size matches want - can allocate 
8f9c			      jr    NC, malloc_alloc_split  ; NC means block is bigger than want - can allocate 
8f9c			 
8f9c			      ; this_free block is not big enough, setup ptrs to test next free block 
8f9c			      pop   HL                      ; Discard previous result 
8f9c			 
8f9c			      ld    L, (IX+2)               ; Move this_free ptr into prev_free 
8f9c			      ld    H, (IX+3) 
8f9c			      ld    (IX+4), L 
8f9c			      ld    (IX+5), H 
8f9c			 
8f9c			      ld    L, (IX+0)               ; Move next_free ptr into this_free 
8f9c			      ld    H, (IX+1) 
8f9c			      ld    (IX+2), L 
8f9c			      ld    (IX+3), H 
8f9c			 
8f9c			      jr    malloc_find_space 
8f9c			 
8f9c			      ; split a bigger block into two - requested size and remaining size 
8f9c			malloc_alloc_split: 
8f9c			      ex    DE, HL                  ; Calculate address of new free block 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			      add   HL, BC 
8f9c			 
8f9c			      ; Create a new block and point it at next_free 
8f9c			      ld    E, (IX+0)               ; Load next_free ptr into DE 
8f9c			      ld    D, (IX+1) 
8f9c			 
8f9c			      ld    (HL), E                 ; Store next_free ptr into new block 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			      pop   DE                      ; Store size of new block into new block 
8f9c			      inc   HL 
8f9c			      ld    (HL), E 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			      ; Update this_free ptr to point to new block 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			 
8f9c			      ld    E, (IX+2)               ; Take a copy of current this_free ptr 
8f9c			      ld    D, (IX+3) 
8f9c			 
8f9c			      ld    (IX+2), L               ; Store new block addr as this_free ptr 
8f9c			      ld    (IX+3), H 
8f9c			 
8f9c			      ; Modify this_free block to be allocation 
8f9c			      ex    DE, HL 
8f9c			      xor   A                       ; Null the next block ptr of allocated block 
8f9c			      ld    (HL), A 
8f9c			      inc   HL 
8f9c			      ld    (HL), A 
8f9c			 
8f9c			      inc   HL                      ; Store want size into allocated block 
8f9c			      ld    (HL), C 
8f9c			      inc   HL 
8f9c			      ld    (HL), B 
8f9c			      inc   HL 
8f9c			      push  HL                      ; Address of allocation to return 
8f9c			 
8f9c			      jr    malloc_update_links 
8f9c			 
8f9c			malloc_alloc_fit: 
8f9c			      pop   HL                      ; Dont need new block size, want is exact fit 
8f9c			 
8f9c			      ; Modify this_free block to be allocation 
8f9c			      ex    DE, HL 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			 
8f9c			      xor   A                       ; Null the next block ptr of allocated block 
8f9c			      ld    (HL), A 
8f9c			      inc   HL 
8f9c			      ld    (HL), A 
8f9c			 
8f9c			      inc   HL                      ; Store address of allocation to return 
8f9c			      inc   HL 
8f9c			      inc   HL 
8f9c			      push  HL 
8f9c			 
8f9c			      ; Copy next_free ptr to this_free, remove allocated block from free list 
8f9c			      ld    L, (IX+0)               ; next_free to HL 
8f9c			      ld    H, (IX+1) 
8f9c			 
8f9c			      ld    (IX+2), L               ; HL to this_free 
8f9c			      ld    (IX+3), H 
8f9c			 
8f9c			 
8f9c			malloc_update_links: 
8f9c			      ; Update prev_free ptr to point to this_free 
8f9c			      ld    L, (IX+4)               ; prev_free ptr to HL 
8f9c			      ld    H, (IX+5) 
8f9c			 
8f9c			      ld    E, (IX+2)               ; this_free ptr to DE 
8f9c			      ld    D, (IX+3) 
8f9c			 
8f9c			      ld    (HL), E                 ; this_free ptr into prev_free 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			      ; Clear the Z flag to indicate successful allocation 
8f9c			      ld    A, D 
8f9c			      or    E 
8f9c			 
8f9c			      pop   DE                      ; Address of allocation 
8f9c			 
8f9c			malloc_no_space: 
8f9c			      ld    HL, 6                   ; Clean up stack frame 
8f9c			      add   HL, SP 
8f9c			      ld    SP, HL 
8f9c			 
8f9c			      ex    DE, HL                  ; Alloc addr into HL for return 
8f9c			 
8f9c			malloc_early_exit: 
8f9c			      pop   IX 
8f9c			      pop   DE 
8f9c			      pop   BC 
8f9c			 
8f9c			      ret 
8f9c			 
8f9c			 
8f9c			;------------------------------------------------------------------------------ 
8f9c			;     free                                                                    : 
8f9c			;                                                                             : 
8f9c			; Description                                                                 : 
8f9c			;     Return the space pointed to by HL to the heap. HL must be an address as : 
8f9c			;     returned by malloc, otherwise the behaviour is undefined.               : 
8f9c			;                                                                             : 
8f9c			;     Where possible, directly adjacent free blocks will be merged together   : 
8f9c			;     into larger blocks to help ensure that the heap does not become         : 
8f9c			;     excessively fragmented.                                                 : 
8f9c			;                                                                             : 
8f9c			;     free does not clear or set any other value into the freed space, and    : 
8f9c			;     therefore its contents may be visible through subsequent malloc's. The  : 
8f9c			;     caller should clear the freed space as required.                        : 
8f9c			;                                                                             : 
8f9c			;     This implementation of free uses the stack exclusively, and is          : 
8f9c			;     therefore re-entrant. But due to the Z80's lack of atomicity, it is     : 
8f9c			;     advisable to disable interrupts before calling free, and recommended    : 
8f9c			;     to avoid the use of free inside ISRs in general.                        : 
8f9c			;                                                                             : 
8f9c			;     NOTE: heap_init must be called before malloc and free can be used.      : 
8f9c			;                                                                             : 
8f9c			; Parameters                                                                  : 
8f9c			;     HL  Pointer to address of first byte of allocation to be freed          : 
8f9c			;                                                                             : 
8f9c			; Returns                                                                     : 
8f9c			;     Nothing                                                                 : 
8f9c			;                                                                             : 
8f9c			; Stack frame                                                                 : 
8f9c			;       |             |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |     BC      |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |     DE      |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |     IX      |                                                       : 
8f9c			;       +-------------+                                                       : 
8f9c			;       |  prev_free  |                                                       : 
8f9c			;   +2  +-------------+                                                       : 
8f9c			;       |  next_free  |                                                       : 
8f9c			;   +0  +-------------+                                                       : 
8f9c			;       |             |                                                       : 
8f9c			;                                                                             : 
8f9c			;------------------------------------------------------------------------------ 
8f9c			free: 
8f9c			      push  BC 
8f9c			      push  DE 
8f9c			      push  IX 
8f9c			 
8f9c			      ld    A, H                    ; Exit if ptr is null 
8f9c			      or    L 
8f9c			      jp    Z, free_early_exit 
8f9c			 
8f9c			      ; Set up stack frame 
8f9c			      ex    DE, HL 
8f9c			      ld    HL, -4                  ; Reserve 4 bytes for stack frame 
8f9c			      add   HL, SP 
8f9c			      ld    SP, HL 
8f9c			      ld    IX, 0                   ; Use IX as a frame pointer 
8f9c			      add   IX, SP 
8f9c			 
8f9c			      ; The address in HL points to the start of the useable allocated space, 
8f9c			      ; but the block struct starts 4 bytes before this. Sub 4 to get the 
8f9c			      ; address of the block itself. 
8f9c			      ex    DE, HL 
8f9c			      ld    DE, -4 
8f9c			      add   HL, DE 
8f9c			 
8f9c			      ; An allocated block must have a null next block pointer in it 
8f9c			      ld    A, (HL) 
8f9c			      inc   HL 
8f9c			      or    (HL) 
8f9c			      jp    NZ, free_done 
8f9c			 
8f9c			      dec   HL 
8f9c			 
8f9c			      ld    B, H                    ; Copy HL to BC 
8f9c			      ld    C, L 
8f9c			 
8f9c			      ; Loop through the free list to find the first block with an address 
8f9c			      ; higher than the block being freed 
8f9c			      ld    HL, free_list 
8f9c			 
8f9c			free_find_higher_block: 
8f9c			      ld    E, (HL)                 ; Load next ptr from free block 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      dec   HL 
8f9c			 
8f9c			      ld    (IX+0), E               ; Save ptr to next free block 
8f9c			      ld    (IX+1), D 
8f9c			      ld    (IX+2), L               ; Save ptr to prev free block 
8f9c			      ld    (IX+3), H 
8f9c			 
8f9c			      ld    A, B                    ; Check if DE is greater than BC 
8f9c			      cp    D                       ; Compare MSB first 
8f9c			      jr    Z, $+4                  ; MSB the same, compare LSB 
8f9c			      jr    NC, free_find_higher_block_skip 
8f9c			      ld    A, C 
8f9c			      cp    E                       ; Then compare LSB 
8f9c			      jr    C, free_found_higher_block 
8f9c			 
8f9c			free_find_higher_block_skip: 
8f9c			      ld    A, D                    ; Reached the end of the free list? 
8f9c			      or    E 
8f9c			      jp    Z, free_done 
8f9c			 
8f9c			      ex    DE, HL 
8f9c			 
8f9c			      jr    free_find_higher_block 
8f9c			 
8f9c			free_found_higher_block: 
8f9c			      ; Insert freed block between prev and next free blocks 
8f9c			      ld    (HL), C                 ; Point prev free block to freed block 
8f9c			      inc   HL 
8f9c			      ld    (HL), B 
8f9c			 
8f9c			      ld    H, B                    ; Point freed block at next free block 
8f9c			      ld    L, C 
8f9c			      ld    (HL), E 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			      ; Check if the freed block is adjacent to the next free block 
8f9c			      inc   HL                      ; Load size of freed block into HL 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      ex    DE, HL 
8f9c			 
8f9c			      add   HL, BC                  ; Add addr of freed block and its size 
8f9c			 
8f9c			      ld    E, (IX+0)               ; Load addr of next free block into DE 
8f9c			      ld    D, (IX+1) 
8f9c			 
8f9c			      or    A                       ; Clear the carry flag 
8f9c			      sbc   HL, DE                  ; Subtract addrs to compare adjacency 
8f9c			      jr    NZ, free_check_adjacent_to_prev 
8f9c			 
8f9c			      ; Freed block is adjacent to next, merge into one bigger block 
8f9c			      ex    DE, HL                  ; Load next ptr from next block into DE 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      push  HL                      ; Save ptr to next block for later 
8f9c			 
8f9c			      ld    H, B                    ; Store ptr from next block into freed block 
8f9c			      ld    L, C 
8f9c			      ld    (HL), E 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			      pop   HL                      ; Restore ptr to next block 
8f9c			      inc   HL                      ; Load size of next block into DE 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      push  DE                      ; Save next block size for later 
8f9c			 
8f9c			      ld    H, B                    ; Load size of freed block into HL 
8f9c			      ld    L, C 
8f9c			      inc   HL 
8f9c			      inc   HL 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      ex    DE, HL 
8f9c			 
8f9c			      pop   DE                      ; Restore size of next block 
8f9c			      add   HL, DE                  ; Add sizes of both blocks 
8f9c			      ex    DE, HL 
8f9c			 
8f9c			      ld    H, B                    ; Store new bigger size into freed block 
8f9c			      ld    L, C 
8f9c			      inc   HL 
8f9c			      inc   HL 
8f9c			      ld    (HL), E 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			free_check_adjacent_to_prev: 
8f9c			      ; Check if the freed block is adjacent to the prev free block 
8f9c			      ld    L, (IX+2)               ; Prev free block ptr into HL 
8f9c			      ld    H, (IX+3) 
8f9c			 
8f9c			      inc   HL                      ; Size of prev free block into DE 
8f9c			      inc   HL 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			      dec   HL 
8f9c			 
8f9c			      add   HL, DE                  ; Add prev block addr and size 
8f9c			 
8f9c			      or    A                       ; Clear the carry flag 
8f9c			      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
8f9c			      jr    NZ, free_done 
8f9c			 
8f9c			      ; Freed block is adjacent to prev, merge into one bigger block 
8f9c			      ld    H, B                    ; Load next ptr from freed block into DE 
8f9c			      ld    L, C 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      push  HL                      ; Save freed block ptr for later 
8f9c			 
8f9c			      ld    L, (IX+2)               ; Store freed block ptr into prev block 
8f9c			      ld    H, (IX+3) 
8f9c			      ld    (HL), E 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			      pop   HL                      ; Restore freed block ptr 
8f9c			      inc   HL                      ; Load size of freed block into DE 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			      push  DE                      ; Save freed block size for later 
8f9c			 
8f9c			      ld    L, (IX+2)               ; Load size of prev block into DE 
8f9c			      ld    H, (IX+3) 
8f9c			      inc   HL 
8f9c			      inc   HL 
8f9c			      ld    E, (HL) 
8f9c			      inc   HL 
8f9c			      ld    D, (HL) 
8f9c			 
8f9c			      pop   HL                      ; Add sizes of both blocks 
8f9c			      add   HL, DE 
8f9c			      ex    DE, HL 
8f9c			 
8f9c			      ld    L, (IX+2)               ; Store new bigger size into prev block 
8f9c			      ld    H, (IX+3) 
8f9c			      inc   HL 
8f9c			      inc   HL 
8f9c			      ld    (HL), E 
8f9c			      inc   HL 
8f9c			      ld    (HL), D 
8f9c			 
8f9c			free_done: 
8f9c			      ld    HL, 4                   ; Clean up stack frame 
8f9c			      add   HL, SP 
8f9c			      ld    SP, HL 
8f9c			 
8f9c			free_early_exit: 
8f9c			      pop   IX 
8f9c			      pop   DE 
8f9c			      pop   BC 
8f9c			 
8f9c			      ret 
8f9c			 
8f9c			 
8f9c			;      .org 0x8000 
8f9c			; 
8f9c			;free_list         .dw   0     ; Block struct for start of free list (MUST be 4 bytes) 
8f9c			 ;                 .dw   0 
8f9c			 
8f9c			endif 
8f9c			 
8f9c			 
8f9c			if MALLOC_4 
8f9c			 
8f9c			; My memory allocation code. Very very simple.... 
8f9c			; allocate space under 250 chars 
8f9c			 
8f9c			heap_init: 
8f9c				; init start of heap as zero 
8f9c				;  
8f9c			 
8f9c				ld hl, heap_start 
8f9c			;	ld a, 0 
8f9c				ld (hl), 0      ; empty block 
8f9c				inc hl 
8f9c			;	ld a, 0 
8f9c				ld (hl), 0      ; length of block 
8f9c				; write end of list 
8f9c				inc hl 
8f9c				ld a,(hl) 
8f9c				inc hl 
8f9c				ld a,(hl) 
8f9c				 
8f9c			 
8f9c				; init some malloc vars 
8f9c			 
8f9c				ld hl, 0 
8f9c				ld (free_list), hl       ; store last malloc location 
8f9c			 
8f9c				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
8f9c			;	ld a, 0 
8f9c				ld (hl), 0 
8f9c			 
8f9c			 
8f9c				ld hl, heap_start 
8f9c				;  
8f9c				  
8f9c				ret 
8f9c			 
8f9c			 
8f9c			;    free block marker 
8f9c			;    requested size  
8f9c			;    pointer to next block 
8f9c			;    .... 
8f9c			;    next block marker 
8f9c			 
8f9c			 
8f9c			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
8f9c			; 
8f9c			 
8f9c			 
8f9c			malloc:  
8f9c				push de 
8f9c				push bc 
8f9c				push af 
8f9c			 
8f9c				; hl space required 
8f9c				 
8f9c				ld c, l    ; hold space   (TODO only a max of 255) 
8f9c			 
8f9c			;	inc c     ; TODO BUG need to fix memory leak on push str 
8f9c			;	inc c 
8f9c			;	inc c 
8f9c			;	inc c 
8f9c			;	inc c 
8f9c			;	inc c 
8f9c			;	inc c 
8f9c			 
8f9c			 
8f9c			 
8f9c				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
8f9c			 
8f9c				ld a, (free_list+3) 
8f9c			;	cp 0 
8f9c				or a 
8f9c				jr z, .contheap 
8f9c			 
8f9c				ld hl, (free_list)     ; get last alloc 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "mrs" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c				jr .startalloc 
8f9c			 
8f9c			.contheap: 
8f9c				ld hl, heap_start 
8f9c			 
8f9c			.startalloc: 
8f9c			 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "mym" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c			.findblock: 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "mmf" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c			 
8f9c				ld a,(hl)  
8f9c				; if byte is zero then clear to use 
8f9c			 
8f9c			;	cp 0 
8f9c				or a 
8f9c				jr z, .foundemptyblock 
8f9c			 
8f9c				; if byte is not clear 
8f9c				;     then byte is offset to next block 
8f9c			 
8f9c				inc hl 
8f9c				ld a, (hl) ; get size 
8f9c			.nextblock:	inc hl 
8f9c					ld e, (hl) 
8f9c					inc hl 
8f9c					ld d, (hl) 
8f9c					ex de, hl 
8f9c			;	inc hl  ; move past the store space 
8f9c			;	inc hl  ; move past zero index  
8f9c			 
8f9c				; TODO detect no more space 
8f9c			 
8f9c				push hl 
8f9c				ld de, heap_end 
8f9c				call cmp16 
8f9c				pop hl 
8f9c				jr nc, .nospace 
8f9c			 
8f9c				jr .findblock 
8f9c			 
8f9c			.nospace: ld hl, 0 
8f9c				jp .exit 
8f9c			 
8f9c			 
8f9c			.foundemptyblock:	 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "mme" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c			 
8f9c			; TODO has block enough space if reusing??? 
8f9c			 
8f9c				;  
8f9c			 
8f9c			; see if this block has been previously used 
8f9c				inc hl 
8f9c				ld a, (hl) 
8f9c				dec hl 
8f9c			;	cp 0 
8f9c				or a 
8f9c				jr z, .newblock 
8f9c			 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "meR" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c			 
8f9c			; no reusing previously allocated block 
8f9c			 
8f9c			; is it smaller than previously used? 
8f9c				 
8f9c				inc hl    ; move to size 
8f9c				ld a, c 
8f9c				sub (hl)        ; we want c < (hl) 
8f9c				dec hl    ; move back to marker 
8f9c			        jr z, .findblock 
8f9c			 
8f9c				; update with the new size which should be lower 
8f9c			 
8f9c			        ;inc  hl   ; negate next move. move back to size  
8f9c			 
8f9c			.newblock: 
8f9c				; need to be at marker here 
8f9c			 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "meN" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c			 
8f9c			 
8f9c				ld a, c 
8f9c			 
8f9c				ld (free_list+3), a	 ; flag resume from last malloc  
8f9c				ld (free_list), hl    ; save out last location 
8f9c			 
8f9c			 
8f9c				;inc a     ; space for length byte 
8f9c				ld (hl), a     ; save block in use marker 
8f9c			 
8f9c				inc hl   ; move to space marker 
8f9c				ld (hl), a    ; save new space 
8f9c			 
8f9c				inc hl   ; move to start of allocated area 
8f9c				 
8f9c			;	push hl     ; save where we are - 1  
8f9c			 
8f9c			;	inc hl  ; move past zero index  
8f9c				; skip space to set down new marker 
8f9c			 
8f9c				; provide some extra space for now 
8f9c			 
8f9c				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
8f9c				inc a 
8f9c				inc a 
8f9c			 
8f9c				push hl   ; save where we are in the node block 
8f9c			 
8f9c				call addatohl 
8f9c			 
8f9c				; write linked list point 
8f9c			 
8f9c				pop de     ; get our node position 
8f9c				ex de, hl 
8f9c			 
8f9c				ld (hl), e 
8f9c				inc hl 
8f9c				ld (hl), d 
8f9c			 
8f9c				inc hl 
8f9c			 
8f9c				; now at start of allocated data so save pointer 
8f9c			 
8f9c				push hl 
8f9c			 
8f9c				; jump to position of next node and setup empty header in DE 
8f9c			 
8f9c				ex de, hl 
8f9c			 
8f9c			;	inc hl ; move past end of block 
8f9c			 
8f9c			;	ld a, 0 
8f9c				ld (hl), 0   ; empty marker 
8f9c				inc hl 
8f9c				ld (hl), 0   ; size 
8f9c				inc hl  
8f9c				ld (hl), 0   ; ptr 
8f9c				inc hl 
8f9c				ld (hl), 0   ; ptr 
8f9c			 
8f9c			 
8f9c				pop hl 
8f9c			 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "mmr" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c			 
8f9c			.exit: 
8f9c				pop af 
8f9c				pop bc 
8f9c				pop de  
8f9c				ret 
8f9c			 
8f9c			 
8f9c			 
8f9c			 
8f9c			free:  
8f9c				push hl 
8f9c				push af 
8f9c				; get address in hl 
8f9c			 
8f9c					if DEBUG_FORTH_MALLOC_INT 
8f9c						DMARK "fre" 
8f9c						CALLMONITOR 
8f9c					endif 
8f9c				; data is at hl - move to block count 
8f9c				dec hl 
8f9c				dec hl    ; get past pointer 
8f9c				dec hl 
8f9c			 
8f9c				ld a, (hl)    ; need this for a validation check 
8f9c			 
8f9c				dec hl    ; move to block marker 
8f9c			 
8f9c				; now check that the block count and block marker are the same  
8f9c			        ; this checks that we are on a malloc node and not random memory 
8f9c			        ; OK a faint chance this could be a problem but rare - famous last words! 
8f9c			 
8f9c				ld c, a 
8f9c				ld a, (hl)    
8f9c			 
8f9c				cp c 
8f9c				jr nz, .freeignore      ; not a valid malloc node in use so dont break anything 
8f9c			 
8f9c				; yes good chance we are on a malloc node 
8f9c			 
8f9c			;	ld a, 0      
8f9c				ld (hl), 0   ; mark as free 
8f9c			 
8f9c				ld (free_list+3), a	 ; flag reuse of existing block on next malloc 
8f9c			 
8f9c			.freeignore:  
8f9c			 
8f9c				pop af 
8f9c				pop hl 
8f9c			 
8f9c				ret 
8f9c			 
8f9c			 
8f9c			 
8f9c			endif 
8f9c			 
