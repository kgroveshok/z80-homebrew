8d8f			; https://tutorials.eeems.ca/ASMin28Days/lesson/day16.html#cmp 
8d8f			 
8d8f			; String Length 
8d8f			;With a length-prefixed string, finding the length is trivial. For a null-terminated string, the process is decidedly more involved. This is where CPIR comes in. 
8d8f			 
8d8f			; Get the length of the null-terminated string starting at $8000 hl 
8d8f			;    LD     HL, $8000 
8d8f			 
8d8f			strlenz: 
8d8f			 
8d8f af			    XOR    A               ; Zero is the value we are looking for. 
8d90 47			    LD     B, A             ; Since we haven't the slightest clue as to the  
8d91 4f			    LD     C, A             ; actual size of the string, put 0 in BC to search 
8d92			                           ; 65, 536 bytes (the entire addressable memory space). 
8d92 ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
8d94			 
8d94			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
8d94 67			    LD     H, A             ; Zero HL (basically set it to 65, 536) to get the 
8d95 6f			    LD     L, A             ; number of bytes 
8d96 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
8d98 2b			    DEC    HL              ; Compensate for null. 
8d99 c9				ret 
8d9a			 
8d9a			; Get the length of the A terminated string starting at $8000 hl 
8d9a			;    LD     HL, $8000 
8d9a			 
8d9a			strlent: 
8d9a			 
8d9a			                  ; A is the value we are looking for. 
8d9a 06 00		    LD     B, 0             ; Since we haven't the slightest clue as to the  
8d9c 0e 00		    LD     C, 0             ; actual size of the string, put 0 in BC to search 
8d9e			                           ; 65, 536 bytes (the entire addressable memory space). 
8d9e ed b1		    CPIR                   ; Begin search for a byte equalling zero. 
8da0			 
8da0			; BC has been decremented so that it holds -length. Now need to synthesize a NEG BC. 
8da0 26 00		    LD     H, 0             ; Zero HL (basically set it to 65, 536) to get the 
8da2 2e 00		    LD     L, 0             ; number of bytes 
8da4 ed 42		    SBC    HL, BC           ; Find the size. CPIR doesn't affect carry. 
8da6 2b			    DEC    HL              ; Compensate for null. 
8da7 c9				ret 
8da8			 
8da8			 
8da8			;Comparing Strings 
8da8			 
8da8			;IN    HL     Address of string1. 
8da8			;      DE     Address of string2. 
8da8			 
8da8			; doc given but wrong??? 
8da8			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
8da8			;      carry  Set if string1 > string2, reset if string1 <= string2. 
8da8			; tested 
8da8			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
8da8			 
8da8			strcmp_old: 
8da8 e5			    PUSH   HL 
8da9 d5			    PUSH   DE 
8daa			 
8daa 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
8dab be			    CP     (HL)            ; (want to minimize work). 
8dac 38 01		    JR     C, Str1IsBigger 
8dae 7e			    LD     A, (HL) 
8daf			 
8daf			Str1IsBigger: 
8daf 4f			    LD     C, A             ; Put length in BC 
8db0 06 00		    LD     B, 0 
8db2 13			    INC    DE              ; Increment pointers to meat of string. 
8db3 23			    INC    HL 
8db4			 
8db4			CmpLoop: 
8db4 1a			    LD     A, (DE)          ; Compare bytes. 
8db5 ed a1		    CPI 
8db7 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
8db9 13			    INC    DE              ; Update pointer. 
8dba ea b4 8d		    JP     PE, CmpLoop 
8dbd			 
8dbd d1			    POP    DE 
8dbe e1			    POP    HL 
8dbf 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
8dc0 be			    CP     (HL) 
8dc1 c9			    RET 
8dc2			 
8dc2			NoMatch: 
8dc2 2b			    DEC    HL 
8dc3 be			    CP     (HL)            ; Compare again to affect carry. 
8dc4 d1			    POP    DE 
8dc5 e1			    POP    HL 
8dc6 c9			    RET 
8dc7			 
