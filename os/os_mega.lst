104e			; Decimal Signed Version 
104e			 
104e			; DispA 
104e			; -------------------------------------------------------------- 
104e			; Converts a signed integer value to a zero-terminated ASCII 
104e			; string representative of that value (using radix 10). 
104e			; -------------------------------------------------------------- 
104e			; INPUTS: 
104e			;     HL     Value to convert (two's complement integer). 
104e			;     DE     Base address of string destination. (pointer). 
104e			; -------------------------------------------------------------- 
104e			; OUTPUTS: 
104e			;     None 
104e			; -------------------------------------------------------------- 
104e			; REGISTERS/MEMORY DESTROYED 
104e			; AF HL 
104e			; -------------------------------------------------------------- 
104e			 
104e			;DispHLToASCII: 
104e			;   push    de 
104e			;   push    bc 
104e			; 
104e			;; Detect sign of HL. 
104e			;    bit    7, h 
104e			;    jr     z, ._DoConvert 
104e			; 
104e			;; HL is negative. Output '-' to string and negate HL. 
104e			;    ld     a, '-' 
104e			;    ld     (de), a 
104e			;    inc    de 
104e			; 
104e			;; Negate HL (using two's complement) 
104e			;    xor    a 
104e			;    sub    l 
104e			;    ld     l, a 
104e			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
104e			;    sbc    a, h 
104e			;    ld     h, a 
104e			; 
104e			;; Convert HL to digit characters 
104e			;._DoConvert: 
104e			;    ld     b, 0     ; B will count character length of number 
104e			;-   ld     a, 10 
104e			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
104e			;    push   af 
104e			;    inc    b 
104e			;    ld     a, h 
104e			;    or     l 
104e			;    jr     nz, - 
104e			; 
104e			;; Retrieve digits from stack 
104e			;-   pop    af 
104e			;    or     $30 
104e			;    ld     (de), a 
104e			;    inc    de 
104e			;    djnz   - 
104e			; 
104e			;; Terminate string with NULL 
104e			;    xor    a 
104e			;    ld     (de), a 
104e			; 
104e			;    pop    bc 
104e			;    pop    de 
104e			;    ret 
104e			 
104e			;Comments 
104e			; 
104e			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
104e			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
104e			;    Note that the output string will not be fixed-width. 
104e			; 
104e			;Example Usage 
104e			; 
104e			;    ld    hl, -1004 
104e			;    ld    de, OP1 
104e			;    call  DispA 
104e			;    ld    hl, OP1 
104e			;    syscall  PutS 
