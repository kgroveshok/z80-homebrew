110d			free_check_adjacent_to_prev: 
110d			      ; Check if the freed block is adjacent to the prev free block 
110d dd 6e 02		      ld    L, (IX+2)               ; Prev free block ptr into HL 
1110 dd 66 03		      ld    H, (IX+3) 
1113			 
1113 23			      inc   HL                      ; Size of prev free block into DE 
1114 23			      inc   HL 
1115 5e			      ld    E, (HL) 
1116 23			      inc   HL 
1117 56			      ld    D, (HL) 
1118 2b			      dec   HL 
1119 2b			      dec   HL 
111a 2b			      dec   HL 
111b			 
111b 19			      add   HL, DE                  ; Add prev block addr and size 
111c			 
111c b7			      or    A                       ; Clear the carry flag 
111d ed 42		      sbc   HL, BC                  ; Subtract addrs to compare adjacency 
111f 20 2e		      jr    NZ, free_done 
1121			 
1121			      ; Freed block is adjacent to prev, merge into one bigger block 
1121 60			      ld    H, B                    ; Load next ptr from freed block into DE 
1122 69			      ld    L, C 
1123 5e			      ld    E, (HL) 
1124 23			      inc   HL 
1125 56			      ld    D, (HL) 
1126 e5			      push  HL                      ; Save freed block ptr for later 
1127			 
1127 dd 6e 02		      ld    L, (IX+2)               ; Store freed block ptr into prev block 
112a dd 66 03		      ld    H, (IX+3) 
112d 73			      ld    (HL), E 
112e 23			      inc   HL 
112f 72			      ld    (HL), D 
1130			 
1130 e1			      pop   HL                      ; Restore freed block ptr 
1131 23			      inc   HL                      ; Load size of freed block into DE 
1132 5e			      ld    E, (HL) 
1133 23			      inc   HL 
1134 56			      ld    D, (HL) 
1135 d5			      push  DE                      ; Save freed block size for later 
1136			 
1136 dd 6e 02		      ld    L, (IX+2)               ; Load size of prev block into DE 
1139 dd 66 03		      ld    H, (IX+3) 
113c 23			      inc   HL 
113d 23			      inc   HL 
113e 5e			      ld    E, (HL) 
113f 23			      inc   HL 
1140 56			      ld    D, (HL) 
1141			 
1141 e1			      pop   HL                      ; Add sizes of both blocks 
1142 19			      add   HL, DE 
1143 eb			      ex    DE, HL 
1144			 
1144 dd 6e 02		      ld    L, (IX+2)               ; Store new bigger size into prev block 
1147 dd 66 03		      ld    H, (IX+3) 
114a 23			      inc   HL 
114b 23			      inc   HL 
114c 73			      ld    (HL), E 
114d 23			      inc   HL 
114e 72			      ld    (HL), D 
114f			 
114f			free_done: 
114f 21 04 00		      ld    HL, 4                   ; Clean up stack frame 
1152 39			      add   HL, SP 
1153 f9			      ld    SP, HL 
1154			 
1154			free_early_exit: 
1154 dd e1		      pop   IX 
1156 d1			      pop   DE 
1157 c1			      pop   BC 
1158			 
1158 c9			      ret 
1159			 
