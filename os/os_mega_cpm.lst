13ce			.genfile: 
13ce				push hl 
13ce				push de 
13ce			 
13ce				call clear_display 
13ce				ld a, display_row_1 
13ce				ld de, .genfiletxt 
13ce				call str_at_display 
13ce				call update_display 
13ce			 
13ce				pop de 
13ce				pop hl 
13ce			 
13ce			 
13ce				push de 
13ce				call storage_create 
13ce				; id in hl 
13ce				pop de   ; table of strings to add 
13ce			 
13ce			.genloop: 
13ce			 
13ce				push hl ; save id for next time around 
13ce				push de ; save de for next time around 
13ce			 
13ce				ex de, hl 
13ce				call loadwordinhl 
13ce				ex de, hl 
13ce			 
13ce				; need hl to be the id 
13ce				; need de to be the string ptr 
13ce				 
13ce				call storage_append 
13ce			 
13ce				pop de 
13ce				pop hl 
13ce			 
13ce				inc de 
13ce				inc de 
13ce			 
13ce				ld a,(de) 
13ce				cp 0 
13ce				jr nz, .genloop 
13ce				inc de 
13ce				ld a, (de) 
13ce				dec de 
13ce				cp 0 
13ce				jr nz, .genloop	 
13ce			 
13ce				ret 
