8fb5			 
8fb5			; My memory allocation code. Very very simple.... 
8fb5			; allocate space under 250 chars 
8fb5			 
8fb5			heap_init: 
8fb5				; init start of heap as zero 
8fb5				;  
8fb5			 
8fb5				ld hl, heap_start 
8fb5			;	ld a, 0 
8fb5				ld (hl), 0      ; empty block 
8fb5				inc hl 
8fb5			;	ld a, 0 
8fb5				ld (hl), 0      ; length of block 
8fb5				; write end of list 
8fb5				inc hl 
8fb5				ld a,(hl) 
8fb5				inc hl 
8fb5				ld a,(hl) 
8fb5				 
8fb5			 
8fb5				; init some malloc vars 
8fb5			 
8fb5				ld hl, 0 
8fb5				ld (free_list), hl       ; store last malloc location 
8fb5			 
8fb5				ld hl, free_list+3      ; flag for 'free' being used and force a rescan for reuse of block  
8fb5			;	ld a, 0 
8fb5				ld (hl), 0 
8fb5			 
8fb5			 
8fb5				ld hl, heap_start 
8fb5				;  
8fb5				  
8fb5				ret 
8fb5			 
8fb5			 
8fb5			;    free block marker 
8fb5			;    requested size  
8fb5			;    pointer to next block 
8fb5			;    .... 
8fb5			;    next block marker 
8fb5			 
8fb5			 
8fb5			; TODO add a flag that is reset on use of free. if flag is reset then start scan from start of heap otherwise use last location 
8fb5			; 
8fb5			 
8fb5			 
8fb5			malloc:  
8fb5				push de 
8fb5				push bc 
8fb5				push af 
8fb5			 
8fb5				; hl space required 
8fb5				 
8fb5				ld c, l    ; hold space   (TODO only a max of 255) 
8fb5			 
8fb5			;	inc c     ; TODO BUG need to fix memory leak on push str 
8fb5			;	inc c 
8fb5			;	inc c 
8fb5			;	inc c 
8fb5			;	inc c 
8fb5			;	inc c 
8fb5			;	inc c 
8fb5			 
8fb5			 
8fb5			 
8fb5				; start at heap if a free has been issued so we can reclaim it otherwise continue from last time 
8fb5			 
8fb5				ld a, (free_list+3) 
8fb5			;	cp 0 
8fb5				or a 
8fb5				jr z, .contheap 
8fb5			 
8fb5				ld hl, (free_list)     ; get last alloc 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "mrs" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5				jr .startalloc 
8fb5			 
8fb5			.contheap: 
8fb5				ld hl, heap_start 
8fb5			 
8fb5			.startalloc: 
8fb5			 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "mym" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5			.findblock: 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "mmf" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5			 
8fb5				ld a,(hl)  
8fb5				; if byte is zero then clear to use 
8fb5			 
8fb5			;	cp 0 
8fb5				or a 
8fb5				jr z, .foundemptyblock 
8fb5			 
8fb5				; if byte is not clear 
8fb5				;     then byte is offset to next block 
8fb5			 
8fb5				inc hl 
8fb5				ld a, (hl) ; get size 
8fb5			.nextblock:	inc hl 
8fb5					ld e, (hl) 
8fb5					inc hl 
8fb5					ld d, (hl) 
8fb5					ex de, hl 
8fb5			;	inc hl  ; move past the store space 
8fb5			;	inc hl  ; move past zero index  
8fb5			 
8fb5				; TODO detect no more space 
8fb5			 
8fb5				push hl 
8fb5				ld de, heap_end 
8fb5				call cmp16 
8fb5				pop hl 
8fb5				jr nc, .nospace 
8fb5			 
8fb5				jr .findblock 
8fb5			 
8fb5			.nospace: ld hl, 0 
8fb5				jp .exit 
8fb5			 
8fb5			 
8fb5			.foundemptyblock:	 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "mme" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5			 
8fb5			; TODO has block enough space if reusing??? 
8fb5			 
8fb5				;  
8fb5			 
8fb5			; see if this block has been previously used 
8fb5				inc hl 
8fb5				ld a, (hl) 
8fb5				dec hl 
8fb5			;	cp 0 
8fb5				or a 
8fb5				jr z, .newblock 
8fb5			 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "meR" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5			 
8fb5			; no reusing previously allocated block 
8fb5			 
8fb5			; is it smaller than previously used? 
8fb5				 
8fb5				inc hl    ; move to size 
8fb5				ld a, c 
8fb5				sub (hl)        ; we want c < (hl) 
8fb5				dec hl    ; move back to marker 
8fb5			        jr z, .findblock 
8fb5			 
8fb5				; update with the new size which should be lower 
8fb5			 
8fb5			        ;inc  hl   ; negate next move. move back to size  
8fb5			 
8fb5			.newblock: 
8fb5				; need to be at marker here 
8fb5			 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "meN" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5			 
8fb5			 
8fb5				ld a, c 
8fb5			 
8fb5				ld (free_list+3), a	 ; flag resume from last malloc  
8fb5				ld (free_list), hl    ; save out last location 
8fb5			 
8fb5			 
8fb5				;inc a     ; space for length byte 
8fb5				ld (hl), a     ; save block in use marker 
8fb5			 
8fb5				inc hl   ; move to space marker 
8fb5				ld (hl), a    ; save new space 
8fb5			 
8fb5				inc hl   ; move to start of allocated area 
8fb5				 
8fb5			;	push hl     ; save where we are - 1  
8fb5			 
8fb5			;	inc hl  ; move past zero index  
8fb5				; skip space to set down new marker 
8fb5			 
8fb5				; provide some extra space for now 
8fb5			 
8fb5				inc a    ; actual is one fewer than bytes requested. correct if zero index is taken into account 
8fb5				inc a 
8fb5				inc a 
8fb5			 
8fb5				push hl   ; save where we are in the node block 
8fb5			 
8fb5				call addatohl 
8fb5			 
8fb5				; write linked list point 
8fb5			 
8fb5				pop de     ; get our node position 
8fb5				ex de, hl 
8fb5			 
8fb5				ld (hl), e 
8fb5				inc hl 
8fb5				ld (hl), d 
8fb5			 
8fb5				inc hl 
8fb5			 
8fb5				; now at start of allocated data so save pointer 
8fb5			 
8fb5				push hl 
8fb5			 
8fb5				; jump to position of next node and setup empty header in DE 
8fb5			 
8fb5				ex de, hl 
8fb5			 
8fb5			;	inc hl ; move past end of block 
8fb5			 
8fb5			;	ld a, 0 
8fb5				ld (hl), 0   ; empty marker 
8fb5				inc hl 
8fb5				ld (hl), 0   ; size 
8fb5				inc hl  
8fb5				ld (hl), 0   ; ptr 
8fb5				inc hl 
8fb5				ld (hl), 0   ; ptr 
8fb5			 
8fb5			 
8fb5				pop hl 
8fb5			 
8fb5					if DEBUG_FORTH_MALLOC_INT 
8fb5						DMARK "mmr" 
8fb5						CALLMONITOR 
8fb5					endif 
8fb5			 
8fb5			.exit: 
8fb5				pop af 
8fb5				pop bc 
8fb5				pop de  
