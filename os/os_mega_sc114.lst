d523			include "forth_startup.asm" 
d523			; Which startup method to use? 
d523			; 
d523			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
d523			; followed by loading of a list of scripts in eeprom 
d523			 
d523			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
d523			; from eeprom 
d523			 
d523			; Select with define in main stubs 
d523			 
d523			if STARTUP_V1 
d523				include "forth_startupv1.asm" 
d523			; Startup script loading version 1 
d523			 
d523			; If SE storage is available first stage is to use the selected file 
d523			; then go through the eeprom list 
d523			 
d523 .. 00		sprompt1: db "Startup load...",0 
d533 .. 00		sprompt2: db "Run? 1=No *=End #=All",0 
