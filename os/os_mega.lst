15a3			; Support for the DART serial chip. Might work with SIO(2) too. 
15a3			 
15a3			Device_Dart: equ Device_A  
15a3			 
15a3			SIOA_D: equ    Device_Dart    ;SIO CHANNEL A DATA REGISTER 
15a3			SIOA_C: equ    Device_Dart+2    ;SIO CHANNEL A CONTROL REGISTER 
15a3			SIOB_D: equ    Device_Dart+1    ;SIO CHANNEL B DATA REGISTER 
15a3			SIOB_C: equ    Device_Dart+3    ;SIO CHANNEL B CONTROL REGISTER 
15a3			 
15a3			dart_init:  
15a3			; init Z80 SIO A 
15a3			; Z80 SIO Register Mnemonics 
15a3			 
15a3			; TODO CHANGEME 
15a3			;;// initialize SIO port A CLK 1X 8N1 
15a3			 
15a3			; TODO CHANGEME 
15a3			 
15a3 3e 00		        LD A,00H                ;REQUEST REGISTER #0 
15a5 d3 02		        OUT (SIOA_C),A 
15a7 3e 18		        LD A,18H                ;LOAD #0 WITH 18H - CHANNEL RESET 
15a9 d3 02		    	OUT (SIOA_C),A 
15ab			; 
15ab 3e 01		        LD A,01H 
15ad d3 02		        OUT (SIOA_C),A 
15af 3e 00		        LD A,00H 
15b1 d3 02		    	OUT (SIOA_C),A 
15b3			; 
15b3 3e 04			    LD A,04H                ;REQUEST TRANSFER TO REGISTER #4 
15b5 d3 02			    OUT (SIOA_C),A 
15b7 3e c4		        LD A,0C4H               ;WRITE #4 WITH X/0 CLOCK 1X STOP BIT 
15b9 d3 02		        OUT (SIOA_C),A          ;  AND NO PARITY 
15bb			; 
15bb 3e 03		        LD A,03H                ;REQUEST TRANSFER TO REGISTER #3 
15bd d3 02		        OUT (SIOA_C),A 
15bf 3e c1		        LD A,0C1H 
15c1 d3 02		        OUT (SIOA_C),A          ;WRITE #3 WITH COH - RECEIVER 8 BITS & RX ENABLE 
15c3			; 
15c3 3e 05		        LD A,05H                ;REQUEST TRANSFER TO REGISTER #5 
15c5 d3 02		        OUT (SIOA_C),A 
15c7 3e 68		        LD A,068H 
15c9 d3 02		        OUT (SIOA_C),A          ;WRITE #5 WITH 60H - TRANSMIT 8 BITS & TX ENABLE 
15cb			 
15cb			        ;SETUP PORT B 
15cb 3e 00		        LD A,00H                ;REQUEST REGISTER #0 
15cd d3 03		        OUT (SIOB_C),A 
15cf 3e 18		        LD A,018H                ;LOAD #0 WITH 18H - CHANNEL RESET 
15d1 d3 03			    OUT (SIOB_C),A 
15d3 c9				ret 
