20fd			macro_forth_dsp_next: 
20fd				if DEBUG_FORTH_STACK_GUARD 
20fd cd 7f 65				call check_stacks 
2100				endif 
2100 e5				push hl 
2101 d5				push de 
2102 eb				ex de,hl 
2103 2a 05 f9			ld hl,(cli_data_sp) 
2106 23				inc hl 
2107 23				inc hl 
2108			 
