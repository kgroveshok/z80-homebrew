0dce			.DATA: 
0dce 30					DEFB	30h	; 0 
0dcf 31					DEFB	31h	; 1 
0dd0 32					DEFB	32h	; 2 
0dd1 33					DEFB	33h	; 3 
0dd2 34					DEFB	34h	; 4 
0dd3 35					DEFB	35h	; 5 
0dd4 36					DEFB	36h	; 6 
0dd5 37					DEFB	37h	; 7 
0dd6 38					DEFB	38h	; 8 
0dd7 39					DEFB	39h	; 9 
0dd8 41					DEFB	41h	; A 
0dd9 42					DEFB	42h	; B 
0dda 43					DEFB	43h	; C 
0ddb 44					DEFB	44h	; D 
0ddc 45					DEFB	45h	; E 
