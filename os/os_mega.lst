25aa			 
25aa			; the core word dictionary v4 
25aa			; https://www.complang.tuwien.ac.at/forth/gforth/Docs-html/Notation.html#Notation 
25aa			 
25aa			; this is a linked list for each of the system words used 
25aa			; user defined words will follow the same format but will be in ram 
25aa			 
25aa			 
25aa			; 
25aa			; 
25aa			; define linked list: 
25aa			; 
25aa			; 1. compiled byte op code 
25aa			; 2. len of text word 
25aa			; 3. text word 
25aa			; 4. ptr to next dictionary word 
25aa			; 5. asm, calls etc for the word 
25aa			; 
25aa			;  if 1 == 0 then last word in dict  
25aa			;   
25aa			; set the start of dictionary scanning to be in ram and the last word point to the system dict 
25aa			;  
25aa			;  
25aa			; create basic standard set of words 
25aa			; 
25aa			;  
25aa			; + - / * DUP EMIT . SWAP IF..THEN..ELSE DO..LOOP  : ; DROP  
25aa			; 2DUP 2DROP 2SWAP  
25aa			; @ C@ - get byte  
25aa			; ! C! - store byte 
25aa			; 0< true if less than zero 
25aa			; 0= true if zero 
25aa			; < >  
25aa			; = true if same 
25aa			; variables 
25aa			 
25aa			 
25aa			; Hardware specific words I may need 
25aa			; 
25aa			; IN OUT  
25aa			; calls to key util functions 
25aa			; calls to hardward abstraction stuff 
25aa			; easy control of frame buffers and lcd i/o 
25aa			; keyboard  
25aa			 
25aa			 
25aa			;DICT: macro 
25aa			; op_code, len, word, next 
25aa			;    word: 
25aa			;    db op_code 
25aa			;    ds word zero term 
25aa			;    dw next 
25aa			;    endm 
25aa			 
25aa			 
25aa			 
25aa			 
25aa			; op code 1 is a flag for user define words which are to be handled differently 
25aa			 
25aa			 
25aa			; 
25aa			; 
25aa			;    TODO on entry to a word this should be the expected environment 
25aa			;    hl - tos value if number then held, if string this is the ptr 
25aa			;    de -  
25aa			 
25aa			 
25aa			; opcode ranges 
25aa			; 0 - end of word dict 
25aa			; 255 - user define words 
25aa			 
25aa			sysdict: 
25aa			include "forth_opcodes.asm" 
25aa			; op codes for forth keywords 
25aa			 
25aa			; Changing use of opcodes to flag is the word exists in compiled form or not.  
25aa			; This provides a means to compile uwords if required for higher performance 
25aa			; by avoiding the use of the keyword parser and just jumping directly to the code 
25aa			; Actually there is already a flag for if the code exists as binary thinking about it... 
25aa			 
25aa			 
25aa			 
25aa			 
