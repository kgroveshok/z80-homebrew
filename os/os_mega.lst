251c						CALLMONITOR 
251c					endif 
251c			 
251c			;	cp 0 
251c b7				or a 
251d 28 0b			jr z, .fntmatchyes 
251f			 
251f				; are we at the end of the token to find? 
251f			 
251f					if DEBUG_FORTH 
251f						DMARK "NT5" 
251f						CALLMONITOR 
251f					endif 
251f 3e 00			ld a, 0 
2521 b9				cp c 
2522			 
2522 c2 0d 25			jp nz, .fnt2cmpmore    ; no, so keep going to a direct hit 
2525			 
2525					if DEBUG_FORTH 
2525						DMARK "NT6" 
2525						CALLMONITOR 
2525					endif 
2525				; token to find is exhusted but no match to stream 
2525			 
2525				; restore tok pointer and continue on 
2525 d1				pop de 
2526 d5				push de 
2527 c3 fd 24			jp .fnt1 
