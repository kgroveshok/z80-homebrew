98dc			 
98dc			macro_forth_dsp_next: 
98dc				if DEBUG_FORTH_STACK_GUARD 
98dc cd 86 d2				call check_stacks 
98df				endif 
98df e5				push hl 
98e0 d5				push de 
98e1 eb				ex de,hl 
98e2 2a d2 e9			ld hl,(cli_data_sp) 
98e5 23				inc hl 
98e6 23				inc hl 
98e7			 
98e7			; PARSEV5 
98e7 23				inc hl 
98e8 22 d2 e9			ld (cli_data_sp),hl 
98eb 73				ld (hl), e 
98ec 23				inc hl 
98ed 72				ld (hl), d 
98ee d1				pop de 
98ef e1				pop hl 
98f0				if DEBUG_FORTH_STACK_GUARD 
98f0 cd 86 d2				call check_stacks 
98f3				endif 
98f3 c9				ret 
