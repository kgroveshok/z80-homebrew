716e			 
716e			chk_stk_init: 
716e				; a vague random number to check so we dont get any "lucky" hits 
716e 3e 2d			ld a, 45 
7170 6f				ld l, a 
7171 00				nop 
7172 3e 17			ld a, 23 
7174 67				ld h, a 
7175			 
7175 22 cb f0			ld (chk_word), hl     ; the word we need to check against 
7178			 
7178			;	ld (chk_stund), hl	; stack points.... 
7178 22 3b fe			ld (chk_stovr), hl 
717b 22 1a f9			ld (chk_ret_und), hl 
717e 22 d8 f8			ld (chk_ret_ovr), hl 
7181 22 56 f8			ld (chk_loop_ovr), hl 
7184 22 54 f6			ld (chk_data_ovr), hl 
7187 c9				ret 
