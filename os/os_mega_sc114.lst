98dc			 
98dc			 
98dc			FORTH_CHK_DSP_UNDER: macro 
98dc				push hl 
98dc				push de 
98dc				ld hl,(cli_data_sp) 
98dc				ld de, cli_data_stack 
98dc				call cmp16 
98dc				jp c, fault_dsp_under 
98dc				pop de 
98dc				pop hl 
98dc				endm 
98dc			 
98dc			 
98dc			FORTH_CHK_RSP_UNDER: macro 
98dc				push hl 
98dc				push de 
98dc				ld hl,(cli_ret_sp) 
98dc				ld de, cli_ret_stack 
98dc				call cmp16 
98dc				jp c, fault_rsp_under 
98dc				pop de 
98dc				pop hl 
98dc				endm 
98dc			 
98dc			FORTH_CHK_LOOP_UNDER: macro 
98dc				push hl 
98dc				push de 
98dc				ld hl,(cli_loop_sp) 
98dc				ld de, cli_loop_stack 
98dc				call cmp16 
98dc				jp c, fault_loop_under 
98dc				pop de 
98dc				pop hl 
98dc				endm 
98dc			 
98dc			FORTH_ERR_TOS_NOTSTR: macro 
98dc				; TOSO might need more for checks when used 
98dc				push af 
98dc				ld a,(hl) 
98dc				cp DS_TYPE_STR 
98dc				jp nz, type_faultn   
98dc				pop af 
98dc				endm 
98dc			 
98dc			FORTH_ERR_TOS_NOTNUM: macro 
98dc				push af 
98dc				ld a,(hl) 
98dc				cp DS_TYPE_INUM 
98dc				jp nz, type_faultn   
98dc				pop af 
98dc				endm 
