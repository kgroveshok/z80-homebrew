6972			; **********************************************************************  
6972			; **  Constants  
6972			; **********************************************************************  
6972			  
6972			; Constants that must be defined externally  
6972			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
6972			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
6972			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
6972			;kLCDWidth: EQU 20             ;Width in characters  
6972			  
6972			; general line offsets in any frame buffer  
6972			  
6972			  
6972			display_row_1: equ 0  
6972			display_row_2: equ display_row_1+display_cols  
6972			display_row_3: equ display_row_2 + display_cols  
6972			display_row_4: equ display_row_3 + display_cols  
6972			;display_row_4_eol:   
6972			  
6972			  
6972			; Cursor position values for the start of each line  
6972			  
6972			; E  
6972			kLCD_Line1: EQU 0x00   
6972			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
6972			; E1  
6972			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
6972			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
6972			  
6972			; Instructions to send as A register to fLCD_Inst  
6972			kLCD_Clear: EQU 00000001b     ;LCD clear  
6972			kLCD_Off:   EQU 00001000b     ;LCD off  
6972			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
6972			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
6972			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
6972			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
6972			  
6972			; Constants used by this code module  
6972			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
6972			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
6972			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
6972			  
