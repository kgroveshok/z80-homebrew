96a0				endif 
96a0 e5				push hl 
96a1 d5				push de 
96a2 eb				ex de,hl 
96a3 2a e5 e9			ld hl,(cli_ret_sp) 
96a6 23				inc hl 
96a7 23				inc hl 
96a8 22 e5 e9			ld (cli_ret_sp),hl 
96ab 73				ld (hl), e 
96ac 23				inc hl 
96ad 72				ld (hl), d 
96ae d1				pop de 
96af e1				pop hl 
96b0				if DEBUG_FORTH_STACK_GUARD 
96b0 cd 9b cb				call check_stacks 
96b3				endif 
96b3 c9				ret 
