0df5			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0df5			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
0df5			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
0df5			tohex: 
0df5 e5					PUSH HL 
0df6 d5					PUSH DE 
0df7 16 00				LD D, 0 
0df9 5f					LD E, A 
0dfa 21 02 0e				LD HL, .DATA 
0dfd 19					ADD HL, DE 
0dfe 7e					LD A, (HL) 
0dff d1					POP DE 
0e00 e1					POP HL 
0e01 c9					RET 
0e02			 
0e02			.DATA: 
0e02 30					DEFB	30h	; 0 
0e03 31					DEFB	31h	; 1 
0e04 32					DEFB	32h	; 2 
0e05 33					DEFB	33h	; 3 
0e06 34					DEFB	34h	; 4 
0e07 35					DEFB	35h	; 5 
0e08 36					DEFB	36h	; 6 
0e09 37					DEFB	37h	; 7 
0e0a 38					DEFB	38h	; 8 
0e0b 39					DEFB	39h	; 9 
0e0c 41					DEFB	41h	; A 
0e0d 42					DEFB	42h	; B 
0e0e 43					DEFB	43h	; C 
0e0f 44					DEFB	44h	; D 
0e10 45					DEFB	45h	; E 
0e11 46					DEFB	46h	; F 
0e12			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0e12			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
0e12			;;    subtract $30, if result > 9 then subtract $7 more 
0e12			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
0e12			atohex: 
0e12 d6 30				SUB $30 
0e14 fe 0a				CP 10 
0e16 f8					RET M		; If result negative it was 0-9 so we're done 
0e17 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
0e19 c9					RET		 
