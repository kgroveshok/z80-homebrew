920e			 
920e			.diritem:	 
920e				push bc 
920e				; for each of the current ids do a search for them and if found push to stack 
920e			 
920e					ld hl, STORE_BLOCK_PHY 
920e					ld d, 0		 ; look for extent 0 of block id as this contains file name 
920e					ld e,b 
920e			 
920e					call storage_findnextid 
920e			 
920e			 
920e					; if found hl will be non zero 
920e			 
920e					call ishlzero 
920e					jr z, .dirnotfound 
920e			 
920e					; increase count 
920e			 
920e					pop bc	 
920e					inc c 
920e					push bc 
920e					 
920e			 
920e					; get file header and push the file name 
920e			 
920e					ld de, store_page 
920e					call storage_read_block 
920e			 
920e					; push file id to stack 
920e				 
920e					ld a, (store_page) 
920e					ld h, 0 
920e					ld l, a 
920e			 
920e					;call forth_push_numhl 
920e					; TODO store id 
920e			 
920e					push hl 
920e			 
920e					; push extent count to stack  
920e				 
920e					ld hl, store_page+3 
920e			 
920e					; get file name length 
920e			 
920e					call strlenz   
920e			 
920e					inc hl   ; cover zero term 
920e					inc hl  ; stick the id at the end of the area 
920e			 
920e					push hl 
920e					pop bc    ; move length to bc 
920e			 
920e					call malloc 
920e			 
920e					; TODO save malloc area to scratch 
920e			 
920e					ex de, hl 
920e					ld hl, (store_tmp2) 
920e					ld (hl), e 
920e					inc hl 
920e					ld (hl), d 
920e					inc hl 
920e					ld (store_tmp2), hl 
920e			 
920e					 
920e			 
920e					;pop hl   ; get source 
920e			;		ex de, hl    ; swap aronund	 
920e			 
920e					ld hl, store_page+3 
920e					if DEBUG_FORTH_WORDS 
920e						DMARK "CFd" 
920e						CALLMONITOR 
920e					endif 
920e					ldir 
920e			 
920e					; de is past string, move back one and store id 
920e					 
920e					dec de 
920e			 
920e					; store file id 
920e			 
920e					pop hl 
920e					ex de,hl 
920e					ld (hl), e 
920e			 
920e					if DEBUG_FORTH_WORDS 
920e						DMARK "Cdi" 
920e						CALLMONITOR 
920e					endif 
920e					 
920e			.dirnotfound: 
920e					pop bc     
920e					djnz .diritem 
920e				 
