69cd			; **********************************************************************  
69cd			; **  Alphanumeric LCD example                  by Stephen C Cousins  **  
69cd			; **********************************************************************  
69cd			;  
69cd			; **  Written as a Small Computer Monitor App  
69cd			; **  www.scc.me.uk  
69cd			;  
69cd			; History  
69cd			; 2018-05-20  v0.2.0  SCC  Example for LiNC80 SBC1 only  
69cd			; 2018-06-28  v0.3.0  SCC  Added support for RC2014 and Z280RC  
69cd			; 2019-09-14  v0.4.0  SCC  Added support for SC129 digital I/O module  
69cd			;  
69cd			; **********************************************************************  
69cd			;  
69cd			; This program is an example of one of the methods of interfacing an   
69cd			; alphanumeric LCD module.   
69cd			;  
69cd			; In this example the display is connected to either a Z80 PIO or a   
69cd			; simple 8-bit output port.   
69cd			;  
69cd			; This interfacing method uses 4-bit data mode and uses time delays  
69cd			; rather than polling the display's ready status. As a result the   
69cd			; interface only requires 6 simple output lines:  
69cd			;   Output bit 0 = not used  
69cd			;   Output bit 1 = not used  
69cd			;   Output bit 2 = RS         High = data, Low = instruction  
69cd			;   Output bit 3 = E          Active high  
69cd			;   Output bit 4 = DB4  
69cd			;   Output bit 5 = DB5  
69cd			;   Output bit 6 = DB6  
69cd			;   Output bit 7 = DB7  
69cd			; Display's R/W is connected to 0v so it is always in write mode  
69cd			;  
69cd			; This set up should work with any system supporting the RC2014 bus  
69cd			  
69cd			; To set up PIO port A in mode 3 (control) using LiNC80 as example  
69cd			;   I/O address 0x1A = 0b11001111 (0xCF)   Select mode 3 (control)  
69cd			;   I/O address 0x1A = 0b00000000 (0x00)   All pins are output  
69cd			;  
69cd			; **********************************************************************  
69cd			  
69cd			; Additonal for 4x40. E1 and E2 instead of just E   
69cd			; TODO swipe vidout signal on port a to activate E2  
69cd			  
69cd			; **********************************************************************  
69cd			; **  Constants  
69cd			; **********************************************************************  
69cd			; LCD constants required by LCD support module  
69cd			kLCDPrt:    EQU kDataReg       ;LCD port is the PIO port A data reg  
69cd			kLCDBitRS:  EQU 2              ;Port bit for LCD RS signal  
69cd			kLCDBitE:   EQU 3              ;Port bit for LCD E signal             
69cd			kLCDBitE2:   EQU 0              ;Port bit for LCD E2 signal            VIDOUT  
69cd			kLCDBitLED:   EQU 1              ;Port bit for LCD E2 signal            VIDIN  
69cd			; TODO Decide which E is being set  
69cd			kLCDWidth:  EQU display_cols             ;Width in characters  
69cd			  
69cd			; **********************************************************************  
69cd			; **  Code library usage  
69cd			; **********************************************************************  
69cd			  
69cd			; send character to current cursor position  
69cd			; wraps and/or scrolls screen automatically  
69cd			  
69cd			  
69cd			  
69cd			lcd_init:  
69cd			  
69cd			; SCMonAPI functions used  
69cd			  
69cd			; Alphanumeric LCD functions used  
69cd			; no need to specify specific functions for this module  
69cd			  
69cd 3e cf		            LD   A, 11001111b  
69cf d3 c2		            OUT  (kContReg), A  ;Port A = PIO 'control' mode  
69d1 3e 00		            LD   A, 00000000b  
69d3 d3 c2		            OUT  (kContReg),A   ;Port A = all lines are outputs  
69d5			  
69d5			; Initialise alphanumeric LCD module  
69d5 3e 00				ld a, 0  
69d7 32 fb fa				ld (display_lcde1e2), a  
69da cd 5b 6a		            CALL fLCD_Init      ;Initialise LCD module  
69dd 3e 01				ld a, 1  
69df 32 fb fa				ld (display_lcde1e2), a  
69e2 cd 5b 6a		            CALL fLCD_Init      ;Initialise LCD module  
69e5			  
69e5 c9				ret  
69e6			  
69e6			;  
69e6			;;  
69e6			; lcd functions  
69e6			;  
69e6			;  
69e6			  
69e6			; what is at cursor position   
69e6			  
69e6			;get_cursor:	ld de, (cursor_row)   ;  row + col  
69e6			;		call curptr  
69e6			;		ret  
69e6			  
69e6			  
69e6			; take current custor pos in de (d=row,e=col) and return a pointer to the frame buffer  
69e6			  
69e6			curptr:  
69e6 c5				push bc  
69e7 21 e1 fc			ld hl, display_fb0  
69ea			cpr:	  
69ea				; loop for cursor whole row  
69ea 0e 28			ld c, display_cols  
69ec 23			cpr1:	inc hl  
69ed 0d				dec c  
69ee 20 fc			jr nz, cpr1  
69f0 05				dec b  
69f1 20 f7			jr nz, cpr  
69f3			  
69f3				; add col	  
69f3			  
69f3 23			cpr2:	inc hl  
69f4 1d				dec e  
69f5 20 fc			jr nz, cpr2  
69f7			  
69f7 c1				pop bc  
69f8 c9				ret  
69f9				  
69f9			  
69f9			  
69f9			  
69f9			  
69f9			; write the frame buffer given in hl to hardware   
69f9 22 f9 fa		write_display: ld (display_write_tmp), hl 	   
69fc 3e 00			ld a, kLCD_Line1  
69fe cd 24 6b		            CALL fLCD_Pos       ;Position cursor to location in A  
6a01 06 28			ld b, display_cols  
6a03 ed 5b f9 fa		ld de, (display_write_tmp)  
6a07 cd 53 6a			call write_len_string  
6a0a				  
