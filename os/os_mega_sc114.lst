d5af			 
d5af					if DEBUG_FORTH_WORDS 
d5af						DMARK "ASr" 
d5af						CALLMONITOR 
d5af					endif 
d5af			 
d5af					call ishlzero 
d5af					ret z             ; file not found 
d5af			 
d5af					ld a, display_row_2 + 10 
