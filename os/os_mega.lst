0ffc			; Decimal Signed Version 
0ffc			 
0ffc			; DispA 
0ffc			; -------------------------------------------------------------- 
0ffc			; Converts a signed integer value to a zero-terminated ASCII 
0ffc			; string representative of that value (using radix 10). 
0ffc			; -------------------------------------------------------------- 
0ffc			; INPUTS: 
0ffc			;     HL     Value to convert (two's complement integer). 
0ffc			;     DE     Base address of string destination. (pointer). 
0ffc			; -------------------------------------------------------------- 
0ffc			; OUTPUTS: 
0ffc			;     None 
0ffc			; -------------------------------------------------------------- 
0ffc			; REGISTERS/MEMORY DESTROYED 
0ffc			; AF HL 
0ffc			; -------------------------------------------------------------- 
0ffc			 
0ffc			;DispHLToASCII: 
0ffc			;   push    de 
0ffc			;   push    bc 
0ffc			; 
0ffc			;; Detect sign of HL. 
0ffc			;    bit    7, h 
0ffc			;    jr     z, ._DoConvert 
0ffc			; 
0ffc			;; HL is negative. Output '-' to string and negate HL. 
0ffc			;    ld     a, '-' 
0ffc			;    ld     (de), a 
0ffc			;    inc    de 
0ffc			; 
0ffc			;; Negate HL (using two's complement) 
0ffc			;    xor    a 
0ffc			;    sub    l 
0ffc			;    ld     l, a 
0ffc			;    ld     a, 0     ; Note that XOR A or SUB A would disturb CF 
0ffc			;    sbc    a, h 
0ffc			;    ld     h, a 
0ffc			; 
0ffc			;; Convert HL to digit characters 
0ffc			;._DoConvert: 
0ffc			;    ld     b, 0     ; B will count character length of number 
0ffc			;-   ld     a, 10 
0ffc			;    syscall  .DivHLByA  ; HL = HL / A, A = remainder 
0ffc			;    push   af 
0ffc			;    inc    b 
0ffc			;    ld     a, h 
0ffc			;    or     l 
0ffc			;    jr     nz, - 
0ffc			; 
0ffc			;; Retrieve digits from stack 
0ffc			;-   pop    af 
0ffc			;    or     $30 
0ffc			;    ld     (de), a 
0ffc			;    inc    de 
0ffc			;    djnz   - 
0ffc			; 
0ffc			;; Terminate string with NULL 
0ffc			;    xor    a 
0ffc			;    ld     (de), a 
0ffc			; 
0ffc			;    pop    bc 
0ffc			;    pop    de 
0ffc			;    ret 
0ffc			 
0ffc			;Comments 
0ffc			; 
0ffc			;    This routine uses the common positive-integer radix conversion algorithm of repeatedly dividing a value by the desired radix (base case: the value is zero) and saving the remainders of each division. 
0ffc			;    As this algorithm gives the digits in reverse order, they are pushed onto the hardware stack so that subsequently popping them yields the correct order. 
0ffc			;    Note that the output string will not be fixed-width. 
0ffc			; 
0ffc			;Example Usage 
0ffc			; 
0ffc			;    ld    hl, -1004 
0ffc			;    ld    de, OP1 
0ffc			;    call  DispA 
0ffc			;    ld    hl, OP1 
0ffc			;    syscall  PutS 
