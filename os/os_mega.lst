00a0			; memory allocation   
00a0			  
00a0			chk_stund: equ tos+2           ; underflow check word  
00a0			chk_stovr: equ chk_stund-stacksize -2; overflow check word  
00a0			  
00a0			; keyscan table needs rows x cols buffer  
00a0			;key_rows: equ 5     ; TODO move out to mini and maxi + 1 null  
00a0			;key_cols: equ 10    ; TODO move out to mini and maxi + 1 null  
00a0			  
00a0			key_macroroot:  equ chk_stovr - 2       ; root ptr for start of keyboard macro strings  
00a0			key_macrolast:  equ key_macroroot - 2   ; last macro defined to aid linked list ptr  
00a0			;  
00a0			; Macro linked list format  
00a0			; key code single byte   
00a0			; ptr to next or zero if last in the list  
00a0			; zero term string   
00a0			  
00a0			;keyscan_table_row1: equ chk_stovr -key_cols-1  
00a0			keyscan_table_row1: equ key_macrolast -key_cols-1  
00a0			keyscan_table_row2: equ keyscan_table_row1-key_cols-1  
00a0			keyscan_table_row3: equ keyscan_table_row2-key_cols-1  
00a0			keyscan_table_row4: equ keyscan_table_row3-key_cols-1  
00a0			keyscan_table_row5: equ keyscan_table_row4-key_cols-1  
00a0			keyscan_table: equ keyscan_table_row5-(key_cols*key_rows)-1  
00a0			keyscan_scancol: equ keyscan_table-key_cols  
00a0			;keyscan_table_len: equ key_rows*key_cols  
00a0			;keybufptr: equ keyscan_table - 2  
00a0			;keysymbol: equ keybufptr - 1  
00a0			key_held: equ keyscan_scancol-1	; currently held  
00a0			key_held_prev: equ key_held - 1   ; previously held (to detect bounce and cycle of key if required)  
00a0			key_repeat_ct: equ key_held_prev - 4 ; timers (two words)  
00a0			key_fa: equ key_repeat_ct -1 ;  
00a0			key_fb: equ key_fa -1 ;  
00a0			key_fc: equ key_fb -1 ;  
00a0			key_fd: equ key_fc -1 ;  
00a0			key_face_held: equ key_fd - 1   
00a0			; flag for enabling/disabling various hardware diag loading via block 0 on bank 1  
00a0			  
00a0			hardware_config: equ key_face_held - 10  
00a0			  
00a0			; hardware config switches  
00a0			; TODO add bitmasks on includes for hardware  
00a0			; high byte for expansion ids  
00a0			;     0000 0000  no card inserted  
00a0			;     0000 0001  storage card inserted  
00a0			;     0000 0010  spi sd card active  
00a0			;     0000 0100  LED is on, 0 if off  
00a0			;     1000 0000  NMI has been activated  
00a0			  
00a0			;       
00a0			; low byte:  
00a0			;     0000 0001   4x4 keypad  
00a0			;     0000 0010   full keyboard  
00a0			;     0000 0011   spi/ext keyboard  
00a0			;     0000 0100   20x4 lcd  
00a0			;     0000 1000   40x4 lcd  
00a0			;     0000 1100   spi/ext display  
00a0			;     0001 0000   ide interface available  
00a0			  
00a0			hardware_word: equ hardware_config - 2  
00a0			  
00a0			; debug marker - optional display of debug point on the debug screens  
00a0			  
00a0			nmi_vector:  equ hardware_word - 3   ; vector to the nmi handler  
00a0			debug_vector:  equ nmi_vector - 3   ; vector to the debug handler  
00a0			parse_vector:  equ debug_vector - 3 ; vector to the parser vector  
00a0			  
00a0			debug_umark: equ parse_vector - 6  ; current user mark  
00a0			  
