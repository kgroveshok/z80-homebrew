1016			; from z80uartmonitor 
1016			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
1016			; OUTPUT VALUE OF A IN HEX ONE NYBBLE AT A TIME 
1016			; pass hl for where to put the text 
1016			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
1016 c5			hexout:	PUSH BC 
1017 f5					PUSH AF 
1018 47					LD B, A 
1019					; Upper nybble 
1019 cb 3f				SRL A 
101b cb 3f				SRL A 
101d cb 3f				SRL A 
101f cb 3f				SRL A 
1021 cd 31 10				CALL tohex 
1024 77					ld (hl),a 
1025 23					inc hl	 
1026					 
1026					; Lower nybble 
1026 78					LD A, B 
1027 e6 0f				AND 0FH 
1029 cd 31 10				CALL tohex 
102c 77					ld (hl),a 
102d 23					inc hl	 
102e					 
102e f1					POP AF 
102f c1					POP BC 
1030 c9					RET 
1031					 
1031			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
1031			; TRANSLATE value in lower A TO 2 HEX CHAR CODES FOR DISPLAY 
1031			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;	 
1031			tohex: 
1031 e5					PUSH HL 
1032 d5					PUSH DE 
1033 16 00				LD D, 0 
1035 5f					LD E, A 
1036 21 3e 10				LD HL, .DATA 
1039 19					ADD HL, DE 
103a 7e					LD A, (HL) 
103b d1					POP DE 
103c e1					POP HL 
103d c9					RET 
103e			 
103e			.DATA: 
103e 30					DEFB	30h	; 0 
103f 31					DEFB	31h	; 1 
1040 32					DEFB	32h	; 2 
1041 33					DEFB	33h	; 3 
1042 34					DEFB	34h	; 4 
1043 35					DEFB	35h	; 5 
1044 36					DEFB	36h	; 6 
1045 37					DEFB	37h	; 7 
1046 38					DEFB	38h	; 8 
1047 39					DEFB	39h	; 9 
1048 41					DEFB	41h	; A 
1049 42					DEFB	42h	; B 
104a 43					DEFB	43h	; C 
104b 44					DEFB	44h	; D 
104c 45					DEFB	45h	; E 
104d 46					DEFB	46h	; F 
104e			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
104e			;; 	ASCII char code for 0-9,A-F in A to single hex digit 
104e			;;    subtract $30, if result > 9 then subtract $7 more 
104e			;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
104e			atohex: 
104e d6 30				SUB $30 
1050 fe 0a				CP 10 
1052 f8					RET M		; If result negative it was 0-9 so we're done 
1053 d6 07				SUB $7		; otherwise, subtract $7 more to get to $0A-$0F 
1055 c9					RET		 
1056			 
1056			 
1056			 
1056			 
1056			; Get 2 ASCII characters as hex byte from pointer in hl 
1056			 
1056			BYTERD: 
1056 16 00			LD	D,00h		;Set up 
1058 cd 60 10			CALL	HEXCON		;Get byte and convert to hex 
105b 87				ADD	A,A		;First nibble so 
105c 87				ADD	A,A		;multiply by 16 
105d 87				ADD	A,A		; 
105e 87				ADD	A,A		; 
105f 57				LD	D,A		;Save hi nibble in D 
1060			HEXCON: 
1060 7e				ld a, (hl)		;Get next chr 
1061 23				inc hl 
1062 d6 30			SUB	030h		;Makes '0'-'9' equal 0-9 
1064 fe 0a			CP	00Ah		;Is it 0-9 ? 
1066 38 02			JR	C,NALPHA	;If so miss next bit 
1068 d6 07			SUB	007h		;Else convert alpha 
106a			NALPHA: 
106a b2				OR	D		;Add hi nibble back 
106b c9				RET			; 
106c			 
106c			 
106c			; 
106c			; Get a word (16 bit) in hexadecimal notation. The result is returned in HL. 
106c			; Since the routines get_byte and therefore get_nibble are called, only valid 
106c			; characters (0-9a-f) are accepted. 
106c			; 
106c			;get_word        push    af 
106c			;                call    get_byte        ; Get the upper byte 
106c			;                ld      h, a 
106c			;                call    get_byte        ; Get the lower byte 
106c			;                ld      l, a 
106c			;                pop     af 
106c			;                ret 
106c			; 
106c			; Get a byte in hexadecimal notation. The result is returned in A. Since 
106c			; the routine get_nibble is used only valid characters are accepted - the  
106c			; input routine only accepts characters 0-9a-f. 
106c			; 
106c c5			get_byte:        push    bc              ; Save contents of B (and C) 
106d 7e					ld a,(hl) 
106e 23					inc hl 
106f cd 94 10		                call    nibble2val      ; Get upper nibble 
1072 cb 07		                rlc     a 
1074 cb 07		                rlc     a 
1076 cb 07		                rlc     a 
1078 cb 07		                rlc     a 
107a 47			                ld      b, a            ; Save upper four bits 
107b 7e					ld a,(hl) 
107c cd 94 10		                call    nibble2val      ; Get lower nibble 
107f b0			                or      b               ; Combine both nibbles 
1080 c1			                pop     bc              ; Restore B (and C) 
1081 c9			                ret 
1082			; 
1082			; Get a hexadecimal digit from the serial line. This routine blocks until 
1082			; a valid character (0-9a-f) has been entered. A valid digit will be echoed 
1082			; to the serial line interface. The lower 4 bits of A contain the value of  
1082			; that particular digit. 
1082			; 
1082			;get_nibble      ld a,(hl)           ; Read a character 
1082			;                call    to_upper        ; Convert to upper case 
1082			;                call    is_hex          ; Was it a hex digit? 
1082			;                jr      nc, get_nibble  ; No, get another character 
1082			 ;               call    nibble2val      ; Convert nibble to value 
1082			 ;               call    print_nibble 
1082			 ;               ret 
1082			; 
1082			; is_hex checks a character stored in A for being a valid hexadecimal digit. 
1082			; A valid hexadecimal digit is denoted by a set C flag. 
1082			; 
