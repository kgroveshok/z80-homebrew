118b			 
118b			;Comparing Strings 
118b			 
118b			;IN    HL     Address of string1. 
118b			;      DE     Address of string2. 
118b			 
118b			; doc given but wrong??? 
118b			;OUT   zero   Set if string1 = string2, reset if string1 != string2. 
118b			;      carry  Set if string1 > string2, reset if string1 <= string2. 
118b			; tested 
118b			;OUT   carry set  if string1 = string2, carry  reset if string1 != string2. 
118b			 
118b			strcmp_old: 
118b e5			    PUSH   HL 
118c d5			    PUSH   DE 
118d			 
118d 1a			    LD     A, (DE)          ; Compare lengths to determine smaller string 
118e be			    CP     (HL)            ; (want to minimize work). 
118f 38 01		    JR     C, Str1IsBigger 
1191 7e			    LD     A, (HL) 
1192			 
1192			Str1IsBigger: 
1192 4f			    LD     C, A             ; Put length in BC 
1193 06 00		    LD     B, 0 
1195 13			    INC    DE              ; Increment pointers to meat of string. 
1196 23			    INC    HL 
1197			 
1197			CmpLoop: 
1197 1a			    LD     A, (DE)          ; Compare bytes. 
1198 ed a1		    CPI 
119a 20 09		    JR     NZ, NoMatch      ; If (HL) != (DE), abort. 
119c 13			    INC    DE              ; Update pointer. 
119d ea 97 11		    JP     PE, CmpLoop 
11a0			 
11a0 d1			    POP    DE 
11a1 e1			    POP    HL 
11a2 1a			    LD     A, (DE)          ; Check string lengths to see if really equal. 
11a3 be			    CP     (HL) 
11a4 c9			    RET 
11a5			 
11a5			NoMatch: 
11a5 2b			    DEC    HL 
11a6 be			    CP     (HL)            ; Compare again to affect carry. 
11a7 d1			    POP    DE 
11a8 e1			    POP    HL 
11a9 c9			    RET 
