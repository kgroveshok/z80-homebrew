ca26			 
ca26					; one value on hl get other one back 
ca26			 
ca26			;		pop hl   ; u2 - addr 
ca26			 
ca26					; TODO Send SPI byte 
ca26			 
ca26			;		push hl 
ca26			;		call spi_ce_low 
ca26			;		pop hl 
ca26					ld a, l 
ca26					call spi_send_byte 
ca26			;		call spi_ce_high 
