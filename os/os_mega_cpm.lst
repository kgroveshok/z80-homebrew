523c			.SPIO: 
523c			 
523c			if STORAGE_SE 
523c				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
523c			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
523c			 
523c					call spi_ce_low 
523c			    NEXTW 
523c			 
523c			.SPICEH: 
523c				CWHEAD .SPIOb 61 "SPICEH" 6 WORD_FLAG_CODE 
523c			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
523c			 
523c					call spi_ce_high 
523c			    NEXTW 
523c			 
523c			 
523c			.SPIOb: 
523c			 
523c				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
523c			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
523c			 
523c					if DEBUG_FORTH_WORDS_KEY 
523c						DMARK "SPo" 
523c						CALLMONITOR 
523c					endif 
523c					; get port 
523c			 
523c			 
523c					; get byte to send 
523c			 
523c					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
523c			 
523c			;		push hl    ; u1  
523c			 
523c					; destroy value TOS 
523c			 
523c					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
523c			 
523c					; one value on hl get other one back 
523c			 
523c			;		pop hl   ; u2 - addr 
523c			 
523c					; TODO Send SPI byte 
523c			 
523c			;		push hl 
523c			;		call spi_ce_low 
523c			;		pop hl 
523c					ld a, l 
523c					call spi_send_byte 
523c			;		call spi_ce_high 
523c			 
523c					NEXTW 
523c			 
523c			.SPII: 
523c				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
523c			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
523c					if DEBUG_FORTH_WORDS_KEY 
523c						DMARK "SPi" 
523c						CALLMONITOR 
523c					endif 
523c			 
523c					; TODO Get SPI byte 
523c			 
523c					call spi_read_byte 
523c			 
523c					if DEBUG_FORTH_WORDS 
523c						DMARK "Si2" 
523c						CALLMONITOR 
523c					endif 
523c					ld h, 0 
523c					ld l, a 
523c					if DEBUG_FORTH_WORDS 
523c						DMARK "Si3" 
523c						CALLMONITOR 
523c					endif 
523c					call forth_push_numhl 
523c			 
523c					NEXTW 
523c			 
523c			 
523c			 
523c			.SESEL: 
523c				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
523c			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
523c			; | | Zero is disabled storage. 
523c					if DEBUG_FORTH_WORDS_KEY 
523c						DMARK "BN?" 
523c						CALLMONITOR 
523c					endif 
523c					ld a, (spi_device_id) 
523c					sub '0' 
523c					ld h, 0 
523c					ld l, a 
523c					call forth_push_numhl 
523c					NEXTW 
523c			.SESELS: 
523c				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
523c			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
523c			; | | Set to zero to disable storage. 
523c					if DEBUG_FORTH_WORDS_KEY 
523c						DMARK "BNK" 
523c						CALLMONITOR 
523c					endif 
523c			 
523c					ld a, 255 
523c					ld (spi_cartdev), a 
523c			 
523c					; get bank 
523c			 
523c					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
523c			 
523c			;		push hl 
523c			 
523c					; destroy value TOS 
523c			 
523c					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
523c			 
523c					; one value on hl get other one back 
523c			 
523c			;		pop hl 
523c			 
523c			 
523c					ld c, SPI_CE_HIGH 
523c					ld b, '0'    ; human readable bank number 
523c			 
523c					ld a, l 
523c			 
523c					if DEBUG_FORTH_WORDS 
523c						DMARK "BNK" 
523c						CALLMONITOR 
523c					endif 
523c			 
523c					; active low 
523c			 
523c			;		cp 0 
523c					or a 
523c					jr z, .bset 
523c					cp 1 
523c					jr nz, .b2 
523c					res 0, c 
523c					ld b, '1'    ; human readable bank number 
523c			.b2:		cp 2 
523c					jr nz, .b3 
523c					res 1, c 
523c					ld b, '2'    ; human readable bank number 
523c			.b3:		cp 3 
523c					jr nz, .b4 
523c					res 2, c 
523c					ld b, '3'    ; human readable bank number 
523c			.b4:		cp 4 
523c					jr nz, .b5 
523c					res 3, c 
523c					ld b, '4'    ; human readable bank number 
523c			.b5:		cp 5 
523c					jr nz, .bset 
523c					res 4, c 
523c					ld b, '5'    ; human readable bank number 
523c			 
523c			.bset: 
523c					ld a, c 
523c					ld (spi_device),a 
523c					ld a, b 
523c					ld (spi_device_id),a 
523c					if DEBUG_FORTH_WORDS 
523c						DMARK "BN2" 
523c						CALLMONITOR 
523c					endif 
523c			 
523c					; set default SPI clk pulse time as disabled for BANK use 
523c			 
523c					ld a, 0 
523c					ld (spi_clktime), a 
523c			 
523c					NEXTW 
523c			 
523c			.CARTDEV: 
523c				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
523c			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
523c			; | | Set to zero to disable devices. 
523c					if DEBUG_FORTH_WORDS_KEY 
523c						DMARK "CDV" 
523c						CALLMONITOR 
523c					endif 
523c			 
523c					; disable se storage bank selection 
523c			 
523c					ld a, SPI_CE_HIGH		; ce high 
523c					ld (spi_device), a 
523c			 
523c					; get bank 
523c			 
523c					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
523c			 
523c			;		push hl 
523c			 
523c					; destroy value TOS 
523c			 
523c					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
523c			 
523c					; one value on hl get other one back 
523c			 
523c			;		pop hl 
523c			 
523c					; active low 
523c			 
523c					ld c, 255 
523c			 
523c					ld a, l 
523c					if DEBUG_FORTH_WORDS 
523c						DMARK "CDV" 
523c						CALLMONITOR 
523c					endif 
523c			;		cp 0 
523c					or a 
523c					jr z, .cset 
523c					cp 1 
523c					jr nz, .c2 
523c					res 0, c 
523c			.c2:		cp 2 
523c					jr nz, .c3 
523c					res 1, c 
523c			.c3:		cp 3 
523c					jr nz, .c4 
523c					res 2, c 
523c			.c4:		cp 4 
523c					jr nz, .c5 
523c					res 3, c 
523c			.c5:		cp 5 
523c					jr nz, .c6 
523c					res 4, c 
523c			.c6:		cp 6 
523c					jr nz, .c7 
523c					res 5, c 
523c			.c7:		cp 7 
523c					jr nz, .c8 
523c					res 6, c 
523c			.c8:		cp 8 
523c					jr nz, .cset 
523c					res 7, c 
523c			.cset:		ld a, c 
523c					ld (spi_cartdev),a 
523c			 
523c					if DEBUG_FORTH_WORDS 
523c						DMARK "CD2" 
523c						CALLMONITOR 
523c					endif 
523c			 
523c					; set default SPI clk pulse time as 10ms for CARTDEV use 
523c			 
523c					ld a, $0a 
523c					ld (spi_clktime), a 
523c					NEXTW 
523c			endif 
523c			 
523c			.ENDDEVICE: 
523c			; eof 
