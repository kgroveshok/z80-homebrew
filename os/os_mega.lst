6712			; handle the auto run of code from files in storage 
6712			 
6712			 
6712			include "forth_startup.asm" 
6712			; Which startup method to use? 
6712			; 
6712			; version 1 - allows for a single stored file to be selected to run at start up (if se storage is enabled) 
6712			; followed by loading of a list of scripts in eeprom 
6712			 
6712			; version 2 - if se storage is enabled then auto load all files which begin with a '*' else use loading 
6712			; from eeprom 
6712			 
6712			; Select with define in main stubs 
6712			 
6712			if STARTUP_V1 
6712				include "forth_startupv1.asm" 
6712			endif 
6712			if STARTUP_V2 
6712				include "forth_startupv2.asm" 
6712			; Version 2 of the startup  
6712			;  
6712			; Auto load any files in bank 1 that start with a '*' 
6712			; If no se storage then revert to using eprom 
6712			 
6712			 
6712			if STORAGE_SE = 0 
6712			 
6712			sprompt1: db "Startup load...",0 
6712			sprompt2: db "Run? 1=No *=End #=All",0 
6712			 
6712			 
6712			 
6712			 
6712			forth_startup: 
6712				ld hl, startcmds 
6712				ld a, 0 
6712				ld (os_last_cmd), a    ; tmp var to skip prompts if doing all 
6712			 
6712			.start1:	push hl 
6712				call clear_display 
6712				ld de, sprompt1 
6712			        ld a, display_row_1 
6712				call str_at_display 
6712				ld de, sprompt2 
6712			        ld a, display_row_2 
6712				call str_at_display 
6712				pop hl 
6712				push hl 
6712				ld e,(hl) 
6712				inc hl 
6712				ld d,(hl) 
6712			        ld a, display_row_3 
6712				call str_at_display 
6712				call update_display 
6712			 
6712			 
6712				ld a, (os_last_cmd) 
6712			;	cp 0 
6712				or a 
6712				jr z, .startprompt 
6712				call delay250ms 
6712				jr .startdo 
6712				 
6712				 
6712			 
6712			.startprompt: 
6712			 
6712				ld a,display_row_4 + display_cols - 1 
6712			        ld de, endprg 
6712				call str_at_display 
6712				call update_display 
6712				call delay1s 
6712				call cin_wait 
6712						 
6712				cp '*' 
6712				jr z, .startupend1 
6712				cp '#' 
6712				jr nz, .startno 
6712				ld a, 1 
6712				ld (os_last_cmd),a 
6712				jr .startdo 
6712			.startno:	cp '1' 
6712				jr z,.startnxt  
6712			 
6712				; exec startup line 
6712			.startdo:	 
6712				pop hl 
6712				push hl 
6712				 
6712				ld e,(hl) 
6712				inc hl 
6712				ld d,(hl) 
6712				ex de,hl 
6712			 
6712				push hl 
6712			 
6712				ld a, 0 
6712				;ld a, FORTH_END_BUFFER 
6712				call strlent 
6712				inc hl   ; include zero term to copy 
6712				ld b,0 
6712				ld c,l 
6712				pop hl 
6712				ld de, scratch 
6712				ldir 
6712			 
6712			 
6712				ld hl, scratch 
6712				call forthparse 
6712				call forthexec 
6712				call forthexec_cleanup 
6712			 
6712				ld a, display_row_4 
6712				ld de, endprog 
6712			 
6712				call update_display		 
6712			 
6712				ld a, (os_last_cmd) 
6712			;	cp 0 
6712				or a 
6712				jr nz, .startnxt 
6712				call next_page_prompt 
6712			        call clear_display 
6712				call update_display		 
6712			 
6712				; move onto next startup line? 
6712			.startnxt: 
6712			 
6712				call delay250ms 
6712				pop hl 
6712			 
6712				inc hl 
6712				inc hl 
6712			 
6712				push hl 
6712				ld e, (hl) 
6712				inc hl 
6712				ld d, (hl) 
6712				pop hl 
6712				; TODO replace 0 test 
6712			 
6712				ex de, hl 
6712				call ishlzero 
6712			;	ld a,e 
6712			;	add d 
6712			;	cp 0    ; any left to do? 
6712				ex de, hl 
6712				jp nz, .start1 
6712				jr .startupend 
6712			 
6712			.startupend1: pop hl 
6712			.startupend: 
6712			 
6712				call clear_display 
6712				call update_display 
6712				ret 
6712			endif 
