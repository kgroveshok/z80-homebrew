0f90			StrictStrCmp: 
0f90				; Load next chars of each string 
0f90 1a				ld a, (de) 
0f91 47				ld b, a 
0f92 7e				ld a, (hl) 
0f93				; Compare 
0f93 b8				cp b 
0f94				; Return non-zero if chars don't match 
0f94 c0				ret nz 
0f95				; Check for end of both strings 
0f95 fe 00			cp "\0" 
0f97				; Return if strings have ended 
0f97 c8				ret z 
0f98				; Otherwise, advance to next chars 
0f98 23				inc hl 
0f99 13				inc de 
0f9a 18 f4			jr StrictStrCmp 
0f9c			 
0f9c			;end 
0f9c			; eof 
