a414					ld a, (.dmark+1)  
a414					ld (debug_mark+1),a  
a414					ld a, (.dmark+2)  
a414					ld (debug_mark+2),a  
a414				endif  
a414 18 04			jr .pastdmark  
a416 ..			.dmark: db "MON"  
a419				if DEMARK_VERSION = 1  
a419 00					db 0  
a41a				endif  
a41a				if DEMARK_VERSION = 1  
a41a e1			.pastdmark: pop hl  
a41b				endif  
