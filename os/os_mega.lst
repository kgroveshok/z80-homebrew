00ca cd 6b 0a			call delay1s  
00cd 3e 2b			ld a,'+'  
00cf cd 31 0b			call fill_display  
00d2 cd 4e 0b			call update_display  
00d5 cd 6b 0a			call delay1s  
00d8 3e 2a			ld a,'*'  
00da cd 31 0b			call fill_display  
00dd cd 4e 0b			call update_display  
00e0 cd 6b 0a			call delay1s  
00e3 3e 2d			ld a,'-'  
00e5 cd 31 0b			call fill_display  
00e8 cd 4e 0b			call update_display  
00eb cd 6b 0a			call delay1s  
