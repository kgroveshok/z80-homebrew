104e			 
104e			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
104e			 
104e			 
104e			;Converts an ASCII string to an unsigned 16-bit integer 
104e			;Quits when it reaches a non-decimal digit 
104e			 
104e			string_to_uint16: 
104e			atoui_16: 
104e			;Input: 
104e			;     DE points to the string 
104e			;Outputs: 
104e			;     HL is the result 
104e			;     A is the 8-bit value of the number 
104e			;     DE points to the byte after the number 
104e			;Destroys: 
104e			;     BC 
104e			;       if the string is non-empty, BC is HL/10 
104e			;Size:  24 bytes 
104e			;Speed: 42+d(104+{0,9}) 
104e			;       d is the number of digits in the number 
104e			;       max is 640 cycles for a 5 digit number 
104e			;Assuming no leading zeros: 
104e			;1 digit:  146cc 
104e			;2 digit:  250cc 
104e			;3 digit:  354cc or 363cc (avg: 354.126cc) 
104e			;4 digit:  458cc or 467cc (avg: 458.27cc) 
104e			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
104e			;avg: 544.81158447265625cc (544+13297/16384) 
104e			;=============================================================== 
104e 21 00 00		  ld hl,0 
1051			.u16a: 
1051 1a			  ld a,(de) 
1052 d6 30		  sub 30h 
1054 fe 0a		  cp 10 
1056 d0			  ret nc 
1057 13			  inc de 
1058 44			  ld b,h 
1059 4d			  ld c,l 
105a 29			  add hl,hl 
105b 29			  add hl,hl 
105c 09			  add hl,bc 
105d 29			  add hl,hl 
105e 85			  add a,l 
105f 6f			  ld l,a 
1060 30 ef		  jr nc,.u16a 
1062 24			  inc h 
1063 c3 51 10		  jp .u16a 
1066			 
1066			 
1066			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/string_to_uint16.z80 
1066			 
1066			;written by Zeda 
1066			;Converts a 16-bit unsigned integer to an ASCII string. 
1066			 
1066			uitoa_16: 
1066			;Input: 
1066			;   DE is the number to convert 
1066			;   HL points to where to write the ASCII string (up to 6 bytes needed). 
1066			;Output: 
1066			;   HL points to the null-terminated ASCII string 
1066			;      NOTE: This isn't necessarily the same as the input HL. 
1066 d5			  push de 
1067 c5			  push bc 
1068 f5			  push af 
1069 eb			  ex de,hl 
106a			 
106a 01 f0 d8		  ld bc,-10000 
106d 3e 2f		  ld a,'0'-1 
106f 3c			  inc a 
1070 09			  add hl,bc  
1071 38 fc		   jr c,$-2 
1073 12			  ld (de),a 
1074 13			  inc de 
1075			 
1075 01 e8 03		  ld bc,1000 
1078 3e 3a		  ld a,'9'+1 
107a 3d			  dec a  
107b 09			  add hl,bc  
107c 30 fc		   jr nc,$-2 
107e 12			  ld (de),a 
107f 13			  inc de 
1080			 
1080 01 9c ff		  ld bc,-100 
1083 3e 2f		  ld a,'0'-1 
1085 3c			  inc a  
1086 09			  add hl,bc  
1087 38 fc		   jr c,$-2 
1089 12			  ld (de),a 
108a 13			  inc de 
108b			 
108b 7d			  ld a,l 
108c 26 3a		  ld h,'9'+1 
108e 25			  dec h  
108f c6 0a		  add a,10  
1091 30 fb		   jr nc,$-3 
1093 c6 30		  add a,'0' 
1095 eb			  ex de,hl 
1096 72			  ld (hl),d 
1097 23			  inc hl 
1098 77			  ld (hl),a 
1099 23			  inc hl 
109a 36 00		  ld (hl),0 
109c			 
109c			;Now strip the leading zeros 
109c 0e fa		  ld c,-6 
109e 09			  add hl,bc 
109f 3e 30		  ld a,'0' 
10a1 23			  inc hl  
10a2 be			  cp (hl)  
10a3 28 fc		  jr z,$-2 
10a5			 
10a5			;Make sure that the string is non-empty! 
10a5 7e			  ld a,(hl) 
10a6 b7			  or a 
10a7 20 01		  jr nz,.atoub 
10a9 2b			  dec hl 
10aa			.atoub: 
10aa			 
10aa f1			  pop af 
10ab c1			  pop bc 
10ac d1			  pop de 
10ad c9			  ret 
10ae			 
10ae			; from https://github.com/Zeda/Z80-Optimized-Routines/blob/master/conversion/toUpper.z80 
10ae			 
10ae			toUpper: 
10ae			;A is the char. 
10ae			;If A is a lowercase letter, this sets it to the matching uppercase 
10ae			;18cc or 30cc or 41cc 
10ae			;avg: 26.75cc 
10ae fe 61		  cp 'a' 
10b0 d8			  ret c 
10b1 fe 7b		  cp 'z'+1 
10b3 d0			  ret nc 
10b4 d6 20		  sub 'a'-'A' 
10b6 c9			  ret 
