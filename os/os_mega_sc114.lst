8f62			 
8f62			;Converts an ASCII string to an unsigned 16-bit integer 
8f62			;Quits when it reaches a non-decimal digit 
8f62			 
8f62			string_to_uint16: 
8f62			atoui_16: 
8f62			;Input: 
8f62			;     DE points to the string 
8f62			;Outputs: 
8f62			;     HL is the result 
8f62			;     A is the 8-bit value of the number 
8f62			;     DE points to the byte after the number 
8f62			;Destroys: 
8f62			;     BC 
8f62			;       if the string is non-empty, BC is HL/10 
8f62			;Size:  24 bytes 
8f62			;Speed: 42+d(104+{0,9}) 
8f62			;       d is the number of digits in the number 
8f62			;       max is 640 cycles for a 5 digit number 
8f62			;Assuming no leading zeros: 
8f62			;1 digit:  146cc 
8f62			;2 digit:  250cc 
8f62			;3 digit:  354cc or 363cc (avg: 354.126cc) 
8f62			;4 digit:  458cc or 467cc (avg: 458.27cc) 
8f62			;5 digit:  562cc or 571cc or 580cc (avg: 562.4104cc) 
8f62			;avg: 544.81158447265625cc (544+13297/16384) 
8f62			;=============================================================== 
8f62 21 00 00		  ld hl,0 
8f65			.u16a: 
8f65 1a			  ld a,(de) 
8f66 d6 30		  sub 30h 
8f68 fe 0a		  cp 10 
8f6a d0			  ret nc 
8f6b 13			  inc de 
8f6c 44			  ld b,h 
8f6d 4d			  ld c,l 
8f6e 29			  add hl,hl 
8f6f 29			  add hl,hl 
8f70 09			  add hl,bc 
8f71 29			  add hl,hl 
8f72 85			  add a,l 
8f73 6f			  ld l,a 
8f74 30 ef		  jr nc,.u16a 
8f76 24			  inc h 
8f77 c3 65 8f		  jp .u16a 
