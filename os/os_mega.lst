75ca 11 28 00			ld de, display_cols  
75cd 19				add hl,de  
75ce 22 f7 fa			ld (display_write_tmp),hl  
75d1			  
75d1				  
75d1 3e 50			ld a, kLCD_Line3  
75d3 cd ad 76		            CALL fLCD_Pos       ;Position cursor to location in A  
75d6 06 28			ld b, display_cols  
75d8 ed 5b f7 fa		ld de, (display_write_tmp)  
75dc cd f8 75			call write_len_string  
75df				  
75df 2a f7 fa			ld hl, (display_write_tmp)  
75e2 11 28 00			ld de, display_cols  
75e5 19				add hl,de  
75e6 22 f7 fa			ld (display_write_tmp),hl  
75e9			  
75e9				  
75e9 3e 78			ld a, kLCD_Line4  
75eb cd ad 76		            CALL fLCD_Pos       ;Position cursor to location in A  
75ee 06 28			ld b, display_cols  
75f0 ed 5b f7 fa		ld de, (display_write_tmp)  
75f4 cd f8 75			call write_len_string  
75f7 c9					ret  
