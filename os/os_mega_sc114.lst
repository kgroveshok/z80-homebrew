892d			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
892d			; random number generators 
892d			 
892d			 
892d			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
892d			 
892d			 
892d			;-----> Generate a random number 
892d			; output a=answer 0<=a<=255 
892d			; all registers are preserved except: af 
892d			random: 
892d e5			        push    hl 
892e d5			        push    de 
892f 2a a0 eb		        ld      hl,(randData) 
8932 ed 5f		        ld      a,r 
8934 57			        ld      d,a 
8935 5e			        ld      e,(hl) 
8936 19			        add     hl,de 
8937 85			        add     a,l 
8938 ac			        xor     h 
8939 22 a0 eb		        ld      (randData),hl 
893c d1			        pop     de 
893d e1			        pop     hl 
893e c9			        ret 
893f			 
893f			 
893f			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
893f			 
893f			 
893f			 
893f			;------LFSR------ 
893f			;James Montelongo 
893f			;optimized by Spencer Putt 
893f			;out: 
893f			; a = 8 bit random number 
893f			RandLFSR: 
893f 21 a6 eb		        ld hl,LFSRSeed+4 
8942 5e			        ld e,(hl) 
8943 23			        inc hl 
8944 56			        ld d,(hl) 
8945 23			        inc hl 
8946 4e			        ld c,(hl) 
8947 23			        inc hl 
8948 7e			        ld a,(hl) 
8949 47			        ld b,a 
894a cb 13		        rl e  
894c cb 12			rl d 
894e cb 11		        rl c  
8950 17				rla 
8951 cb 13		        rl e  
8953 cb 12			rl d 
8955 cb 11		        rl c  
8957 17				rla 
8958 cb 13		        rl e  
895a cb 12			rl d 
895c cb 11		        rl c  
895e 17				rla 
895f 67			        ld h,a 
8960 cb 13		        rl e  
8962 cb 12			rl d 
8964 cb 11		        rl c  
8966 17				rla 
8967 a8			        xor b 
8968 cb 13		        rl e  
896a cb 12			rl d 
896c ac			        xor h 
896d a9			        xor c 
896e aa			        xor d 
896f 21 a8 eb		        ld hl,LFSRSeed+6 
8972 11 a9 eb		        ld de,LFSRSeed+7 
8975 01 07 00		        ld bc,7 
8978 ed b8		        lddr 
897a 12			        ld (de),a 
897b c9			        ret 
897c			 
897c			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
897c			 
897c			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
897c			 
897c			 
897c			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
897c			 
897c			prng16: 
897c			;Inputs: 
897c			;   (seed1) contains a 16-bit seed value 
897c			;   (seed2) contains a NON-ZERO 16-bit seed value 
897c			;Outputs: 
897c			;   HL is the result 
897c			;   BC is the result of the LCG, so not that great of quality 
897c			;   DE is preserved 
897c			;Destroys: 
897c			;   AF 
897c			;cycle: 4,294,901,760 (almost 4.3 billion) 
897c			;160cc 
897c			;26 bytes 
897c 2a 9a eb		    ld hl,(seed1) 
897f 44			    ld b,h 
8980 4d			    ld c,l 
8981 29			    add hl,hl 
8982 29			    add hl,hl 
8983 2c			    inc l 
8984 09			    add hl,bc 
8985 22 9a eb		    ld (seed1),hl 
8988 2a 98 eb		    ld hl,(seed2) 
898b 29			    add hl,hl 
898c 9f			    sbc a,a 
898d e6 2d		    and %00101101 
898f ad			    xor l 
8990 6f			    ld l,a 
8991 22 98 eb		    ld (seed2),hl 
8994 09			    add hl,bc 
8995 c9			    ret 
8996			 
8996			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
8996			 
8996			rand32: 
8996			;Inputs: 
8996			;   (seed1_0) holds the lower 16 bits of the first seed 
8996			;   (seed1_1) holds the upper 16 bits of the first seed 
8996			;   (seed2_0) holds the lower 16 bits of the second seed 
8996			;   (seed2_1) holds the upper 16 bits of the second seed 
8996			;   **NOTE: seed2 must be non-zero 
8996			;Outputs: 
8996			;   HL is the result 
8996			;   BC,DE can be used as lower quality values, but are not independent of HL. 
8996			;Destroys: 
8996			;   AF 
8996			;Tested and passes all CAcert tests 
8996			;Uses a very simple 32-bit LCG and 32-bit LFSR 
8996			;it has a period of 18,446,744,069,414,584,320 
8996			;roughly 18.4 quintillion. 
8996			;LFSR taps: 0,2,6,7  = 11000101 
8996			;291cc 
8996			;seed1_0=$+1 
8996			;    ld hl,12345 
8996			;seed1_1=$+1 
8996			;    ld de,6789 
8996			;    ld b,h 
8996			;    ld c,l 
8996			;    add hl,hl \ rl e \ rl d 
8996			;    add hl,hl \ rl e \ rl d 
8996			;    inc l 
8996			;    add hl,bc 
8996			;    ld (seed1_0),hl 
8996			;    ld hl,(seed1_1) 
8996			;    adc hl,de 
8996			;    ld (seed1_1),hl 
8996			;    ex de,hl 
8996			;seed2_0=$+1 
8996			;    ld hl,9876 
8996			;seed2_1=$+1 
8996			;    ld bc,54321 
8996			;    add hl,hl \ rl c \ rl b 
8996			;    ld (seed2_1),bc 
8996			;    sbc a,a 
8996			;    and %11000101 
8996			;    xor l 
8996			;    ld l,a 
8996			;    ld (seed2_0),hl 
8996			;    ex de,hl 
8996			;    add hl,bc 
8996			;    ret 
8996			; 
8996			 
8996			; 16-bit xorshift pseudorandom number generator by John Metcalf 
8996			; 20 bytes, 86 cycles (excluding ret) 
8996			 
8996			; returns   hl = pseudorandom number 
8996			; corrupts   a 
8996			 
8996			; generates 16-bit pseudorandom numbers with a period of 65535 
8996			; using the xorshift method: 
8996			 
8996			; hl ^= hl << 7 
8996			; hl ^= hl >> 9 
8996			; hl ^= hl << 8 
8996			 
8996			; some alternative shift triplets which also perform well are: 
8996			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
8996			 
8996			;  org 32768 
8996			 
8996			xrnd: 
8996 2a 9e eb		  ld hl,(xrandc)       ; seed must not be 0 
8999 3e 00		  ld a,0 
899b bd			  cp l 
899c 20 02		  jr nz, .xrnd1 
899e 2e 01		  ld l, 1 
89a0			.xrnd1: 
89a0			 
89a0 7c			  ld a,h 
89a1 1f			  rra 
89a2 7d			  ld a,l 
89a3 1f			  rra 
89a4 ac			  xor h 
89a5 67			  ld h,a 
89a6 7d			  ld a,l 
89a7 1f			  rra 
89a8 7c			  ld a,h 
89a9 1f			  rra 
89aa ad			  xor l 
89ab 6f			  ld l,a 
89ac ac			  xor h 
89ad 67			  ld h,a 
89ae			 
89ae 22 9e eb		  ld (xrandc),hl 
89b1			 
89b1 c9			  ret 
