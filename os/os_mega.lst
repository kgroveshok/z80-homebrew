69c9			; **********************************************************************  
69c9			; **  Alphanumeric LCD support                  by Stephen C Cousins  **  
69c9			; **********************************************************************  
69c9			;  
69c9			; **  Written as a Small Computer Monitor App   
69c9			; **  Version 0.1 SCC 2018-05-16  
69c9			; **  www.scc.me.uk  
69c9			;  
69c9			; **********************************************************************  
69c9			;  
69c9			; This module provides support for alphanumeric LCD modules using with  
69c9			; *  HD44780 (or compatible) controller  
69c9			; *  5 x 7 pixel fonts  
69c9			; *  Up to 80 characters in total (eg. 4 lines of 20 characters)  
69c9			; *  Interface via six digital outputs to the display (see below)  
69c9			;  
69c9			; LCD module pinout:  
69c9			;   1  Vss   0v supply  
69c9			;   2  Vdd   5v supply  
69c9			;   3  Vo    LCD input voltage (near zero volts via potentiometer)  
69c9			;   4  RS    High = data, Low = instruction  
69c9			;   5  R/W   High = Read, Low = Write  
69c9			;   6  E     Enable signal (active high)  
69c9			;   7  DB0   Data bit 0  
69c9			;   8  DB1   Data bit 1  
69c9			;   9  DB2   Data bit 2  
69c9			;  10  DB3   Data bit 3  
69c9			;  11  DB4   Data bit 4  
69c9			;  12  DB5   Data bit 5  
69c9			;  13  DB6   Data bit 6  
69c9			;  14  DB7   Data bit 7  
69c9			;  15  A     Backlight anode (+)  
69c9			;  16  K     Backlight cathode (-)  
69c9			;  
69c9			; This interfacing method uses 4-bit data mode and uses time delays  
69c9			; rather than polling the display's ready status. As a result the   
69c9			; interface only requires 6 simple output lines:  
69c9			;   LCD E   = Microcomputer output port bit <kLCDBitE>  
69c9			;   LCD RS  = Microcomputer output port bit <kLCDBitRS>  
69c9			;   LCD DB4 = Microcomputer output port bit 4  
69c9			;   LCD DB5 = Microcomputer output port bit 5  
69c9			;   LCD DB6 = Microcomputer output port bit 6  
69c9			;   LCD DB7 = Microcomputer output port bit 7  
69c9			; Display's R/W is connected to 0v so it is always in write mode  
69c9			; All 6 connections must be on the same port address <kLCDPrt>  
69c9			; This method also allows a decent length of cable from micro to LCD  
69c9			;  
69c9			; **********************************************************************  
69c9			;  
69c9			; To include the code for any given function provided by this module,   
69c9			; add the appropriate #REQUIRES <FunctionName> statement at the top of   
69c9			; the parent source file.  
69c9			; For example:  #REQUIRES   uHexPrefix  
69c9			;  
69c9			; Also #INCLUDE this file at some point after the #REQUIRES statements  
69c9			; in the parent source file.  
69c9			; For example:  #INCLUDE    ..\_CodeLibrary\Utilities.asm  
69c9			;  
69c9			; These are the function names provided by this module:  
69c9			; fLCD_Init                     ;Initialise LCD  
69c9			; fLCD_Inst                     ;Send instruction to LCD  
69c9			; fLCD_Data                     ;Send data byte to LCD  
69c9			; fLCD_Pos                      ;Position cursor  
69c9			; fLCD_Str                      ;Display string  
69c9			; fLCD_Def                      ;Define custom character  
69c9			;  
69c9			; **********************************************************************  
69c9			;  
69c9			; Requires SCMonAPI.asm to also be included in the project  
69c9			;  
69c9			  
69c9			  
69c9			; **********************************************************************  
69c9			; **  Constants  
69c9			; **********************************************************************  
69c9			  
69c9			; Constants that must be defined externally  
69c9			;kLCDPrt:   EQU 0xc0           ;Port address used for LCD  
69c9			;kLCDBitRS: EQU 2              ;Port bit for LCD RS signal  
69c9			;kLCDBitE:  EQU 3              ;Port bit for LCD E signal  
69c9			;kLCDWidth: EQU 20             ;Width in characters  
69c9			  
69c9			; general line offsets in any frame buffer  
69c9			  
69c9			  
69c9			display_row_1: equ 0  
69c9			display_row_2: equ display_row_1+display_cols  
69c9			display_row_3: equ display_row_2 + display_cols  
69c9			display_row_4: equ display_row_3 + display_cols  
69c9			;display_row_4_eol:   
69c9			  
69c9			  
69c9			; Cursor position values for the start of each line  
69c9			  
69c9			; E  
69c9			kLCD_Line1: EQU 0x00   
69c9			kLCD_Line2: EQU kLCD_Line1+kLCDWidth  
69c9			; E1  
69c9			kLCD_Line3: EQU kLCD_Line2+kLCDWidth  
69c9			kLCD_Line4: EQU kLCD_Line3+kLCDWidth   
69c9			  
69c9			; Instructions to send as A register to fLCD_Inst  
69c9			kLCD_Clear: EQU 00000001b     ;LCD clear  
69c9			kLCD_Off:   EQU 00001000b     ;LCD off  
69c9			kLCD_On:    EQU 00001100b     ;LCD on, no cursor or blink  
69c9			kLCD_Under: EQU 00001110b     ;LCD on, cursor = underscore  
69c9			kLCD_Blink: EQU 00001101b     ;LCD on, cursor = blink block  
69c9			kLCD_Both:  EQU 00001111b     ;LCD on, cursor = under+blink  
69c9			  
69c9			; Constants used by this code module  
69c9			kLCD_Clr:   EQU 00000001b     ;LCD command: Clear display  
69c9			kLCD_Pos:   EQU 10000000b     ;LCD command: Position cursor  
69c9			kLCD_Def:   EQU 01000000b     ;LCD command: Define character  
69c9			  
69c9			  
69c9			  
69c9			; **********************************************************************  
69c9			; **  LCD support functions  
69c9			; **********************************************************************  
69c9			  
69c9			; Initialise alphanumeric LCD module  
69c9			; LCD control register codes:  
69c9			;   DL   0 = 4-bit mode        1 = 8-bit mode  
69c9			;   N    0 = 1-line mode       1 = 2-line mode  
69c9			;   F    0 = Font 5 x 8        1 = Font 5 x 11  
69c9			;   D    0 = Display off       1 = Display on  
69c9			;   C    0 = Cursor off        1 = Cursor on  
69c9			;   B    0 = Blinking off      1 = Blinking on  
69c9			;   ID   0 = Decrement mode    1 = Increment mode  
69c9			;   SH   0 = Entire shift off  1 = Entire shift on  
69c9 3e 28		fLCD_Init:  LD   A, 40  
69cb cd 0c 6b		            CALL LCDDelay       ;Delay 40ms after power up  
69ce			; For reliable reset set 8-bit mode - 3 times  
69ce cd dc 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69d1 cd dc 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69d4 cd dc 6a		            CALL WrFn8bit       ;Function = 8-bit mode  
69d7			; Set 4-bit mode  
69d7 cd d8 6a		            CALL WrFn4bit       ;Function = 4-bit mode  
69da cd 0a 6b		            CALL LCDDelay1      ;Delay 37 us or more  
69dd			; Function set  
69dd 3e 28		            LD   A, 00101000b  ;Control reg:  0  0  1  DL N  F  x  x  
69df cd 02 6a		            CALL fLCD_Inst      ;2 line, display on  
69e2			; Display On/Off control  
69e2 3e 0c		            LD   A, 00001100b  ;Control reg:  0  0  0  0  1  D  C  B   
69e4 cd 02 6a		            CALL fLCD_Inst      ;Display on, cursor on, blink off  
69e7			; Display Clear  
69e7 3e 01		            LD   A, 00000001b  ;Control reg:  0  0  0  0  0  0  0  1  
69e9 cd 02 6a		            CALL fLCD_Inst      ;Clear display  
69ec			; Entry mode  
69ec 3e 06		            LD   A, 00000110b  ;Control reg:  0  0  0  0  0  1  ID SH  
69ee cd 02 6a		            CALL fLCD_Inst      ;Increment mode, shift off  
69f1			; Display module now initialised  
69f1 c9			            RET  
69f2			; ok to here  
69f2			  
69f2			; decide on setting bit for LED on or off  
69f2			; Set correct bit in A  
69f2 e5			IsLED: push hl  
69f3 21 ad fd			ld hl, hardware_word+1  
69f6 cb 56			bit 2, (hl)    ; led bit  
69f8 20 04			jr nz, .isled1  
69fa cb 8f			res kLCDBitLED, a  
69fc 18 02			jr .isleddone  
69fe cb cf		.isled1: set kLCDBitLED, a  
6a00			.isleddone:  	  
6a00 e1				pop hl  
6a01			  
6a01 c9				ret  
6a02			  
6a02			  
6a02			; Write instruction to LCD  
6a02			;   On entry: A = Instruction byte to be written  
6a02			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a02 f5			fLCD_Inst:  PUSH AF  
6a03 f5			            PUSH AF  
6a04 cd 16 6a		            CALL Wr4bits       ;Write bits 4 to 7 of instruction  
6a07 f1			            POP  AF  
6a08 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a09 17			            RLA  
6a0a 17			            RLA  
6a0b 17			            RLA  
6a0c cd 16 6a		            CALL Wr4bits       ;Write bits 0 to 3 of instruction  
6a0f 3e 02		            LD   A, 2  
6a11 cd 0c 6b		            CALL LCDDelay       ;Delay 2 ms to complete   
6a14 f1			            POP  AF  
6a15 c9			            RET  
6a16			Wr4bits:   
6a16 f5					push af  
6a17 3a fb fa				ld a, (display_lcde1e2)  
6a1a fe 00				cp 0     ; e  
6a1c 20 13				jr nz, .wea2	  
6a1e f1					pop af  
6a1f e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a21 cd f2 69				call IsLED  
6a24 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a26 cb df		            SET  kLCDBitE, A	    ; TODO decide which E is being set  
6a28 cb 87		            res  kLCDBitE2, A	    ; TODO decide which E is being set  
6a2a d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a2c cb 9f		            RES  kLCDBitE, A        ; TODO decide which E is being set  
6a2e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a30 c9			            RET  
6a31 f1			.wea2:		pop af  
6a32 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a34 cd f2 69				call IsLED  
6a37 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a39 cb c7		            SET  kLCDBitE2, A	    ; TODO decide which E is being set  
6a3b cb 9f		            res  kLCDBitE, A	    ; TODO decide which E is being set  
6a3d d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=Low  
6a3f cb 87		            RES  kLCDBitE2, A        ; TODO decide which E is being set  
6a41 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a43 c9			            RET  
6a44			  
6a44			  
6a44			; Write data to LCD  
6a44			;   On entry: A = Data byte to be written  
6a44			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a44 f5			fLCD_Data:  PUSH AF  
6a45 f5			            PUSH AF  
6a46 cd 58 6a		            CALL Wr4bitsa       ;Write bits 4 to 7 of data byte  
6a49 f1			            POP  AF  
6a4a 17			            RLA                 ;Rotate bits 0-3 into bits 4-7...  
6a4b 17			            RLA  
6a4c 17			            RLA  
6a4d 17			            RLA  
6a4e cd 58 6a		            CALL Wr4bitsa       ;Write bits 0 to 3 of data byte  
6a51 3e 96		            LD   A, 150  
6a53 3d			Wait:      DEC  A              ;Wait a while to allow data   
6a54 20 fd		            JR   NZ, Wait      ;  write to complete  
6a56 f1			            POP  AF  
6a57 c9			            RET  
6a58			Wr4bitsa:     
6a58 f5					push af  
6a59 3a fb fa				ld a, (display_lcde1e2)  
6a5c fe 00				cp 0     ; e1  
6a5e 20 19				jr nz, .we2	  
6a60 f1					pop af  
6a61 e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a63 cd f2 69				call IsLED  
6a66 cb d7		            SET  kLCDBitRS, A  
6a68 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a6a cb df		            SET  kLCDBitE, A      ; TODO Decide which E is being set  
6a6c cb 87		            res  kLCDBitE2, A      ; TODO Decide which E is being set  
6a6e d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a70 cb 9f		            RES  kLCDBitE, A       ; TODO Decide which E is being set  
6a72 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a74 cb 97		            RES  kLCDBitRS, A  
6a76 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a78 c9			            RET  
6a79 f1			.we2:		pop af  
6a7a e6 f0			    AND  0xF0           ;Mask so we only have D4 to D7  
6a7c cd f2 69				call IsLED  
6a7f cb d7		            SET  kLCDBitRS, A  
6a81 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a83 cb c7		            SET  kLCDBitE2, A      ; TODO Decide which E is being set  
6a85 cb 9f		            res  kLCDBitE, A      ; TODO Decide which E is being set  
6a87 d3 c0		            OUT  (kLCDPrt), A   ;Output with E=High and RS=High  
6a89 cb 87		            RES  kLCDBitE2, A       ; TODO Decide which E is being set  
6a8b d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=High  
6a8d cb 97		            RES  kLCDBitRS, A  
6a8f d3 c0		            OUT  (kLCDPrt), A   ;Output with E=Low and RS=Low  
6a91 c9			            RET  
6a92			  
6a92			  
6a92			; Position cursor to specified location  
6a92			;   On entry: A = Cursor position  
6a92			;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved  
6a92 f5			fLCD_Pos:   PUSH AF  
6a93					; at this point set the E1 or E2 flag depending on position  
6a93			  
6a93 c5					push bc  
6a94			;		push af  
6a94 06 00				ld b, 0  
6a96 4f					ld c, a  
6a97 3e 4f				ld a, kLCD_Line3-1  
6a99 b7			 		or a      ;clear carry flag  
6a9a 99					sbc a,c    ; TODO may need to sub 80 from a to put in context of current frame    
6a9b 38 04				jr c, .pe1  
6a9d			  
6a9d					; E selection  
6a9d cb 80				res 0, b         ; bit 0 unset e  
6a9f			;		pop af    ; before line 3 so recover orig pos  
6a9f			;		ld c, a    ; save for poking back  
6a9f 18 06				jr .peset	          
6aa1			.pe1:          	; E2 selection  
6aa1 cb c0				set 0, b         ; bit 0 set e1  
6aa3 79					ld a, c  
6aa4 de 4f				sbc a, kLCD_Line3-1  
6aa6 4f					ld c, a	         ; save caculated offset  
6aa7			;		pop af     ; bin this original value now we have calculated form  
6aa7			  
6aa7			.peset:		; set bit  
6aa7 78					ld a, b  
6aa8 32 fb fa				ld (display_lcde1e2), a 	  
6aab 79					ld a, c  
6aac c1					pop bc  
6aad			  
6aad f6 80		            OR   kLCD_Pos       ;Prepare position cursor instruction  
6aaf cd 02 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ab2 f1			            POP  AF  
6ab3 c9			            RET  
6ab4			  
6ab4			  
6ab4			; Output text string to LCD  
6ab4			;   On entry: DE = Pointer to null terminated text string  
6ab4			;   On exit:  BC HL IX IY I AF' BC' DE' HL' preserved  
6ab4 1a			fLCD_Str:   LD   A, (DE)        ;Get character from string  
6ab5 b7			            OR   A              ;Null terminator?  
6ab6 c8			            RET  Z              ;Yes, so finished  
6ab7 cd 44 6a		            CALL fLCD_Data      ;Write character to display  
6aba 13			            INC  DE             ;Point to next character  
6abb 18 f7		            JR   fLCD_Str       ;Repeat  
6abd c9					ret  
6abe			  
6abe			; Define custom character  
6abe			;   On entry: A = Character number (0 to 7)  
6abe			;             DE = Pointer to character bitmap data  
6abe			;   On exit:  A = Next character number  
6abe			;             DE = Next location following bitmap  
6abe			;             BC HL IX IY I AF' BC' DE' HL' preserved  
6abe			; Character is   
6abe c5			fLCD_Def:   PUSH BC  
6abf f5			            PUSH AF  
6ac0 07			            RLCA                ;Calculate location  
6ac1 07			            RLCA                ;  for bitmap data  
6ac2 07			            RLCA                ;  = 8 x CharacterNumber  
6ac3 f6 40		            OR   kLCD_Def       ;Prepare define character instruction  
6ac5 cd 02 6a		            CALL fLCD_Inst      ;Write instruction to LCD  
6ac8 06 00		            LD   B, 0  
6aca 1a			Loop:      LD   A, (DE)        ;Get byte from bitmap  
6acb cd 44 6a		            CALL fLCD_Data      ;Write byte to display  
6ace 13			            INC  DE             ;Point to next byte  
6acf 04			            INC  B              ;Count bytes  
6ad0 cb 58		            BIT  3, B           ;Finish all 8 bytes?  
6ad2 28 f6		            JR   Z, Loop       ;No, so repeat  
6ad4 f1			            POP  AF  
6ad5 3c			            INC  A              ;Increment character number  
6ad6 c1			            POP  BC  
6ad7 c9			            RET  
6ad8			  
