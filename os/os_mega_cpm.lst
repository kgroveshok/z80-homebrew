4495			.SPIO: 
4495			 
4495			if STORAGE_SE 
4495				CWHEAD .SPICEH 61 "SPICEL" 6 WORD_FLAG_CODE 
4495			; | SPICEL ( -- ) Set SPI CE low for the currently selected device |  DONE 
4495			 
4495					call spi_ce_low 
4495			    NEXTW 
4495			 
4495			.SPICEH: 
4495				CWHEAD .SPIBOb 61 "SPICEH" 6 WORD_FLAG_CODE 
4495			; | SPICEH ( -- ) Set SPI CE high for the currently selected device |  DONE 
4495			 
4495					call spi_ce_high 
4495			    NEXTW 
4495			 
4495			.SPIBOb: 
4495			 
4495				CWHEAD .SPII 61 "SPIO" 4 WORD_FLAG_CODE 
4495			; | SPIO ( u1 -- ) Send byte u1 to SPI  |  DONE 
4495			 
4495					if DEBUG_FORTH_WORDS_KEY 
4495						DMARK "SPo" 
4495						CALLMONITOR 
4495					endif 
4495					; get port 
4495			 
4495			 
4495					; get byte to send 
4495			 
4495					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4495			 
4495			;		push hl    ; u1  
4495			 
4495					; destroy value TOS 
4495			 
4495					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4495			 
4495					; one value on hl get other one back 
4495			 
4495			;		pop hl   ; u2 - addr 
4495			 
4495					; TODO Send SPI byte 
4495			 
4495			;		push hl 
4495			;		call spi_ce_low 
4495			;		pop hl 
4495					ld a, l 
4495					call spi_send_byte 
4495			;		call spi_ce_high 
4495			 
4495					NEXTW 
4495			 
4495			.SPII: 
4495				CWHEAD .SESEL 62 "SPII" 5 WORD_FLAG_CODE 
4495			; | SPII ( -- u1 ) Get a byte from SPI  | DONE 
4495					if DEBUG_FORTH_WORDS_KEY 
4495						DMARK "SPi" 
4495						CALLMONITOR 
4495					endif 
4495			 
4495					; TODO Get SPI byte 
4495			 
4495					call spi_read_byte 
4495			 
4495					if DEBUG_FORTH_WORDS 
4495						DMARK "Si2" 
4495						CALLMONITOR 
4495					endif 
4495					ld h, 0 
4495					ld l, a 
4495					if DEBUG_FORTH_WORDS 
4495						DMARK "Si3" 
4495						CALLMONITOR 
4495					endif 
4495					;call forth_push_numhl 
4495					FORTH_PUSH_VALUEHL 
4495			 
4495					NEXTW 
4495			 
4495			 
4495			 
4495			.SESEL: 
4495				CWHEAD .SESELS 82 "BANK?" 5 WORD_FLAG_CODE 
4495			; | BANK? ( -- u ) Reports on the serial EEPROM Bank Device at bank address u1 1-5.  | DONE 
4495			; | | Zero is disabled storage. 
4495					if DEBUG_FORTH_WORDS_KEY 
4495						DMARK "BN?" 
4495						CALLMONITOR 
4495					endif 
4495					ld a, (spi_device_id) 
4495					sub '0' 
4495					ld h, 0 
4495					ld l, a 
4495					FORTH_PUSH_VALUEHL 
4495					;call forth_push_numhl 
4495					NEXTW 
4495			.SESELS: 
4495				CWHEAD .CARTDEV 82 "BANK" 4 WORD_FLAG_CODE 
4495			; | BANK ( u1 -- ) Select Serial EEPROM Bank Device at bank address u1 1-5 (disables CARTDEV).  | DONE 
4495			; | | Set to zero to disable storage. 
4495					if DEBUG_FORTH_WORDS_KEY 
4495						DMARK "BNK" 
4495						CALLMONITOR 
4495					endif 
4495			 
4495					ld a, 255 
4495					ld (spi_cartdev), a 
4495			 
4495					; get bank 
4495			 
4495					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4495			 
4495			;		push hl 
4495			 
4495					; destroy value TOS 
4495			 
4495					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4495			 
4495					; one value on hl get other one back 
4495			 
4495			;		pop hl 
4495			 
4495			 
4495					ld c, SPI_CE_HIGH 
4495					ld b, '0'    ; human readable bank number 
4495			 
4495					ld a, l 
4495			 
4495					if DEBUG_FORTH_WORDS 
4495						DMARK "BNK" 
4495						CALLMONITOR 
4495					endif 
4495			 
4495					; active low 
4495			 
4495			;		cp 0 
4495					or a 
4495					jr z, .bset 
4495					cp 1 
4495					jr nz, .b2 
4495					res 0, c 
4495					ld b, '1'    ; human readable bank number 
4495			.b2:		cp 2 
4495					jr nz, .b3 
4495					res 1, c 
4495					ld b, '2'    ; human readable bank number 
4495			.b3:		cp 3 
4495					jr nz, .b4 
4495					res 2, c 
4495					ld b, '3'    ; human readable bank number 
4495			.b4:		cp 4 
4495					jr nz, .b5 
4495					res 3, c 
4495					ld b, '4'    ; human readable bank number 
4495			.b5:		cp 5 
4495					jr nz, .bset 
4495					res 4, c 
4495					ld b, '5'    ; human readable bank number 
4495			 
4495			.bset: 
4495					ld a, c 
4495					ld (spi_device),a 
4495					ld a, b 
4495					ld (spi_device_id),a 
4495					if DEBUG_FORTH_WORDS 
4495						DMARK "BN2" 
4495						CALLMONITOR 
4495					endif 
4495			 
4495					; set default SPI clk pulse time as disabled for BANK use 
4495			 
4495					ld a, 0 
4495					ld (spi_clktime), a 
4495			 
4495					NEXTW 
4495			 
4495			.CARTDEV: 
4495				CWHEAD .ENDDEVICE 82 "CARTDEV" 7 WORD_FLAG_CODE 
4495			; | CARTDEV ( u1 -- ) Select cart device 1-8 (Disables BANK). | DONE 
4495			; | | Set to zero to disable devices. 
4495					if DEBUG_FORTH_WORDS_KEY 
4495						DMARK "CDV" 
4495						CALLMONITOR 
4495					endif 
4495			 
4495					; disable se storage bank selection 
4495			 
4495					ld a, SPI_CE_HIGH		; ce high 
4495					ld (spi_device), a 
4495			 
4495					; get bank 
4495			 
4495					FORTH_DSP_VALUEHL     			; TODO skip type check and assume number.... lol 
4495			 
4495			;		push hl 
4495			 
4495					; destroy value TOS 
4495			 
4495					FORTH_DSP_POP  ; TODO add stock underflow checks and throws  
4495			 
4495					; one value on hl get other one back 
4495			 
4495			;		pop hl 
4495			 
4495					; active low 
4495			 
4495					ld c, 255 
4495			 
4495					ld a, l 
4495					if DEBUG_FORTH_WORDS 
4495						DMARK "CDV" 
4495						CALLMONITOR 
4495					endif 
4495			;		cp 0 
4495					or a 
4495					jr z, .cset 
4495					cp 1 
4495					jr nz, .c2 
4495					res 0, c 
4495			.c2:		cp 2 
4495					jr nz, .c3 
4495					res 1, c 
4495			.c3:		cp 3 
4495					jr nz, .c4 
4495					res 2, c 
4495			.c4:		cp 4 
4495					jr nz, .c5 
4495					res 3, c 
4495			.c5:		cp 5 
4495					jr nz, .c6 
4495					res 4, c 
4495			.c6:		cp 6 
4495					jr nz, .c7 
4495					res 5, c 
4495			.c7:		cp 7 
4495					jr nz, .c8 
4495					res 6, c 
4495			.c8:		cp 8 
4495					jr nz, .cset 
4495					res 7, c 
4495			.cset:		ld a, c 
4495					ld (spi_cartdev),a 
4495			 
4495					if DEBUG_FORTH_WORDS 
4495						DMARK "CD2" 
4495						CALLMONITOR 
4495					endif 
4495			 
4495					; set default SPI clk pulse time as 10ms for CARTDEV use 
4495			 
4495					ld a, $0a 
4495					ld (spi_clktime), a 
4495					NEXTW 
4495			endif 
