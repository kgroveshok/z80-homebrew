1104			if MALLOC_2 
1104			; Z80 Malloc and Free Functions 
1104			 
1104			; Malloc Function: 
1104			; Input: 
1104			;   HL: Size of block to allocate 
1104			; Output: 
1104			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1104			 
1104			malloc: 
1104				 
1104			if DEBUG_FORTH_MALLOC_HIGH 
1104			call malloc_guard_entry 
1104			endif 
1104			 
1104			 
1104			 
1104			 
1104					if DEBUG_FORTH_MALLOC 
1104						DMARK "mal" 
1104						CALLMONITOR 
1104					endif 
1104			    push af            ; Save AF register 
1104			    ld a, l            ; Load low byte of size into A 
1104			    or h               ; Check if size is zero 
1104			    jp z, malloc_exit  ; If size is zero, exit with NULL pointer 
1104			 
1104			    ; Allocate memory 
1104			    ld hl, (heap_start) ; Load start of heap into HL 
1104					if DEBUG_FORTH_MALLOC 
1104						DMARK "ma1" 
1104						CALLMONITOR 
1104					endif 
1104			    call malloc_internal ; Call internal malloc function 
1104			    pop af             ; Restore AF register 
1104			if DEBUG_FORTH_MALLOC_HIGH 
1104			call malloc_guard_exit 
1104			call malloc_guard_zerolen 
1104			endif 
1104			    ret                ; Return 
1104			 
1104			; Free Function: 
1104			; Input: 
1104			;   HL: Pointer to memory block to free 
1104			; Output: 
1104			;   None 
1104			 
1104			free: 
1104			    push af            ; Save AF register 
1104			    ld a, l            ; Load low byte of pointer into A 
1104			    or h               ; Check if pointer is NULL 
1104			    jp z, free_exit    ; If pointer is NULL, exit 
1104			 
1104			    ; Free memory 
1104			    ld hl, (heap_start) ; Load start of heap into HL 
1104			    call free_internal  ; Call internal free function 
1104			    pop af             ; Restore AF register 
1104			    ret                ; Return 
1104			 
1104			; Internal Malloc Function: 
1104			; Input: 
1104			;   HL: Size of block to allocate 
1104			; Output: 
1104			;   HL: Pointer to allocated memory block (NULL if allocation fails) 
1104			 
1104			malloc_internal: 
1104			    ld bc, 2           ; Number of bytes to allocate for management overhead 
1104			    add hl, bc         ; Add management overhead to requested size 
1104			    ex de, hl          ; Save total size in DE, and keep it in HL 
1104					if DEBUG_FORTH_MALLOC 
1104						DMARK "ma2" 
1104						CALLMONITOR 
1104					endif 
1104			 
1104			    ; Search for free memory block 
1104			    ld de, (heap_end)  ; Load end of heap into DE 
1104			    ld bc, 0           ; Initialize counter 
1104			 
1104					if DEBUG_FORTH_MALLOC 
1104						DMARK "ma2" 
1104						CALLMONITOR 
1104					endif 
1104			malloc_search_loop: 
1104			    ; Check if current block is free 
1104			    ld a, (hl)         ; Load current block's status (free or used) 
1104			;    cp 0               ; Compare with zero (free) 
1104				or a 
1104			    jr nz, malloc_skip_block_check  ; If not free, skip to the next block 
1104			 
1104			    ; Check if current block is large enough 
1104			    ld a, (hl+1)       ; Load high byte of block size 
1104			    cp l               ; Compare with low byte of requested size 
1104			    jr nz, malloc_skip_block_check  ; If not large enough, skip to the next block 
1104			 
1104			    ld a, (hl+2)       ; Load low byte of block size 
1104			    cp h               ; Compare with high byte of requested size 
1104			    jr c, malloc_skip_block_check   ; If not large enough, skip to the next block 
1104			 
1104			    ; Mark block as used 
1104			    ld (hl), 0xFF      ; Set status byte to indicate used block 
1104			 
1104			    ; Calculate remaining space in block 
1104			    ld bc, 0           ; Clear BC 
1104			    add hl, bc         ; Increment HL to point to start of data block 
1104			    add hl, de         ; HL = HL + DE (total size) 
1104			    ld bc, 1           ; Number of bytes to allocate for management overhead 
1104			    add hl, bc         ; Add management overhead to start of data block 
1104			 
1104			    ; Save pointer to allocated block in HL 
1104			if DEBUG_FORTH_MALLOC_HIGH 
1104						DMARK "ma5" 
1104			call malloc_guard_exit 
1104			call malloc_guard_zerolen 
1104			endif 
1104			    ret 
1104			 
1104			malloc_skip_block_check: 
1104			    ; Move to the next block 
1104			    ld bc, 3           ; Size of management overhead 
1104			    add hl, bc         ; Move to the next block 
1104			    inc de             ; Increment counter 
1104			 
1104			    ; Check if we have reached the end of heap 
1104			    ld a, e            ; Load low byte of heap end address 
1104			    cp (hl)            ; Compare with low byte of current address 
1104			    jr nz, malloc_search_loop  ; If not equal, continue searching 
1104			    ld a, d            ; Load high byte of heap end address 
1104			;    cp 0               ; Check if it's zero (end of memory) 
1104				or a 
1104			    jr nz, malloc_search_loop  ; If not zero, continue searching 
1104			 
1104			    ; If we reached here, allocation failed 
1104			    xor a              ; Set result to NULL 
1104			if DEBUG_FORTH_MALLOC_HIGH 
1104						DMARK "ma6" 
1104			call malloc_guard_exit 
1104			call malloc_guard_zerolen 
1104			endif 
1104			    ret 
1104			malloc_exit: 
1104			if DEBUG_FORTH_MALLOC_HIGH 
1104						DMARK "ma7" 
1104			call malloc_guard_exit 
1104			call malloc_guard_zerolen 
1104			endif 
1104			    ret 
1104			 
1104			; Internal Free Function: 
1104			; Input: 
1104			;   HL: Pointer to memory block to free 
1104			; Output: 
1104			;   None 
1104			 
1104			free_internal: 
1104			    ld de, (heap_start) ; Load start of heap into DE 
1104			    ld bc, 0            ; Initialize counter 
1104			 
1104			free_search_loop: 
1104			    ; Check if current block contains the pointer 
1104			    ld a, l             ; Load low byte of pointer 
1104			    cp (hl+1)           ; Compare with high byte of current block's address 
1104			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1104			    ld a, h             ; Load high byte of pointer 
1104			    cp (hl+2)           ; Compare with low byte of current block's address 
1104			    jr nz, free_skip_block_check  ; If not equal, skip to the next block 
1104			 
1104			    ; Mark block as free 
1104			    ld (hl), 0          ; Set status byte to indicate free block 
1104			    ret                 ; Return 
1104			 
1104			free_skip_block_check: 
1104			    ; Move to the next block 
1104			    ld bc, 3            ; Size of management overhead 
1104			    add hl, bc          ; Move to the next block 
1104			    inc de              ; Increment counter 
1104			 
1104			    ; Check if we have reached the end of heap 
1104			    ld a, e             ; Load low byte of heap end address 
1104			    cp (hl)             ; Compare with low byte of current address 
1104			    jr nz, free_search_loop  ; If not equal, continue searching 
1104			    ld a, d             ; Load high byte of heap end address 
1104			;    cp 0                ; Check if it's zero (end of memory) 
1104				or a 
1104			    jr nz, free_search_loop  ; If not zero, continue searching 
1104			 
1104			    ; If we reached here, pointer is not found in heap 
1104			    ret 
1104			 
1104			free_exit: 
1104			    ret                 ; Return 
1104			 
1104			; Define heap start and end addresses 
1104			;heap_start:    .dw 0xC000   ; Start of heap 
1104			;heap_end:      .dw 0xE000   ; End of heap 
1104			 
1104			endif 
