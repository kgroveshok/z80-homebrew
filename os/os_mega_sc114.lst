8b4b			include "firmware_maths.asm"     ; any odd maths stuff   TODO removed until I fix up the rng code  
8b4b			; random number generators 
8b4b			 
8b4b			 
8b4b			; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random 
8b4b			 
8b4b			 
8b4b			;-----> Generate a random number 
8b4b			; output a=answer 0<=a<=255 
8b4b			; all registers are preserved except: af 
8b4b			random: 
8b4b e5			        push    hl 
8b4c d5			        push    de 
8b4d 2a 9e eb		        ld      hl,(randData) 
8b50 ed 5f		        ld      a,r 
8b52 57			        ld      d,a 
8b53 5e			        ld      e,(hl) 
8b54 19			        add     hl,de 
8b55 85			        add     a,l 
8b56 ac			        xor     h 
8b57 22 9e eb		        ld      (randData),hl 
8b5a d1			        pop     de 
8b5b e1			        pop     hl 
8b5c c9			        ret 
8b5d			 
8b5d			 
8b5d			; randData here must be a 2 byte seed located in ram. While this is a fast generator, it's generally not considered very good in terms of randomness. 
8b5d			 
8b5d			 
8b5d			 
8b5d			;------LFSR------ 
8b5d			;James Montelongo 
8b5d			;optimized by Spencer Putt 
8b5d			;out: 
8b5d			; a = 8 bit random number 
8b5d			RandLFSR: 
8b5d 21 a4 eb		        ld hl,LFSRSeed+4 
8b60 5e			        ld e,(hl) 
8b61 23			        inc hl 
8b62 56			        ld d,(hl) 
8b63 23			        inc hl 
8b64 4e			        ld c,(hl) 
8b65 23			        inc hl 
8b66 7e			        ld a,(hl) 
8b67 47			        ld b,a 
8b68 cb 13		        rl e  
8b6a cb 12			rl d 
8b6c cb 11		        rl c  
8b6e 17				rla 
8b6f cb 13		        rl e  
8b71 cb 12			rl d 
8b73 cb 11		        rl c  
8b75 17				rla 
8b76 cb 13		        rl e  
8b78 cb 12			rl d 
8b7a cb 11		        rl c  
8b7c 17				rla 
8b7d 67			        ld h,a 
8b7e cb 13		        rl e  
8b80 cb 12			rl d 
8b82 cb 11		        rl c  
8b84 17				rla 
8b85 a8			        xor b 
8b86 cb 13		        rl e  
8b88 cb 12			rl d 
8b8a ac			        xor h 
8b8b a9			        xor c 
8b8c aa			        xor d 
8b8d 21 a6 eb		        ld hl,LFSRSeed+6 
8b90 11 a7 eb		        ld de,LFSRSeed+7 
8b93 01 07 00		        ld bc,7 
8b96 ed b8		        lddr 
8b98 12			        ld (de),a 
8b99 c9			        ret 
8b9a			 
8b9a			;While this may produces better numbers, it is slower, larger and requires a bigger seed than ionrandom. Assuming theres is a good seed to start, it should generate ~2^56 bytes before repeating. However if there is not a good seed(0 for example), then the numbers created will not be adequate. Unlike Ionrandom and its use of the r register, starting with the same seed the same numbers will be generated. With Ionrandom the code running may have an impact on the number generated. This means this method requires more initialization. 
8b9a			 
8b9a			;You can initialize with TI-OS's seeds, stored at seed1 and seed2, both are ti-floats but will serve the purpose.  
8b9a			 
8b9a			 
8b9a			;This is a very fast, quality pseudo-random number generator. It combines a 16-bit Linear Feedback Shift Register and a 16-bit LCG. 
8b9a			 
8b9a			prng16: 
8b9a			;Inputs: 
8b9a			;   (seed1) contains a 16-bit seed value 
8b9a			;   (seed2) contains a NON-ZERO 16-bit seed value 
8b9a			;Outputs: 
8b9a			;   HL is the result 
8b9a			;   BC is the result of the LCG, so not that great of quality 
8b9a			;   DE is preserved 
8b9a			;Destroys: 
8b9a			;   AF 
8b9a			;cycle: 4,294,901,760 (almost 4.3 billion) 
8b9a			;160cc 
8b9a			;26 bytes 
8b9a 2a 98 eb		    ld hl,(seed1) 
8b9d 44			    ld b,h 
8b9e 4d			    ld c,l 
8b9f 29			    add hl,hl 
8ba0 29			    add hl,hl 
8ba1 2c			    inc l 
8ba2 09			    add hl,bc 
8ba3 22 98 eb		    ld (seed1),hl 
8ba6 2a 96 eb		    ld hl,(seed2) 
8ba9 29			    add hl,hl 
8baa 9f			    sbc a,a 
8bab e6 2d		    and %00101101 
8bad ad			    xor l 
8bae 6f			    ld l,a 
8baf 22 96 eb		    ld (seed2),hl 
8bb2 09			    add hl,bc 
8bb3 c9			    ret 
8bb4			 
8bb4			;On their own, LCGs and LFSRs don't produce great results and are generally very cyclical, but they are very fast to compute. The 16-bit LCG in the above example will bounce around and reach each number from 0 to 65535, but the lower bits are far more predictable than the upper bits. The LFSR mixes up the predictability of a given bit's state, but it hits every number except 0, meaning there is a slightly higher chance of any given bit in the result being a 1 instead of a 0. It turns out that by adding together the outputs of these two generators, we can lose the predictability of a bit's state, while ensuring it has a 50% chance of being 0 or 1. As well, since the periods, 65536 and 65535 are coprime, then the overall period of the generator is 65535*65536, which is over 4 billion.  
8bb4			 
8bb4			rand32: 
8bb4			;Inputs: 
8bb4			;   (seed1_0) holds the lower 16 bits of the first seed 
8bb4			;   (seed1_1) holds the upper 16 bits of the first seed 
8bb4			;   (seed2_0) holds the lower 16 bits of the second seed 
8bb4			;   (seed2_1) holds the upper 16 bits of the second seed 
8bb4			;   **NOTE: seed2 must be non-zero 
8bb4			;Outputs: 
8bb4			;   HL is the result 
8bb4			;   BC,DE can be used as lower quality values, but are not independent of HL. 
8bb4			;Destroys: 
8bb4			;   AF 
8bb4			;Tested and passes all CAcert tests 
8bb4			;Uses a very simple 32-bit LCG and 32-bit LFSR 
8bb4			;it has a period of 18,446,744,069,414,584,320 
8bb4			;roughly 18.4 quintillion. 
8bb4			;LFSR taps: 0,2,6,7  = 11000101 
8bb4			;291cc 
8bb4			;seed1_0=$+1 
8bb4			;    ld hl,12345 
8bb4			;seed1_1=$+1 
8bb4			;    ld de,6789 
8bb4			;    ld b,h 
8bb4			;    ld c,l 
8bb4			;    add hl,hl \ rl e \ rl d 
8bb4			;    add hl,hl \ rl e \ rl d 
8bb4			;    inc l 
8bb4			;    add hl,bc 
8bb4			;    ld (seed1_0),hl 
8bb4			;    ld hl,(seed1_1) 
8bb4			;    adc hl,de 
8bb4			;    ld (seed1_1),hl 
8bb4			;    ex de,hl 
8bb4			;seed2_0=$+1 
8bb4			;    ld hl,9876 
8bb4			;seed2_1=$+1 
8bb4			;    ld bc,54321 
8bb4			;    add hl,hl \ rl c \ rl b 
8bb4			;    ld (seed2_1),bc 
8bb4			;    sbc a,a 
8bb4			;    and %11000101 
8bb4			;    xor l 
8bb4			;    ld l,a 
8bb4			;    ld (seed2_0),hl 
8bb4			;    ex de,hl 
8bb4			;    add hl,bc 
8bb4			;    ret 
8bb4			; 
8bb4			 
8bb4			; 16-bit xorshift pseudorandom number generator by John Metcalf 
8bb4			; 20 bytes, 86 cycles (excluding ret) 
8bb4			 
8bb4			; returns   hl = pseudorandom number 
8bb4			; corrupts   a 
8bb4			 
8bb4			; generates 16-bit pseudorandom numbers with a period of 65535 
8bb4			; using the xorshift method: 
8bb4			 
8bb4			; hl ^= hl << 7 
8bb4			; hl ^= hl >> 9 
8bb4			; hl ^= hl << 8 
8bb4			 
8bb4			; some alternative shift triplets which also perform well are: 
8bb4			; 6, 7, 13; 7, 9, 13; 9, 7, 13. 
8bb4			 
8bb4			;  org 32768 
8bb4			 
8bb4			xrnd: 
8bb4 2a 9c eb		  ld hl,(xrandc)       ; seed must not be 0 
8bb7 3e 00		  ld a,0 
8bb9 bd			  cp l 
8bba 20 02		  jr nz, .xrnd1 
8bbc 2e 01		  ld l, 1 
8bbe			.xrnd1: 
8bbe			 
8bbe 7c			  ld a,h 
8bbf 1f			  rra 
8bc0 7d			  ld a,l 
8bc1 1f			  rra 
8bc2 ac			  xor h 
8bc3 67			  ld h,a 
8bc4 7d			  ld a,l 
8bc5 1f			  rra 
8bc6 7c			  ld a,h 
8bc7 1f			  rra 
8bc8 ad			  xor l 
8bc9 6f			  ld l,a 
8bca ac			  xor h 
8bcb 67			  ld h,a 
8bcc			 
8bcc 22 9c eb		  ld (xrandc),hl 
8bcf			 
8bcf c9			  ret 
