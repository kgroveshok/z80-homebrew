9227			config_fdir: 
9227				; using the scratch dir go through and release the memory allocated for each string 
9227				 
9227				ld hl, scratch 
9227			.cfdir:	ld e,(hl) 
9227				inc hl 
9227				ld d,(hl) 
9227				inc hl 
9227			 
9227				ex de, hl 
9227				call ishlzero 
9227				ret z     ; return on null pointer 
9227				call free 
9227				ex de, hl 
9227				jr .cfdir 
9227			 
9227			 
9227				ret 
9227			 
9227			 
9227			config_dir: 
9227			 
9227				; for the config menus that need to build a directory of storage call this routine 
9227				; it will construct a menu in scratch to pass to menu 
9227			 
9227				; open storage device 
9227			 
9227				; execute DIR to build a list of files and their ids into scratch in menu format 
9227				; once the menu has finished then will need to call config_fdir to release the strings 
9227				 
9227				; c = number items 
9227			 
9227				 
9227				call storage_get_block_0 
9227			 
9227				ld hl, store_page     ; get current id count 
9227				ld b, (hl) 
9227				ld c, 0    ; count of files   
9227			 
9227			 
9227				ld hl, scratch 
9227				ld (store_tmp2), hl    ; location to poke strings 
9227			 
9227				; check for empty drive 
9227			 
9227				ld a, 0 
9227				cp b 
9227				jp z, .dirdone 
9227			 
9227				 
9227					if DEBUG_FORTH_WORDS 
9227						DMARK "Cdc" 
9227						CALLMONITOR 
9227					endif 
9227			 
9227			 
9227			.diritem:	 
9227				push bc 
9227				; for each of the current ids do a search for them and if found push to stack 
9227			 
9227					ld hl, STORE_BLOCK_PHY 
9227					ld d, 0		 ; look for extent 0 of block id as this contains file name 
9227					ld e,b 
9227			 
9227					call storage_findnextid 
9227			 
9227			 
9227					; if found hl will be non zero 
9227			 
9227					call ishlzero 
9227					jr z, .dirnotfound 
9227			 
9227					; increase count 
9227			 
9227					pop bc	 
9227					inc c 
9227					push bc 
9227					 
9227			 
9227					; get file header and push the file name 
9227			 
9227					ld de, store_page 
9227					call storage_read_block 
9227			 
9227					; push file id to stack 
9227				 
9227					ld a, (store_page) 
9227					ld h, 0 
9227					ld l, a 
9227			 
9227					;call forth_push_numhl 
9227					; TODO store id 
9227			 
9227					push hl 
9227			 
9227					; push extent count to stack  
9227				 
9227					ld hl, store_page+3 
9227			 
9227					; get file name length 
9227			 
9227					call strlenz   
9227			 
9227					inc hl   ; cover zero term 
9227					inc hl  ; stick the id at the end of the area 
9227			 
9227					push hl 
9227					pop bc    ; move length to bc 
9227			 
9227					call malloc 
9227			 
9227					; TODO save malloc area to scratch 
9227			 
9227					ex de, hl 
9227					ld hl, (store_tmp2) 
9227					ld (hl), e 
9227					inc hl 
9227					ld (hl), d 
9227					inc hl 
9227					ld (store_tmp2), hl 
9227			 
9227					 
9227			 
9227					;pop hl   ; get source 
9227			;		ex de, hl    ; swap aronund	 
9227			 
9227					ld hl, store_page+3 
9227					if DEBUG_FORTH_WORDS 
9227						DMARK "CFd" 
9227						CALLMONITOR 
9227					endif 
9227					ldir 
9227			 
9227					; de is past string, move back one and store id 
9227					 
9227					dec de 
9227			 
9227					; store file id 
9227			 
9227					pop hl 
9227					ex de,hl 
9227					ld (hl), e 
9227			 
9227					if DEBUG_FORTH_WORDS 
9227						DMARK "Cdi" 
9227						CALLMONITOR 
9227					endif 
9227					 
9227			.dirnotfound: 
9227					pop bc     
9227					djnz .diritem 
9227				 
9227			.dirdone:	 
9227			 
9227			;		ld a, 0 
9227					ld hl, (store_tmp2) 
9227					ld (hl), 0 
9227					inc hl 
9227					ld (hl), 0 
9227					inc hl 
9227					; push a count of the dir items found 
9227			 
9227			;		ld h, 0 
9227			;		ld l, c 
9227			 
9227				ret 
9227			 
9227			endif 
